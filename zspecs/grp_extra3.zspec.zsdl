spec: grp_extra3
version: ">=3.9"
backend: python_module(grp)

docs: https://docs.python.org/3/library/grp.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/grp.html — Python grp documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/grpmodule.c"
  notes:
    - "This spec extends grp.zspec.zsdl and prior extras."
    - "grp.zspec.zsdl covers: function __name__ and is_builtin, struct_group __name__/__module__/is_type, n_sequence_fields==4, n_fields==4, getgrall returns list."
    - "grp_extra.zspec.zsdl covers: function __name__, is_builtin, struct_group name/module/type, n_sequence_fields, __match_args__ is tuple/len/contains, function __qualname__."
    - "grp_extra2.zspec.zsdl covers: __match_args__ positional indices [0..3], n_unnamed_fields==0, function __qualname__ table, getgrall()[0] is struct_group, struct_group.__bases__[0] is tuple."
    - "New here: grp module __name__, struct_group.__qualname__, function __doc__ type checks, struct_group.__bases__.__len__==1, struct_group MRO checks."
    - "grp is a POSIX-only Unix module; not available on Windows."
    - "struct_group.__qualname__ == 'struct_group' — not scoped to any class or function."
    - "struct_group.__bases__ has exactly one entry (tuple) — single inheritance."
    - "struct_group.__mro__[1].__name__ == 'tuple' — via MRO, position 1 is tuple."
    - "struct_group.__mro__[2].__name__ == 'object' — position 2 is object (root of MRO)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module __name__ — not covered in any prior spec
# ---------------------------------------------------------------------------

invariant grp_extra3.module.name:
  description: "grp.__name__ == 'grp' — the module's own __name__ attribute"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["grp"]
  expected: true

# ---------------------------------------------------------------------------
# struct_group.__qualname__ — not covered in any prior spec
# grp.zspec.zsdl and grp_extra cover __name__ and __module__ but not __qualname__.
# ---------------------------------------------------------------------------

invariant grp_extra3.struct_group.qualname:
  description: "grp.struct_group.__qualname__ == 'struct_group' — top-level class, not nested"
  category: class_identity
  kind: python_call_eq
  function: struct_group.__qualname__.__eq__
  args: ["struct_group"]
  expected: true

# ---------------------------------------------------------------------------
# Function __doc__ type checks — not covered in any prior spec
# All three C-level grp functions have non-None docstrings (type == 'str').
# ---------------------------------------------------------------------------

table grp_extra3.function_docs:
  kind: python_call_eq
  category: function_docs
  id_prefix: fdoc

  columns: [id, function, args, expected]
  rows:
    - [getgrall, getgrall.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [getgrgid, getgrgid.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [getgrnam, getgrnam.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# struct_group.__bases__.__len__ == 1 — single inheritance (not in any prior spec)
# grp_extra2 checks __bases__[0].__name__=='tuple' but not the bases count.
# ---------------------------------------------------------------------------

invariant grp_extra3.struct_group.bases_len:
  description: "len(grp.struct_group.__bases__) == 1 — struct_group has exactly one base class"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_group.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# struct_group.__mro__ — method resolution order (not in any prior spec)
# struct_group inherits from tuple which inherits from object.
# MRO: [struct_group, tuple, object] — length 3.
# ---------------------------------------------------------------------------

invariant grp_extra3.struct_group.mro_len:
  description: "len(grp.struct_group.__mro__) == 3 — MRO is [struct_group, tuple, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_group.__mro__.__len__
  args: []
  expected: 3

invariant grp_extra3.struct_group.mro_1_is_tuple:
  description: "grp.struct_group.__mro__[1].__name__ == 'tuple' — MRO position 1 is tuple"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_group.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "tuple"

invariant grp_extra3.struct_group.mro_2_is_object:
  description: "grp.struct_group.__mro__[2].__name__ == 'object' — MRO position 2 is object"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_group.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "object"
