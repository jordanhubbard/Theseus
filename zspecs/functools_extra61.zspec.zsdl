spec: functools_extra61
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra60.zspec.zsdl."
    - "No prior functools spec records __repr__.__class__.__name__ or __hash__.__class__.__name__ for partial or _lru_cache_wrapper at the class level."
    - "No prior functools spec records WRAPPER_ASSIGNMENTS.__len__() or WRAPPER_UPDATES.__len__()."
    - "This spec covers: functools.partial.__repr__.__class__.__name__.__eq__('wrapper_descriptor')==true; functools.partial.__hash__.__class__.__name__.__eq__('wrapper_descriptor')==true; functools._lru_cache_wrapper.__repr__.__class__.__name__.__eq__('wrapper_descriptor')==true; functools._lru_cache_wrapper.__hash__.__class__.__name__.__eq__('wrapper_descriptor')==true; functools.WRAPPER_ASSIGNMENTS.__len__()==6; functools.WRAPPER_UPDATES.__len__()==1."
    - "Key findings: functools.partial is a C-extension type defined in Modules/_functoolsmodule.c. Its class-level __repr__ and __hash__ are inherited slot wrappers of type 'wrapper_descriptor' — this is the class-level descriptor for a C slot method. At the instance level these become 'method-wrapper' objects, but the spec tests the class-level descriptor. functools._lru_cache_wrapper is similarly a C-extension type; its class-level __repr__ and __hash__ are also 'wrapper_descriptor'. WRAPPER_ASSIGNMENTS is a 6-element tuple in Python 3.14 (added __annotate__ and __type_params__ relative to older versions). WRAPPER_UPDATES is a 1-element tuple containing '__dict__'. All six invariants are new to extra61."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools C-type class-level __repr__/__hash__ are wrapper_descriptor — extra61
#
# functools.partial is a C-extension type in Modules/_functoolsmodule.c.
# When __repr__ or __hash__ is accessed on the class object (not an instance),
# Python returns a 'wrapper_descriptor' — the raw C-level slot method descriptor
# stored in the type object's tp_repr and tp_hash slots respectively.
# At the instance level these become 'method-wrapper' objects bound to the
# instance. The class-level descriptor is always 'wrapper_descriptor'.
#
# functools._lru_cache_wrapper is also a C-extension type; it behaves the same
# way: class-level __repr__ and __hash__ are both 'wrapper_descriptor'.
#
# This is distinct from pure-Python classes (like inspect.Parameter), whose
# __repr__ at the class level is a 'function' object defined in Python code.
#
# No prior functools spec records __repr__.__class__.__name__ or
# __hash__.__class__.__name__ at the class level for any functools object.
# All four checks below are new to extra61.
# ---------------------------------------------------------------------------

table functools_extra61.c_type_repr_hash_descriptor:
  description: "functools C-extension type class-level __repr__/__hash__ are wrapper_descriptor — partial and _lru_cache_wrapper are C types; class-level slot methods are wrapper_descriptor; not recorded in any prior functools spec; new to extra61"
  kind: python_call_eq
  category: class_identity
  id_prefix: functoolsrep61

  columns: [id, function, args, expected, description]
  rows:
    - [partial_repr_class_name,
       partial.__repr__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "functools.partial.__repr__.__class__.__name__ == 'wrapper_descriptor' — partial is a C-extension type in Modules/_functoolsmodule.c; accessed at the class level (not on an instance), __repr__ is the raw C-slot method descriptor stored in tp_repr; Python exposes this as a 'wrapper_descriptor' object; at the instance level this becomes a 'method-wrapper'; the class-level form is always 'wrapper_descriptor'; no prior functools spec records __repr__.__class__.__name__ for partial; new to extra61"]
    - [partial_hash_class_name,
       partial.__hash__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "functools.partial.__hash__.__class__.__name__ == 'wrapper_descriptor' — partial is a C-extension type; its class-level __hash__ is the tp_hash slot descriptor inherited from object (partial does not define its own __hash__; it inherits the default identity-based hash from object); the descriptor type for a C-level slot method accessed on the class is 'wrapper_descriptor'; no prior functools spec records __hash__.__class__.__name__ for partial; new to extra61"]
    - [lru_cache_wrapper_repr_class_name,
       "_lru_cache_wrapper.__repr__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools._lru_cache_wrapper.__repr__.__class__.__name__ == 'wrapper_descriptor' — _lru_cache_wrapper is the internal C-extension type used to wrap functions decorated with @lru_cache; defined in Modules/_functoolsmodule.c; its class-level __repr__ is the tp_repr slot descriptor, exposed as a 'wrapper_descriptor'; no prior functools spec records __repr__.__class__.__name__ for _lru_cache_wrapper; new to extra61"]
    - [lru_cache_wrapper_hash_class_name,
       "_lru_cache_wrapper.__hash__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "functools._lru_cache_wrapper.__hash__.__class__.__name__ == 'wrapper_descriptor' — _lru_cache_wrapper is the internal C-extension type for lru_cache-decorated functions; its class-level __hash__ is the tp_hash slot descriptor inherited from object, exposed as a 'wrapper_descriptor'; contrasts with instance level where it becomes 'method-wrapper'; no prior functools spec records __hash__.__class__.__name__ for _lru_cache_wrapper; new to extra61"]

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES __len__() — extra61
#
# functools.WRAPPER_ASSIGNMENTS is a tuple of function attribute names that
# update_wrapper copies from the wrapped function to the wrapper function.
# In Python 3.14, it contains 6 elements: '__module__', '__name__',
# '__qualname__', '__doc__', '__annotate__', '__type_params__'.
# (Earlier Python versions had 5 elements; '__annotate__' and '__type_params__'
# were added for PEP 695/PEP 696 type parameter support.)
#
# functools.WRAPPER_UPDATES is a tuple of attribute names updated (not replaced)
# by update_wrapper. It contains 1 element: '__dict__'.
#
# Prior extra60 established that both are tuple objects (__class__.__name__ ==
# 'tuple') but did not record their __len__(). All two checks below are new to extra61.
# ---------------------------------------------------------------------------

table functools_extra61.wrapper_constants_len:
  description: "WRAPPER_ASSIGNMENTS.__len__()==6 and WRAPPER_UPDATES.__len__()==1 — module-level tuple constants; WRAPPER_ASSIGNMENTS has 6 elements in Python 3.14 (added __annotate__ and __type_params__); WRAPPER_UPDATES has 1 element (__dict__); prior extra60 confirmed tuple type but not length; new to extra61"
  kind: python_call_eq
  category: length
  id_prefix: functoolsrep61

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_ASSIGNMENTS_len,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS is a 6-element tuple in Python 3.14: ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'); '__annotate__' and '__type_params__' were added for PEP 695/696 type parameter support; prior extra60 confirmed __class__.__name__=='tuple' but not length; this is the first __len__ check for WRAPPER_ASSIGNMENTS; new to extra61"]
    - [WRAPPER_UPDATES_len,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is a 1-element tuple: ('__dict__',); update_wrapper merges (rather than replaces) the __dict__ attribute from wrapped to wrapper to preserve any existing wrapper-function attributes; prior extra60 confirmed __class__.__name__=='tuple' but not length; this is the first __len__ check for WRAPPER_UPDATES; new to extra61"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra61
# ---------------------------------------------------------------------------

invariant functools_extra61.partial_repr_is_wrapper_descriptor:
  description: "partial.__repr__.__class__.__name__ == 'wrapper_descriptor' — C-extension type class-level slot methods are wrapper_descriptor; contrasts with pure-Python class __repr__ which is 'function'; new to extra61"
  kind: python_call_eq
  function: partial.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant functools_extra61.partial_hash_is_wrapper_descriptor:
  description: "partial.__hash__.__class__.__name__ == 'wrapper_descriptor' — partial is hashable (inherits hash from object) and the class-level hash descriptor is a wrapper_descriptor; new to extra61"
  kind: python_call_eq
  function: partial.__hash__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant functools_extra61.WRAPPER_ASSIGNMENTS_has_six_elements:
  description: "WRAPPER_ASSIGNMENTS.__len__() == 6 — Python 3.14 added __annotate__ and __type_params__ to the standard set of copied attributes; prior extra60 confirmed tuple type but not count; new to extra61"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra61.WRAPPER_UPDATES_has_one_element:
  description: "WRAPPER_UPDATES.__len__() == 1 — only '__dict__' is in WRAPPER_UPDATES; update_wrapper merges the __dict__ rather than replacing it; new to extra61"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1
