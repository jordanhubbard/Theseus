spec: logging_extra19
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "https://docs.python.org/3/library/logging.handlers.html — logging.handlers module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "CPython source: Lib/logging/handlers.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra18.zspec.zsdl."
    - "logging_extra4 covers: Manager/__name__ and PlaceHolder/__name__ as standalone invariants."
    - "logging_extra8 covers: Manager/__module__ and PlaceHolder/__module__; Manager/__qualname__ and PlaceHolder/__qualname__ via table."
    - "logging_extra10 covers: StreamHandler/__name__, FileHandler/__name__, NullHandler/__name__, LogRecord/__name__, Filter/__name__ as standalone invariants."
    - "logging_extra14 covers: Filter/__qualname__ and LogRecord/__qualname__ as standalone invariants."
    - "logging_extra18 covers: Logger/__class__.__name__, Handler/__class__.__name__, Formatter/__class__.__name__ == 'type'."
    - "NOT yet covered in any prior spec: Manager/__class__.__name__, PlaceHolder/__class__.__name__, LogRecord/__class__.__name__, Filter/__class__.__name__ == 'type'."
    - "NOT yet covered in any prior spec: RotatingFileHandler (from logging.handlers) in any form."
    - "logging.handlers.RotatingFileHandler.__module__ == 'logging.handlers' (not 'logging')."
    - "logging.handlers.RotatingFileHandler.mro() == [RotatingFileHandler, BaseRotatingHandler, FileHandler, StreamHandler, Handler, Filterer, object] (7 entries)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Manager, PlaceHolder, LogRecord, Filter — __class__.__name__ == 'type'
#
# logging_extra18 covers Logger/Handler/Formatter __class__.__name__ == 'type'.
# No prior spec records this for Manager, PlaceHolder, LogRecord, or Filter.
# All four are plain Python classes whose metaclass is the builtin 'type'.
# ---------------------------------------------------------------------------

invariant logging_extra19.Manager.class_name:
  description: "logging.Manager.__class__.__name__ == 'type'"
  category: class_identity
  kind: python_call_eq
  function: Manager.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant logging_extra19.PlaceHolder.class_name:
  description: "logging.PlaceHolder.__class__.__name__ == 'type'"
  category: class_identity
  kind: python_call_eq
  function: PlaceHolder.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant logging_extra19.LogRecord.class_name:
  description: "logging.LogRecord.__class__.__name__ == 'type'"
  category: class_identity
  kind: python_call_eq
  function: LogRecord.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant logging_extra19.Filter.class_name:
  description: "logging.Filter.__class__.__name__ == 'type'"
  category: class_identity
  kind: python_call_eq
  function: Filter.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# logging.handlers.RotatingFileHandler — identity attributes
#
# RotatingFileHandler lives in logging.handlers, not in the top-level logging
# namespace. No prior spec in this corpus covers RotatingFileHandler at all.
# __name__ == 'RotatingFileHandler', __qualname__ == 'RotatingFileHandler',
# __module__ == 'logging.handlers', __class__.__name__ == 'type'.
# MRO has 7 entries: RotatingFileHandler, BaseRotatingHandler, FileHandler,
# StreamHandler, Handler, Filterer, object.
# ---------------------------------------------------------------------------

table logging_extra19.RotatingFileHandler_identity:
  description: "Identity attributes for logging.handlers.RotatingFileHandler"
  kind: python_call_eq
  category: class_identity
  backend: python_module(logging.handlers)

  columns: [id, function, args, expected]
  rows:
    - [name,       RotatingFileHandler.__name__.__eq__,            ["RotatingFileHandler"],  true]
    - [qualname,   RotatingFileHandler.__qualname__.__eq__,        ["RotatingFileHandler"],  true]
    - [module,     RotatingFileHandler.__module__.__eq__,          ["logging.handlers"],     true]
    - [class_name, RotatingFileHandler.__class__.__name__.__eq__,  ["type"],                 true]

invariant logging_extra19.RotatingFileHandler.mro_len:
  description: "logging.handlers.RotatingFileHandler.mro() has 7 entries"
  category: mro
  kind: python_call_eq
  backend: python_module(logging.handlers)
  function: RotatingFileHandler.mro
  args: []
  method: __len__
  expected: 7
