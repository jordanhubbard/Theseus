spec: struct_extra2446
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "struct_extra.zspec.zsdl and other pre-existing struct_extra files"
  notes:
    - "Theme: __enter__/__exit__ context manager protocol dict-presence for struct.Struct."
    - "struct.Struct does NOT define __enter__ or __exit__ in its own __dict__; Struct instances cannot be used as context managers."
    - "struct.Struct is a C extension type that defines the binary packing/unpacking API directly: pack, unpack, pack_into, unpack_from, iter_unpack, size, format."
    - "struct.Struct.__dict__ also contains attribute access overrides (__getattribute__, __setattr__, __delattr__) and __new__, __repr__, __sizeof__ as own C-level methods."
    - "struct.Struct has no __iter__ or __next__ — it is not iterable by itself; iter_unpack returns a separate iterator object."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: struct.Struct — context manager protocol absent
#
# struct.Struct is a C extension type for compiled binary format strings. It
# exposes a packing/unpacking API but does NOT define __enter__ or __exit__ in
# its class __dict__. Struct instances are not context managers. There is also
# no iteration protocol (__iter__, __next__) in the class dict — iter_unpack
# returns a separate iterator and is not on the Struct class itself.
# ---------------------------------------------------------------------------

table struct_extra2446.struct_ctx_protocol_absent:
  description: "struct.Struct.__dict__: __enter__ and __exit__ absent — Struct is not a context manager; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2446

  columns: [id, function, args, expected]
  rows:
    - ["st2446-001", "struct.Struct.__dict__.__contains__", ["__enter__"], false]
    - ["st2446-002", "struct.Struct.__dict__.__contains__", ["__exit__"], false]
    - ["st2446-003", "struct.Struct.__dict__.__contains__", ["__iter__"], false]
    - ["st2446-004", "struct.Struct.__dict__.__contains__", ["__next__"], false]

# ---------------------------------------------------------------------------
# Table 2: struct.Struct — packing/unpacking API present in __dict__
#
# struct.Struct defines the full binary format API directly: pack, unpack,
# pack_into, unpack_from, iter_unpack. It also exposes size (computed byte
# width of the format) and format (the original format string) as descriptors.
# All are own attributes in __dict__, not inherited. This contrasts with
# Table 1: the data API IS present but the context manager protocol is NOT.
# ---------------------------------------------------------------------------

table struct_extra2446.struct_pack_api_present:
  description: "struct.Struct.__dict__: pack, unpack, pack_into, unpack_from, iter_unpack, size, format present; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2446

  columns: [id, function, args, expected]
  rows:
    - ["st2446-005", "struct.Struct.__dict__.__contains__", ["pack"], true]
    - ["st2446-006", "struct.Struct.__dict__.__contains__", ["unpack"], true]
    - ["st2446-007", "struct.Struct.__dict__.__contains__", ["pack_into"], true]
    - ["st2446-008", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st2446-009", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st2446-010", "struct.Struct.__dict__.__contains__", ["size"], true]
    - ["st2446-011", "struct.Struct.__dict__.__contains__", ["format"], true]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct — C-level special methods in __dict__
#
# As a C extension type struct.Struct overrides __new__, __repr__, __sizeof__,
# __getattribute__, __setattr__, and __delattr__ at the C level. These appear
# in the class __dict__ as slot wrappers. Their presence confirms this is a C
# type with custom attribute handling. New to extra2446.
# ---------------------------------------------------------------------------

table struct_extra2446.struct_c_special_methods:
  description: "struct.Struct.__dict__: __new__, __sizeof__, __getattribute__, __setattr__, __delattr__ present; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2446

  columns: [id, function, args, expected]
  rows:
    - ["st2446-012", "struct.Struct.__dict__.__contains__", ["__new__"], true]
    - ["st2446-013", "struct.Struct.__dict__.__contains__", ["__sizeof__"], true]
    - ["st2446-014", "struct.Struct.__dict__.__contains__", ["__getattribute__"], true]
    - ["st2446-015", "struct.Struct.__dict__.__contains__", ["__setattr__"], true]
    - ["st2446-016", "struct.Struct.__dict__.__contains__", ["__delattr__"], true]
    - ["st2446-017", "struct.Struct.__dict__.__contains__", ["__repr__"], true]
