spec: abc_extra2566
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 2566 theme: __getattr__, __setattr__, __delattr__ dict-presence — custom attribute access protocol."
    - "abc.ABCMeta defines NONE of __getattr__, __setattr__, or __delattr__ in its own class __dict__, despite being a metaclass that intercepts class creation to track abstract methods."
    - "abc.ABC likewise defines none of these three attribute-access dunders."
    - "abc.abstractmethod (a function) and abc.abstractproperty (a class) both define none of the three dunders."
    - "ABCMeta intercepts abstract-method tracking through __new__ (class creation), not __setattr__."
    - "ABCMeta.__dict__ contains __new__, register, __instancecheck__, __subclasscheck__, _dump_registry."
    - "abc.ABC.__dict__ contains __slots__, __abstractmethods__, __module__, __doc__ but no attribute-access overrides."
    - "abc.abstractproperty.__dict__ contains __isabstractmethod__ (True) but no __getattr__/__setattr__/__delattr__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# abc.ABCMeta — attribute access protocol absent despite metaclass role
# ---------------------------------------------------------------------------

table abc_extra2566.abcmeta_attr_protocol:
  description: "abc.ABCMeta defines none of __getattr__, __setattr__, __delattr__ in its class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2566

  columns: [id, function, args, expected]
  rows:
    - ["ab2566001", "abc.ABCMeta.__dict__.__contains__", ["__getattr__"], false]
    - ["ab2566002", "abc.ABCMeta.__dict__.__contains__", ["__setattr__"], false]
    - ["ab2566003", "abc.ABCMeta.__dict__.__contains__", ["__delattr__"], false]

# ---------------------------------------------------------------------------
# abc.ABCMeta — positive presence of metaclass API in __dict__
# ---------------------------------------------------------------------------

table abc_extra2566.abcmeta_dict_positive:
  description: "abc.ABCMeta metaclass methods are defined directly in the class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2566

  columns: [id, function, args, expected]
  rows:
    - ["ab2566004", "abc.ABCMeta.__dict__.__contains__", ["__new__"],            true]
    - ["ab2566005", "abc.ABCMeta.__dict__.__contains__", ["register"],           true]
    - ["ab2566006", "abc.ABCMeta.__dict__.__contains__", ["__instancecheck__"],  true]
    - ["ab2566007", "abc.ABCMeta.__dict__.__contains__", ["__subclasscheck__"],  true]
    - ["ab2566008", "abc.ABCMeta.__dict__.__contains__", ["_dump_registry"],     true]
    - ["ab2566009", "abc.ABCMeta.__dict__.__contains__", ["__init__"],           false]

# ---------------------------------------------------------------------------
# abc.ABC — attribute access protocol absent
# ---------------------------------------------------------------------------

table abc_extra2566.abc_class_attr_protocol:
  description: "abc.ABC defines none of __getattr__, __setattr__, __delattr__ in its class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2566

  columns: [id, function, args, expected]
  rows:
    - ["ab2566010", "abc.ABC.__dict__.__contains__", ["__getattr__"],        false]
    - ["ab2566011", "abc.ABC.__dict__.__contains__", ["__setattr__"],        false]
    - ["ab2566012", "abc.ABC.__dict__.__contains__", ["__delattr__"],        false]
    - ["ab2566013", "abc.ABC.__dict__.__contains__", ["__slots__"],          true]
    - ["ab2566014", "abc.ABC.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["ab2566015", "abc.ABC.__dict__.__contains__", ["__module__"],         true]
    - ["ab2566016", "abc.ABC.__dict__.__contains__", ["__doc__"],            true]

# ---------------------------------------------------------------------------
# abc.abstractproperty — attribute access protocol absent; __isabstractmethod__ present
# ---------------------------------------------------------------------------

table abc_extra2566.abstractproperty_attr_protocol:
  description: "abc.abstractproperty defines none of the three attribute-access dunders; __isabstractmethod__ is present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2566

  columns: [id, function, args, expected]
  rows:
    - ["ab2566017", "abc.abstractproperty.__dict__.__contains__", ["__getattr__"],         false]
    - ["ab2566018", "abc.abstractproperty.__dict__.__contains__", ["__setattr__"],         false]
    - ["ab2566019", "abc.abstractproperty.__dict__.__contains__", ["__delattr__"],         false]
    - ["ab2566020", "abc.abstractproperty.__dict__.__contains__", ["__isabstractmethod__"], true]
