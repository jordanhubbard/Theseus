spec: operator_extra15
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra14.zspec.zsdl."
    - "operator_extra14 covers: __module__.__eq__ for add/sub/mul/eq/lt (== '_operator'); __module__.__eq__ for itemgetter/attrgetter/methodcaller (== 'operator'); __module__.__eq__ for truth/not_/index (== '_operator'); __name__.__eq__ for truth/not_/index."
    - "operator_extra13 covers: __qualname__.__eq__ for add/sub/mul/truediv/pow/neg/pos/abs/eq/ne/lt/gt."
    - "operator.zspec.zsdl covers: call results for add/sub/mul/truediv/floordiv/mod/pow; neg/abs; eq/ne/lt/le/gt/ge; and_/or_/xor; not_/truth; contains/length_hint/concat/getitem/index."
    - "No prior operator spec records __name__.__len__() for any operator function."
    - "Name lengths: add==3, sub==3, mul==3, truediv==7, floordiv==8, mod==3, pow==3, neg==3, abs==3, eq==2, ne==2, lt==2, gt==2, le==2, ge==2."
    - "Name lengths: and_==4, or_==3, xor==3, not_==4, truth==5, index==5."
    - "Name lengths: itemgetter==10, attrgetter==10, methodcaller==12, contains==8, length_hint==11, concat==6, getitem==7."
    - "No prior operator spec records __module__.__len__() for any function."
    - "__module__.__len__() == 9 for '_operator' (9 chars) — all C-level functions."
    - "__module__.__len__() == 8 for 'operator' (8 chars) — itemgetter, attrgetter, methodcaller."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for arithmetic operators
#
# No prior operator spec records __name__.__len__() for any function.
# These provide a second behavioral axis (string length) for the name attribute,
# complementing the __name__.__eq__ checks in the base spec and prior extras.
# ---------------------------------------------------------------------------

invariant operator_extra15.add.name_len:
  description: "operator.add.__name__.__len__() == 3 — len('add')"
  category: name_lengths
  kind: python_call_eq
  function: add.__name__.__len__
  args: []
  expected: 3

invariant operator_extra15.truediv.name_len:
  description: "operator.truediv.__name__.__len__() == 7 — len('truediv')"
  category: name_lengths
  kind: python_call_eq
  function: truediv.__name__.__len__
  args: []
  expected: 7

invariant operator_extra15.floordiv.name_len:
  description: "operator.floordiv.__name__.__len__() == 8 — len('floordiv')"
  category: name_lengths
  kind: python_call_eq
  function: floordiv.__name__.__len__
  args: []
  expected: 8

invariant operator_extra15.pow.name_len:
  description: "operator.pow.__name__.__len__() == 3 — len('pow')"
  category: name_lengths
  kind: python_call_eq
  function: pow.__name__.__len__
  args: []
  expected: 3

invariant operator_extra15.mod.name_len:
  description: "operator.mod.__name__.__len__() == 3 — len('mod')"
  category: name_lengths
  kind: python_call_eq
  function: mod.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# __name__.__len__() for comparison and logical operators
# ---------------------------------------------------------------------------

invariant operator_extra15.eq.name_len:
  description: "operator.eq.__name__.__len__() == 2 — len('eq')"
  category: name_lengths
  kind: python_call_eq
  function: eq.__name__.__len__
  args: []
  expected: 2

invariant operator_extra15.truth.name_len:
  description: "operator.truth.__name__.__len__() == 5 — len('truth')"
  category: name_lengths
  kind: python_call_eq
  function: truth.__name__.__len__
  args: []
  expected: 5

invariant operator_extra15.not_.name_len:
  description: "operator.not_.__name__.__len__() == 4 — len('not_')"
  category: name_lengths
  kind: python_call_eq
  function: not_.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# __name__.__len__() for sequence and getter types
# ---------------------------------------------------------------------------

invariant operator_extra15.itemgetter.name_len:
  description: "operator.itemgetter.__name__.__len__() == 10 — len('itemgetter')"
  category: name_lengths
  kind: python_call_eq
  function: itemgetter.__name__.__len__
  args: []
  expected: 10

invariant operator_extra15.attrgetter.name_len:
  description: "operator.attrgetter.__name__.__len__() == 10 — len('attrgetter')"
  category: name_lengths
  kind: python_call_eq
  function: attrgetter.__name__.__len__
  args: []
  expected: 10

invariant operator_extra15.methodcaller.name_len:
  description: "operator.methodcaller.__name__.__len__() == 12 — len('methodcaller')"
  category: name_lengths
  kind: python_call_eq
  function: methodcaller.__name__.__len__
  args: []
  expected: 12

invariant operator_extra15.contains.name_len:
  description: "operator.contains.__name__.__len__() == 8 — len('contains')"
  category: name_lengths
  kind: python_call_eq
  function: contains.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# __module__.__len__() for C-level operator functions
#
# No prior operator spec records __module__.__len__() for any function.
# C-level functions (add, sub, truediv, etc.) have __module__ == '_operator'
# (9 chars). Python-level types (itemgetter, attrgetter, methodcaller) have
# __module__ == 'operator' (8 chars).
# ---------------------------------------------------------------------------

invariant operator_extra15.add.module_len:
  description: "operator.add.__module__.__len__() == 9 — len('_operator')"
  category: module_attr_lengths
  kind: python_call_eq
  function: add.__module__.__len__
  args: []
  expected: 9

invariant operator_extra15.itemgetter.module_len:
  description: "operator.itemgetter.__module__.__len__() == 8 — len('operator')"
  category: module_attr_lengths
  kind: python_call_eq
  function: itemgetter.__module__.__len__
  args: []
  expected: 8

invariant operator_extra15.attrgetter.module_len:
  description: "operator.attrgetter.__module__.__len__() == 8 — len('operator')"
  category: module_attr_lengths
  kind: python_call_eq
  function: attrgetter.__module__.__len__
  args: []
  expected: 8
