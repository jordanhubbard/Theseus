spec: concurrent_futures_extra119
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "This spec extends concurrent_futures_extra118.zspec.zsdl."
    - "This spec covers: wave 261 theme — concurrent.futures module __spec__ and __package__ attributes not previously covered at the level of __spec__.parent, __spec__.loader.__class__.__qualname__, __spec__.submodule_search_locations.__len__(), and string length cross-comparisons. Prior specs covered: extra35 covered __package__.__len__()==18; extra50/extra55/extra88 covered __package__.__eq__('concurrent.futures'), __spec__.__class__.__name__.__eq__('ModuleSpec'), __spec__.name.__eq__('concurrent.futures'), __loader__.__class__.__name__.__eq__('SourceFileLoader'). NOT previously covered: __spec__.parent.__eq__('concurrent.futures'); __spec__.parent.__len__()==18; __spec__.loader.__class__.__qualname__.__eq__('SourceFileLoader'); __spec__.submodule_search_locations.__len__()==1; __spec__.__class__.__name__.__len__()==10; __loader__.__class__.__name__.__len__()==16; name/parent/package length equality cross-checks. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__spec__.parent == 'concurrent.futures' (len=18). For a package module, ModuleSpec.parent equals the package name. For concurrent.futures, parent == name == __package__ == 'concurrent.futures'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__spec__.loader.__class__.__qualname__ == 'SourceFileLoader' (len=16). The loader's qualname equals its __name__ for a top-level class. __spec__.loader is a SourceFileLoader instance loaded from importlib._bootstrap_external. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__spec__.submodule_search_locations.__len__()==1. The submodule_search_locations list contains exactly one path entry (the directory of the concurrent/futures/ package). As a regular package (not a namespace package), it has exactly one search path. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.__spec__.__class__.__name__.__len__()==10 ('ModuleSpec'=10). __spec__.__class__.__name__=='ModuleSpec' (covered in extra88); __len__()==10 is a new measurement. concurrent.futures.__loader__.__class__.__name__.__len__()==16 ('SourceFileLoader'=16). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.__spec__.parent and loader qualname — extra119
#
# Wave 261 theme: __spec__.parent equality and loader qualname equality.
#
# __spec__.parent == 'concurrent.futures'  (len=18, tied with __spec__.name and __package__)
# __spec__.loader.__class__.__qualname__ == 'SourceFileLoader'  (len=16)
# ---------------------------------------------------------------------------

table concurrent_futures_extra119.spec_parent_and_loader_qualname:
  description: "concurrent.futures __spec__.parent and __spec__.loader.__class__.__qualname__ checks in cfspec119 namespace — wave 261 theme: __spec__.parent is a ModuleSpec field that indicates the parent package; for a top-level package like concurrent.futures, parent==name==__package__=='concurrent.futures' (all three are the same string: 18 chars); __spec__.parent.__eq__('concurrent.futures')==True (len=18: first standalone coverage of __spec__.parent.__eq__ for concurrent.futures; prior specs covered __spec__.name.__eq__ in extra88 and __package__.__eq__ in extra50/extra55/extra88 — parent is the third such equality check and confirms all three attributes have the same value for a package module); __spec__.parent.__len__()==18 (tied with __spec__.name.__len__()==18 from extra88 and __package__.__len__()==18 from extra35); __spec__.loader.__class__.__qualname__.__eq__('SourceFileLoader')==True (len=16: the loader's __class__.__qualname__ equals its __class__.__name__ because SourceFileLoader is a top-level class not nested inside another class; extra88 covered __loader__.__class__.__name__.__eq__('SourceFileLoader') while this spec adds __loader__.__class__.__qualname__.__eq__; for a top-level class, __name__==__qualname__==16 chars); __spec__.loader.__class__.__qualname__.__len__()==16 ('SourceFileLoader'=16: 'Source'=6+'File'=4+'Loader'=6=16); length ordering: __spec__.__class__.__name__='ModuleSpec'=10 < __loader__.__class__.__name__='SourceFileLoader'=16 (6 more); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_attrs
  id_prefix: cfspec119

  columns: [id, function, args, expected, description]
  rows:
    - [parent_eq,      concurrent.futures.__spec__.parent.__eq__,                         ["concurrent.futures"], true, "__spec__.parent == 'concurrent.futures' (len=18; parent==name==__package__ for a package module); verified with Python 3.14.3"]
    - [parent_len,     concurrent.futures.__spec__.parent.__len__,                        [],                     18,   "__spec__.parent.__len__() == 18 ('concurrent.futures'=18; tied with __spec__.name=18 and __package__=18); verified with Python 3.14.3"]
    - [ldr_qn_eq,      concurrent.futures.__spec__.loader.__class__.__qualname__.__eq__,  ["SourceFileLoader"],   true, "__spec__.loader.__class__.__qualname__ == 'SourceFileLoader' (len=16; qualname==name for top-level class); verified with Python 3.14.3"]
    - [ldr_qn_len,     concurrent.futures.__spec__.loader.__class__.__qualname__.__len__, [],                     16,   "__spec__.loader.__class__.__qualname__.__len__() == 16 ('SourceFileLoader'=16); verified with Python 3.14.3"]
    - [spec_cls_len,   concurrent.futures.__spec__.__class__.__name__.__len__,            [],                     10,   "__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'=10; 6 shorter than SourceFileLoader=16); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.__spec__.submodule_search_locations and cross-checks — extra119
#
# Wave 261 theme: submodule_search_locations length and string length cross-comparisons.
#
# __spec__.submodule_search_locations.__len__() == 1  (one directory entry for the package)
# __spec__.name.__len__() == 18  (tied with parent and __package__)
# __loader__.__class__.__name__.__len__() == 16  (SourceFileLoader)
# __spec__.__class__.__name__.__len__() == 10  (ModuleSpec)
# ---------------------------------------------------------------------------

table concurrent_futures_extra119.spec_submodule_locations_and_lengths:
  description: "concurrent.futures __spec__.submodule_search_locations and length cross-checks in cfspec119a namespace — wave 261 theme: submodule_search_locations is a list with exactly one path entry for a regular package; as a filesystem package (not a namespace package), concurrent.futures has a single source directory (the concurrent/futures/ folder containing __init__.py); __spec__.submodule_search_locations.__len__()==1 (exactly one entry: the physical directory path of the package; namespace packages can have multiple entries; regular packages have exactly one; concurrent.futures is a regular package so len==1); string length ordering in concurrent.futures __spec__ and module attrs: __spec__.__class__.__name__='ModuleSpec'=10 < __loader__.__class__.__name__='SourceFileLoader'=16 < __spec__.name==__spec__.parent==__package__='concurrent.futures'=18 (all three equal at 18); the pattern name==parent==__package__==18 confirms concurrent.futures is its own top-level package with no parent namespace; __spec__.name.__len__()==18 (cross-check: same as covered in extra88 for the string but its length was not measured as a standalone vector); __loader__.__class__.__name__.__len__()==16 (cross-check: 'SourceFileLoader'=16); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_attrs
  id_prefix: cfspec119a

  columns: [id, function, args, expected, description]
  rows:
    - [ssl_len,      concurrent.futures.__spec__.submodule_search_locations.__len__, [],  1,  "__spec__.submodule_search_locations.__len__() == 1 (exactly one directory for a regular package); verified with Python 3.14.3"]
    - [name_len,     concurrent.futures.__spec__.name.__len__,                       [],  18, "__spec__.name.__len__() == 18 ('concurrent.futures'=18; tied with parent=18 and __package__=18); verified with Python 3.14.3"]
    - [ldr_nm_len,   concurrent.futures.__loader__.__class__.__name__.__len__,       [],  16, "__loader__.__class__.__name__.__len__() == 16 ('SourceFileLoader'=16; 2 shorter than name=18); verified with Python 3.14.3"]
    - [spec_cls_nm,  concurrent.futures.__spec__.__class__.__name__.__len__,         [],  10, "__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'=10; 6 shorter than SourceFileLoader=16); verified with Python 3.14.3"]
    - [pkg_len,      concurrent.futures.__package__.__len__,                         [],  18, "__package__.__len__() == 18 ('concurrent.futures'=18; tied with name=18 and parent=18); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures __spec__ attribute string equality cross-table — extra119
#
# Wave 261 theme: cross-comparison of __spec__ string attributes.
#
# __spec__.name == __spec__.parent == __package__ == 'concurrent.futures'
# All three have the same string value and the same length (18).
# ---------------------------------------------------------------------------

table concurrent_futures_extra119.spec_string_attrs_cross_compare:
  description: "concurrent.futures __spec__ string attributes cross-comparison in cfspec119b namespace — wave 261 theme: for a top-level package module, __spec__.name, __spec__.parent, and __package__ all equal the same string 'concurrent.futures' (len=18); __spec__.name.__eq__('concurrent.futures')==True (cross-check; covered in extra88; included here for cross-reference); __spec__.parent.__eq__('concurrent.futures')==True (new in extra119: parent==name for packages); __package__.__eq__('concurrent.futures')==True (cross-check; covered in extra50/extra55/extra88; included here for cross-reference); the three-way equality name==parent==__package__=='concurrent.futures' is a structural property of top-level packages in Python's importlib; compare: for a submodule like concurrent.futures.thread, __spec__.name='concurrent.futures.thread' but __spec__.parent='concurrent.futures' (they differ); for the top-level package itself, all three are the same; __spec__.loader.__class__.__qualname__.__eq__('SourceFileLoader')==True (cross-check of loader qualname equality); __spec__.submodule_search_locations.__len__()==1 (cross-check; regular package); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_attrs
  id_prefix: cfspec119b

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,    concurrent.futures.__spec__.name.__eq__,                          ["concurrent.futures"], true, "__spec__.name == 'concurrent.futures' (cross-check; covered in extra88); verified with Python 3.14.3"]
    - [parent_eq,  concurrent.futures.__spec__.parent.__eq__,                        ["concurrent.futures"], true, "__spec__.parent == 'concurrent.futures' (new in extra119: parent==name for packages); verified with Python 3.14.3"]
    - [pkg_eq,     concurrent.futures.__package__.__eq__,                            ["concurrent.futures"], true, "__package__ == 'concurrent.futures' (cross-check; covered in extra50/extra88); verified with Python 3.14.3"]
    - [ldr_qn_eq2, concurrent.futures.__spec__.loader.__class__.__qualname__.__eq__, ["SourceFileLoader"],   true, "__spec__.loader.__class__.__qualname__ == 'SourceFileLoader' (cross-check; qualname==name for top-level class); verified with Python 3.14.3"]
    - [ssl_len1,   concurrent.futures.__spec__.submodule_search_locations.__len__,   [],                     1,    "__spec__.submodule_search_locations.__len__() == 1 (cross-check; regular package); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra119
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra119.spec_parent_eq_concurrent_futures:
  description: "concurrent.futures.__spec__.parent.__eq__('concurrent.futures') returns True — __spec__.parent=='concurrent.futures' (len=18); ModuleSpec.parent is the parent package name; for a top-level package module (one that IS a package, not just a member of a package), parent equals the module's own full name; this means __spec__.parent == __spec__.name == __package__ == 'concurrent.futures' for concurrent.futures as a package; for a submodule, parent would differ (e.g., concurrent.futures.thread has parent='concurrent.futures'); the fact that parent==name==__package__ confirms concurrent.futures is a self-contained top-level package (not a submodule of another package despite the dotted name); concurrent is a namespace package while futures is a real subpackage of it; __spec__.parent.__len__()==18 (tied with __spec__.name and __package__: all three have the same 18-char string 'concurrent.futures'); first standalone __spec__.parent equality invariant for concurrent.futures in cfspec119 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_attrs
  kind: python_call_eq
  function: concurrent.futures.__spec__.parent.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra119.spec_loader_qualname_eq_SourceFileLoader:
  description: "concurrent.futures.__spec__.loader.__class__.__qualname__.__eq__('SourceFileLoader') returns True — __spec__.loader.__class__.__qualname__=='SourceFileLoader' (len=16); the loader is an instance of importlib._bootstrap_external.SourceFileLoader; SourceFileLoader is a top-level class (not nested inside another class), so its __qualname__ equals its __name__ (both 'SourceFileLoader'); prior spec extra88 covered __loader__.__class__.__name__.__eq__('SourceFileLoader'); this spec adds __loader__.__class__.__qualname__.__eq__ as a new coverage angle; the __qualname__ would differ from __name__ only for nested classes (e.g., 'Outer.Inner'); for SourceFileLoader, name==qualname=='SourceFileLoader'=16 chars; 'SourceFileLoader'=16: 'Source'=6+'File'=4+'Loader'=6=16; compare: __spec__.__class__.__qualname__=='ModuleSpec'=10 (6 shorter: ModuleSpec is also a top-level class so qualname==name); __spec__.loader.__class__.__qualname__.__len__()==16 (tied with __spec__.loader.__class__.__name__.__len__()==16); first standalone __spec__.loader.__class__.__qualname__ equality invariant in cfspec119 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_attrs
  kind: python_call_eq
  function: concurrent.futures.__spec__.loader.__class__.__qualname__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant concurrent_futures_extra119.spec_submodule_search_locations_len_1:
  description: "concurrent.futures.__spec__.submodule_search_locations.__len__() == 1 — submodule_search_locations is a list containing exactly one path: the directory of the concurrent/futures/ package (the folder containing __init__.py and the submodule files thread.py, process.py, _base.py); for a regular filesystem package, submodule_search_locations always has exactly one entry (the single package directory); namespace packages (PEP 420) can have multiple entries across different filesystem locations; concurrent.futures is a regular package (has __init__.py) so len==1; __spec__.submodule_search_locations.__len__()==1 is a new measurement not covered in prior specs; compare: abc.__spec__.submodule_search_locations is None (not a package: abc is a single-file module with no submodules; covered in abc specs); asyncio.__spec__.submodule_search_locations has len>=1 (asyncio is also a package directory); first standalone __spec__.submodule_search_locations length invariant in cfspec119a namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_attrs
  kind: python_call_eq
  function: concurrent.futures.__spec__.submodule_search_locations.__len__
  args: []
  expected: 1

invariant concurrent_futures_extra119.loader_class_name_len_16:
  description: "concurrent.futures.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader'=16 chars; 'Source'=6+'File'=4+'Loader'=6=16; compare: __spec__.__class__.__name__='ModuleSpec'=10 (6 shorter than SourceFileLoader=16); __spec__.name.__len__()==18 (2 more than SourceFileLoader=16); __package__.__len__()==18 (tied with __spec__.name=18; both are 'concurrent.futures'); the length ordering in this spec: ModuleSpec=10 < SourceFileLoader=16 < concurrent.futures=18 (name/parent/__package__); __loader__.__class__.__name__=='SourceFileLoader' was covered in extra88 as a string equality; __loader__.__class__.__name__.__len__()==16 is a new measurement not explicitly covered as a standalone invariant in prior specs; concurrent.futures.__spec__.loader.__class__.__qualname__.__len__()==16 (same value: qualname==name for top-level class); first standalone __loader__.__class__.__name__ length invariant in cfspec119a namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_attrs
  kind: python_call_eq
  function: concurrent.futures.__loader__.__class__.__name__.__len__
  args: []
  expected: 16

invariant concurrent_futures_extra119.spec_class_name_len_10:
  description: "concurrent.futures.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec'=10 chars; 'Module'=6+'Spec'=4=10; __spec__.__class__.__name__=='ModuleSpec' was covered in extra88 as an equality check; __spec__.__class__.__name__.__len__()==10 is a new measurement not previously covered as a standalone invariant; extra41 covered __spec__.__class__.__name__.__len__()==10 in a table but not as a standalone invariant; compare: __loader__.__class__.__name__='SourceFileLoader'=16 (6 more than ModuleSpec=10); __spec__.name='concurrent.futures'=18 (8 more than ModuleSpec=10); the length 10 is less than all other string lengths in this spec (parent=18, name=18, __package__=18, SourceFileLoader=16); __spec__.__class__.__qualname__=='ModuleSpec'=10 (qualname==name for top-level class; both are 10-char strings); concurrent.futures.__spec__.__class__.__name__.__len__()==10 is consistent with abc.__spec__.__class__.__name__=='ModuleSpec' (also 10 chars; both are importlib ModuleSpec instances); first standalone __spec__.__class__.__name__ length invariant in cfspec119 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_attrs
  kind: python_call_eq
  function: concurrent.futures.__spec__.__class__.__name__.__len__
  args: []
  expected: 10
