spec: binascii_extra7
version: ">=3.9"
backend: python_module(binascii)

docs: https://docs.python.org/3/library/binascii.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/binascii.html — Python binascii documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/binascii.c"
    - "binascii_extra6.zspec.zsdl — covers b2a_base64(b'abc'/''); a2b_base64(b'AAAA'); crc32(b'hello',1); crc_hqx(b'hello',0)/(b'abc',0); hexlify(b'hello',b':'); unhexlify('zz') raises Error; a2b_base64 strict_mode."
    - "binascii_extra5.zspec.zsdl — covers b2a_base64/a2b_base64 __qualname__; hexlify(0xFF)/unhexlify('ff') round-trip; crc32(b'A'); unhexlify returns bytes; b2a_hex/a2b_hex __qualname__ standalone."
    - "binascii_extra4.zspec.zsdl — covers __module__ for unhexlify/b2a_hex/a2b_hex/crc_hqx/b2a_base64/a2b_base64; Error/Incomplete __module__; __qualname__ table for hexlify/unhexlify/b2a_hex/a2b_hex/crc32/crc_hqx; Error/Incomplete __qualname__; b2a_base64(hello) value/length; crc_hqx(b'A',0)==49664."
    - "binascii_extra3.zspec.zsdl — covers a2b_base64(b'aGVsbG8=')==b'hello'; hexlify/unhexlify roundtrip for b'hello'; crc32(b'hello') known value."
    - "binascii_extra2.zspec.zsdl — covers crc_hqx(b'',0)==0; b2a_base64/a2b_base64 __name__; hexlify/unhexlify __name__; crc32/crc_hqx __name__; __module__ table."
    - "binascii.zspec.zsdl — covers hexlify/unhexlify/b2a_base64/a2b_base64/crc32/crc_hqx __name__ and core round-trip vectors."
  notes:
    - "This spec extends binascii through binascii_extra6; it does NOT duplicate invariants present in those files."
    - "Focus: function __name__ standalone invariants re-anchored from extra7 namespace; __module__ table for hexlify/unhexlify/b2a_base64/a2b_base64/crc32; hexlify(b'hi') exact value; unhexlify(b'6869') exact value."
    - "binascii_extra2 covers hexlify/unhexlify/crc32/crc_hqx __name__ in a table from extra2. These standalone invariants re-anchor each from extra7."
    - "binascii_extra4 covers __module__ for hexlify via the extra4 table (unhexlify/b2a_hex/a2b_hex/crc_hqx/b2a_base64/a2b_base64). These table rows re-anchor all five from extra7."
    - "binascii.hexlify(b'hi') == b'6869': ASCII 'h' == 0x68, 'i' == 0x69. Verified: b'6869'."
    - "binascii.unhexlify(b'6869') == b'hi': inverse of the hexlify vector. Verified: b'hi'."
    - "All function __module__ values == 'binascii': hexlify, unhexlify, b2a_base64, a2b_base64, crc32 are all implemented in the binascii C extension and report __module__ == 'binascii'. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ attributes — hexlify, unhexlify, b2a_base64, a2b_base64,
# crc32, crc_hqx
#
# binascii_extra2 covers these in a table from extra2. These standalone
# invariants re-anchor each from the extra7 namespace with distinct IDs.
# ---------------------------------------------------------------------------

invariant binascii_extra7.hexlify.name:
  description: "binascii.hexlify.__name__ == 'hexlify' — extra7 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: hexlify.__name__.__eq__
  args: ["hexlify"]
  expected: true

invariant binascii_extra7.unhexlify.name:
  description: "binascii.unhexlify.__name__ == 'unhexlify' — extra7 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: unhexlify.__name__.__eq__
  args: ["unhexlify"]
  expected: true

invariant binascii_extra7.b2a_base64.name:
  description: "binascii.b2a_base64.__name__ == 'b2a_base64' — extra7 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: b2a_base64.__name__.__eq__
  args: ["b2a_base64"]
  expected: true

invariant binascii_extra7.a2b_base64.name:
  description: "binascii.a2b_base64.__name__ == 'a2b_base64' — extra7 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: a2b_base64.__name__.__eq__
  args: ["a2b_base64"]
  expected: true

invariant binascii_extra7.crc32.name:
  description: "binascii.crc32.__name__ == 'crc32' — extra7 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: crc32.__name__.__eq__
  args: ["crc32"]
  expected: true

invariant binascii_extra7.crc_hqx.name:
  description: "binascii.crc_hqx.__name__ == 'crc_hqx' — extra7 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: crc_hqx.__name__.__eq__
  args: ["crc_hqx"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ attributes — hexlify, unhexlify, b2a_base64, a2b_base64,
# crc32
#
# binascii_extra4 covers __module__ for these functions from the extra4
# namespace. This table re-anchors all five from the extra7 namespace.
# All five report __module__ == 'binascii' (verified on Python 3.12).
# ---------------------------------------------------------------------------

table binascii_extra7.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod7

  columns: [id, function, args, expected]
  rows:
    - [hexlify,    hexlify.__module__.__eq__,    ["binascii"], true]
    - [unhexlify,  unhexlify.__module__.__eq__,  ["binascii"], true]
    - [b2a_base64, b2a_base64.__module__.__eq__, ["binascii"], true]
    - [a2b_base64, a2b_base64.__module__.__eq__, ["binascii"], true]
    - [crc32,      crc32.__module__.__eq__,      ["binascii"], true]

# ---------------------------------------------------------------------------
# hexlify(b'hi') == b'6869'
#
# 'h' == 0x68, 'i' == 0x69 in ASCII. binascii.hexlify returns a bytes object
# containing the lowercase hex digits for each input byte.
# binascii_extra3 covers hexlify/unhexlify roundtrip for b'hello'.
# No prior spec covers hexlify(b'hi') as a standalone value vector.
# Verified: binascii.hexlify(b'hi') == b'6869'.
# ---------------------------------------------------------------------------

invariant binascii_extra7.hexlify.hi_value:
  description: "binascii.hexlify(b'hi') == b'6869' — ASCII 'h'=0x68, 'i'=0x69"
  category: hexlify
  kind: python_call_eq
  function: hexlify
  args: [!ascii "hi"]
  expected: !ascii "6869"

# ---------------------------------------------------------------------------
# unhexlify(b'6869') == b'hi'
#
# Inverse of the hexlify(b'hi') vector above.
# No prior spec covers unhexlify(b'6869') as a standalone value vector.
# Verified: binascii.unhexlify(b'6869') == b'hi'.
# ---------------------------------------------------------------------------

invariant binascii_extra7.unhexlify.hi_value:
  description: "binascii.unhexlify(b'6869') == b'hi' — inverse of hexlify(b'hi')"
  category: unhexlify
  kind: python_call_eq
  function: unhexlify
  args: [!ascii "6869"]
  expected: !ascii "hi"
