spec: io_extra340
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "io.StringIO is a C type in the _io extension module; __module__ == '_io'."
    - "StringIO('hello world').read(5) returns the first 5 characters 'hello'."
    - "StringIO('hello world').seek(6) returns the new position 6 as an int."
    - "StringIO('hello world').readline() reads to the end since there is no newline — returns 'hello world'."
    - "StringIO('hello\\nworld').readline() stops at and includes the newline — returns 'hello\\n'."
    - "StringIO('hello\\nworld').readlines() returns ['hello\\n', 'world'] — a two-element list."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# StringIO.read(5) — returns 'hello' (first 5 chars)
# ---------------------------------------------------------------------------

invariant io_extra340.StringIO.read5.eq:
  description: "io.StringIO('hello world').read(5).__eq__('hello') == True — read(5) returns the first 5 characters"
  category: read
  kind: python_call_eq
  function: "StringIO('hello world').read(5).__eq__"
  args: ["hello"]
  expected: true

# ---------------------------------------------------------------------------
# StringIO.read(5).__len__() == 5
# ---------------------------------------------------------------------------

invariant io_extra340.StringIO.read5.len:
  description: "io.StringIO('hello world').read(5).__len__() == 5 — the 5-char string has length 5"
  category: read
  kind: python_call_eq
  function: "StringIO('hello world').read(5).__len__"
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# StringIO.seek(6) returns new position 6
# ---------------------------------------------------------------------------

invariant io_extra340.StringIO.seek6.eq:
  description: "io.StringIO('hello world').seek(6).__eq__(6) == True — seek returns the new stream position"
  category: seek
  kind: python_call_eq
  function: "StringIO('hello world').seek(6).__eq__"
  args: [6]
  expected: true

# ---------------------------------------------------------------------------
# StringIO.readline() on single-line string — returns the whole string
# ---------------------------------------------------------------------------

invariant io_extra340.StringIO.readline.no_newline:
  description: "io.StringIO('hello world').readline().__eq__('hello world') == True — no newline so entire content is returned"
  category: readline
  kind: python_call_eq
  function: "StringIO('hello world').readline().__eq__"
  args: ["hello world"]
  expected: true

# ---------------------------------------------------------------------------
# StringIO.readline() on multi-line string — stops at first newline (inclusive)
# ---------------------------------------------------------------------------

invariant io_extra340.StringIO.readline.with_newline:
  description: "io.StringIO('hello\\nworld').readline().__eq__('hello\\n') == True — readline stops at and includes the newline"
  category: readline
  kind: python_call_eq
  function: "StringIO('hello\nworld').readline().__eq__"
  args: ["hello\n"]
  expected: true

# ---------------------------------------------------------------------------
# StringIO.readlines().__len__() == 2
# ---------------------------------------------------------------------------

invariant io_extra340.StringIO.readlines.len:
  description: "io.StringIO('hello\\nworld').readlines().__len__() == 2 — two lines in the buffer"
  category: readlines
  kind: python_call_eq
  function: "StringIO('hello\nworld').readlines().__len__"
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# StringIO.readlines() equality — ['hello\n', 'world']
# ---------------------------------------------------------------------------

invariant io_extra340.StringIO.readlines.eq:
  description: "io.StringIO('hello\\nworld').readlines().__eq__(['hello\\n', 'world']) == True — readlines returns list of lines preserving newlines"
  category: readlines
  kind: python_call_eq
  function: "StringIO('hello\nworld').readlines().__eq__"
  args: [["hello\n", "world"]]
  expected: true

# ---------------------------------------------------------------------------
# StringIO.__module__ == '_io' — C extension class
# ---------------------------------------------------------------------------

invariant io_extra340.StringIO.module:
  description: "io.StringIO.__module__ == '_io' — StringIO is a C type defined in the _io extension module"
  category: class_metadata
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true
