spec: uu3016
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid: UUID objects according to RFC 4122"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 648 (uu3016): __iter__, __next__, __reversed__ dict-presence checks for uuid types."
    - "uuid.UUID is an immutable value object — not a sequence or iterator; it does not define __iter__, __next__, or __reversed__ in its own __dict__."
    - "uuid.SafeUUID is an Enum subclass — not a sequence or iterator type."
    - "None of the uuid types define __iter__, __next__, or __reversed__ in their own __dict__."
    - "Verified types: uuid.UUID, uuid.SafeUUID."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table uu3016.iter:
  description: "uuid types __iter__ dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu3016
  columns: [id, function, args, expected]
  rows:
    - ["uu3016001", operator.contains, [uuid.UUID.__dict__,     "__iter__"], false]
    - ["uu3016002", operator.contains, [uuid.SafeUUID.__dict__, "__iter__"], false]

