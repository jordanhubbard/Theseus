spec: struct_extra1306
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for bad format strings and wrong value types."
    - "struct.pack('z', 1) raises struct.error: bad char in struct format."
    - "struct.pack('i', 'not_int') raises struct.error: required argument is not an integer."
    - "struct.pack('i') raises struct.error: pack expected 1 items for packing (got 0)."
    - "struct.pack('d', 'string') raises struct.error: required argument is not a float."
    - "struct.pack('c', 42) raises struct.error: char format requires a bytes object of length 1."
    - "struct.pack('H', -1) raises struct.error: 'H' format requires 0 <= number <= 65535."
    - "struct.pack('B', -1) raises struct.error: 'B' format requires 0 <= number <= 255."
    - "struct.pack('B', 256) raises struct.error: 'B' format requires 0 <= number <= 255."
    - "struct.pack('i', 2**31) raises struct.error: 'i' format requires -2147483648 <= number <= 2147483647."
    - "struct.pack('h', 32768) raises struct.error: 'h' format requires -32768 <= number <= 32767."
    - "struct.calcsize('z') raises struct.error: bad char in struct format."
    - "struct.calcsize('A') raises struct.error: bad char in struct format."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table struct_extra1306.calcsize_bad_format:
  description: "struct.calcsize raises struct.error for unknown or invalid format characters"
  kind: python_call_raises
  category: bad_format
  id_prefix: st1306cb
  columns: [id, function, args, exception]
  rows:
    - [st1306cb001, struct.calcsize, ["z"],          "struct.error"]
    - [st1306cb002, struct.calcsize, ["A"],          "struct.error"]
    - [st1306cb003, struct.calcsize, ["%"],          "struct.error"]
    - [st1306cb004, struct.calcsize, ["~"],          "struct.error"]
    - [st1306cb005, struct.calcsize, ["Q!"],         "struct.error"]
    - [st1306cb006, struct.calcsize, ["notaformat"], "struct.error"]

table struct_extra1306.pack_bad_format_or_missing_arg:
  description: "struct.pack raises struct.error for invalid format chars or missing required arguments"
  kind: python_call_raises
  category: pack_format_errors
  id_prefix: st1306pf
  columns: [id, function, args, exception]
  rows:
    - [st1306pf001, struct.pack, ["z",  1],         "struct.error"]
    - [st1306pf002, struct.pack, ["A",  1],         "struct.error"]
    - [st1306pf003, struct.pack, ["i"],             "struct.error"]
    - [st1306pf004, struct.pack, ["ii", 1],         "struct.error"]
    - [st1306pf005, struct.pack, ["iii", 1, 2],     "struct.error"]
    - [st1306pf006, struct.pack, ["%", 1],          "struct.error"]

table struct_extra1306.pack_wrong_value_type:
  description: "struct.pack raises struct.error when argument value is wrong type or out of range"
  kind: python_call_raises
  category: pack_value_errors
  id_prefix: st1306pv
  columns: [id, function, args, exception]
  rows:
    - [st1306pv001, struct.pack, ["i",  "not_int"],   "struct.error"]
    - [st1306pv002, struct.pack, ["d",  "string"],    "struct.error"]
    - [st1306pv003, struct.pack, ["c",  42],          "struct.error"]
    - [st1306pv004, struct.pack, ["H",  -1],          "struct.error"]
    - [st1306pv005, struct.pack, ["B",  256],         "struct.error"]
    - [st1306pv006, struct.pack, ["h",  32768],       "struct.error"]
