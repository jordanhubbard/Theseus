spec: functools_extra2776
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "Wave 632 theme: __isub__, __imul__, and __itruediv__ dict-presence checks (in-place subtraction -=, in-place multiplication *=, in-place true division /=)."
    - "None of the functools types (partial, partialmethod, cached_property, singledispatchmethod) define __isub__, __imul__, or __itruediv__ in their __dict__."
    - "'__isub__' in partial.__dict__ == False; likewise for __imul__ and __itruediv__."
    - "partial is a C-level type (Modules/_functoolsmodule.c); partialmethod, cached_property, singledispatchmethod are pure-Python classes."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.partial and functools.partialmethod — __isub__/__imul__/__itruediv__
# dict-presence checks
#
# partial is a C-level type; partialmethod is pure-Python.
# Neither defines in-place arithmetic operator dunders for -=, *=, or /=.
# All six checks return False.
# ---------------------------------------------------------------------------

table functools_extra2776.partial_partialmethod_operator_dict:
  description: "functools.partial and partialmethod __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ft2776pp

  columns: [id, function, args, expected]
  rows:
    - ["ft2776pp_pa_is",  partial.__dict__.__contains__,      ["__isub__"],      false]
    - ["ft2776pp_pa_im",  partial.__dict__.__contains__,      ["__imul__"],      false]
    - ["ft2776pp_pa_it",  partial.__dict__.__contains__,      ["__itruediv__"],  false]
    - ["ft2776pp_pm_is",  partialmethod.__dict__.__contains__, ["__isub__"],      false]
    - ["ft2776pp_pm_im",  partialmethod.__dict__.__contains__, ["__imul__"],      false]
    - ["ft2776pp_pm_it",  partialmethod.__dict__.__contains__, ["__itruediv__"],  false]

# ---------------------------------------------------------------------------
# functools.cached_property and functools.singledispatchmethod —
# __isub__/__imul__/__itruediv__ dict-presence checks
#
# Both are pure-Python descriptor classes.
# Neither implements in-place arithmetic operator dunders.
# All six checks return False.
# ---------------------------------------------------------------------------

table functools_extra2776.cached_property_singledispatchmethod_operator_dict:
  description: "functools.cached_property and singledispatchmethod __isub__, __imul__, __itruediv__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ft2776cs

  columns: [id, function, args, expected]
  rows:
    - ["ft2776cs_cp_is",  cached_property.__dict__.__contains__,      ["__isub__"],      false]
    - ["ft2776cs_cp_im",  cached_property.__dict__.__contains__,      ["__imul__"],      false]
    - ["ft2776cs_cp_it",  cached_property.__dict__.__contains__,      ["__itruediv__"],  false]
    - ["ft2776cs_sd_is",  singledispatchmethod.__dict__.__contains__,  ["__isub__"],      false]
    - ["ft2776cs_sd_im",  singledispatchmethod.__dict__.__contains__,  ["__imul__"],      false]
    - ["ft2776cs_sd_it",  singledispatchmethod.__dict__.__contains__,  ["__itruediv__"],  false]

# ---------------------------------------------------------------------------
# Cross-type summary — all four functools types, all three operator dunders
#
# Consolidates the full 4×3 matrix of dict-presence results in one table.
# Every cell is False: none of partial, partialmethod, cached_property,
# or singledispatchmethod supports the -=, *=, or /= operators natively.
# ---------------------------------------------------------------------------

table functools_extra2776.all_types_isub_imul_itruediv_matrix:
  description: "Full 4×3 dict-presence matrix for functools types vs __isub__/__imul__/__itruediv__ — all 12 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: ft2776mx

  columns: [id, function, args, expected]
  rows:
    - ["ft2776mx_pa_is",  partial.__dict__.__contains__,              ["__isub__"],      false]
    - ["ft2776mx_pa_im",  partial.__dict__.__contains__,              ["__imul__"],      false]
    - ["ft2776mx_pa_it",  partial.__dict__.__contains__,              ["__itruediv__"],  false]
    - ["ft2776mx_pm_is",  partialmethod.__dict__.__contains__,        ["__isub__"],      false]
    - ["ft2776mx_pm_im",  partialmethod.__dict__.__contains__,        ["__imul__"],      false]
    - ["ft2776mx_pm_it",  partialmethod.__dict__.__contains__,        ["__itruediv__"],  false]
    - ["ft2776mx_cp_is",  cached_property.__dict__.__contains__,      ["__isub__"],      false]
    - ["ft2776mx_cp_im",  cached_property.__dict__.__contains__,      ["__imul__"],      false]
    - ["ft2776mx_cp_it",  cached_property.__dict__.__contains__,      ["__itruediv__"],  false]
    - ["ft2776mx_sd_is",  singledispatchmethod.__dict__.__contains__,  ["__isub__"],      false]
    - ["ft2776mx_sd_im",  singledispatchmethod.__dict__.__contains__,  ["__imul__"],      false]
    - ["ft2776mx_sd_it",  singledispatchmethod.__dict__.__contains__,  ["__itruediv__"],  false]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra2776
# ---------------------------------------------------------------------------

invariant functools_extra2776.partial_no_isub:
  description: "'__isub__' not in functools.partial.__dict__ — partial does not implement the -= (in-place subtraction) operator"
  category: behavior
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant functools_extra2776.partial_no_imul:
  description: "'__imul__' not in functools.partial.__dict__ — partial does not implement the *= (in-place multiplication) operator"
  category: behavior
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant functools_extra2776.partial_no_itruediv:
  description: "'__itruediv__' not in functools.partial.__dict__ — partial does not implement the /= (in-place true division) operator"
  category: behavior
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__itruediv__"]
  expected: false

invariant functools_extra2776.partialmethod_no_isub:
  description: "'__isub__' not in functools.partialmethod.__dict__ — partialmethod does not implement the -= operator"
  category: behavior
  kind: python_call_eq
  function: partialmethod.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant functools_extra2776.cached_property_no_imul:
  description: "'__imul__' not in functools.cached_property.__dict__ — cached_property does not implement the *= operator"
  category: behavior
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant functools_extra2776.singledispatchmethod_no_itruediv:
  description: "'__itruediv__' not in functools.singledispatchmethod.__dict__ — singledispatchmethod does not implement the /= operator"
  category: behavior
  kind: python_call_eq
  function: singledispatchmethod.__dict__.__contains__
  args: ["__itruediv__"]
  expected: false
