spec: functools_extra221
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools function __code__ attribute checks: co_varnames.__contains__ and co_firstlineno."
    - "functools.wraps.__code__.co_varnames == ('wrapped', 'assigned', 'updated'); co_firstlineno == 65. Verified with Python 3.14.3."
    - "functools.update_wrapper.__code__.co_varnames contains 'wrapper' and 'wrapped'; co_firstlineno == 35. Verified with Python 3.14.3."
    - "functools.lru_cache.__code__.co_varnames contains 'maxsize'; co_firstlineno == 553. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_varnames contains 'func'; co_firstlineno == 875. Verified with Python 3.14.3."
    - "functools.reduce is a C builtin (no __code__); only pure-Python functools functions are tested here."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.wraps — __code__.co_varnames.__contains__ checks
#
# functools.wraps is a pure-Python function. Its __code__.co_varnames tuple
# holds all local variable names, starting with the formal parameters.
# wraps(wrapped, assigned=..., updated=...) has co_varnames ==
# ('wrapped', 'assigned', 'updated').
#
# Verified with Python 3.14.3:
#   functools.wraps.__code__.co_varnames == ('wrapped', 'assigned', 'updated')
#   co_varnames.__contains__('wrapped') == True
#   co_varnames.__contains__('assigned') == True
#   co_varnames.__contains__('updated') == True
# ---------------------------------------------------------------------------

table functools_extra221.wraps_co_varnames:
  description: "functools.wraps.__code__.co_varnames contains 'wrapped', 'assigned', 'updated'; wave 382; new to extra221"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra221wraps

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_varnames_contains_wrapped,
       wraps.__code__.co_varnames.__contains__,
       ["wrapped"],
       true,
       "functools.wraps.__code__.co_varnames.__contains__('wrapped') == True — wraps() takes 'wrapped' as its first parameter (the function being decorated); co_varnames is the tuple of all local names; 'wrapped' is present so __contains__ returns True; new to extra221"]
    - [wraps_varnames_contains_assigned,
       wraps.__code__.co_varnames.__contains__,
       ["assigned"],
       true,
       "functools.wraps.__code__.co_varnames.__contains__('assigned') == True — wraps() has 'assigned' as a parameter listing which attributes to copy from wrapped to wrapper; co_varnames contains 'assigned' so __contains__ returns True; new to extra221"]
    - [wraps_varnames_contains_updated,
       wraps.__code__.co_varnames.__contains__,
       ["updated"],
       true,
       "functools.wraps.__code__.co_varnames.__contains__('updated') == True — wraps() has 'updated' as a parameter listing which attributes of the wrapper to update with the corresponding attribute from wrapped; co_varnames contains 'updated' so __contains__ returns True; new to extra221"]
    - [wraps_varnames_not_contains_func,
       wraps.__code__.co_varnames.__contains__,
       ["func"],
       false,
       "functools.wraps.__code__.co_varnames.__contains__('func') == False — wraps() does not have a parameter named 'func'; its parameters are 'wrapped', 'assigned', 'updated'; 'func' is not in co_varnames so __contains__ returns False; new to extra221"]

# ---------------------------------------------------------------------------
# Table 2: functools.wraps — co_firstlineno
#
# functools.wraps.__code__.co_firstlineno is the line number of the first
# line of the function definition in Lib/functools.py.
# Verified with Python 3.14.3: co_firstlineno == 65.
# ---------------------------------------------------------------------------

table functools_extra221.wraps_co_firstlineno:
  description: "functools.wraps.__code__.co_firstlineno == 65; wave 382; new to extra221"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra221wrapsfirstline

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_co_firstlineno_eq_65,
       wraps.__code__.co_firstlineno.__eq__,
       [65],
       true,
       "functools.wraps.__code__.co_firstlineno.__eq__(65) == True — co_firstlineno records the first source line of the function; functools.wraps begins at line 65 of Lib/functools.py in Python 3.14.3; int.__eq__(65) returns True; new to extra221"]

# ---------------------------------------------------------------------------
# Table 3: functools.update_wrapper — __code__.co_varnames.__contains__ checks
#
# functools.update_wrapper(wrapper, wrapped, assigned=..., updated=...) is a
# pure-Python function. Its co_varnames tuple contains all parameters and
# local variables: ('wrapper', 'wrapped', 'assigned', 'updated', 'attr', 'value').
#
# Verified with Python 3.14.3:
#   co_varnames.__contains__('wrapper') == True
#   co_varnames.__contains__('wrapped') == True
#   co_varnames.__contains__('attr') == True
# ---------------------------------------------------------------------------

table functools_extra221.update_wrapper_co_varnames:
  description: "functools.update_wrapper.__code__.co_varnames contains 'wrapper', 'wrapped', 'attr'; wave 382; new to extra221"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra221updatewrapper

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_varnames_contains_wrapper,
       update_wrapper.__code__.co_varnames.__contains__,
       ["wrapper"],
       true,
       "functools.update_wrapper.__code__.co_varnames.__contains__('wrapper') == True — update_wrapper() takes 'wrapper' as its first parameter (the function to update); co_varnames contains 'wrapper' so __contains__ returns True; new to extra221"]
    - [update_wrapper_varnames_contains_wrapped,
       update_wrapper.__code__.co_varnames.__contains__,
       ["wrapped"],
       true,
       "functools.update_wrapper.__code__.co_varnames.__contains__('wrapped') == True — update_wrapper() takes 'wrapped' as its second parameter (the function being copied from); co_varnames contains 'wrapped' so __contains__ returns True; new to extra221"]
    - [update_wrapper_varnames_contains_attr,
       update_wrapper.__code__.co_varnames.__contains__,
       ["attr"],
       true,
       "functools.update_wrapper.__code__.co_varnames.__contains__('attr') == True — update_wrapper() uses a local variable 'attr' in its loop over assigned attributes; co_varnames contains 'attr' so __contains__ returns True; new to extra221"]
    - [update_wrapper_co_firstlineno_eq_35,
       update_wrapper.__code__.co_firstlineno.__eq__,
       [35],
       true,
       "functools.update_wrapper.__code__.co_firstlineno.__eq__(35) == True — co_firstlineno records the first source line of update_wrapper in Lib/functools.py; it begins at line 35 in Python 3.14.3; int.__eq__(35) returns True; new to extra221"]

# ---------------------------------------------------------------------------
# Table 4: functools.lru_cache — __code__.co_varnames.__contains__ and co_firstlineno
#
# functools.lru_cache(maxsize=128, typed=False) is a pure-Python function.
# co_varnames includes 'maxsize' and 'typed' (the formal parameters) plus
# inner names like 'user_function', 'wrapper', 'decorating_function'.
#
# Verified with Python 3.14.3:
#   co_varnames.__contains__('maxsize') == True
#   co_varnames.__contains__('typed') == True
#   co_firstlineno == 553
# ---------------------------------------------------------------------------

table functools_extra221.lru_cache_co_varnames:
  description: "functools.lru_cache.__code__.co_varnames contains 'maxsize', 'typed'; co_firstlineno == 553; wave 382; new to extra221"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra221lrucache

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_varnames_contains_maxsize,
       lru_cache.__code__.co_varnames.__contains__,
       ["maxsize"],
       true,
       "functools.lru_cache.__code__.co_varnames.__contains__('maxsize') == True — lru_cache() has 'maxsize' as its first parameter controlling the maximum size of the LRU cache; co_varnames contains 'maxsize' so __contains__ returns True; new to extra221"]
    - [lru_cache_varnames_contains_typed,
       lru_cache.__code__.co_varnames.__contains__,
       ["typed"],
       true,
       "functools.lru_cache.__code__.co_varnames.__contains__('typed') == True — lru_cache() has 'typed' as its second parameter controlling whether different argument types are cached separately; co_varnames contains 'typed' so __contains__ returns True; new to extra221"]
    - [lru_cache_co_firstlineno_eq_553,
       lru_cache.__code__.co_firstlineno.__eq__,
       [553],
       true,
       "functools.lru_cache.__code__.co_firstlineno.__eq__(553) == True — co_firstlineno records the first source line of lru_cache in Lib/functools.py; it begins at line 553 in Python 3.14.3; int.__eq__(553) returns True; new to extra221"]

# ---------------------------------------------------------------------------
# Table 5: functools.singledispatch — __code__.co_varnames.__contains__ and co_firstlineno
#
# functools.singledispatch(func) is a pure-Python decorator factory.
# co_varnames == ('func', 'weakref', 'wrapper'); co_firstlineno == 875.
#
# Verified with Python 3.14.3:
#   co_varnames.__contains__('func') == True
#   co_firstlineno == 875
# ---------------------------------------------------------------------------

table functools_extra221.singledispatch_co_varnames:
  description: "functools.singledispatch.__code__.co_varnames contains 'func'; co_firstlineno == 875; wave 382; new to extra221"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra221singledispatch

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_varnames_contains_func,
       singledispatch.__code__.co_varnames.__contains__,
       ["func"],
       true,
       "functools.singledispatch.__code__.co_varnames.__contains__('func') == True — singledispatch() takes 'func' as its only parameter (the function being decorated to become a generic function); co_varnames contains 'func' so __contains__ returns True; new to extra221"]
    - [singledispatch_varnames_not_contains_maxsize,
       singledispatch.__code__.co_varnames.__contains__,
       ["maxsize"],
       false,
       "functools.singledispatch.__code__.co_varnames.__contains__('maxsize') == False — singledispatch() has no 'maxsize' parameter; that belongs to lru_cache(); co_varnames does not contain 'maxsize' so __contains__ returns False; new to extra221"]
    - [singledispatch_co_firstlineno_eq_875,
       singledispatch.__code__.co_firstlineno.__eq__,
       [875],
       true,
       "functools.singledispatch.__code__.co_firstlineno.__eq__(875) == True — co_firstlineno records the first source line of singledispatch in Lib/functools.py; it begins at line 875 in Python 3.14.3; int.__eq__(875) returns True; new to extra221"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra221
# ---------------------------------------------------------------------------

invariant functools_extra221.wraps_varnames_contains_wrapped:
  description: "functools.wraps.__code__.co_varnames.__contains__('wrapped') == True — 'wrapped' is the first parameter of wraps(); wave 382; new to extra221"
  kind: python_call_eq
  function: wraps.__code__.co_varnames.__contains__
  args: ["wrapped"]
  expected: true

invariant functools_extra221.wraps_varnames_not_contains_func:
  description: "functools.wraps.__code__.co_varnames.__contains__('func') == False — 'func' is not a parameter of wraps(); wave 382; new to extra221"
  kind: python_call_eq
  function: wraps.__code__.co_varnames.__contains__
  args: ["func"]
  expected: false

invariant functools_extra221.wraps_co_firstlineno:
  description: "functools.wraps.__code__.co_firstlineno == 65 — wraps begins at line 65 of Lib/functools.py; wave 382; new to extra221"
  kind: python_call_eq
  function: wraps.__code__.co_firstlineno.__eq__
  args: [65]
  expected: true

invariant functools_extra221.update_wrapper_varnames_contains_wrapper:
  description: "functools.update_wrapper.__code__.co_varnames.__contains__('wrapper') == True — 'wrapper' is the first parameter; wave 382; new to extra221"
  kind: python_call_eq
  function: update_wrapper.__code__.co_varnames.__contains__
  args: ["wrapper"]
  expected: true

invariant functools_extra221.update_wrapper_co_firstlineno:
  description: "functools.update_wrapper.__code__.co_firstlineno == 35 — update_wrapper begins at line 35 of Lib/functools.py; wave 382; new to extra221"
  kind: python_call_eq
  function: update_wrapper.__code__.co_firstlineno.__eq__
  args: [35]
  expected: true

invariant functools_extra221.lru_cache_varnames_contains_maxsize:
  description: "functools.lru_cache.__code__.co_varnames.__contains__('maxsize') == True — 'maxsize' is the first parameter of lru_cache(); wave 382; new to extra221"
  kind: python_call_eq
  function: lru_cache.__code__.co_varnames.__contains__
  args: ["maxsize"]
  expected: true

invariant functools_extra221.lru_cache_co_firstlineno:
  description: "functools.lru_cache.__code__.co_firstlineno == 553 — lru_cache begins at line 553 of Lib/functools.py; wave 382; new to extra221"
  kind: python_call_eq
  function: lru_cache.__code__.co_firstlineno.__eq__
  args: [553]
  expected: true

invariant functools_extra221.singledispatch_varnames_contains_func:
  description: "functools.singledispatch.__code__.co_varnames.__contains__('func') == True — 'func' is the parameter of singledispatch(); wave 382; new to extra221"
  kind: python_call_eq
  function: singledispatch.__code__.co_varnames.__contains__
  args: ["func"]
  expected: true

invariant functools_extra221.singledispatch_co_firstlineno:
  description: "functools.singledispatch.__code__.co_firstlineno == 875 — singledispatch begins at line 875 of Lib/functools.py; wave 382; new to extra221"
  kind: python_call_eq
  function: singledispatch.__code__.co_firstlineno.__eq__
  args: [875]
  expected: true
