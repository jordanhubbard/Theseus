spec: xtend
version: ">=4.0.0"
backend: node(xtend)

docs: https://github.com/Raynos/xtend#readme

provenance:
  derived_from:
    - "xtend README — https://github.com/Raynos/xtend#readme"
    - "Test vectors verified with xtend via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "xtend source"
  notes:
    - "Tiny immutable Object.assign — extends sources into a fresh object without mutating any input."
    - "Install: npm install xtend"
    - "v4 CJS; default export IS the function (variadic). The package's 'main' field points at the immutable variant."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant xtend.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant xtend.merges_two_objects:
  description: "xtend({a:1}, {b:2}).a is 1"
  category: merge
  kind: node_chain_eq
  entry: module
  entry_args: [{"a": 1}, {"b": 2}]
  chain:
    - {get: a}
  expected: 1

invariant xtend.merges_two_objects_b:
  description: "xtend({a:1}, {b:2}).b is 2"
  category: merge
  kind: node_chain_eq
  entry: module
  entry_args: [{"a": 1}, {"b": 2}]
  chain:
    - {get: b}
  expected: 2

invariant xtend.right_overwrites_left:
  description: "Right-most source wins on conflicting keys"
  category: merge
  kind: node_chain_eq
  entry: module
  entry_args: [{"a": 1}, {"a": 2, "b": 3}]
  chain:
    - {get: a}
  expected: 2

invariant xtend.right_overwrites_keeps_other:
  description: "Other keys are still merged when a key conflict resolves"
  category: merge
  kind: node_chain_eq
  entry: module
  entry_args: [{"a": 1}, {"a": 2, "b": 3}]
  chain:
    - {get: b}
  expected: 3

invariant xtend.empty_args_yield_empty_object:
  description: "xtend() returns an empty object"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain: []
  expected: {}

invariant xtend.three_objects_merged:
  description: "Three sources merge in order; last write wins"
  category: merge
  kind: node_chain_eq
  entry: module
  entry_args: [{"a": 1}, {"b": 2}, {"c": 3}]
  chain:
    - {get: c}
  expected: 3

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:37:14Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
