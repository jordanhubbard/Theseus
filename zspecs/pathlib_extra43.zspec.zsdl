spec: pathlib_extra43
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra42.zspec.zsdl — covers Path.lchmod/replace/group/owner __qualname__.__len__(); PurePath.as_uri __qualname__.__len__(); PurePath.__eq__/__lt__/__hash__/__repr__/__bytes__/__rtruediv__ __qualname__.__len__()."
    - "pathlib_extra39.zspec.zsdl — covers PurePath.__fspath__/__qualname__.__len__()==19; PurePath.__str__/__qualname__.__len__()==16; PurePath.relative_to/is_relative_to/match __qualname__.__len__()."
    - "pathlib_extra33.zspec.zsdl — covers PurePath.__init__.__qualname__=='PurePath.__init__' and PurePath.__init__.__name__=='__init__' via equality checks; Path.__init__.__qualname__=='PurePath.__init__' equality; Path.__truediv__.__qualname__=='PurePath.__truediv__' equality."
    - "pathlib_extra35.zspec.zsdl — covers class __qualname__.__len__() for PosixPath/PurePosixPath/PureWindowsPath/WindowsPath."
  notes:
    - "This spec extends pathlib_extra42.zspec.zsdl."
    - "Prior specs collectively covered: Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __name__/__module__/__qualname__ and lengths; MRO depths for all six classes; __bases__[0].__name__/__len__() for all six; all major Path/PurePath method __qualname__/__len__() and __qualname__.__len__(); PurePath property fget __qualname__.__len__() for name/parent/suffix/stem/parts/drive/root/anchor/parents; Path is_* and lifecycle methods; PurePath dunders __eq__/__lt__/__hash__/__repr__/__bytes__/__rtruediv__/__truediv__/__fspath__/__str__ qualname lengths."
    - "This spec covers: PurePath.__new__/__qualname__.__len__()==16 (NOVEL — pathlib_extra33 checks PurePath.__init__.__qualname__ equality but NOT __new__.__qualname__.__len__(); no prior pathlib spec checks PurePath.__new__.__qualname__.__len__()); PurePath.__init__/__qualname__.__len__()==17 (NOVEL — pathlib_extra33 checks __qualname__=='PurePath.__init__' via equality but NOT __len__()); Path.__new__/__qualname__.__len__()==12 (NOVEL — Path.__new__ is defined directly on Path with __qualname__=='Path.__new__'; no prior pathlib spec checks Path.__new__.__qualname__.__len__()); PurePath.__le__/__qualname__.__len__()==15 (NOVEL — pathlib_extra42 covers PurePath.__eq__/__lt__ but NOT __le__/__gt__/__ge__); PurePath.__gt__/__qualname__.__len__()==15 (NOVEL); PurePath.__ge__/__qualname__.__len__()==15 (NOVEL); PurePath.__slots__.__len__()==8 (NOVEL — no prior pathlib spec checks the count of entries in PurePath.__slots__)."
    - "pathlib.PurePath.__new__.__qualname__ == 'PurePath.__new__' — len 16. pathlib_extra33 covers PurePath.__init__.__qualname__ but not __new__.__qualname__.__len__(). PurePath.__new__ is the object constructor. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__init__.__qualname__ == 'PurePath.__init__' — len 17. pathlib_extra33 verifies the string equality but not the length. Novel as a length check. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.Path.__new__.__qualname__ == 'Path.__new__' — len 12. Path.__new__ is defined directly on Path (it selects PosixPath or WindowsPath at construction time). No prior pathlib spec checks Path.__new__.__qualname__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__le__.__qualname__ == 'PurePath.__le__' — len 15. pathlib_extra42 covers PurePath.__eq__(15) and PurePath.__lt__(15) but not __le__/__gt__/__ge__. All three are 15 chars (same as __eq__/__lt__). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__gt__.__qualname__ == 'PurePath.__gt__' — len 15. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__ge__.__qualname__ == 'PurePath.__ge__' — len 15. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__slots__ has 8 entries: ('_raw_paths', '_drv', '_root', '_tail_cached', '_str', '_str_normcase_cached', '_parts_normcase_cached', '_hash'). No prior pathlib spec checks __slots__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePath.__new__ and PurePath.__init__ __qualname__.__len__()
#
# pathlib_extra33 verifies PurePath.__init__.__qualname__ == 'PurePath.__init__'
# via string equality, and PurePath.__init__.__name__ == '__init__' via equality,
# but no prior pathlib spec checks __len__() for either. PurePath.__new__ has
# never been checked for __qualname__.__len__().
#
#   PurePath.__new__  -> 'PurePath.__new__'  -> 16
#   PurePath.__init__ -> 'PurePath.__init__' -> 17
#
# Both novel as length checks. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra43.PurePath_new_qualname_len:
  description: "len(pathlib.PurePath.__new__.__qualname__) == 16 — 'PurePath.__new__' has 16 characters; pathlib_extra33 covers __init__ qualname equality but not __new__.__qualname__.__len__(); novel"
  category: method_identity
  kind: python_call_eq
  function: PurePath.__new__.__qualname__.__len__
  args: []
  expected: 16

invariant pathlib_extra43.PurePath_init_qualname_len:
  description: "len(pathlib.PurePath.__init__.__qualname__) == 17 — 'PurePath.__init__' has 17 characters; pathlib_extra33 checks equality but not __len__(); novel as a length check"
  category: method_identity
  kind: python_call_eq
  function: PurePath.__init__.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# Path.__new__ __qualname__.__len__()
#
# Path.__new__ is defined directly on Path (not inherited from PurePath) because
# it performs platform dispatch at construction time: on POSIX it returns a
# PosixPath instance. Its __qualname__ is therefore 'Path.__new__' (12 chars),
# shorter than PurePath.__new__ (16 chars). No prior pathlib spec checks
# Path.__new__.__qualname__.__len__(). Novel.
# Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra43.Path_new_qualname_len:
  description: "len(pathlib.Path.__new__.__qualname__) == 12 — 'Path.__new__' has 12 characters; Path.__new__ is defined directly on Path for platform dispatch; novel (no prior pathlib spec checks this length)"
  category: method_identity
  kind: python_call_eq
  function: Path.__new__.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# PurePath.__le__, __gt__, __ge__ __qualname__.__len__()
#
# pathlib_extra42 covers PurePath.__eq__(15) and PurePath.__lt__(15) as part
# of the dunder operator table. The three remaining rich comparison operators
# __le__, __gt__, __ge__ were not included in that spec. All three have
# qualnames of length 15, identical to __eq__ and __lt__ since they share
# the 'PurePath.' prefix (9 chars) and 4-char operator names (__le__, etc.).
#
#   PurePath.__le__ -> 'PurePath.__le__' -> 15
#   PurePath.__gt__ -> 'PurePath.__gt__' -> 15
#   PurePath.__ge__ -> 'PurePath.__ge__' -> 15
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra43.PurePath_remaining_comparison_qualname_lens:
  description: "pathlib.PurePath.__le__/__gt__/__ge__ __qualname__.__len__() == 15 — all novel; pathlib_extra42 covers __eq__/__lt__ but not __le__/__gt__/__ge__; all share 'PurePath.' prefix (9 chars) + 4-char operator name + '__' framing"
  kind: python_call_eq
  category: method_identity
  id_prefix: pprcq43

  columns: [id, function, args, expected]
  rows:
    - [dunder_le, PurePath.__le__.__qualname__.__len__, [], 15]
    - [dunder_gt, PurePath.__gt__.__qualname__.__len__, [], 15]
    - [dunder_ge, PurePath.__ge__.__qualname__.__len__, [], 15]

# ---------------------------------------------------------------------------
# PurePath.__slots__.__len__()
#
# PurePath defines a __slots__ tuple to reduce per-instance memory by avoiding
# __dict__. The slots tuple contains 8 entries on Python 3.12:
#
#   ('_raw_paths', '_drv', '_root', '_tail_cached', '_str',
#    '_str_normcase_cached', '_parts_normcase_cached', '_hash')
#
# No prior pathlib spec checks __slots__.__len__(). This count reflects the
# internal caching design of pathlib.PurePath on Python 3.12.
# Novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra43.PurePath_slots_len:
  description: "len(pathlib.PurePath.__slots__) == 8 — eight slot entries: _raw_paths/_drv/_root/_tail_cached/_str/_str_normcase_cached/_parts_normcase_cached/_hash; novel (no prior pathlib spec checks __slots__.__len__())"
  category: class_structure
  kind: python_call_eq
  function: PurePath.__slots__.__len__
  args: []
  expected: 8
