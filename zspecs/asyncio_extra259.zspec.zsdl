table asyncio_extra259.event_class_identity:
  description: "asyncio.Event(len=5) class identity — inherits from _LoopBoundMixin(len=15); defined in asyncio.locks(len=13); set.__qualname__ len=9 (shortest), wait.__qualname__ len=10, clear.__qualname__ len=11, is_set.__qualname__ len=12 (longest); verified with Python 3.14.3"
