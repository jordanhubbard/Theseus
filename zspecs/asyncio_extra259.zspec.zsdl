invariant asyncio_extra259.event_base_is_loop_bound_mixin:
  description: "asyncio.Event.__bases__[0].__name__.__eq__('_LoopBoundMixin') returns True — Event inherits from _LoopBoundMixin (defined in asyncio.mixins); _LoopBoundMixin.__name__ has length 15; Event and Condition share the same __module__ 'asyncio.locks' (len=13); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Event.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

invariant asyncio_extra259.condition_notify_all_qualname_longest:
  description: "asyncio.Condition.notify_all.__qualname__.__len__() == 20 — 'Condition.notify_all' (len=20) is the longest Condition method qualname; this equals Condition.__bases__[0].__name__.__len__() == 20 ('_ContextManagerMixin'); the four Condition method qualname lengths in order: wait=14, notify=16, wait_for=18, notify_all=20; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Condition.notify_all.__qualname__.__len__
  args: []
  expected: 20

invariant asyncio_extra259.event_and_condition_share_module:
  description: "asyncio.Event.__module__.__eq__('asyncio.locks') returns True — both Event and Condition are defined in asyncio.locks (len=13); Event.__module__ and Condition.__module__ are both 'asyncio.locks'; Event.__module__.__len__() == 13 == Condition.__module__.__len__(); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true
