spec: asyncio_extra259
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "asyncio.Event.__name__ == 'Event' (len=5); __module__ == 'asyncio.locks' (len=13); __bases__[0].__name__ == '_LoopBoundMixin' (len=15)."
    - "Event.set.__qualname__ == 'Event.set' (len=9, shortest); Event.clear.__qualname__ == 'Event.clear' (len=11); Event.wait.__qualname__ == 'Event.wait' (len=10); Event.is_set.__qualname__ == 'Event.is_set' (len=12, longest)."
    - "asyncio.Condition.__name__ == 'Condition' (len=9); __module__ == 'asyncio.locks' (len=13); __bases__ has two elements: _ContextManagerMixin and _LoopBoundMixin; __bases__[0].__name__ == '_ContextManagerMixin' (len=20)."
    - "Condition.wait.__qualname__ == 'Condition.wait' (len=14, shortest Condition method); Condition.notify.__qualname__ == 'Condition.notify' (len=16); Condition.wait_for.__qualname__ == 'Condition.wait_for' (len=18); Condition.notify_all.__qualname__ == 'Condition.notify_all' (len=20, longest)."
    - "asyncio.Condition does NOT have acquire/release as class attributes — it uses async context manager protocol (__aenter__/__aexit__) instead."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

