  category: identity
  id_prefix: async259e

  columns: [id, function, args, expected, description]
  rows:
    - [e_name_eq,          Event.__name__.__eq__,                                  ["Event"],             true, "asyncio.Event.__name__ == 'Event'; verified with Python 3.14.3"]
