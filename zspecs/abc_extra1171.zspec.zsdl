spec: abc_extra1171
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc.__all__.__contains__ checks for ABC/ABCMeta/abstractmethod/abstractproperty/get_cache_token, abc.__all__.__len__ value, abc.abstractclassmethod.__module__ identity, abc.abstractstaticmethod.__module__ identity, abc.ABCMeta.__call__ and __instancecheck__ method qualname/name/class identity, abc.get_cache_token class identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.__all__.__contains__ membership for all key public names, abc.__all__.__len__ value, abc.abstractclassmethod/abstractstaticmethod module identity, abc.ABCMeta.__call__/__instancecheck__ qualnames, abc.get_cache_token class identity — behaviors not covered by extra1141 or extra1156"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1171.all_membership_and_len:
  description: "abc.__all__.__contains__ checks for key public names and abc.__all__.__len__ value"
  kind: python_call_eq
  category: module_membership
  id_prefix: ab1171am
  columns: [id, function, args, expected]
  rows:
    - [ab1171am001, abc.__all__.__contains__, ["ABC"],                 true]
    - [ab1171am002, abc.__all__.__contains__, ["ABCMeta"],             true]
    - [ab1171am003, abc.__all__.__contains__, ["abstractmethod"],      true]
    - [ab1171am004, abc.__all__.__contains__, ["abstractproperty"],    true]
    - [ab1171am005, abc.__all__.__contains__, ["get_cache_token"],     true]
    - [ab1171am006, abc.__all__.__contains__, ["update_abstractmethods"], true]
    - [ab1171am007, abc.__all__.__class__.__name__.__eq__, ["list"],   true]
    - [ab1171am008, abc.__all__.__len__,      [],                      7]

table abc_extra1171.abstractclassmethod_and_staticmethod_identity:
  description: "abc.abstractclassmethod and abc.abstractstaticmethod __module__, __name__, and __qualname__ identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: ab1171cs
  columns: [id, function, args, expected]
  rows:
    - [ab1171cs001, abc.abstractclassmethod.__module__.__eq__,         ["abc"],                       true]
    - [ab1171cs002, abc.abstractclassmethod.__name__.__eq__,           ["abstractclassmethod"],        true]
    - [ab1171cs003, abc.abstractclassmethod.__qualname__.__eq__,       ["abstractclassmethod"],        true]
    - [ab1171cs004, abc.abstractclassmethod.__class__.__name__.__eq__, ["type"],                       true]
    - [ab1171cs005, abc.abstractclassmethod.__doc__.__class__.__name__.__eq__, ["str"],               true]
    - [ab1171cs006, abc.abstractstaticmethod.__module__.__eq__,        ["abc"],                        true]
    - [ab1171cs007, abc.abstractstaticmethod.__name__.__eq__,          ["abstractstaticmethod"],       true]
    - [ab1171cs008, abc.abstractstaticmethod.__qualname__.__eq__,      ["abstractstaticmethod"],       true]
    - [ab1171cs009, abc.abstractstaticmethod.__class__.__name__.__eq__, ["type"],                      true]
    - [ab1171cs010, abc.abstractstaticmethod.__doc__.__class__.__name__.__eq__, ["str"],              true]

table abc_extra1171.abcmeta_call_instancecheck_and_cache_token:
  description: "abc.ABCMeta.__call__ and __instancecheck__ qualname/name/class identity, and abc.get_cache_token class identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: ab1171ci
  columns: [id, function, args, expected]
  rows:
    - [ab1171ci001, abc.ABCMeta.__instancecheck__.__qualname__.__eq__, ["ABCMeta.__instancecheck__"],  true]
    - [ab1171ci002, abc.ABCMeta.__instancecheck__.__name__.__eq__,     ["__instancecheck__"],          true]
    - [ab1171ci003, abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__, ["function"],             true]
    - [ab1171ci004, abc.ABCMeta.__instancecheck__.__module__.__eq__,   ["abc"],                        true]
    - [ab1171ci005, abc.ABCMeta.__subclasscheck__.__qualname__.__eq__, ["ABCMeta.__subclasscheck__"],  true]
    - [ab1171ci006, abc.ABCMeta.__subclasscheck__.__name__.__eq__,     ["__subclasscheck__"],          true]
    - [ab1171ci007, abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__, ["function"],             true]
    - [ab1171ci008, abc.ABCMeta.__subclasscheck__.__module__.__eq__,   ["abc"],                        true]
    - [ab1171ci009, abc.get_cache_token.__class__.__name__.__eq__,     ["builtin_function_or_method"],  true]
    - [ab1171ci010, abc.get_cache_token.__name__.__eq__,               ["get_cache_token"],             true]
    - [ab1171ci011, abc.get_cache_token.__qualname__.__eq__,           ["get_cache_token"],             true]
    - [ab1171ci012, abc.get_cache_token.__module__.__eq__,             ["_abc"],                        true]
