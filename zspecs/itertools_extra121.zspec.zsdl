spec: itertools_extra121
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra120.zspec.zsdl."
    - "This spec covers: itertools.groupby class slot qualname string equality values not yet covered — groupby.__next__.__qualname__.__eq__('groupby.__next__')=True, groupby.__iter__.__qualname__.__eq__('groupby.__iter__')=True, groupby.__new__.__qualname__.__eq__('groupby.__new__')=True; groupby.__new__.__qualname__ len=15; wrapper_descriptor class name for __next__ and __iter__; wave 272."
    - "Prior spec extra30 covered groupby.__iter__.__qualname__.__len__() == 16 and groupby.__next__.__qualname__.__len__() == 16 (length only, not equality). Prior extra109 covered groupby.__new__.__class__.__name__.__eq__('builtin_function_or_method'). New here: string equality via __eq__ for __next__ and __iter__ qualnames, plus __new__.__qualname__ string equality and length."
    - "itertools.groupby.__next__.__qualname__ == 'groupby.__next__' (len 16). Verified with Python 3.14.3."
    - "itertools.groupby.__iter__.__qualname__ == 'groupby.__iter__' (len 16). Verified with Python 3.14.3."
    - "itertools.groupby.__new__.__qualname__ == 'groupby.__new__' (len 15). Verified with Python 3.14.3."
    - "itertools.groupby.__next__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.groupby.__iter__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.groupby.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "groupby.__new__.__qualname__ len = 15: 'groupby'(7) + '.'(1) + '__new__'(7) = 15. One less than __next__ and __iter__ (both 16) because '__new__' has 7 chars while '__next__' and '__iter__' have 8 chars."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.groupby.__next__ and __iter__ slot qualname string equality
#
# Wave 272 theme: itertools.groupby is a C-extension type that groups consecutive
# elements of an iterable by a key function. Prior spec extra30 confirmed that
# groupby.__next__.__qualname__.__len__() == 16 and
# groupby.__iter__.__qualname__.__len__() == 16. New here: the string equality
# check via __eq__ — confirming the exact qualname values rather than just their
# lengths. Both are 'wrapper_descriptor' type slots on the groupby C type.
# 'groupby.__next__' = 7+1+8 = 16 chars; 'groupby.__iter__' = 7+1+8 = 16 chars.
# These share the same length because both slot names ('__next__', '__iter__')
# have 8 characters including the dunder underscores.
#
# groupby.__next__.__qualname__ == 'groupby.__next__'  (len 16)
# groupby.__iter__.__qualname__ == 'groupby.__iter__'  (len 16)
#
# New to extra121.
# ---------------------------------------------------------------------------

table itertools_extra121.groupby_next_iter_qualname_eq:
  description: "itertools.groupby slot qualname equality: __next__='groupby.__next__'(16), __iter__='groupby.__iter__'(16); both wrapper_descriptor; prior extra30 covered lengths only; wave 272; new to extra121"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsgbniq121

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_next_qualname_eq,
       "groupby.__next__.__qualname__.__eq__",
       ["groupby.__next__"],
       true,
       "itertools.groupby.__next__.__qualname__.__eq__('groupby.__next__') == True — groupby exposes its tp_iternext slot as __next__; the qualname is 'groupby.__next__' (16 chars); prior extra30 confirmed len=16; str.__eq__('groupby.__next__') returns True; new to extra121"]
    - [groupby_iter_qualname_eq,
       "groupby.__iter__.__qualname__.__eq__",
       ["groupby.__iter__"],
       true,
       "itertools.groupby.__iter__.__qualname__.__eq__('groupby.__iter__') == True — groupby exposes its tp_iter slot as __iter__; the qualname is 'groupby.__iter__' (16 chars); prior extra30 confirmed len=16; str.__eq__('groupby.__iter__') returns True; new to extra121"]
    - [groupby_next_qualname_len,
       "groupby.__next__.__qualname__.__len__",
       [],
       16,
       "itertools.groupby.__next__.__qualname__.__len__() == 16 — 'groupby.__next__' = groupby(7)+dot(1)+__next__(8) = 16; same length as __iter__ qualname (also 16); extra30 confirmed this; str.__len__() returns 16; new to extra121"]
    - [groupby_next_class_name_eq,
       "groupby.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.groupby.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — the tp_iternext slot on groupby is a wrapper_descriptor; consistent with all other itertools C-iterator __next__ slots; str.__eq__('wrapper_descriptor') returns True; new to extra121"]
    - [groupby_iter_class_name_eq,
       "groupby.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.groupby.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — the tp_iter slot on groupby is a wrapper_descriptor; consistent with all other itertools C-iterator __iter__ slots; str.__eq__('wrapper_descriptor') returns True; new to extra121"]

# ---------------------------------------------------------------------------
# Table 2: itertools.groupby.__new__ qualname string equality and length
#
# Wave 272 theme: itertools.groupby.__new__ is the C-level allocation function
# for the groupby type. Prior spec extra109 covered its class name
# == 'builtin_function_or_method'. New here: the qualname 'groupby.__new__'
# (len 15). The qualname length is 15 = 7+1+7: 'groupby'(7) + '.'(1) +
# '__new__'(7). This differs from __next__ and __iter__ qualnames (both 16)
# because '__new__' has 7 chars while '__next__' and '__iter__' both have 8 chars.
# The qualname class for __new__ is 'builtin_function_or_method' (not
# 'wrapper_descriptor' like __next__ and __iter__).
#
# groupby.__new__.__qualname__ == 'groupby.__new__'  (len 15)
# groupby.__new__.__class__.__name__ == 'builtin_function_or_method'
#
# New to extra121.
# ---------------------------------------------------------------------------

table itertools_extra121.groupby_new_qualname:
  description: "itertools.groupby.__new__ qualname: 'groupby.__new__'(15); 7+1+7=15 (one less than __next__/__iter__ at 16); class is builtin_function_or_method; prior extra109 covered class name; wave 272; new to extra121"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsgbnwq121

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_new_qualname_eq,
       "groupby.__new__.__qualname__.__eq__",
       ["groupby.__new__"],
       true,
       "itertools.groupby.__new__.__qualname__.__eq__('groupby.__new__') == True — groupby exposes its tp_new slot as __new__; qualname is 'groupby.__new__' (15 chars); str.__eq__('groupby.__new__') returns True; new to extra121"]
    - [groupby_new_qualname_len,
       "groupby.__new__.__qualname__.__len__",
       [],
       15,
       "itertools.groupby.__new__.__qualname__.__len__() == 15 — 'groupby.__new__' = groupby(7)+dot(1)+__new__(7) = 15; one less than __next__ and __iter__ qualnames (16) because '__new__' is 7 chars vs 8; str.__len__() returns 15; new to extra121"]
    - [groupby_new_class_name_eq,
       "groupby.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.groupby.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — the tp_new slot is a builtin_function_or_method, unlike __next__ and __iter__ which are wrapper_descriptors; prior extra109 confirmed this; str.__eq__('builtin_function_or_method') returns True; new to extra121"]
    - [groupby_new_vs_next_len_diff,
       "groupby.__iter__.__qualname__.__len__",
       [],
       16,
       "itertools.groupby.__iter__.__qualname__.__len__() == 16 — confirming that __iter__ qualname (16) is one longer than __new__ qualname (15); the difference arises because '__iter__' is 8 chars vs '__new__' 7 chars; str.__len__() returns 16; new to extra121"]
    - [groupby_name_len,
       "groupby.__name__.__len__",
       [],
       7,
       "itertools.groupby.__name__.__len__() == 7 — 'groupby' has 7 chars: g-r-o-u-p-b-y; this drives all slot qualname lengths: 7+1+8=16 for __next__/__iter__, 7+1+7=15 for __new__; str.__len__() returns 7; new to extra121"]

# ---------------------------------------------------------------------------
# Table 3: itertools.groupby slot qualname length cross-comparison
#
# Wave 272 theme: A cross-comparison of all three groupby slot qualname lengths
# against other itertools types with 7-char names. Both 'groupby' (7 chars) and
# 'starmap' (7 chars) and 'product' (7 chars) have the same name length. Their
# __next__ slot qualnames are all 16 chars (7+1+8). However, their __new__
# qualnames would be 15 chars (7+1+7). This table establishes that groupby's
# __next__.__qualname__ length (16) equals product.__next__.__qualname__ length
# (16, from extra120) and starmap.__next__.__qualname__ length (16, from extra119),
# confirming the formula: qualname_len = class_name_len + 1 + slot_name_len.
#
# groupby.__next__.__qualname__.__len__() == 16
# product.__next__.__qualname__.__len__() == 16 (extra120)
# groupby.__new__.__qualname__.__len__()  == 15
#
# New to extra121.
# ---------------------------------------------------------------------------

table itertools_extra121.groupby_slot_qualname_length_comparison:
  description: "itertools.groupby slot qualname length comparison: __next__ len=16, __iter__ len=16, __new__ len=15; equal to product/__next__ (extra120) and starmap/__next__ (extra119); formula class_len+1+slot_len; wave 272; new to extra121"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolsgbslc121

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_next_len_16,
       "groupby.__next__.__qualname__.__len__",
       [],
       16,
       "itertools.groupby.__next__.__qualname__.__len__() == 16 — formula: 'groupby'(7)+dot(1)+'__next__'(8)=16; equal to product.__next__ qualname len (extra120) because both class names are 7 chars; str.__len__() returns 16; new to extra121"]
    - [groupby_iter_len_16,
       "groupby.__iter__.__qualname__.__len__",
       [],
       16,
       "itertools.groupby.__iter__.__qualname__.__len__() == 16 — formula: 'groupby'(7)+dot(1)+'__iter__'(8)=16; equal to __next__ qualname length because '__iter__' and '__next__' share the same 8-char length; str.__len__() returns 16; new to extra121"]
    - [groupby_new_len_15,
       "groupby.__new__.__qualname__.__len__",
       [],
       15,
       "itertools.groupby.__new__.__qualname__.__len__() == 15 — formula: 'groupby'(7)+dot(1)+'__new__'(7)=15; one less than __next__/__iter__ (16) because '__new__' is 7 chars; str.__len__() returns 15; new to extra121"]
    - [groupby_next_qualname_ne_new,
       "groupby.__next__.__qualname__.__eq__",
       ["groupby.__new__"],
       false,
       "itertools.groupby.__next__.__qualname__.__eq__('groupby.__new__') == False — __next__ qualname is 'groupby.__next__', not 'groupby.__new__'; confirming they are distinct slot names; str.__eq__('groupby.__new__') returns False; new to extra121"]
    - [groupby_name_eq,
       "groupby.__name__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__name__.__eq__('groupby') == True — the class is named 'groupby'; 7 chars; base for computing all slot qualname lengths; str.__eq__('groupby') returns True; new to extra121"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra121
# ---------------------------------------------------------------------------

invariant itertools_extra121.groupby_next_qualname_eq:
  description: "itertools.groupby.__next__.__qualname__ == 'groupby.__next__' — tp_iternext slot; len=16; prior extra30 covered len only; wave 272; new to extra121"
  kind: python_call_eq
  function: groupby.__next__.__qualname__.__eq__
  args: ["groupby.__next__"]
  expected: true

invariant itertools_extra121.groupby_iter_qualname_eq:
  description: "itertools.groupby.__iter__.__qualname__ == 'groupby.__iter__' — tp_iter slot; len=16; same length as __next__ qualname; wave 272; new to extra121"
  kind: python_call_eq
  function: groupby.__iter__.__qualname__.__eq__
  args: ["groupby.__iter__"]
  expected: true

invariant itertools_extra121.groupby_new_qualname_eq:
  description: "itertools.groupby.__new__.__qualname__ == 'groupby.__new__' — tp_new slot; len=15; one less than __next__/__iter__ (16); wave 272; new to extra121"
  kind: python_call_eq
  function: groupby.__new__.__qualname__.__eq__
  args: ["groupby.__new__"]
  expected: true

invariant itertools_extra121.groupby_new_qualname_len:
  description: "itertools.groupby.__new__.__qualname__.__len__() == 15 — 'groupby.__new__' = 7+1+7=15; one less than __next__/__iter__ at 16; wave 272; new to extra121"
  kind: python_call_eq
  function: groupby.__new__.__qualname__.__len__
  args: []
  expected: 15

invariant itertools_extra121.groupby_next_class_wrapper_descriptor:
  description: "itertools.groupby.__next__.__class__.__name__ == 'wrapper_descriptor' — tp_iternext slot type; consistent with all itertools C-iterator __next__ slots; wave 272; new to extra121"
  kind: python_call_eq
  function: groupby.__next__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
