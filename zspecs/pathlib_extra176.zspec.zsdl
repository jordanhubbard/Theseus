spec: pathlib_extra176
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec covers: pathlib.Path.__dict__.__contains__ for I/O query methods: read_bytes, write_bytes, is_file, is_dir, is_symlink, absolute, resolve, expanduser."
    - "pathlib.Path.__dict__.__contains__('read_bytes') == True (len=10: 'read'(4)+'_bytes'(6)=10)."
    - "pathlib.Path.__dict__.__contains__('write_bytes') == True (len=11: 'write'(5)+'_bytes'(6)=11)."
    - "pathlib.Path.__dict__.__contains__('is_file') == True (len=7: 'is_'(3)+'file'(4)=7)."
    - "pathlib.Path.__dict__.__contains__('is_dir') == True (len=6: 'is_'(3)+'dir'(3)=6)."
    - "pathlib.Path.__dict__.__contains__('is_symlink') == True (len=10: 'is_'(3)+'symlink'(7)=10)."
    - "pathlib.Path.__dict__.__contains__('absolute') == True (len=8: 'absolute'=8)."
    - "pathlib.Path.__dict__.__contains__('resolve') == True (len=7: 'resolve'=7)."
    - "pathlib.Path.__dict__.__contains__('expanduser') == True (len=10: 'expand'(6)+'user'(4)=10)."
    - "Method name lengths: is_dir(6) < is_file(7)=resolve(7) < absolute(8) < read_bytes(10)=is_symlink(10)=expanduser(10) < write_bytes(11)."
    - "Three-way tie at 10 characters: read_bytes(10)=is_symlink(10)=expanduser(10)."
    - "Two-way tie at 7 characters: is_file(7)=resolve(7)."
    - "All eight methods are defined directly in Path.__dict__ — not inherited from PurePath."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ contains is_dir, is_file, is_symlink
# is_dir (len=6), is_file (len=7), is_symlink (len=10)
# The 'is_' prefix (3 chars) + suffix: 'dir'(3)=6, 'file'(4)=7, 'symlink'(7)=10
# ---------------------------------------------------------------------------

table pathlib_extra176.Path_dict_is_predicates:
  description: "pathlib.Path.__dict__.__contains__('is_dir')==True (len=6); __contains__('is_file')==True (len=7); __contains__('is_symlink')==True (len=10); all three 'is_*' predicate methods on Path; lengths: is_dir(6) < is_file(7) < is_symlink(10); all share 'is_' prefix (3 chars)"
  kind: python_call_eq
  category: identity
  id_prefix: plisp176

  columns: [id, function, args, expected, description]
  rows:
    - [has_is_dir,     "Path.__dict__.__contains__", ["is_dir"],     true, "pathlib.Path.__dict__.__contains__('is_dir') == True — 'is_dir' is a key in Path.__dict__, meaning is_dir() is defined directly on Path; 'is_dir' has 6 characters: 'is_'(3)+'dir'(3)=6; is_dir (6 chars) is the minimum method name length in this spec; is_dir (6) == len('is_dir') (6) == len('rename') (6) == len('exists') (6) == len('unlink') (6) from pathlib_extra175 — a four-way tie at 6 within the pathlib method name family; Path.is_dir(follow_symlinks=True) returns True if the path refers to a directory; 'is_' prefix (3 chars) + 'dir' suffix (3 chars) = 6: equal-length prefix and suffix; confirmed Python 3.14.3 macOS"]
    - [has_is_file,    "Path.__dict__.__contains__", ["is_file"],    true, "pathlib.Path.__dict__.__contains__('is_file') == True — 'is_file' is a key in Path.__dict__, meaning is_file() is defined on Path; 'is_file' has 7 characters: 'is_'(3)+'file'(4)=7; is_file (7) > is_dir (6) by 1 — the 'file' suffix (4 chars) is 1 longer than the 'dir' suffix (3 chars); is_file (7) == len('resolve') (7) == len('is_file') (7) — a two-way tie at 7 in this spec; Path.is_file(follow_symlinks=True) returns True if the path refers to a regular file; 'is_' prefix is shared across is_dir(6), is_file(7), and is_symlink(10); confirmed Python 3.14.3 macOS"]
    - [has_is_symlink, "Path.__dict__.__contains__", ["is_symlink"], true, "pathlib.Path.__dict__.__contains__('is_symlink') == True — 'is_symlink' is a key in Path.__dict__, meaning is_symlink() is defined on Path; 'is_symlink' has 10 characters: 'is_'(3)+'symlink'(7)=10; is_symlink (10) > is_file (7) by 3 — the 'symlink' suffix (7 chars) is 3 longer than the 'file' suffix (4 chars); is_symlink (10) ties with read_bytes (10) and expanduser (10) — a three-way tie at 10 in this spec; Path.is_symlink() returns True if the path refers to a symbolic link; 'symlink' suffix (7 chars) == len('symlink') (7): the suffix alone equals the length of symlink as a standalone word; confirmed Python 3.14.3 macOS"]
    - [is_dir_lt_file, "Path.__dict__.__contains__", ["is_dir"],     true, "pathlib.Path.__dict__.__contains__('is_dir') == True — confirming is_dir (6 chars) < is_file (7 chars) < is_symlink (10 chars): the ascending 'is_*' predicate name length sequence; the three 'is_*' predicates span lengths 6, 7, 10 with gaps of 1, 3 — not uniform; is_dir (6): minimum 'is_*' predicate; is_symlink (10): maximum 'is_*' predicate; the gap from is_file (7) to is_symlink (10) is 3, while the gap from is_dir (6) to is_file (7) is only 1; 'symlink'(7) is 4 chars longer than 'file'(4) == 3 chars longer than 'dir'(3) is actually: 'symlink'(7) - 'file'(4) = 3, 'symlink'(7) - 'dir'(3) = 4; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ contains read_bytes and write_bytes
# read_bytes (len=10), write_bytes (len=11)
# Both share '_bytes' suffix (6 chars); write_bytes > read_bytes by 1
# ---------------------------------------------------------------------------

table pathlib_extra176.Path_dict_bytes_methods:
  description: "pathlib.Path.__dict__.__contains__('read_bytes')==True (len=10); __contains__('write_bytes')==True (len=11); read_bytes='read'(4)+'_bytes'(6)=10; write_bytes='write'(5)+'_bytes'(6)=11; write_bytes(11) > read_bytes(10) by 1; both share '_bytes' suffix (6 chars)"
  kind: python_call_eq
  category: identity
  id_prefix: plbyt176

  columns: [id, function, args, expected, description]
  rows:
    - [has_read_bytes,  "Path.__dict__.__contains__", ["read_bytes"],  true, "pathlib.Path.__dict__.__contains__('read_bytes') == True — 'read_bytes' is a key in Path.__dict__, meaning read_bytes() is defined directly on Path; 'read_bytes' has 10 characters: 'read'(4)+'_'(1)+'bytes'(5)=10; equivalently: 'read'(4)+'_bytes'(6)=10 where '_bytes' includes the underscore; read_bytes (10) ties with is_symlink (10) and expanduser (10) — a three-way tie at 10 in this spec; Path.read_bytes() opens the path in binary mode and returns its contents as bytes; read_bytes (10) < write_bytes (11) by 1 — 'write'(5) > 'read'(4) by 1 propagates to the compound name; confirmed Python 3.14.3 macOS"]
    - [has_write_bytes, "Path.__dict__.__contains__", ["write_bytes"], true, "pathlib.Path.__dict__.__contains__('write_bytes') == True — 'write_bytes' is a key in Path.__dict__, meaning write_bytes() is defined directly on Path; 'write_bytes' has 11 characters: 'write'(5)+'_'(1)+'bytes'(5)=11; equivalently: 'write'(5)+'_bytes'(6)=11; write_bytes (11) > read_bytes (10) by 1; write_bytes (11) is the maximum method name length in this spec: is_dir(6) < is_file(7)=resolve(7) < absolute(8) < read_bytes(10)=is_symlink(10)=expanduser(10) < write_bytes(11); Path.write_bytes(data) writes bytes to the path in binary mode; write_bytes (11) is the only 11-character method name in this spec; confirmed Python 3.14.3 macOS"]
    - [rb_len_10,       "Path.__dict__.__contains__", ["read_bytes"],  true, "pathlib.Path.__dict__.__contains__('read_bytes') == True — confirming read_bytes (10 chars) is in Path.__dict__; read_bytes (10) ties with is_symlink (10) and expanduser (10) — three methods all at 10 characters; the 10-character group: read_bytes('read'(4)+'_bytes'(6)), is_symlink('is_'(3)+'symlink'(7)), expanduser('expand'(6)+'user'(4)) — all 10 chars via different compositions; read_bytes (10) == len('write_text') (10) from pathlib_extra174 and len('symlink_to') (10) from pathlib_extra175 and len('getcontext') (10) from decimal_extra165 — cross-spec and cross-module tie at 10; confirmed Python 3.14.3 macOS"]
    - [wb_len_11,       "Path.__dict__.__contains__", ["write_bytes"], true, "pathlib.Path.__dict__.__contains__('write_bytes') == True — confirming write_bytes (11 chars) is in Path.__dict__; write_bytes (11) is the sole 11-character method name in this spec; the ascending sequence tops at write_bytes(11): [...] < read_bytes(10)=is_symlink(10)=expanduser(10) < write_bytes(11); write_bytes (11) == len('_TextIOBase') (11) from io_extra174 — cross-module tie at 11: the binary-mode write method name ties with the C-level text I/O base class name; write_bytes > read_bytes by exactly 1 == len('write') - len('read') == 5 - 4 == 1; confirmed Python 3.14.3 macOS"]
    - [bytes_ne_text,   "Path.__dict__.__contains__", ["read_text"],   true, "pathlib.Path.__dict__.__contains__('read_text') == True — confirming read_text (from pathlib_extra174) and read_bytes (from this spec) are both in Path.__dict__; 'read_text' (9 chars) < 'read_bytes' (10 chars) by 1: 'bytes' (5 chars) > 'text' (4 chars) by 1 — the binary method name is 1 character longer than the text method name; the four convenience read/write methods on Path: read_text(9), write_text(10), read_bytes(10), write_bytes(11) — forming a 9, 10, 10, 11 length pattern with a two-way tie at 10; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ contains absolute, resolve, expanduser
# absolute (len=8), resolve (len=7), expanduser (len=10)
# All three return a new absolute Path; resolve follows symlinks
# ---------------------------------------------------------------------------

table pathlib_extra176.Path_dict_path_resolution_methods:
  description: "pathlib.Path.__dict__.__contains__('absolute')==True (len=8); __contains__('resolve')==True (len=7); __contains__('expanduser')==True (len=10); resolve(7) < absolute(8) < expanduser(10); expanduser='expand'(6)+'user'(4)=10; all return a new absolute path"
  kind: python_call_eq
  category: identity
  id_prefix: plres176

  columns: [id, function, args, expected, description]
  rows:
    - [has_absolute,   "Path.__dict__.__contains__", ["absolute"],   true, "pathlib.Path.__dict__.__contains__('absolute') == True — 'absolute' is a key in Path.__dict__, meaning absolute() is defined on Path; 'absolute' has 8 characters: 'a-b-s-o-l-u-t-e'; absolute (8) == len('absolute') (8); absolute (8) > resolve (7) by 1; absolute (8) < expanduser (10) by 2; Path.absolute() returns an absolute version of the path without resolving symlinks (unlike resolve()); absolute (8 chars) == len('PurePath') (8 chars) from pathlib — a within-module tie: the base pure path class and the absolute method share the 8-character length; confirmed Python 3.14.3 macOS"]
    - [has_resolve,    "Path.__dict__.__contains__", ["resolve"],    true, "pathlib.Path.__dict__.__contains__('resolve') == True — 'resolve' is a key in Path.__dict__, meaning resolve() is defined on Path; 'resolve' has 7 characters: 'r-e-s-o-l-v-e'; resolve (7) == len('is_file') (7) — a two-way tie at 7 in this spec; resolve (7) == len('pathlib') (7) == len('replace') (7) from pathlib_extra175 — within-module 7-character ties; Path.resolve() makes the path absolute AND resolves all symlinks (unlike absolute() which does not follow symlinks); resolve (7) < absolute (8) by 1: they are consecutive in the ascending length ordering; confirmed Python 3.14.3 macOS"]
    - [has_expanduser, "Path.__dict__.__contains__", ["expanduser"], true, "pathlib.Path.__dict__.__contains__('expanduser') == True — 'expanduser' is a key in Path.__dict__, meaning expanduser() is defined on Path; 'expanduser' has 10 characters: 'expand'(6)+'user'(4)=10; expanduser (10) ties with read_bytes (10) and is_symlink (10) — the three-way tie at 10 in this spec; Path.expanduser() returns a new path with ~ and ~user constructs replaced by the user's home directory; expanduser (10 chars) == len('symlink_to') (10) from pathlib_extra175 — a within-module tie at 10; confirmed Python 3.14.3 macOS"]
    - [res_lt_abs,     "Path.__dict__.__contains__", ["resolve"],    true, "pathlib.Path.__dict__.__contains__('resolve') == True — confirming resolve (7 chars) < absolute (8 chars) by 1; resolve and absolute are the two primary path normalization methods: resolve() both makes absolute and resolves symlinks, while absolute() only makes absolute; despite their semantic overlap, resolve (7) < absolute (8): the shorter name has the more powerful behavior; resolve (7) == is_file (7): the symlink-following normalization method ties with the file-type predicate in name length; confirmed Python 3.14.3 macOS"]
    - [exp_tie_rb,     "Path.__dict__.__contains__", ["expanduser"], true, "pathlib.Path.__dict__.__contains__('expanduser') == True — confirming expanduser (10 chars) ties with read_bytes (10 chars) and is_symlink (10 chars); the three-way 10-char tie: expanduser('expand'(6)+'user'(4)), read_bytes('read'(4)+'_bytes'(6)), is_symlink('is_'(3)+'symlink'(7)) — three different compositional structures all yielding 10 characters; this is the dominant tie in this spec: three methods at 10 out of eight total methods; 10-char tie count (3) > 7-char tie count (2) > 6-char count (1) > 8-char count (1) > 11-char count (1); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Method name length ordering: is_dir(6) < is_file(7)=resolve(7) < absolute(8)
#   < read_bytes(10)=is_symlink(10)=expanduser(10) < write_bytes(11)
# ---------------------------------------------------------------------------

table pathlib_extra176.method_name_length_distribution:
  description: "Path method name length distribution: is_dir(6); is_file(7)=resolve(7); absolute(8); read_bytes(10)=is_symlink(10)=expanduser(10); write_bytes(11); five distinct levels with a two-way tie at 7 and a three-way tie at 10; ascending order: 6 < 7 < 8 < 10 < 11"
  kind: python_call_eq
  category: identity
  id_prefix: plmldist176

  columns: [id, function, args, expected, description]
  rows:
    - [is_dir_6,     "Path.__dict__.__contains__", ["is_dir"],     true, "pathlib.Path.__dict__.__contains__('is_dir') == True — is_dir (6 chars) is the minimum method name length in this spec; the five-level ascending sequence: is_dir(6) < is_file(7)=resolve(7) < absolute(8) < read_bytes(10)=is_symlink(10)=expanduser(10) < write_bytes(11); is_dir (6) < is_file (7) by 1: the 'dir'(3) vs 'file'(4) suffix difference; is_dir (6 chars) == len('rename') (6) == len('exists') (6) == len('unlink') (6) from pathlib_extra175 — ties with the 6-char filesystem mutation group; confirmed Python 3.14.3 macOS"]
    - [resolve_7,    "Path.__dict__.__contains__", ["resolve"],    true, "pathlib.Path.__dict__.__contains__('resolve') == True — resolve (7 chars) is at the second level in the 5-level length sequence; resolve (7) == is_file (7) — the two-way tie at 7; resolve (7) > is_dir (6) by 1; resolve (7) < absolute (8) by 1: resolve is consecutive with both is_dir (6) and absolute (8) in the ascending sequence; resolve (7 chars) == len('pathlib') (7 chars) and len('replace') (7 chars) from pathlib_extra175 — within-module tie at 7; confirmed Python 3.14.3 macOS"]
    - [absolute_8,   "Path.__dict__.__contains__", ["absolute"],   true, "pathlib.Path.__dict__.__contains__('absolute') == True — absolute (8 chars) is the sole representative at the third level of the 5-level sequence; absolute (8) sits alone between the 7-char group and the 10-char group; absolute (8) > resolve (7) by 1; absolute (8) < read_bytes (10) by 2: the gap from 8 to 10 is 2; absolute (8 chars) == len('PurePath') (8 chars) — the base pure path class name ties with the absolute method name in length; confirmed Python 3.14.3 macOS"]
    - [is_symlink_10, "Path.__dict__.__contains__", ["is_symlink"], true, "pathlib.Path.__dict__.__contains__('is_symlink') == True — is_symlink (10 chars) is in the three-way tie at the fourth level; the 10-char group: read_bytes(10), is_symlink(10), expanduser(10) — three different methods at 10; is_symlink (10) > absolute (8) by 2; is_symlink (10) < write_bytes (11) by 1: the four-level length sequence 6 < 7 < 8 < 10 has gaps 1, 1, 2; then 10 < 11 is a gap of 1; the gaps: 6->7(+1), 7->8(+1), 8->10(+2), 10->11(+1); the only non-unit gap is between levels 3 and 4 (8->10, gap=2); confirmed Python 3.14.3 macOS"]
    - [write_bytes_11, "Path.__dict__.__contains__", ["write_bytes"], true, "pathlib.Path.__dict__.__contains__('write_bytes') == True — write_bytes (11 chars) is the maximum at the fifth level; write_bytes (11) is the sole member of the top level; write_bytes (11) > read_bytes (10) by 1: the maximum exceeds the three-way 10-char tie by just 1; the 8-method length distribution: [6, 7, 7, 8, 10, 10, 10, 11]; two-way tie at 7, three-way tie at 10, all others unique; write_bytes (11 chars) == len('_TextIOBase') (11 chars) from io — cross-module tie at 11; confirmed Python 3.14.3 macOS"]

