spec: socket_extra92
version: ">=3.9"
extends: socket_extra91
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra91.zspec.zsdl — covers socket module string identity cross-checks / socket.socket dunder method class names / socket constant class names and integer values (table + invariants)."
    - "socket_extra90.zspec.zsdl — covers socket.socket Python-level method __class__.__name__ identity (accept/close/makefile/__init__/sendfile etc. all 'function') (table + invariants)."
    - "socket_extra89.zspec.zsdl — covers socket module integer constants class identity (AF_INET/AF_INET6 AddressFamily, SOCK_DGRAM/SOCK_RAW SocketKind, IPPROTO_TCP/IPPROTO_UDP int) (table + invariants)."
    - "socket_extra88.zspec.zsdl — covers socket.socket.__dict__ negative membership / AddressFamily and SocketKind class identity (__qualname__/__module__/__mro__.__len__()==6/__name__) (table + invariants)."
    - "socket_extra86.zspec.zsdl — covers socket.socket/__module__/__qualname__/__mro__.__len__()==3/__bases__[0].__name__ / AF_INET/SOCK_STREAM class identity / AddressFamily/SocketKind __bases__[0].__name__/__qualname__ (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra91; it does NOT duplicate invariants present in those files."
    - "Wave 256 theme: socket.socket class identity and socket.error / socket.timeout / socket.herror / socket.gaierror exception hierarchy."
    - "socket.socket.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__qualname__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__mro__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__mro__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.error.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__name__ == 'TimeoutError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__bases__[0].__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__mro__.__len__() == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.timeout.__module__ == 'builtins'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__name__ == 'herror'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__bases__[0].__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__mro__.__len__() == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.herror.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__name__ == 'gaierror'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__bases__[0].__name__ == 'OSError'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__mro__.__len__() == 5. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gaierror.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__bases__[0].__name__ == 'IntEnum'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket Python wrapper (in Lib/socket.py) inherits from _socket.socket (C extension); thus socket.socket.__bases__[0].__name__ is 'socket' and __mro__.__len__() is 3."
    - "Note: socket.error is an alias for OSError (builtins); socket.timeout is an alias for TimeoutError (builtins); socket.herror/gaierror are socket-specific Exception subclasses."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket')
# socket.socket.__module__.__eq__('socket')
# socket.socket.__qualname__.__eq__('socket')
#
# Wave 256 theme: socket.socket class string identity.
#
# socket.socket.__name__, __module__, and __qualname__ are all 'socket'. The
# Python-level socket class in socket.py has the same name as the module.
# socket_extra86 anchors __module__/__qualname__; this table groups all three
# together under socketsocketcls92. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra92.socket_class_string_identity:
  description: "socket.socket.__name__.__eq__('socket')==True / socket.__module__.__eq__('socket')==True / socket.__qualname__.__eq__('socket')==True — socket.socket's __name__, __module__, and __qualname__ are all 'socket'; socket_extra86 anchors __module__/__qualname__; this table groups all three under socketsocketcls92; first socketsocketcls92 anchor for socket.socket string identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: socketsocketcls92

  columns: [id, function, args, expected]
  rows:
    - [socket_class_name_eq,     socket.__name__.__eq__,     ["socket"], true]
    - [socket_class_module_eq,   socket.__module__.__eq__,   ["socket"], true]
    - [socket_class_qualname_eq, socket.__qualname__.__eq__,  ["socket"], true]

# ---------------------------------------------------------------------------
# socket.socket.__bases__[0].__name__.__eq__('socket')
# socket.socket.__mro__.__len__()==3
#
# Wave 256 theme: socket.socket class hierarchy.
#
# socket.socket (Python wrapper) inherits from _socket.socket (C extension),
# whose __name__ is also 'socket'. The MRO is [socket.socket, _socket.socket,
# object] with length 3. socket_extra86 first anchors both __bases__[0].__name__
# and __mro__.__len__(); this table cross-checks them together under socketsocketcls92.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra92.socket_class_hierarchy:
  description: "socket.socket/__bases__[0]/__name__.__eq__('socket')==True / socket/__mro__/__len__()==3 — socket.socket (Python wrapper) inherits from _socket.socket (C extension); MRO is [socket.socket, _socket.socket, object] with length 3; socket_extra86 first anchors both; this table cross-checks under socketsocketcls92; first socketsocketcls92 anchor for socket.socket hierarchy"
  kind: python_call_eq
  category: type_identity
  id_prefix: socketsocketcls92

  columns: [id, function, args, expected]
  rows:
    - ["socket_bases0_name_eq", "socket.__bases__[0].__name__.__eq__", ["socket"], true]
    - [socket_mro_len,          socket.__mro__.__len__,                [],         3]

# ---------------------------------------------------------------------------
# socket.error.__bases__[0].__name__.__eq__('Exception') / __mro__.__len__()==4
# socket.timeout.__bases__[0].__name__.__eq__('OSError') / __mro__.__len__()==5
# socket.herror.__bases__[0].__name__.__eq__('OSError') / __mro__.__len__()==5
# socket.gaierror.__bases__[0].__name__.__eq__('OSError') / __mro__.__len__()==5
#
# Wave 256 theme: socket error exception base classes and MRO lengths.
#
# socket.error is OSError (Exception base, MRO len 4). socket.timeout is
# TimeoutError (OSError base, MRO len 5). socket.herror and socket.gaierror
# are socket-specific Exception subclasses (OSError base, MRO len 5 each).
# No prior socket spec anchors these four together under socketsocketcls92.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra92.socket_exception_hierarchy:
  description: "socket.error/__bases__[0]/__name__.__eq__('Exception')==True / error/__mro__/__len__()==4 / timeout/__bases__[0]/__name__.__eq__('OSError')==True / timeout/__mro__/__len__()==5 / herror/__bases__[0]/__name__.__eq__('OSError')==True / herror/__mro__/__len__()==5 / gaierror/__bases__[0]/__name__.__eq__('OSError')==True / gaierror/__mro__/__len__()==5 — socket.error==OSError(MRO 4); socket.timeout==TimeoutError/socket.herror/socket.gaierror are OSError subclasses (MRO 5); no prior socket spec anchors these together; first socketsocketcls92 anchor for socket exception hierarchy"
  kind: python_call_eq
  category: type_identity
  id_prefix: socketsocketcls92

  columns: [id, function, args, expected]
  rows:
    - ["error_bases0_name_eq",   "error.__bases__[0].__name__.__eq__",   ["Exception"], true]
    - [error_mro_len,            error.__mro__.__len__,                  [],            4]
    - ["timeout_bases0_name_eq", "timeout.__bases__[0].__name__.__eq__", ["OSError"],   true]
    - [timeout_mro_len,          timeout.__mro__.__len__,                [],            5]
    - ["herror_bases0_name_eq",  "herror.__bases__[0].__name__.__eq__",  ["OSError"],   true]
    - [herror_mro_len,           herror.__mro__.__len__,                 [],            5]
    - ["gaierror_bases0_name_eq","gaierror.__bases__[0].__name__.__eq__",["OSError"],   true]
    - [gaierror_mro_len,         gaierror.__mro__.__len__,               [],            5]

# ---------------------------------------------------------------------------
# socket.AddressFamily.__name__.__eq__('AddressFamily')
# socket.AddressFamily.__module__.__eq__('socket')
# socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum')
# socket.SocketKind.__name__.__eq__('SocketKind')
# socket.SocketKind.__module__.__eq__('socket')
# socket.SocketKind.__bases__[0].__name__.__eq__('IntEnum')
#
# Wave 256 theme: AddressFamily and SocketKind enum class identity.
#
# socket.AddressFamily and socket.SocketKind are both IntEnum subclasses defined
# in the socket module. socket_extra88 first anchors their __name__, __qualname__,
# __module__, and __mro__.__len__()==6; this table cross-checks __name__, __module__,
# and __bases__[0].__name__ for both together under socketsocketcls92.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra92.address_family_socket_kind_identity:
  description: "socket.AddressFamily.__name__.__eq__('AddressFamily')==True / AddressFamily.__module__.__eq__('socket')==True / AddressFamily/__bases__[0]/__name__.__eq__('IntEnum')==True / SocketKind.__name__.__eq__('SocketKind')==True / SocketKind.__module__.__eq__('socket')==True / SocketKind/__bases__[0]/__name__.__eq__('IntEnum')==True — AddressFamily and SocketKind are IntEnum subclasses defined in socket; socket_extra88 first anchors __name__/__module__/__mro__.__len__; this table cross-checks __name__/__module__/__bases__[0].__name__ together; first socketsocketcls92 anchor for AddressFamily/SocketKind identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: socketsocketcls92

  columns: [id, function, args, expected]
  rows:
    - [af_name_eq,               AddressFamily.__name__.__eq__,                       ["AddressFamily"], true]
    - [af_module_eq,             AddressFamily.__module__.__eq__,                     ["socket"],        true]
    - ["af_bases0_name_eq",      "AddressFamily.__bases__[0].__name__.__eq__",        ["IntEnum"],       true]
    - [sk_name_eq,               SocketKind.__name__.__eq__,                          ["SocketKind"],    true]
    - [sk_module_eq,             SocketKind.__module__.__eq__,                        ["socket"],        true]
    - ["sk_bases0_name_eq",      "SocketKind.__bases__[0].__name__.__eq__",           ["IntEnum"],       true]

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket') — standalone
#
# socket.socket.__name__ is 'socket'. socket_extra86 first anchors __qualname__
# for the socket class; this standalone anchors __name__ under socketsocketcls92.
# The Python-level socket.socket class shares its name with the module itself.
# First standalone for socket.socket.__name__ under socketsocketcls92.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra92.socket_class_name_eq:
  description: "socket.socket.__name__.__eq__('socket') == True — socket.socket (Python wrapper class) has __name__ 'socket'; it shares the name with the module; socket_extra86 first anchors __qualname__ for the socket class; first standalone for socket.socket.__name__ under socketsocketcls92"
  category: type_identity
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__mro__.__len__() == 3 — standalone
#
# socket.socket.__mro__.__len__() is 3. The MRO is [socket.socket, _socket.socket,
# object]. socket_extra86 first anchors this; this standalone re-anchors under
# socketsocketcls92. First standalone for socket.socket MRO length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra92.socket_mro_len:
  description: "socket.socket.__mro__.__len__() == 3 — socket.socket (Python wrapper) inherits from _socket.socket (C extension); the MRO is [socket.socket, _socket.socket, object] with length 3; socket_extra86 first anchors this; first standalone for socket.socket MRO length under socketsocketcls92"
  category: type_identity
  kind: python_call_eq
  function: socket.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# socket.error.__mro__.__len__() == 4 — standalone
#
# socket.error is an alias for OSError. Its MRO is [OSError, Exception,
# BaseException, object] with length 4. No prior socket spec anchors
# error.__mro__.__len__ as a standalone under socketsocketcls92.
# First standalone for socket.error MRO length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra92.error_mro_len:
  description: "socket.error.__mro__.__len__() == 4 — socket.error is an alias for OSError; its MRO is [OSError, Exception, BaseException, object] with length 4; no prior socket spec anchors this as a standalone; first standalone for socket.error MRO length under socketsocketcls92"
  category: type_identity
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum') — standalone
#
# socket.AddressFamily.__bases__[0].__name__ is 'IntEnum'. AddressFamily is a
# direct subclass of IntEnum, combining integer and enum semantics for address
# family constants. socket_extra88 first anchors AddressFamily identity; this
# standalone anchors __bases__[0].__name__ under socketsocketcls92.
# First standalone for AddressFamily base class name.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra92.af_bases0_name_eq:
  description: "socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum') == True — AddressFamily is a direct subclass of IntEnum combining integer values with enum semantics for address family constants like AF_INET/AF_INET6; socket_extra88 first anchors AddressFamily identity; first standalone for AddressFamily base class name under socketsocketcls92"
  category: type_identity
  kind: python_call_eq
  function: "AddressFamily.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gaierror.__mro__.__len__() == 5 — standalone
#
# socket.gaierror.__mro__.__len__() is 5. The MRO is [gaierror, OSError,
# Exception, BaseException, object]. gaierror is a socket-specific exception
# for getaddrinfo and getnameinfo errors. No prior socket spec anchors
# gaierror.__mro__.__len__ as a standalone under socketsocketcls92.
# First standalone for socket.gaierror MRO length.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra92.gaierror_mro_len:
  description: "socket.gaierror.__mro__.__len__() == 5 — socket.gaierror is a socket-specific exception for getaddrinfo/getnameinfo errors; its MRO is [gaierror, OSError, Exception, BaseException, object] with length 5; no prior socket spec anchors this as a standalone; first standalone for socket.gaierror MRO length under socketsocketcls92"
  category: type_identity
  kind: python_call_eq
  function: gaierror.__mro__.__len__
  args: []
  expected: 5
