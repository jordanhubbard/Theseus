spec: as3541
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 683 (as3541): __format__, __sizeof__, __dir__ dict-presence checks for asyncio types."
    - "All values false — asyncio types do not define __format__, __sizeof__, or __dir__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __format__ dict-presence — operator.contains(Cls.__dict__, '__format__')
# ---------------------------------------------------------------------------

table as3541.format:
  description: "asyncio types __format__ dict-presence checks; wave 683"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: as3541
  columns: [id, function, args, expected]
  rows:
    - ["as3541001", operator.contains, [asyncio.Task.__dict__,             "__format__"], false]
    - ["as3541002", operator.contains, [asyncio.Future.__dict__,           "__format__"], false]
    - ["as3541003", operator.contains, [asyncio.Event.__dict__,            "__format__"], false]
    - ["as3541004", operator.contains, [asyncio.Lock.__dict__,             "__format__"], false]
    - ["as3541005", operator.contains, [asyncio.Semaphore.__dict__,        "__format__"], false]
    - ["as3541006", operator.contains, [asyncio.BoundedSemaphore.__dict__, "__format__"], false]
    - ["as3541007", operator.contains, [asyncio.Condition.__dict__,        "__format__"], false]
    - ["as3541008", operator.contains, [asyncio.Queue.__dict__,            "__format__"], false]
    - ["as3541009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__format__"], false]
    - ["as3541010", operator.contains, [asyncio.LifoQueue.__dict__,        "__format__"], false]

