spec: itertools_extra259
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.chain, itertools.zip_longest, itertools.product class identity — name, module, bases, __new__.__qualname__; also itertools.chain.from_iterable classmethod identity."
    - "itertools.chain.__name__ == 'chain' — C extension type name. Verified with Python 3.14.3."
    - "itertools.chain.__module__ == 'itertools' — defined in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.chain.__bases__[0].__name__ == 'object' — chain inherits directly from object. Verified with Python 3.14.3."
    - "itertools.chain.__new__.__qualname__ == 'chain.__new__' — C-level constructor qualname. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__name__ == 'from_iterable' — classmethod name. Verified with Python 3.14.3."
    - "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method' — from_iterable is a C-level classmethod. Verified with Python 3.14.3."
    - "itertools.zip_longest.__name__ == 'zip_longest' — C extension type name. Verified with Python 3.14.3."
    - "itertools.zip_longest.__module__ == 'itertools' — defined in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.zip_longest.__bases__[0].__name__ == 'object' — zip_longest inherits directly from object. Verified with Python 3.14.3."
    - "itertools.product.__name__ == 'product' — C extension type name. Verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools' — defined in itertoolsmodule.c. Verified with Python 3.14.3."
    - "itertools.product.__bases__[0].__name__ == 'object' — product inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain class identity contracts
#
# itertools.chain.__name__              == 'chain'
# itertools.chain.__module__            == 'itertools'
# itertools.chain.__bases__[0].__name__ == 'object'
# itertools.chain.__new__.__qualname__  == 'chain.__new__'
# itertools.chain.from_iterable.__name__ == 'from_iterable'
#
# chain is a C extension type. New to extra259.
# ---------------------------------------------------------------------------

table itertools_extra259.chain_identity:
  description: "itertools.chain name, module, base, __new__ qualname, from_iterable name contracts; C extension type; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: itcha259

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_eq,
       chain.__name__.__eq__,
       ["chain"],
       true,
       "itertools.chain.__name__.__eq__('chain') == True — C extension type name; new to extra259"]
    - [chain_module_eq,
       chain.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — defined in itertoolsmodule.c; new to extra259"]
    - [chain_base_name_eq,
       "chain.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.chain.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra259"]
    - [chain_new_qualname_eq,
       chain.__new__.__qualname__.__eq__,
       ["chain.__new__"],
       true,
       "itertools.chain.__new__.__qualname__.__eq__('chain.__new__') == True — C-level constructor qualname; new to extra259"]
    - [chain_from_iterable_name_eq,
       chain.from_iterable.__name__.__eq__,
       ["from_iterable"],
       true,
       "itertools.chain.from_iterable.__name__.__eq__('from_iterable') == True — classmethod name; new to extra259"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain.from_iterable classmethod identity and
#          itertools.zip_longest class identity contracts
#
# itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'
# itertools.zip_longest.__name__              == 'zip_longest'
# itertools.zip_longest.__module__            == 'itertools'
# itertools.zip_longest.__bases__[0].__name__ == 'object'
# itertools.zip_longest.__new__.__qualname__  == 'zip_longest.__new__'
#
# from_iterable is a C-level classmethod; zip_longest is a C extension type.
# New to extra259.
# ---------------------------------------------------------------------------

table itertools_extra259.from_iterable_and_zip_longest:
  description: "itertools.chain.from_iterable class identity and itertools.zip_longest name, module, base, __new__ qualname contracts; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: itfi259

  columns: [id, function, args, expected, description]
  rows:
    - [from_iterable_class_name_eq,
       chain.from_iterable.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "itertools.chain.from_iterable.__class__.__name__.__eq__('builtin_function_or_method') == True — from_iterable is a C-level classmethod; new to extra259"]
    - [zip_longest_name_eq,
       zip_longest.__name__.__eq__,
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__.__eq__('zip_longest') == True — C extension type name; new to extra259"]
    - [zip_longest_module_eq,
       zip_longest.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.zip_longest.__module__.__eq__('itertools') == True — defined in itertoolsmodule.c; new to extra259"]
    - [zip_longest_base_name_eq,
       "zip_longest.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.zip_longest.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra259"]
    - [zip_longest_new_qualname_eq,
       zip_longest.__new__.__qualname__.__eq__,
       ["zip_longest.__new__"],
       true,
       "itertools.zip_longest.__new__.__qualname__.__eq__('zip_longest.__new__') == True — C-level constructor qualname; new to extra259"]

# ---------------------------------------------------------------------------
# Table 3: itertools.product class identity contracts
#
# itertools.product.__name__              == 'product'
# itertools.product.__module__            == 'itertools'
# itertools.product.__bases__[0].__name__ == 'object'
# itertools.product.__new__.__qualname__  == 'product.__new__'
# itertools.product.__name__.__class__.__name__ == 'str'
#
# product is a C extension type. New to extra259.
# ---------------------------------------------------------------------------

table itertools_extra259.product_identity:
  description: "itertools.product name, module, base, __new__ qualname contracts; C extension type; new to extra259"
  kind: python_call_eq
  category: identity
  id_prefix: itprod259

  columns: [id, function, args, expected, description]
  rows:
    - [product_name_eq,
       product.__name__.__eq__,
       ["product"],
       true,
       "itertools.product.__name__.__eq__('product') == True — C extension type name; new to extra259"]
    - [product_module_eq,
       product.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.product.__module__.__eq__('itertools') == True — defined in itertoolsmodule.c; new to extra259"]
    - [product_base_name_eq,
       "product.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.product.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra259"]
    - [product_new_qualname_eq,
       product.__new__.__qualname__.__eq__,
       ["product.__new__"],
       true,
       "itertools.product.__new__.__qualname__.__eq__('product.__new__') == True — C-level constructor qualname; new to extra259"]
    - [product_name_class_eq,
       product.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.product.__name__.__class__.__name__.__eq__('str') == True — __name__ is a str; new to extra259"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra259
# ---------------------------------------------------------------------------

invariant itertools_extra259.chain.name_eq:
  description: "itertools.chain.__name__ == 'chain' — C extension type name; new to extra259"
  category: identity
  kind: python_call_eq
  function: chain.__name__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra259.chain.module_eq:
  description: "itertools.chain.__module__ == 'itertools' — defined in itertoolsmodule.c; new to extra259"
  category: identity
  kind: python_call_eq
  function: chain.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra259.chain.base_is_object:
  description: "itertools.chain.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra259"
  category: identity
  kind: python_call_eq
  function: "chain.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra259.chain.new_qualname:
  description: "itertools.chain.__new__.__qualname__ == 'chain.__new__' — C-level constructor qualname; new to extra259"
  category: identity
  kind: python_call_eq
  function: chain.__new__.__qualname__.__eq__
  args: ["chain.__new__"]
  expected: true

invariant itertools_extra259.chain.from_iterable_name:
  description: "itertools.chain.from_iterable.__name__ == 'from_iterable' — classmethod name; new to extra259"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__name__.__eq__
  args: ["from_iterable"]
  expected: true

invariant itertools_extra259.chain.from_iterable_class:
  description: "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method' — C-level classmethod; new to extra259"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra259.zip_longest.name_eq:
  description: "itertools.zip_longest.__name__ == 'zip_longest' — C extension type name; new to extra259"
  category: identity
  kind: python_call_eq
  function: zip_longest.__name__.__eq__
  args: ["zip_longest"]
  expected: true

invariant itertools_extra259.zip_longest.module_eq:
  description: "itertools.zip_longest.__module__ == 'itertools' — defined in itertoolsmodule.c; new to extra259"
  category: identity
  kind: python_call_eq
  function: zip_longest.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra259.zip_longest.base_is_object:
  description: "itertools.zip_longest.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra259"
  category: identity
  kind: python_call_eq
  function: "zip_longest.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra259.product.name_eq:
  description: "itertools.product.__name__ == 'product' — C extension type name; new to extra259"
  category: identity
  kind: python_call_eq
  function: product.__name__.__eq__
  args: ["product"]
  expected: true

invariant itertools_extra259.product.module_eq:
  description: "itertools.product.__module__ == 'itertools' — defined in itertoolsmodule.c; new to extra259"
  category: identity
  kind: python_call_eq
  function: product.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra259.product.base_is_object:
  description: "itertools.product.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra259"
  category: identity
  kind: python_call_eq
  function: "product.__bases__[0].__name__.__eq__"
  args: ["object"]
