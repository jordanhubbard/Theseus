spec: struct_extra211
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "verified with Python 3.14.3."
    - "struct.calcsize('!B') == 1; struct.calcsize('!H') == 2; struct.calcsize('!I') == 4."
    - "struct.calcsize('!Q') == 8; struct.calcsize('!f') == 4; struct.calcsize('!d') == 8."
    - "struct.calcsize('!HH') == 4; struct.calcsize('!IH') == 6; struct.calcsize('!BH') == 3."
    - "struct.pack('!H', 65536) raises struct.error: 'H' format requires 0 <= number <= 65535."
    - "struct.pack('!H', -1) raises struct.error: 'H' format requires 0 <= number <= 65535."
    - "struct.unpack('!I', b'abc') raises struct.error: unpack requires a buffer of 4 bytes."
    - "struct.unpack('!Q', b'abcd') raises struct.error: unpack requires a buffer of 8 bytes."
    - "All exception types verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize — size checks for network-order primitive formats
#
# struct.calcsize('!B')  == 1   (unsigned char)
# struct.calcsize('!H')  == 2   (unsigned short)
# struct.calcsize('!I')  == 4   (unsigned int)
# struct.calcsize('!Q')  == 8   (unsigned long long)
# struct.calcsize('!f')  == 4   (float)
# struct.calcsize('!d')  == 8   (double)
# ---------------------------------------------------------------------------

table struct_extra211.calcsize_primitive_formats:
  description: "struct.calcsize size checks for network-order primitive format characters in structeq211 namespace — wave 211 theme: B=1, H=2, I=4, Q=8, f=4, d=8; these are the IEEE 754 and C type sizes mandated by the struct format specification; verified with Python 3.14.3"
  kind: python_call_eq
  category: calcsize
  id_prefix: structeq211

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_B,  struct.calcsize,  ["!B"],  1,  "struct.calcsize('!B') == 1 — unsigned char is 1 byte"]
    - [calcsize_H,  struct.calcsize,  ["!H"],  2,  "struct.calcsize('!H') == 2 — unsigned short is 2 bytes"]
    - [calcsize_I,  struct.calcsize,  ["!I"],  4,  "struct.calcsize('!I') == 4 — unsigned int is 4 bytes"]
    - [calcsize_Q,  struct.calcsize,  ["!Q"],  8,  "struct.calcsize('!Q') == 8 — unsigned long long is 8 bytes"]
    - [calcsize_f,  struct.calcsize,  ["!f"],  4,  "struct.calcsize('!f') == 4 — IEEE 754 single-precision float is 4 bytes"]
    - [calcsize_d,  struct.calcsize,  ["!d"],  8,  "struct.calcsize('!d') == 8 — IEEE 754 double-precision float is 8 bytes"]

# ---------------------------------------------------------------------------
# struct.calcsize — size checks for multi-field format strings
#
# struct.calcsize('!HH')  == 4
# struct.calcsize('!IH')  == 6
# struct.calcsize('!BH')  == 3
# struct.calcsize('!BI')  == 5
# struct.calcsize('!2H')  == 4
# struct.calcsize('!2I')  == 8
# ---------------------------------------------------------------------------

table struct_extra211.calcsize_compound_formats:
  description: "struct.calcsize size checks for compound network-order format strings in structeq211a namespace — wave 211 theme: HH=4; IH=6; BH=3; BI=5; 2H=4; 2I=8; sizes are the sum of the constituent field sizes; network byte order does not introduce padding between fields; verified with Python 3.14.3"
  kind: python_call_eq
  category: calcsize
  id_prefix: structeq211a

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_HH,  struct.calcsize,  ["!HH"],  4,  "struct.calcsize('!HH') == 4 — two unsigned shorts = 2+2 bytes"]
    - [calcsize_IH,  struct.calcsize,  ["!IH"],  6,  "struct.calcsize('!IH') == 6 — unsigned int + unsigned short = 4+2 bytes"]
    - [calcsize_BH,  struct.calcsize,  ["!BH"],  3,  "struct.calcsize('!BH') == 3 — unsigned char + unsigned short = 1+2 bytes"]
    - [calcsize_BI,  struct.calcsize,  ["!BI"],  5,  "struct.calcsize('!BI') == 5 — unsigned char + unsigned int = 1+4 bytes"]
    - [calcsize_2H,  struct.calcsize,  ["!2H"],  4,  "struct.calcsize('!2H') == 4 — repeat count 2 applied to H: 2*2 bytes"]
    - [calcsize_2I,  struct.calcsize,  ["!2I"],  8,  "struct.calcsize('!2I') == 8 — repeat count 2 applied to I: 2*4 bytes"]

# ---------------------------------------------------------------------------
# struct.pack — raises struct.error for out-of-range unsigned short values
#
# struct.pack('!H', 65536) raises struct.error
# struct.pack('!H', -1)    raises struct.error
# ---------------------------------------------------------------------------

table struct_extra211.pack_out_of_range_raises:
  description: "struct.pack raises struct.error for unsigned short values outside 0..65535 in structerr211 namespace — wave 211 theme: struct.pack('!H', 65536) raises struct.error; struct.pack('!H', -1) raises struct.error; format 'H' maps to C unsigned short with range [0, 65535]; values outside this range are always rejected; verified with Python 3.14.3"
  kind: python_call_raises
  category: errors
  id_prefix: structerr211

  columns: [id, function, args, expected, description]
  rows:
    - [pack_H_too_large,   struct.pack,  ["!H", 65536],  struct.error,  "struct.pack('!H', 65536) raises struct.error — 65536 exceeds unsigned short maximum 65535"]
    - [pack_H_negative,    struct.pack,  ["!H", -1],     struct.error,  "struct.pack('!H', -1) raises struct.error — negative values are out of range for unsigned short"]

# ---------------------------------------------------------------------------
# struct.unpack — raises struct.error for wrong buffer size
#
# struct.unpack('!I', b'abc')  raises struct.error  (needs 4 bytes, got 3)
# struct.unpack('!Q', b'abcd') raises struct.error  (needs 8 bytes, got 4)
# ---------------------------------------------------------------------------

table struct_extra211.unpack_wrong_buffer_size_raises:
  description: "struct.unpack raises struct.error when the buffer does not match the format size in structerr211a namespace — wave 211 theme: struct.unpack('!I', b'abc') raises struct.error; struct.unpack('!Q', b'abcd') raises struct.error; unpack is strict about buffer length — it will not pad or truncate; verified with Python 3.14.3"
  kind: python_call_raises
  category: errors
  id_prefix: structerr211a

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_I_short_buf,  struct.unpack,  ["!I", {type: bytes_ascii, value: "abc"}],   struct.error,  "struct.unpack('!I', b'abc') raises struct.error — format '!I' requires 4 bytes but buffer has 3"]
    - [unpack_Q_short_buf,  struct.unpack,  ["!Q", {type: bytes_ascii, value: "abcd"}],  struct.error,  "struct.unpack('!Q', b'abcd') raises struct.error — format '!Q' requires 8 bytes but buffer has 4"]

# ---------------------------------------------------------------------------
# struct.calcsize — raises struct.error for invalid format character
# ---------------------------------------------------------------------------

invariant struct_extra211.calcsize_invalid_char_raises:
  description: "struct.calcsize('!Z') raises struct.error — 'Z' is not a recognised struct format character; struct.calcsize validates the entire format string before computing any size; an unrecognised character causes struct.error with 'bad char in struct format'; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: struct.calcsize
  args: ["!Z"]
  expected_exception: struct.error

