spec: symtable_extra6
version: ">=3.12"
backend: python_module(symtable)

docs: https://docs.python.org/3/library/symtable.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/symtable.html — Python symtable documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/symtable.py"
    - "symtable.zspec.zsdl — covers symtable/__name__, class __name__/__module__, method names, symtable() exec returns Module"
    - "symtable_extra.zspec.zsdl — covers class_names/class_modules tables, Function/Class __bases__[0].__name__, get_type()=='module'"
    - "symtable_extra2.zspec.zsdl — covers SymbolTableError identity, class __qualname__ table, Symbol.__module__"
    - "symtable_extra3.zspec.zsdl — covers Symbol.__bases__[0], SymbolTableError.__qualname__, symtable.__qualname__, class __name__ type table"
    - "symtable_extra4.zspec.zsdl — covers SymbolTable extra method names, Symbol extra method names, Function method names, SymbolTableType class, behavioral is_optimized/is_nested/has_children"
    - "symtable_extra5.zspec.zsdl — covers module __name__/__spec__.name, symtable() function class identity, SymbolTable method qualnames (get_type/get_id/get_name/get_children/get_symbols), Function/Class __bases__.__len__, Function.get_parameters.__qualname__"
  notes:
    - "This spec adds invariants not covered in any prior symtable spec."
    - "Symbol method __qualname__ checks — symtable_extra5 covers SymbolTable method qualnames; Symbol method qualnames (is_parameter/is_local/is_global/is_assigned/is_referenced/get_name) are not covered in any prior spec."
    - "Function method __qualname__ for get_locals/get_globals/get_frees/get_nonlocals — symtable_extra5 covers get_parameters.__qualname__; the other Function-specific methods are new."
    - "SymbolTableType.__module__ — symtable_extra4 covers SymbolTableType.__name__ and base (StrEnum); __module__ is not covered in any prior spec."
    - "SymbolTableType value checks — no prior spec checks the string values of SymbolTableType enum members."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Symbol method __qualname__ checks
# symtable_extra4 covers Symbol method __name__; symtable_extra5 covers
# SymbolTable method qualnames. Symbol method qualnames are new here.
# ---------------------------------------------------------------------------

table symtable_extra6.Symbol.method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: sym_mqname

  columns: [id, function, args, expected]
  rows:
    - [get_name,       Symbol.get_name.__qualname__.__eq__,       ["Symbol.get_name"],       true]
    - [is_parameter,   Symbol.is_parameter.__qualname__.__eq__,   ["Symbol.is_parameter"],   true]
    - [is_local,       Symbol.is_local.__qualname__.__eq__,       ["Symbol.is_local"],       true]
    - [is_global,      Symbol.is_global.__qualname__.__eq__,      ["Symbol.is_global"],      true]
    - [is_assigned,    Symbol.is_assigned.__qualname__.__eq__,    ["Symbol.is_assigned"],    true]
    - [is_referenced,  Symbol.is_referenced.__qualname__.__eq__,  ["Symbol.is_referenced"],  true]

# ---------------------------------------------------------------------------
# Function method __qualname__ for get_locals, get_globals, get_frees, get_nonlocals
# symtable_extra5 covers Function.get_parameters.__qualname__; the remaining
# Function-specific methods are new here.
# ---------------------------------------------------------------------------

table symtable_extra6.Function.method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: fn_mqname

  columns: [id, function, args, expected]
  rows:
    - [get_locals,    Function.get_locals.__qualname__.__eq__,    ["Function.get_locals"],    true]
    - [get_globals,   Function.get_globals.__qualname__.__eq__,   ["Function.get_globals"],   true]
    - [get_frees,     Function.get_frees.__qualname__.__eq__,     ["Function.get_frees"],     true]
    - [get_nonlocals, Function.get_nonlocals.__qualname__.__eq__, ["Function.get_nonlocals"], true]

# ---------------------------------------------------------------------------
# SymbolTableType.__module__ — not covered in any prior symtable spec
# symtable_extra4 covers SymbolTableType.__name__ and base class; __module__ is new.
# ---------------------------------------------------------------------------

invariant symtable_extra6.SymbolTableType.module:
  description: "symtable.SymbolTableType.__module__ == 'symtable'"
  category: SymbolTableType
  kind: python_call_eq
  function: SymbolTableType.__module__.__eq__
  args: ["symtable"]
  expected: true

# ---------------------------------------------------------------------------
# SymbolTableType enum member values — string values of MODULE and FUNCTION
# No prior spec checks the .value attribute of SymbolTableType members.
# SymbolTableType.MODULE.value == 'module' and FUNCTION.value == 'function'.
# ---------------------------------------------------------------------------

invariant symtable_extra6.SymbolTableType.MODULE.value:
  description: "symtable.SymbolTableType.MODULE.value == 'module'"
  category: SymbolTableType
  kind: python_call_eq
  function: SymbolTableType.MODULE.value.__eq__
  args: ["module"]
  expected: true

invariant symtable_extra6.SymbolTableType.FUNCTION.value:
  description: "symtable.SymbolTableType.FUNCTION.value == 'function'"
  category: SymbolTableType
  kind: python_call_eq
  function: SymbolTableType.FUNCTION.value.__eq__
  args: ["function"]
  expected: true

invariant symtable_extra6.SymbolTableType.CLASS.value:
  description: "symtable.SymbolTableType.CLASS.value == 'class'"
  category: SymbolTableType
  kind: python_call_eq
  function: SymbolTableType.CLASS.value.__eq__
  args: ["class"]
  expected: true
