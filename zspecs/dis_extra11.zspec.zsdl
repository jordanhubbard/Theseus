spec: dis_extra11
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis.zspec.zsdl — covers class __name__ checks for Instruction/Bytecode; function __name__ for dis/disassemble/code_info/show_code/get_instructions/stack_effect; opname class/length; opmap contains/values; stack_effect values; haslocal/hasname"
    - "dis_extra.zspec.zsdl — covers module __name__, distb/__name__, findlinestarts/__name__, findlabels/__name__, disassemble/__name__, code_info/__name__, show_code/__name__, get_instructions/__name__, stack_effect/__name__, Instruction/__name__/__module__, opname/__class__/__name__, opmap/__class__/__name__, HAVE_ARGUMENT/__class__/__name__"
    - "dis_extra2.zspec.zsdl — covers __module__ for dis functions/classes; Instruction/Bytecode __name__/__module__/__bases__[0]; opname/opmap class checks; HAVE_ARGUMENT class check"
    - "dis_extra3.zspec.zsdl — covers __name__/__module__ for Instruction/Bytecode (table); __name__ for findlinestarts/findlabels/get_instructions/stack_effect (table); opname class/length; opmap class/contains; HAVE_ARGUMENT value; Bytecode.__module__"
    - "dis_extra4.zspec.zsdl — covers Instruction.__qualname__; Instruction._fields class/contains-opname/contains-opcode; opname.__len__ >= 100; dis/disassemble/get_instructions/findlinestarts __qualname__ (table)"
    - "dis_extra5.zspec.zsdl — covers __qualname__ for code_info/show_code/stack_effect/findlabels/distb; Bytecode.__qualname__; Instruction._fields[0]=='opname'; show_code/__module__; distb/__module__"
    - "dis_extra6.zspec.zsdl — covers hasjabs empty list; hasjrel/hasconst/hascompare/hasfree class+len; Instruction._fields[1]/'opcode' and _fields[2]/'arg'; opmap LOAD_CONST/LOAD_GLOBAL/RETURN_VALUE/STORE_NAME values; opname[82]=='LOAD_CONST'"
    - "dis_extra7.zspec.zsdl — covers Instruction._fields[3]/'argval' and _fields[4]/'argrepr'; hasexc class and nonempty; hasarg class and nonempty; Bytecode.__bases__[0].__name__=='object'; opmap BINARY_OP/CALL/RESUME; opname idx31/idx116/idx35"
    - "dis_extra8.zspec.zsdl — covers standalone __module__ invariants for all major dis public names; Bytecode/__name__/__module__; Instruction/__name__/__module__"
    - "dis_extra9.zspec.zsdl — covers Instruction._fields[5]-[11]; _fields.__len__==12; opmap BUILD_TUPLE/BUILD_LIST/COMPARE_OP/IMPORT_NAME/IMPORT_FROM; opname[51]/[46]/[56]/[73]/[72]"
    - "dis_extra10.zspec.zsdl — covers opmap.__contains__ for JUMP_FORWARD/FOR_ITER/MAKE_FUNCTION; opmap values for JUMP_FORWARD/FOR_ITER/MAKE_FUNCTION/POP_TOP; opname round-trip for those opcodes; Bytecode.__bases__.__len__==1"
  notes:
    - "This spec extends dis_extra10.zspec.zsdl."
    - "dis.Instruction.__bases__.__len__() == 1 — not yet checked as a standalone invariant."
    - "dis.hasconst.__len__() == 1 — exactly one opcode takes a constant argument."
    - "dis.haslocal.__len__() == 13 — number of opcodes referencing local variables."
    - "dis.hasname.__len__() == 14 — number of opcodes referencing names."
    - "dis.hascompare.__len__() == 1 — exactly one comparison opcode."
    - "dis.hasjrel.__len__() == 16 — number of relative-jump opcodes."
    - "dis.hasfree.__len__() == 4 — number of free-variable opcodes."
    - "dis.opmap.__len__() == 154 — total number of defined opcodes on Python 3.12."
    - "dis.Bytecode.__qualname__ == 'Bytecode' — not yet verified as standalone invariant."
    - "dis.Instruction.__qualname__ == 'Instruction' — not yet verified as standalone invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Instruction and Bytecode __qualname__ as standalone invariants
#
# dis_extra4 covers Instruction.__qualname__ and dis_extra5 covers
# Bytecode.__qualname__ but they appear in the context of a table.
# These standalone invariants use the dis_extra11 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra11.Instruction.qualname:
  description: "dis.Instruction.__qualname__ == 'Instruction'"
  category: class_qualnames
  kind: python_call_eq
  function: Instruction.__qualname__.__eq__
  args: ["Instruction"]
  expected: true

invariant dis_extra11.Bytecode.qualname:
  description: "dis.Bytecode.__qualname__ == 'Bytecode'"
  category: class_qualnames
  kind: python_call_eq
  function: Bytecode.__qualname__.__eq__
  args: ["Bytecode"]
  expected: true

# ---------------------------------------------------------------------------
# Instruction.__bases__.__len__ — single direct base
#
# dis_extra2 covers Instruction.__bases__[0].__name__. dis_extra10 covers
# Bytecode.__bases__.__len__(). No prior dis spec checks
# Instruction.__bases__.__len__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant dis_extra11.Instruction.bases_len:
  description: "dis.Instruction.__bases__.__len__() == 1 — Instruction has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Instruction.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# opmap.__len__ — total opcode count
#
# dis_extra3 and dis_extra4 check opname.__len__. No prior dis spec checks
# opmap.__len__ as a standalone invariant. On Python 3.12, 154 opcodes are
# defined (opname may be longer due to placeholder entries).
# ---------------------------------------------------------------------------

invariant dis_extra11.opmap.len:
  description: "dis.opmap.__len__() == 154 — total defined opcodes on Python 3.12"
  category: opmap
  kind: python_call_eq
  function: opmap.__len__
  args: []
  expected: 154

# ---------------------------------------------------------------------------
# Opcode list lengths — hasconst, haslocal, hasname, hascompare, hasjrel, hasfree
#
# dis_extra6 covers hasconst/hasjrel/hascompare/hasfree class and nonempty checks.
# dis_extra7 covers hasexc and hasarg nonempty checks.
# No prior dis spec verifies the exact __len__() integer for these lists.
# ---------------------------------------------------------------------------

table dis_extra11.opcode_list_lengths:
  kind: python_call_eq
  category: opcode_lists
  id_prefix: len

  columns: [id, function, args, expected]
  rows:
    - [hasconst,  hasconst.__len__,  [], 1]
    - [haslocal,  haslocal.__len__,  [], 13]
    - [hasname,   hasname.__len__,   [], 14]
    - [hascompare, hascompare.__len__, [], 1]
    - [hasjrel,   hasjrel.__len__,   [], 16]
    - [hasfree,   hasfree.__len__,   [], 4]

# ---------------------------------------------------------------------------
# haslocal and hasname class checks
#
# dis_extra6 covers hasconst/hasjrel/hascompare/hasfree class checks.
# No prior spec checks haslocal.__class__.__name__ or hasname.__class__.__name__
# as standalone invariants — those appeared only as length checks in dis.zspec.
# ---------------------------------------------------------------------------

invariant dis_extra11.haslocal.class:
  description: "dis.haslocal.__class__.__name__ == 'list' — haslocal is a list"
  category: opcode_lists
  kind: python_call_eq
  function: haslocal.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant dis_extra11.hasname.class:
  description: "dis.hasname.__class__.__name__ == 'list' — hasname is a list"
  category: opcode_lists
  kind: python_call_eq
  function: hasname.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant dis_extra11.hasjrel.class:
  description: "dis.hasjrel.__class__.__name__ == 'list' — hasjrel is a list"
  category: opcode_lists
  kind: python_call_eq
  function: hasjrel.__class__.__name__.__eq__
  args: ["list"]
  expected: true
