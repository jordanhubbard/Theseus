spec: struct_extra1606
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "struct.Struct is a C extension type from _struct; its __dict__ has no __slots__, __dict__, or __weakref__ keys"
    - "struct.Struct instances do NOT have a per-instance __dict__ (C type with fixed layout)"
    - "struct.Struct instances DO support weakref (verified empirically)"
    - "struct.Struct.format and .size are getset_descriptor (read-only C-level attributes)"
    - "struct.Struct.pack, .unpack, .pack_into, .unpack_from, .iter_unpack are method_descriptor"
    - "struct.Struct.__init__ and __repr__ and __new__ appear as wrapper_descriptor or builtin_function_or_method"
    - "struct.error is an Exception subclass with module 'struct'; its __dict__ has __doc__ (NoneType), __module__, and __weakref__"
    - "struct module-level functions (pack, unpack, calcsize, etc.) are builtin_function_or_method"
    - "struct.Struct.__module__ is '_struct' (the C accelerator), not 'struct'"
  created_at: "2026-04-12"
error_model: python_exceptions

table struct_extra1606.struct_no_slots:
  description: "struct.Struct is a C extension type; its __dict__ has no __slots__, __dict__, or __weakref__ keys"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1606ns

  columns: [id, function, args, expected]
  rows:
    - ["st1606ns001", "struct.Struct.__dict__.__contains__", ["__slots__"],           false]
    - ["st1606ns002", "struct.Struct.__dict__.__contains__", ["__dict__"],            false]
    - ["st1606ns003", "struct.Struct.__dict__.__contains__", ["__weakref__"],         false]
    - ["st1606ns004", "struct.Struct.__dict__.__contains__", ["format"],              true]
    - ["st1606ns005", "struct.Struct.__dict__.__contains__", ["size"],                true]
    - ["st1606ns006", "struct.Struct.__dict__.__contains__", ["pack"],                true]
    - ["st1606ns007", "struct.Struct.__dict__.__contains__", ["unpack"],              true]
    - ["st1606ns008", "struct.Struct.__dict__.__contains__", ["pack_into"],           true]
    - ["st1606ns009", "struct.Struct.__dict__.__contains__", ["unpack_from"],         true]
    - ["st1606ns010", "struct.Struct.__dict__.__contains__", ["iter_unpack"],         true]
    - ["st1606ns011", "struct.Struct.__dict__.__contains__", ["__doc__"],             true]
    - ["st1606ns012", "struct.Struct.__dict__.__contains__", ["__module__"],          true]
    - ["st1606ns013", "struct.Struct.__dict__.__contains__", ["__init__"],            true]
    - ["st1606ns014", "struct.Struct.__dict__.__contains__", ["__new__"],             true]
    - ["st1606ns015", "struct.Struct.__dict__.__contains__", ["__repr__"],            true]
    - ["st1606ns016", "struct.Struct.__dict__.__contains__", ["__sizeof__"],          true]
    - ["st1606ns017", "struct.Struct.__dict__.__contains__", ["__delattr__"],         true]
    - ["st1606ns018", "struct.Struct.__dict__.__contains__", ["__setattr__"],         true]
    - ["st1606ns019", "struct.Struct.__dict__.__contains__", ["__getattribute__"],    true]
    - ["st1606ns020", "struct.Struct.__dict__.__contains__", ["__iter__"],            false]
    - ["st1606ns021", "struct.Struct.__dict__.__contains__", ["__next__"],            false]
    - ["st1606ns022", "struct.Struct.__dict__.__contains__", ["__reduce__"],          false]
    - ["st1606ns023", "struct.Struct.__name__.__eq__",       ["Struct"],              true]
    - ["st1606ns024", "struct.Struct.__module__.__eq__",     ["_struct"],             true]
    - ["st1606ns025", "struct.Struct.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]

table struct_extra1606.struct_attr_descriptor_types:
  description: "Descriptor types in struct.Struct.__dict__: format/size are getset_descriptor; methods are method_descriptor; __init__/__repr__/__delattr__/__setattr__/__getattribute__ are wrapper_descriptor; __new__ is builtin_function_or_method"
  kind: python_call_eq
  category: descriptor_type
  id_prefix: st1606dt

  columns: [id, function, args, expected]
  rows:
    - ["st1606dt001", "type(struct.Struct.__dict__['format']).__name__.__eq__",          ["getset_descriptor"],          true]
    - ["st1606dt002", "type(struct.Struct.__dict__['size']).__name__.__eq__",            ["getset_descriptor"],          true]
    - ["st1606dt003", "type(struct.Struct.__dict__['pack']).__name__.__eq__",            ["method_descriptor"],          true]
    - ["st1606dt004", "type(struct.Struct.__dict__['unpack']).__name__.__eq__",          ["method_descriptor"],          true]
    - ["st1606dt005", "type(struct.Struct.__dict__['pack_into']).__name__.__eq__",       ["method_descriptor"],          true]
    - ["st1606dt006", "type(struct.Struct.__dict__['unpack_from']).__name__.__eq__",     ["method_descriptor"],          true]
    - ["st1606dt007", "type(struct.Struct.__dict__['iter_unpack']).__name__.__eq__",     ["method_descriptor"],          true]
    - ["st1606dt008", "type(struct.Struct.__dict__['__init__']).__name__.__eq__",        ["wrapper_descriptor"],         true]
    - ["st1606dt009", "type(struct.Struct.__dict__['__repr__']).__name__.__eq__",        ["wrapper_descriptor"],         true]
    - ["st1606dt010", "type(struct.Struct.__dict__['__new__']).__name__.__eq__",         ["builtin_function_or_method"], true]
    - ["st1606dt011", "type(struct.Struct.__dict__['__delattr__']).__name__.__eq__",     ["wrapper_descriptor"],         true]
    - ["st1606dt012", "type(struct.Struct.__dict__['__setattr__']).__name__.__eq__",     ["wrapper_descriptor"],         true]
    - ["st1606dt013", "type(struct.Struct.__dict__['__getattribute__']).__name__.__eq__", ["wrapper_descriptor"],        true]
    - ["st1606dt014", "type(struct.Struct.__dict__['__sizeof__']).__name__.__eq__",      ["method_descriptor"],          true]
    - ["st1606dt015", "struct.Struct('>I').format.__eq__",                               [">I"],                         true]
    - ["st1606dt016", "struct.Struct('>I').size.__eq__",                                 [4],                            true]
    - ["st1606dt017", "struct.Struct('>H').size.__eq__",                                 [2],                            true]
    - ["st1606dt018", "struct.Struct('>Q').size.__eq__",                                 [8],                            true]
    - ["st1606dt019", "struct.Struct('!4s').size.__eq__",                                [4],                            true]
    - ["st1606dt020", "type(struct.pack).__name__.__eq__",                               ["builtin_function_or_method"], true]
    - ["st1606dt021", "type(struct.unpack).__name__.__eq__",                             ["builtin_function_or_method"], true]
    - ["st1606dt022", "type(struct.calcsize).__name__.__eq__",                           ["builtin_function_or_method"], true]
    - ["st1606dt023", "type(struct.pack_into).__name__.__eq__",                          ["builtin_function_or_method"], true]
    - ["st1606dt024", "type(struct.unpack_from).__name__.__eq__",                        ["builtin_function_or_method"], true]
    - ["st1606dt025", "type(struct.iter_unpack).__name__.__eq__",                        ["builtin_function_or_method"], true]

table struct_extra1606.struct_error_class:
  description: "struct.error is an Exception subclass with no __slots__; its __dict__ contains __doc__ (NoneType), __module__, and __weakref__"
  kind: python_call_eq
  category: exception_class
  id_prefix: st1606ec

  columns: [id, function, args, expected]
  rows:
    - ["st1606ec001", "struct.error.__dict__.__contains__", ["__slots__"],      false]
    - ["st1606ec002", "struct.error.__dict__.__contains__", ["__doc__"],        true]
    - ["st1606ec003", "struct.error.__dict__.__contains__", ["__module__"],     true]
    - ["st1606ec004", "struct.error.__dict__.__contains__", ["__weakref__"],    true]
    - ["st1606ec005", "struct.error.__dict__.__contains__", ["__dict__"],       false]
    - ["st1606ec006", "struct.error.__dict__.__contains__", ["args"],           false]
    - ["st1606ec007", "struct.error.__dict__.__contains__", ["__init__"],       false]
    - ["st1606ec008", "issubclass(struct.error, Exception).__eq__",            [true],     true]
    - ["st1606ec009", "issubclass(struct.error, OSError).__eq__",              [false],    true]
    - ["st1606ec010", "struct.error.__name__.__eq__",                          ["error"],  true]
    - ["st1606ec011", "struct.error.__module__.__eq__",                        ["struct"], true]
    - ["st1606ec012", "struct.error.__bases__.__len__",                        [],         1]
    - ["st1606ec013", "struct.error.__bases__.__contains__",                   [Exception], true]
    - ["st1606ec014", "type(struct.error.__dict__['__doc__']).__name__.__eq__", ["NoneType"], true]
    - ["st1606ec015", "type(struct.error.__dict__['__module__']).__name__.__eq__", ["str"], true]
    - ["st1606ec016", "type(struct.error.__dict__['__weakref__']).__name__.__eq__", ["getset_descriptor"], true]
    - ["st1606ec017", "struct.error.__class__.__name__.__eq__",                ["type"],   true]
    - ["st1606ec018", "struct.error.__dict__.__class__.__name__.__eq__",       ["mappingproxy"], true]
    - ["st1606ec019", "struct.error.__dict__.__contains__",                    ["__reduce__"], false]
    - ["st1606ec020", "struct.error.__dict__.__contains__",                    ["__str__"],   false]
    - ["st1606ec021", "struct.error.__dict__.__contains__",                    ["__repr__"],  false]
    - ["st1606ec022", "struct.error.__dict__.__contains__",                    ["__new__"],   false]
    - ["st1606ec023", "struct.error.__dict__.__contains__",                    ["message"],   false]
    - ["st1606ec024", "struct.error.__dict__.__contains__",                    ["errno"],     false]
    - ["st1606ec025", "struct.error.__dict__.__contains__",                    ["strerror"],  false]
