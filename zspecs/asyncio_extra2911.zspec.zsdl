spec: as2911
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [asyncio source, Python docs, https://docs.python.org/3/library/asyncio-sync.html, https://docs.python.org/3/library/asyncio-task.html]
  not_derived_from: [asyncio_extra2896.zspec.zsdl — covers __itruediv__/__ifloordiv__/__imod__ dict-presence, asyncio_extra2881.zspec.zsdl — covers __iadd__/__isub__/__imul__ dict-presence, asyncio_extra2866.zspec.zsdl — covers __rand__/__ror__/__rxor__ dict-presence, asyncio_extra2851.zspec.zsdl — covers __rlshift__/__rrshift__/__rpow__ dict-presence]
  notes: [Wave 641 theme — __ilshift__/__irshift__/__ipow__ dict-presence checks for asyncio types. In-place left-shift, right-shift, and power operators. Task/Future/Queue/Event/Semaphore/BoundedSemaphore/Lock/Condition/Handle/TimerHandle/Timeout/TaskGroup are async coordination primitives not numeric types — none define these dunders. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table as2911.ilshift:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
