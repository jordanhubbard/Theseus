spec: re_extra233
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module top-level function __name__ and name length contracts."
    - "re.match.__name__ == 'match' — re.match function name; verified Python 3.14.3 macOS."
    - "re.search.__name__ == 'search' — re.search function name; verified Python 3.14.3 macOS."
    - "re.findall.__name__ == 'findall' — re.findall function name; verified Python 3.14.3 macOS."
    - "re.finditer.__name__ == 'finditer' — re.finditer function name; length 8; verified Python 3.14.3 macOS."
    - "re.sub.__name__ == 'sub' — re.sub function name; verified Python 3.14.3 macOS."
    - "re.subn.__name__ == 'subn' — re.subn function name; verified Python 3.14.3 macOS."
    - "re.split.__name__ == 'split' — re.split function name; verified Python 3.14.3 macOS."
    - "re.compile.__name__ == 'compile' — re.compile function name; verified Python 3.14.3 macOS."
    - "re.fullmatch.__name__ == 'fullmatch' — re.fullmatch function name; length 9; verified Python 3.14.3 macOS."
    - "re.escape.__name__ == 'escape' — re.escape function name; verified Python 3.14.3 macOS."
    - "re.purge.__name__ == 'purge' — re.purge function name; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module function __name__ contracts
# All standard re module functions carry their canonical name as __name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra233.function_names:
  description: "re module function __name__ contracts — match, search, findall, finditer, sub, subn, split, compile, fullmatch, escape, purge; verified with Python 3.14.3"
  kind: python_call_eq
  category: function_name
  id_prefix: refuncnames233

  columns: [id, function, args, expected]
  rows:
    - [re_match_name,      match.__name__.__eq__,      ["match"],     true]
    - [re_search_name,     search.__name__.__eq__,     ["search"],    true]
    - [re_findall_name,    findall.__name__.__eq__,    ["findall"],   true]
    - [re_finditer_name,   finditer.__name__.__eq__,   ["finditer"],  true]
    - [re_sub_name,        sub.__name__.__eq__,        ["sub"],       true]
    - [re_subn_name,       subn.__name__.__eq__,       ["subn"],      true]
    - [re_split_name,      split.__name__.__eq__,      ["split"],     true]
    - [re_compile_name,    compile.__name__.__eq__,    ["compile"],   true]
    - [re_fullmatch_name,  fullmatch.__name__.__eq__,  ["fullmatch"], true]
    - [re_escape_name,     escape.__name__.__eq__,     ["escape"],    true]
    - [re_purge_name,      purge.__name__.__eq__,      ["purge"],     true]

# ---------------------------------------------------------------------------
# re module function name length contracts
# Spot-check name lengths for finditer (8) and fullmatch (9).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra233.finditer.name_length:
  description: "re.finditer.__name__.__len__() == 8 — 'finditer' has 8 characters; verified Python 3.14.3 macOS"
  category: function_name
  kind: python_call_eq
  function: finditer.__name__.__len__
  args: []
  expected: 8

invariant re_extra233.fullmatch.name_length:
  description: "re.fullmatch.__name__.__len__() == 9 — 'fullmatch' has 9 characters; verified Python 3.14.3 macOS"
  category: function_name
  kind: python_call_eq
  function: fullmatch.__name__.__len__
  args: []
  expected: 9

invariant re_extra233.match.name_length:
  description: "re.match.__name__.__len__() == 5 — 'match' has 5 characters; verified Python 3.14.3 macOS"
  category: function_name
  kind: python_call_eq
  function: match.__name__.__len__
  args: []
  expected: 5

invariant re_extra233.compile.name_length:
  description: "re.compile.__name__.__len__() == 7 — 'compile' has 7 characters; verified Python 3.14.3 macOS"
  category: function_name
  kind: python_call_eq
  function: compile.__name__.__len__
  args: []
  expected: 7
