spec: lodash_trimstart
version: ">=4.0.0"
backend: node(lodash.trimstart)

docs: https://lodash.com/docs/#trimStart

provenance:
  derived_from:
    - "lodash.trimstart README — https://www.npmjs.com/package/lodash.trimstart"
    - "Test vectors verified with lodash.trimstart@4.5.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.trimstart exports the _.trimStart function directly as module.exports."
    - "trimStart(string, chars) removes leading chars from string."
    - "Removes whitespace by default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns left-trimmed string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_trimstart.trimstart:
  kind: node_module_call_eq
  function: ~
  category: trimstart
  id_prefix: ltrs

  columns: [id, args, expected]
  rows:
    - [spaces,       ["  hello  "],          "hello  "]
    - [custom_char,  ["--hello--", "-"],      "hello--"]
    - [no_change,    ["hello  "],             "hello  "]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:49:47Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
