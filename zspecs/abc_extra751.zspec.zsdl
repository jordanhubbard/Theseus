spec: abc_extra751
version: ">=3.9"
backend: python_module(abc)
docs: Cover abc.abstractmethod and ABC class method identity via __class__.__name__ attribute chains
error_model: python_exceptions
provenance:
  derived_from:
    - abc standard library documentation
    - CPython source Lib/abc.py
    - CPython source Modules/_abc.c
  not_derived_from:
    - zope.interface or other alternative ABC implementations
    - typing module abstract base class utilities
  notes:
    - abstractmethod is a class (type) not a function, so __class__.__name__ == 'type'
    - ABC.__class__.__name__ is 'ABCMeta' confirming metaclass assignment
    - get_cache_token is implemented in C (_abc module) so it is a builtin_function_or_method
    - update_abstractmethods is a pure-Python function added in Python 3.10 but present in >=3.9 stubs
  created_at: "2026-04-12"

table abc_extra751.name:
  description: Identity checks for abc.abstractmethod, ABCMeta, and ABC class method type names
  kind: python_call_eq
  category: module_identity
  id_prefix: ab751xx
  columns: [id, function, args, expected]
  rows:
    - [ab751xx001, abc.abstractmethod.__class__.__name__.__eq__, ["type"], true]
    - [ab751xx002, abc.ABCMeta.__class__.__name__.__eq__, ["type"], true]
    - [ab751xx003, abc.ABC.__class__.__name__.__eq__, ["ABCMeta"], true]
    - [ab751xx004, abc.abstractmethod.__init__.__class__.__name__.__eq__, ["function"], true]
    - [ab751xx005, abc.abstractmethod.__call__.__class__.__name__.__eq__, ["function"], true]
    - [ab751xx006, abc.ABCMeta.register.__class__.__name__.__eq__, ["function"], true]
    - [ab751xx007, abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__, ["function"], true]
    - [ab751xx008, abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__, ["function"], true]
    - [ab751xx009, abc.get_cache_token.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ab751xx010, abc.update_abstractmethods.__class__.__name__.__eq__, ["function"], true]
    - [ab751xx011, abc.abstractmethod.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab751xx012, abc.ABCMeta.__doc__.__class__.__name__.__eq__, ["str"], true]
