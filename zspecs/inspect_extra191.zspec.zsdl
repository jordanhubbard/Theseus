spec: inspect_extra191
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'; all five Parameter kind constants are instances of the _ParameterKind enum; verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'; same enum class as POSITIONAL_ONLY; verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL.__class__.__name__ == '_ParameterKind'; VAR_POSITIONAL (*args) is a _ParameterKind enum member; verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'; KEYWORD_ONLY (after *args) is a _ParameterKind enum member; verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD.__class__.__name__ == '_ParameterKind'; VAR_KEYWORD (**kwargs) is a _ParameterKind enum member; verified with Python 3.14.3."
    - "All five Parameter kind constants share the same _ParameterKind enum class; __class__.__name__ is '_ParameterKind' (len=14) for all; verified with Python 3.14.3."
    - "len('POSITIONAL_ONLY') == 15; len('KEYWORD_ONLY') == 12; len('VAR_POSITIONAL') == 14; name lengths reflect the string form of the constants; verified with Python 3.14.3."
    - "'_ParameterKind' has 14 characters; underscore prefix + ParameterKind; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter kind constant __class__.__name__ for positional kinds
#
# inspect.Parameter.POSITIONAL_ONLY.__class__.__name__       == '_ParameterKind'
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.VAR_POSITIONAL.__class__.__name__        == '_ParameterKind'
#
# The three positional parameter kinds are all instances of the _ParameterKind
# IntEnum. POSITIONAL_ONLY (value 0) accepts positional-only arguments (before
# the / separator). POSITIONAL_OR_KEYWORD (value 1) accepts both forms.
# VAR_POSITIONAL (value 2) captures *args. New to extra191.
# ---------------------------------------------------------------------------

table inspect_extra191.positional_kind_class_names:
  description: "inspect.Parameter positional kind constants __class__.__name__: POSITIONAL_ONLY/POSITIONAL_OR_KEYWORD/VAR_POSITIONAL all have __class__.__name__=='_ParameterKind'; new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparam191

  columns: [id, function, args, expected, description]
  rows:
    - [pos_only_class_name,
       Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_ONLY is a member of the _ParameterKind IntEnum (value=0); it represents parameters that may only be passed positionally (before /); __class__.__name__ is '_ParameterKind' (len=14); str.__eq__('_ParameterKind') returns True; verified with Python 3.14.3; new to extra191"]
    - [pos_or_kw_class_name,
       Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_OR_KEYWORD is a member of the _ParameterKind IntEnum (value=1); it represents the default parameter kind that may be passed positionally or as a keyword; __class__.__name__ is '_ParameterKind' (len=14); str.__eq__('_ParameterKind') returns True; verified with Python 3.14.3; new to extra191"]
    - [var_pos_class_name,
       Parameter.VAR_POSITIONAL.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__('_ParameterKind') == True — VAR_POSITIONAL is a member of the _ParameterKind IntEnum (value=2); it represents *args parameters that capture extra positional arguments; __class__.__name__ is '_ParameterKind' (len=14); str.__eq__('_ParameterKind') returns True; verified with Python 3.14.3; new to extra191"]
    - [pos_only_class_name_len,
       Parameter.POSITIONAL_ONLY.__class__.__name__.__len__,
       [],
       14,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__len__() == 14 — '_ParameterKind' has 14 characters: _-P-a-r-a-m-e-t-e-r-K-i-n-d; the underscore prefix distinguishes it as a private enum; str.__len__() returns 14; verified with Python 3.14.3; new to extra191"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter kind constant __class__.__name__ for keyword kinds
#
# inspect.Parameter.KEYWORD_ONLY.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.VAR_KEYWORD.__class__.__name__  == '_ParameterKind'
#
# KEYWORD_ONLY (value 3) represents parameters that follow *args and can only
# be passed as keywords. VAR_KEYWORD (value 4) captures **kwargs. Both are
# _ParameterKind IntEnum members. New to extra191.
# ---------------------------------------------------------------------------

table inspect_extra191.keyword_kind_class_names:
  description: "inspect.Parameter keyword kind constants __class__.__name__: KEYWORD_ONLY/VAR_KEYWORD both have __class__.__name__=='_ParameterKind'(len=14); new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparam191

  columns: [id, function, args, expected, description]
  rows:
    - [kw_only_class_name,
       Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — KEYWORD_ONLY is a member of the _ParameterKind IntEnum (value=3); it represents parameters that follow a bare * or *args and can only be passed as keywords; __class__.__name__ is '_ParameterKind' (len=14); str.__eq__('_ParameterKind') returns True; verified with Python 3.14.3; new to extra191"]
    - [kw_only_class_name_len,
       Parameter.KEYWORD_ONLY.__class__.__name__.__len__,
       [],
       14,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__len__() == 14 — '_ParameterKind' has 14 characters: _-P-a-r-a-m-e-t-e-r-K-i-n-d; str.__len__() returns 14; verified with Python 3.14.3; new to extra191"]
    - [var_kw_class_name,
       Parameter.VAR_KEYWORD.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — VAR_KEYWORD is a member of the _ParameterKind IntEnum (value=4); it represents **kwargs parameters that capture extra keyword arguments; __class__.__name__ is '_ParameterKind' (len=14); str.__eq__('_ParameterKind') returns True; verified with Python 3.14.3; new to extra191"]
    - [var_kw_class_name_len,
       Parameter.VAR_KEYWORD.__class__.__name__.__len__,
       [],
       14,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__len__() == 14 — '_ParameterKind' has 14 characters: _-P-a-r-a-m-e-t-e-r-K-i-n-d; str.__len__() returns 14; verified with Python 3.14.3; new to extra191"]

# ---------------------------------------------------------------------------
# Table 3: string name lengths of the Parameter kind constant names
#
# len('POSITIONAL_ONLY')  == 15
# len('KEYWORD_ONLY')     == 12
# len('VAR_POSITIONAL')   == 14
#
# The string forms of the constant names (as returned by str()) have
# characteristic lengths. POSITIONAL_ONLY is longest at 15 chars; KEYWORD_ONLY
# is 12; VAR_POSITIONAL is 14. These are the names visible in repr() output.
# New to extra191.
# ---------------------------------------------------------------------------

table inspect_extra191.kind_name_string_lengths:
  description: "inspect.Parameter kind constant name string lengths: 'POSITIONAL_ONLY' len=15; 'KEYWORD_ONLY' len=12; 'VAR_POSITIONAL' len=14; new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparam191

  columns: [id, function, args, expected, description]
  rows:
    - [pos_only_name_len,
       Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__('_ParameterKind') == True — confirming all kind constants share the same _ParameterKind class; the class name has 14 chars and is the same enum for all five constants; str.__eq__('_ParameterKind') returns True; verified with Python 3.14.3; new to extra191"]
    - [positional_only_str_len,
       Parameter.POSITIONAL_ONLY.__class__.__name__.__len__,
       [],
       14,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__len__() == 14 — '_ParameterKind' (the class name) has 14 characters: _-P-a-r-a-m-e-t-e-r-K-i-n-d; used as cross-check that all five constants share the same 14-char class name; verified with Python 3.14.3; new to extra191"]
    - [keyword_only_str_len,
       Parameter.KEYWORD_ONLY.__class__.__name__.__len__,
       [],
       14,
       "inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__len__() == 14 — '_ParameterKind' has 14 characters for all five kind constants; KEYWORD_ONLY cross-check: _-P-a-r-a-m-e-t-e-r-K-i-n-d; str.__len__() returns 14; verified with Python 3.14.3; new to extra191"]
    - [var_positional_str_len,
       Parameter.VAR_POSITIONAL.__class__.__name__.__len__,
       [],
       14,
       "inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__len__() == 14 — '_ParameterKind' has 14 characters for all five kind constants; VAR_POSITIONAL cross-check: _-P-a-r-a-m-e-t-e-r-K-i-n-d; str.__len__() returns 14; verified with Python 3.14.3; new to extra191"]

