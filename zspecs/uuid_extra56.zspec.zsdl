spec: uuid_extra56
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra55.zspec.zsdl — covers uuid4.__code__.co_name ('uuid4') / uuid1.__code__.co_name ('uuid1') / uuid4.__code__.co_argcount==0 / uuid1.__code__.co_argcount==2 / UUID.__doc__.__contains__('hex') / UUID.__doc__.__contains__('int') (table + invariants)."
    - "uuid_extra54.zspec.zsdl — covers uuid4.__defaults__.__class__.__name__.__eq__('NoneType') / uuid1.__defaults__.__class__.__name__.__eq__('tuple') / uuid4.__code__.__class__.__name__.__eq__('code') / uuid1.__code__.__class__.__name__.__eq__('code') / UUID.__doc__.__contains__('bytes') / uuid4.__closure__.__class__.__name__.__eq__('NoneType') (table + invariants)."
    - "uuid_extra53.zspec.zsdl — covers uuid4/uuid1/uuid3/uuid5 __annotations__.__class__.__name__.__eq__('dict') / __annotations__.__len__()==0 / uuid4.__globals__.__class__.__name__.__eq__('dict') / uuid4.__globals__.__contains__('UUID') / UUID.__doc__.__contains__('UUID') (table + invariants)."
    - "uuid_extra52.zspec.zsdl — covers UUID.__setattr__/__getstate__/__setstate__/__init_subclass__/__subclasshook__ __qualname__.__eq__ string values (table + invariants)."
    - "uuid_extra51.zspec.zsdl — covers uuid.__spec__.origin.__class__.__name__.__eq__('str') / submodule_search_locations.__class__.__name__.__eq__('NoneType') / has_location==True / UUID.__ne__.__qualname__.__eq__('object.__ne__') (table + invariants)."
    - "uuid_extra50.zspec.zsdl — covers uuid.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "uuid_extra48.zspec.zsdl — covers UUID.__eq__/__lt__/__le__/__gt__/__ge__.__class__.__name__.__eq__('function'); uuid.__dict__.__contains__('__all__') == False."
    - "uuid_extra41.zspec.zsdl — covers UUID/uuid4/uuid1/uuid3/uuid5/getnode/module __doc__.__class__.__name__.__eq__('str') and UUID.hex/int/bytes/version .fget.__qualname__.__eq__."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra55; it does NOT duplicate invariants present in those files."
    - "Wave 231 theme: __code__.co_varnames / co_filename / co_flags chains for Python functions + NAMESPACE_* constants class identity checks."
    - "uuid4.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple for Python code objects. uuid4() is a pure Python function in Lib/uuid.py. No prior uuid spec checks uuid4.__code__.co_varnames. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid1.__code__.co_varnames.__class__.__name__ == 'tuple' — uuid1(node=None, clock_seq=None) is a pure Python function in Lib/uuid.py. No prior uuid spec checks uuid1.__code__.co_varnames. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid1.__code__.co_varnames[0] == 'node' — uuid1(node=None, clock_seq=None) has 'node' as the first parameter, so co_varnames[0]=='node'. uuid4() takes no arguments so co_varnames[0] may not exist (empty or local vars only); only uuid1 is checked for first arg. No prior uuid spec checks co_varnames[0] for any uuid function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid4.__code__.co_filename.__contains__('.py') == True — co_filename records the source file; uuid4 is defined in Lib/uuid.py. No prior uuid spec checks co_filename. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid1.__code__.co_filename.__contains__('.py') == True — same reasoning. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — NAMESPACE_DNS is a module-level constant of type uuid.UUID. Python docs list it as a UUID namespace for DNS names. No prior uuid spec checks NAMESPACE_DNS.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — NAMESPACE_URL is a UUID namespace constant for URLs. uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' — namespace for ISO OIDs. uuid.NAMESPACE_X500.__class__.__name__ == 'UUID' — namespace for X.500 DNs. All four are UUID instances. No prior uuid spec checks any NAMESPACE_* constant. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid4 and uuid1 __code__.co_varnames class name
#
# Wave 231 theme: __code__.co_varnames chains for Python functions.
#
# co_varnames is a tuple of local variable names (parameters first, then
# locals) for a Python code object. Both uuid4 and uuid1 are pure Python
# functions in Lib/uuid.py, so their co_varnames is a tuple.
# No prior uuid spec checks co_varnames for any uuid function.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra56.co_varnames_class_name:
  description: "uuid4.__code__.co_varnames.__class__.__name__=='tuple' and uuid1.__code__.co_varnames.__class__.__name__=='tuple' — co_varnames is always a tuple for Python code objects; both uuid4 and uuid1 are pure Python functions in Lib/uuid.py; no prior uuid spec checks co_varnames for any uuid function; first co_varnames anchor for uuid"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidcode3_56

  columns: [id, function, args, expected]
  rows:
    - [uuid4_co_varnames_class_name, uuid4.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]
    - [uuid1_co_varnames_class_name, uuid1.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]

# ---------------------------------------------------------------------------
# uuid1.__code__.co_varnames first element
#
# Wave 231 theme: __code__.co_varnames[0] for Python functions.
#
# uuid1(node=None, clock_seq=None) has 'node' as the first parameter, so
# co_varnames[0] == 'node'. uuid4() takes no arguments; its co_varnames may
# be empty or contain only local variable names, so uuid4 is not checked for
# co_varnames[0]. The [0] subscript requires double-quoting in table rows.
# No prior uuid spec checks co_varnames[0] for any uuid function.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra56.co_varnames_first_arg:
  description: "uuid1.__code__.co_varnames[0].__eq__('node') — uuid1(node=None, clock_seq=None) has 'node' as first parameter; co_varnames[0]=='node'; uuid4() takes no args so is not tested for [0]; no prior uuid spec checks co_varnames[0] for any uuid function; first co_varnames element anchor for uuid"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidcode3_56

  columns: [id, function, args, expected]
  rows:
    - [uuid1_co_varnames_0_node, "uuid1.__code__.co_varnames[0].__eq__", ["node"], true]

# ---------------------------------------------------------------------------
# uuid4 and uuid1 __code__.co_filename contains '.py'
#
# Wave 231 theme: __code__.co_filename chains for Python functions.
#
# co_filename records the source file path. uuid4 and uuid1 are both defined
# in Lib/uuid.py so co_filename ends in '.py'. No prior uuid spec checks
# co_filename for any uuid function. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra56.co_filename_contains_py:
  description: "uuid4.__code__.co_filename.__contains__('.py') and uuid1.__code__.co_filename.__contains__('.py') — co_filename records the source file path; both functions are defined in Lib/uuid.py so co_filename ends in '.py'; no prior uuid spec checks co_filename for any uuid function; first co_filename anchor for uuid"
  kind: python_call_eq
  category: code_objects
  id_prefix: uuidcode3_56

  columns: [id, function, args, expected]
  rows:
    - [uuid4_co_filename_contains_py, uuid4.__code__.co_filename.__contains__, [".py"], true]
    - [uuid1_co_filename_contains_py, uuid1.__code__.co_filename.__contains__, [".py"], true]

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_* constants class identity checks
#
# Wave 231 theme: module-level UUID constant type identity checks.
#
# The uuid module defines four standard namespace UUID constants per RFC 4122:
# NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500. All four are
# instances of uuid.UUID. No prior uuid spec checks any NAMESPACE_* attribute.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra56.namespace_constants_class:
  description: "uuid.NAMESPACE_DNS/URL/OID/X500.__class__.__name__=='UUID' — the four RFC 4122 namespace constants defined in the uuid module are all instances of uuid.UUID; NAMESPACE_DNS is for DNS names, NAMESPACE_URL for URLs, NAMESPACE_OID for ISO OIDs, NAMESPACE_X500 for X.500 distinguished names; no prior uuid spec checks any NAMESPACE_* constant in any form; first type identity anchor for uuid namespace constants"
  kind: python_call_eq
  category: module_constants
  id_prefix: uuidcode3_56

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_DNS_class_UUID,  NAMESPACE_DNS.__class__.__name__.__eq__,  ["UUID"], true]
    - [NAMESPACE_URL_class_UUID,  NAMESPACE_URL.__class__.__name__.__eq__,  ["UUID"], true]
    - [NAMESPACE_OID_class_UUID,  NAMESPACE_OID.__class__.__name__.__eq__,  ["UUID"], true]
    - [NAMESPACE_X500_class_UUID, NAMESPACE_X500.__class__.__name__.__eq__, ["UUID"], true]

# ---------------------------------------------------------------------------
# uuid4.__code__.co_varnames.__class__.__name__.__eq__('tuple') — standalone
#
# uuid4 is a pure Python function in Lib/uuid.py. Its code object's
# co_varnames is a tuple — the standard type for code object variable name
# sequences. No prior uuid spec checks uuid4.__code__.co_varnames in any form.
# First co_varnames anchor for any uuid function. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant uuid_extra56.uuid4_co_varnames_tuple:
  description: "uuid.uuid4.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is always a tuple for Python code objects; uuid4 is a pure Python function in Lib/uuid.py; no prior uuid spec checks uuid4.__code__.co_varnames; first co_varnames anchor for any uuid function"
  category: code_objects
  kind: python_call_eq
  function: uuid4.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# uuid1.__code__.co_varnames[0] == 'node' — standalone
#
# uuid1(node=None, clock_seq=None) is defined in Lib/uuid.py. The first
# parameter is 'node', which appears first in co_varnames. This anchors the
# first parameter name for uuid1 via the co_varnames subscript. No prior uuid
# spec checks co_varnames[0] for any uuid function. First co_varnames element
# anchor for uuid. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra56.uuid1_co_varnames_first_node:
  description: "uuid.uuid1.__code__.co_varnames[0].__eq__('node') == True — uuid1(node=None, clock_seq=None) has 'node' as the first parameter so co_varnames[0]=='node'; no prior uuid spec checks co_varnames[0] for any uuid function; first co_varnames element anchor for uuid1"
  category: code_objects
  kind: python_call_eq
  function: uuid1.__code__.co_varnames
  method_chain: ["__getitem__", "__eq__"]
  method_chain_args: [[0], ["node"]]
  expected: true

# ---------------------------------------------------------------------------
# uuid4.__code__.co_filename.__contains__('.py') — standalone
#
# uuid4 is defined in Lib/uuid.py. The code object's co_filename records the
# source file path, which ends in '.py' for any file compiled from Python
# source. This confirms uuid4 is a genuine Python function, not a C extension.
# No prior uuid spec checks co_filename for any uuid function. First co_filename
# anchor for uuid. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra56.uuid4_co_filename_contains_py:
  description: "uuid.uuid4.__code__.co_filename.__contains__('.py') == True — co_filename records the source file; uuid4 is defined in Lib/uuid.py so co_filename ends in '.py'; this confirms uuid4 is a Python (not C) function; no prior uuid spec checks co_filename for any uuid function; first co_filename anchor for uuid"
  category: code_objects
  kind: python_call_eq
  function: uuid4.__code__.co_filename.__contains__
  args: [".py"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') — standalone
#
# NAMESPACE_DNS is a module-level constant in the uuid module equal to the
# UUID assigned to the DNS namespace per RFC 4122. It is an instance of
# uuid.UUID (the class defined in the same module). No prior uuid spec checks
# any NAMESPACE_* constant in any form. First type identity anchor for the
# uuid namespace constants. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra56.NAMESPACE_DNS_class_UUID:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — NAMESPACE_DNS is defined in Lib/uuid.py as a UUID instance representing the DNS namespace per RFC 4122; its class name is 'UUID'; no prior uuid spec checks any NAMESPACE_* constant; first type identity anchor for uuid namespace constants"
  category: module_constants
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true
