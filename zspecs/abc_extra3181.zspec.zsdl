spec: ab3181
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 659 (ab3181): __truediv__, __floordiv__, __mod__ dict-presence for abc module types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: abc.ABC, abc.ABCMeta, and type(abc.abstractmethod(lambda: None)) — the built-in function type."
    - "Key finding (__truediv__): all 3 abc subjects return false for __truediv__. abc.ABC is a plain abstract base class helper with no arithmetic semantics. abc.ABCMeta is a metaclass responsible for abstract method tracking and virtual subclass registration — it does not define / for class-level division. The function type (type(abc.abstractmethod(lambda: None)) is <class 'function'>) does not define __truediv__ — functions are callables, not divisible operands. f / g is not a valid Python expression."
    - "Key finding (__floordiv__): all 3 abc subjects return false for __floordiv__. Floor division is not defined for any abc type. abc.ABCMeta does not define // for metaclass floor division; its power lies in class-hierarchy machinery (__subclasshook__, register(), __abstractmethods__), not in arithmetic operators. The function type does not define __floordiv__ — f // g is not a valid Python expression. abc.ABC has no floor division protocol."
    - "Key finding (__mod__): all 3 abc subjects return false for __mod__. Modulo is not defined for any abc type. abc.ABC does not define % — ABC instances are abstract base markers, not format strings or numeric types. abc.ABCMeta does not define % — metaclass objects do not participate in old-style string formatting or numeric modulo. The function type does not define __mod__ — f % args is not how Python formats with functions (str.__mod__ handles % formatting for strings)."
    - "All 9 values in this wave are false — continuing the all-false pattern from wave 658."
    - "The function type profile across all waves: it has returned true only for __get__ (wave 652), __repr__ (wave 655), and __call__ (wave 656). All other dunders tested — including this wave's __truediv__/__floordiv__/__mod__ — are false. The function type is tightly scoped to its role as a callable, displayable, descriptor."
    - "abc.ABCMeta continues its all-false streak across arithmetic operators: while ABCMeta is a powerful metaclass, none of its machinery maps to any arithmetic or collection protocol. It has now returned false for every arithmetic dunder tested across 8 consecutive waves."
    - "Cross-wave summary for abc subjects:"
    - "  Wave 652 (ab3076): __get__ true for function type; __set__/__delete__ false."
    - "  Wave 653 (ab3091): __hash__/__eq__/__bool__ all false for all 3."
    - "  Wave 654 (ab3106): __lt__/__le__/__gt__ all false for all 3."
    - "  Wave 655 (ab3121): __ge__ false; __repr__ true for function type only; __str__ false."
    - "  Wave 656 (ab3136): __call__ true for function type only; __len__/__getitem__ false."
    - "  Wave 657 (ab3151): __setitem__/__delitem__/__contains__ — all false for all 3."
    - "  Wave 658 (ab3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (ab3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __truediv__ dict-presence — operator.contains(Cls.__dict__, '__truediv__')
#
# All 3 abc subjects return false for __truediv__.
# abc.ABC: a plain abstract base class helper; not an arithmetic type.
#   ABC / n or ABC / ABC is not defined — ABC is a class factory aid,
#   not a numeric or collection type.
# abc.ABCMeta: a metaclass for abstract base class machinery; no / operator.
#   ABCMeta handles class hierarchy, abstract method tracking, and virtual
#   subclass registration. None of these capabilities map to division.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __truediv__. f / g is not a valid Python
#   expression. Function composition is achieved through explicit wrapping,
#   functools.reduce, or similar — not through the / operator.
# ---------------------------------------------------------------------------

table ab3181.truediv:
  description: "abc types __truediv__ dict-presence checks; wave 659"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3181

  columns: [id, function, args, expected]
  rows:
    - ["ab3181001", operator.contains, [abc.ABC.__dict__,                                 "__truediv__"], false]
    - ["ab3181002", operator.contains, [abc.ABCMeta.__dict__,                             "__truediv__"], false]
    - ["ab3181003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__truediv__"], false]

# ---------------------------------------------------------------------------
# __floordiv__ dict-presence — operator.contains(Cls.__dict__, '__floordiv__')
#
# All 3 abc subjects return false for __floordiv__.
# abc.ABC: no floor division protocol; abstract base classes are not
#   numeric types and do not participate in // arithmetic.
# abc.ABCMeta: does not define // for metaclass floor division.
#   ABCMeta's power lies in __subclasshook__, register(), and
#   __abstractmethods__ — none of which involve floor division.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __floordiv__. f // g is not a valid Python
#   expression. Functions are not divisible operands.
# ---------------------------------------------------------------------------

table ab3181.floordiv:
  description: "abc types __floordiv__ dict-presence checks; wave 659"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3181

  columns: [id, function, args, expected]
  rows:
    - ["ab3181004", operator.contains, [abc.ABC.__dict__,                                 "__floordiv__"], false]
    - ["ab3181005", operator.contains, [abc.ABCMeta.__dict__,                             "__floordiv__"], false]
    - ["ab3181006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__floordiv__"], false]

# ---------------------------------------------------------------------------
# __mod__ dict-presence — operator.contains(Cls.__dict__, '__mod__')
#
# All 3 abc subjects return false for __mod__.
# abc.ABC: does not define % — ABC is not a numeric or string type.
#   abc.ABC % something is not a defined operation.
# abc.ABCMeta: does not define % for metaclass modulo. ABCMeta is a
#   powerful metaclass, but its API surface (subclasshook, register,
#   abstractmethods) has no modulo component. Old-style % formatting
#   (__mod__ on str) does not apply to metaclass objects.
# type(abc.abstractmethod(lambda: None)) is <class 'function'>:
#   functions do not define __mod__. f % args is not how Python calls
#   functions with arguments — that would be f(*args). The % operator on
#   functions is not defined. str.__mod__ handles % formatting for strings;
#   functions have no analogous modulo protocol.
# ---------------------------------------------------------------------------

table ab3181.mod:
  description: "abc types __mod__ dict-presence checks; wave 659"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
