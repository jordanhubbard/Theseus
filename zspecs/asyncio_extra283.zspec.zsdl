spec: asyncio_extra283
version: ">=3.13"
backend: python_module(asyncio.queues)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio Queues documentation"
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "asyncio_extra282.zspec.zsdl — covers asyncio.coroutines module identity; iscoroutine and iscoroutinefunction function identity"
    - "asyncio_extra281.zspec.zsdl — covers asyncio.runners module identity; asyncio.run and asyncio.Runner class identity"
    - "asyncio_extra280.zspec.zsdl — covers asyncio.exceptions module identity; CancelledError, InvalidStateError, SendfileNotAvailableError class identity"
    - "asyncio_extra28.zspec.zsdl — covers Queue/Lock/Event __module__.__len__(); class __name__.__len__() and function __qualname__ checks"
    - "asyncio_extra.zspec.zsdl — covers Queue/Lock/Event/Semaphore/Task/Future __name__ and __module__ equality checks"
  notes:
    - "This spec covers: asyncio.queues submodule identity (__name__, __spec__.name, __package__, __loader__.__class__.__name__, __all__ class and len); Queue method __qualname__ lengths (put_nowait, get_nowait, put, get, empty, full, qsize, task_done, join); LifoQueue/PriorityQueue __module__ equality, __name__.__len__(), __mro__.__len__(); QueueShutDown (added 3.13) class identity."
    - "asyncio.queues.__name__ == 'asyncio.queues' (len=14); __package__ == 'asyncio' (len=7); __spec__.name == 'asyncio.queues'; __loader__.__class__.__name__ == 'SourceFileLoader' (plain source module). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.queues.__all__ is a tuple (not a list) with 6 members: ('Queue', 'PriorityQueue', 'LifoQueue', 'QueueFull', 'QueueEmpty', 'QueueShutDown'). QueueShutDown was added in Python 3.13. Compare: asyncio.coroutines.__all__ has 2 members. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "Queue method __qualname__ lengths: put_nowait=16, get_nowait=16, put=9, get=9, empty=11, full=10, qsize=11, task_done=15, join=10. put_nowait and get_nowait are the two longest Queue method qualnames (both 16 chars: 'Queue.'=6 + 'put_nowait'/'get_nowait'=10). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "LifoQueue and PriorityQueue both have __module__ == 'asyncio.queues' and __bases__[0].__name__ == 'Queue'. Their __mro__.__len__() == 4 (LifoQueue/PriorityQueue -> Queue -> _LoopBoundMixin -> object). LifoQueue.__name__.__len__()==9; PriorityQueue.__name__.__len__()==13. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "QueueShutDown.__name__.__len__()==13; QueueShutDown.__bases__[0].__name__=='Exception'; QueueShutDown.__mro__.__len__()==4 (QueueShutDown, Exception, BaseException, object). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "LifoQueue.put_nowait.__qualname__ == 'Queue.put_nowait' — inherited from Queue, not overridden. PriorityQueue.put_nowait.__qualname__ == 'Queue.put_nowait' — same. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.queues module identity — extra283
#
# asyncio.queues.__name__             == 'asyncio.queues'    (len=14)
# asyncio.queues.__spec__.name        == 'asyncio.queues'
# asyncio.queues.__package__          == 'asyncio'           (len=7)
# asyncio.queues.__loader__.__class__.__name__ == 'SourceFileLoader'
# asyncio.queues.__all__.__class__.__name__    == 'tuple'
# asyncio.queues.__all__.__len__()             == 6
# ---------------------------------------------------------------------------

table asyncio_extra283.asyncio_queues_module_identity:
  description: "asyncio.queues module identity checks in extra283 namespace — asyncio.queues.__name__=='asyncio.queues' (len=14); __spec__.name=='asyncio.queues'; __package__=='asyncio' (len=7); __loader__.__class__.__name__=='SourceFileLoader' (plain source module); __all__ is a tuple with 6 members including QueueShutDown (added 3.13); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqueues283

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,   asyncio.queues.__name__.__eq__,                      ["asyncio.queues"],   true,  "asyncio.queues.__name__ == 'asyncio.queues'; verified with Python 3.14.3"]
    - [mod_spec_eq,   asyncio.queues.__spec__.name.__eq__,                 ["asyncio.queues"],   true,  "asyncio.queues.__spec__.name == 'asyncio.queues'; verified with Python 3.14.3"]
    - [mod_name_len,  asyncio.queues.__name__.__len__,                     [],                   14,    "asyncio.queues.__name__.__len__() == 14 ('asyncio.queues'=14); verified with Python 3.14.3"]
    - [mod_pkg_eq,    asyncio.queues.__package__.__eq__,                   ["asyncio"],          true,  "asyncio.queues.__package__ == 'asyncio' (parent package); verified with Python 3.14.3"]
    - [mod_loader_eq, asyncio.queues.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true,  "asyncio.queues.__loader__.__class__.__name__ == 'SourceFileLoader'; verified with Python 3.14.3"]
    - [all_class_eq,  asyncio.queues.__all__.__class__.__name__.__eq__,    ["tuple"],            true,  "asyncio.queues.__all__.__class__.__name__ == 'tuple' (not a list); verified with Python 3.14.3"]
    - [all_len,       asyncio.queues.__all__.__len__,                      [],                   6,     "asyncio.queues.__all__.__len__() == 6 — Queue/PriorityQueue/LifoQueue/QueueFull/QueueEmpty/QueueShutDown; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Queue method __qualname__ length table — extra283
#
# All Queue methods carry 'Queue.' (6 chars) as their __qualname__ prefix.
# Lengths for the public API methods:
#   Queue.put_nowait.__qualname__  == 'Queue.put_nowait'  (16)
#   Queue.get_nowait.__qualname__  == 'Queue.get_nowait'  (16)
#   Queue.task_done.__qualname__   == 'Queue.task_done'   (15)
#   Queue.empty.__qualname__       == 'Queue.empty'       (11)
#   Queue.qsize.__qualname__       == 'Queue.qsize'       (11)
#   Queue.full.__qualname__        == 'Queue.full'        (10)
#   Queue.join.__qualname__        == 'Queue.join'        (10)
#   Queue.put.__qualname__         == 'Queue.put'         (9)
#   Queue.get.__qualname__         == 'Queue.get'         (9)
# put_nowait and get_nowait share the maximum length of 16 among Queue methods.
# ---------------------------------------------------------------------------

table asyncio_extra283.queue_method_qualname_lengths:
  description: "asyncio.Queue method __qualname__.__len__() for public API methods in extra283 namespace — put_nowait/get_nowait tie at 16 (longest); put/get tie at 9 (shortest); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: qmqualnamelen283

  columns: [id, function, args, expected]
  rows:
    - [put_nowait, Queue.put_nowait.__qualname__.__len__, [], 16]
    - [get_nowait, Queue.get_nowait.__qualname__.__len__, [], 16]
    - [task_done,  Queue.task_done.__qualname__.__len__,  [], 15]
    - [empty,      Queue.empty.__qualname__.__len__,      [], 11]
    - [qsize,      Queue.qsize.__qualname__.__len__,      [], 11]
    - [full,       Queue.full.__qualname__.__len__,       [], 10]
    - [join,       Queue.join.__qualname__.__len__,       [], 10]
    - [put,        Queue.put.__qualname__.__len__,        [], 9]
    - [get,        Queue.get.__qualname__.__len__,        [], 9]

# ---------------------------------------------------------------------------
# LifoQueue and PriorityQueue class identity — extra283
#
# Both LifoQueue and PriorityQueue are subclasses of Queue defined in
# asyncio.queues. Key facts:
#   LifoQueue.__module__      == 'asyncio.queues'  (len=14)
#   LifoQueue.__name__.__len__() == 9
#   LifoQueue.__mro__.__len__()  == 4
#   PriorityQueue.__module__     == 'asyncio.queues' (len=14)
#   PriorityQueue.__name__.__len__() == 13
#   PriorityQueue.__mro__.__len__()  == 4
# LifoQueue.put_nowait.__qualname__ == 'Queue.put_nowait' — inherited from Queue.
# PriorityQueue.put_nowait.__qualname__ == 'Queue.put_nowait' — also inherited.
# ---------------------------------------------------------------------------

invariant asyncio_extra283.LifoQueue.module_eq:
  description: "asyncio.LifoQueue.__module__ == 'asyncio.queues' — LifoQueue is defined in the asyncio.queues submodule"
  category: identity
  kind: python_call_eq
  function: LifoQueue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra283.PriorityQueue.module_eq:
  description: "asyncio.PriorityQueue.__module__ == 'asyncio.queues' — PriorityQueue is defined in the asyncio.queues submodule"
  category: identity
  kind: python_call_eq
  function: PriorityQueue.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra283.LifoQueue.name_len:
  description: "asyncio.LifoQueue.__name__.__len__() == 9 — 'LifoQueue' is 9 characters"
  category: identity
  kind: python_call_eq
  function: LifoQueue.__name__.__len__
  args: []
  expected: 9

invariant asyncio_extra283.PriorityQueue.name_len:
  description: "asyncio.PriorityQueue.__name__.__len__() == 13 — 'PriorityQueue' is 13 characters"
  category: identity
  kind: python_call_eq
  function: PriorityQueue.__name__.__len__
  args: []
  expected: 13

invariant asyncio_extra283.LifoQueue.mro_len:
  description: "asyncio.LifoQueue.__mro__.__len__() == 4 — MRO is [LifoQueue, Queue, _LoopBoundMixin, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: LifoQueue.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra283.PriorityQueue.mro_len:
  description: "asyncio.PriorityQueue.__mro__.__len__() == 4 — MRO is [PriorityQueue, Queue, _LoopBoundMixin, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: PriorityQueue.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# QueueShutDown class identity (Python 3.13+) — extra283
#
# QueueShutDown was added in Python 3.13 to signal that a queue has been
# shut down (via Queue.shutdown()). It is an Exception subclass.
# QueueShutDown.__name__.__len__()      == 13
# QueueShutDown.__bases__[0].__name__   == 'Exception'
# QueueShutDown.__mro__.__len__()       == 4  ([QueueShutDown, Exception, BaseException, object])
# QueueShutDown.__module__              == 'asyncio.queues'
# ---------------------------------------------------------------------------

invariant asyncio_extra283.QueueShutDown.module_eq:
  description: "asyncio.QueueShutDown.__module__ == 'asyncio.queues' — new exception added in Python 3.13"
  category: identity
  kind: python_call_eq
  function: QueueShutDown.__module__.__eq__
  args: ["asyncio.queues"]
  expected: true

invariant asyncio_extra283.QueueShutDown.base_name_eq:
  description: "asyncio.QueueShutDown.__bases__[0].__name__ == 'Exception' — QueueShutDown is a direct Exception subclass"
  category: class_hierarchy
  kind: python_call_eq
  function: "QueueShutDown.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant asyncio_extra283.QueueShutDown.mro_len:
  description: "asyncio.QueueShutDown.__mro__.__len__() == 4 — [QueueShutDown, Exception, BaseException, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: QueueShutDown.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra283.Queue.put_nowait_qualname_eq:
  description: "asyncio.Queue.put_nowait.__qualname__ == 'Queue.put_nowait' — method defined on Queue itself (len=16)"
  category: method_names
  kind: python_call_eq
  function: Queue.put_nowait.__qualname__.__eq__
  args: ["Queue.put_nowait"]
  expected: true

invariant asyncio_extra283.LifoQueue.put_nowait_qualname_inherited:
  description: "asyncio.LifoQueue.put_nowait.__qualname__ == 'Queue.put_nowait' — put_nowait is inherited from Queue, not overridden in LifoQueue"
  category: method_names
  kind: python_call_eq
  function: LifoQueue.put_nowait.__qualname__.__eq__
  args: ["Queue.put_nowait"]
  expected: true
