spec: abc_extra199
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers abc.__dict__ membership: abc has no __all__, so __dict__.__contains__ is used instead."
    - "abc has no __all__ attribute; all public-name checks use abc.__dict__.__contains__. Verified with Python 3.14.3."
    - "abc.__dict__.__class__.__name__ == 'dict' — the module __dict__ is a plain Python dict. Verified with Python 3.14.3."
    - "abc.__dict__.__len__() == 22 — abc.__dict__ has exactly 22 keys as of Python 3.14.3."
    - "'ABC' in abc.__dict__ == True — ABC is the convenience base class for abstract base classes. Verified with Python 3.14.3."
    - "'ABCMeta' in abc.__dict__ == True — ABCMeta is the metaclass for ABCs. Verified with Python 3.14.3."
    - "'abstractmethod' in abc.__dict__ == True — abstractmethod is the decorator for abstract methods. Verified with Python 3.14.3."
    - "'get_cache_token' in abc.__dict__ == True — get_cache_token returns the ABC caching token. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.__dict__ type and length
#
# abc.__dict__.__class__.__name__ == 'dict' (len 4)
# abc.__dict__.__len__() == 22
# New to abc_extra199.
# ---------------------------------------------------------------------------

table abc_extra199.dict_type_and_len:
  description: "abc.__dict__ is a dict of 22 keys; abc has no __all__; new to abc_extra199"
  kind: python_call_eq
  category: dict_attrs
  id_prefix: abcall199

  columns: [id, function, args, expected, description]
  rows:
    - [dict_class_name_eq,
       "__dict__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "abc.__dict__.__class__.__name__.__eq__('dict') == True — module __dict__ is a plain dict; new to abc_extra199"]
    - [dict_class_name_len_eq_4,
       "__dict__.__class__.__name__.__len__",
       [],
       4,
       "abc.__dict__.__class__.__name__.__len__() == 4 — 'dict' has 4 characters; new to abc_extra199"]
    - [dict_len_eq_22,
       "__dict__.__len__",
       [],
       22,
       "abc.__dict__.__len__() == 22 — abc module dict has exactly 22 keys; new to abc_extra199"]
    - [dict_contains_abc,
       "__dict__.__contains__",
       ["ABC"],
       true,
       "abc.__dict__.__contains__('ABC') == True — ABC convenience class is present; new to abc_extra199"]

# ---------------------------------------------------------------------------
# Table 2: abc.__dict__ membership — core metaclass and decorator
#
# 'ABCMeta', 'abstractmethod', 'abstractproperty', 'abstractclassmethod' checks
# New to abc_extra199.
# ---------------------------------------------------------------------------

table abc_extra199.dict_membership_core:
  description: "abc.__dict__ contains ABCMeta, abstractmethod, abstractproperty, abstractclassmethod; new to abc_extra199"
  kind: python_call_eq
  category: dict_attrs
  id_prefix: abcall199

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_abcmeta,
       "__dict__.__contains__",
       ["ABCMeta"],
       true,
       "abc.__dict__.__contains__('ABCMeta') == True — ABCMeta is the metaclass for ABCs; new to abc_extra199"]
    - [dict_contains_abstractmethod,
       "__dict__.__contains__",
       ["abstractmethod"],
       true,
       "abc.__dict__.__contains__('abstractmethod') == True — abstractmethod is the core ABC decorator; new to abc_extra199"]
    - [dict_contains_abstractproperty,
       "__dict__.__contains__",
       ["abstractproperty"],
       true,
       "abc.__dict__.__contains__('abstractproperty') == True — abstractproperty (deprecated) is present; new to abc_extra199"]
    - [dict_contains_abstractclassmethod,
       "__dict__.__contains__",
       ["abstractclassmethod"],
       true,
       "abc.__dict__.__contains__('abstractclassmethod') == True — abstractclassmethod (deprecated) is present; new to abc_extra199"]

# ---------------------------------------------------------------------------
# Table 3: abc.__dict__ membership — remaining public names
#
# 'abstractstaticmethod', 'get_cache_token' checks plus module name identity
# New to abc_extra199.
# ---------------------------------------------------------------------------

table abc_extra199.dict_membership_remaining:
  description: "abc.__dict__ contains abstractstaticmethod, get_cache_token; module name checks; new to abc_extra199"
  kind: python_call_eq
  category: dict_attrs
  id_prefix: abcall199

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_abstractstaticmethod,
       "__dict__.__contains__",
       ["abstractstaticmethod"],
       true,
       "abc.__dict__.__contains__('abstractstaticmethod') == True — abstractstaticmethod (deprecated) is present; new to abc_extra199"]
    - [dict_contains_get_cache_token,
       "__dict__.__contains__",
       ["get_cache_token"],
       true,
       "abc.__dict__.__contains__('get_cache_token') == True — get_cache_token returns the ABC caching token; new to abc_extra199"]
    - [module_name_eq,
       "__name__.__eq__",
       ["abc"],
       true,
       "abc.__name__.__eq__('abc') == True — module name is 'abc'; new to abc_extra199"]
    - [module_name_len_eq_3,
       "__name__.__len__",
       [],
       3,
       "abc.__name__.__len__() == 3 — 'abc' has 3 characters; new to abc_extra199"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra199
# ---------------------------------------------------------------------------

invariant abc_extra199.dict_class_name_eq_dict:
  description: "abc.__dict__.__class__.__name__ == 'dict' — the module __dict__ is a plain Python dict; abc has no __all__; new to abc_extra199; verified Python 3.14.3"
  category: dict_attrs
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant abc_extra199.dict_len_eq_22:
  description: "abc.__dict__.__len__() == 22 — abc module dict has exactly 22 keys; new to abc_extra199; verified Python 3.14.3"
  category: dict_attrs
  kind: python_call_eq
  function: __dict__.__len__
  args: []
  expected: 22

invariant abc_extra199.dict_contains_abc:
  description: "abc.__dict__.__contains__('ABC') == True — ABC is the convenience base class for abstract base classes; new to abc_extra199; verified Python 3.14.3"
  category: dict_attrs
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["ABC"]
  expected: true

invariant abc_extra199.dict_contains_abcmeta:
  description: "abc.__dict__.__contains__('ABCMeta') == True — ABCMeta is the metaclass for all ABCs; new to abc_extra199; verified Python 3.14.3"
  category: dict_attrs
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra199.dict_contains_abstractmethod:
  description: "abc.__dict__.__contains__('abstractmethod') == True — abstractmethod is the core decorator for abstract methods; new to abc_extra199; verified Python 3.14.3"
  category: dict_attrs
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra199.dict_contains_abstractclassmethod:
  description: "abc.__dict__.__contains__('abstractclassmethod') == True — abstractclassmethod (deprecated since 3.3) is still present; new to abc_extra199; verified Python 3.14.3"
  category: dict_attrs
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["abstractclassmethod"]
  expected: true

invariant abc_extra199.dict_contains_abstractstaticmethod:
  description: "abc.__dict__.__contains__('abstractstaticmethod') == True — abstractstaticmethod (deprecated since 3.3) is still present; new to abc_extra199; verified Python 3.14.3"
  category: dict_attrs
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["abstractstaticmethod"]
  expected: true

invariant abc_extra199.dict_contains_get_cache_token:
  description: "abc.__dict__.__contains__('get_cache_token') == True — get_cache_token returns the current ABC caching token; new to abc_extra199; verified Python 3.14.3"
  category: dict_attrs
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["get_cache_token"]
  expected: true

