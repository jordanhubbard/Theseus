spec: dataclasses_extra23
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl through dataclasses_extra22.zspec.zsdl."
    - "dataclasses_extra22 covers: combined __qualname__.__eq__ table for Field/InitVar/FrozenInstanceError; combined __bases__[0].__name__ table for those three; Field.__mro__.__len__ == 2 standalone; InitVar.__mro__.__len__ == 2 standalone; MISSING.__class__.__module__ standalone."
    - "dataclasses_extra20 covers: combined __name__ table for dataclass/field/fields/asdict/astuple/make_dataclass/replace."
    - "dataclasses_extra19 covers: fields/__qualname__.__eq__; is_dataclass/__qualname__.__eq__; asdict/__qualname__.__eq__; astuple/__qualname__.__eq__; replace/__qualname__.__eq__; make_dataclass/__qualname__.__eq__."
    - "Focus of this spec: (1) combined __qualname__ table for dataclass/field/asdict/astuple/make_dataclass/replace/fields/is_dataclass — function qualnames not yet tested together in the extra23 namespace; (2) combined __qualname__.__len__ table for dataclass/asdict/astuple/make_dataclass; (3) dataclass.__qualname__.__len__ == 9 standalone; (4) make_dataclass.__qualname__.__len__ == 14 standalone."
    - "NOT yet covered (entering this spec): combined __qualname__ table for all eight function names in the extra23 namespace; combined __qualname__.__len__ table for dataclass/asdict/astuple/make_dataclass; dataclass.__qualname__.__len__ == 9 standalone; make_dataclass.__qualname__.__len__ == 14 standalone."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for the eight primary dataclasses functions
#
# dataclasses_extra19 covers __qualname__.__eq__ for six of these as
# standalone invariants. dataclasses_extra20 covers __name__ for seven.
# No prior spec collects all eight together in one combined __qualname__ table
# under the extra23 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra23.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__qualname__.__eq__,      ["dataclass"],      true]
    - [field,          field.__qualname__.__eq__,          ["field"],          true]
    - [asdict,         asdict.__qualname__.__eq__,         ["asdict"],         true]
    - [astuple,        astuple.__qualname__.__eq__,        ["astuple"],        true]
    - [make_dataclass, make_dataclass.__qualname__.__eq__, ["make_dataclass"], true]
    - [replace,        replace.__qualname__.__eq__,        ["replace"],        true]
    - [fields,         fields.__qualname__.__eq__,         ["fields"],         true]
    - [is_dataclass,   is_dataclass.__qualname__.__eq__,   ["is_dataclass"],   true]

# ---------------------------------------------------------------------------
# __qualname__.__len__ for dataclass, asdict, astuple, make_dataclass
#
# These four function names have qualname lengths of 9, 6, 7, and 14
# respectively. No prior spec collects these four lengths together in one
# combined table under the extra23 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra23.function_qualname_lens:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__qualname__.__len__,      [], 9]
    - [asdict,         asdict.__qualname__.__len__,         [], 6]
    - [astuple,        astuple.__qualname__.__len__,        [], 7]
    - [make_dataclass, make_dataclass.__qualname__.__len__, [], 14]

# ---------------------------------------------------------------------------
# dataclass.__qualname__.__len__() == 9
#
# The qualname string 'dataclass' has length 9. dataclasses_extra19 covers
# dataclass/__qualname__.__eq__ but not its length as a standalone invariant.
# ---------------------------------------------------------------------------

invariant dataclasses_extra23.dataclass.qualname.len:
  description: "dataclasses.dataclass.__qualname__.__len__() == 9 — len('dataclass') == 9"
  category: qualnames
  kind: python_call_eq
  function: dataclass.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# make_dataclass.__qualname__.__len__() == 14
#
# The qualname string 'make_dataclass' has length 14. No prior spec verifies
# the length of make_dataclass.__qualname__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant dataclasses_extra23.make_dataclass.qualname.len:
  description: "dataclasses.make_dataclass.__qualname__.__len__() == 14 — len('make_dataclass') == 14"
  category: qualnames
  kind: python_call_eq
  function: make_dataclass.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# field.__qualname__.__len__() == 5
#
# The qualname string 'field' has length 5. No prior spec verifies the length
# of field.__qualname__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant dataclasses_extra23.field.qualname.len:
  description: "dataclasses.field.__qualname__.__len__() == 5 — len('field') == 5"
  category: qualnames
  kind: python_call_eq
  function: field.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# replace.__qualname__.__len__() == 7
#
# The qualname string 'replace' has length 7. No prior spec verifies the
# length of replace.__qualname__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant dataclasses_extra23.replace.qualname.len:
  description: "dataclasses.replace.__qualname__.__len__() == 7 — len('replace') == 7"
  category: qualnames
  kind: python_call_eq
  function: replace.__qualname__.__len__
  args: []
  expected: 7
