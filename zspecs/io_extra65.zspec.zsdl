spec: io_extra65
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra64.zspec.zsdl — covers io.__all__.__contains__ membership; io.__package__.__eq__(''); io BytesIO/IOBase __doc__.__class__.__name__.__len__()==3."
    - "io_extra62.zspec.zsdl — covers BytesIO/StringIO/TextIOWrapper/IOBase/RawIOBase __repr__.__class__.__name__.__eq__('wrapper_descriptor'); io.__spec__.__class__.__name__.__eq__('ModuleSpec'); io.__spec__.name.__class__.__name__.__eq__('str'); BytesIO/StringIO __hash__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "io_extra61.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper __class__.__module__.__eq__('builtins'); IOBase/RawIOBase/BufferedIOBase/TextIOBase __class__.__module__.__eq__('abc'); io.__spec__.name.__eq__('io') and __len__()==2."
    - "io_extra60.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/IOBase __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy')."
    - "io_extra44.zspec.zsdl — covers io.__name__.__len__()==2; io.__file__.__class__.__name__.__len__()==3."
  notes:
    - "This spec extends io_extra64.zspec.zsdl."
    - "Wave 225 theme: __loader__ identity + __spec__ attribute chains + __file__/__cached__ class name checks."
    - "IMPORTANT: io is a special hybrid module. io.__loader__ is the FrozenImporter CLASS itself (not an instance). Therefore io.__loader__.__class__ is 'type' (the metaclass), and io.__loader__.__name__ is 'FrozenImporter'. The Python wrapper io.py is loaded by the frozen bootstrap; the underlying _io C extension is separate."
    - "io.__loader__.__class__.__name__ == 'type' — io.__loader__ is the FrozenImporter class object itself, not an instance of FrozenImporter. The class of a class object is 'type' (the metaclass). This contrasts with pathlib/re/decimal where __loader__ is a SourceFileLoader instance and __loader__.__class__.__name__ == 'SourceFileLoader'. No prior io spec checks __loader__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__loader__.__name__ == 'FrozenImporter' — io.__loader__ is the FrozenImporter class; as a class it has a __name__ attribute equal to 'FrozenImporter'. This 14-character string identifies the frozen bootstrap importer used for io. No prior io spec checks __loader__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__spec__.origin == 'frozen' — io.__spec__.origin identifies the origin of the module's source. Because io is loaded by FrozenImporter, its origin is the string 'frozen'. This contrasts with pure Python modules (origin is a .py file path) and C extensions (origin is a .so path). No prior io spec checks __spec__.origin. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__file__.__class__.__name__.__eq__('str') == True — io_extra44 covers __file__.__class__.__name__.__len__()==3 (length anchor). The equality anchor __file__.__class__.__name__.__eq__('str') is distinct and novel in the ioload65 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io has NO __cached__ attribute (hasattr(io, '__cached__') == False). Because io.__loader__ is FrozenImporter (the bootstrap frozen importer), no bytecode cache path is set. This is unlike pure Python modules which always have __cached__. The absence of __cached__ is a key distinguishing feature of frozen/bootstrap-loaded modules."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.__loader__ identity: class name and loader name
#
# io is a special module: its __loader__ is the FrozenImporter CLASS OBJECT
# itself (not an instance). This means:
#
#   io.__loader__.__class__.__name__ == 'type'          (class of a class is type)
#   io.__loader__.__name__           == 'FrozenImporter'  (the class name)
#
# This differs fundamentally from pathlib/re/decimal where __loader__ is a
# SourceFileLoader instance and __loader__.__class__.__name__ == 'SourceFileLoader'.
#
# No prior io spec checks __loader__.__class__.__name__ or __loader__.__name__.
# Both anchors are novel in the ioload65 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra65.loader_identity:
  description: "io.__loader__ identity — io.__loader__ is the FrozenImporter class object itself (not an instance); therefore __loader__.__class__.__name__=='type' (metaclass) and __loader__.__name__=='FrozenImporter' (14 chars); contrasts with pure Python modules where __loader__ is a SourceFileLoader instance; no prior io spec checks __loader__ attributes; both anchors novel in ioload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: ioload65ldr

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_type,       __loader__.__class__.__name__.__eq__, ["type"],           true]
    - [loader_name_FrozenImporter,   __loader__.__name__.__eq__,           ["FrozenImporter"], true]
    - [loader_name_len_14,           __loader__.__name__.__len__,          [],                 14  ]

# ---------------------------------------------------------------------------
# io.__spec__.origin identity
#
# io.__spec__.origin identifies the source origin of the module. Because io
# is loaded by the frozen bootstrap importer (FrozenImporter), its origin is
# the string 'frozen'. This contrasts with:
#   - pure Python modules: origin is the path to the .py file
#   - C extensions: origin is the path to the .so/.pyd file
#
#   io.__spec__.origin.__eq__('frozen')           == True
#   io.__spec__.origin.__class__.__name__.__eq__('str') == True
#
# No prior io spec checks __spec__.origin. Both anchors are novel in ioload65.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra65.spec_origin:
  description: "io.__spec__.origin identity — io.__spec__.origin=='frozen' because io is loaded by FrozenImporter (bootstrap frozen importer); origin.__class__.__name__=='str'; contrasts with pure Python (.py path) and C extension (.so path) origins; no prior io spec checks __spec__.origin; both anchors novel in ioload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: ioload65orig

  columns: [id, function, args, expected]
  rows:
    - [spec_origin_frozen,           __spec__.origin.__eq__,                    ["frozen"], true]
    - [spec_origin_class_name_str,   __spec__.origin.__class__.__name__.__eq__, ["str"],    true]

# ---------------------------------------------------------------------------
# io.__file__.__class__.__name__.__eq__('str')
#
# io_extra44 covered io.__file__.__class__.__name__.__len__()==3 (length anchor).
# This spec adds the equality anchor: __file__.__class__.__name__.__eq__('str').
# The equality test is distinct from the length test and is novel in ioload65.
#
# io.__file__ is the path to io.py (the Python wrapper). Because io is a module
# with a Python wrapper file, __file__ is a str. Note that io has NO __cached__
# attribute (hasattr(io, '__cached__') == False) because its loader is
# FrozenImporter which does not set a bytecode cache path.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra65.file_class_name_eq:
  description: "io.__file__.__class__.__name__.__eq__('str') — io.__file__ is a str path to io.py (the Python wrapper); io_extra44 covers __file__.__class__.__name__.__len__()==3 (length); this __eq__('str') equality anchor is novel in ioload65 namespace; NOTE: io has no __cached__ attribute (FrozenImporter does not set bytecode cache); novel anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: ioload65file

  columns: [id, function, args, expected]
  rows:
    - [file_class_name_eq_str, __file__.__class__.__name__.__eq__, ["str"], true]

invariant io_extra65.loader_class_name_type:
  description: "io.__loader__.__class__.__name__.__eq__('type') == True — io.__loader__ is the FrozenImporter class object; the class of a class object is 'type' (the metaclass); no prior io spec checks __loader__.__class__.__name__; novel anchor in ioload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra65.loader_name_FrozenImporter:
  description: "io.__loader__.__name__.__eq__('FrozenImporter') == True — io.__loader__ is the FrozenImporter class; as a class it has __name__=='FrozenImporter'; no prior io spec checks __loader__.__name__; novel anchor in ioload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__name__.__eq__
  args: ["FrozenImporter"]
  expected: true

invariant io_extra65.spec_origin_frozen:
  description: "io.__spec__.origin.__eq__('frozen') == True — io is loaded by FrozenImporter so its spec origin is 'frozen'; contrasts with pure Python (file path) and C extension (.so path) origins; no prior io spec checks __spec__.origin; novel anchor in ioload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.origin.__eq__
  args: ["frozen"]
  expected: true

invariant io_extra65.file_class_name_eq_str:
  description: "io.__file__.__class__.__name__.__eq__('str') == True — io.__file__ is a str path to io.py; io_extra44 covers the length (3); this equality anchor is novel in ioload65 namespace; io has no __cached__ attribute (FrozenImporter does not set bytecode cache); verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
