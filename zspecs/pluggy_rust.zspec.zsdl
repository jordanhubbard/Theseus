spec: pluggy_rust
version: ">=3.9"
backend: rust_module(pluggy_rust)

docs: https://pluggy.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://pluggy.readthedocs.io/ — pluggy documentation"
  not_derived_from:
    - "pluggy source: src/pluggy/_manager.py"
  notes:
    - "pluggy: plugin management library used by pytest and other tools."
    - "PluginManager(project_name) creates a new plugin manager."
    - "Expose make_manager_name(name) -> str: returns PluginManager(name).project_name."
    - "Expose manager_plugin_count(name) -> int: len(PluginManager(name).get_plugins())."
    - "A fresh PluginManager has no plugins registered: get_plugins() returns empty list."
    - "Expose manager_is_registered(name, plugin) -> bool: False for fresh manager."
    - "HookspecMarker(project_name) creates a marker callable."
    - "Expose hookspec_project_name(name) -> str: HookspecMarker(name).project_name."
    - "All test vectors verified against pluggy 1.5.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# make_manager_name — PluginManager.project_name attribute
table pluggy_rust.manager.project_name:
  kind: python_call_eq
  category: project_name
  id_prefix: pg_pn
  function: make_manager_name

  columns: [id, args, expected]
  rows:
    - [myproject,  ["myproject"],  "myproject"]
    - [pytest,     ["pytest"],     "pytest"]
    - [myapp,      ["myapp"],      "myapp"]

# manager_plugin_count — fresh manager has 0 plugins
table pluggy_rust.manager.plugin_count:
  kind: python_call_eq
  category: plugin_count
  id_prefix: pg_pc
  function: manager_plugin_count

  columns: [id, args, expected]
  rows:
    - [myproject, ["myproject"], 0]
    - [pytest,    ["pytest"],    0]

# hookspec_project_name — HookspecMarker.project_name
table pluggy_rust.hookspec.project_name:
  kind: python_call_eq
  category: hookspec
  id_prefix: pg_hs
  function: hookspec_project_name

  columns: [id, args, expected]
  rows:
    - [myproject, ["myproject"], "myproject"]
    - [pytest,    ["pytest"],    "pytest"]
    - [myapp,     ["myapp"],     "myapp"]

# is_registered — fresh manager has nothing registered
invariant pluggy_rust.manager.not_registered:
  description: "Fresh PluginManager has no registered plugins"
  category: registered
  kind: python_call_eq
  function: manager_is_registered
  args: ["myproject", null]
  expected: false

