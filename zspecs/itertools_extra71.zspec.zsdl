spec: itertools_extra71
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra70.zspec.zsdl."
    - "Wave 237 theme: itertools C type __doc__ content — confirming each type has a str docstring."
    - "chain.__doc__.__class__.__name__ == 'str' — chain is a C type with a C-level docstring stored as a Python str. Verified with Python 3.14.3."
    - "chain.__doc__.__contains__('chain') == True — the word 'chain' appears in the chain type docstring. Verified with Python 3.14.3."
    - "islice.__doc__.__class__.__name__ == 'str' — islice has a C-level docstring stored as a Python str. Verified with Python 3.14.3."
    - "islice.__doc__.__contains__('islice') == True — the word 'islice' appears in the islice type docstring. Verified with Python 3.14.3."
    - "product.__doc__.__class__.__name__ == 'str' — product has a C-level docstring stored as a Python str. Verified with Python 3.14.3."
    - "product.__doc__.__contains__('product') == True — the word 'product' appears in the product type docstring. Verified with Python 3.14.3."
    - "cycle.__doc__.__class__.__name__ == 'str' — cycle has a C-level docstring stored as a Python str. Verified with Python 3.14.3."
    - "cycle.__doc__.__contains__('iterable') == True — the word 'iterable' appears in the cycle type docstring ('Return elements from the iterable until it is exhausted. Then repeat the sequence indefinitely.'). NOTE: 'cycle' itself does not appear in the cycle docstring text; 'iterable' is the keyword used instead. Verified with Python 3.14.3."
    - "accumulate.__doc__.__class__.__name__ == 'str' — accumulate has a C-level docstring stored as a Python str. Verified with Python 3.14.3."
    - "accumulate.__doc__.__contains__('accumulate') == True — the word 'accumulate' appears in the accumulate type docstring. Verified with Python 3.14.3."
    - "combinations.__doc__.__class__.__name__ == 'str' — combinations has a C-level docstring stored as a Python str. Verified with Python 3.14.3."
    - "combinations.__doc__.__contains__('combinations') == True — the word 'combinations' appears in the combinations type docstring. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools C type __doc__ class identity — set 1 — extra71
#
# Wave 237 theme: chain, islice, product, combinations each have a C-level
# docstring stored as a Python str object.
#
# chain.__doc__.__class__.__name__        == 'str'
# islice.__doc__.__class__.__name__       == 'str'
# product.__doc__.__class__.__name__      == 'str'
# combinations.__doc__.__class__.__name__ == 'str'
#
# No prior itertools spec checks __doc__.__class__.__name__ via itertdoc71. New to extra71.
# ---------------------------------------------------------------------------

table itertools_extra71.itertools_doc_class_1:
  description: "itertools types __doc__.__class__.__name__=='str': chain/islice/product/combinations; wave 237 __doc__ class identity; new to extra71"
  kind: python_call_eq
  category: type_doc
  id_prefix: itertdoc71

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_class_name_eq_str,
       chain.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — chain is a C extension type defined in Modules/itertoolsmodule.c; C extension types expose their docstring as the tp_doc slot which Python makes available as the __doc__ attribute; this docstring is a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior itertools spec checks chain.__doc__.__class__.__name__ via itertdoc71; new to extra71"]
    - [islice_doc_class_name_eq_str,
       islice.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.islice.__doc__.__class__.__name__.__eq__('str') == True — islice is a C extension type defined in Modules/itertoolsmodule.c; its tp_doc slot docstring is accessible as __doc__ and is a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior itertools spec checks islice.__doc__.__class__.__name__ via itertdoc71; new to extra71"]
    - [product_doc_class_name_eq_str,
       product.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.product.__doc__.__class__.__name__.__eq__('str') == True — product is a C extension type defined in Modules/itertoolsmodule.c; its tp_doc slot docstring is accessible as __doc__ and is a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior itertools spec checks product.__doc__.__class__.__name__ via itertdoc71; new to extra71"]
    - [combinations_doc_class_name_eq_str,
       combinations.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.combinations.__doc__.__class__.__name__.__eq__('str') == True — combinations is a C extension type defined in Modules/itertoolsmodule.c; its tp_doc slot docstring is accessible as __doc__ and is a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior itertools spec checks combinations.__doc__.__class__.__name__ via itertdoc71; new to extra71"]

# ---------------------------------------------------------------------------
# itertools C type __doc__ content — set 2 — extra71
#
# Wave 237 theme: chain and islice docstrings contain their own type names.
#
# chain.__doc__.__contains__('chain')   == True
# islice.__doc__.__contains__('islice') == True
#
# No prior itertools spec checks __doc__.__contains__ via itertdoc71. New to extra71.
# ---------------------------------------------------------------------------

table itertools_extra71.itertools_doc_contains_1:
  description: "chain.__doc__ contains 'chain', islice.__doc__ contains 'islice'; wave 237 __doc__ content; new to extra71"
  kind: python_call_eq
  category: type_doc
  id_prefix: itertdoc71

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_contains_chain,
       chain.__doc__.__contains__,
       ["chain"],
       true,
       "itertools.chain.__doc__.__contains__('chain') == True — the chain type docstring describes the chain class and uses its name 'chain' in the description; str.__contains__('chain') returns True at the first occurrence of the 4-char substring; no prior itertools spec checks chain.__doc__.__contains__('chain') via itertdoc71; new to extra71"]
    - [islice_doc_contains_islice,
       islice.__doc__.__contains__,
       ["islice"],
       true,
       "itertools.islice.__doc__.__contains__('islice') == True — the islice type docstring describes the islice class and uses its name 'islice' in the description; str.__contains__('islice') returns True at the first occurrence of the 6-char substring; no prior itertools spec checks islice.__doc__.__contains__('islice') via itertdoc71; new to extra71"]

# ---------------------------------------------------------------------------
# itertools C type __doc__ content — set 3 — extra71
#
# Wave 237 theme: product, accumulate, combinations docstrings contain their names.
#
# product.__doc__.__contains__('product')             == True
# accumulate.__doc__.__contains__('accumulate')       == True
# combinations.__doc__.__contains__('combinations')   == True
#
# cycle.__doc__.__contains__('iterable') == True (NOTE: 'cycle' is NOT in the
# cycle docstring; the word 'iterable' appears instead in the description
# "Return elements from the iterable until it is exhausted.")
#
# No prior itertools spec checks these __doc__ contents via itertdoc71. New to extra71.
# ---------------------------------------------------------------------------

table itertools_extra71.itertools_doc_contains_2:
  description: "product/__doc__ contains 'product', accumulate/__doc__ contains 'accumulate', combinations/__doc__ contains 'combinations'; wave 237 __doc__ content; new to extra71"
  kind: python_call_eq
  category: type_doc
  id_prefix: itertdoc71

  columns: [id, function, args, expected, description]
  rows:
    - [product_doc_contains_product,
       product.__doc__.__contains__,
       ["product"],
       true,
       "itertools.product.__doc__.__contains__('product') == True — the product type docstring describes the Cartesian product and uses the word 'product' in the description; str.__contains__('product') returns True; no prior itertools spec checks product.__doc__.__contains__('product') via itertdoc71; new to extra71"]
    - [accumulate_doc_contains_accumulate,
       accumulate.__doc__.__contains__,
       ["accumulate"],
       true,
       "itertools.accumulate.__doc__.__contains__('accumulate') == True — the accumulate type docstring describes the accumulate function and uses the word 'accumulate' in the description; str.__contains__('accumulate') returns True; no prior itertools spec checks accumulate.__doc__.__contains__('accumulate') via itertdoc71; new to extra71"]
    - [combinations_doc_contains_combinations,
       combinations.__doc__.__contains__,
       ["combinations"],
       true,
       "itertools.combinations.__doc__.__contains__('combinations') == True — the combinations type docstring describes r-length subsequences and uses the word 'combinations' in the description; str.__contains__('combinations') returns True; no prior itertools spec checks combinations.__doc__.__contains__('combinations') via itertdoc71; new to extra71"]

# ---------------------------------------------------------------------------
# itertools cycle and accumulate __doc__ class identity — set 4 — extra71
#
# Wave 237 theme: cycle and accumulate __doc__ are str; cycle doc contains
# 'iterable' (not 'cycle' — the cycle docstring does not mention its own name).
#
# cycle.__doc__.__class__.__name__        == 'str'
# cycle.__doc__.__contains__('iterable') == True
# accumulate.__doc__.__class__.__name__   == 'str'
#
# No prior itertools spec checks cycle or accumulate __doc__ via itertdoc71. New to extra71.
# ---------------------------------------------------------------------------

table itertools_extra71.itertools_cycle_accumulate_doc:
  description: "cycle.__doc__ is str and contains 'iterable'; accumulate.__doc__ is str; wave 237 cycle/accumulate __doc__; new to extra71"
  kind: python_call_eq
  category: type_doc
  id_prefix: itertdoc71

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_doc_class_name_eq_str,
       cycle.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.cycle.__doc__.__class__.__name__.__eq__('str') == True — cycle is a C extension type defined in Modules/itertoolsmodule.c; its tp_doc slot docstring ('Return elements from the iterable until it is exhausted. Then repeat the sequence indefinitely.') is accessible as __doc__ and is a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior itertools spec checks cycle.__doc__.__class__.__name__ via itertdoc71; new to extra71"]
    - [cycle_doc_contains_iterable,
       cycle.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.cycle.__doc__.__contains__('iterable') == True — the cycle type docstring reads 'Return elements from the iterable until it is exhausted. Then repeat the sequence indefinitely.'; the word 'iterable' (8 chars) appears in the description; note that 'cycle' itself does NOT appear in the docstring body; str.__contains__('iterable') returns True; no prior itertools spec checks cycle.__doc__.__contains__('iterable') via itertdoc71; new to extra71"]
    - [accumulate_doc_class_name_eq_str,
       accumulate.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "itertools.accumulate.__doc__.__class__.__name__.__eq__('str') == True — accumulate is a C extension type defined in Modules/itertoolsmodule.c; its tp_doc slot docstring is accessible as __doc__ and is a Python str object; str.__name__ == 'str' (3 chars); __eq__ returns True; no prior itertools spec checks accumulate.__doc__.__class__.__name__ via itertdoc71; new to extra71"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra71
# ---------------------------------------------------------------------------

invariant itertools_extra71.chain_doc_str:
  description: "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — chain has a C-level str docstring; wave 237 __doc__ class identity; new to extra71"
  kind: python_call_eq
  function: chain.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra71.chain_doc_contains_chain:
  description: "itertools.chain.__doc__.__contains__('chain') == True — 'chain' appears in the chain docstring; wave 237 __doc__ content; new to extra71"
  kind: python_call_eq
  function: chain.__doc__.__contains__
  args: ["chain"]
  expected: true

invariant itertools_extra71.islice_doc_contains_islice:
  description: "itertools.islice.__doc__.__contains__('islice') == True — 'islice' appears in the islice docstring; wave 237 __doc__ content; new to extra71"
  kind: python_call_eq
  function: islice.__doc__.__contains__
  args: ["islice"]
  expected: true

invariant itertools_extra71.cycle_doc_contains_iterable:
  description: "itertools.cycle.__doc__.__contains__('iterable') == True — 'iterable' appears in the cycle docstring (the word 'cycle' does not appear in the cycle docstring body); wave 237 __doc__ content; new to extra71"
  kind: python_call_eq
  function: cycle.__doc__.__contains__
  args: ["iterable"]
  expected: true

invariant itertools_extra71.combinations_doc_contains_combinations:
  description: "itertools.combinations.__doc__.__contains__('combinations') == True — 'combinations' appears in the combinations docstring; wave 237 __doc__ content; new to extra71"
  kind: python_call_eq
  function: combinations.__doc__.__contains__
  args: ["combinations"]
  expected: true
