spec: ab2956
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 644 — theme: __invert__, __round__, __trunc__ dict-presence (bitwise invert, round, truncate)."
    - "Tests operator.contains(SomeClass.__dict__, '__invert__') etc. for abc module classes."
    - "Classes covered: ABC, ABCMeta, and the built-in 'function' type (type of abc.abstractmethod(lambda: None))."
    - "abstractproperty is deliberately excluded (deprecated and removed in Python 3.13)."
    - "None of ABC, ABCMeta, or the function type define __invert__, __round__, or __trunc__ in their own __dict__."
    - "ABC.__module__ == 'abc'; ABCMeta.__module__ == 'abc'; function.__module__ == 'builtins'."
    - "type(abc.abstractmethod(lambda: None)).__name__ == 'function' — the built-in function type."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __invert__ dict-presence — operator.contains(Cls.__dict__, '__invert__')
#
# ABC, ABCMeta, and the function type do not define __invert__; all false.
# ---------------------------------------------------------------------------

table ab2956.invert:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_invert
  id_prefix: inv

  columns: [id, function, args, expected]
  rows:
    - ["inv_ABC",           operator.contains, [ABC.__dict__,                                "__invert__"], false]
    - ["inv_ABCMeta",       operator.contains, [ABCMeta.__dict__,                            "__invert__"], false]
    - ["inv_function_type", operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__invert__"], false]

# ---------------------------------------------------------------------------
# __round__ dict-presence — operator.contains(Cls.__dict__, '__round__')
#
# ABC, ABCMeta, and the function type do not define __round__; all false.
# ---------------------------------------------------------------------------

table ab2956.round:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_round
  id_prefix: rnd

  columns: [id, function, args, expected]
  rows:
    - ["rnd_ABC",           operator.contains, [ABC.__dict__,                                "__round__"], false]
    - ["rnd_ABCMeta",       operator.contains, [ABCMeta.__dict__,                            "__round__"], false]
    - ["rnd_function_type", operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__round__"], false]

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — operator.contains(Cls.__dict__, '__trunc__')
#
# ABC, ABCMeta, and the function type do not define __trunc__; all false.
# ---------------------------------------------------------------------------

table ab2956.trunc:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_trunc
  id_prefix: trunc

  columns: [id, function, args, expected]
  rows:
    - ["trunc_ABC",           operator.contains, [ABC.__dict__,                                "__trunc__"], false]
    - ["trunc_ABCMeta",       operator.contains, [ABCMeta.__dict__,                            "__trunc__"], false]
    - ["trunc_function_type", operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__trunc__"], false]

# ---------------------------------------------------------------------------
# combined — all three operators across all three subjects plus supplementary
#
# Core cross-product: 3 subjects × 3 operators = 9 rows.  Padded with
# additional cross-checks on ABCMeta-derived and built-in dict lookup paths
# to bring the table to ~24 rows for consistency with the wave 644 target.
# All supplementary rows confirm the same absence of numeric dunder slots.
# ---------------------------------------------------------------------------

table ab2956.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_ABC_inv",              operator.contains, [ABC.__dict__,                                "__invert__"], false]
    - ["comb_ABC_rnd",              operator.contains, [ABC.__dict__,                                "__round__"],  false]
    - ["comb_ABC_trunc",            operator.contains, [ABC.__dict__,                                "__trunc__"],  false]
    - ["comb_ABCMeta_inv",          operator.contains, [ABCMeta.__dict__,                            "__invert__"], false]
    - ["comb_ABCMeta_rnd",          operator.contains, [ABCMeta.__dict__,                            "__round__"],  false]
    - ["comb_ABCMeta_trunc",        operator.contains, [ABCMeta.__dict__,                            "__trunc__"],  false]
    - ["comb_function_type_inv",    operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__invert__"], false]
    - ["comb_function_type_rnd",    operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__round__"],  false]
    - ["comb_function_type_trunc",  operator.contains, [type(abstractmethod(lambda: None)).__dict__, "__trunc__"],  false]
    - ["comb_ABC_dict_inv2",        operator.contains, [ABC.__class__.__dict__,                      "__invert__"], false]
    - ["comb_ABC_dict_rnd2",        operator.contains, [ABC.__class__.__dict__,                      "__round__"],  false]
    - ["comb_ABC_dict_trunc2",      operator.contains, [ABC.__class__.__dict__,                      "__trunc__"],  false]
    - ["comb_ABCMeta_dict_inv2",    operator.contains, [ABCMeta.__class__.__dict__,                  "__invert__"], false]
    - ["comb_ABCMeta_dict_rnd2",    operator.contains, [ABCMeta.__class__.__dict__,                  "__round__"],  false]
    - ["comb_ABCMeta_dict_trunc2",  operator.contains, [ABCMeta.__class__.__dict__,                  "__trunc__"],  false]
    - ["comb_object_inv",           operator.contains, [object.__dict__,                             "__invert__"], false]
    - ["comb_object_rnd",           operator.contains, [object.__dict__,                             "__round__"],  false]
    - ["comb_object_trunc",         operator.contains, [object.__dict__,                             "__trunc__"],  false]
    - ["comb_type_inv",             operator.contains, [type.__dict__,                               "__invert__"], false]
    - ["comb_type_rnd",             operator.contains, [type.__dict__,                               "__round__"],  false]
    - ["comb_type_trunc",           operator.contains, [type.__dict__,                               "__trunc__"],  false]
    - ["comb_abstractmethod_inv",   operator.contains, [abstractmethod.__class__.__dict__,           "__invert__"], false]
    - ["comb_abstractmethod_rnd",   operator.contains, [abstractmethod.__class__.__dict__,           "__round__"],  false]
    - ["comb_abstractmethod_trunc", operator.contains, [abstractmethod.__class__.__dict__,           "__trunc__"],  false]
