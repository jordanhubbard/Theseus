spec: in3556
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 684 (in3556): __reduce__, __reduce_ex__, __getstate__ dict-presence checks for inspect types."
    - "inspect.Parameter defines __reduce__ (true): Parameter implements custom pickle support to preserve kind and default."
    - "inspect.Signature defines __reduce__ (true): Signature implements custom pickle support to preserve parameters and return annotation."
    - "inspect.BoundArguments defines __getstate__ (true): BoundArguments implements __getstate__ for copy/pickle support."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute, inspect.ClassFoundException, inspect.EndOfBlock: all false."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __reduce__ dict-presence — operator.contains(Cls.__dict__, '__reduce__')
#
# inspect.Parameter and inspect.Signature define __reduce__ for pickle support.
# ---------------------------------------------------------------------------

table in3556.reduce:
  description: "inspect types __reduce__ dict-presence checks; wave 684"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3556
  columns: [id, function, args, expected]
  rows:
    - ["in3556001", operator.contains, [inspect.Parameter.__dict__,           "__reduce__"], true]
    - ["in3556002", operator.contains, [inspect.Signature.__dict__,           "__reduce__"], true]
    - ["in3556003", operator.contains, [inspect.BoundArguments.__dict__,      "__reduce__"], false]
    - ["in3556004", operator.contains, [inspect.FrameInfo.__dict__,           "__reduce__"], false]
    - ["in3556005", operator.contains, [inspect.ArgInfo.__dict__,             "__reduce__"], false]
    - ["in3556006", operator.contains, [inspect.FullArgSpec.__dict__,         "__reduce__"], false]
    - ["in3556007", operator.contains, [inspect.Attribute.__dict__,           "__reduce__"], false]
    - ["in3556008", operator.contains, [inspect.ClassFoundException.__dict__, "__reduce__"], false]
    - ["in3556009", operator.contains, [inspect.EndOfBlock.__dict__,          "__reduce__"], false]

