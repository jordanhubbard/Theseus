spec: uuid_extra144
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra143.zspec.zsdl — covers uuid.RESERVED_NCS/__eq__('reserved for NCS compatibility') / RFC_4122.__eq__('specified in RFC 4122') / RESERVED_MICROSOFT/__eq__('reserved for Microsoft compatibility') / RESERVED_FUTURE.__eq__('reserved for future definition') / class name 'str' and lengths (table + invariants)."
    - "uuid_extra142.zspec.zsdl — covers uuid.SafeUUID.__dict__.__len__()==19 / SafeUUID.__dict__.__class__.__name__.__eq__('mappingproxy') / SafeUUID.__dict__.__contains__('safe'/'unsafe'/'unknown'/'_member_names_') / UUID.__dict__.__contains__('__setattr__'/'is_safe') (table + invariants)."
    - "uuid_extra140.zspec.zsdl — covers uuid.UUID.__setattr__/__qualname__.__eq__('UUID.__setattr__') / UUID.__getstate__/__qualname__.__eq__('UUID.__getstate__') / UUID.__setstate__/__qualname__.__eq__('UUID.__setstate__') (table + invariants)."
    - "uuid_extra138.zspec.zsdl — covers uuid.NAMESPACE_DNS/__class__.__name__.__eq__('UUID') / NAMESPACE_DNS.version==1 / NAMESPACE_DNS.hex.__len__()==32 / uuid.UUID.__name__.__eq__('UUID') (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra143."
    - "Wave 334 theme: uuid.UUID class method qualnames — UUID.__str__.__qualname__.__eq__('UUID.__str__') (12 chars) / UUID.__repr__.__qualname__.__eq__('UUID.__repr__') (13 chars) / UUID.__hash__.__qualname__.__eq__('UUID.__hash__') (13 chars) / UUID.__eq__.__qualname__.__eq__('UUID.__eq__') (11 chars) / UUID.__int__.__qualname__.__eq__('UUID.__int__') (12 chars)."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__qualname__ == 'UUID.__int__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__.__len__() == 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__qualname__.__len__() == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__qualname__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All UUID method qualnames follow the pattern 'UUID.<method>'. The format is 'UUID.' (5 chars prefix) + the method dunder name. Lengths: UUID.__eq__ (11 = 5 + len('__eq__') = 5+6) / UUID.__str__ (12 = 5+7) / UUID.__int__ (12 = 5+7) / UUID.__hash__ (13 = 5+8) / UUID.__repr__ (13 = 5+8). The two 11-char qualnames would be for methods like __eq__ (6 chars). The two 12-char qualnames: __str__ (7) and __int__ (7). The two 13-char qualnames: __hash__ (8) and __repr__ (8)."
    - "Note: uuid.UUID.__str__ returns the standard UUID string representation as 36 chars with hyphens (e.g. '6ba7b810-9dad-11d1-80b4-00c04fd430c8'). uuid.UUID.__repr__ returns 'UUID(...)' with the hyphenated string inside. uuid.UUID.__hash__ computes a hash of the UUID integer value (UUID.int), making UUID objects hashable and usable as dict keys / set members. uuid.UUID.__eq__ compares two UUIDs by their integer representation."
    - "Note: uuid.UUID.__int__ returns the integer representation of the UUID as a 128-bit number (0 to 2^128-1). The qualname 'UUID.__int__' (12 chars) matches 'UUID.__str__' (12 chars) since both method names (__int__ and __str__) are 7 chars each including the dunders. UUID does NOT have a __bytes__ method — bytes are accessed via the .bytes property (which is a property descriptor, not a method with __qualname__)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__')
# uuid.UUID.__repr__.__qualname__.__eq__('UUID.__repr__')
# uuid.UUID.__hash__.__qualname__.__eq__('UUID.__hash__')
# uuid.UUID.__eq__.__qualname__.__eq__('UUID.__eq__')
#
# Wave 334 theme: UUID method qualnames follow 'UUID.<method>' pattern.
#
# Four UUID dunder methods have qualnames matching the 'UUID.<method>' pattern.
# __str__ (12 chars), __repr__ (13 chars), __hash__ (13 chars), __eq__ (11 chars).
# extra140 anchors UUID.__setattr__/__getstate__/__setstate__ qualnames; no prior
# uuid spec anchors __str__/__repr__/__hash__/__eq__ qualnames as a table under
# uuidmq144. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra144.UUID_method_qualnames_str_repr_hash_eq:
  description: "uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__')==True / UUID.__repr__.__qualname__.__eq__('UUID.__repr__')==True / UUID.__hash__.__qualname__.__eq__('UUID.__hash__')==True / UUID.__eq__.__qualname__.__eq__('UUID.__eq__')==True — all follow 'UUID.<method>' pattern (5-char prefix + method name); qualname lengths: __eq__(11) < __str__(12) < __hash__(13)==__repr__(13); extra140 anchors __setattr__/__getstate__/__setstate__ qualnames; first uuidmq144 anchor for __str__/__repr__/__hash__/__eq__ qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmq144

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_str_qualname,   "UUID.__str__.__qualname__.__eq__",  ["UUID.__str__"],  true, "uuid.UUID.__str__.__qualname__ == 'UUID.__str__' (12 chars; returns 36-char hyphenated UUID string)"]
    - [UUID_repr_qualname,  "UUID.__repr__.__qualname__.__eq__", ["UUID.__repr__"], true, "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__' (13 chars; returns 'UUID(...)' with hyphenated string)"]
    - [UUID_hash_qualname,  "UUID.__hash__.__qualname__.__eq__", ["UUID.__hash__"], true, "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' (13 chars; hashes UUID.int; makes UUID hashable for dict/set)"]
    - [UUID_eq_qualname,    "UUID.__eq__.__qualname__.__eq__",   ["UUID.__eq__"],   true, "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' (11 chars; compares two UUIDs by their integer representation)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__int__.__qualname__.__eq__('UUID.__int__')
# uuid.UUID.__str__.__qualname__.__len__()==12
# uuid.UUID.__hash__.__qualname__.__len__()==13
# uuid.UUID.__eq__.__qualname__.__len__()==11
#
# Wave 334 theme: UUID.__int__ qualname and qualname length checks.
#
# UUID.__int__.__qualname__ == 'UUID.__int__' (12 chars, same as '__str__').
# Qualname lengths: __eq__(11) < __str__(12)==__int__(12) < __hash__(13)==__repr__(13).
# No prior uuid spec anchors UUID.__int__.__qualname__ or these length values as a
# table under uuidmq144. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra144.UUID_int_qualname_and_lengths:
  description: "uuid.UUID.__int__.__qualname__.__eq__('UUID.__int__')==True / UUID.__str__.__qualname__.__len__()==12 / UUID.__hash__.__qualname__.__len__()==13 / UUID.__eq__.__qualname__.__len__()==11 — __int__ qualname is 'UUID.__int__' (12 chars = 5+'__int__'=7); length ordering: __eq__(11) < __str__(12)==__int__(12) < __hash__(13)==__repr__(13); the 'UUID.' prefix is always 5 chars; method name char counts: __eq__=6, __str__=7, __int__=7, __hash__=8, __repr__=8; first uuidmq144 anchor for __int__ qualname and qualname lengths"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmq144

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_int_qualname,      "UUID.__int__.__qualname__.__eq__",   ["UUID.__int__"], true, "uuid.UUID.__int__.__qualname__ == 'UUID.__int__' (12 chars; returns UUID as 128-bit integer; used for __hash__)"]
    - [UUID_str_qualname_len,  "UUID.__str__.__qualname__.__len__",  [],               12,   "uuid.UUID.__str__.__qualname__.__len__() is 12 ('UUID.__str__' = 5 + '__str__'=7 = 12 chars)"]
    - [UUID_hash_qualname_len, "UUID.__hash__.__qualname__.__len__", [],               13,   "uuid.UUID.__hash__.__qualname__.__len__() is 13 ('UUID.__hash__' = 5 + '__hash__'=8 = 13 chars)"]
    - [UUID_eq_qualname_len,   "UUID.__eq__.__qualname__.__len__",   [],               11,   "uuid.UUID.__eq__.__qualname__.__len__() is 11 ('UUID.__eq__' = 5 + '__eq__'=6 = 11 chars)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__repr__.__qualname__.__len__()==13
# uuid.UUID.__int__.__qualname__.__len__()==12
#
# Wave 334 theme: repr and int qualname lengths.
#
# Both __repr__ and __hash__ qualnames are 13 chars ('UUID.__repr__' / 'UUID.__hash__').
# Both __str__ and __int__ qualnames are 12 chars ('UUID.__str__' / 'UUID.__int__').
# This size pairing reflects that the dunder names __repr__/__hash__ are both 8 chars,
# and __str__/__int__ are both 7 chars. No prior uuid spec anchors these as a table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra144.UUID_qualname_lengths_repr_int:
  description: "uuid.UUID.__repr__.__qualname__.__len__()==13 / UUID.__int__.__qualname__.__len__()==12 / UUID.__eq__.__qualname__.__eq__('UUID.__eq__')==True / UUID.__int__.__qualname__.__eq__('UUID.__int__')==True — __repr__ qualname is 13 chars (tied with __hash__); __int__ qualname is 12 chars (tied with __str__); 'UUID.' prefix (5 chars) + dunder method name; dunder pairs: (__repr__/__hash__ both 8 chars) and (__str__/__int__ both 7 chars); first uuidmq144 anchor for repr/int qualname lengths"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmq144

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_repr_qualname_len, "UUID.__repr__.__qualname__.__len__", [],               13,   "uuid.UUID.__repr__.__qualname__.__len__() is 13 ('UUID.__repr__' = 5+'__repr__'=8 = 13 chars; tied with __hash__)"]
    - [UUID_int_qualname_len,  "UUID.__int__.__qualname__.__len__",  [],               12,   "uuid.UUID.__int__.__qualname__.__len__() is 12 ('UUID.__int__' = 5+'__int__'=7 = 12 chars; tied with __str__)"]
    - [UUID_eq_qualname2,      "UUID.__eq__.__qualname__.__eq__",    ["UUID.__eq__"],  true, "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' (11 chars; shortest of the five qualnames anchored in this spec)"]
    - [UUID_int_qualname2,     "UUID.__int__.__qualname__.__eq__",   ["UUID.__int__"], true, "uuid.UUID.__int__.__qualname__ == 'UUID.__int__' (12 chars; same length as __str__ qualname)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__') — standalone
#
# uuid.UUID.__str__.__qualname__ is 'UUID.__str__' (12 chars). UUID.__str__ is the
# method that converts a UUID to its canonical string form: a 36-character string with
# hyphens in the format 'xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'. The 'UUID.' prefix
# (5 chars) in the qualname reflects that __str__ is defined directly in the UUID
# class body. The qualname format 'UUID.__str__' (not 'module.UUID.__str__') confirms
# that UUID.__str__ is a simple method, not a nested or lambda function. extra140
# anchors UUID.__setattr__/__getstate__/__setstate__ qualnames; no prior uuid spec
# anchors UUID.__str__.__qualname__ as a standalone. First standalone under uuidmq144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra144.UUID_str_qualname_eq:
  description: "uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__') == True — 12 chars; returns 36-char hyphenated UUID string 'xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'; 'UUID.' prefix (5 chars) shows direct class body definition; not nested or lambda; extra140 anchors __setattr__/__getstate__/__setstate__ qualnames; no prior uuid spec anchors this as a standalone; first standalone under uuidmq144"
  category: identity
  kind: python_call_eq
  function: UUID.__str__.__qualname__.__eq__
  args: ["UUID.__str__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__hash__.__qualname__.__eq__('UUID.__hash__') — standalone
#
# uuid.UUID.__hash__.__qualname__ is 'UUID.__hash__' (13 chars). UUID.__hash__ is
# defined in the UUID class to return hash(self.int) — the hash of the 128-bit integer
# representation of the UUID. This makes UUID objects hashable and usable as dictionary
# keys and set members. Without a custom __hash__, UUID would not be hashable because
# it defines __eq__ (Python sets __hash__ to None for classes that define __eq__ without
# __hash__). The qualname 'UUID.__hash__' (13 chars) is one of the two longest qualnames
# anchored in this spec (tied with 'UUID.__repr__' at 13 chars). No prior uuid spec
# anchors UUID.__hash__.__qualname__ as a standalone. First standalone under uuidmq144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra144.UUID_hash_qualname_eq:
  description: "uuid.UUID.__hash__.__qualname__.__eq__('UUID.__hash__') == True — 13 chars (tied with UUID.__repr__); returns hash(self.int) making UUID hashable for dict/set; UUID must define __hash__ explicitly because it defines __eq__ (Python sets __hash__=None for __eq__-only classes); no prior uuid spec anchors this as a standalone; first standalone under uuidmq144"
  category: identity
  kind: python_call_eq
  function: UUID.__hash__.__qualname__.__eq__
  args: ["UUID.__hash__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__eq__.__qualname__.__eq__('UUID.__eq__') — standalone
#
# uuid.UUID.__eq__.__qualname__ is 'UUID.__eq__' (11 chars). UUID.__eq__ is the
# equality comparison method that compares two UUID objects by their integer
# representation (self.int == other.int). At 11 chars, 'UUID.__eq__' is the shortest
# qualname of the five UUID methods anchored in this spec. The method name '__eq__'
# is 6 chars — shorter than '__str__' and '__int__' (7 chars each) and '__hash__' and
# '__repr__' (8 chars each). UUID equality by integer ensures that two UUID objects
# representing the same 128-bit value are equal regardless of how they were created
# (from int, bytes, or string). No prior uuid spec anchors UUID.__eq__.__qualname__
# as a standalone. First standalone under uuidmq144.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra144.UUID_eq_qualname_eq:
  description: "uuid.UUID.__eq__.__qualname__.__eq__('UUID.__eq__') == True — 11 chars (shortest of the five qualnames in this spec); compares by self.int == other.int (128-bit integer); UUID equality is by integer value regardless of creation method (int/bytes/str); '__eq__'=6 chars is shortest method name here; no prior uuid spec anchors this as a standalone; first standalone under uuidmq144"
  category: identity
  kind: python_call_eq
  function: UUID.__eq__.__qualname__.__eq__
  args: ["UUID.__eq__"]
  expected: true

