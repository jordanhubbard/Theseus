invariant multiprocessing_extra163.mp_Pool_apply_async_qualname_eq:
  description: "multiprocessing.pool.Pool.apply_async.__qualname__.__eq__('Pool.apply_async') returns True — Pool.apply_async is the asynchronous version of Pool.apply; apply_async.__qualname__=='Pool.apply_async' (len=16: 'Pool'=4+'.'=1+'apply_async'=11=16; 'apply_async'='apply'=5+'_async'=6=11); apply_async(func, args=(), kwds={}, callback=None, error_callback=None) submits func to a worker process and returns an AsyncResult immediately without blocking; the caller can call result.get() later to retrieve the value; callback(result) is called in the main process when the result is ready; error_callback(exc) is called if an exception occurs; Pool.apply_async is directly in Pool.__dict__ (confirmed by extra162 Pool.__dict__.__len__()==42 listing); compare: Pool.apply (sync) blocks until the result is ready; Pool.apply_async (async) returns immediately; qualname length 16: apply_async(16) is between map_async(14) and starmap_async(18) in length ordering: imap(9) < map_async(14) < apply_async(16) < starmap_async(18) < imap_unordered(19); NEW in extra163: first standalone Pool.apply_async.__qualname__ invariant in mppoolavq163 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.apply_async.__qualname__.__eq__
  args: ["Pool.apply_async"]
  expected: true

invariant multiprocessing_extra163.mp_Pool_map_async_qualname_eq:
  description: "multiprocessing.pool.Pool.map_async.__qualname__.__eq__('Pool.map_async') returns True — Pool.map_async is the asynchronous version of Pool.map; map_async.__qualname__=='Pool.map_async' (len=14: 'Pool'=4+'.'=1+'map_async'=9=14; 'map_async'='map'=3+'_async'=6=9); map_async(func, iterable, chunksize=None, callback=None, error_callback=None) applies func to every item of iterable in worker processes and returns a MapResult/AsyncResult immediately; the MapResult.get() method blocks until all results are complete; map_async qualname(14) is the shortest among the three async variants: map_async(14) < apply_async(16) < starmap_async(18); 'map_async'=9 is the shortest async method name: 'map'=3 is the shortest base method, and 3+'_async'=6=9; compare: Pool.map (sync) qualname == 'Pool.map' (len=8: 'Pool'=4+'.'=1+'map'=3=8; not covered in this spec); NEW in extra163: first standalone Pool.map_async.__qualname__ invariant in mppoolavq163 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.map_async.__qualname__.__eq__
  args: ["Pool.map_async"]
  expected: true

invariant multiprocessing_extra163.mp_Pool_starmap_async_qualname_eq:
  description: "multiprocessing.pool.Pool.starmap_async.__qualname__.__eq__('Pool.starmap_async') returns True — Pool.starmap_async is the asynchronous version of Pool.starmap; starmap_async.__qualname__=='Pool.starmap_async' (len=18: 'Pool'=4+'.'=1+'starmap_async'=13=18; 'starmap_async'='starmap'=7+'_async'=6=13); starmap_async(func, iterable, chunksize=None, callback=None, error_callback=None) is like map_async but unpacks arguments from iterable tuples — func(*args) for each args tuple; starmap_async qualname(18) is the longest among the three async variants: map_async(14) < apply_async(16) < starmap_async(18); 'starmap_async'=13 > 'apply_async'=11 by 2 because 'starmap'=7 > 'apply'=5 by 2; the async variant naming pattern: sync_name + '_async'; starmap_async(18) ties with StreamWriter.close qualname(18) from extra165 as a coincidental length match; NEW in extra163: first standalone Pool.starmap_async.__qualname__ invariant in mppoolavq163 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.starmap_async.__qualname__.__eq__
  args: ["Pool.starmap_async"]
  expected: true

invariant multiprocessing_extra163.mp_Pool_imap_qualname_eq:
  description: "multiprocessing.pool.Pool.imap.__qualname__.__eq__('Pool.imap') returns True — Pool.imap is the lazy iterator-based map method; imap.__qualname__=='Pool.imap' (len=9: 'Pool'=4+'.'=1+'imap'=4=9); imap(func, iterable, chunksize=1) applies func to each element of iterable using worker processes, returning results as an iterator that yields values as they become ready (in input order); unlike Pool.map() which blocks until all results are complete, imap returns immediately and yields results one at a time — memory-efficient for large iterables; 'Pool.imap' qualname(9) is the shortest Pool qualname in this spec: imap(9) < map_async(14) < apply_async(16) < starmap_async(18) < imap_unordered(19); coincidentally ties with asyncio.Queue.put and asyncio.Queue.get qualnames (both len=9, established in extra163) — both use 3-char method names with a 5/6-char class prefix; imap.__qualname__ qualname(9) = 5-char 'Pool.' prefix + 4-char 'imap'; NEW in extra163: first standalone Pool.imap.__qualname__ invariant in mppoolimq163 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.imap.__qualname__.__eq__
  args: ["Pool.imap"]
  expected: true

invariant multiprocessing_extra163.mp_Pool_imap_unordered_qualname_eq:
  description: "multiprocessing.pool.Pool.imap_unordered.__qualname__.__eq__('Pool.imap_unordered') returns True — Pool.imap_unordered is the unordered lazy iterator variant; imap_unordered.__qualname__=='Pool.imap_unordered' (len=19: 'Pool'=4+'.'=1+'imap_unordered'=14=19; 'imap_unordered'='imap'=4+'_unordered'=10=14; '_unordered'='_'=1+'unordered'=9=10); imap_unordered(func, iterable, chunksize=1) is like imap() but yields results in completion order rather than input order — when result ordering is not required, imap_unordered is faster because it does not need to buffer results waiting for earlier items; imap_unordered qualname(19) is the longest Pool qualname in this spec: imap(9) < map_async(14) < apply_async(16) < starmap_async(18) < imap_unordered(19); imap_unordered(19) > starmap_async(18) by 1 because 'imap_unordered'=14 > 'starmap_async'=13 by 1; 'unordered'=9 is longer than 'async'=5 by 4, which is why imap_unordered(14) > map_async(9) in method name length; NEW in extra163: first standalone Pool.imap_unordered.__qualname__ invariant in mppoolimq163 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.imap_unordered.__qualname__.__eq__
  args: ["Pool.imap_unordered"]
  expected: true

