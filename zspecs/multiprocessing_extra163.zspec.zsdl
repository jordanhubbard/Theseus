    - [imap_unord_qn,      multiprocessing.pool.Pool.imap_unordered.__qualname__.__eq__,  ["Pool.imap_unordered"],  true,  "Pool.imap_unordered.__qualname__ == 'Pool.imap_unordered' (len=19; 'imap_unordered'=14; longest qualname in spec); verified with Python 3.14.3"]
