table multiprocessing_extra163.mp_pool_async_variant_qualnames:
  description: "multiprocessing.pool.Pool async-variant method qualname checks in mppoolavq163 namespace — Pool.apply_async.__qualname__=='Pool.apply_async' (len=16: 'Pool'=4+'.'=1+'apply_async'=11=16; 'apply_async'='apply'=5+'_async'=6=11; apply_async(func, args=(), kwds={}, callback=None, error_callback=None) runs func asynchronously in a worker process and returns an AsyncResult; does NOT block — returns immediately while the work is dispatched; callback is called with the result when available); Pool.map_async.__qualname__=='Pool.map_async' (len=14: 'Pool'=4+'.'=1+'map_async'=9=14; 'map_async'='map'=3+'_async'=6=9; map_async(func, iterable, chunksize=None, callback=None, error_callback=None) applies func to each iterable element asynchronously, returning a MapResult/AsyncResult; map_async qualname(14) < apply_async qualname(16) because 'map_async'=9 < 'apply_async'=11 by 2); Pool.starmap_async.__qualname__=='Pool.starmap_async' (len=18: 'Pool'=4+'.'=1+'starmap_async'=13=18; 'starmap_async'='starmap'=7+'_async'=6=13; starmap_async qualname(18) > apply_async qualname(16) because 'starmap_async'=13 > 'apply_async'=11 by 2); qualname ordering in this table: map_async(14) < apply_async(16) < starmap_async(18); verified with Python 3.14.3"
