  rows:
    - [apply_async_qn,   multiprocessing.pool.Pool.apply_async.__qualname__.__eq__,   ["Pool.apply_async"],   true,  "Pool.apply_async.__qualname__ == 'Pool.apply_async' (len=16; 'apply_async'=11); verified with Python 3.14.3"]
    - [map_async_qn,     multiprocessing.pool.Pool.map_async.__qualname__.__eq__,     ["Pool.map_async"],     true,  "Pool.map_async.__qualname__ == 'Pool.map_async' (len=14; 'map_async'=9; shorter than apply_async=16 by 2); verified with Python 3.14.3"]
    - [starmap_async_qn, multiprocessing.pool.Pool.starmap_async.__qualname__.__eq__, ["Pool.starmap_async"], true,  "Pool.starmap_async.__qualname__ == 'Pool.starmap_async' (len=18; 'starmap_async'=13; longest async variant); verified with Python 3.14.3"]
