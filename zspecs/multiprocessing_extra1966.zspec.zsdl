  columns: [id, function, args, expected]
  rows:
    - ["mp1966025", "multiprocessing.pool.Pool.__dict__.__contains__",                    ["__aenter__"], false]
    - ["mp1966026", "multiprocessing.pool.Pool.__dict__.__contains__",                    ["__aexit__"],  false]
    - ["mp1966027", "multiprocessing.Process.__dict__.__contains__",                      ["__aenter__"], false]
    - ["mp1966028", "multiprocessing.Process.__dict__.__contains__",                      ["__aexit__"],  false]
    - ["mp1966029", "multiprocessing.synchronize.Lock.__dict__.__contains__",             ["__aenter__"], false]
    - ["mp1966030", "multiprocessing.synchronize.Lock.__dict__.__contains__",             ["__aexit__"],  false]
    - ["mp1966031", "multiprocessing.synchronize.Condition.__dict__.__contains__",        ["__aenter__"], false]
    - ["mp1966032", "multiprocessing.synchronize.Condition.__dict__.__contains__",        ["__aexit__"],  false]
