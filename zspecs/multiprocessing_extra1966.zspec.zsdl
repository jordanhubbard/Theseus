spec: multiprocessing_extra1966
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 578 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.pool.Pool defines __enter__, __exit__, and __del__ directly in its own __dict__."
    - "multiprocessing.synchronize.Condition defines __enter__ and __exit__ (it wraps a threading.Condition)."
    - "multiprocessing.synchronize.Lock/RLock/Semaphore/BoundedSemaphore inherit __enter__/__exit__ from SemLock — not in their own __dict__."
    - "multiprocessing.managers.BaseManager, AcquirerProxy, PoolProxy define __enter__ and __exit__."
    - "multiprocessing.managers.SharedMemoryManager defines __del__; it does not override __enter__/__exit__."
    - "multiprocessing.Process and all queue types do not define any context manager or finalizer protocol methods."
    - "No multiprocessing class defines __aenter__ or __aexit__."
  created_at: "2026-04-12"
error_model: python_exceptions

table multiprocessing_extra1966.sync_enter_protocol:
  description: "multiprocessing types __enter__ dict-presence — Condition, pool.Pool, and manager types define it; others do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1966

  columns: [id, function, args, expected]
  rows:
    - ["mp1966001", "multiprocessing.pool.Pool.__dict__.__contains__",                    ["__enter__"], true]
    - ["mp1966002", "multiprocessing.synchronize.Condition.__dict__.__contains__",        ["__enter__"], true]
    - ["mp1966003", "multiprocessing.managers.BaseManager.__dict__.__contains__",         ["__enter__"], true]
    - ["mp1966004", "multiprocessing.managers.AcquirerProxy.__dict__.__contains__",       ["__enter__"], true]
    - ["mp1966005", "multiprocessing.managers.PoolProxy.__dict__.__contains__",           ["__enter__"], true]
    - ["mp1966006", "multiprocessing.Process.__dict__.__contains__",                      ["__enter__"], false]
    - ["mp1966007", "multiprocessing.synchronize.Lock.__dict__.__contains__",             ["__enter__"], false]
    - ["mp1966008", "multiprocessing.synchronize.RLock.__dict__.__contains__",            ["__enter__"], false]
    - ["mp1966009", "multiprocessing.synchronize.Semaphore.__dict__.__contains__",        ["__enter__"], false]
    - ["mp1966010", "multiprocessing.synchronize.BoundedSemaphore.__dict__.__contains__", ["__enter__"], false]
    - ["mp1966011", "multiprocessing.synchronize.Event.__dict__.__contains__",            ["__enter__"], false]
    - ["mp1966012", "multiprocessing.synchronize.Barrier.__dict__.__contains__",          ["__enter__"], false]

