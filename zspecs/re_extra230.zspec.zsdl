spec: re_extra230
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.compile pattern flags contracts — IGNORECASE, MULTILINE, DOTALL flag bits, default flags value, pattern attribute, groups count."
    - "re.compile('hello').flags == 32 — default flags include re.UNICODE (value 32) only; verified Python 3.14.3 macOS."
    - "re.UNICODE integer value is 32; re.IGNORECASE is 2; re.MULTILINE is 8; re.DOTALL is 16; verified Python 3.14.3 macOS."
    - "re.compile('hello', re.IGNORECASE).flags & re.IGNORECASE != 0 — IGNORECASE bit is set when flag passed; verified Python 3.14.3 macOS."
    - "re.compile('hello', re.MULTILINE).flags & re.MULTILINE != 0 — MULTILINE bit is set when flag passed; verified Python 3.14.3 macOS."
    - "re.compile('[a-z]+').pattern == '[a-z]+' — pattern attribute stores the original pattern string; verified Python 3.14.3 macOS."
    - "re.compile('hello').groups == 0 — no capturing groups in pattern 'hello'; verified Python 3.14.3 macOS."
    - "re.compile('(hello)').groups == 1 — one capturing group; verified Python 3.14.3 macOS."
    - "re.compile('(a)(b)').groups == 2 — two capturing groups; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile default flags behavioral contracts
# compile('hello').flags == 32 — re.UNICODE is always included by default.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra230.compile.default_flags_eq_32:
  description: "re.compile('hello').flags == 32 — default compiled pattern flags equal re.UNICODE (32); re.UNICODE is added automatically; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: compile
  args: ["hello"]
  method: flags.__eq__
  method_args: [32]
  expected: true

# ---------------------------------------------------------------------------
# re.compile flag bit behavioral contracts
# IGNORECASE (2) and MULTILINE (8) bits are set when those flags are passed.
# Check with bitwise AND: flags & flag_value != 0.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra230.compile.ignorecase_bit_set:
  description: "re.compile('hello', re.IGNORECASE).flags & 2 != 0 — IGNORECASE flag (value 2) is set in compiled pattern flags; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: compile
  args: ["hello", 2]
  method: flags.__and__
  method_args: [2]
  method_chain: __ne__
  method_chain_args: [0]
  expected: true

invariant re_extra230.compile.multiline_bit_set:
  description: "re.compile('hello', re.MULTILINE).flags & 8 != 0 — MULTILINE flag (value 8) is set in compiled pattern flags; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: compile
  args: ["hello", 8]
  method: flags.__and__
  method_args: [8]
  method_chain: __ne__
  method_chain_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# re.compile pattern attribute behavioral contracts
# compile(pattern).pattern stores the original pattern string.
# Patterns containing '[' must be double-quoted per ZSDL rules.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra230.compile.pattern_hello:
  description: "re.compile('hello').pattern == 'hello' — pattern attribute stores the original pattern string unchanged; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: compile
  args: ["hello"]
  method: pattern.__eq__
  method_args: ["hello"]
  expected: true

invariant re_extra230.compile.pattern_charclass:
  description: "re.compile('[a-z]+').pattern == '[a-z]+' — pattern with character class stored verbatim; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: compile
  args: ["[a-z]+"]
  method: pattern.__eq__
  method_args: ["[a-z]+"]
  expected: true

# ---------------------------------------------------------------------------
# re.compile groups count behavioral contracts
# groups attribute counts the number of capturing groups in the pattern.
# compile('hello').groups == 0 (no groups).
# compile('(hello)').groups == 1 (one group).
# compile('(a)(b)').groups == 2 (two groups).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra230.compile.groups_zero:
  description: "re.compile('hello').groups == 0 — pattern 'hello' contains no capturing groups; groups is 0; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: compile
  args: ["hello"]
  method: groups.__eq__
  method_args: [0]
  expected: true

invariant re_extra230.compile.groups_one:
  description: "re.compile('(hello)').groups == 1 — pattern '(hello)' has one capturing group; groups is 1; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: compile
  args: ["(hello)"]
  method: groups.__eq__
  method_args: [1]
  expected: true

invariant re_extra230.compile.groups_two:
  description: "re.compile('(a)(b)').groups == 2 — pattern '(a)(b)' has two capturing groups; groups is 2; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: compile
  args: ["(a)(b)"]
  method: groups.__eq__
  method_args: [2]
  expected: true

# ---------------------------------------------------------------------------
# re.compile dotall flag behavioral contracts
# DOTALL (16) bit is set when re.DOTALL flag is passed.
# Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra230.compile.dotall_bit_set:
  description: "re.compile('hello', re.DOTALL).flags & 16 != 0 — DOTALL flag (value 16) is set in compiled pattern flags; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: compile
  args: ["hello", 16]
  method: flags.__and__
  method_args: [16]
  method_chain: __ne__
  method_chain_args: [0]
  expected: true
