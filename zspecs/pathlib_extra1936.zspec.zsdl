spec: pathlib_extra1936
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
    - "pathlib.zspec.zsdl"
    - "pathlib_pure.zspec.zsdl"
    - "pathlib_extra.zspec.zsdl"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol, __set_name__, __class__ checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "pathlib.Path, PurePath, PurePosixPath, PureWindowsPath are not descriptor types."
    - "None of the pathlib classes define __get__, __set__, __delete__, or __set_name__ in their own __dict__."
    - "pathlib module __class__.__name__ == 'module'; pathlib class objects have __class__.__name__ == 'type'."
  created_at: "2026-04-12"
error_model: python_exceptions

table pathlib_extra1936.descriptor_get:
  description: "pathlib types __get__ dict-presence checks — none define __get__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1936

  columns: [id, function, args, expected]
  rows:
    - ["pl1936001", "pathlib.Path.__dict__.__contains__",            ["__get__"], false]
    - ["pl1936002", "pathlib.PurePath.__dict__.__contains__",        ["__get__"], false]
    - ["pl1936003", "pathlib.PurePosixPath.__dict__.__contains__",   ["__get__"], false]
    - ["pl1936004", "pathlib.PureWindowsPath.__dict__.__contains__", ["__get__"], false]

