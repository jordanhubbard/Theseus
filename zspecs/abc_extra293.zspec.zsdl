spec: abc_extra293
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "abc.abstractmethod is a plain Python function (type.__name__ == 'function'), not a class."
    - "When abc.abstractmethod decorates a function, the result has __isabstractmethod__ == True."
    - "abc.ABC.__abstractmethods__ is an empty frozenset — ABC itself defines no abstract methods."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta is a metaclass that extends the built-in type."
    - "ABCMeta(name, bases, ns) raises TypeError when name is not a str (delegates to type.__new__)."
    - "All expected values verified by running Python 3.14.3 abc module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractmethod — decorator identity
#
# abc.abstractmethod is a plain function. Its __class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

invariant abc.abstractmethod.class_name:
  description: "abc.abstractmethod.__class__.__name__ == 'function'"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# abc.ABC — base class identity
#
# abc.ABC.__abstractmethods__ is frozenset() — empty, because ABC itself
# defines no abstract methods.
# ---------------------------------------------------------------------------

invariant abc.abc_class.abstractmethods_class:
  description: "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset'"
  category: abc_class
  kind: python_call_eq
  function: ABC.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant abc.abc_class.abstractmethods_empty:
  description: "len(abc.ABC.__abstractmethods__) == 0 — ABC has no abstract methods of its own"
  category: abc_class
  kind: python_call_eq
  function: ABC.__abstractmethods__.__len__
  args: []
  expected: 0

invariant abc.abc_class.name:
  description: "abc.ABC.__name__ == 'ABC'"
  category: abc_class
  kind: python_call_eq
  function: ABC.__name__.__eq__
  args: ["ABC"]
  expected: true

# ---------------------------------------------------------------------------
# abc.ABCMeta — metaclass identity
#
# ABCMeta extends the built-in 'type' metaclass.
# ---------------------------------------------------------------------------

invariant abc.abcmeta.name:
  description: "abc.ABCMeta.__name__ == 'ABCMeta'"
  category: abcmeta
  kind: python_call_eq
  function: ABCMeta.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc.abcmeta.module:
  description: "abc.ABCMeta.__module__ == 'abc'"
  category: abcmeta
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc.abcmeta.base_name:
  description: "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta is a metaclass extending type"
  category: abcmeta
  kind: python_call_eq
  function: ABCMeta.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "type"

# ---------------------------------------------------------------------------
# TypeError: ABCMeta with a non-string class name
#
# ABCMeta(name, bases, namespace) delegates to type.__new__(), which requires
# name to be a str. Passing an integer raises TypeError.
# ---------------------------------------------------------------------------

invariant abc.error.abcmeta_nonstring_name:
  description: "ABCMeta(123, [], {}) raises TypeError — class name must be a str"
  category: error
  kind: python_call_raises
  function: ABCMeta
  args: [123, [], {}]
  raises: TypeError
