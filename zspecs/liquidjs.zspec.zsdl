spec: liquidjs
version: ">=10.0.0"
backend: node(liquidjs)

docs: https://liquidjs.com/

provenance:
  derived_from:
    - "LiquidJS documentation — https://liquidjs.com/"
    - "Shopify Liquid template language — https://shopify.github.io/liquid/"
    - "Test vectors verified with liquidjs via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "liquidjs source"
  notes:
    - "LiquidJS is a Node implementation of Shopify's Liquid template language used by Jekyll, Eleventy, etc."
    - "Install: npm install liquidjs"
    - "Pattern: const {Liquid} = require('liquidjs'); new Liquid().parseAndRenderSync(template, scope)"
    - "Liquid uses {{ }} for output, {% %} for control flow; standard filters (upcase, downcase, capitalize, etc.) are pipe-applied."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "parseAndRenderSync returns a string; throws on syntax errors not exercised here."
  stderr: "null"
  stickiness: "N/A — each Liquid instance is independent."
  codes: {}

table liquidjs.render:
  kind: node_chain_eq
  category: render
  entry: constructor
  class: Liquid
  entry_args: []
  id_prefix: render

  columns: [id, chain, expected]
  rows:
    - [variable_substitution,
       [{method: parseAndRenderSync, args: ["Hello {{name}}", {name: "World"}]}],
       "Hello World"]

    - [if_truthy,
       [{method: parseAndRenderSync, args: ["{% if x %}YES{% endif %}", {x: true}]}],
       "YES"]

    - [if_falsy_empty_output,
       [{method: parseAndRenderSync, args: ["{% if x %}YES{% endif %}", {x: false}]}],
       ""]

    - [for_loop,
       [{method: parseAndRenderSync, args: ["{% for i in items %}{{i}},{% endfor %}", {items: [1, 2, 3]}]}],
       "1,2,3,"]

    - [filter_upcase,
       [{method: parseAndRenderSync, args: ["{{ name | upcase }}", {name: "hello"}]}],
       "HELLO"]

    - [filter_downcase,
       [{method: parseAndRenderSync, args: ["{{ name | downcase }}", {name: "HELLO"}]}],
       "hello"]

    - [filter_capitalize,
       [{method: parseAndRenderSync, args: ["{{ name | capitalize }}", {name: "hello world"}]}],
       "Hello world"]

    - [filter_size_string,
       [{method: parseAndRenderSync, args: ["{{ s | size }}", {s: "abc"}]}],
       "3"]

    - [filter_size_array,
       [{method: parseAndRenderSync, args: ["{{ a | size }}", {a: [1, 2, 3, 4]}]}],
       "4"]

    - [no_template_vars,
       [{method: parseAndRenderSync, args: ["plain text", {}]}],
       "plain text"]

    - [missing_variable_renders_empty,
       [{method: parseAndRenderSync, args: ["Hello {{missing}}!", {}]}],
       "Hello !"]
