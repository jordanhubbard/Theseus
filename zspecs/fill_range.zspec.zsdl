spec: fill_range
version: ">=7.1.1"
backend: node(fill-range)

docs: https://www.npmjs.com/package/fill-range

provenance:
  derived_from:
    - "fill-range README — https://www.npmjs.com/package/fill-range"
    - "Test vectors verified with fill-range via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "fill-range source"
  notes:
    - "fill-range is an npm package. Install: npm install fill-range"
    - "Fills in a range of letters or numbers between start and end values."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table fill_range.fill:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: fr

  columns: [id, args, expected]
  rows:
    - [letters,  ["a", "e"],  ["a", "b", "c", "d", "e"]]
    - [numbers,  [1, 5],      [1, 2, 3, 4, 5]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:12:05Z
  iterations: 2
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 2 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
