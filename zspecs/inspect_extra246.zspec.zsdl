spec: inspect_extra246
version: ">=3.0"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra245.zspec.zsdl — covers ismodule, isclass, ismethod function identity"
    - "inspect_extra244.zspec.zsdl — covers getmembers_static, get_annotations, descriptor predicate identity"
    - "inspect_extra243.zspec.zsdl — covers classify_class_attrs and getmembers identity"
    - "inspect_extra242.zspec.zsdl — covers isclass, isfunction, ismethod identity"
  notes:
    - "This spec covers inspect.BoundArguments and inspect.FullArgSpec class identity."
    - "inspect.BoundArguments.__name__ == 'BoundArguments' (len=14). Verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect' (len=7). Verified with Python 3.14.3."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__qualname__ == 'BoundArguments'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__name__ == 'FullArgSpec' (len=11). Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__module__ == 'inspect' (len=7). Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple, inheriting from tuple. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__qualname__ == 'FullArgSpec'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.BoundArguments class identity contracts
#
# inspect.BoundArguments.__name__ == 'BoundArguments' (len=14)
# inspect.BoundArguments.__module__ == 'inspect' (len=7)
# inspect.BoundArguments.__bases__[0].__name__ == 'object'
# inspect.BoundArguments.__qualname__ == 'BoundArguments'
# inspect.BoundArguments.__name__.__len__() == 14
#
# BoundArguments is a pure-Python class defined in Lib/inspect.py. New to extra246.
# ---------------------------------------------------------------------------

table inspect_extra246.inspba246_boundargs_identity:
  description: "inspect.BoundArguments class identity: name, module, bases, qualname; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: inspba246

  columns: [id, function, args, expected, description]
  rows:
    - [ba_name_eq,
       BoundArguments.__name__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments is a pure-Python class defined in Lib/inspect.py; __name__ is 'BoundArguments' (len=14); new to extra246"]
    - [ba_name_len_14,
       BoundArguments.__name__.__len__,
       [],
       14,
       "inspect.BoundArguments.__name__.__len__() == 14 — 'BoundArguments' has exactly 14 characters; str.__len__() returns 14; new to extra246"]
    - [ba_module_inspect,
       BoundArguments.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra246"]
    - [ba_module_len_7,
       BoundArguments.__module__.__len__,
       [],
       7,
       "inspect.BoundArguments.__module__.__len__() == 7 — 'inspect' has exactly 7 characters; str.__len__() returns 7; new to extra246"]
    - [ba_bases0_object,
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — BoundArguments directly inherits from object; __bases__[0].__name__ is 'object'; new to extra246"]

# ---------------------------------------------------------------------------
# Table 2: inspect.BoundArguments extra class checks
#
# inspect.BoundArguments.__qualname__ == 'BoundArguments'
# inspect.BoundArguments.__class__.__name__ == 'type'
# inspect.BoundArguments.__bases__[0].__module__ == 'builtins'
# inspect.BoundArguments.__name__.__contains__('Bound') == True
# inspect.BoundArguments.__module__.__contains__('inspect') == True
#
# New to extra246.
# ---------------------------------------------------------------------------

table inspect_extra246.inspba246_boundargs_extra:
  description: "inspect.BoundArguments extra class checks: qualname, class type, name/module content; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: inspba246b

  columns: [id, function, args, expected, description]
  rows:
    - [ba_qualname_eq,
       BoundArguments.__qualname__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True — __qualname__ equals __name__ for a top-level class; 'BoundArguments'; new to extra246"]
    - [ba_class_is_type,
       BoundArguments.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.BoundArguments.__class__.__name__.__eq__('type') == True — BoundArguments is a class so __class__ is 'type'; new to extra246"]
    - [ba_bases0_module_builtins,
       "BoundArguments.__bases__[0].__module__.__eq__",
       ["builtins"],
       true,
       "inspect.BoundArguments.__bases__[0].__module__.__eq__('builtins') == True — object is defined in builtins; __bases__[0].__module__ is 'builtins'; new to extra246"]
    - [ba_name_contains_bound,
       BoundArguments.__name__.__contains__,
       ["Bound"],
       true,
       "inspect.BoundArguments.__name__.__contains__('Bound') == True — 'BoundArguments' contains 'Bound'; new to extra246"]
    - [ba_module_contains_inspect,
       BoundArguments.__module__.__contains__,
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__contains__('inspect') == True — 'inspect' contains 'inspect'; new to extra246"]

# ---------------------------------------------------------------------------
# Table 3: inspect.FullArgSpec class identity contracts
#
# inspect.FullArgSpec.__name__ == 'FullArgSpec' (len=11)
# inspect.FullArgSpec.__module__ == 'inspect' (len=7)
# inspect.FullArgSpec.__bases__[0].__name__ == 'tuple'
# inspect.FullArgSpec.__qualname__ == 'FullArgSpec'
# inspect.FullArgSpec.__name__.__len__() == 11
#
# FullArgSpec is a namedtuple (inherits from tuple) defined in Lib/inspect.py. New to extra246.
# ---------------------------------------------------------------------------

table inspect_extra246.inspfas246_fullargspec_identity:
  description: "inspect.FullArgSpec class identity: name, module, bases (tuple), qualname; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: inspfas246

  columns: [id, function, args, expected, description]
  rows:
    - [fas_name_eq,
       FullArgSpec.__name__.__eq__,
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — FullArgSpec is a namedtuple defined in Lib/inspect.py; __name__ is 'FullArgSpec' (len=11); new to extra246"]
    - [fas_name_len_11,
       FullArgSpec.__name__.__len__,
       [],
       11,
       "inspect.FullArgSpec.__name__.__len__() == 11 — 'FullArgSpec' has exactly 11 characters; str.__len__() returns 11; new to extra246"]
    - [fas_module_inspect,
       FullArgSpec.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__.__eq__('inspect') == True — FullArgSpec is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra246"]
    - [fas_module_len_7,
       FullArgSpec.__module__.__len__,
       [],
       7,
       "inspect.FullArgSpec.__module__.__len__() == 7 — 'inspect' has exactly 7 characters; str.__len__() returns 7; new to extra246"]
    - [fas_bases0_tuple,
       "FullArgSpec.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — FullArgSpec is a namedtuple and inherits from tuple; __bases__[0].__name__ is 'tuple'; new to extra246"]

# ---------------------------------------------------------------------------
# Table 4: inspect.FullArgSpec extra class checks
#
# inspect.FullArgSpec.__qualname__ == 'FullArgSpec'
# inspect.FullArgSpec.__class__.__name__ == 'type'
# inspect.FullArgSpec.__bases__[0].__module__ == 'builtins'
# inspect.FullArgSpec.__name__.__contains__('Spec') == True
# inspect.FullArgSpec.__module__.__contains__('inspect') == True
#
# New to extra246.
# ---------------------------------------------------------------------------

table inspect_extra246.inspfas246_fullargspec_extra:
  description: "inspect.FullArgSpec extra class checks: qualname, class type, name/module content; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: inspfas246b

  columns: [id, function, args, expected, description]
  rows:
    - [fas_qualname_eq,
       FullArgSpec.__qualname__.__eq__,
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__qualname__.__eq__('FullArgSpec') == True — __qualname__ equals __name__ for a top-level class; 'FullArgSpec'; new to extra246"]
    - [fas_class_is_type,
       FullArgSpec.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.FullArgSpec.__class__.__name__.__eq__('type') == True — FullArgSpec is a class so __class__ is 'type'; new to extra246"]
    - [fas_bases0_module_builtins,
       "FullArgSpec.__bases__[0].__module__.__eq__",
       ["builtins"],
       true,
       "inspect.FullArgSpec.__bases__[0].__module__.__eq__('builtins') == True — tuple is defined in builtins; __bases__[0].__module__ is 'builtins'; new to extra246"]
    - [fas_name_contains_spec,
       FullArgSpec.__name__.__contains__,
       ["Spec"],
       true,
       "inspect.FullArgSpec.__name__.__contains__('Spec') == True — 'FullArgSpec' contains 'Spec'; new to extra246"]
    - [fas_module_contains_inspect,
       FullArgSpec.__module__.__contains__,
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__.__contains__('inspect') == True — 'inspect' contains 'inspect'; new to extra246"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra246
# ---------------------------------------------------------------------------

invariant inspect_extra246.ba_name_eq:
  description: "inspect.BoundArguments.__name__ == 'BoundArguments' (len=14); new to extra246"
  kind: python_call_eq
  function: BoundArguments.__name__.__eq__
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra246.ba_module_inspect:
  description: "inspect.BoundArguments.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra246"
  kind: python_call_eq
  function: BoundArguments.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra246.ba_bases0_object:
  description: "inspect.BoundArguments.__bases__[0].__name__ == 'object'; new to extra246"
  kind: python_call_eq
  function: "BoundArguments.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra246.ba_name_len_14:
  description: "inspect.BoundArguments.__name__.__len__() == 14; new to extra246"
  kind: python_call_eq
  function: BoundArguments.__name__.__len__
  args: []
  expected: 14

invariant inspect_extra246.fas_name_eq:
  description: "inspect.FullArgSpec.__name__ == 'FullArgSpec' (len=11); new to extra246"
  kind: python_call_eq
  function: FullArgSpec.__name__.__eq__
  args: ["FullArgSpec"]
  expected: true

invariant inspect_extra246.fas_module_inspect:
  description: "inspect.FullArgSpec.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra246"
  kind: python_call_eq
  function: FullArgSpec.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra246.fas_bases0_tuple:
  description: "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple; new to extra246"
  kind: python_call_eq
  function: "FullArgSpec.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

invariant inspect_extra246.fas_name_len_11:
  description: "inspect.FullArgSpec.__name__.__len__() == 11; new to extra246"
  kind: python_call_eq
  function: FullArgSpec.__name__.__len__
  args: []
  expected: 11

invariant inspect_extra246.ba_class_is_type:
  description: "inspect.BoundArguments.__class__.__name__ == 'type' — BoundArguments is a class; new to extra246"
  kind: python_call_eq
  function: BoundArguments.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra246.fas_class_is_type:
  description: "inspect.FullArgSpec.__class__.__name__ == 'type' — FullArgSpec is a class; new to extra246"
  kind: python_call_eq
  function: FullArgSpec.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra246.ba_module_len_7:
  description: "inspect.BoundArguments.__module__.__len__() == 7; new to extra246"
  kind: python_call_eq
  function: BoundArguments.__module__.__len__
  args: []
  expected: 7

invariant inspect_extra246.fas_module_len_7:
  description: "inspect.FullArgSpec.__module__.__len__() == 7; new to extra246"
  kind: python_call_eq
  function: FullArgSpec.__module__.__len__
  args: []
  expected: 7
