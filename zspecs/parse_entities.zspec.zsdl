spec: parse_entities
version: ">=4.0.2"
backend: node(parse-entities)

docs: https://www.npmjs.com/package/parse-entities

provenance:
  derived_from:
    - "parse-entities README — https://www.npmjs.com/package/parse-entities"
    - "Test vectors verified with parse-entities via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "parse-entities source"
  notes:
    - "parse-entities is an npm package. Install: npm install parse-entities"
    - "Decodes HTML character references and named entities."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table parse_entities.parseEntities:
  kind: node_module_call_eq
  function: parseEntities
  category: decode
  id_prefix: parseent

  columns: [id, args, expected]
  rows:
    - [amp,     ["&amp;"],     "&"]
    - [lt_gt,   ["&lt;&gt;"], "<>"]
    - [numeric, ["&#65;"],    "A"]
