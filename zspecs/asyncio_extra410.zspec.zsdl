spec: asyncio_extra410
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio-queue.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio queue documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "asyncio.Queue.put.__name__ == 'put'"
    - "asyncio.Queue.put_nowait.__name__ == 'put_nowait'"
    - "asyncio.Queue.get.__name__ == 'get'"
    - "asyncio.Queue.get_nowait.__name__ == 'get_nowait'"
    - "asyncio.Queue.empty.__name__ == 'empty'"
    - "asyncio.Queue.full.__name__ == 'full'"
    - "asyncio.Queue.qsize.__name__ == 'qsize'"
    - "asyncio.Queue.task_done.__name__ == 'task_done'"
    - "asyncio.Queue.join.__name__ == 'join'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra410.queue_method_names:
  description: "Verify __name__ attribute of asyncio.Queue methods"
  kind: python_call_eq
  category: identity
  id_prefix: aio410q

  columns: [id, function, args, expected]
  rows:
    - [aio410q001, asyncio.Queue.put.__name__.__eq__, ["put"], true]
    - [aio410q002, asyncio.Queue.put_nowait.__name__.__eq__, ["put_nowait"], true]
    - [aio410q003, asyncio.Queue.get.__name__.__eq__, ["get"], true]
    - [aio410q004, asyncio.Queue.get_nowait.__name__.__eq__, ["get_nowait"], true]
    - [aio410q005, asyncio.Queue.empty.__name__.__eq__, ["empty"], true]
    - [aio410q006, asyncio.Queue.full.__name__.__eq__, ["full"], true]
    - [aio410q007, asyncio.Queue.qsize.__name__.__eq__, ["qsize"], true]
    - [aio410q008, asyncio.Queue.task_done.__name__.__eq__, ["task_done"], true]
    - [aio410q009, asyncio.Queue.join.__name__.__eq__, ["join"], true]
