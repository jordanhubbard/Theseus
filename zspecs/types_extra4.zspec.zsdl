spec: types_extra4
version: ">=3.9"
backend: python_module(types)

docs: https://docs.python.org/3/library/types.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/types.html — Python types module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/types.py"
  notes:
    - "This spec extends prior types specs."
    - "Focus: __module__ and __name__ for types not yet covered."
    - "types.FunctionType.__name__ == 'function'."
    - "types.LambdaType.__name__ == 'function' (same as FunctionType)."
    - "types.CodeType.__name__ == 'code'."
    - "types.FrameType.__name__ == 'frame'."
    - "types.TracebackType.__name__ == 'traceback'."
    - "types.ModuleType.__name__ == 'module'."
    - "types.MethodType.__name__ == 'method'."
    - "types.BuiltinFunctionType.__name__ == 'builtin_function_or_method'."
    - "types.MappingProxyType.__name__ == 'mappingproxy'."
    - "types.CellType.__name__ == 'cell'."
    - "types.NoneType.__name__ == 'NoneType' (Python 3.10+)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table types_extra4.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [FunctionType,        FunctionType.__name__.__eq__,        ["function"],                   true]
    - [CodeType,            CodeType.__name__.__eq__,            ["code"],                        true]
    - [FrameType,           FrameType.__name__.__eq__,           ["frame"],                       true]
    - [TracebackType,       TracebackType.__name__.__eq__,       ["traceback"],                   true]
    - [ModuleType,          ModuleType.__name__.__eq__,          ["module"],                      true]
    - [MethodType,          MethodType.__name__.__eq__,          ["method"],                      true]
    - [BuiltinFunctionType, BuiltinFunctionType.__name__.__eq__, ["builtin_function_or_method"],  true]
    - [MappingProxyType,    MappingProxyType.__name__.__eq__,    ["mappingproxy"],                true]
    - [CellType,            CellType.__name__.__eq__,            ["cell"],                        true]
    - [NoneType,            NoneType.__name__.__eq__,            ["NoneType"],                    true]

table types_extra4.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [FunctionType,     FunctionType.__module__.__eq__,     ["builtins"], true]
    - [CodeType,         CodeType.__module__.__eq__,         ["builtins"], true]
    - [ModuleType,       ModuleType.__module__.__eq__,       ["builtins"], true]
    - [MappingProxyType, MappingProxyType.__module__.__eq__, ["builtins"], true]
    - [NoneType,         NoneType.__module__.__eq__,         ["builtins"], true]

invariant types_extra4.SimpleNamespace.class_name:
  description: "types.SimpleNamespace.__name__ == 'SimpleNamespace'"
  category: class_names
  kind: python_call_eq
  function: SimpleNamespace.__name__.__eq__
  args: ["SimpleNamespace"]
  expected: true

invariant types_extra4.SimpleNamespace.module:
  description: "types.SimpleNamespace.__module__ == 'builtins'"
  category: module
  kind: python_call_eq
  function: SimpleNamespace.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant types_extra4.SimpleNamespace.instance:
  description: "types.SimpleNamespace(x=1).x == 1"
  category: SimpleNamespace
  kind: python_call_eq
  function: SimpleNamespace
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["SimpleNamespace"]
  expected: true

invariant types_extra4.ModuleType.instance:
  description: "types.ModuleType('test').__class__.__name__ == 'module'"
  category: ModuleType
  kind: python_call_eq
  function: ModuleType
  args: ["test"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["module"]
  expected: true

invariant types_extra4.MappingProxyType.instance:
  description: "types.MappingProxyType({}).__class__.__name__ == 'mappingproxy'"
  category: MappingProxyType
  kind: python_call_eq
  function: MappingProxyType
  args: [{}]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["mappingproxy"]
  expected: true
