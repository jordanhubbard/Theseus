spec: socketserver_extra2
version: ">=3.9"
backend: python_module(socketserver)

docs: https://docs.python.org/3/library/socketserver.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socketserver.html — Python socketserver module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socketserver.py"
    - "socketserver.zspec.zsdl — covers __name__ tables (server classes and handler classes), TCPServer.__module__, TCPServer/StreamRequestHandler hierarchy"
    - "socketserver_extra.zspec.zsdl — covers standalone __name__ invariants for all server/handler/mixin classes, TCPServer/UDPServer __module__, TCPServer base, StreamRequestHandler/DatagramRequestHandler bases, ThreadingTCPServer/ForkingTCPServer names"
  notes:
    - "This spec adds __qualname__ vectors for all major socketserver classes — not covered in any prior spec."
    - "socketserver.TCPServer.__qualname__ == 'TCPServer' — top-level class, qualname equals name."
    - "socketserver.UDPServer.__qualname__ == 'UDPServer' — top-level class."
    - "socketserver.StreamRequestHandler.__qualname__ == 'StreamRequestHandler' — top-level class."
    - "socketserver.DatagramRequestHandler.__qualname__ == 'DatagramRequestHandler' — top-level class."
    - "socketserver.BaseServer.__qualname__ == 'BaseServer' — abstract base class."
    - "socketserver.BaseRequestHandler.__qualname__ == 'BaseRequestHandler' — abstract base handler."
    - "socketserver.ThreadingMixIn.__qualname__ == 'ThreadingMixIn' — concurrency mixin."
    - "socketserver.ForkingMixIn.__qualname__ == 'ForkingMixIn' — forking concurrency mixin (POSIX)."
    - "socketserver.TCPServer.__module__ == 'socketserver' — covered in socketserver.zspec; omitted here."
    - "socketserver.BaseServer.__module__ == 'socketserver' — not covered in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — all major socketserver classes
# Not covered in any prior socketserver spec.
# ---------------------------------------------------------------------------

table socketserver_extra2.qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [TCPServer,              TCPServer.__qualname__.__eq__,              ["TCPServer"],              true]
    - [UDPServer,              UDPServer.__qualname__.__eq__,              ["UDPServer"],              true]
    - [StreamRequestHandler,   StreamRequestHandler.__qualname__.__eq__,   ["StreamRequestHandler"],   true]
    - [DatagramRequestHandler, DatagramRequestHandler.__qualname__.__eq__, ["DatagramRequestHandler"], true]
    - [BaseServer,             BaseServer.__qualname__.__eq__,             ["BaseServer"],             true]
    - [BaseRequestHandler,     BaseRequestHandler.__qualname__.__eq__,     ["BaseRequestHandler"],     true]
    - [ThreadingMixIn,         ThreadingMixIn.__qualname__.__eq__,         ["ThreadingMixIn"],         true]
    - [ForkingMixIn,           ForkingMixIn.__qualname__.__eq__,           ["ForkingMixIn"],           true]

# ---------------------------------------------------------------------------
# BaseServer module check
# socketserver.zspec covers TCPServer.__module__.
# socketserver_extra covers TCPServer.__module__ and UDPServer.__module__.
# BaseServer.__module__ has never been checked in any prior spec.
# ---------------------------------------------------------------------------

invariant socketserver_extra2.BaseServer.module:
  description: "socketserver.BaseServer.__module__ == 'socketserver'"
  category: class_modules
  kind: python_call_eq
  function: BaseServer.__module__.__eq__
  args: ["socketserver"]
  expected: true
