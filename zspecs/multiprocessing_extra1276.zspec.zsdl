spec: multiprocessing_extra1276
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 532 _extra1276: TYPE checks for __subclasses__, __mro__, and __bases__ on multiprocessing classes — uses submodule class paths since Queue/Lock are factory functions at top level; distinct from prior waves that checked lengths"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1276.subclasses_type:
  description: "multiprocessing core classes __subclasses__() return type is list"
  kind: python_call_eq
  category: subclasses_type
  id_prefix: mp1276sc
  columns: [id, function, args, expected]
  rows:
    - [mp1276sc001, multiprocessing.Process.__subclasses__().__class__.__name__.__eq__,                    ["list"], true]
    - [mp1276sc002, multiprocessing.queues.Queue.__subclasses__().__class__.__name__.__eq__,               ["list"], true]
    - [mp1276sc003, multiprocessing.queues.JoinableQueue.__subclasses__().__class__.__name__.__eq__,       ["list"], true]
    - [mp1276sc004, multiprocessing.synchronize.Lock.__subclasses__().__class__.__name__.__eq__,           ["list"], true]
    - [mp1276sc005, multiprocessing.synchronize.Semaphore.__subclasses__().__class__.__name__.__eq__,      ["list"], true]
    - [mp1276sc006, multiprocessing.pool.Pool.__subclasses__().__class__.__name__.__eq__,                  ["list"], true]
    - [mp1276sc007, multiprocessing.synchronize.Event.__subclasses__().__class__.__name__.__eq__,          ["list"], true]
    - [mp1276sc008, multiprocessing.synchronize.Barrier.__subclasses__().__class__.__name__.__eq__,        ["list"], true]

