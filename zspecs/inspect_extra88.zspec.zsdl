spec: inspect_extra88
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra87

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra87.zspec.zsdl."
    - "This spec covers: inspect module function __qualname__ string equality for predicates and utility functions (Wave 250)."
    - "inspect.ismodule.__qualname__ == 'ismodule' — pure-Python function in Lib/inspect.py; __qualname__ is 'ismodule'. Verified with Python 3.14.3."
    - "inspect.isclass.__qualname__ == 'isclass' — pure-Python function; __qualname__ is 'isclass'. Verified with Python 3.14.3."
    - "inspect.isfunction.__qualname__ == 'isfunction' — pure-Python function; __qualname__ is 'isfunction'. Verified with Python 3.14.3."
    - "inspect.ismethod.__qualname__ == 'ismethod' — pure-Python function; __qualname__ is 'ismethod'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__qualname__ == 'isbuiltin' — pure-Python function; __qualname__ is 'isbuiltin'. Verified with Python 3.14.3."
    - "inspect.isgenerator.__qualname__ == 'isgenerator' — pure-Python function; __qualname__ is 'isgenerator'. Verified with Python 3.14.3."
    - "inspect.getmembers.__qualname__ == 'getmembers' — pure-Python function; __qualname__ is 'getmembers'. Verified with Python 3.14.3."
    - "inspect.signature.__qualname__ == 'signature' — pure-Python function; __qualname__ is 'signature'. Verified with Python 3.14.3."
    - "inspect.getdoc.__qualname__ == 'getdoc' — pure-Python function; __qualname__ is 'getdoc'. Verified with Python 3.14.3."
    - "inspect.getfile.__qualname__ == 'getfile' — pure-Python function; __qualname__ is 'getfile'. Verified with Python 3.14.3."
    - "inspect.getsource.__qualname__ == 'getsource' — pure-Python function; __qualname__ is 'getsource'. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__qualname__ == 'getsourcelines' — pure-Python function; __qualname__ is 'getsourcelines'. Verified with Python 3.14.3."
    - "inspect.getsourcefile.__qualname__ == 'getsourcefile' — pure-Python function; __qualname__ is 'getsourcefile'. Verified with Python 3.14.3."
    - "inspect.getmodule.__qualname__ == 'getmodule' — pure-Python function; __qualname__ is 'getmodule'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Predicate qualnames group 1: ismodule, isclass, isfunction, ismethod
#
# Wave 250 theme: inspect predicate function __qualname__ string equality — group 1.
#
# inspect.ismodule.__qualname__.__eq__('ismodule')     == True
# inspect.isclass.__qualname__.__eq__('isclass')       == True
# inspect.isfunction.__qualname__.__eq__('isfunction') == True
# inspect.ismethod.__qualname__.__eq__('ismethod')     == True
#
# Prior spec extra87 checked Parameter/Signature/BoundArguments class identity. This spec (extra88) checks function __qualname__. New to extra88.
# ---------------------------------------------------------------------------

table inspect_extra88.predicate_qualnames_group1:
  description: "ismodule/isclass/isfunction/ismethod __qualname__ strings; pure-Python predicates in Lib/inspect.py; wave 250; new to extra88"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfnqual88

  columns: [id, function, args, expected, description]
  rows:
    - [ismodule_qualname_eq_ismodule,
       ismodule.__qualname__.__eq__,
       ["ismodule"],
       true,
       "inspect.ismodule.__qualname__.__eq__('ismodule') == True — ismodule is a pure-Python predicate function in Lib/inspect.py that returns True if the object is a module; as a module-level function __qualname__ equals __name__; __qualname__ is 'ismodule' (8 chars); str.__eq__('ismodule') returns True; no prior inspect spec checks ismodule.__qualname__ via inspectfnqual88; new to extra88"]
    - [isclass_qualname_eq_isclass,
       isclass.__qualname__.__eq__,
       ["isclass"],
       true,
       "inspect.isclass.__qualname__.__eq__('isclass') == True — isclass is a pure-Python predicate function in Lib/inspect.py that returns True if the object is a class; as a module-level function __qualname__ equals __name__; __qualname__ is 'isclass' (7 chars); str.__eq__('isclass') returns True; no prior inspect spec checks isclass.__qualname__ via inspectfnqual88; new to extra88"]
    - [isfunction_qualname_eq_isfunction,
       isfunction.__qualname__.__eq__,
       ["isfunction"],
       true,
       "inspect.isfunction.__qualname__.__eq__('isfunction') == True — isfunction is a pure-Python predicate function in Lib/inspect.py that returns True if the object is a Python function; as a module-level function __qualname__ equals __name__; __qualname__ is 'isfunction' (10 chars); str.__eq__('isfunction') returns True; no prior inspect spec checks isfunction.__qualname__ via inspectfnqual88; new to extra88"]
    - [ismethod_qualname_eq_ismethod,
       ismethod.__qualname__.__eq__,
       ["ismethod"],
       true,
       "inspect.ismethod.__qualname__.__eq__('ismethod') == True — ismethod is a pure-Python predicate function in Lib/inspect.py that returns True if the object is a bound method; as a module-level function __qualname__ equals __name__; __qualname__ is 'ismethod' (8 chars); str.__eq__('ismethod') returns True; no prior inspect spec checks ismethod.__qualname__ via inspectfnqual88; new to extra88"]

# ---------------------------------------------------------------------------
# Predicate qualnames group 2: isbuiltin, isgenerator, getmembers, signature
#
# Wave 250 theme: inspect predicate function __qualname__ string equality — group 2.
#
# inspect.isbuiltin.__qualname__.__eq__('isbuiltin')     == True
# inspect.isgenerator.__qualname__.__eq__('isgenerator') == True
# inspect.getmembers.__qualname__.__eq__('getmembers')   == True
# inspect.signature.__qualname__.__eq__('signature')     == True
#
# No prior inspect spec checks __qualname__ for these functions via inspectfnqual88. New to extra88.
# ---------------------------------------------------------------------------

table inspect_extra88.predicate_qualnames_group2:
  description: "isbuiltin/isgenerator/getmembers/signature __qualname__ strings; pure-Python functions in Lib/inspect.py; wave 250; new to extra88"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfnqual88

  columns: [id, function, args, expected, description]
  rows:
    - [isbuiltin_qualname_eq_isbuiltin,
       isbuiltin.__qualname__.__eq__,
       ["isbuiltin"],
       true,
       "inspect.isbuiltin.__qualname__.__eq__('isbuiltin') == True — isbuiltin is a pure-Python predicate function in Lib/inspect.py that returns True if the object is a built-in function or bound method; as a module-level function __qualname__ equals __name__; __qualname__ is 'isbuiltin' (9 chars); str.__eq__('isbuiltin') returns True; no prior inspect spec checks isbuiltin.__qualname__ via inspectfnqual88; new to extra88"]
    - [isgenerator_qualname_eq_isgenerator,
       isgenerator.__qualname__.__eq__,
       ["isgenerator"],
       true,
       "inspect.isgenerator.__qualname__.__eq__('isgenerator') == True — isgenerator is a pure-Python predicate function in Lib/inspect.py that returns True if the object is a generator; as a module-level function __qualname__ equals __name__; __qualname__ is 'isgenerator' (11 chars); str.__eq__('isgenerator') returns True; no prior inspect spec checks isgenerator.__qualname__ via inspectfnqual88; new to extra88"]
    - [getmembers_qualname_eq_getmembers,
       getmembers.__qualname__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__qualname__.__eq__('getmembers') == True — getmembers is a pure-Python utility function in Lib/inspect.py that returns all members of an object as a sorted list of (name, value) pairs; as a module-level function __qualname__ equals __name__; __qualname__ is 'getmembers' (10 chars); str.__eq__('getmembers') returns True; no prior inspect spec checks getmembers.__qualname__ via inspectfnqual88; new to extra88"]
    - [signature_qualname_eq_signature,
       signature.__qualname__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__qualname__.__eq__('signature') == True — signature is a pure-Python utility function in Lib/inspect.py that returns a Signature object for the given callable; as a module-level function __qualname__ equals __name__; __qualname__ is 'signature' (9 chars); str.__eq__('signature') returns True; no prior inspect spec checks signature.__qualname__ via inspectfnqual88; new to extra88"]

# ---------------------------------------------------------------------------
# Source-related function qualnames: getsource, getsourcelines, getsourcefile, getfile
#
# Wave 250 theme: inspect source-related function __qualname__ string equality.
#
# inspect.getsource.__qualname__.__eq__('getsource')           == True
# inspect.getsourcelines.__qualname__.__eq__('getsourcelines') == True
# inspect.getsourcefile.__qualname__.__eq__('getsourcefile')   == True
# inspect.getfile.__qualname__.__eq__('getfile')               == True
#
# No prior inspect spec checks __qualname__ for these functions via inspectfnqual88. New to extra88.
# ---------------------------------------------------------------------------

table inspect_extra88.source_fn_qualnames:
  description: "getsource/getsourcelines/getsourcefile/getfile __qualname__ strings; source-related utility functions in Lib/inspect.py; wave 250; new to extra88"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfnqual88

  columns: [id, function, args, expected, description]
  rows:
    - [getsource_qualname_eq_getsource,
       getsource.__qualname__.__eq__,
       ["getsource"],
       true,
       "inspect.getsource.__qualname__.__eq__('getsource') == True — getsource is a pure-Python function in Lib/inspect.py that returns the source code text for an object; as a module-level function __qualname__ equals __name__; __qualname__ is 'getsource' (9 chars); str.__eq__('getsource') returns True; no prior inspect spec checks getsource.__qualname__ via inspectfnqual88; new to extra88"]
    - [getsourcelines_qualname_eq_getsourcelines,
       getsourcelines.__qualname__.__eq__,
       ["getsourcelines"],
       true,
       "inspect.getsourcelines.__qualname__.__eq__('getsourcelines') == True — getsourcelines is a pure-Python function in Lib/inspect.py that returns a list of source lines and starting line number for an object; as a module-level function __qualname__ equals __name__; __qualname__ is 'getsourcelines' (14 chars); str.__eq__('getsourcelines') returns True; no prior inspect spec checks getsourcelines.__qualname__ via inspectfnqual88; new to extra88"]
    - [getsourcefile_qualname_eq_getsourcefile,
       getsourcefile.__qualname__.__eq__,
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__qualname__.__eq__('getsourcefile') == True — getsourcefile is a pure-Python function in Lib/inspect.py that returns the filename of a Python source file for an object; as a module-level function __qualname__ equals __name__; __qualname__ is 'getsourcefile' (13 chars); str.__eq__('getsourcefile') returns True; no prior inspect spec checks getsourcefile.__qualname__ via inspectfnqual88; new to extra88"]
    - [getfile_qualname_eq_getfile,
       getfile.__qualname__.__eq__,
       ["getfile"],
       true,
       "inspect.getfile.__qualname__.__eq__('getfile') == True — getfile is a pure-Python function in Lib/inspect.py that returns the name of the Python source file in which an object was defined; as a module-level function __qualname__ equals __name__; __qualname__ is 'getfile' (7 chars); str.__eq__('getfile') returns True; no prior inspect spec checks getfile.__qualname__ via inspectfnqual88; new to extra88"]

# ---------------------------------------------------------------------------
# Utility function qualnames: getdoc, getmodule, and cross-checks
#
# Wave 250 theme: inspect utility function __qualname__ string equality + cross-checks.
#
# inspect.getdoc.__qualname__.__eq__('getdoc')       == True
# inspect.getmodule.__qualname__.__eq__('getmodule') == True
# inspect.ismodule.__qualname__.__eq__('isclass')    == False (cross-check)
# inspect.getdoc.__qualname__.__eq__('getfile')      == False (cross-check)
#
# No prior inspect spec checks __qualname__ for getdoc/getmodule via inspectfnqual88. New to extra88.
# ---------------------------------------------------------------------------

table inspect_extra88.utility_fn_qualnames:
  description: "getdoc/getmodule __qualname__ strings + cross-checks; utility functions in Lib/inspect.py; wave 250; new to extra88"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectfnqual88

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_qualname_eq_getdoc,
       getdoc.__qualname__.__eq__,
       ["getdoc"],
       true,
       "inspect.getdoc.__qualname__.__eq__('getdoc') == True — getdoc is a pure-Python function in Lib/inspect.py that returns the docstring for an object, cleaned up with cleandoc; as a module-level function __qualname__ equals __name__; __qualname__ is 'getdoc' (6 chars); str.__eq__('getdoc') returns True; no prior inspect spec checks getdoc.__qualname__ via inspectfnqual88; new to extra88"]
    - [getmodule_qualname_eq_getmodule,
       getmodule.__qualname__.__eq__,
       ["getmodule"],
       true,
       "inspect.getmodule.__qualname__.__eq__('getmodule') == True — getmodule is a pure-Python function in Lib/inspect.py that returns the name of the Python module in which an object was defined; as a module-level function __qualname__ equals __name__; __qualname__ is 'getmodule' (9 chars); str.__eq__('getmodule') returns True; no prior inspect spec checks getmodule.__qualname__ via inspectfnqual88; new to extra88"]
    - [ismodule_qualname_ne_isclass,
       ismodule.__qualname__.__eq__,
       ["isclass"],
       false,
       "inspect.ismodule.__qualname__.__eq__('isclass') == False — ismodule.__qualname__ is 'ismodule', not 'isclass'; each inspect function has a unique __qualname__; str.__eq__('isclass') returns False; confirms __qualname__ distinguishes ismodule from isclass; new to extra88"]
    - [getdoc_qualname_ne_getfile,
       getdoc.__qualname__.__eq__,
       ["getfile"],
       false,
       "inspect.getdoc.__qualname__.__eq__('getfile') == False — getdoc.__qualname__ is 'getdoc', not 'getfile'; each inspect function has a unique __qualname__; str.__eq__('getfile') returns False; confirms __qualname__ distinguishes getdoc from getfile; new to extra88"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra88
# ---------------------------------------------------------------------------

invariant inspect_extra88.ismodule_qualname_eq_ismodule:
  description: "inspect.ismodule.__qualname__.__eq__('ismodule') == True — ismodule __qualname__ is 'ismodule'; wave 250; new to extra88"
  kind: python_call_eq
  function: ismodule.__qualname__.__eq__
  args: ["ismodule"]
  expected: true

invariant inspect_extra88.isfunction_qualname_eq_isfunction:
  description: "inspect.isfunction.__qualname__.__eq__('isfunction') == True — isfunction __qualname__ is 'isfunction'; wave 250; new to extra88"
  kind: python_call_eq
  function: isfunction.__qualname__.__eq__
  args: ["isfunction"]
  expected: true

invariant inspect_extra88.getsource_qualname_eq_getsource:
  description: "inspect.getsource.__qualname__.__eq__('getsource') == True — getsource __qualname__ is 'getsource'; wave 250; new to extra88"
  kind: python_call_eq
  function: getsource.__qualname__.__eq__
  args: ["getsource"]
  expected: true

invariant inspect_extra88.signature_qualname_eq_signature:
  description: "inspect.signature.__qualname__.__eq__('signature') == True — signature __qualname__ is 'signature'; wave 250; new to extra88"
  kind: python_call_eq
  function: signature.__qualname__.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra88.getmodule_qualname_eq_getmodule:
  description: "inspect.getmodule.__qualname__.__eq__('getmodule') == True — getmodule __qualname__ is 'getmodule'; wave 250; new to extra88"
  kind: python_call_eq
  function: getmodule.__qualname__.__eq__
  args: ["getmodule"]
  expected: true
