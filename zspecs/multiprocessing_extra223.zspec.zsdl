# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool worker method name contracts — extra223 namespace
#
# Pool.apply, map, starmap are the core work-submission methods.
# All have qualnames with 'Pool.' prefix.
# apply (5 chars), map (3 chars), starmap (7 chars).
# ---------------------------------------------------------------------------

table multiprocessing_extra223.pool_worker_method_names:
  description: "multiprocessing.pool.Pool worker method __name__ and __qualname__ contracts in mp223wmn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp223wmn

  columns: [id, function, args, expected, description]
  rows:
    - [pool_apply_name_eq,     Pool.apply.__name__.__eq__,       ["apply"],        true, "multiprocessing.pool.Pool.apply.__name__ == 'apply'; verified with Python 3.14.3"]
    - [pool_apply_name_len_5,  Pool.apply.__name__.__len__,      [],               5,    "multiprocessing.pool.Pool.apply.__name__.__len__() == 5 — 'apply' has 5 characters; verified with Python 3.14.3"]
    - [pool_apply_qualname_eq, Pool.apply.__qualname__.__eq__,   ["Pool.apply"],   true, "multiprocessing.pool.Pool.apply.__qualname__ == 'Pool.apply'; verified with Python 3.14.3"]
    - [pool_map_name_eq,       Pool.map.__name__.__eq__,         ["map"],          true, "multiprocessing.pool.Pool.map.__name__ == 'map'; verified with Python 3.14.3"]
    - [pool_map_name_len_3,    Pool.map.__name__.__len__,        [],               3,    "multiprocessing.pool.Pool.map.__name__.__len__() == 3 — 'map' has 3 characters; verified with Python 3.14.3"]
    - [pool_map_qualname_eq,   Pool.map.__qualname__.__eq__,     ["Pool.map"],     true, "multiprocessing.pool.Pool.map.__qualname__ == 'Pool.map'; verified with Python 3.14.3"]
    - [pool_smap_name_eq,      Pool.starmap.__name__.__eq__,     ["starmap"],      true, "multiprocessing.pool.Pool.starmap.__name__ == 'starmap'; verified with Python 3.14.3"]
    - [pool_smap_name_len_7,   Pool.starmap.__name__.__len__,    [],               7,    "multiprocessing.pool.Pool.starmap.__name__.__len__() == 7 — 'starmap' has 7 characters; verified with Python 3.14.3"]
