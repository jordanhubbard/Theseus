spec: decimal_extra225
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Context attribute contracts — default precision (prec=28), rounding mode (ROUND_HALF_EVEN), and rounding constant string identity."
    - "decimal.getcontext().__class__.__name__ == 'Context' — getcontext() returns a Context instance; verified Python 3.14.3 macOS."
    - "decimal.getcontext().prec == 28 — default thread-local precision is 28 significant digits; verified Python 3.14.3 macOS."
    - "decimal.getcontext().rounding == 'ROUND_HALF_EVEN' — default rounding mode is banker's rounding; verified Python 3.14.3 macOS."
    - "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str' — rounding constants are plain strings; verified Python 3.14.3 macOS."
    - "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True; verified Python 3.14.3 macOS."
    - "decimal.ROUND_UP.__eq__('ROUND_UP') == True; verified Python 3.14.3 macOS."
    - "decimal.ROUND_DOWN.__eq__('ROUND_DOWN') == True; verified Python 3.14.3 macOS."
    - "decimal.ROUND_CEILING.__eq__('ROUND_CEILING') == True; verified Python 3.14.3 macOS."
    - "decimal.ROUND_FLOOR.__eq__('ROUND_FLOOR') == True; verified Python 3.14.3 macOS."
    - "decimal.ROUND_HALF_UP.__eq__('ROUND_HALF_UP') == True; verified Python 3.14.3 macOS."
    - "decimal.ROUND_HALF_DOWN.__eq__('ROUND_HALF_DOWN') == True; verified Python 3.14.3 macOS."
    - "decimal.ROUND_05UP.__eq__('ROUND_05UP') == True; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context class name and default attribute contracts
# getcontext().__class__.__name__ == 'Context'.
# Default prec == 28 and rounding == 'ROUND_HALF_EVEN'.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra225.getcontext.class_name:
  description: "decimal.getcontext().__class__.__name__ == 'Context' — getcontext() returns an instance of decimal.Context; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: getcontext().__class__.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra225.getcontext.default_prec:
  description: "decimal.getcontext().prec == 28 — default thread-local Context precision is 28 significant digits; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: getcontext().prec.__eq__
  args: [28]
  expected: true

invariant decimal_extra225.getcontext.default_rounding:
  description: "decimal.getcontext().rounding == 'ROUND_HALF_EVEN' — default rounding mode is ROUND_HALF_EVEN (banker's rounding); verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: getcontext().rounding.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

# ---------------------------------------------------------------------------
# decimal rounding constant string identity contracts
# All rounding constants are plain str instances.
# ROUND_HALF_EVEN, ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR,
# ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_05UP.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra225.ROUND_HALF_EVEN.class_name:
  description: "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str' — rounding constants are plain string objects; verified Python 3.14.3 macOS"
  category: constant
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__class__.__name__.__eq__
  args: ["str"]
  expected: true

table decimal_extra225.rounding_constants:
  description: "decimal rounding constant string identity contracts — each constant equals its own name string; verified with Python 3.14.3"
  kind: python_call_eq
  category: constant
  id_prefix: decroundconst225

  columns: [id, function, args, expected]
  rows:
    - [round_half_even,  ROUND_HALF_EVEN.__eq__,  ["ROUND_HALF_EVEN"],  true]
    - [round_up,         ROUND_UP.__eq__,         ["ROUND_UP"],         true]
    - [round_down,       ROUND_DOWN.__eq__,       ["ROUND_DOWN"],       true]
    - [round_ceiling,    ROUND_CEILING.__eq__,    ["ROUND_CEILING"],    true]
    - [round_floor,      ROUND_FLOOR.__eq__,      ["ROUND_FLOOR"],      true]
    - [round_half_up,    ROUND_HALF_UP.__eq__,    ["ROUND_HALF_UP"],    true]
    - [round_half_down,  ROUND_HALF_DOWN.__eq__,  ["ROUND_HALF_DOWN"],  true]
    - [round_05up,       ROUND_05UP.__eq__,       ["ROUND_05UP"],       true]
