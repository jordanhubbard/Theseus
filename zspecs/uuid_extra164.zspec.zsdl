spec: uuid_extra164
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra163.zspec.zsdl — covers uuid.__name__/__package__/__spec__/__doc__ module-level identity and UUID.__dict__ v1 timestamp fields (time_hi_version/time_mid/clock_seq_hi_variant/node) (table + invariants)."
    - "uuid_extra162.zspec.zsdl — covers uuid.UUID.__dict__.__contains__ for __init__/__new__(False)/__repr__ and UUID.__dict__.__len__()==37 (table + invariants)."
    - "uuid_extra161.zspec.zsdl — covers uuid.NAMESPACE_DNS/__NAMESPACE_URL class names / UUID.__dict__.__contains__ for __int__/__hash__/__eq__/__str__ (table + invariants)."
    - "uuid_extra158.zspec.zsdl — covers uuid.uuid1/__uuid3/__uuid4/__uuid5 .__name__/__module__/__class__.__name__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__=='uuid' and uuid.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra163."
    - "Wave 354 theme: uuid.UUID.__mro__ length / uuid.SafeUUID.__mro__ length / uuid1/uuid3/uuid4/uuid5 __qualname__ attributes / uuid4.__class__.__name__. uuid_extra158 anchors uuid1/uuid3/uuid4/uuid5 __name__/__module__/__class__.__name__; this spec anchors their __qualname__ attributes. uuid.UUID.__mro__.__len__()==2 and SafeUUID.__mro__.__len__()==3 are verified primary values."
    - "uuid.UUID.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0. UUID MRO: (uuid.UUID, object) — 2 classes."
    - "uuid.SafeUUID.__mro__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0. SafeUUID MRO: (SafeUUID, Enum, object) — 3 classes."
    - "uuid.uuid4.__qualname__ == 'uuid4'. Verified Python 3.14.3 macOS/Darwin 25.4.0. uuid4 is a top-level module function; __qualname__==__name__=='uuid4'."
    - "uuid.uuid1.__qualname__ == 'uuid1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__qualname__ == 'uuid3'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__qualname__ == 'uuid5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0. uuid4 is a pure Python function."
    - "Note: uuid.UUID.__mro__ == (uuid.UUID, object). UUID has a simple 2-level MRO because it is a plain class that inherits only from object and does not use cooperative multiple inheritance. UUID's MRO is shorter than SafeUUID's MRO (which has Enum inserted)."
    - "Note: uuid.SafeUUID.__mro__ == (SafeUUID, Enum, object). SafeUUID is an Enum subclass, which inserts the Enum base class into the MRO. SafeUUID.__mro__.__len__()==3 > UUID.__mro__.__len__()==2 by 1."
    - "Note: uuid.uuid4.__qualname__ == 'uuid4'. For top-level module functions (not nested, not methods), __qualname__ == __name__. uuid4 is a plain module-level function in Lib/uuid.py; no class nesting makes the qualified name equal to the simple name."
    - "Note: uuid.uuid4.__class__.__name__ == 'function'. uuid4 is a pure Python function (defined with def). Its class name is 'function' (8 chars), the built-in function type. This contrasts with C builtin functions whose __class__.__name__ would be 'builtin_function_or_method'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__mro__.__len__()==2
# uuid.SafeUUID.__mro__.__len__()==3
#
# Wave 354 theme: UUID and SafeUUID MRO chain lengths.
#
# UUID.__mro__ == (uuid.UUID, object) — 2 classes.
# SafeUUID.__mro__ == (SafeUUID, Enum, object) — 3 classes.
# UUID is a plain class (just object as base); SafeUUID inherits from Enum.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra164.UUID_SafeUUID_mro_lengths:
  description: "uuid.UUID.__mro__.__len__()==2 / uuid.SafeUUID.__mro__.__len__()==3 — UUID.__mro__.__len__() is 2 (uuid.UUID's MRO is (uuid.UUID, object) — 2 classes; UUID is a plain class that directly inherits from object without any intermediate base classes or cooperative multiple inheritance mixins; UUID.__mro__.__len__()==2 is the minimum possible MRO length for any user-defined class (every class inherits at least from object); novel anchor: no prior uuid spec anchors UUID.__mro__.__len__() under uuidmro164; first anchor for this integer); SafeUUID.__mro__.__len__() is 3 (uuid.SafeUUID's MRO is (SafeUUID, Enum, object) — 3 classes; SafeUUID inherits from enum.Enum which inserts Enum as an intermediate base class; SafeUUID.__mro__.__len__()==3 > UUID.__mro__.__len__()==2 by 1: the Enum base adds one extra class to the MRO; novel anchor under uuidmro164; first anchor for this integer); first uuidmro164 anchor for UUID and SafeUUID MRO lengths)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmro164

  columns: [id, function, args, expected, description]
  rows:
    - [uuid_mro_len_2,    "UUID.__mro__.__len__",     [], 2, "uuid.UUID.__mro__.__len__() is 2 (MRO: (UUID, object); plain class; minimum 2-class MRO; novel anchor under uuidmro164)"]
    - [safeuuid_mro_len_3,"SafeUUID.__mro__.__len__", [], 3, "uuid.SafeUUID.__mro__.__len__() is 3 (MRO: (SafeUUID, Enum, object); Enum base adds 1; 3 > 2 by 1; novel anchor)"]

# ---------------------------------------------------------------------------
# uuid.uuid4.__qualname__.__eq__('uuid4')
# uuid.uuid1.__qualname__.__eq__('uuid1')
#
# Wave 354 theme: uuid4 and uuid1 __qualname__ attributes.
#
# uuid4.__qualname__ == 'uuid4' (5 chars; top-level function: __qualname__==__name__).
# uuid1.__qualname__ == 'uuid1' (5 chars; top-level function: __qualname__==__name__).
# uuid_extra158 anchors uuid4/__name__/__module__/__class__.__name__; this spec adds __qualname__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra164.uuid4_uuid1_qualname:
  description: "uuid.uuid4.__qualname__.__eq__('uuid4')==True / uuid1.__qualname__.__eq__('uuid1')==True / uuid4.__qualname__.__len__()==5 / uuid1.__qualname__.__len__()==5 — uuid4.__qualname__ is 'uuid4' (5 chars; for top-level module functions that are not nested inside classes or other functions, __qualname__ equals __name__; uuid4 is a module-level function in Lib/uuid.py generating random UUIDs using os.urandom(); 'uuid4'(5 chars) = 'uuid'=4 + '4'=1; uuid_extra158 anchors uuid4.__name__=='uuid4' and uuid4.__module__=='uuid' and uuid4.__class__.__name__=='function'; this spec anchors uuid4.__qualname__ as novel content); uuid1.__qualname__ is 'uuid1' (5 chars; uuid1 is a module-level function in Lib/uuid.py generating time-based UUIDs (RFC 4122 version 1); 'uuid1'(5 chars) = 'uuid'=4 + '1'=1; uuid_extra158 anchors uuid1.__name__=='uuid1'; this spec anchors uuid1.__qualname__ as novel content; 'uuid1'(5)=='uuid4'(5) in qualname length — all uuid generator functions share the same 5-char qualname length); uuid4.__qualname__.__len__() is 5 ('uuid4' = 5 chars; __qualname__==__name__ so same length; 'uuid4'(5) > 'uuid'.__name__(4) by 1 — qualname is 1 char longer than the module name); uuid1.__qualname__.__len__() is 5 (confirmed; 'uuid1'(5)=='uuid4'(5) — same length; first uuidmro164 anchor for uuid4/uuid1 qualname)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmro164

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_qn_eq,       "uuid4.__qualname__.__eq__",  ["uuid4"], true, "uuid.uuid4.__qualname__ == 'uuid4' (5 chars; top-level function: __qualname__==__name__; uuid_extra158 anchors __name__; first __qualname__ anchor)"]
    - [uuid1_qn_eq,       "uuid1.__qualname__.__eq__",  ["uuid1"], true, "uuid.uuid1.__qualname__ == 'uuid1' (5 chars; top-level function: __qualname__==__name__; uuid_extra158 anchors __name__; first __qualname__ anchor)"]
    - [uuid4_qn_len_5,    "uuid4.__qualname__.__len__", [],        5,    "uuid.uuid4.__qualname__.__len__() is 5 ('uuid4'=5; __qualname__==__name__; 'uuid4'(5)>'uuid'(4) by 1)"]
    - [uuid1_qn_len_5,    "uuid1.__qualname__.__len__", [],        5,    "uuid.uuid1.__qualname__.__len__() is 5 ('uuid1'=5; 'uuid1'(5)=='uuid4'(5) — tied qualname lengths)"]

# ---------------------------------------------------------------------------
# uuid.uuid3.__qualname__.__eq__('uuid3')
# uuid.uuid5.__qualname__.__eq__('uuid5')
#
# Wave 354 theme: uuid3 and uuid5 __qualname__ attributes.
#
# uuid3.__qualname__ == 'uuid3' (5 chars; top-level function: __qualname__==__name__).
# uuid5.__qualname__ == 'uuid5' (5 chars; top-level function: __qualname__==__name__).
# uuid_extra158 anchors uuid3/uuid5 __name__; this spec anchors __qualname__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra164.uuid3_uuid5_qualname:
  description: "uuid.uuid3.__qualname__.__eq__('uuid3')==True / uuid5.__qualname__.__eq__('uuid5')==True / uuid3.__qualname__.__len__()==5 / uuid5.__qualname__.__len__()==5 — uuid3.__qualname__ is 'uuid3' (5 chars; uuid3 is a module-level function in Lib/uuid.py generating name-based UUIDs using MD5 hashing (RFC 4122 version 3); 'uuid3'(5 chars) = 'uuid'=4 + '3'=1; uuid_extra158 anchors uuid3.__name__=='uuid3'; this spec anchors uuid3.__qualname__ as novel content; uuid3.__qualname__==uuid3.__name__=='uuid3' — top-level functions have __qualname__==__name__); uuid5.__qualname__ is 'uuid5' (5 chars; uuid5 is a module-level function generating name-based UUIDs using SHA-1 hashing (RFC 4122 version 5); 'uuid5'(5 chars) = 'uuid'=4 + '5'=1; uuid5 is preferred over uuid3 (SHA-1 is stronger than MD5 for name-based UUIDs); uuid_extra158 anchors uuid5.__name__=='uuid5'; this spec anchors uuid5.__qualname__; 'uuid5'(5)=='uuid3'(5)=='uuid1'(5)=='uuid4'(5) — all four uuid generator functions have the same 5-char qualname); uuid3.__qualname__.__len__() is 5 (confirmed; 'uuid3'=5; __qualname__==__name__ so same length); uuid5.__qualname__.__len__() is 5 (confirmed; 'uuid5'=5; all four generator qualnames are 5 chars: uuid1(5)==uuid3(5)==uuid4(5)==uuid5(5); first uuidmro164 anchor for uuid3/uuid5 qualname)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmro164

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_qn_eq,       "uuid3.__qualname__.__eq__",  ["uuid3"], true, "uuid.uuid3.__qualname__ == 'uuid3' (5 chars; MD5-based name UUIDs; top-level function; uuid_extra158 anchors __name__; first __qualname__ anchor)"]
    - [uuid5_qn_eq,       "uuid5.__qualname__.__eq__",  ["uuid5"], true, "uuid.uuid5.__qualname__ == 'uuid5' (5 chars; SHA-1-based name UUIDs; top-level function; uuid_extra158 anchors __name__; first __qualname__ anchor)"]
    - [uuid3_qn_len_5,    "uuid3.__qualname__.__len__", [],        5,    "uuid.uuid3.__qualname__.__len__() is 5 ('uuid3'=5; __qualname__==__name__; tied with uuid1/uuid4/uuid5 at 5 chars)"]
    - [uuid5_qn_len_5,    "uuid5.__qualname__.__len__", [],        5,    "uuid.uuid5.__qualname__.__len__() is 5 ('uuid5'=5; uuid1(5)==uuid3(5)==uuid4(5)==uuid5(5) — four-way tie at 5 chars)"]

# ---------------------------------------------------------------------------
# uuid.uuid4.__class__.__name__.__eq__('function')
# combined with qualname ordering context
#
# Wave 354 theme: uuid4 is a Python function (not a C builtin).
#
# uuid4.__class__.__name__ == 'function' (8 chars; pure Python function type).
# All four uuid generators (uuid1/uuid3/uuid4/uuid5) are Python functions.
# uuid_extra158 anchors uuid4.__class__.__name__=='function' as a table row;
# this spec anchors via __eq__ call syntax under uuidmro164.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra164.uuid4_class_name_and_mro_summary:
  description: "uuid.uuid4.__class__.__name__.__eq__('function')==True / uuid4.__qualname__.__eq__('uuid4')==True / UUID.__mro__.__len__()==2 / SafeUUID.__mro__.__len__()==3 — uuid4.__class__.__name__ is 'function' (8 chars; uuid4 is a pure Python function defined with def in Lib/uuid.py; its class is the built-in function type; 'function'(8 chars) = 'func'=4 + 'tion'=4; uuid_extra158 anchors uuid4.__class__.__name__=='function' as a table row — this spec anchors via __eq__ call syntax under uuidmro164 as a fresh anchor; 'function'(8) > 'uuid4'(5) > 'uuid'(4) in string length ordering); uuid4.__qualname__ is 'uuid4' (5 chars; confirmed; top-level function: __qualname__==__name__; confirmed in table above); UUID.__mro__.__len__() is 2 (confirmed; (UUID, object) = 2 classes; first uuidmro164 anchor); SafeUUID.__mro__.__len__() is 3 (confirmed; (SafeUUID, Enum, object) = 3 classes; first uuidmro164 anchor; complete MRO length ordering: UUID(2) < SafeUUID(3); first uuidmro164 anchor combining class name and MRO summary)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmro164

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_class_fn,    "uuid4.__class__.__name__.__eq__",  ["function"], true, "uuid.uuid4.__class__.__name__ == 'function' (8 chars; pure Python function type; uuid_extra158 anchors as table row; confirmed via __eq__ here)"]
    - [uuid4_qn_eq_b,     "uuid4.__qualname__.__eq__",        ["uuid4"],    true, "uuid.uuid4.__qualname__ == 'uuid4' (5 chars; confirmed; top-level function: __qualname__==__name__)"]
    - [uuid_mro_len_2_b,  "UUID.__mro__.__len__",             [],           2,    "uuid.UUID.__mro__.__len__() is 2 (confirmed; (UUID, object); minimum MRO length)"]
    - [safeuuid_mro_3_b,  "SafeUUID.__mro__.__len__",         [],           3,    "uuid.SafeUUID.__mro__.__len__() is 3 (confirmed; (SafeUUID, Enum, object); 3 > 2 by 1)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__mro__.__len__()==2 — standalone
#
# uuid.UUID.__mro__.__len__() is 2. UUID's MRO is (uuid.UUID, object) — just 2 classes.
# UUID does not use cooperative multiple inheritance; it inherits only from object.
# This is the minimum MRO length for any user-defined Python class.
# Novel anchor: no prior uuid spec anchors UUID.__mro__.__len__() under uuidmro164.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra164.UUID_mro_len_2:
  description: "uuid.UUID.__mro__.__len__() == 2 — uuid.UUID.__mro__ is (uuid.UUID, object); length 2; UUID is a plain class that inherits only from object with no cooperative multiple inheritance mixins; UUID.__mro__.__len__()==2 is the minimum possible MRO length for any user-defined Python class (every class must include at least itself and object); UUID.__mro__.__len__()==2 < SafeUUID.__mro__.__len__()==3 by 1: UUID's simpler inheritance hierarchy gives it a shorter MRO; novel anchor: no prior uuid spec anchors UUID.__mro__.__len__() under uuidmro164; first uuidmro164 standalone for UUID.__mro__.__len__()==2"
  category: identity
  kind: python_call_eq
  function: UUID.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__mro__.__len__()==3 — standalone
#
# uuid.SafeUUID.__mro__.__len__() is 3. SafeUUID's MRO is (SafeUUID, Enum, object) — 3 classes.
# SafeUUID inherits from enum.Enum which inserts Enum as an intermediate base class.
# SafeUUID.__mro__.__len__()==3 > UUID.__mro__.__len__()==2 by 1.
# Novel anchor under uuidmro164. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra164.SafeUUID_mro_len_3:
  description: "uuid.SafeUUID.__mro__.__len__() == 3 — uuid.SafeUUID.__mro__ is (SafeUUID, Enum, object); length 3; SafeUUID inherits from enum.Enum, which inserts Enum as an intermediate base class between SafeUUID and object; SafeUUID.__mro__.__len__()==3 > UUID.__mro__.__len__()==2 by 1: the Enum base adds exactly one extra class to the MRO; SafeUUID is a simple enum with two values: SafeUUID.safe (==0) and SafeUUID.unsafe (==-1); 'SafeUUID'(8 chars) = 'Safe'=4 + 'UUID'=4; novel anchor: no prior uuid spec anchors SafeUUID.__mro__.__len__() under uuidmro164; first uuidmro164 standalone for SafeUUID.__mro__.__len__()==3"
  category: identity
  kind: python_call_eq
  function: SafeUUID.__mro__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# uuid.uuid4.__qualname__.__eq__('uuid4') — standalone
#
# uuid.uuid4.__qualname__ is 'uuid4' (5 chars). uuid4 is a top-level module function;
# for top-level functions, __qualname__ == __name__ == 'uuid4'. uuid_extra158 anchors
# uuid4.__name__=='uuid4'; this standalone anchors __qualname__ under uuidmro164.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra164.uuid4_qualname_eq:
  description: "uuid.uuid4.__qualname__.__eq__('uuid4') == True — 'uuid4' (5 chars = 'uuid'=4 + '4'=1; uuid4 is a module-level function generating random UUIDs using os.urandom() for version-4 (purely random) UUIDs per RFC 4122/9562; for top-level module functions, __qualname__ == __name__ == 'uuid4'; 'uuid4'(5) > 'uuid'(4) by 1 char: the function name is 1 char longer than the module name; uuid_extra158 anchors uuid4.__name__=='uuid4' as a table row and standalone; this spec provides the first anchor for uuid4.__qualname__ under uuidmro164; first uuidmro164 standalone for uuid4.__qualname__.__eq__('uuid4')"
  category: identity
  kind: python_call_eq
  function: uuid4.__qualname__.__eq__
  args: ["uuid4"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid1.__qualname__.__eq__('uuid1') — standalone
#
# uuid.uuid1.__qualname__ is 'uuid1' (5 chars). uuid1 generates time-based UUIDs (RFC 4122
# version 1) using the current time and MAC address. For top-level functions,
# __qualname__ == __name__ == 'uuid1'. Novel anchor under uuidmro164.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra164.uuid1_qualname_eq:
  description: "uuid.uuid1.__qualname__.__eq__('uuid1') == True — 'uuid1' (5 chars = 'uuid'=4 + '1'=1; uuid1 generates time-based UUIDs using the current system time and MAC address; version-1 UUIDs encode temporal and spatial uniqueness; for top-level module functions, __qualname__ == __name__ == 'uuid1'; 'uuid1'(5)==uuid4.__qualname__.__len__(5) — tied at 5 chars; uuid_extra158 anchors uuid1.__name__=='uuid1' as a table row; this spec provides the first anchor for uuid1.__qualname__ under uuidmro164; first uuidmro164 standalone for uuid1.__qualname__.__eq__('uuid1')"
  category: identity
  kind: python_call_eq
  function: uuid1.__qualname__.__eq__
  args: ["uuid1"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid3.__qualname__.__eq__('uuid3') — standalone
#
# uuid.uuid3.__qualname__ is 'uuid3' (5 chars). uuid3 generates name-based UUIDs using
# MD5 hashing (RFC 4122 version 3). For top-level functions, __qualname__ == __name__
# == 'uuid3'. Novel anchor under uuidmro164.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra164.uuid3_qualname_eq:
  description: "uuid.uuid3.__qualname__.__eq__('uuid3') == True — 'uuid3' (5 chars = 'uuid'=4 + '3'=1; uuid3 generates name-based UUIDs using MD5 hashing of a namespace UUID + name; version-3 UUIDs are deterministic: the same namespace + name always produces the same UUID; for top-level module functions, __qualname__ == __name__ == 'uuid3'; 'uuid3'(5)==uuid1(5)==uuid4(5) — three-way qualname tie at 5 chars; uuid_extra158 anchors uuid3.__name__=='uuid3' as a table row; this spec provides the first anchor for uuid3.__qualname__ under uuidmro164; first uuidmro164 standalone for uuid3.__qualname__.__eq__('uuid3')"
  category: identity
  kind: python_call_eq
  function: uuid3.__qualname__.__eq__
  args: ["uuid3"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid5.__qualname__.__eq__('uuid5') — standalone
#
# uuid.uuid5.__qualname__ is 'uuid5' (5 chars). uuid5 generates name-based UUIDs using
# SHA-1 hashing (RFC 4122 version 5). For top-level functions, __qualname__ == __name__
# == 'uuid5'. uuid5 is preferred over uuid3 (SHA-1 is stronger than MD5).
# Novel anchor under uuidmro164. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra164.uuid5_qualname_eq:
  description: "uuid.uuid5.__qualname__.__eq__('uuid5') == True — 'uuid5' (5 chars = 'uuid'=4 + '5'=1; uuid5 generates name-based UUIDs using SHA-1 hashing of a namespace UUID + name; version-5 UUIDs are deterministic (same as uuid3) but use SHA-1 instead of MD5 — uuid5 is preferred for new code; for top-level module functions, __qualname__ == __name__ == 'uuid5'; 'uuid5'(5)==uuid1(5)==uuid3(5)==uuid4(5) — four-way qualname tie at 5 chars; all four uuid generator functions have identical qualname lengths; uuid_extra158 anchors uuid5.__name__=='uuid5' as a table row; this spec provides the first anchor for uuid5.__qualname__ under uuidmro164; first uuidmro164 standalone for uuid5.__qualname__.__eq__('uuid5')"
  category: identity
  kind: python_call_eq
  function: uuid5.__qualname__.__eq__
  args: ["uuid5"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__class__.__name__.__eq__('function') — standalone
#
# uuid.uuid4.__class__.__name__ is 'function' (8 chars). uuid4 is a pure Python function
# (defined with def in Lib/uuid.py). Its class is the built-in function type, named
# 'function'. 'function' (8 chars) = 'func'=4 + 'tion'=4. uuid_extra158 anchors
# uuid4.__class__.__name__=='function' as a table row; this standalone anchors via
# __eq__ call syntax under uuidmro164 as a fresh anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra164.uuid4_class_name_function:
  description: "uuid.uuid4.__class__.__name__.__eq__('function') == True — 'function' (8 chars = 'func'=4 + 'tion'=4; uuid4 is a pure Python function defined with def in Lib/uuid.py; its class is the built-in Python function type, named 'function'; 'function'(8) > 'uuid4'(5) > 'uuid'(4) in string length ordering: the class name is longer than the function name which is longer than the module name; this contrasts with C builtin functions whose __class__.__name__ would be 'builtin_function_or_method'(24 chars) — Python functions use the shorter 'function'(8 chars) type name; uuid_extra158 anchors uuid4.__class__.__name__=='function' as a table row; this spec provides a fresh anchor via __eq__ call syntax under uuidmro164; first uuidmro164 standalone for uuid4.__class__.__name__.__eq__('function')"
  category: identity
  kind: python_call_eq
  function: uuid4.__class__.__name__.__eq__
  args: ["function"]
  expected: true
