spec: asyncio_extra291
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Task and Future method qualnames"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c, Lib/asyncio/tasks.py, Lib/asyncio/futures.py"
  notes:
    - "asyncio.Task is implemented in C (_asyncio extension) on CPython; method __qualname__ values are still 'Task.<method>'"
    - "asyncio.Future is also a C extension type; Future.get_loop is defined on Future, so Task.get_loop.__qualname__ == 'Future.get_loop'"
    - "All qualnames verified interactively with Python 3.14.4 on macOS/Darwin 25.4.0"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra291.task_method_qualnames_a:
  description: "asyncio.Task method __qualname__ for cancel, cancelled, done, result, exception, add_done_callback, remove_done_callback"
  kind: python_call_eq
  category: identity
  id_prefix: asyncio291a

  columns: [id, function, args, expected, description]
  rows:
    - [asyncio291a001, asyncio.Task.cancel.__qualname__.__eq__, ["Task.cancel"], true, "Task.cancel qualname"]
    - [asyncio291a002, asyncio.Task.cancelled.__qualname__.__eq__, ["Task.cancelled"], true, "Task.cancelled qualname"]
    - [asyncio291a003, asyncio.Task.done.__qualname__.__eq__, ["Task.done"], true, "Task.done qualname"]
    - [asyncio291a004, asyncio.Task.result.__qualname__.__eq__, ["Task.result"], true, "Task.result qualname"]
    - [asyncio291a005, asyncio.Task.exception.__qualname__.__eq__, ["Task.exception"], true, "Task.exception qualname"]
    - [asyncio291a006, asyncio.Task.add_done_callback.__qualname__.__eq__, ["Task.add_done_callback"], true, "Task.add_done_callback qualname"]
    - [asyncio291a007, asyncio.Task.remove_done_callback.__qualname__.__eq__, ["Task.remove_done_callback"], true, "Task.remove_done_callback qualname"]

table asyncio_extra291.task_future_qualnames_b:
  description: "asyncio.Task method __qualname__ for get_coro, get_name, set_name, get_loop; asyncio.Future method __qualname__ for cancel, done, result, set_result"
  kind: python_call_eq
  category: identity
  id_prefix: asyncio291b

  columns: [id, function, args, expected, description]
  rows:
    - [asyncio291b001, asyncio.Task.get_coro.__qualname__.__eq__, ["Task.get_coro"], true, "Task.get_coro qualname"]
    - [asyncio291b002, asyncio.Task.get_name.__qualname__.__eq__, ["Task.get_name"], true, "Task.get_name qualname"]
    - [asyncio291b003, asyncio.Task.set_name.__qualname__.__eq__, ["Task.set_name"], true, "Task.set_name qualname"]
    - [asyncio291b004, asyncio.Task.get_loop.__qualname__.__eq__, ["Future.get_loop"], true, "Task.get_loop qualname is Future.get_loop (inherited from Future C impl)"]
    - [asyncio291b005, asyncio.Future.cancel.__qualname__.__eq__, ["Future.cancel"], true, "Future.cancel qualname"]
    - [asyncio291b006, asyncio.Future.done.__qualname__.__eq__, ["Future.done"], true, "Future.done qualname"]
    - [asyncio291b007, asyncio.Future.result.__qualname__.__eq__, ["Future.result"], true, "Future.result qualname"]
    - [asyncio291b008, asyncio.Future.set_result.__qualname__.__eq__, ["Future.set_result"], true, "Future.set_result qualname"]

invariant asyncio_extra291.task_cancel_qualname:
  description: "asyncio.Task.cancel.__qualname__ is 'Task.cancel'"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.cancel.__qualname__.__eq__
  args: ["Task.cancel"]
  expected: true

invariant asyncio_extra291.future_result_qualname:
  description: "asyncio.Future.result.__qualname__ is 'Future.result'"
  category: identity
  kind: python_call_eq
  function: asyncio.Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true

invariant asyncio_extra291.task_get_loop_inherits_future:
  description: "Task.get_loop.__qualname__ is 'Future.get_loop' because Task inherits get_loop from Future in C impl"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.get_loop.__qualname__.__eq__
  args: ["Future.get_loop"]
  expected: true
