spec: fnmatch_extra7
version: ">=3.9"
backend: python_module(fnmatch)

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fnmatch.html — Python fnmatch module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fnmatch.py"
  notes:
    - "This spec extends fnmatch.zspec.zsdl and fnmatch_extra through fnmatch_extra6.zspec.zsdl."
    - "fnmatch.zspec.zsdl covers: fnmatch star/question/charclass/empty tables; fnmatchcase case table; filter lists table; translate patterns table."
    - "fnmatch_extra covers: module/__module__ checks for all 4 functions; function kind; filter overlap; translate_returns_str; fnmatchcase bracket table; fnmatch compound table."
    - "fnmatch_extra2 covers: function_names/qualnames tables; translate star_py value/nonempty/contains_dot_escape/not_equal_to_input; fnmatch/fnmatchcase callable checks."
    - "fnmatch_extra3 covers: function_names_direct table; fnmatch.module standalone; translate.returns_str; fnmatch hello.py match; fnmatch HELLO.PY no-match; fnmatchcase uppercase; filter two_py_one_txt."
    - "fnmatch_extra4 covers: fnmatch py_vs_txt no-match; fnmatch mixed_case_py_match; fnmatchcase lowercase_vs_upper_pattern; filter hello_world_foo."
    - "fnmatch_extra5 covers: translate('*')/''; fnmatch txt_extension_match; fnmatch empty_matches_empty; filter empty_list; fnmatchcase exact_lowercase_match; fnmatchcase lower_name_upper_literal_pattern."
    - "fnmatch_extra6 covers: translate('[a-z]'/'*.md'/'file.txt'/'[!abc]'/'?.py'); fnmatch digit_prefix match/no-match; fnmatch compound_extension match/no-match; fnmatch negation [!.]* match/no-match; fnmatchcase prefix_star_match; fnmatchcase extension_case_mismatch; filter md_extension."
    - "Focus: function __module__ attributes as extra7-namespace standalone invariants; fnmatch/fnmatchcase/filter extra7-namespace behavioral anchors."
    - "fnmatch.fnmatch.__module__ == 'fnmatch' — covered in extra/extra3 (table/standalone); extra7-namespace anchor."
    - "fnmatch.fnmatchcase.__module__ == 'fnmatch' — covered in extra; extra7-namespace anchor."
    - "fnmatch.filter.__module__ == 'fnmatch' — covered in extra; extra7-namespace anchor."
    - "fnmatch.translate.__module__ == 'fnmatch' — covered in extra; extra7-namespace anchor."
    - "fnmatch.fnmatch('file.txt', '*.txt') == True — covered in extra5; extra7-namespace anchor."
    - "fnmatch.fnmatch('file.py', '*.txt') == False — new vector: py file against txt pattern."
    - "fnmatch.fnmatch('FILE.TXT', '*.txt') — on POSIX/macOS this is False (case-sensitive); on Windows it would be True. This spec targets POSIX."
    - "fnmatch.fnmatchcase('FILE.TXT', '*.txt') == False — always case-sensitive regardless of OS."
    - "fnmatch.fnmatchcase('file.txt', '*.txt') == True — lowercase exact-case match with wildcard."
    - "fnmatch.filter(['a.txt', 'b.py', 'c.txt'], '*.txt') == ['a.txt', 'c.txt'] — filters mixed list."
    - "fnmatch.filter(['x', 'y'], '*.txt') == [] — no matches yields empty list."
    - "fnmatch.translate('*.txt').__class__.__name__ == 'str' — translate always returns a str."
    - "fnmatch.translate('*.txt') starts with '(?s:' — the Python 3.12+ translate prefix."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ attributes — extra7-namespace standalone invariants
#
# fnmatch_extra covers these in a table; fnmatch_extra3 has a standalone
# fnmatch.__module__ invariant. These are extra7-namespace anchors for all
# four public functions, using the dotted __eq__ chain pattern.
# ---------------------------------------------------------------------------

invariant fnmatch_extra7.fnmatch.module:
  description: "fnmatch.fnmatch.__module__ == 'fnmatch'"
  category: function_identity
  kind: python_call_eq
  function: fnmatch.__module__.__eq__
  args: ["fnmatch"]
  expected: true

invariant fnmatch_extra7.fnmatchcase.module:
  description: "fnmatch.fnmatchcase.__module__ == 'fnmatch'"
  category: function_identity
  kind: python_call_eq
  function: fnmatchcase.__module__.__eq__
  args: ["fnmatch"]
  expected: true

invariant fnmatch_extra7.filter.module:
  description: "fnmatch.filter.__module__ == 'fnmatch'"
  category: function_identity
  kind: python_call_eq
  function: filter.__module__.__eq__
  args: ["fnmatch"]
  expected: true

invariant fnmatch_extra7.translate.module:
  description: "fnmatch.translate.__module__ == 'fnmatch'"
  category: function_identity
  kind: python_call_eq
  function: translate.__module__.__eq__
  args: ["fnmatch"]
  expected: true

# ---------------------------------------------------------------------------
# fnmatch behavioral vectors — extra7-namespace anchors and new vectors
#
# fnmatch('file.txt', '*.txt') covered in extra5; this is the extra7 anchor.
# fnmatch('file.py', '*.txt') is a new vector (py file against txt pattern).
# fnmatch('FILE.TXT', '*.txt') on POSIX/macOS is False (case-sensitive).
# ---------------------------------------------------------------------------

invariant fnmatch_extra7.fnmatch.txt_extension_match:
  description: "fnmatch.fnmatch('file.txt', '*.txt') == True — star matches any prefix"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["file.txt", "*.txt"]
  expected: true

invariant fnmatch_extra7.fnmatch.py_vs_txt_no_match:
  description: "fnmatch.fnmatch('file.py', '*.txt') == False — .py does not match *.txt"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["file.py", "*.txt"]
  expected: false

invariant fnmatch_extra7.fnmatch.uppercase_posix_no_match:
  description: "fnmatch.fnmatch('FILE.TXT', '*.txt') == False — POSIX is case-sensitive"
  category: fnmatch
  kind: python_call_eq
  function: fnmatch
  args: ["FILE.TXT", "*.txt"]
  expected: false

# ---------------------------------------------------------------------------
# fnmatchcase behavioral vectors
#
# fnmatchcase is always case-sensitive regardless of OS.
# fnmatchcase('FILE.TXT', '*.txt') == False — uppercase name vs lowercase pattern.
# fnmatchcase('file.txt', '*.txt') == True — exact case match with wildcard.
# ---------------------------------------------------------------------------

invariant fnmatch_extra7.fnmatchcase.uppercase_name_lowercase_pattern:
  description: "fnmatch.fnmatchcase('FILE.TXT', '*.txt') == False — always case-sensitive"
  category: fnmatchcase
  kind: python_call_eq
  function: fnmatchcase
  args: ["FILE.TXT", "*.txt"]
  expected: false

invariant fnmatch_extra7.fnmatchcase.lowercase_match:
  description: "fnmatch.fnmatchcase('file.txt', '*.txt') == True — case matches exactly"
  category: fnmatchcase
  kind: python_call_eq
  function: fnmatchcase
  args: ["file.txt", "*.txt"]
  expected: true

# ---------------------------------------------------------------------------
# filter behavioral vectors
#
# filter(['a.txt', 'b.py', 'c.txt'], '*.txt') == ['a.txt', 'c.txt'] — mixed list.
# filter(['x', 'y'], '*.txt') == [] — no matches yields empty list.
# ---------------------------------------------------------------------------

invariant fnmatch_extra7.filter.mixed_list_txt:
  description: "fnmatch.filter(['a.txt', 'b.py', 'c.txt'], '*.txt') == ['a.txt', 'c.txt']"
  category: filter
  kind: python_call_eq
  function: filter
  args: [["a.txt", "b.py", "c.txt"], "*.txt"]
  expected: ["a.txt", "c.txt"]

invariant fnmatch_extra7.filter.no_matches_empty:
  description: "fnmatch.filter(['x', 'y'], '*.txt') == [] — no elements match *.txt"
  category: filter
  kind: python_call_eq
  function: filter
  args: [["x", "y"], "*.txt"]
  expected: []

# ---------------------------------------------------------------------------
# translate('*.txt') — return type and prefix
#
# translate always returns a str. The Python 3.12+ output starts with '(?s:'.
# fnmatch_extra2 checks translate returns non-empty str for '*.py'.
# This spec uses '*.txt' as the pattern and adds a prefix check via startswith.
# ---------------------------------------------------------------------------

invariant fnmatch_extra7.translate.txt_returns_str:
  description: "fnmatch.translate('*.txt').__class__.__name__ == 'str'"
  category: translate
  kind: python_call_eq
  function: translate
  args: ["*.txt"]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant fnmatch_extra7.translate.txt_starts_with_prefix:
  description: "fnmatch.translate('*.txt').startswith('(?s:') == True — Python 3.12+ regex prefix"
  category: translate
  kind: python_call_eq
  function: translate
  args: ["*.txt"]
  method: startswith
  method_args: ["(?s:"]
  expected: true
