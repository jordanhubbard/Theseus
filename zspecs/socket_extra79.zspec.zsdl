spec: socket_extra79
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra78.zspec.zsdl — covers socket.socket/__name__/__module__ / socket.error/__name__/__module__ / socket.timeout/__name__ / socket.gaierror/__name__/__module__/__bases__[0]/__name__ / socket.herror/__name__/__module__/__bases__[0]/__name__/__mro__.__len__() (table + invariants)."
    - "socket_extra77.zspec.zsdl — covers gaierror/herror __dict__ key membership / AddressFamily/SocketKind __mro__[0]/__mro__[5] __name__ (table + invariants)."
    - "socket_extra76.zspec.zsdl — covers socket.socket/__dict__.__contains__ / AddressFamily/SocketKind/__class__/__name__/__module__ (table + invariants)."
    - "socket_extra53.zspec.zsdl — covers socket.socket/herror/gaierror/timeout/__dict__/__class__/__qualname__ (table + invariants)."
    - "socket_extra35.zspec.zsdl — covers AddressFamily/SocketKind/__mro__.__len__()==6 (table + invariants)."
    - "socket_extra29.zspec.zsdl — covers socket.socket/__mro__.__len__()==3 / gaierror/__mro__.__len__()==5 (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra78; it does NOT duplicate invariants present in those files."
    - "Wave 246 theme: socket module-level function identity: gethostname/gethostbyname/getaddrinfo/getnameinfo/setdefaulttimeout/getdefaulttimeout/inet_aton/inet_ntoa/htons."
    - "socket.gethostname.__class__.__name__ == 'builtin_function_or_method' — gethostname is a C builtin from _socket. No prior socket spec checks gethostname.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__module__ == '_socket' — gethostname comes from the _socket C extension. No prior socket spec checks gethostname.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__qualname__ == 'gethostname' — gethostname qualname matches its name. No prior socket spec checks gethostname.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__class__.__name__ == 'builtin_function_or_method' — gethostbyname is a C builtin. No prior socket spec checks gethostbyname.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__module__ == '_socket' — gethostbyname comes from _socket. No prior socket spec checks gethostbyname.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__class__.__name__ == 'function' — getaddrinfo is a Python-level wrapper function in the socket module (not a direct C builtin). No prior socket spec checks getaddrinfo.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__module__ == 'socket' — getaddrinfo is defined in the Python socket module. No prior socket spec checks getaddrinfo.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getnameinfo.__class__.__name__ == 'builtin_function_or_method' — getnameinfo is a C builtin. No prior socket spec checks getnameinfo.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getnameinfo.__module__ == '_socket' — getnameinfo comes from _socket. No prior socket spec checks getnameinfo.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__class__.__name__ == 'builtin_function_or_method' — setdefaulttimeout is a C builtin. No prior socket spec checks setdefaulttimeout.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__module__ == '_socket' — setdefaulttimeout comes from _socket. No prior socket spec checks setdefaulttimeout.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getdefaulttimeout.__class__.__name__ == 'builtin_function_or_method' — getdefaulttimeout is a C builtin. No prior socket spec checks getdefaulttimeout.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getdefaulttimeout.__module__ == '_socket' — getdefaulttimeout comes from _socket. No prior socket spec checks getdefaulttimeout.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.inet_aton.__class__.__name__ == 'builtin_function_or_method' — inet_aton is a C builtin. No prior socket spec checks inet_aton.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.inet_ntoa.__class__.__name__ == 'builtin_function_or_method' — inet_ntoa is a C builtin. No prior socket spec checks inet_ntoa.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.htons.__class__.__name__ == 'builtin_function_or_method' — htons is a C builtin. No prior socket spec checks htons.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.gethostname __class__.__name__, __module__, __qualname__
#
# Wave 246 theme: socket.gethostname function identity.
#
# socket.gethostname is a C builtin from _socket. Its __class__.__name__ is
# 'builtin_function_or_method', __module__ is '_socket', __qualname__ is
# 'gethostname'. No prior socket spec checks any of these attributes.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra79.gethostname_identity:
  description: "socket.gethostname/__class__/__name__.__eq__('builtin_function_or_method')==True / gethostname/__module__.__eq__('_socket')==True / gethostname/__qualname__.__eq__('gethostname')==True — gethostname is a C builtin from _socket; no prior socket spec checks gethostname.__class__.__name__/__module__/__qualname__; first identity anchor for socket.gethostname"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra79

  columns: [id, function, args, expected]
  rows:
    - [gethostname_class_builtin,    gethostname.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [gethostname_module_socket,    gethostname.__module__.__eq__,           ["_socket"],                    true]
    - [gethostname_qualname_eq,      gethostname.__qualname__.__eq__,         ["gethostname"],                true]

# ---------------------------------------------------------------------------
# socket.gethostbyname __class__.__name__ / __module__
# socket.getaddrinfo __class__.__name__ / __module__
#
# Wave 246 theme: gethostbyname and getaddrinfo identity.
#
# gethostbyname is a C builtin (__class__.__name__=='builtin_function_or_method',
# __module__=='_socket'). getaddrinfo is a Python-level wrapper function
# (__class__.__name__=='function', __module__=='socket'). No prior socket spec
# checks any of these attributes. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra79.gethostbyname_getaddrinfo_identity:
  description: "socket.gethostbyname/__class__/__name__.__eq__('builtin_function_or_method')==True / gethostbyname/__module__.__eq__('_socket')==True / getaddrinfo/__class__/__name__.__eq__('function')==True / getaddrinfo/__module__.__eq__('socket')==True — gethostbyname is a C builtin; getaddrinfo is a Python wrapper in the socket module; no prior socket spec checks these attributes; first identity anchor for gethostbyname and getaddrinfo"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra79

  columns: [id, function, args, expected]
  rows:
    - [gethostbyname_class_builtin,   gethostbyname.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [gethostbyname_module_socket,   gethostbyname.__module__.__eq__,          ["_socket"],                    true]
    - [getaddrinfo_class_function,    getaddrinfo.__class__.__name__.__eq__,    ["function"],                   true]
    - [getaddrinfo_module_socket,     getaddrinfo.__module__.__eq__,            ["socket"],                     true]

# ---------------------------------------------------------------------------
# socket.getnameinfo and socket.setdefaulttimeout identity
#
# Wave 246 theme: getnameinfo and setdefaulttimeout identity.
#
# getnameinfo is a C builtin from _socket (__class__.__name__=='builtin_function_or_method',
# __module__=='_socket'). setdefaulttimeout likewise. No prior socket spec checks
# any of these attributes. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra79.getnameinfo_setdefaulttimeout_identity:
  description: "socket.getnameinfo/__class__/__name__.__eq__('builtin_function_or_method')==True / getnameinfo/__module__.__eq__('_socket')==True / setdefaulttimeout/__class__/__name__.__eq__('builtin_function_or_method')==True / setdefaulttimeout/__module__.__eq__('_socket')==True — getnameinfo and setdefaulttimeout are C builtins from _socket; no prior socket spec checks these attributes; first identity anchor for getnameinfo and setdefaulttimeout"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra79

  columns: [id, function, args, expected]
  rows:
    - [getnameinfo_class_builtin,        getnameinfo.__class__.__name__.__eq__,       ["builtin_function_or_method"], true]
    - [getnameinfo_module_socket,        getnameinfo.__module__.__eq__,                ["_socket"],                    true]
    - [setdefaulttimeout_class_builtin,  setdefaulttimeout.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [setdefaulttimeout_module_socket,  setdefaulttimeout.__module__.__eq__,          ["_socket"],                    true]

# ---------------------------------------------------------------------------
# socket.getdefaulttimeout / socket.inet_aton / socket.inet_ntoa / socket.htons
#
# Wave 246 theme: getdefaulttimeout, inet_aton, inet_ntoa, htons identity.
#
# All four are C builtins (__class__.__name__=='builtin_function_or_method').
# No prior socket spec checks any of these __class__.__name__ attributes.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra79.getdefaulttimeout_inet_htons_identity:
  description: "socket.getdefaulttimeout/__class__/__name__.__eq__('builtin_function_or_method')==True / getdefaulttimeout/__module__.__eq__('_socket')==True / inet_aton/__class__/__name__.__eq__('builtin_function_or_method')==True / inet_ntoa/__class__/__name__.__eq__('builtin_function_or_method')==True / htons/__class__/__name__.__eq__('builtin_function_or_method')==True — getdefaulttimeout/inet_aton/inet_ntoa/htons are all C builtins from _socket; no prior socket spec checks these __class__.__name__ attributes; first identity anchor for these functions"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra79

  columns: [id, function, args, expected]
  rows:
    - [getdefaulttimeout_class_builtin, getdefaulttimeout.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [getdefaulttimeout_module_socket, getdefaulttimeout.__module__.__eq__,          ["_socket"],                    true]
    - [inet_aton_class_builtin,         inet_aton.__class__.__name__.__eq__,          ["builtin_function_or_method"], true]
    - [inet_ntoa_class_builtin,         inet_ntoa.__class__.__name__.__eq__,          ["builtin_function_or_method"], true]
    - [htons_class_builtin,             htons.__class__.__name__.__eq__,              ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# socket.gethostname.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# gethostname is a C builtin. No prior socket spec checks gethostname.__class__.__name__.
# First __class__.__name__ standalone for socket.gethostname.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra79.gethostname_class_builtin:
  description: "socket.gethostname.__class__.__name__.__eq__('builtin_function_or_method') == True — gethostname is a C builtin from _socket; no prior socket spec checks gethostname.__class__.__name__; first __class__.__name__ standalone for socket.gethostname"
  category: class_attrs
  kind: python_call_eq
  function: gethostname.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__class__.__name__.__eq__('function') — standalone
#
# getaddrinfo is a Python wrapper function (not a C builtin). No prior socket
# spec checks getaddrinfo.__class__.__name__. First __class__.__name__ standalone
# for socket.getaddrinfo. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra79.getaddrinfo_class_function:
  description: "socket.getaddrinfo.__class__.__name__.__eq__('function') == True — getaddrinfo is a Python-level wrapper function in the socket module; no prior socket spec checks getaddrinfo.__class__.__name__; first __class__.__name__ standalone for socket.getaddrinfo"
  category: class_attrs
  kind: python_call_eq
  function: getaddrinfo.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getaddrinfo.__module__.__eq__('socket') — standalone
#
# getaddrinfo is defined in the Python socket module (not _socket). No prior
# socket spec checks getaddrinfo.__module__. First __module__ standalone for
# socket.getaddrinfo. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra79.getaddrinfo_module_socket:
  description: "socket.getaddrinfo.__module__.__eq__('socket') == True — getaddrinfo is a Python wrapper function defined in the socket module; no prior socket spec checks getaddrinfo.__module__; first __module__ standalone for socket.getaddrinfo"
  category: class_attrs
  kind: python_call_eq
  function: getaddrinfo.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostname.__module__.__eq__('_socket') — standalone
#
# gethostname is defined in the _socket C extension. No prior socket spec checks
# gethostname.__module__. First __module__ standalone for socket.gethostname.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra79.gethostname_module_socket:
  description: "socket.gethostname.__module__.__eq__('_socket') == True — gethostname is a C builtin defined in the _socket extension; no prior socket spec checks gethostname.__module__; first __module__ standalone for socket.gethostname"
  category: class_attrs
  kind: python_call_eq
  function: gethostname.__module__.__eq__
  args: ["_socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.inet_aton.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# inet_aton is a C builtin from _socket. No prior socket spec checks
# inet_aton.__class__.__name__. First __class__.__name__ standalone for
# socket.inet_aton. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra79.inet_aton_class_builtin:
  description: "socket.inet_aton.__class__.__name__.__eq__('builtin_function_or_method') == True — inet_aton is a C builtin from _socket; no prior socket spec checks inet_aton.__class__.__name__; first __class__.__name__ standalone for socket.inet_aton"
  category: class_attrs
  kind: python_call_eq
  function: inet_aton.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
