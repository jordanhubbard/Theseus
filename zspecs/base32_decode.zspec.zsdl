spec: base32_decode
version: ">=1.0.0"
backend: node(base32-decode)

docs: https://github.com/LinusU/base32-decode#readme

provenance:
  derived_from:
    - "base32-decode README — https://github.com/LinusU/base32-decode#readme"
    - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings"
    - "Crockford's Base32 — http://www.crockford.com/base32.html"
    - "Test vectors verified with base32-decode via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "base32-decode source"
  notes:
    - "base32-decode supports two variants: 'RFC4648' (the standard) and 'Crockford' (case-insensitive, no I/L/O/U)."
    - "Install: npm install base32-decode"
    - "Module export IS the decoder function. Returns an ArrayBuffer; we read .byteLength and chain through Buffer.from for byte-content checks via Uint8Array views."
  rfcs:
    - "RFC 4648 — The Base16, Base32, and Base64 Data Encodings — https://www.rfc-editor.org/rfc/rfc4648"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Throws on invalid characters; valid input always produces an ArrayBuffer."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# RFC 4648 round-trip: 'JBSWY3DPEBLW64TMMQ' -> 'Hello World' (11 bytes)
table base32_decode.rfc4648_byteLength:
  kind: node_chain_eq
  category: rfc4648_length
  entry: module
  id_prefix: rfc

  columns: [id, entry_args, chain, expected]
  rows:
    - [hello_world,
       ["JBSWY3DPEBLW64TMMQ", "RFC4648"],
       [{get: byteLength}],
       11]

    - [empty,
       ["", "RFC4648"],
       [{get: byteLength}],
       0]

    - [single_char_padded,
       ["MY======", "RFC4648"],
       [{get: byteLength}],
       1]

    - [foo,
       ["MZXW6===", "RFC4648"],
       [{get: byteLength}],
       3,
       {description: "RFC 4648 §10 known vector: 'foo' = MZXW6==="}]

    - [foobar,
       ["MZXW6YTBOI======", "RFC4648"],
       [{get: byteLength}],
       6,
       {description: "RFC 4648 §10 known vector: 'foobar' = MZXW6YTBOI======"}]

# Crockford round-trip: case-insensitive, no padding
table base32_decode.crockford:
  kind: node_chain_eq
  category: crockford
  entry: module
  id_prefix: crock

  columns: [id, entry_args, chain, expected]
  rows:
    - [hello_world_byteLength,
       ["91JPRV3F41BPYWKCCG", "Crockford"],
       [{get: byteLength}],
       11]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:44:59Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
