  rows:
    - ["pp2281010", "pathlib.Path.__mro__.__len__", [], 3]
    - ["pp2281011", "pathlib.Path.__bases__.__len__", [], 1]
    - ["pp2281012", "pathlib.Path.__dict__.__len__", [], 62]
    - ["pp2281013", "pathlib.PosixPath.__mro__.__len__", [], 5]
    - ["pp2281014", "pathlib.PosixPath.__bases__.__len__", [], 2]
    - ["pp2281015", "pathlib.PosixPath.__dict__.__len__", [], 5]
    - ["pp2281016", "pathlib.WindowsPath.__mro__.__len__", [], 5]
