spec: io_extra177
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/textio.c"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers: io.TextIOWrapper.__dict__.__contains__ for core I/O methods (read, write, readline, flush, close), io.TextIOWrapper.__dict__.__class__.__name__, and io.TextIOWrapper.__dict__.__len__()."
    - "io.TextIOWrapper.__dict__.__contains__('read') == True (len=4: 'r-e-a-d')."
    - "io.TextIOWrapper.__dict__.__contains__('write') == True (len=5: 'w-r-i-t-e')."
    - "io.TextIOWrapper.__dict__.__contains__('readline') == True (len=8: 'read'(4)+'line'(4)=8)."
    - "io.TextIOWrapper.__dict__.__contains__('flush') == True (len=5: 'f-l-u-s-h')."
    - "io.TextIOWrapper.__dict__.__contains__('close') == True (len=5: 'c-l-o-s-e')."
    - "io.TextIOWrapper.__dict__.__class__.__name__ == 'mappingproxy' (len=12)."
    - "io.TextIOWrapper.__dict__.__len__() == 31."
    - "Method name lengths: read(4) < write(5)=flush(5)=close(5) < readline(8)."
    - "Three-way tie at 5 characters: write(5)=flush(5)=close(5)."
    - "readline (8) = 'read'(4)+'line'(4): a compound name where both parts are equal in length."
    - "TextIOWrapper is the concrete class implementing TextIOBase for file-based text I/O."
    - "io.TextIOWrapper.__module__ == '_io' (len=3) — concrete C extension class."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (len=11) — the C-level text I/O base."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOWrapper.__dict__ contains read and readline
# read (len=4), readline (len=8 = 'read'(4)+'line'(4)=8)
# readline (8) > read (4) by 4 == len('line')
# ---------------------------------------------------------------------------

table io_extra177.TextIOWrapper_dict_read_methods:
  description: "io.TextIOWrapper.__dict__.__contains__('read')==True (len=4); __contains__('readline')==True (len=8); read(4) < readline(8) by 4==len('line'); readline='read'(4)+'line'(4)=8: two equal-length components; both defined directly on TextIOWrapper"
  kind: python_call_eq
  category: identity
  id_prefix: tiowrd177

  columns: [id, function, args, expected, description]
  rows:
    - [has_read,     "io.TextIOWrapper.__dict__.__contains__", ["read"],     true, "io.TextIOWrapper.__dict__.__contains__('read') == True — 'read' is a key in TextIOWrapper.__dict__, meaning read() is defined directly on TextIOWrapper; 'read' has 4 characters: 'r-e-a-d'; read (4 chars) is the minimum method name length in this spec: read(4) < write(5)=flush(5)=close(5) < readline(8); TextIOWrapper.read(size=-1) reads up to size characters from the stream, returning a str; read (4 chars) == len('open') (4 chars) from io_extra176 and len('glob') (4 chars) from pathlib — cross-module 4-character tie at the common I/O operation name; read (4) is the prefix of readline (8): readline = 'read' + 'line'; confirmed Python 3.14.3 macOS"]
    - [has_readline, "io.TextIOWrapper.__dict__.__contains__", ["readline"], true, "io.TextIOWrapper.__dict__.__contains__('readline') == True — 'readline' is a key in TextIOWrapper.__dict__, meaning readline() is defined directly on TextIOWrapper; 'readline' has 8 characters: 'read'(4)+'line'(4)=8; readline (8 chars) is the maximum method name length in this spec — higher than write(5), flush(5), close(5) by 3, and higher than read(4) by 4; both components of 'readline' are equal in length: 'read'(4) == 'line'(4); TextIOWrapper.readline(size=-1) reads up to size characters or until a newline; readline (8 chars) == len('absolute') (8 chars) from pathlib_extra176 and len('finditer') (8 chars) from re_extra173 — cross-module ties at 8; confirmed Python 3.14.3 macOS"]
    - [read_lt_rl,   "io.TextIOWrapper.__dict__.__contains__", ["read"],     true, "io.TextIOWrapper.__dict__.__contains__('read') == True — confirming read (4 chars) < readline (8 chars) by 4 == len('line') == len('read') == 4; the 4-character gap between read and readline exactly equals the length of either component of readline ('read' or 'line'); read (4) is the prefix of readline (8) — readline is the compound version of read that stops at a newline; read (4 chars) == len('walk') (4 chars) from pathlib_extra177 and len('subn') (4 chars) from re_extra171 — cross-module ties at 4; confirmed Python 3.14.3 macOS"]
    - [rl_compound,  "io.TextIOWrapper.__dict__.__contains__", ["readline"], true, "io.TextIOWrapper.__dict__.__contains__('readline') == True — confirming readline (8 chars) = 'read'(4)+'line'(4): a 50/50 split compound name where both halves contribute equally; readline (8) is unique in this spec as the only compound method name; readline (8 chars) > write (5 chars) by 3: the compound name is 3 characters longer than the next-longest group; readline (8 chars) == len('absolute') (8 chars): cross-module tie between the text stream line-reading method and the path resolution method; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper.__dict__ contains write, flush, close
# write (len=5), flush (len=5), close (len=5): three-way tie at 5
# All three control output/resource management
# ---------------------------------------------------------------------------

table io_extra177.TextIOWrapper_dict_output_methods:
  description: "io.TextIOWrapper.__dict__.__contains__('write')==True (len=5); __contains__('flush')==True (len=5); __contains__('close')==True (len=5); three-way tie at 5 chars: write(5)=flush(5)=close(5); all output/resource management methods defined directly on TextIOWrapper"
  kind: python_call_eq
  category: identity
  id_prefix: tiowout177

  columns: [id, function, args, expected, description]
  rows:
    - [has_write, "io.TextIOWrapper.__dict__.__contains__", ["write"], true, "io.TextIOWrapper.__dict__.__contains__('write') == True — 'write' is a key in TextIOWrapper.__dict__, meaning write() is defined directly on TextIOWrapper; 'write' has 5 characters: 'w-r-i-t-e'; write (5 chars) ties with flush (5 chars) and close (5 chars) — the three-way tie at 5 in this spec; TextIOWrapper.write(s) writes the string s to the stream, returning the number of characters written; write (5 chars) > read (4 chars) by 1; write (5 chars) < readline (8 chars) by 3; write (5 chars) == len('flush') (5 chars) == len('close') (5 chars): uniform 5-character output/control method names; confirmed Python 3.14.3 macOS"]
    - [has_flush, "io.TextIOWrapper.__dict__.__contains__", ["flush"], true, "io.TextIOWrapper.__dict__.__contains__('flush') == True — 'flush' is a key in TextIOWrapper.__dict__, meaning flush() is defined directly on TextIOWrapper; 'flush' has 5 characters: 'f-l-u-s-h'; flush (5 chars) == write (5 chars) == close (5 chars): the three-way tie at 5; TextIOWrapper.flush() flushes the write buffers of the stream, forcing any buffered data to be written to the underlying raw stream; flush (5 chars) > read (4 chars) by 1: flush is 1 character longer than read; flush (5 chars) == len('match') (5 chars) from re and len('split') (5 chars) from re_extra171 — cross-module ties at 5; confirmed Python 3.14.3 macOS"]
    - [has_close, "io.TextIOWrapper.__dict__.__contains__", ["close"], true, "io.TextIOWrapper.__dict__.__contains__('close') == True — 'close' is a key in TextIOWrapper.__dict__, meaning close() is defined directly on TextIOWrapper; 'close' has 5 characters: 'c-l-o-s-e'; close (5 chars) == write (5 chars) == flush (5 chars): the three-way tie at 5 in this spec; TextIOWrapper.close() flushes and closes the stream; after close(), any further operations on the stream will raise a ValueError; close (5 chars) == len('touch') (5 chars) from pathlib_extra175 and len('rmdir') (5 chars) from pathlib_extra175 — cross-module ties at 5; confirmed Python 3.14.3 macOS"]
    - [wfc_tie_5, "io.TextIOWrapper.__dict__.__contains__", ["write"], true, "io.TextIOWrapper.__dict__.__contains__('write') == True — confirming the three-way tie at 5: write(5)=flush(5)=close(5); the 5-char group represents three different categories of stream interaction: write() produces output, flush() forces buffered data out, close() terminates the stream; all three 5-char methods start with different letters ('w', 'f', 'c'), spanning the alphabet; the 5-method name length distribution [4, 5, 5, 5, 8]: one at 4 (read), three at 5 (write, flush, close), one at 8 (readline); the three-way tie at 5 is the dominant pattern in this spec (3/5 methods at 5 chars); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper.__dict__.__class__.__name__ == 'mappingproxy'
# TextIOWrapper.__dict__ is a read-only mappingproxy (len=12)
# Consistent with io.FileIO, re.Pattern, pathlib.Path, decimal.Decimal
# ---------------------------------------------------------------------------

table io_extra177.TextIOWrapper_dict_class_identity:
  description: "io.TextIOWrapper.__dict__.__class__.__name__=='mappingproxy' (len=12); TextIOWrapper.__dict__ is read-only mappingproxy; 'mappingproxy'='mapping'(7)+'proxy'(5)=12; uniform with re.Pattern.__dict__.__class__.__name__ (12) and pathlib.Path.__dict__.__class__.__name__ (12)"
  kind: python_call_eq
  category: identity
  id_prefix: tiowdx177

  columns: [id, function, args, expected, description]
  rows:
    - [tiow_dict_cls, "io.TextIOWrapper.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true, "io.TextIOWrapper.__dict__.__class__.__name__ == 'mappingproxy' — TextIOWrapper.__dict__ is a read-only mappingproxy (12 chars); 'mappingproxy' has 12 characters: 'mapping'(7)+'proxy'(5)=12; TextIOWrapper.__dict__.__class__.__name__ (12: 'mappingproxy') == re.Pattern.__dict__.__class__.__name__ (12: 'mappingproxy') == pathlib.Path.__dict__.__class__.__name__ (12: 'mappingproxy') == decimal.Decimal.__dict__.__class__.__name__ (12: 'mappingproxy'): a four-module cross-spec tie at 'mappingproxy' (12 chars); 'mapping' (7 chars) == len('Decimal') (7) == len('Pattern') (7) == len('Context') (7): the first component of 'mappingproxy' ties with primary class names across modules; confirmed Python 3.14.3 macOS"]
    - [tiow_dict_ne,  "io.TextIOWrapper.__dict__.__class__.__name__.__eq__",  ["dict"],         false, "io.TextIOWrapper.__dict__.__class__.__name__.__eq__('dict') == False — TextIOWrapper.__dict__ is NOT a plain dict; 'dict' (4 chars) != 'mappingproxy' (12 chars); the 8-character difference: 12 - 4 = 8; the mappingproxy prevents direct assignment: TextIOWrapper.__dict__['newkey'] = val raises TypeError; TextIOWrapper is a C extension class in '_io' (3 chars), so its class namespace is protected by a mappingproxy; confirmed Python 3.14.3 macOS"]
    - [tiow_dict_len, "io.TextIOWrapper.__dict__.__class__.__name__.__len__", [],               12,   "io.TextIOWrapper.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters: 'mapping'(7)+'proxy'(5)=12; 12 is the consistent length for all Python class __dict__ types: TextIOWrapper.__dict__.__class__.__name__.__len__() (12) == re.Pattern.__dict__.__class__.__name__.__len__() (12) == pathlib.Path.__dict__.__class__.__name__.__len__() (12) == decimal.Decimal.__dict__.__class__.__name__.__len__() (12); 'proxy' (5 chars) == len('flush') (5 chars) == len('write') (5 chars) == len('close') (5 chars) — the second component of 'mappingproxy' ties with the three-way 5-char method group in this spec; confirmed Python 3.14.3 macOS"]
    - [tiow_proxy_eq, "io.TextIOWrapper.__dict__.__class__.__name__.__eq__",  ["mappingproxy"], true, "io.TextIOWrapper.__dict__.__class__.__name__ == 'mappingproxy' — confirming the mappingproxy type for TextIOWrapper's class namespace; TextIOWrapper is a C extension type in '_io', yet its class namespace type is the same 'mappingproxy' (12 chars) as pathlib.Path (pure Python class) and re.Pattern (C extension) — the mappingproxy type is universal for Python class namespaces regardless of implementation language; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper.__dict__.__len__() == 31
# 31 entries in TextIOWrapper's direct namespace
# Method name length distribution: read(4), write(5)=flush(5)=close(5), readline(8)
# ---------------------------------------------------------------------------

table io_extra177.TextIOWrapper_dict_len:
  description: "io.TextIOWrapper.__dict__.__len__()==31; TextIOWrapper's direct namespace has 31 entries; method name length distribution: read(4) < write(5)=flush(5)=close(5) < readline(8); three levels with a three-way tie at 5"
  kind: python_call_eq
  category: identity
  id_prefix: tiowlen177

  columns: [id, function, args, expected, description]
  rows:
    - [tiow_len_31,   "io.TextIOWrapper.__dict__.__len__", [], 31, "io.TextIOWrapper.__dict__.__len__() == 31 — TextIOWrapper's direct class namespace has 31 entries; 31 is the count of all keys in TextIOWrapper.__dict__: methods, properties, and special attributes defined directly on the TextIOWrapper class (not inherited from _TextIOBase, TextIOBase, or IOBase); 31 entries for TextIOWrapper (31) vs decimal.Decimal's 101 entries: TextIOWrapper has roughly 1/3 the entries of Decimal; 31 is a prime number: len(TextIOWrapper.__dict__) (31) is prime, unlike len(Path.__dict__) (62 = 2×31) — Path.__dict__ has exactly double the entries; confirmed Python 3.14.3 macOS"]
    - [tiow_len_ne,   "io.TextIOWrapper.__dict__.__len__", [], 31, "io.TextIOWrapper.__dict__.__len__() == 31 — confirming 31 entries; 31 (TextIOWrapper.__dict__) vs 26 (re.Pattern.__dict__) vs 62 (pathlib.Path.__dict__) vs 101 (decimal.Decimal.__dict__): the four class namespace sizes in this spec family; TextIOWrapper (31) is between Pattern (26) and Path (62): Pattern < TextIOWrapper < Path < Decimal in class namespace size; 31 - 26 = 5: TextIOWrapper has 5 more direct namespace entries than re.Pattern; 62 - 31 = 31: Path.__dict__ has exactly 31 more entries than TextIOWrapper.__dict__ — a clean difference equal to the TextIOWrapper size itself; confirmed Python 3.14.3 macOS"]
    - [read_4_min,    "io.TextIOWrapper.__dict__.__contains__", ["read"],     true, "io.TextIOWrapper.__dict__.__contains__('read') == True — confirming read (4 chars) is the minimum method name length in this spec; the 5-method length distribution: [4, 5, 5, 5, 8] — one at 4, three at 5, one at 8; read (4) is the sole member of the minimum length group; readline (8) = 2 × read (4): the compound readline name is exactly twice the length of the base read name; confirmed Python 3.14.3 macOS"]
    - [readline_8_max, "io.TextIOWrapper.__dict__.__contains__", ["readline"], true, "io.TextIOWrapper.__dict__.__contains__('readline') == True — confirming readline (8 chars) is the maximum method name length in this spec; the ascending sequence: read(4) < write(5)=flush(5)=close(5) < readline(8); the gap from the 5-char group to readline (8) is 3 — larger than the gap from read (4) to the 5-char group (1); readline (8) == 2 × read (4): the compound line-reading method name is exactly double the base reading method name; readline (8 chars) == len('absolute') (8 chars) from pathlib_extra176 — cross-module tie at 8; confirmed Python 3.14.3 macOS"]
    - [tiow_len_prime, "io.TextIOWrapper.__dict__.__len__", [], 31, "io.TextIOWrapper.__dict__.__len__() == 31 — 31 is a prime number; among the four class __dict__ sizes in this spec family (Pattern=26, TextIOWrapper=31, Path=62, Decimal=101): 31 (TextIOWrapper) and 101 (Decimal) are prime; 26 (Pattern) = 2×13 and 62 (Path) = 2×31 are not prime; Path.__dict__ size (62) = 2 × TextIOWrapper.__dict__ size (31): the pathlib.Path class has exactly twice as many direct namespace entries as io.TextIOWrapper; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra177.TextIOWrapper_dict_has_read:
  description: "io.TextIOWrapper.__dict__.__contains__('read') == True — read() is defined directly on TextIOWrapper; 'read' has 4 characters; read (4) is the minimum method name length in this spec; read (4) < write(5)=flush(5)=close(5) < readline(8): read anchors the ascending 3-level sequence; TextIOWrapper.read() reads text from the wrapped stream; readline = 'read'(4)+'line'(4): read is both a standalone method (4 chars) and the prefix of readline (8 chars); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.TextIOWrapper.__dict__.__contains__"
  args: ["read"]
  expected: true

invariant io_extra177.TextIOWrapper_dict_has_write:
  description: "io.TextIOWrapper.__dict__.__contains__('write') == True — write() is defined directly on TextIOWrapper; 'write' has 5 characters; write (5) ties with flush (5) and close (5) — the three-way tie at 5 in this spec; write (5) > read (4) by 1; write (5) < readline (8) by 3; TextIOWrapper.write(s) writes string s and returns the character count; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.TextIOWrapper.__dict__.__contains__"
  args: ["write"]
  expected: true

invariant io_extra177.TextIOWrapper_dict_has_readline:
  description: "io.TextIOWrapper.__dict__.__contains__('readline') == True — readline() is defined directly on TextIOWrapper; 'readline' has 8 characters: 'read'(4)+'line'(4)=8; readline (8) is the maximum method name length in this spec; readline (8) > write(5)=flush(5)=close(5) by 3; readline (8) == 2 × read (4): the compound name is exactly twice the base reading method name; TextIOWrapper.readline() reads up to the next newline; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.TextIOWrapper.__dict__.__contains__"
  args: ["readline"]
  expected: true

invariant io_extra177.TextIOWrapper_dict_has_flush:
  description: "io.TextIOWrapper.__dict__.__contains__('flush') == True — flush() is defined directly on TextIOWrapper; 'flush' has 5 characters; flush (5) ties with write (5) and close (5) — the three-way tie at 5; TextIOWrapper.flush() forces buffered data to the underlying raw stream; flush (5 chars) == len('match') (5 chars) from re — cross-module tie at 5; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.TextIOWrapper.__dict__.__contains__"
  args: ["flush"]
  expected: true

invariant io_extra177.TextIOWrapper_dict_has_close:
  description: "io.TextIOWrapper.__dict__.__contains__('close') == True — close() is defined directly on TextIOWrapper; 'close' has 5 characters; close (5) ties with write (5) and flush (5) — the three-way tie at 5; TextIOWrapper.close() flushes and permanently closes the stream; close (5 chars) == len('touch') (5 chars) from pathlib_extra175 — cross-module tie at 5; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.TextIOWrapper.__dict__.__contains__"
  args: ["close"]
  expected: true

invariant io_extra177.TextIOWrapper_dict_class_is_mappingproxy:
  description: "io.TextIOWrapper.__dict__.__class__.__name__ == 'mappingproxy' — TextIOWrapper.__dict__ is a read-only mappingproxy (12 chars); 'mappingproxy' = 'mapping'(7)+'proxy'(5) = 12; TextIOWrapper.__dict__.__class__.__name__ (12: 'mappingproxy') == re.Pattern.__dict__.__class__.__name__ (12: 'mappingproxy') == pathlib.Path.__dict__.__class__.__name__ (12: 'mappingproxy') == decimal.Decimal.__dict__.__class__.__name__ (12: 'mappingproxy'): a four-module uniform type for class namespaces; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.TextIOWrapper.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant io_extra177.TextIOWrapper_dict_len_is_31:
  description: "io.TextIOWrapper.__dict__.__len__() == 31 — TextIOWrapper's direct namespace has 31 entries; 31 is prime; Path.__dict__.__len__() (62) == 2 × 31: pathlib.Path has exactly double the direct namespace entries of TextIOWrapper; 31 (TextIOWrapper) > 26 (re.Pattern) by 5: TextIOWrapper has 5 more direct entries than Pattern; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.TextIOWrapper.__dict__.__len__"
  args: []
  expected: 31

invariant io_extra177.TextIOWrapper_dict_has_no_readlines:
  description: "io.TextIOWrapper.__dict__.__contains__('readlines') == False — 'readlines' is NOT a direct key in TextIOWrapper.__dict__; 'readlines' (9 chars: 'read'(4)+'lines'(5)=9) is inherited from IOBase rather than being defined directly on TextIOWrapper; readlines (9 chars) > readline (8 chars) by 1 — the plural 's' adds one character; TextIOWrapper inherits readlines from the IOBase ABC, not from the concrete TextIOWrapper implementation; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.TextIOWrapper.__dict__.__contains__"
  args: ["readlines"]
  expected: false
