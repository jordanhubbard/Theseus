spec: toidentifier
version: ">=1.0.0"
backend: node(toidentifier)

docs: https://github.com/component/toidentifier#readme

provenance:
  derived_from:
    - "toidentifier README — https://github.com/component/toidentifier#readme"
    - "Test vectors verified with toidentifier via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "toidentifier source"
  notes:
    - "Convert a string to a JS identifier — used by http-errors to produce class names like 'NotFoundError'."
    - "Install: npm install toidentifier"
    - "v1 CJS; module export IS the function."
    - "Algorithm: split on whitespace, capitalize each token's first letter, drop non-identifier chars from the rest of each token, then join."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; throws TypeError if input is not a string."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant toidentifier.simple_phrase:
  description: "'Hello World' becomes 'HelloWorld'"
  category: convert
  kind: node_chain_eq
  entry: module
  entry_args: ["Hello World"]
  chain: []
  expected: "HelloWorld"

invariant toidentifier.hyphenated_word:
  description: "'not-found' loses the hyphen and only the first letter is capitalised → 'Notfound'"
  category: convert
  kind: node_chain_eq
  entry: module
  entry_args: ["not-found"]
  chain: []
  expected: "Notfound"

invariant toidentifier.three_word_hyphen:
  description: "'payment-required' becomes 'Paymentrequired' (only first letter capped)"
  category: convert
  kind: node_chain_eq
  entry: module
  entry_args: ["payment-required"]
  chain: []
  expected: "Paymentrequired"

invariant toidentifier.space_separated:
  description: "Each space-separated token is capitalised and concatenated"
  category: convert
  kind: node_chain_eq
  entry: module
  entry_args: ["http error"]
  chain: []
  expected: "HttpError"

invariant toidentifier.mixed_hyphen_and_space:
  description: "'multi-word phrase' → 'MultiwordPhrase' (hyphen removed without case change; space triggers cap)"
  category: convert
  kind: node_chain_eq
  entry: module
  entry_args: ["multi-word phrase"]
  chain: []
  expected: "MultiwordPhrase"

invariant toidentifier.empty_input_empty_output:
  description: "Empty input returns empty string"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [""]
  chain: []
  expected: ""

invariant toidentifier.already_identifier:
  description: "Single-word lowercase input has its first letter capitalised"
  category: convert
  kind: node_chain_eq
  entry: module
  entry_args: ["hello"]
  chain: []
  expected: "Hello"
