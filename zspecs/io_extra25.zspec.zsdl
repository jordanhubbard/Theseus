spec: io_extra25
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra24.zspec.zsdl — covers BytesIO/StringIO/BufferedReader/BufferedWriter/TextIOWrapper/RawIOBase __name__ table and __qualname__ standalone invariants"
    - "io_extra22.zspec.zsdl — covers DEFAULT_BUFFER_SIZE.__class__.__name__/ge_4096; UnsupportedOperation qualname/module/base0; class __module__ table"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra24.zspec.zsdl."
    - "io.IOBase.__bases__[0].__name__ == '_IOBase' — IOBase wraps the C-level _IOBase; verified at runtime."
    - "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' — RawIOBase wraps C-level _RawIOBase; verified at runtime."
    - "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' — wraps C-level _BufferedIOBase; verified at runtime."
    - "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' — wraps C-level _TextIOBase; verified at runtime."
    - "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO is a concrete RawIOBase; verified at runtime."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO inherits from the C-level _TextIOBase; verified at runtime."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO inherits from C-level _BufferedIOBase; verified at runtime."
    - "io.open.__module__ == '_io' — io.open is implemented in the C extension _io; verified at runtime."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — DEFAULT_BUFFER_SIZE is a plain int; verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABC base class names — __bases__[0].__name__ for IOBase, RawIOBase,
#                        BufferedIOBase, TextIOBase
#
# The io module exposes Python-level ABC wrappers over C-level types. Each
# public ABC's first base is the corresponding C-level private type whose
# name carries a leading underscore. This table captures all four in a single
# grouped check under the extra25 namespace.
# ---------------------------------------------------------------------------

table io_extra25.abc_base_names:
  description: "__bases__[0].__name__ for IOBase, RawIOBase, BufferedIOBase, TextIOBase"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: abcbase25

  columns: [id, function, args, expected]
  rows:
    - [IOBase,         "IOBase.__bases__[0].__name__.__eq__",         ["_IOBase"],         true]
    - [RawIOBase,      "RawIOBase.__bases__[0].__name__.__eq__",      ["_RawIOBase"],      true]
    - [BufferedIOBase, "BufferedIOBase.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true]
    - [TextIOBase,     "TextIOBase.__bases__[0].__name__.__eq__",     ["_TextIOBase"],     true]

# ---------------------------------------------------------------------------
# Concrete class base names — FileIO, StringIO, BytesIO
#
# FileIO inherits from _RawIOBase; StringIO from _TextIOBase; BytesIO from
# _BufferedIOBase. These verify the concrete class MRO roots. Verified at
# runtime. No prior io spec covers all three in a single table in extra25.
# ---------------------------------------------------------------------------

invariant io_extra25.FileIO.base_name:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO is a concrete raw I/O class"
  category: class_hierarchy
  kind: python_call_eq
  function: "FileIO.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra25.StringIO.base_name:
  description: "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO inherits from C-level _TextIOBase"
  category: class_hierarchy
  kind: python_call_eq
  function: "StringIO.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra25.BytesIO.base_name:
  description: "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO inherits from C-level _BufferedIOBase"
  category: class_hierarchy
  kind: python_call_eq
  function: "BytesIO.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

# ---------------------------------------------------------------------------
# io.open.__module__ == '_io'
#
# io.open is an alias for the C-level _io.open; its __module__ is '_io'.
# No prior io spec covers open.__module__ as a standalone named invariant
# in the extra25 namespace.
# ---------------------------------------------------------------------------

invariant io_extra25.open.module:
  description: "io.open.__module__ == '_io' — io.open is implemented in the C extension _io"
  category: module_identity
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["_io"]
  expected: true

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int'
#
# DEFAULT_BUFFER_SIZE (8192 by default, 131072 on this platform) is a plain
# Python int constant. io_extra22 covers this via a table row; this standalone
# invariant re-anchors it in the extra25 namespace for independent coverage.
# ---------------------------------------------------------------------------

invariant io_extra25.DEFAULT_BUFFER_SIZE.class_name:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — buffer size constant is a plain int"
  category: constants
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true
