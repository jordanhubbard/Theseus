table asyncio_extra210.sync_dict_lengths:
  description: "asyncio.Semaphore and asyncio.Condition __dict__ length and __init__ membership checks in asynciorepr210 namespace — Semaphore.__dict__.__len__()==10 (the Semaphore class dict has 10 entries on Python 3.14.3: __module__, __firstlineno__, __doc__, __init__, __repr__, locked, acquire, release, _wake_up_next, __static_attributes__); Condition.__dict__.__len__()==11 (Condition has 11 entries: __module__, __firstlineno__, __doc__, __init__, __repr__, wait, wait_for, notify, _notify, notify_all, __static_attributes__); Semaphore has __init__ (direct init); Condition has __init__ (direct init); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: asynciorepr210c

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_dict_len,          "asyncio.Semaphore.__dict__.__len__",          [],            10,   "asyncio.Semaphore.__dict__.__len__() == 10; verified Python 3.14.3"]
    - [condition_dict_len,          "asyncio.Condition.__dict__.__len__",          [],            11,   "asyncio.Condition.__dict__.__len__() == 11; verified Python 3.14.3"]
    - [semaphore_dict_has_init,     "asyncio.Semaphore.__dict__.__contains__",     ["__init__"],  true, "asyncio.Semaphore.__dict__.__contains__('__init__') == True; verified Python 3.14.3"]
    - [condition_dict_has_init,     "asyncio.Condition.__dict__.__contains__",     ["__init__"],  true, "asyncio.Condition.__dict__.__contains__('__init__') == True; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra210
# ---------------------------------------------------------------------------

invariant asyncio_extra210.semaphore_dict_contains_acquire:
  description: "asyncio.Semaphore.__dict__.__contains__('acquire') returns True — asyncio.Semaphore defines acquire() directly in its class body in Lib/asyncio/locks.py; Semaphore.acquire() is a coroutine that decrements the counter when it is greater than zero, or blocks and waits to be notified when zero; 'acquire' is in Semaphore.__dict__ (not inherited from a base class); NEW in extra210; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Semaphore.__dict__.__contains__
  args: ["acquire"]
  expected: true

invariant asyncio_extra210.semaphore_dict_contains_release:
  description: "asyncio.Semaphore.__dict__.__contains__('release') returns True — asyncio.Semaphore defines release() directly in its class body; Semaphore.release() releases the semaphore by incrementing the internal counter by one; if the counter was zero and another coroutine is waiting it is woken; 'release' is in Semaphore.__dict__ (not inherited); NEW in extra210; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Semaphore.__dict__.__contains__
  args: ["release"]
  expected: true

invariant asyncio_extra210.semaphore_dict_contains_locked:
  description: "asyncio.Semaphore.__dict__.__contains__('locked') returns True — asyncio.Semaphore defines locked() directly in its class body; Semaphore.locked() returns True if the semaphore cannot be acquired immediately (internal counter is zero); unlike Lock.locked() which checks a boolean, Semaphore.locked() checks counter == 0; 'locked' is in Semaphore.__dict__ (not inherited); NEW in extra210; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Semaphore.__dict__.__contains__
  args: ["locked"]
  expected: true

invariant asyncio_extra210.condition_dict_contains_wait:
  description: "asyncio.Condition.__dict__.__contains__('wait') returns True — asyncio.Condition defines wait() directly in its class body in asyncio.locks; Condition.wait() is a coroutine that releases the underlying lock and blocks until awakened by notify() or notify_all(); upon waking it reacquires the lock; 'wait' is in Condition.__dict__ (not inherited); NEW in extra210; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Condition.__dict__.__contains__
  args: ["wait"]
  expected: true

invariant asyncio_extra210.condition_dict_contains_notify:
  description: "asyncio.Condition.__dict__.__contains__('notify') returns True — asyncio.Condition defines notify() directly in its class body; Condition.notify(n=1) wakes up n coroutines waiting on this condition; the lock must be held when notify() is called; 'notify' is in Condition.__dict__ (not inherited); NEW in extra210; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Condition.__dict__.__contains__
  args: ["notify"]
  expected: true

invariant asyncio_extra210.condition_dict_contains_notify_all:
  description: "asyncio.Condition.__dict__.__contains__('notify_all') returns True — asyncio.Condition defines notify_all() directly in its class body; Condition.notify_all() wakes up all coroutines waiting on this condition; equivalent to notify(n=len(waiters)); 'notify_all' is in Condition.__dict__ (not inherited); NEW in extra210; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Condition.__dict__.__contains__
  args: ["notify_all"]
  expected: true

invariant asyncio_extra210.semaphore_dict_len_ten:
  description: "asyncio.Semaphore.__dict__.__len__() returns 10 — asyncio.Semaphore's class dict has 10 entries on Python 3.14.3: __module__, __firstlineno__, __doc__, __init__, __repr__, locked, acquire, release, _wake_up_next, __static_attributes__; this is the full set of names defined directly on the class; NEW in extra210; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Semaphore.__dict__.__len__
  args: []
  expected: 10

invariant asyncio_extra210.condition_dict_len_eleven:
  description: "asyncio.Condition.__dict__.__len__() returns 11 — asyncio.Condition's class dict has 11 entries on Python 3.14.3: __module__, __firstlineno__, __doc__, __init__, __repr__, wait, wait_for, notify, _notify, notify_all, __static_attributes__; this is the full set of names defined directly on the class; NEW in extra210; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Condition.__dict__.__len__
  args: []
  expected: 11
