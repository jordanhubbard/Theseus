spec: th3286
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 666 (th3286): __iadd__, __isub__, __imul__ dict-presence checks for threading types."
    - "Theme: __iadd__/__isub__/__imul__ in-place arithmetic dict-presence."
    - "In-place augmented assignment operators (+=, -=, *=) fall back to __add__/__sub__/__mul__ if not defined."
    - "All values False — callable/iterator/inspection/synchronization types have no in-place arithmetic operators."
    - "None of the threading types define __iadd__, __isub__, or __imul__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3286.iadd:
  description: "threading types __iadd__ dict-presence checks; wave 666"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3286
  columns: [id, function, args, expected]
  rows:
    - ["th3286001", operator.contains, [threading.Thread.__dict__,           "__iadd__"], false]
    - ["th3286002", operator.contains, [threading.Event.__dict__,            "__iadd__"], false]
    - ["th3286003", operator.contains, [threading.Condition.__dict__,        "__iadd__"], false]
    - ["th3286004", operator.contains, [threading.Semaphore.__dict__,        "__iadd__"], false]
    - ["th3286005", operator.contains, [threading.BoundedSemaphore.__dict__, "__iadd__"], false]
    - ["th3286006", operator.contains, [threading.Timer.__dict__,            "__iadd__"], false]
    - ["th3286007", operator.contains, [threading.Barrier.__dict__,          "__iadd__"], false]
    - ["th3286008", operator.contains, [threading.local.__dict__,            "__iadd__"], false]
    - ["th3286009", operator.contains, [type(threading.Lock()).__dict__,     "__iadd__"], false]
    - ["th3286010", operator.contains, [type(threading.RLock()).__dict__,    "__iadd__"], false]

