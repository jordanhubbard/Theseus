table socket_extra1561.exception_numeric_protocol:
  description: "socket.error and socket.timeout define no numeric conversion protocol methods in their own __dict__ — sk1561ex namespace. socket.error is an alias for builtins.OSError; socket.timeout is an alias for builtins.TimeoutError; exception classes are not numeric types; none of the numeric dunders are present in their __dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: numeric_protocol_presence
  id_prefix: sk1561ex

  columns: [id, function, args, expected, description]
  rows:
    - [sk1561ex001, socket.error.__dict__.__contains__,   ["__bool__"],    false, "socket.error.__dict__.__contains__('__bool__')==False — socket.error (OSError alias) defines no __bool__ in its own __dict__; verified with Python 3.14.3"]
    - [sk1561ex002, socket.error.__dict__.__contains__,   ["__int__"],     false, "socket.error.__dict__.__contains__('__int__')==False — socket.error defines no __int__ in its own __dict__; verified with Python 3.14.3"]
    - [sk1561ex003, socket.error.__dict__.__contains__,   ["__float__"],   false, "socket.error.__dict__.__contains__('__float__')==False — socket.error defines no __float__ in its own __dict__; verified with Python 3.14.3"]
    - [sk1561ex004, socket.error.__dict__.__contains__,   ["__index__"],   false, "socket.error.__dict__.__contains__('__index__')==False — socket.error defines no __index__ in its own __dict__; verified with Python 3.14.3"]
    - [sk1561ex005, socket.timeout.__dict__.__contains__, ["__bool__"],    false, "socket.timeout.__dict__.__contains__('__bool__')==False — socket.timeout (TimeoutError alias) defines no __bool__ in its own __dict__; verified with Python 3.14.3"]
    - [sk1561ex006, socket.timeout.__dict__.__contains__, ["__int__"],     false, "socket.timeout.__dict__.__contains__('__int__')==False — socket.timeout defines no __int__ in its own __dict__; verified with Python 3.14.3"]
    - [sk1561ex007, socket.timeout.__dict__.__contains__, ["__float__"],   false, "socket.timeout.__dict__.__contains__('__float__')==False — socket.timeout defines no __float__ in its own __dict__; verified with Python 3.14.3"]
    - [sk1561ex008, socket.timeout.__dict__.__contains__, ["__index__"],   false, "socket.timeout.__dict__.__contains__('__index__')==False — socket.timeout defines no __index__ in its own __dict__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: socket.socket — actual interface dunder presence (positive checks)
#
# Confirms the dunders socket.socket DOES define in its own __dict__:
# __init__, __enter__, __exit__, __repr__, __getstate__, __slots__
# ---------------------------------------------------------------------------

table socket_extra1561.socket_interface_presence:
  description: "socket.socket defines its context manager and lifecycle dunders in its own __dict__ — sk1561si namespace. These positive checks confirm socket.socket owns: __init__ (initializes the socket fd with family/type/proto), __enter__ (context manager entry, returns self), __exit__ (context manager exit, calls close()), __repr__ (human-readable socket description), __getstate__ (pickling support), __slots__ (memory efficiency); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk1561si

  columns: [id, function, args, expected, description]
  rows:
    - [sk1561si001, socket.socket.__dict__.__contains__, ["__init__"],     true,  "socket.socket.__dict__.__contains__('__init__')==True — socket.__init__ IS defined; initializes the socket with family, type, proto, and optional fileno; verified with Python 3.14.3"]
    - [sk1561si002, socket.socket.__dict__.__contains__, ["__enter__"],    true,  "socket.socket.__dict__.__contains__('__enter__')==True — socket.__enter__ IS defined; enables use as a context manager returning self; verified with Python 3.14.3"]
    - [sk1561si003, socket.socket.__dict__.__contains__, ["__exit__"],     true,  "socket.socket.__dict__.__contains__('__exit__')==True — socket.__exit__ IS defined; calls self.close() on context manager exit; verified with Python 3.14.3"]
    - [sk1561si004, socket.socket.__dict__.__contains__, ["__repr__"],     true,  "socket.socket.__dict__.__contains__('__repr__')==True — socket.__repr__ IS defined; produces human-readable socket description including fd, family, type, laddr, raddr; verified with Python 3.14.3"]
    - [sk1561si005, socket.socket.__dict__.__contains__, ["__getstate__"], true,  "socket.socket.__dict__.__contains__('__getstate__')==True — socket.__getstate__ IS defined; supports pickling protocol; verified with Python 3.14.3"]
    - [sk1561si006, socket.socket.__dict__.__contains__, ["__slots__"],    true,  "socket.socket.__dict__.__contains__('__slots__')==True — socket.__slots__ IS defined; socket.socket uses __slots__ for memory efficiency; verified with Python 3.14.3"]
    - [sk1561si007, socket.socket.__dict__.__contains__, ["__add__"],      false, "socket.socket.__dict__.__contains__('__add__')==False — socket.socket has no arithmetic operators; verified with Python 3.14.3"]
    - [sk1561si008, socket.socket.__dict__.__contains__, ["__mul__"],      false, "socket.socket.__dict__.__contains__('__mul__')==False — socket.socket has no multiplication operator; verified with Python 3.14.3"]
