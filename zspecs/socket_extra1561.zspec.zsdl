spec: socket_extra1561
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "POSIX.1-2017 — socket() API specification"
  notes:
    - "Wave 551 (_extra1561): numeric type conversion protocol dict-presence checks for socket classes."
    - "socket.socket is the main socket class; it defines __enter__, __exit__, __repr__, __getstate__ in its own __dict__ — but no numeric protocol methods."
    - "socket.error is an alias for OSError (socket.error is builtins.OSError); its __dict__ is minimal and contains no numeric protocol dunders."
    - "socket.timeout is an alias for TimeoutError (socket.timeout is builtins.TimeoutError); its __dict__ also contains no numeric protocol dunders."
    - "Verified: socket.error.__module__ == 'builtins'; socket.timeout.__module__ == 'builtins'; verified with Python 3.14.3."
    - "Verified: socket.socket.__dict__ dunder keys: __module__, __firstlineno__, __doc__, __slots__, __init__, __enter__, __exit__, __repr__, __getstate__, __static_attributes__, __weakref__; no numeric protocol methods."
    - "None of __bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, __round__ appear in socket.socket.__dict__, socket.error.__dict__, or socket.timeout.__dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.socket — numeric conversion protocol dict-presence (all False)
#
# socket.socket.__dict__.__contains__('__bool__')    == False
# socket.socket.__dict__.__contains__('__int__')     == False
# socket.socket.__dict__.__contains__('__float__')   == False
# socket.socket.__dict__.__contains__('__complex__') == False
# socket.socket.__dict__.__contains__('__index__')   == False
# socket.socket.__dict__.__contains__('__trunc__')   == False
# socket.socket.__dict__.__contains__('__floor__')   == False
# socket.socket.__dict__.__contains__('__ceil__')    == False
# socket.socket.__dict__.__contains__('__round__')   == False
# ---------------------------------------------------------------------------

table socket_extra1561.socket_numeric_protocol:
  description: "socket.socket defines no numeric conversion protocol methods in its own __dict__ — sk1561sn namespace. socket.socket is a network endpoint abstraction; it wraps a file descriptor and provides send/recv/bind/connect/accept operations; it is a resource handle, not a numeric type; none of the numeric protocol dunders (__bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, __round__) appear in socket.socket.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: numeric_protocol_presence
  id_prefix: sk1561sn

  columns: [id, function, args, expected, description]
  rows:
    - [sk1561sn001, socket.socket.__dict__.__contains__, ["__bool__"],    false, "socket.socket.__dict__.__contains__('__bool__')==False — socket.socket defines no __bool__ in its own __dict__; verified with Python 3.14.3"]
    - [sk1561sn002, socket.socket.__dict__.__contains__, ["__int__"],     false, "socket.socket.__dict__.__contains__('__int__')==False — socket.socket defines no __int__; cannot be converted to int; verified with Python 3.14.3"]
    - [sk1561sn003, socket.socket.__dict__.__contains__, ["__float__"],   false, "socket.socket.__dict__.__contains__('__float__')==False — socket.socket defines no __float__; verified with Python 3.14.3"]
    - [sk1561sn004, socket.socket.__dict__.__contains__, ["__complex__"], false, "socket.socket.__dict__.__contains__('__complex__')==False — socket.socket defines no __complex__; verified with Python 3.14.3"]
    - [sk1561sn005, socket.socket.__dict__.__contains__, ["__index__"],   false, "socket.socket.__dict__.__contains__('__index__')==False — socket.socket cannot be used as a sequence index; no __index__ in its __dict__; verified with Python 3.14.3"]
    - [sk1561sn006, socket.socket.__dict__.__contains__, ["__trunc__"],   false, "socket.socket.__dict__.__contains__('__trunc__')==False — math.trunc() protocol not supported by socket.socket; verified with Python 3.14.3"]
    - [sk1561sn007, socket.socket.__dict__.__contains__, ["__floor__"],   false, "socket.socket.__dict__.__contains__('__floor__')==False — math.floor() protocol not supported by socket.socket; verified with Python 3.14.3"]
    - [sk1561sn008, socket.socket.__dict__.__contains__, ["__ceil__"],    false, "socket.socket.__dict__.__contains__('__ceil__')==False — math.ceil() protocol not supported by socket.socket; verified with Python 3.14.3"]
    - [sk1561sn009, socket.socket.__dict__.__contains__, ["__round__"],   false, "socket.socket.__dict__.__contains__('__round__')==False — round() protocol not supported by socket.socket; verified with Python 3.14.3"]

