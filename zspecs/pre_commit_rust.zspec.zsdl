spec: pre_commit_rust
version: ">=3.9"
backend: rust_module(pre_commit_rust)

docs: https://pre-commit.com/

provenance:
  derived_from:
    - "https://pre-commit.com/ — pre-commit hooks"
  notes:
    - "pre-commit manages and maintains multi-language pre-commit hooks."
    - "pre_commit.main is importable."
    - "pre_commit.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pre_commit_rust.has_main_module:
  description: "pre_commit.main is importable"
  category: presence
  kind: python_call_eq
  function: pre_commit_has_main_module
  args: []
  expected: true

invariant pre_commit_rust.has_commands:
  description: "pre_commit.commands is importable"
  category: presence
  kind: python_call_eq
  function: pre_commit_has_commands
  args: []
  expected: true

invariant pre_commit_rust.version_nonempty:
  description: "pre_commit.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pre_commit_version_nonempty
  args: []
  expected: true

