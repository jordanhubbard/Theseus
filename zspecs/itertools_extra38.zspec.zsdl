spec: itertools_extra38
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra37.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types; __qualname__.__len__() for groupby/islice/zip_longest/accumulate/chain.from_iterable/combinations_with_replacement; __mro__.__len__()==2 for all major types; __bases__[0].__name__.__len__()==6 ('object') for all major types; __dict__.__class__.__name__.__len__()==12 ('mappingproxy') for all major types; chain.from_iterable.__name__.__len__()==13; chain/__doc__(190)/count/__doc__(205)/repeat/__doc__(154)/cycle/__doc__(95)/dropwhile/__doc__(126)/takewhile/__doc__(101)/compress/__doc__(164)/accumulate/__doc__(69)/filterfalse/__doc__(120)/starmap/__doc__(126)/pairwise/__doc__(112)/combinations_with_replacement/__doc__(234)/permutations/__doc__(140)/combinations/__doc__(134)/product/__doc__(681)/islice/__doc__(453)/zip_longest/__doc__(427)/groupby/__doc__(323)."
    - "This spec covers: count.__qualname__.__len__() (5 — 'count'); cycle.__qualname__.__len__() (5 — 'cycle', same as count); repeat.__qualname__.__len__() (6 — 'repeat'); starmap.__qualname__.__len__() (7 — 'starmap'); compress.__qualname__.__len__() (8 — 'compress'); dropwhile.__qualname__.__len__() (9 — 'dropwhile'); takewhile.__qualname__.__len__() (9 — 'takewhile', same as dropwhile); filterfalse.__qualname__.__len__() (11 — 'filterfalse'); list(repeat(7, 3)) == [7, 7, 7]; next(dropwhile(lambda x: x < 5, [3,4,5,6])) == 5."
    - "Key findings: For all itertools C-level types, __qualname__ equals __name__ — there is no enclosing class scope. count and cycle share __qualname__ length 5. repeat has length 6. starmap has length 7 — one more than compress(8)? No: starmap(7) < compress(8). dropwhile and takewhile share length 9. filterfalse is the longest at 11. These __qualname__ values are identical to the corresponding __name__ lengths recorded in earlier specs, confirming that top-level C types have __qualname__ == __name__. No prior itertools spec records __qualname__.__len__() for count/cycle/repeat/starmap/compress/dropwhile/takewhile/filterfalse in the extra38 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Infinite-iterator and mapping C-type __qualname__.__len__() — extra38 namespace
#
# itertools.count.__qualname__ is 'count' (5 chars). itertools.cycle.__qualname__
# is 'cycle' (5 chars) — the same length as count, because both are 5-letter
# words. itertools.repeat.__qualname__ is 'repeat' (6 chars). itertools.starmap.
# __qualname__ is 'starmap' (7 chars). For all itertools C-level types,
# __qualname__ == __name__ (no enclosing class). These four form a natural group:
# they are the infinite or mapping types (count/cycle/repeat are infinite; starmap
# applies a function to argument tuples). No prior itertools spec records
# __qualname__.__len__() for count, cycle, repeat, or starmap. These four values
# are recorded together for the first time in the extra38 namespace.
# ---------------------------------------------------------------------------

table itertools_extra38.infinite_and_mapping_qualname_lengths:
  description: "itertools infinite-iterator and mapping C-type __qualname__.__len__(): count(5), cycle(5), repeat(6), starmap(7)"
  kind: python_call_eq
  category: string_properties
  id_prefix: infinitemapqlen38

  columns: [id, function, args, expected, description]
  rows:
    - [count,
       count.__qualname__.__len__,
       [],
       5,
       "len(itertools.count.__qualname__) == 5 — 'count' (__qualname__ == __name__ for top-level C types; same length as cycle)"]
    - [cycle,
       cycle.__qualname__.__len__,
       [],
       5,
       "len(itertools.cycle.__qualname__) == 5 — 'cycle' (__qualname__ == __name__; same length as count)"]
    - [repeat,
       repeat.__qualname__.__len__,
       [],
       6,
       "len(itertools.repeat.__qualname__) == 6 — 'repeat' (__qualname__ == __name__; one char longer than count/cycle)"]
    - [starmap,
       starmap.__qualname__.__len__,
       [],
       7,
       "len(itertools.starmap.__qualname__) == 7 — 'starmap' (__qualname__ == __name__; applies function to argument tuples)"]

# ---------------------------------------------------------------------------
# Filtering C-type __qualname__.__len__() — extra38 namespace
#
# itertools.compress.__qualname__ is 'compress' (8 chars). itertools.dropwhile.
# __qualname__ is 'dropwhile' (9 chars). itertools.takewhile.__qualname__ is
# 'takewhile' (9 chars) — the same length as dropwhile, because both names are
# 9 characters. itertools.filterfalse.__qualname__ is 'filterfalse' (11 chars)
# — the longest __qualname__ among all filtering types. For all C-level types,
# __qualname__ == __name__. No prior itertools spec records __qualname__.__len__()
# for compress, dropwhile, takewhile, or filterfalse. These four values are
# recorded together for the first time in the extra38 namespace.
# ---------------------------------------------------------------------------

table itertools_extra38.filtering_type_qualname_lengths:
  description: "itertools filtering C-type __qualname__.__len__(): compress(8), dropwhile(9), takewhile(9), filterfalse(11)"
  kind: python_call_eq
  category: string_properties
  id_prefix: filterqlen38

  columns: [id, function, args, expected, description]
  rows:
    - [compress,
       compress.__qualname__.__len__,
       [],
       8,
       "len(itertools.compress.__qualname__) == 8 — 'compress' (__qualname__ == __name__; selects elements based on a boolean selector iterable)"]
    - [dropwhile,
       dropwhile.__qualname__.__len__,
       [],
       9,
       "len(itertools.dropwhile.__qualname__) == 9 — 'dropwhile' (__qualname__ == __name__; skips elements while predicate is true, then yields all)"]
    - [takewhile,
       takewhile.__qualname__.__len__,
       [],
       9,
       "len(itertools.takewhile.__qualname__) == 9 — 'takewhile' (__qualname__ == __name__; same length as dropwhile; yields while predicate is true then stops)"]
    - [filterfalse,
       filterfalse.__qualname__.__len__,
       [],
       11,
       "len(itertools.filterfalse.__qualname__) == 11 — 'filterfalse' (__qualname__ == __name__; longest filtering-type qualname; complement of builtin filter)"]

# ---------------------------------------------------------------------------
# itertools.repeat behavioral — list(repeat(7, 3)) == [7, 7, 7]
#
# itertools.repeat(7, 3) produces an iterator that yields 7 exactly 3 times.
# Converting to a list gives [7, 7, 7]. This is the fundamental bounded-repeat
# behavior: the second argument is a count limit. repeat without a count limit
# is infinite; with a count it is finite and materializable. No prior itertools
# spec records list(repeat(7, 3)) == [7, 7, 7] in the extra38 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra38.repeat_bounded_list:
  description: "list(itertools.repeat(7, 3)) == [7, 7, 7] — repeat(value, count) yields value exactly count times"
  category: behavioral
  kind: python_call_eq
  function: repeat
  args: [7, 3]
  method: __iter__
  method_args: []
  expected: [7, 7, 7]
