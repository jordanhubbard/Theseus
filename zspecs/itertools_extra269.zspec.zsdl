spec: itertools_extra269
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools.chain.from_iterable.__name__ == 'from_iterable' (len=13); __qualname__ == 'chain.from_iterable' (len=19); __class__.__name__ == 'builtin_function_or_method' (len=26)."
    - "chain.from_iterable is a classmethod descriptor on chain; its __qualname__ includes the owning class prefix 'chain.' so qualname(19) > name(13)."
    - "itertools.chain.__name__ == 'chain' (len=5); __module__ == 'itertools'; __class__.__name__ == 'type' — chain is a C-level type."
    - "itertools.accumulate.__name__ == 'accumulate' (len=10); __module__ == 'itertools'; __class__.__name__ == 'type'."
    - "itertools.islice([], -1) raises ValueError — stop argument must be None or integer >= 0."
    - "itertools.combinations([1,2], 5) returns [] (empty list) — r > n yields empty sequence, no error raised."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.chain.from_iterable and chain identity
#
# chain.from_iterable.__name__ (13) < chain.from_iterable.__qualname__ (19).
# chain.from_iterable is a builtin_function_or_method (C level).
# chain.__class__.__name__ == 'type'; accumulate.__class__.__name__ == 'type'.
# Both chain and accumulate have __module__ == 'itertools'.
# ---------------------------------------------------------------------------

table itertools_extra269.chain_and_accumulate_identity:
  description: "itertools.chain(5) and accumulate(10) identity, and chain.from_iterable(13) as classmethod descriptor — from_iterable qualname(19) longer than name(13); chain and accumulate both type in itertools; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex269a

  columns: [id, function, args, expected, description]
  rows:
    - [fi_name_eq,          chain.from_iterable.__name__.__eq__,         ["from_iterable"],              true, "itertools.chain.from_iterable.__name__ == 'from_iterable'; verified with Python 3.14.3"]
    - [fi_name_len,         chain.from_iterable.__name__.__len__,        [],                             13,   "itertools.chain.from_iterable.__name__.__len__() == 13; verified with Python 3.14.3"]
    - [fi_qn_eq,            chain.from_iterable.__qualname__.__eq__,     ["chain.from_iterable"],        true, "itertools.chain.from_iterable.__qualname__ == 'chain.from_iterable' — includes owning class prefix; verified with Python 3.14.3"]
    - [fi_qn_len,           chain.from_iterable.__qualname__.__len__,    [],                             19,   "itertools.chain.from_iterable.__qualname__.__len__() == 19 — longer than name(13); verified with Python 3.14.3"]
    - [fi_cls_eq,           chain.from_iterable.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"]
    - [fi_cls_len,          chain.from_iterable.__class__.__name__.__len__, [],                          26,   "itertools.chain.from_iterable.__class__.__name__.__len__() == 26; verified with Python 3.14.3"]
    - [ch_name_eq,          chain.__name__.__eq__,                       ["chain"],                      true, "itertools.chain.__name__ == 'chain' (len=5); verified with Python 3.14.3"]
    - [ch_name_len,         chain.__name__.__len__,                      [],                             5,    "itertools.chain.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [ch_mod_eq,           chain.__module__.__eq__,                     ["itertools"],                  true, "itertools.chain.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [ch_cls_eq,           chain.__class__.__name__.__eq__,             ["type"],                       true, "itertools.chain.__class__.__name__ == 'type' — chain is a C-level type; verified with Python 3.14.3"]
    - [ac_name_eq,          accumulate.__name__.__eq__,                  ["accumulate"],                 true, "itertools.accumulate.__name__ == 'accumulate' (len=10); verified with Python 3.14.3"]
    - [ac_name_len,         accumulate.__name__.__len__,                 [],                             10,   "itertools.accumulate.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [ac_mod_eq,           accumulate.__module__.__eq__,                ["itertools"],                  true, "itertools.accumulate.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [ac_cls_eq,           accumulate.__class__.__name__.__eq__,        ["type"],                       true, "itertools.accumulate.__class__.__name__ == 'type' — accumulate is a C-level type; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra269
# ---------------------------------------------------------------------------

invariant itertools_extra269.chain_from_iterable_name_is_from_iterable:
  description: "itertools.chain.from_iterable.__name__ == 'from_iterable' (len=13) — shorter than its qualname 'chain.from_iterable' (len=19)"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__name__.__eq__
  args: ["from_iterable"]
  expected: true

invariant itertools_extra269.chain_from_iterable_qualname_len:
  description: "itertools.chain.from_iterable.__qualname__.__len__() == 19 — qualname 'chain.from_iterable' (19) is longer than name 'from_iterable' (13) by the 'chain.' prefix"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__len__
  args: []
  expected: 19

invariant itertools_extra269.chain_from_iterable_is_builtin:
  description: "itertools.chain.from_iterable.__class__.__name__ == 'builtin_function_or_method' — from_iterable is a C-level builtin classmethod descriptor on chain"
  category: identity
  kind: python_call_eq
  function: chain.from_iterable.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra269.accumulate_name_len_is_ten:
  description: "itertools.accumulate.__name__.__len__() == 10 — 'accumulate' has 10 characters; longer than chain(5) shorter than from_iterable(13)"
  category: identity
  kind: python_call_eq
  function: accumulate.__name__.__len__
  args: []
  expected: 10

invariant itertools_extra269.islice_negative_stop_raises_valueerror:
  description: "itertools.islice([], -1) raises ValueError — stop argument for islice() must be None or an integer >= 0; negative stop raises ValueError immediately"
  category: errors
  kind: python_call_raises
  function: islice
  args: [[], -1]
  raises: ValueError
