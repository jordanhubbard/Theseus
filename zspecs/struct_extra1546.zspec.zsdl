spec: struct_extra1546
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra1531.zspec.zsdl — covers comparison operator absence on Struct and struct.error."
    - "struct_extra1516.zspec.zsdl — covers arithmetic operator absence (__add__ through __pow__) on Struct."
    - "struct_extra1501.zspec.zsdl — covers bitwise operator absence on Struct and struct.error (earlier wave)."
    - "struct_extra991.zspec.zsdl — covers method __qualname__ and descriptor class names."
  notes:
    - "This spec is wave 550 / suffix _extra1546. Theme: bitwise operator dict-presence checks on struct.Struct and struct.error."
    - "struct.Struct is a compiled binary layout descriptor: it holds a format string and the derived byte size. It has no integer semantics — applying bitwise operators to a Struct instance is meaningless."
    - "Bitwise operators (__and__, __or__, __xor__, __invert__, __lshift__, __rshift__) are integer-domain operations. A Struct object is not an integer, so none of these dunders appear in Struct.__dict__."
    - "Reflected bitwise variants (__rand__, __ror__, __rxor__) are also absent — Struct cannot serve as the right-hand operand in a bitwise expression."
    - "struct.error is a subclass of Exception. Exception types carry error information, not numeric state. No bitwise dunders appear in struct.error.__dict__."
    - "Verified: '__and__' in struct.Struct.__dict__ == False."
    - "Verified: '__or__' in struct.Struct.__dict__ == False."
    - "Verified: '__xor__' in struct.Struct.__dict__ == False."
    - "Verified: '__invert__' in struct.Struct.__dict__ == False."
    - "Verified: '__lshift__' in struct.Struct.__dict__ == False."
    - "Verified: '__rshift__' in struct.Struct.__dict__ == False."
    - "Verified: '__rand__' in struct.Struct.__dict__ == False."
    - "Verified: '__ror__' in struct.Struct.__dict__ == False."
    - "Verified: '__rxor__' in struct.Struct.__dict__ == False."
    - "Verified: '__and__' in struct.error.__dict__ == False (through __rxor__) == False."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct — bitwise operator absence checks
#
# struct.Struct is a C-extension type describing a binary data layout. It
# stores a format string (e.g. ">HH") and the computed byte size; it provides
# no numeric value that would make bitwise operations meaningful. No bitwise
# dunders (__and__, __or__, __xor__, __invert__, __lshift__, __rshift__) are
# defined in Struct.__dict__. The reflected variants (__rand__, __ror__,
# __rxor__) are equally absent. True entries (pack, unpack, pack_into,
# iter_unpack, format, size) confirm that the dict-presence mechanism works.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table struct_extra1546.Struct_bitwise_absent:
  description: "Bitwise operator dunders absent from struct.Struct.__dict__ — layout descriptor, not a numeric type"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st1546sa

  columns: [id, function, args, expected]
  rows:
    - ["st1546sa001", "Struct.__dict__.__contains__", ["__and__"],    false]
    - ["st1546sa002", "Struct.__dict__.__contains__", ["__or__"],     false]
    - ["st1546sa003", "Struct.__dict__.__contains__", ["__xor__"],    false]
    - ["st1546sa004", "Struct.__dict__.__contains__", ["__invert__"], false]
    - ["st1546sa005", "Struct.__dict__.__contains__", ["__lshift__"], false]
    - ["st1546sa006", "Struct.__dict__.__contains__", ["__rshift__"], false]
    - ["st1546sa007", "Struct.__dict__.__contains__", ["__rand__"],   false]
    - ["st1546sa008", "Struct.__dict__.__contains__", ["__ror__"],    false]
    - ["st1546sa009", "Struct.__dict__.__contains__", ["__rxor__"],   false]
    - ["st1546sa010", "Struct.__dict__.__contains__", ["pack"],       true]
    - ["st1546sa011", "Struct.__dict__.__contains__", ["unpack"],     true]
    - ["st1546sa012", "Struct.__dict__.__contains__", ["format"],     true]

# ---------------------------------------------------------------------------
# struct.error — bitwise operator absence checks
#
# struct.error is the exception type raised by struct on bad format strings,
# insufficient data, or value-range violations. It inherits from Exception ->
# BaseException -> object. Exceptions represent error conditions, not numeric
# values. None of the bitwise dunders (__and__, __or__, __xor__, __invert__,
# __lshift__, __rshift__, __rand__, __ror__, __rxor__) appear in
# struct.error.__dict__. The True entries (__doc__, __module__) confirm that
# dict-presence lookups on struct.error work correctly and that the False
# results are genuine absences.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table struct_extra1546.error_bitwise_absent:
  description: "Bitwise operator dunders absent from struct.error.__dict__ — exception type, not numeric"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st1546eb

  columns: [id, function, args, expected]
  rows:
    - ["st1546eb001", "error.__dict__.__contains__", ["__and__"],    false]
    - ["st1546eb002", "error.__dict__.__contains__", ["__or__"],     false]
    - ["st1546eb003", "error.__dict__.__contains__", ["__xor__"],    false]
    - ["st1546eb004", "error.__dict__.__contains__", ["__invert__"], false]
    - ["st1546eb005", "error.__dict__.__contains__", ["__lshift__"], false]
    - ["st1546eb006", "error.__dict__.__contains__", ["__rshift__"], false]
    - ["st1546eb007", "error.__dict__.__contains__", ["__rand__"],   false]
    - ["st1546eb008", "error.__dict__.__contains__", ["__ror__"],    false]
    - ["st1546eb009", "error.__dict__.__contains__", ["__rxor__"],   false]
    - ["st1546eb010", "error.__dict__.__contains__", ["__doc__"],    true]
    - ["st1546eb011", "error.__dict__.__contains__", ["__module__"], true]

# ---------------------------------------------------------------------------
# struct.Struct — pack/unpack API and attribute presence checks
#
# Beyond the core pack/unpack pair, struct.Struct defines pack_into,
# unpack_from, and iter_unpack for buffer-interface integration, plus the
# format and size attribute descriptors. The __new__, __repr__, __sizeof__,
# __module__, __doc__ meta-dunders are also present. This table validates
# these True entries alongside additional absent bitwise operators to
# complete the wave-550 bitwise theme for struct.Struct.
# ---------------------------------------------------------------------------

table struct_extra1546.Struct_api_present:
  description: "Pack/unpack API and meta-dunder presence in struct.Struct.__dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st1546ap

  columns: [id, function, args, expected]
  rows:
    - ["st1546ap001", "Struct.__dict__.__contains__", ["pack_into"],   true]
    - ["st1546ap002", "Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st1546ap003", "Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st1546ap004", "Struct.__dict__.__contains__", ["size"],        true]
    - ["st1546ap005", "Struct.__dict__.__contains__", ["__repr__"],    true]
    - ["st1546ap006", "Struct.__dict__.__contains__", ["__sizeof__"],  true]
    - ["st1546ap007", "Struct.__dict__.__contains__", ["__module__"],  true]
    - ["st1546ap008", "Struct.__dict__.__contains__", ["__doc__"],     true]
    - ["st1546ap009", "Struct.__dict__.__contains__", ["__and__"],     false]
    - ["st1546ap010", "Struct.__dict__.__contains__", ["__or__"],      false]
    - ["st1546ap011", "Struct.__dict__.__contains__", ["__invert__"],  false]
    - ["st1546ap012", "Struct.__dict__.__contains__", ["__xor__"],     false]
