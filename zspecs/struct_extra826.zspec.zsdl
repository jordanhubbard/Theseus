spec: struct_extra826
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - struct
  not_derived_from:
    - ctypes
    - array
  notes:
    - Covers struct.Struct method qualnames and struct.error exception qualnames
    - Qualname checks verify CPython method identity strings for Struct class and error exception
  created_at: "2026-04-12"

table struct_extra826.struct_method_qualnames:
  description: struct.Struct method qualnames
  kind: python_call_eq
  category: qualname
  id_prefix: st826sm
  columns: [id, function, args, expected]
  rows:
    - [st826sm001, struct.Struct.pack.__qualname__.__eq__, ["Struct.pack"], true]
    - [st826sm002, struct.Struct.unpack.__qualname__.__eq__, ["Struct.unpack"], true]
    - [st826sm003, struct.Struct.pack_into.__qualname__.__eq__, ["Struct.pack_into"], true]
    - [st826sm004, struct.Struct.unpack_from.__qualname__.__eq__, ["Struct.unpack_from"], true]
    - [st826sm005, struct.Struct.iter_unpack.__qualname__.__eq__, ["Struct.iter_unpack"], true]
    - [st826sm006, struct.Struct.__init__.__qualname__.__eq__, ["Struct.__init__"], true]
    - [st826sm007, struct.Struct.__repr__.__qualname__.__eq__, ["Struct.__repr__"], true]

table struct_extra826.struct_error_qualnames:
  description: struct.error exception qualnames and module identity
  kind: python_call_eq
  category: qualname
  id_prefix: st826er
  columns: [id, function, args, expected]
  rows:
    - [st826er001, struct.error.__qualname__.__eq__, ["error"], true]
    - [st826er002, struct.error.__module__.__eq__, ["struct"], true]
    - [st826er003, struct.error.__init__.__qualname__.__eq__, ["error.__init__"], true]
    - [st826er004, struct.error.__str__.__qualname__.__eq__, ["error.__str__"], true]
    - [st826er005, struct.error.__repr__.__qualname__.__eq__, ["error.__repr__"], true]
