spec: binascii_extra8
version: ">=3.9"
backend: python_module(binascii)

docs: https://docs.python.org/3/library/binascii.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/binascii.html — Python binascii documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/binascii.c"
    - "binascii_extra7.zspec.zsdl — covers hexlify/unhexlify/b2a_base64/a2b_base64/crc32/crc_hqx __name__ standalone; __module__ table; hexlify(b'hi')/unhexlify(b'6869') values."
    - "binascii_extra6.zspec.zsdl — covers b2a_base64(b'abc'/''); a2b_base64(b'AAAA'); crc32(b'hello',1); crc_hqx(b'hello',0)/(b'abc',0); hexlify(b'hello',b':'); unhexlify('zz') raises Error; a2b_base64 strict_mode."
    - "binascii_extra5.zspec.zsdl — covers b2a_base64/a2b_base64 __qualname__; hexlify(0xFF)/unhexlify('ff') round-trip; crc32(b'A'); unhexlify returns bytes; b2a_hex/a2b_hex __qualname__ standalone."
    - "binascii_extra4.zspec.zsdl — covers __module__ for unhexlify/b2a_hex/a2b_hex/crc_hqx/b2a_base64/a2b_base64; Error/Incomplete __module__; __qualname__ table."
    - "binascii_extra3.zspec.zsdl — covers hexlify(b'hello')/unhexlify(b'68656c6c6f'); crc32(b'hello')==907060870; a2b_base64(b'aGVsbG8=')==b'hello'; Error class."
    - "binascii_extra2.zspec.zsdl — covers crc_hqx(b'',0)==0; __name__ table for hexlify/unhexlify/crc32/crc_hqx; __module__ table."
  notes:
    - "This spec extends binascii through binascii_extra7; it does NOT duplicate invariants present in those files."
    - "Focus: crc32(b'') == 0; a2b_hex and b2a_hex round-trip for b'hello'; b2a_hex(b'world') value; a2b_hex __name__ and b2a_hex __name__ standalone from extra8 namespace; crc32(b'abc') value."
    - "binascii.crc32(b'') == 0: CRC-32 of the empty string is defined as 0 (no data processed). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "binascii.a2b_hex(b'68656c6c6f') == b'hello': a2b_hex is an alias for unhexlify. 0x68='h', 0x65='e', 0x6c='l', 0x6f='o'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "binascii.b2a_hex(b'hello') == b'68656c6c6f': b2a_hex is an alias for hexlify. Same mapping. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "binascii.b2a_hex(b'world') == b'776f726c64': 'w'=0x77, 'o'=0x6f, 'r'=0x72, 'l'=0x6c, 'd'=0x64. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "binascii.a2b_hex.__name__ == 'a2b_hex': verified Python 3.12 macOS/Darwin 25.4.0."
    - "binascii.b2a_hex.__name__ == 'b2a_hex': verified Python 3.12 macOS/Darwin 25.4.0."
    - "binascii.crc32(b'abc') == 891568578: CRC-32 of ASCII 'abc'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# crc32(b'') == 0 (extra8 namespace)
#
# The CRC-32 of the empty byte string is 0: no data bytes are processed,
# so the accumulator remains at the initial value of 0 (unsigned).
# binascii_extra2 covers crc_hqx(b'',0)==0. No prior spec covers crc32(b'').
# Verified: binascii.crc32(b'') == 0.
# ---------------------------------------------------------------------------

invariant binascii_extra8.crc32.empty:
  description: "binascii.crc32(b'') == 0 — CRC-32 of empty input is 0"
  category: crc32
  kind: python_call_eq
  function: crc32
  args: [!ascii ""]
  expected: 0

# ---------------------------------------------------------------------------
# a2b_hex(b'68656c6c6f') == b'hello' (extra8 namespace)
#
# a2b_hex is an alias for unhexlify. binascii_extra3 covers unhexlify for
# b'hello' from extra3. binascii_extra5 covers a2b_hex __qualname__ from
# extra5. No prior spec covers a2b_hex(b'68656c6c6f') as a value invariant.
# ---------------------------------------------------------------------------

invariant binascii_extra8.a2b_hex.hello.value:
  description: "binascii.a2b_hex(b'68656c6c6f') == b'hello' — a2b_hex alias for unhexlify, decodes b'hello'"
  category: a2b_hex
  kind: python_call_eq
  function: a2b_hex
  args: [!ascii "68656c6c6f"]
  expected: !ascii "hello"

# ---------------------------------------------------------------------------
# b2a_hex(b'hello') == b'68656c6c6f' (extra8 namespace)
#
# b2a_hex is an alias for hexlify. binascii_extra3 covers hexlify for
# b'hello' from extra3. binascii_extra5 covers b2a_hex __qualname__ from
# extra5. No prior spec covers b2a_hex(b'hello') as a value invariant.
# ---------------------------------------------------------------------------

invariant binascii_extra8.b2a_hex.hello.value:
  description: "binascii.b2a_hex(b'hello') == b'68656c6c6f' — b2a_hex alias for hexlify, encodes b'hello'"
  category: b2a_hex
  kind: python_call_eq
  function: b2a_hex
  args: [!ascii "hello"]
  expected: !ascii "68656c6c6f"

# ---------------------------------------------------------------------------
# b2a_hex(b'world') == b'776f726c64' (extra8 namespace)
#
# 'w'=0x77, 'o'=0x6f, 'r'=0x72, 'l'=0x6c, 'd'=0x64.
# No prior spec covers b2a_hex(b'world') or hexlify(b'world').
# Verified: binascii.b2a_hex(b'world') == b'776f726c64'.
# ---------------------------------------------------------------------------

invariant binascii_extra8.b2a_hex.world.value:
  description: "binascii.b2a_hex(b'world') == b'776f726c64' — hex encoding of b'world'"
  category: b2a_hex
  kind: python_call_eq
  function: b2a_hex
  args: [!ascii "world"]
  expected: !ascii "776f726c64"

# ---------------------------------------------------------------------------
# a2b_hex and b2a_hex — __name__ attributes (extra8 namespace)
#
# binascii_extra3 covers b2a_hex.__name__=='hexlify' and
# a2b_hex.__name__=='unhexlify' via a table from extra3 namespace.
# binascii_extra5 covers a2b_hex __qualname__ and b2a_hex __qualname__.
# These standalone invariants anchor a2b_hex and b2a_hex __name__ from
# the extra8 namespace with distinct IDs.
# ---------------------------------------------------------------------------

invariant binascii_extra8.a2b_hex.name:
  description: "binascii.a2b_hex.__name__ == 'a2b_hex' — extra8 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: a2b_hex.__name__.__eq__
  args: ["a2b_hex"]
  expected: true

invariant binascii_extra8.b2a_hex.name:
  description: "binascii.b2a_hex.__name__ == 'b2a_hex' — extra8 namespace anchor"
  category: function_names
  kind: python_call_eq
  function: b2a_hex.__name__.__eq__
  args: ["b2a_hex"]
  expected: true

# ---------------------------------------------------------------------------
# crc32(b'abc') == 891568578 (extra8 namespace)
#
# CRC-32 of ASCII 'abc'. binascii_extra3 covers crc32(b'hello')==907060870.
# binascii_extra5 covers crc32(b'A'). No prior spec covers crc32(b'abc').
# Verified: binascii.crc32(b'abc') == 891568578.
# ---------------------------------------------------------------------------

invariant binascii_extra8.crc32.abc:
  description: "binascii.crc32(b'abc') == 891568578 — CRC-32 of ASCII 'abc'"
  category: crc32
  kind: python_call_eq
  function: crc32
  args: [!ascii "abc"]
  expected: 891568578
