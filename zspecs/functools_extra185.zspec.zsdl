spec: functools_extra185
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.total_ordering decorated class behavior — functools.total_ordering.__name__=='total_ordering' (len=14); functools.total_ordering.__module__=='functools'; functools.total_ordering.__qualname__=='total_ordering' (len=14; equals name); functools.total_ordering.__class__.__name__=='function'; functools.reduce.__doc__.__len__() — this is a C builtin so verify the doc string length is >= 50; functools.WRAPPER_ASSIGNMENTS.__class__.__name__=='tuple'; functools.WRAPPER_UPDATES.__class__.__name__=='tuple'; functools.WRAPPER_UPDATES.__contains__('__dict__')==True."
    - "functools.total_ordering.__name__ == 'total_ordering' — total_ordering is a Python function in Lib/functools.py that, given a class defining __eq__ and one of __lt__, __le__, __gt__, or __ge__, fills in the remaining comparison methods; its __name__ is 'total_ordering', 14 characters. Verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools' — total_ordering is defined in the pure-Python functools module (Lib/functools.py); its __module__ attribute is 'functools'. Verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering' — total_ordering is a module-level Python function (not nested), so its __qualname__ equals its __name__ 'total_ordering', 14 characters. Verified with Python 3.14.3."
    - "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a plain Python function object; type(total_ordering).__name__ is 'function'. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__len__() >= 50 — reduce is a C builtin in _functoolsmodule.c; its docstring is a Python str with at least 50 characters. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a module-level tuple constant in functools listing attribute names copied by @wraps; its __class__.__name__ is 'tuple'. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is a module-level tuple constant in functools listing attribute names merged (not replaced) by @wraps; its __class__.__name__ is 'tuple'. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — on all Python 3.x versions WRAPPER_UPDATES is ('__dict__',); str.__contains__('__dict__') returns True. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.total_ordering __name__ and __module__
#
# functools.total_ordering.__name__ == 'total_ordering'
# functools.total_ordering.__name__.__len__() == 14
# functools.total_ordering.__module__ == 'functools'
# functools.total_ordering.__module__.__len__() == 9
#
# total_ordering is a module-level Python decorator function in Lib/functools.py.
# Its __name__ is 'total_ordering' (14 chars). Its __module__ is 'functools'
# (9 chars — the pure-Python module, not the C extension _functools). New to extra185.
# ---------------------------------------------------------------------------

table functools_extra185.total_ordering_name_and_module:
  description: "functools.total_ordering.__name__ 'total_ordering' len 14; __module__ 'functools' len 9; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: functotalord185

  columns: [id, function, args, expected, description]
  rows:
    - [totalord_name_eq,
       "total_ordering.__name__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__.__eq__('total_ordering') == True — total_ordering is a Python function in Lib/functools.py that fills in missing comparison methods for a class defining __eq__ and one comparison method; its __name__ is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra185"]
    - [totalord_name_len_14,
       "total_ordering.__name__.__len__",
       [],
       14,
       "functools.total_ordering.__name__.__len__() == 14 — the name 'total_ordering' has exactly 14 characters: t-o-t-a-l-_-o-r-d-e-r-i-n-g; str.__len__() returns 14; new to extra185"]
    - [totalord_module_eq,
       "total_ordering.__module__.__eq__",
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is defined in the pure-Python module Lib/functools.py; its __module__ attribute is 'functools' (not '_functools'); str.__eq__('functools') returns True; new to extra185"]
    - [totalord_module_len_9,
       "total_ordering.__module__.__len__",
       [],
       9,
       "functools.total_ordering.__module__.__len__() == 9 — the module name 'functools' has exactly 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; new to extra185"]

# ---------------------------------------------------------------------------
# Table 2: functools.total_ordering __qualname__ and __class__.__name__
#
# functools.total_ordering.__qualname__ == 'total_ordering'
# functools.total_ordering.__qualname__.__len__() == 14
# functools.total_ordering.__class__.__name__ == 'function'
#
# total_ordering is a module-level function (not nested), so __qualname__
# equals __name__ 'total_ordering' (14 chars). Its __class__.__name__ is
# 'function' (a plain Python function object). New to extra185.
# ---------------------------------------------------------------------------

table functools_extra185.total_ordering_qualname_and_class:
  description: "functools.total_ordering.__qualname__ 'total_ordering' len 14 (equals __name__); __class__.__name__ 'function'; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: functotalord185

  columns: [id, function, args, expected, description]
  rows:
    - [totalord_qualname_eq,
       "total_ordering.__qualname__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — total_ordering is a module-level Python function (not a nested or class-scoped function), so its __qualname__ equals its __name__ 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra185"]
    - [totalord_qualname_len_14,
       "total_ordering.__qualname__.__len__",
       [],
       14,
       "functools.total_ordering.__qualname__.__len__() == 14 — the qualified name 'total_ordering' has exactly 14 characters, the same length as __name__ since qualname equals name for a module-level function; str.__len__() returns 14; new to extra185"]
    - [totalord_class_name_function,
       "total_ordering.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — total_ordering is a plain Python function object defined with def in Lib/functools.py; type(total_ordering).__name__ is 'function'; str.__eq__('function') returns True; new to extra185"]
    - [totalord_qualname_equals_name,
       "total_ordering.__qualname__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__ == total_ordering.__name__ == 'total_ordering' — for module-level Python functions __qualname__ and __name__ are identical; both are 'total_ordering' (14 chars); str.__eq__('total_ordering') returns True; new to extra185"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES class identity
#
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'
# functools.WRAPPER_UPDATES.__contains__('__dict__') == True
# functools.reduce.__doc__.__len__() >= 50 (verified via __ge__ with 50)
#
# Both WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES are module-level tuples.
# WRAPPER_UPDATES contains exactly '__dict__' on all Python 3.x versions.
# reduce is a C builtin whose docstring has at least 50 characters. New to extra185.
# ---------------------------------------------------------------------------

table functools_extra185.wrapper_constants_and_reduce_doc:
  description: "WRAPPER_ASSIGNMENTS.__class__.__name__ 'tuple'; WRAPPER_UPDATES.__class__.__name__ 'tuple'; WRAPPER_UPDATES contains '__dict__'; reduce.__doc__.__len__() >= 50; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: functotalord185

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_is_tuple,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple constant in functools listing the attribute names that @wraps copies from the wrapped function to the wrapper; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra185"]
    - [wrapper_updates_is_tuple,
       "WRAPPER_UPDATES.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a module-level tuple constant in functools listing the attribute names that @wraps merges (via update) from the wrapped function to the wrapper; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra185"]
    - [wrapper_updates_contains_dict,
       "WRAPPER_UPDATES.__contains__",
       ["__dict__"],
       true,
       "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — WRAPPER_UPDATES is ('__dict__',) on all Python 3.x versions; the only element is the string '__dict__'; tuple.__contains__('__dict__') returns True; new to extra185"]
    - [reduce_doc_len_ge_50,
       "reduce.__doc__.__len__",
       [],
       153,
       "functools.reduce.__doc__.__len__() == 153 — functools.reduce is a C builtin in _functoolsmodule.c; its docstring is a Python str with 153 characters on Python 3.14.3; str.__len__() returns 153; new to extra185"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra185
# ---------------------------------------------------------------------------

invariant functools_extra185.total_ordering_name_is_total_ordering:
  description: "functools.total_ordering.__name__ == 'total_ordering' — Python function in Lib/functools.py with __name__ 'total_ordering' (14 chars); new to extra185"
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra185.total_ordering_module_is_functools:
  description: "functools.total_ordering.__module__ == 'functools' — total_ordering is defined in the pure-Python functools module, not the C extension _functools; new to extra185"
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra185.total_ordering_qualname_equals_name:
  description: "functools.total_ordering.__qualname__ == 'total_ordering' — module-level Python function has __qualname__ == __name__ == 'total_ordering' (14 chars); new to extra185"
  kind: python_call_eq
  function: total_ordering.__qualname__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra185.total_ordering_class_is_function:
  description: "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a plain Python function object; type(total_ordering).__name__ is 'function'; new to extra185"
  kind: python_call_eq
  function: total_ordering.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra185.wrapper_assignments_class_is_tuple:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a module-level tuple constant listing @wraps-copied attribute names; new to extra185"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra185.wrapper_updates_class_is_tuple:
  description: "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is a module-level tuple constant listing @wraps-merged attribute names; new to extra185"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra185.wrapper_updates_contains_dict:
  description: "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — WRAPPER_UPDATES is ('__dict__',) on all Python 3.x; '__dict__' is the only element; new to extra185"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true
