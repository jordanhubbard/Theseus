spec: struct_extra631
version: ">=3.9"
backend: python_module(struct)
docs: "Behavioral spec for struct module __doc__ presence and Struct class qualname/module identity."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module functions and Struct class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks that key struct functions and classes carry str __doc__, and that Struct qualnames and module attributes are correct"
  created_at: "2026-04-12T00:00:00Z"

table struct_extra631.doc_class_name:
  description: "struct module symbols __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: doc_identity
  id_prefix: st631dc
  columns: [id, function, args, expected]
  rows:
    - [st631dc001, struct.Struct.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st631dc002, struct.error.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st631dc003, struct.pack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st631dc004, struct.unpack.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st631dc005, struct.pack_into.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st631dc006, struct.unpack_from.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st631dc007, struct.calcsize.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st631dc008, struct.iter_unpack.__doc__.__class__.__name__.__eq__, ["str"], true]

table struct_extra631.struct_qualname_module:
  description: "Struct class method qualnames and module identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: st631fn
  columns: [id, function, args, expected]
  rows:
    - [st631fn001, struct.Struct.__init__.__qualname__.__eq__, ["Struct.__init__"], true]
    - [st631fn002, struct.Struct.__repr__.__qualname__.__eq__, ["Struct.__repr__"], true]
    - [st631fn003, struct.Struct.__module__.__eq__, ["struct"], true]
    - [st631fn004, struct.error.__module__.__eq__, ["struct"], true]
