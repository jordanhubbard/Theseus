spec: string_extra23
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/string.py"
  notes:
    - "This spec extends string.zspec.zsdl and prior extras through string_extra22.zspec.zsdl."
    - "string_extra5 covers: Formatter.__qualname__=='Formatter'; Template.__qualname__=='Template'; capwords.__qualname__=='capwords'."
    - "string_extra21 covers: Formatter.format/vformat/parse __qualname__; Template.substitute/safe_substitute __qualname__."
    - "string_extra22 covers: Formatter.get_field/get_value/check_unused_args/format_field/convert_field __qualname__; Template.__init__/__init_subclass__ __qualname__; whitespace/punctuation __class__.__name__."
    - "string_extra17 covers: ascii_letters/__class__.__name__=='str'; digits/__class__.__name__=='str' as standalone invariants."
    - "No prior spec covers Formatter.__module__, Template.__module__, or capwords.__module__ as standalone invariants."
    - "No prior spec covers Formatter.__bases__[0].__name__ or Template.__bases__[0].__name__ as standalone invariants."
    - "No prior spec covers hexdigits/__class__.__name__, octdigits/__class__.__name__, printable/__class__.__name__, ascii_uppercase/__class__.__name__, or ascii_lowercase/__class__.__name__ as standalone invariants."
    - "string.Formatter.__module__ == 'string' — class is defined in the string module. Verified at runtime."
    - "string.Template.__module__ == 'string' — class is defined in the string module. Verified at runtime."
    - "string.capwords.__module__ == 'string' — top-level function defined in the string module. Verified at runtime."
    - "string.Formatter.__bases__[0].__name__ == 'object' — Formatter directly inherits from object. Verified at runtime."
    - "string.Template.__bases__[0].__name__ == 'object' — Template directly inherits from object. Verified at runtime."
    - "string.hexdigits.__class__.__name__ == 'str' — hexdigits constant is a str. Verified at runtime."
    - "string.octdigits.__class__.__name__ == 'str' — octdigits constant is a str. Verified at runtime."
    - "string.printable.__class__.__name__ == 'str' — printable constant is a str. Verified at runtime."
    - "string.ascii_uppercase.__class__.__name__ == 'str' — ascii_uppercase constant is a str. Verified at runtime."
    - "string.ascii_lowercase.__class__.__name__ == 'str' — ascii_lowercase constant is a str. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# string.Formatter — __module__
#
# string_extra5 covers Formatter.__qualname__ == 'Formatter'. No prior spec
# verifies Formatter.__module__ as a standalone invariant. The Formatter class
# is defined in the string module, so __module__ == 'string'.
# Verified at runtime: 'string'.
# ---------------------------------------------------------------------------

invariant string_extra23.Formatter.module:
  description: "string.Formatter.__module__ == 'string' — class is defined in the string module"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__module__.__eq__
  args: ["string"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template — __module__
#
# string_extra5 covers Template.__qualname__ == 'Template'. No prior spec
# verifies Template.__module__ as a standalone invariant. The Template class
# is defined in the string module, so __module__ == 'string'.
# Verified at runtime: 'string'.
# ---------------------------------------------------------------------------

invariant string_extra23.Template.module:
  description: "string.Template.__module__ == 'string' — class is defined in the string module"
  category: class_identity
  kind: python_call_eq
  function: Template.__module__.__eq__
  args: ["string"]
  expected: true

# ---------------------------------------------------------------------------
# string.capwords — __module__
#
# string_extra5/extra21 cover capwords.__qualname__ == 'capwords'. No prior
# spec verifies capwords.__module__ as a standalone invariant. capwords is a
# module-level function defined in string, so __module__ == 'string'.
# Verified at runtime: 'string'.
# ---------------------------------------------------------------------------

invariant string_extra23.capwords.module:
  description: "string.capwords.__module__ == 'string' — top-level function defined in the string module"
  category: function_identity
  kind: python_call_eq
  function: capwords.__module__.__eq__
  args: ["string"]
  expected: true

# ---------------------------------------------------------------------------
# string.Formatter — __bases__[0].__name__
#
# No prior spec verifies Formatter.__bases__[0].__name__ as a standalone
# invariant. Formatter has no explicit base class other than object, so
# __bases__[0].__name__ == 'object'. Verified at runtime: 'object'.
# ---------------------------------------------------------------------------

invariant string_extra23.Formatter.base_name:
  description: "string.Formatter.__bases__[0].__name__ == 'object' — Formatter directly inherits from object"
  category: class_identity
  kind: python_call_eq
  function: "Formatter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# string.Template — __bases__[0].__name__
#
# No prior spec verifies Template.__bases__[0].__name__ as a standalone
# invariant. Template has no explicit base class other than object, so
# __bases__[0].__name__ == 'object'. Verified at runtime: 'object'.
# ---------------------------------------------------------------------------

invariant string_extra23.Template.base_name:
  description: "string.Template.__bases__[0].__name__ == 'object' — Template directly inherits from object"
  category: class_identity
  kind: python_call_eq
  function: "Template.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# string.hexdigits — __class__.__name__
#
# No prior spec verifies string.hexdigits.__class__.__name__ as a standalone
# invariant. hexdigits is a module-level string constant ('0123456789abcdefABCDEF'),
# so __class__.__name__ == 'str'. Verified at runtime: 'str'.
# ---------------------------------------------------------------------------

invariant string_extra23.hexdigits.class_name:
  description: "string.hexdigits.__class__.__name__ == 'str' — hexdigits constant is a str"
  category: string_constants
  kind: python_call_eq
  function: hexdigits.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# string.octdigits — __class__.__name__
#
# No prior spec verifies string.octdigits.__class__.__name__ as a standalone
# invariant. octdigits is a module-level string constant ('01234567'), so
# __class__.__name__ == 'str'. Verified at runtime: 'str'.
# ---------------------------------------------------------------------------

invariant string_extra23.octdigits.class_name:
  description: "string.octdigits.__class__.__name__ == 'str' — octdigits constant is a str"
  category: string_constants
  kind: python_call_eq
  function: octdigits.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# string.printable — __class__.__name__
#
# No prior spec verifies string.printable.__class__.__name__ as a standalone
# invariant. printable is a module-level string constant, so
# __class__.__name__ == 'str'. Verified at runtime: 'str'.
# ---------------------------------------------------------------------------

invariant string_extra23.printable.class_name:
  description: "string.printable.__class__.__name__ == 'str' — printable constant is a str"
  category: string_constants
  kind: python_call_eq
  function: printable.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# string.ascii_uppercase — __class__.__name__
#
# No prior spec verifies string.ascii_uppercase.__class__.__name__ as a
# standalone invariant. ascii_uppercase is a module-level string constant
# ('ABCDEFGHIJKLMNOPQRSTUVWXYZ'), so __class__.__name__ == 'str'.
# Verified at runtime: 'str'.
# ---------------------------------------------------------------------------

invariant string_extra23.ascii_uppercase.class_name:
  description: "string.ascii_uppercase.__class__.__name__ == 'str' — ascii_uppercase constant is a str"
  category: string_constants
  kind: python_call_eq
  function: ascii_uppercase.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# string.ascii_lowercase — __class__.__name__
#
# No prior spec verifies string.ascii_lowercase.__class__.__name__ as a
# standalone invariant. ascii_lowercase is a module-level string constant
# ('abcdefghijklmnopqrstuvwxyz'), so __class__.__name__ == 'str'.
# Verified at runtime: 'str'.
# ---------------------------------------------------------------------------

invariant string_extra23.ascii_lowercase.class_name:
  description: "string.ascii_lowercase.__class__.__name__ == 'str' — ascii_lowercase constant is a str"
  category: string_constants
  kind: python_call_eq
  function: ascii_lowercase.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Table: class __module__ and __bases__[0].__name__ for Formatter and Template
#
# No prior spec groups Formatter/__module__, Template/__module__,
# capwords/__module__, Formatter/__bases__[0].__name__, and
# Template/__bases__[0].__name__ into a single table.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table string_extra23.class_module_and_bases:
  description: "string module class __module__ and direct base class name checks for Formatter, Template, and capwords"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [Formatter_module,
       Formatter.__module__.__eq__,
       ["string"],
       true,
       "Formatter.__module__ == 'string'"]
    - [Template_module,
       Template.__module__.__eq__,
       ["string"],
       true,
       "Template.__module__ == 'string'"]
    - [capwords_module,
       capwords.__module__.__eq__,
       ["string"],
       true,
       "capwords.__module__ == 'string'"]
    - [Formatter_base,
       "Formatter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "Formatter.__bases__[0].__name__ == 'object'"]
    - [Template_base,
       "Template.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "Template.__bases__[0].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# Table: additional string constant __class__.__name__ values
#
# No prior spec groups hexdigits, octdigits, printable, ascii_uppercase, and
# ascii_lowercase __class__.__name__ checks into a single table. All are str.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table string_extra23.additional_constant_class_names:
  description: "string module additional constant __class__.__name__ values — hexdigits, octdigits, printable, ascii_uppercase, ascii_lowercase"
  kind: python_call_eq
  category: string_constants
  columns: [id, function, args, expected, description]
  rows:
    - [hexdigits,
       hexdigits.__class__.__name__.__eq__,
       ["str"],
       true,
       "hexdigits.__class__.__name__ == 'str'"]
    - [octdigits,
       octdigits.__class__.__name__.__eq__,
       ["str"],
       true,
       "octdigits.__class__.__name__ == 'str'"]
    - [printable,
       printable.__class__.__name__.__eq__,
       ["str"],
       true,
       "printable.__class__.__name__ == 'str'"]
    - [ascii_uppercase,
       ascii_uppercase.__class__.__name__.__eq__,
       ["str"],
       true,
       "ascii_uppercase.__class__.__name__ == 'str'"]
    - [ascii_lowercase,
       ascii_lowercase.__class__.__name__.__eq__,
       ["str"],
       true,
       "ascii_lowercase.__class__.__name__ == 'str'"]
