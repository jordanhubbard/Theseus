  columns: [id, function, args, expected]
  rows:
    - [hl1501sa001, hashlib.blake2s.__dict__.__contains__, ["__await__"],  false]
    - [hl1501sa002, hashlib.blake2s.__dict__.__contains__, ["__aiter__"],  false]
    - [hl1501sa003, hashlib.blake2s.__dict__.__contains__, ["__anext__"],  false]
    - [hl1501sa004, hashlib.blake2s.__dict__.__contains__, ["__aenter__"], false]
    - [hl1501sa005, hashlib.blake2s.__dict__.__contains__, ["__aexit__"],  false]
    - [hl1501sa006, hashlib.blake2s.__dict__.__contains__, ["digest"],     true]
