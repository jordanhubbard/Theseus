spec: hashlib_extra1501
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module HASH and blake2 class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 547 (_extra1501): async protocol method dict-presence checks for hashlib HASH, blake2b, and blake2s classes."
    - "hashlib is a sync-only hashing module; none of its types implement __await__, __aiter__, __anext__, __aenter__, or __aexit__."
    - "Positive anchor columns confirm that genuine methods (digest, hexdigest, update, copy) ARE present in the respective __dict__."
    - "All results verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# HASH (e.g. hashlib.sha256()) — async protocol absent, sync methods present
# ---------------------------------------------------------------------------

table hashlib_extra1501.HASH.async_protocol_absent:
  description: "hashlib HASH type has no async protocol methods in its __dict__"
  kind: python_call_eq
  category: async_protocol
  id_prefix: hl1501ha
  columns: [id, function, args, expected]
  rows:
    - [hl1501ha001, hashlib.sha256.__call__.__class__.__name__.__eq__,                       ["builtin_function_or_method"], true]
    - [hl1501ha002, hashlib.sha256.__class__.__name__.__eq__,                                ["builtin_function_or_method"], true]
    - [hl1501ha003, hashlib.sha256().__class__.__dict__.__contains__,                        ["__await__"],                  false]
    - [hl1501ha004, hashlib.sha256().__class__.__dict__.__contains__,                        ["__aiter__"],                  false]
    - [hl1501ha005, hashlib.sha256().__class__.__dict__.__contains__,                        ["__anext__"],                  false]
    - [hl1501ha006, hashlib.sha256().__class__.__dict__.__contains__,                        ["__aenter__"],                 false]
    - [hl1501ha007, hashlib.sha256().__class__.__dict__.__contains__,                        ["__aexit__"],                  false]

table hashlib_extra1501.HASH.sync_methods_present:
  description: "hashlib HASH type sync methods ARE present in its __dict__"
  kind: python_call_eq
  category: async_protocol
  id_prefix: hl1501hs
  columns: [id, function, args, expected]
  rows:
    - [hl1501hs001, hashlib.sha256().__class__.__dict__.__contains__, ["digest"],      true]
    - [hl1501hs002, hashlib.sha256().__class__.__dict__.__contains__, ["hexdigest"],   true]
    - [hl1501hs003, hashlib.sha256().__class__.__dict__.__contains__, ["update"],      true]
    - [hl1501hs004, hashlib.sha256().__class__.__dict__.__contains__, ["copy"],        true]
    - [hl1501hs005, hashlib.sha256().__class__.__dict__.__contains__, ["digest_size"], true]
    - [hl1501hs006, hashlib.sha256().__class__.__dict__.__contains__, ["block_size"],  true]

# ---------------------------------------------------------------------------
# blake2b — async protocol absent, sync methods present
# ---------------------------------------------------------------------------

table hashlib_extra1501.blake2b.async_protocol_absent:
  description: "hashlib.blake2b has no async protocol methods in its __dict__"
  kind: python_call_eq
  category: async_protocol
  id_prefix: hl1501ba
  columns: [id, function, args, expected]
  rows:
    - [hl1501ba001, hashlib.blake2b.__dict__.__contains__, ["__await__"],  false]
    - [hl1501ba002, hashlib.blake2b.__dict__.__contains__, ["__aiter__"],  false]
    - [hl1501ba003, hashlib.blake2b.__dict__.__contains__, ["__anext__"],  false]
    - [hl1501ba004, hashlib.blake2b.__dict__.__contains__, ["__aenter__"], false]
    - [hl1501ba005, hashlib.blake2b.__dict__.__contains__, ["__aexit__"],  false]
    - [hl1501ba006, hashlib.blake2b.__dict__.__contains__, ["digest"],     true]
    - [hl1501ba007, hashlib.blake2b.__dict__.__contains__, ["hexdigest"],  true]
    - [hl1501ba008, hashlib.blake2b.__dict__.__contains__, ["update"],     true]

