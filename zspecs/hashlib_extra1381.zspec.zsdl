spec: hashlib_extra1381
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ frozenset checks."
    - "hashlib.new('md5').__class__ is _hashlib.HASH — a C extension type; it has no __abstractmethods__ attribute, so __class__.__dict__.__contains__('__abstractmethods__') returns False."
    - "hashlib.algorithms_guaranteed is a plain Python set; set.__dict__.__contains__('__abstractmethods__') returns False — set defines no abstract methods."
    - "frozenset is the type that __abstractmethods__ would be on abstract classes; frozenset.__class__.__name__ == 'type' and frozenset.__bases__.__class__.__name__ == 'tuple'."
    - "frozenset.__dict__.__contains__('__abstractmethods__') returns False — frozenset itself has no abstract methods."
    - "set.__dict__.__contains__('__abstractmethods__') returns False — set has no abstract methods defined in its class dict."
    - "The __dict__ of all these classes is a mappingproxy; __dict__.__class__.__name__ == 'mappingproxy'."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table hashlib_extra1381.hash_class_abstractmethods_absent:
  description: "hashlib HASH class dict does not contain __abstractmethods__ — HASH type defines no abstract methods; __dict__.__contains__ returns False for both md5 and sha256 HASH instances"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: hl1381ha
  columns: [id, function, args, expected]
  rows:
    - [hl1381ha001, hashlib.new("md5").__class__.__dict__.__contains__,    ["__abstractmethods__"], false]
    - [hl1381ha002, hashlib.new("sha256").__class__.__dict__.__contains__,  ["__abstractmethods__"], false]
    - [hl1381ha003, hashlib.new("sha512").__class__.__dict__.__contains__,  ["__abstractmethods__"], false]
    - [hl1381ha004, hashlib.new("sha1").__class__.__dict__.__contains__,    ["__abstractmethods__"], false]
    - [hl1381ha005, hashlib.new("sha3_256").__class__.__dict__.__contains__, ["__abstractmethods__"], false]
    - [hl1381ha006, hashlib.new("blake2b").__class__.__dict__.__contains__, ["__abstractmethods__"], false]

table hashlib_extra1381.set_frozenset_abstractmethods_absent:
  description: "set (type of hashlib.algorithms_guaranteed) and frozenset class dicts do not contain __abstractmethods__ — neither set nor frozenset defines abstract methods"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: hl1381sf
  columns: [id, function, args, expected]
  rows:
    - [hl1381sf001, set.__dict__.__contains__,       ["__abstractmethods__"], false]
    - [hl1381sf002, frozenset.__dict__.__contains__,  ["__abstractmethods__"], false]
    - [hl1381sf003, frozenset.__class__.__name__.__eq__,    ["type"],  true]
    - [hl1381sf004, frozenset.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [hl1381sf005, set.__class__.__name__.__eq__,          ["type"],  true]
    - [hl1381sf006, set.__bases__.__class__.__name__.__eq__, ["tuple"], true]

table hashlib_extra1381.hash_dict_mappingproxy_checks:
  description: "hashlib HASH class __dict__ is a mappingproxy; the mappingproxy type itself does not contain __abstractmethods__ in its own dict"
  kind: python_call_eq
  category: abstractmethods_checks
  id_prefix: hl1381mp
  columns: [id, function, args, expected]
  rows:
    - [hl1381mp001, hashlib.new("md5").__class__.__dict__.__class__.__name__.__eq__,    ["mappingproxy"], true]
    - [hl1381mp002, hashlib.new("sha256").__class__.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [hl1381mp003, hashlib.new("sha512").__class__.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [hl1381mp004, set.__dict__.__class__.__name__.__eq__,                              ["mappingproxy"], true]
    - [hl1381mp005, frozenset.__dict__.__class__.__name__.__eq__,                        ["mappingproxy"], true]
    - [hl1381mp006, hashlib.new("blake2b").__class__.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
