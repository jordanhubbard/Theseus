spec: validator
version: ">=13.0.0"
backend: node(validator)

docs: https://github.com/validatorjs/validator.js#readme

provenance:
  derived_from:
    - "validator README — https://github.com/validatorjs/validator.js#readme"
    - "Test vectors verified with validator@13.15.35 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "validator source: src/index.js"
  notes:
    - "validator exports an object with many string validation and sanitization methods."
    - "All validator methods expect string arguments — passing non-strings throws a TypeError."
    - "isEmail, isURL, isInt, isAlpha, isAlphanumeric, isEmpty, isNumeric check format/content."
    - "trim() strips leading/trailing whitespace."
    - "escape() converts HTML special chars to entities."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Validator methods return boolean; sanitizers return string. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table validator.email:
  kind: node_module_call_eq
  function: isEmail
  category: email
  id_prefix: val_email

  columns: [id, args, expected]
  rows:
    - [valid,    ["user@example.com"],  true]
    - [invalid,  ["notanemail"],        false]

table validator.url:
  kind: node_module_call_eq
  function: isURL
  category: url
  id_prefix: val_url

  columns: [id, args, expected]
  rows:
    - [valid,    ["https://example.com"],  true]
    - [invalid,  ["not a url"],            false]

table validator.numeric:
  kind: node_module_call_eq
  function: isInt
  category: numeric
  id_prefix: val_int

  columns: [id, args, expected]
  rows:
    - [valid,    ["42"],   true]
    - [invalid,  ["3.5"],  false]
    - [neg,      ["-1"],   true]

table validator.alpha:
  kind: node_module_call_eq
  function: isAlpha
  category: alpha
  id_prefix: val_alpha

  columns: [id, args, expected]
  rows:
    - [valid,    ["hello"],  true]
    - [invalid,  ["abc1"],   false]

table validator.empty:
  kind: node_module_call_eq
  function: isEmpty
  category: empty
  id_prefix: val_empty

  columns: [id, args, expected]
  rows:
    - [empty,      [""],      true]
    - [not_empty,  ["abc"],   false]

table validator.sanitize:
  kind: node_module_call_eq
  function: trim
  category: sanitize
  id_prefix: val_trim

  columns: [id, args, expected]
  rows:
    - [spaces,  ["  hello  "],  "hello"]
    - [clean,   ["hello"],      "hello"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:21:12Z
  iterations: 1
  pass_count: 13
  fail_count: 0
  total_invariants: 13
  notes: Synthesis succeeded in 1 iteration(s). 13 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
