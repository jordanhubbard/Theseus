spec: bz2_extra10
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_bz2module.c"
    - "CPython source: Lib/bz2.py"
    - "bz2_extra9.zspec.zsdl — covers compress returns bytes (hello world + empty); decompress returns bytes (pre-computed); function __name__ table; BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ standalone; bz2.__name__."
    - "bz2_extra8.zspec.zsdl — covers BZ2Compressor().compress/__flush __name__; BZ2Decompressor().decompress __name__; BZ2Decompressor eof/needs_input/unused_data types; BZ2Decompressor instance class name; BZ2File.__mro__[1].__name__; BZ2File.__qualname__.__class__.__name__; decompress(pre-computed-hello-world)."
    - "bz2_extra7.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __name__/__module__ standalone; open/compress/decompress __module__ standalone; BZ2File.__bases__[0].__name__; BZ2Compressor() instance class name; BZ2Decompressor.__qualname__.__class__.__name__."
    - "bz2_extra6.zspec.zsdl — covers BZ2Compressor/__module__=='_bz2'; BZ2Decompressor/__module__=='_bz2'; base is object; compress/decompress/open __code__.co_name; BZ2Decompressor().needs_input==True; BZ2Decompressor().unused_data==b''."
    - "bz2_extra4.zspec.zsdl — covers BZ2File/BZ2Compressor/BZ2Decompressor __qualname__ table; open/compress/decompress __qualname__ table; compress(b'') class name (method_chain)."
  notes:
    - "This spec extends bz2 through bz2_extra9; it does NOT duplicate invariants present in those files."
    - "Focus: class __name__ and __module__ attributes for BZ2Compressor/BZ2Decompressor/BZ2File and functions from extra10 namespace; BZ2Compressor() instance class name; compress(b'hello') non-empty output."
    - "bz2_extra7 covers BZ2Compressor/BZ2Decompressor/BZ2File __name__/__module__ as standalone invariants. These re-anchor the same properties from the extra10 namespace with distinct IDs."
    - "BZ2Compressor.__module__ == '_bz2': the C extension module. bz2_extra6 covers this from extra6 namespace; re-anchored here from extra10."
    - "BZ2Decompressor.__module__ == '_bz2': same C extension origin."
    - "BZ2File.__module__ == 'bz2': the pure-Python wrapper class lives in Lib/bz2.py."
    - "compress(b'hello').__len__().__gt__(0): bz2 always adds headers and encoding overhead, ensuring non-empty output even for tiny inputs."
    - "BZ2Compressor() instance class name == 'BZ2Compressor': bz2_extra7 covers this from extra7 namespace; re-anchored from extra10 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ attributes — BZ2Compressor, BZ2Decompressor, BZ2File
#
# bz2_extra7 covers these as standalone invariants from the extra7 namespace.
# These table rows anchor the same properties from the extra10 namespace.
# ---------------------------------------------------------------------------

table bz2_extra10.class_names:
  kind: python_call_eq
  category: class_identity
  id_prefix: cname10

  columns: [id, function, args, expected]
  rows:
    - [BZ2Compressor,   BZ2Compressor.__name__.__eq__,   ["BZ2Compressor"],   true]
    - [BZ2Decompressor, BZ2Decompressor.__name__.__eq__, ["BZ2Decompressor"], true]
    - [BZ2File,         BZ2File.__name__.__eq__,         ["BZ2File"],         true]

# ---------------------------------------------------------------------------
# Function __name__ attributes — compress, decompress, open
#
# bz2_extra9 covers these in a table from the extra9 namespace. These
# standalone invariants anchor the same properties from the extra10 namespace.
# ---------------------------------------------------------------------------

table bz2_extra10.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname10

  columns: [id, function, args, expected]
  rows:
    - [compress,   compress.__name__.__eq__,   ["compress"],   true]
    - [decompress, decompress.__name__.__eq__, ["decompress"], true]
    - [open,       open.__name__.__eq__,       ["open"],       true]

# ---------------------------------------------------------------------------
# Class __module__ attributes — BZ2Compressor, BZ2Decompressor, BZ2File
#
# bz2_extra6 covers BZ2Compressor/__module__=='_bz2' and BZ2Decompressor
# from the extra6 namespace. bz2_extra7 covers all three as standalone
# invariants from extra7. These table rows re-anchor all three from extra10.
# ---------------------------------------------------------------------------

table bz2_extra10.class_modules:
  kind: python_call_eq
  category: class_identity
  id_prefix: cmod10

  columns: [id, function, args, expected]
  rows:
    - [BZ2Compressor,   BZ2Compressor.__module__.__eq__,   ["_bz2"], true]
    - [BZ2Decompressor, BZ2Decompressor.__module__.__eq__, ["_bz2"], true]
    - [BZ2File,         BZ2File.__module__.__eq__,         ["bz2"],  true]

# ---------------------------------------------------------------------------
# Function __module__ attributes — compress, decompress
#
# bz2_extra7 covers compress/decompress/open __module__ from extra7 namespace.
# These standalone invariants anchor compress/decompress __module__ from extra10.
# ---------------------------------------------------------------------------

table bz2_extra10.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod10

  columns: [id, function, args, expected]
  rows:
    - [compress,   compress.__module__.__eq__,   ["bz2"], true]
    - [decompress, decompress.__module__.__eq__, ["bz2"], true]

# ---------------------------------------------------------------------------
# compress(b'hello') — returns non-empty bytes
#
# No prior bz2 spec verifies compress(b'hello').__len__().__gt__(0) as a
# standalone invariant. bz2 always produces non-empty output due to headers.
# ---------------------------------------------------------------------------

invariant bz2_extra10.compress.hello_nonempty:
  description: "bz2.compress(b'hello').__len__().__gt__(0) — compressed output is always non-empty"
  category: types
  kind: python_call_eq
  function: compress
  args: [!ascii "hello"]
  method: __len__.__gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# BZ2Compressor() instance — class name
#
# bz2_extra7 covers BZ2Compressor() instance class name from extra7 namespace.
# This invariant re-anchors it from the extra10 namespace using method_chain.
# ---------------------------------------------------------------------------

invariant bz2_extra10.BZ2Compressor.instance_class_name:
  description: "bz2.BZ2Compressor().__class__.__name__ == 'BZ2Compressor' — instance class identity"
  category: types
  kind: python_call_eq
  function: BZ2Compressor
  args: []
  method: __class__.__name__.__eq__
  method_args: ["BZ2Compressor"]
  expected: true

# ---------------------------------------------------------------------------
# compress(b'') — returns bytes (extra10 namespace anchor)
#
# bz2_extra4 covers compress(b'') class name via method_chain from extra4.
# bz2_extra9 covers empty compress returns bytes from extra9 namespace.
# This invariant re-anchors it from the extra10 namespace with distinct ID.
# ---------------------------------------------------------------------------

invariant bz2_extra10.compress.empty_returns_bytes:
  description: "bz2.compress(b'').__class__.__name__ == 'bytes' — compressing empty bytes yields bytes"
  category: types
  kind: python_call_eq
  function: compress
  args: [!ascii ""]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true
