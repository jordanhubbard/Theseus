spec: uuid_extra213
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.uuid1.__qualname__ == 'uuid1' (5 chars)."
    - "uuid.uuid3.__qualname__ == 'uuid3' (5 chars)."
    - "uuid.uuid4.__qualname__ == 'uuid4' (5 chars)."
    - "uuid.uuid5.__qualname__ == 'uuid5' (5 chars)."
    - "uuid.UUID.__qualname__ == 'UUID' (4 chars)."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__' (12 chars)."
    - "uuid.UUID.__repr__.__qualname__ == 'UUID.__repr__' (13 chars)."
    - "uuid.UUID.__eq__.__qualname__ == 'UUID.__eq__' (11 chars)."
    - "uuid.UUID.__hash__.__qualname__ == 'UUID.__hash__' (13 chars)."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid generator function __qualname__.__len__() checks
#
# uuid.uuid1.__qualname__.__len__() == 5  ('uuid1')
# uuid.uuid3.__qualname__.__len__() == 5  ('uuid3')
# uuid.uuid4.__qualname__.__len__() == 5  ('uuid4')
# uuid.uuid5.__qualname__.__len__() == 5  ('uuid5')
# uuid.UUID.__qualname__.__len__()  == 4  ('UUID')
# ---------------------------------------------------------------------------

table uuid_extra213.generator_func_qualname_lengths:
  description: "uuid generator function __qualname__.__len__() checks in uuid213 namespace — wave 213 theme: uuid1/uuid3/uuid4/uuid5 all have qualname length 5 (matching their function name); UUID class qualname is 4 chars; these are pure Python functions so qualname equals __name__; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuid213

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_qualname_len,  uuid.uuid1.__qualname__.__len__, [], 5, "uuid.uuid1.__qualname__.__len__() == 5 — qualname 'uuid1' is 5 characters"]
    - [uuid3_qualname_len,  uuid.uuid3.__qualname__.__len__, [], 5, "uuid.uuid3.__qualname__.__len__() == 5 — qualname 'uuid3' is 5 characters"]
    - [uuid4_qualname_len,  uuid.uuid4.__qualname__.__len__, [], 5, "uuid.uuid4.__qualname__.__len__() == 5 — qualname 'uuid4' is 5 characters"]
    - [uuid5_qualname_len,  uuid.uuid5.__qualname__.__len__, [], 5, "uuid.uuid5.__qualname__.__len__() == 5 — qualname 'uuid5' is 5 characters"]
    - [UUID_qualname_len,   uuid.UUID.__qualname__.__len__,  [], 4, "uuid.UUID.__qualname__.__len__() == 4 — class qualname 'UUID' is 4 characters"]

# ---------------------------------------------------------------------------
# uuid.UUID method __qualname__.__len__() checks
#
# uuid.UUID.__str__.__qualname__.__len__()   == 12  ('UUID.__str__')
# uuid.UUID.__repr__.__qualname__.__len__()  == 13  ('UUID.__repr__')
# uuid.UUID.__eq__.__qualname__.__len__()    == 11  ('UUID.__eq__')
# uuid.UUID.__hash__.__qualname__.__len__()  == 13  ('UUID.__hash__')
# ---------------------------------------------------------------------------

table uuid_extra213.UUID_method_qualname_lengths:
  description: "uuid.UUID method __qualname__.__len__() checks in uuid213a namespace — wave 213 theme: UUID.__str__ qualname is 12 chars; UUID.__repr__ is 13 chars; UUID.__eq__ is 11 chars; UUID.__hash__ is 13 chars; all methods carry the 'UUID.' prefix (5 chars); these are pure Python dunder methods; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuid213a

  columns: [id, function, args, expected, description]
  rows:
    - [UUID_str_qualname_len,    uuid.UUID.__str__.__qualname__.__len__,    [], 12, "uuid.UUID.__str__.__qualname__.__len__() == 12 — 'UUID.__str__' is 12 characters"]
    - [UUID_repr_qualname_len,   uuid.UUID.__repr__.__qualname__.__len__,   [], 13, "uuid.UUID.__repr__.__qualname__.__len__() == 13 — 'UUID.__repr__' is 13 characters"]
    - [UUID_eq_qualname_len,     uuid.UUID.__eq__.__qualname__.__len__,     [], 11, "uuid.UUID.__eq__.__qualname__.__len__() == 11 — 'UUID.__eq__' is 11 characters"]
    - [UUID_hash_qualname_len,   uuid.UUID.__hash__.__qualname__.__len__,   [], 13, "uuid.UUID.__hash__.__qualname__.__len__() == 13 — 'UUID.__hash__' is 13 characters"]

# ---------------------------------------------------------------------------
# uuid function and UUID method __qualname__ equality checks
#
# uuid.uuid1.__qualname__.__eq__('uuid1')          == True
# uuid.uuid4.__qualname__.__eq__('uuid4')          == True
# uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__') == True
# uuid.UUID.__repr__.__qualname__.__eq__('UUID.__repr__') == True
# uuid.UUID.__hash__.__qualname__.__eq__('UUID.__hash__') == True
# ---------------------------------------------------------------------------

invariant uuid_extra213.uuid1_qualname_eq:
  description: "uuid.uuid1.__qualname__.__eq__('uuid1') == True — uuid1 is a top-level pure Python function; its qualname equals its name 'uuid1'; generates RFC 4122 version-1 (time-based) UUIDs; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "uuid.uuid1.__qualname__.__eq__"
  args: ["uuid1"]
  expected: true

invariant uuid_extra213.uuid4_qualname_eq:
  description: "uuid.uuid4.__qualname__.__eq__('uuid4') == True — uuid4 is a top-level pure Python function; its qualname equals its name 'uuid4'; generates RFC 4122 version-4 (random) UUIDs; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "uuid.uuid4.__qualname__.__eq__"
  args: ["uuid4"]
  expected: true

invariant uuid_extra213.UUID_str_qualname_eq:
  description: "uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__') == True — UUID.__str__ is a method of the UUID class; qualified name 'UUID.__str__' correctly names the class and method; returns 'xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx' format; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "uuid.UUID.__str__.__qualname__.__eq__"
  args: ["UUID.__str__"]
  expected: true

invariant uuid_extra213.UUID_repr_qualname_eq:
  description: "uuid.UUID.__repr__.__qualname__.__eq__('UUID.__repr__') == True — UUID.__repr__ is a method of the UUID class; qualified name is 'UUID.__repr__'; returns 'UUID(...)' representation; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "uuid.UUID.__repr__.__qualname__.__eq__"
  args: ["UUID.__repr__"]
  expected: true

invariant uuid_extra213.UUID_hash_qualname_eq:
  description: "uuid.UUID.__hash__.__qualname__.__eq__('UUID.__hash__') == True — UUID.__hash__ is a method of the UUID class; qualified name is 'UUID.__hash__'; UUID objects are hashable; verified with Python 3.14.3"
  category: function_identity
  kind: python_call_eq
  function: "uuid.UUID.__hash__.__qualname__.__eq__"
  args: ["UUID.__hash__"]
  expected: true
