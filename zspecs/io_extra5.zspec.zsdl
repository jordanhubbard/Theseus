spec: io_extra5
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "Extends io.zspec.zsdl, io_extra.zspec.zsdl, io_extra2.zspec.zsdl, io_extra3.zspec.zsdl, io_extra4.zspec.zsdl."
    - "io.zspec.zsdl covers: class names (BytesIO, StringIO, TextIOWrapper, BufferedReader, BufferedWriter, BufferedRandom, RawIOBase, FileIO, IOBase, BufferedIOBase, TextIOBase, UnsupportedOperation), BytesIO/StringIO read/write/getvalue/tell/seek, io.DEFAULT_BUFFER_SIZE value (8192)."
    - "io_extra.zspec.zsdl covers: DEFAULT_BUFFER_SIZE type/positive, SEEK_* type checks, TextIOWrapper/BufferedRandom class metadata and bases, UnsupportedOperation name/module/is_type."
    - "io_extra2.zspec.zsdl covers: IOBase/__name__, IOBase/__module__, RawIOBase/__name__, BufferedIOBase/__name__, TextIOBase/__name__, FileIO/__name__, BufferedReader/__name__, BufferedWriter/__name__, BufferedRWPair/__name__, IncrementalNewlineDecoder/__name__."
    - "io_extra3.zspec.zsdl covers: open/__name__, UnsupportedOperation bases count and names, FileIO/StringIO/BytesIO base class names."
    - "io_extra4.zspec.zsdl covers: IOBase/RawIOBase/BufferedIOBase/TextIOBase/StringIO/BytesIO/FileIO/BufferedReader/BufferedWriter __module__ and is_type checks."
    - "This spec adds: BytesIO().readable()/writable()/seekable() == True, StringIO().readable()/writable()/seekable() == True, BytesIO(b'hello').read(3) == b'hel', StringIO('hello').read(3) == 'hel', SEEK_SET/SEEK_CUR/SEEK_END values."
    - "io.BytesIO() is both readable and writable because it is an in-memory random-access buffer."
    - "io.StringIO() is both readable and writable because it is an in-memory text buffer."
    - "io.SEEK_SET == 0, io.SEEK_CUR == 1, io.SEEK_END == 2 — these match POSIX lseek whence constants and are identical to the os module's SEEK_* constants."
    - "BytesIO(b'hello').read(3) returns the first 3 bytes b'hel'; position advances to offset 3."
    - "StringIO('hello').read(3) returns the first 3 characters 'hel'; position advances to offset 3."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# BytesIO capability methods — readable / writable / seekable
#
# An io.BytesIO() instance supports all three capabilities because it is an
# in-memory buffer with no underlying file descriptor restrictions.
# ---------------------------------------------------------------------------

invariant io_extra5.BytesIO.readable:
  description: "io.BytesIO().readable() == True — in-memory buffer is always readable"
  category: BytesIO_capabilities
  kind: python_call_eq
  function: BytesIO
  args: []
  method: readable
  expected: true

invariant io_extra5.BytesIO.writable:
  description: "io.BytesIO().writable() == True — in-memory buffer is always writable"
  category: BytesIO_capabilities
  kind: python_call_eq
  function: BytesIO
  args: []
  method: writable
  expected: true

invariant io_extra5.BytesIO.seekable:
  description: "io.BytesIO().seekable() == True — in-memory buffer is always seekable"
  category: BytesIO_capabilities
  kind: python_call_eq
  function: BytesIO
  args: []
  method: seekable
  expected: true

# ---------------------------------------------------------------------------
# StringIO capability methods — readable / writable / seekable
#
# An io.StringIO() instance supports all three capabilities because it is an
# in-memory text buffer with no underlying file descriptor restrictions.
# ---------------------------------------------------------------------------

invariant io_extra5.StringIO.readable:
  description: "io.StringIO().readable() == True — in-memory text buffer is always readable"
  category: StringIO_capabilities
  kind: python_call_eq
  function: StringIO
  args: []
  method: readable
  expected: true

invariant io_extra5.StringIO.writable:
  description: "io.StringIO().writable() == True — in-memory text buffer is always writable"
  category: StringIO_capabilities
  kind: python_call_eq
  function: StringIO
  args: []
  method: writable
  expected: true

invariant io_extra5.StringIO.seekable:
  description: "io.StringIO().seekable() == True — in-memory text buffer is always seekable"
  category: StringIO_capabilities
  kind: python_call_eq
  function: StringIO
  args: []
  method: seekable
  expected: true

# ---------------------------------------------------------------------------
# BytesIO partial read — read(n) returns exactly n bytes from the initial position
#
# BytesIO(b'hello').read(3) == b'hel' — the first 3 bytes are returned.
# ---------------------------------------------------------------------------

invariant io_extra5.BytesIO.read_partial:
  description: "io.BytesIO(b'hello').read(3) == b'hel' — partial read of 3 bytes from position 0"
  category: BytesIO_read
  kind: python_call_eq
  function: BytesIO
  args: [{type: bytes_ascii, value: "hello"}]
  method: read
  method_args: [3]
  expected: {type: bytes_ascii, value: "hel"}

# ---------------------------------------------------------------------------
# StringIO partial read — read(n) returns exactly n characters from the initial position
#
# StringIO('hello').read(3) == 'hel' — the first 3 characters are returned.
# ---------------------------------------------------------------------------

invariant io_extra5.StringIO.read_partial:
  description: "io.StringIO('hello').read(3) == 'hel' — partial read of 3 characters from position 0"
  category: StringIO_read
  kind: python_call_eq
  function: StringIO
  args: ["hello"]
  method: read
  method_args: [3]
  expected: "hel"

# ---------------------------------------------------------------------------
# Seek constants — SEEK_SET / SEEK_CUR / SEEK_END
#
# These constants are defined in the io module and match POSIX lseek whence values.
# They are also used as arguments to the seek() method on all io stream objects.
# ---------------------------------------------------------------------------

invariant io_extra5.SEEK_SET.value:
  description: "io.SEEK_SET == 0 — seek from beginning of stream"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra5.SEEK_SET.is_int:
  description: "io.SEEK_SET.__class__.__name__ == 'int' — seek constant is a plain int"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_SET.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra5.SEEK_CUR.value:
  description: "io.SEEK_CUR == 1 — seek from current stream position"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_CUR.__eq__
  args: [1]
  expected: true

invariant io_extra5.SEEK_CUR.is_int:
  description: "io.SEEK_CUR.__class__.__name__ == 'int' — seek constant is a plain int"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_CUR.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant io_extra5.SEEK_END.value:
  description: "io.SEEK_END == 2 — seek from end of stream"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_END.__eq__
  args: [2]
  expected: true

invariant io_extra5.SEEK_END.is_int:
  description: "io.SEEK_END.__class__.__name__ == 'int' — seek constant is a plain int"
  category: seek_constants
  kind: python_call_eq
  function: SEEK_END.__class__.__name__.__eq__
  args: ["int"]
  expected: true
