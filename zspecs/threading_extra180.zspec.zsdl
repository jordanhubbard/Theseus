spec: threading_extra180
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Condition method names — threading.Condition.wait.__name__=='wait' (len=4); threading.Condition.wait_for.__name__=='wait_for' (len=8); threading.Condition.notify.__name__=='notify' (len=6); threading.Condition.notify_all.__name__=='notify_all' (len=10); threading.Condition.__enter__.__name__=='__enter__' (len=9); threading.Condition.__exit__.__name__=='__exit__' (len=8); threading.Condition.notifyAll.__name__=='notifyAll' (len=9; same as __enter__); threading.Condition.__class__.__name__=='type'."
    - "threading.Condition.acquire and .release are not class-level attributes on Condition; they are delegated to the underlying lock at instance creation time and are not accessible via the class object. Only wait, wait_for, notify, notify_all, __enter__, __exit__, and notifyAll exist as class-level attributes."
    - "threading.Condition.wait.__name__ == 'wait' — wait is a Python method on threading.Condition in Lib/threading.py that releases the underlying lock and waits until notified or until a timeout elapses, then re-acquires the lock; its __name__ is 'wait', 4 characters. Verified with Python 3.14.3."
    - "threading.Condition.wait_for.__name__ == 'wait_for' — wait_for is a Python method on threading.Condition in Lib/threading.py that waits until a predicate becomes true; its __name__ is 'wait_for', 8 characters. Verified with Python 3.14.3."
    - "threading.Condition.notify.__name__ == 'notify' — notify is a Python method on threading.Condition in Lib/threading.py that wakes up one thread waiting on the condition; its __name__ is 'notify', 6 characters. Verified with Python 3.14.3."
    - "threading.Condition.notify_all.__name__ == 'notify_all' — notify_all is a Python method on threading.Condition in Lib/threading.py that wakes up all threads waiting on the condition; its __name__ is 'notify_all', 10 characters (the longest Condition method name in this spec). Verified with Python 3.14.3."
    - "threading.Condition.__enter__.__name__ == '__enter__' — __enter__ is a Python method on threading.Condition in Lib/threading.py implementing the context manager entry point (acquires the underlying lock); its __name__ is '__enter__', 9 characters. Verified with Python 3.14.3."
    - "threading.Condition.__exit__.__name__ == '__exit__' — __exit__ is a Python method on threading.Condition in Lib/threading.py implementing the context manager exit point (releases the lock regardless of exception); its __name__ is '__exit__', 8 characters. Verified with Python 3.14.3."
    - "threading.Condition.notifyAll.__name__ == 'notifyAll' — notifyAll is a deprecated alias for notify_all on threading.Condition in Lib/threading.py; its __name__ is 'notifyAll', 9 characters, same length as '__enter__'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Condition.wait and .wait_for __name__
#
# threading.Condition.wait.__name__ == 'wait'
# threading.Condition.wait.__name__.__len__() == 4
# threading.Condition.wait_for.__name__ == 'wait_for'
# threading.Condition.wait_for.__name__.__len__() == 8
#
# wait (4 chars) blocks until notified or timeout. wait_for (8 chars) blocks
# until a predicate becomes true. New to extra180.
# ---------------------------------------------------------------------------

table threading_extra180.condition_wait_and_wait_for:
  description: "threading.Condition.wait.__name__ 'wait' len 4; wait_for.__name__ 'wait_for' len 8; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: threadingcond180

  columns: [id, function, args, expected, description]
  rows:
    - [cond_wait_name_eq,
       "Condition.wait.__name__.__eq__",
       ["wait"],
       true,
       "threading.Condition.wait.__name__.__eq__('wait') == True — threading.Condition.wait is a Python method in Lib/threading.py that releases the underlying lock, waits until notified by another thread or until the optional timeout elapses, then re-acquires the lock; its __name__ is 'wait'; str.__eq__('wait') returns True; new to extra180"]
    - [cond_wait_name_len_4,
       "Condition.wait.__name__.__len__",
       [],
       4,
       "threading.Condition.wait.__name__.__len__() == 4 — the name 'wait' has exactly 4 characters: w-a-i-t; str.__len__() returns 4; new to extra180"]
    - [cond_wait_for_name_eq,
       "Condition.wait_for.__name__.__eq__",
       ["wait_for"],
       true,
       "threading.Condition.wait_for.__name__.__eq__('wait_for') == True — threading.Condition.wait_for is a Python method in Lib/threading.py that waits until a supplied predicate function returns a true value, re-checking each time it is notified; its __name__ is 'wait_for'; str.__eq__('wait_for') returns True; new to extra180"]
    - [cond_wait_for_name_len_8,
       "Condition.wait_for.__name__.__len__",
       [],
       8,
       "threading.Condition.wait_for.__name__.__len__() == 8 — the name 'wait_for' has exactly 8 characters: w-a-i-t-_-f-o-r; str.__len__() returns 8; new to extra180"]

# ---------------------------------------------------------------------------
# Table 2: threading.Condition.notify and .notify_all __name__
#
# threading.Condition.notify.__name__ == 'notify'
# threading.Condition.notify.__name__.__len__() == 6
# threading.Condition.notify_all.__name__ == 'notify_all'
# threading.Condition.notify_all.__name__.__len__() == 10
#
# notify (6 chars) wakes one waiting thread. notify_all (10 chars — longest
# Condition method in spec) wakes all waiting threads. New to extra180.
# ---------------------------------------------------------------------------

table threading_extra180.condition_notify_and_notify_all:
  description: "threading.Condition.notify.__name__ 'notify' len 6; notify_all.__name__ 'notify_all' len 10 (longest); new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: threadingcond180

  columns: [id, function, args, expected, description]
  rows:
    - [cond_notify_name_eq,
       "Condition.notify.__name__.__eq__",
       ["notify"],
       true,
       "threading.Condition.notify.__name__.__eq__('notify') == True — threading.Condition.notify is a Python method in Lib/threading.py that wakes up one or more threads waiting on the condition variable (caller must hold the lock); its __name__ is 'notify'; str.__eq__('notify') returns True; new to extra180"]
    - [cond_notify_name_len_6,
       "Condition.notify.__name__.__len__",
       [],
       6,
       "threading.Condition.notify.__name__.__len__() == 6 — the name 'notify' has exactly 6 characters: n-o-t-i-f-y; str.__len__() returns 6; new to extra180"]
    - [cond_notify_all_name_eq,
       "Condition.notify_all.__name__.__eq__",
       ["notify_all"],
       true,
       "threading.Condition.notify_all.__name__.__eq__('notify_all') == True — threading.Condition.notify_all is a Python method in Lib/threading.py that wakes all threads waiting on the condition variable (caller must hold the lock); its __name__ is 'notify_all'; str.__eq__('notify_all') returns True; new to extra180"]
    - [cond_notify_all_name_len_10,
       "Condition.notify_all.__name__.__len__",
       [],
       10,
       "threading.Condition.notify_all.__name__.__len__() == 10 — the name 'notify_all' has exactly 10 characters: n-o-t-i-f-y-_-a-l-l; this is the longest Condition method name covered in this spec; str.__len__() returns 10; new to extra180"]

# ---------------------------------------------------------------------------
# Table 3: threading.Condition.__enter__, .__exit__, and .notifyAll __name__
#
# threading.Condition.__enter__.__name__ == '__enter__'
# threading.Condition.__enter__.__name__.__len__() == 9
# threading.Condition.__exit__.__name__ == '__exit__'
# threading.Condition.__exit__.__name__.__len__() == 8
# threading.Condition.notifyAll.__name__ == 'notifyAll'
#
# __enter__ (9 chars) implements context manager entry (acquires the lock).
# __exit__ (8 chars) implements context manager exit (releases the lock).
# notifyAll (9 chars — deprecated alias for notify_all, same length as __enter__)
# is the older camelCase form. New to extra180.
# ---------------------------------------------------------------------------

table threading_extra180.condition_enter_exit_notifyall:
  description: "threading.Condition.__enter__.__name__ '__enter__' len 9; __exit__ len 8; notifyAll.__name__ 'notifyAll' len 9 (same as __enter__); new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: threadingcond180

  columns: [id, function, args, expected, description]
  rows:
    - [cond_enter_name_eq,
       "Condition.__enter__.__name__.__eq__",
       ["__enter__"],
       true,
       "threading.Condition.__enter__.__name__.__eq__('__enter__') == True — threading.Condition.__enter__ is a Python method in Lib/threading.py implementing the context manager entry point (acquires the condition's underlying lock); its __name__ is '__enter__'; str.__eq__('__enter__') returns True; new to extra180"]
    - [cond_enter_name_len_9,
       "Condition.__enter__.__name__.__len__",
       [],
       9,
       "threading.Condition.__enter__.__name__.__len__() == 9 — the name '__enter__' has exactly 9 characters: _-_-e-n-t-e-r-_-_; str.__len__() returns 9; new to extra180"]
    - [cond_exit_name_eq,
       "Condition.__exit__.__name__.__eq__",
       ["__exit__"],
       true,
       "threading.Condition.__exit__.__name__.__eq__('__exit__') == True — threading.Condition.__exit__ is a Python method in Lib/threading.py implementing the context manager exit point (releases the condition's underlying lock regardless of exception); its __name__ is '__exit__'; str.__eq__('__exit__') returns True; new to extra180"]
    - [cond_exit_name_len_8,
       "Condition.__exit__.__name__.__len__",
       [],
       8,
       "threading.Condition.__exit__.__name__.__len__() == 8 — the name '__exit__' has exactly 8 characters: _-_-e-x-i-t-_-_; str.__len__() returns 8; new to extra180"]

