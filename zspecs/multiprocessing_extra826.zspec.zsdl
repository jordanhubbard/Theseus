spec: multiprocessing_extra826
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython multiprocessing source"
    - "Python docs: multiprocessing.Value and Array"
    - "Python docs: multiprocessing.pool.Pool"
  not_derived_from:
    - "any third-party process pool library"
  notes:
    - "Covers Value and Array top-level qualnames"
    - "Covers Pool method qualnames including context manager protocol"
    - "Covers Pool.apply_async in addition to synchronous variants"
  created_at: "2026-04-12"

table multiprocessing_extra826.shared_memory_qualnames:
  description: "multiprocessing.Value and Array __qualname__ identity checks"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: mp826sm
  columns: [id, function, args, expected]
  rows:
    - [mp826sm001, multiprocessing.Value.__qualname__.__eq__, ["Value"], true]
    - [mp826sm002, multiprocessing.Array.__qualname__.__eq__, ["Array"], true]

table multiprocessing_extra826.pool_qualnames:
  description: "multiprocessing.pool.Pool method __qualname__ identity checks"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: mp826pl
  columns: [id, function, args, expected]
  rows:
    - [mp826pl001, multiprocessing.pool.Pool.__init__.__qualname__.__eq__, ["Pool.__init__"], true]
    - [mp826pl002, multiprocessing.pool.Pool.apply.__qualname__.__eq__, ["Pool.apply"], true]
    - [mp826pl003, multiprocessing.pool.Pool.map.__qualname__.__eq__, ["Pool.map"], true]
    - [mp826pl004, multiprocessing.pool.Pool.starmap.__qualname__.__eq__, ["Pool.starmap"], true]
    - [mp826pl005, multiprocessing.pool.Pool.close.__qualname__.__eq__, ["Pool.close"], true]
    - [mp826pl006, multiprocessing.pool.Pool.terminate.__qualname__.__eq__, ["Pool.terminate"], true]
    - [mp826pl007, multiprocessing.pool.Pool.join.__qualname__.__eq__, ["Pool.join"], true]
    - [mp826pl008, multiprocessing.pool.Pool.__enter__.__qualname__.__eq__, ["Pool.__enter__"], true]
    - [mp826pl009, multiprocessing.pool.Pool.__exit__.__qualname__.__eq__, ["Pool.__exit__"], true]
    - [mp826pl010, multiprocessing.pool.Pool.apply_async.__qualname__.__eq__, ["Pool.apply_async"], true]
