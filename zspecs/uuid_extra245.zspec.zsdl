spec: uuid_extra245
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 245 theme: uuid module identity and UUID constructor/string method identity."
    - "uuid.__name__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__package__ == ''. uuid is a top-level stdlib module; __package__ is empty string. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid has no __all__. hasattr(uuid, '__all__') is False. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__qualname__ == 'UUID.__init__'. Confirmed Python function defined directly on UUID class. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__module__ == 'uuid'. __init__ is defined in Lib/uuid.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__name__ == '__str__'. UUID.__str__ is a Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__qualname__ == 'UUID.__str__'. Defined directly on the UUID class. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID(int=0).__class__.__name__ == 'UUID'. Constructing UUID with int=0 returns a UUID instance. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "str(uuid.UUID(int=0)) == '00000000-0000-0000-0000-000000000000'. Zero-integer UUID formats as 32 hex zeros in canonical hyphenated form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID(hex='12345678123456781234567812345678').__class__.__name__ == 'UUID'. Hex constructor also returns a UUID instance. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid has no __all__ attribute (hasattr returns False). The uuid module does not define __all__, so 'from uuid import *' would import all public names."
    - "Note: uuid.__package__ == '' (empty string) — uuid is a standalone module, not a package."
    - "Note: UUID(int=0) creates the all-zeros UUID, formatted as '00000000-0000-0000-0000-000000000000' with 5 hyphen-separated groups."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.__name__.__eq__('uuid')
# uuid.__package__.__eq__('')
#
# Wave 245 theme: uuid module identity attributes.
#
# uuid.__name__ is 'uuid' (the module's import name). uuid.__package__ is ''
# (empty string) because uuid is a standalone top-level stdlib module, not a
# package. Unlike package modules (e.g., email) where __package__ equals the
# package name, top-level modules have __package__ == ''.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra245.module_identity:
  description: "uuid module identity attributes — __name__.__eq__('uuid')==True / __package__.__eq__('')==True — uuid is a top-level stdlib module for UUID generation and parsing; __package__ is empty string (not 'uuid') because it is a standalone module not a package; wave 245 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmod245

  columns: [id, function, args, expected, description]
  rows:
    - [module_name,  __name__.__eq__,     ["uuid"], true, "uuid.__name__ == 'uuid'; top-level stdlib module name for UUID generation and parsing"]
    - [module_pkg,   __package__.__eq__,  [""],     true, "uuid.__package__ == ''; standalone module, not a package (__package__ is empty string)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__')
# uuid.UUID.__init__.__module__.__eq__('uuid')
# uuid.UUID.__str__.__name__.__eq__('__str__')
# uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__')
#
# Wave 245 theme: UUID constructor and string method identity.
#
# UUID is a pure Python class defined in Lib/uuid.py. UUID.__init__ is the
# constructor method that accepts named arguments (hex, bytes, bytes_le,
# fields, int, version, is_safe). Its __qualname__ is 'UUID.__init__' and
# __module__ is 'uuid'. UUID.__str__ returns the canonical hyphenated UUID
# string form; its __name__ is '__str__' and __qualname__ is 'UUID.__str__'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra245.UUID_constructor_str_identity:
  description: "UUID constructor and string method identity — UUID.__init__.__qualname__.__eq__('UUID.__init__')==True / UUID.__init__.__module__.__eq__('uuid')==True / UUID.__str__.__name__.__eq__('__str__')==True / UUID.__str__.__qualname__.__eq__('UUID.__str__')==True — UUID is pure Python (Lib/uuid.py); __init__ accepts hex/bytes/int/fields/version/is_safe kwargs; __str__ returns canonical hyphenated form; wave 245 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: uuidctor245

  columns: [id, function, args, expected, description]
  rows:
    - [init_qualname,  UUID.__init__.__qualname__.__eq__,  ["UUID.__init__"],  true, "UUID.__init__.__qualname__ == 'UUID.__init__'; defined directly on UUID class in Lib/uuid.py"]
    - [init_module,    UUID.__init__.__module__.__eq__,    ["uuid"],           true, "UUID.__init__.__module__ == 'uuid'; __init__ is defined in Lib/uuid.py (pure Python)"]
    - [str_name,       UUID.__str__.__name__.__eq__,       ["__str__"],        true, "UUID.__str__.__name__ == '__str__'; Python-defined string representation method"]
    - [str_qualname,   UUID.__str__.__qualname__.__eq__,   ["UUID.__str__"],   true, "UUID.__str__.__qualname__ == 'UUID.__str__'; defined directly on UUID class"]

# ---------------------------------------------------------------------------
# uuid.UUID(int=0).__class__.__name__.__eq__('UUID')
# uuid.UUID(hex='12345678123456781234567812345678').__class__.__name__.__eq__('UUID')
#
# Wave 245 theme: UUID constructor return type identity.
#
# UUID(int=0) constructs the all-zeros UUID from an integer argument.
# UUID(hex='12345678123456781234567812345678') constructs from a 32-char hex
# string. Both return UUID instances — type(result).__name__ is 'UUID'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra245.UUID_constructor_return_type:
  description: "UUID constructor return type identity — UUID(int=0).__class__.__name__.__eq__('UUID')==True / UUID(hex='12345678123456781234567812345678').__class__.__name__.__eq__('UUID')==True — both int= and hex= constructor forms return UUID instances; UUID(int=0) is the all-zeros UUID; hex= accepts 32-char hex string without hyphens; wave 245 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidctor245

  columns: [id, function, args, expected, description]
  rows:
    - [int0_type,  "UUID(int=0).__class__.__name__.__eq__",                              ["UUID"], true, "UUID(int=0).__class__.__name__ == 'UUID'; int= kwarg constructs the all-zeros UUID"]
    - [hex_type,   "UUID(hex='12345678123456781234567812345678').__class__.__name__.__eq__", ["UUID"], true, "UUID(hex='12345678123456781234567812345678').__class__.__name__ == 'UUID'; hex= kwarg constructs UUID from 32-char hex string"]

# ---------------------------------------------------------------------------
# uuid.__name__.__eq__('uuid') — standalone
#
# uuid.__name__ is 'uuid'. The uuid module provides immutable UUID objects as
# defined in RFC 4122. It supports generating UUIDs of versions 1 (time-based),
# 3 (MD5 name-based), 4 (random), and 5 (SHA-1 name-based) via uuid1(), uuid3(),
# uuid4(), and uuid5() respectively. The UUID class is a pure Python class
# defined in Lib/uuid.py (with optional C acceleration via _uuid). __name__
# equals the module's import name 'uuid'. This is the first standalone anchor
# for uuid.__name__ under uuidmod245. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra245.module_name_is_uuid:
  description: "uuid.__name__.__eq__('uuid') == True — uuid provides immutable UUID objects (RFC 4122); supports uuid1/uuid3/uuid4/uuid5 generation; UUID is a pure Python class in Lib/uuid.py; __name__=='uuid' equals the import name; first standalone for uuid.__name__ under uuidmod245; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') — standalone
#
# uuid.UUID.__init__.__qualname__ is 'UUID.__init__'. UUID.__init__ is the
# constructor for UUID objects. It accepts exactly one of the keyword arguments:
# hex (32-char hex string), bytes (16-byte big-endian bytes object),
# bytes_le (16-byte little-endian bytes), fields (6-tuple of integers), or
# int (128-bit integer). An optional version argument (1-5) sets the variant
# and version bits. The __qualname__ 'UUID.__init__' confirms it is defined
# directly on the UUID class, not inherited or nested. This is the first
# standalone anchor for UUID.__init__.__qualname__ under uuidctor245.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra245.UUID_init_qualname:
  description: "uuid.UUID.__init__.__qualname__.__eq__('UUID.__init__') == True — UUID.__init__ accepts exactly one of hex/bytes/bytes_le/fields/int kwargs plus optional version; sets variant and version bits when version is given; __qualname__=='UUID.__init__' confirms direct definition on UUID class (not inherited); first standalone for UUID.__init__.__qualname__ under uuidctor245; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: UUID.__init__.__qualname__.__eq__
  args: ["UUID.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__') — standalone
#
# uuid.UUID.__str__.__qualname__ is 'UUID.__str__'. UUID.__str__ returns the
# UUID in the canonical RFC 4122 hyphenated format: eight hex digits, followed
# by three groups of four hex digits, followed by twelve hex digits, all
# separated by hyphens (e.g., '12345678-1234-5678-1234-567812345678').
# The total string length is always 36 characters. UUID.__str__ is a Python
# function and its __qualname__ confirms it is defined directly on the UUID class.
# This is the first standalone anchor for UUID.__str__.__qualname__ under
# uuidctor245. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra245.UUID_str_qualname:
  description: "uuid.UUID.__str__.__qualname__.__eq__('UUID.__str__') == True — UUID.__str__ returns canonical RFC 4122 hyphenated form (36 chars: 8-4-4-4-12 hex groups with hyphens); Python function defined directly on UUID class; __qualname__=='UUID.__str__'; first standalone for UUID.__str__.__qualname__ under uuidctor245; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: UUID.__str__.__qualname__.__eq__
  args: ["UUID.__str__"]
  expected: true
