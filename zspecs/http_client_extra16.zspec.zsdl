spec: http_client_extra16
version: ">=3.9"
backend: python_module(http.client)

docs: https://docs.python.org/3/library/http.client.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/http.client.html — Python http.client module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/client.py"
    - "http_client_extra15.zspec.zsdl — covers HTTPConnection.__init__.__name__, HTTPResponse.__bases__[0].__name__, NotConnected/InvalidURL __name__/__bases__[0].__name__, UnknownProtocol/__name__, RemoteDisconnected/__name__/__bases__[0].__name__, IncompleteRead/__name__."
    - "http_client_extra14.zspec.zsdl — covers HTTPConnection/__qualname__/__module__, HTTPSConnection/__qualname__/__module__, HTTP_PORT/HTTPS_PORT constants, BadStatusLine/CannotSendRequest exception attributes."
    - "http_client_extra10.zspec.zsdl — covers __qualname__.__len__() for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException/NotConnected and __module__.__len__()==11."
    - "http_client_extra9.zspec.zsdl — covers __name__.__len__() for several classes."
    - "http_client_extra2.zspec.zsdl — covers __qualname__.__eq__ and __module__.__eq__ for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException."
  notes:
    - "This spec extends http_client_extra15.zspec.zsdl."
    - "Prior specs covered: HTTPConnection/HTTPSConnection/HTTPResponse/__name__/__module__/__qualname__/__bases__, HTTPException/__name__/__module__/__bases__[0].__name__, HTTP_PORT/HTTPS_PORT values, status codes (OK=200/NOT_FOUND=404 etc), HTTPConnection/__init__.__name__, NotConnected/InvalidURL/UnknownProtocol/RemoteDisconnected/IncompleteRead/__name__/__bases__."
    - "This spec covers: __module__.__len__() for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException; __name__.__len__() for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException; __qualname__.__len__() for HTTPConnection; parse_headers/__name__/__qualname__ (module-level function)."
    - "http.client.HTTPConnection.__module__ == 'http.client' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPSConnection.__module__ == 'http.client' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.__module__ == 'http.client' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPException.__module__ == 'http.client' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.__name__ == 'HTTPConnection' — len 14. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPSConnection.__name__ == 'HTTPSConnection' — len 15. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPResponse.__name__ == 'HTTPResponse' — len 12. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPException.__name__ == 'HTTPException' — len 13. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.HTTPConnection.__qualname__ == 'HTTPConnection' — len 14 (same as __name__ for top-level class). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.parse_headers.__name__ == 'parse_headers' — module-level function re-exported from http.client. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "http.client.parse_headers.__qualname__ == 'parse_headers' — qualname equals name for module-level function. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for HTTPConnection, HTTPSConnection, HTTPResponse,
# HTTPException
#
# http_client_extra2/14 cover __module__.__eq__ for these classes.
# http_client_extra10 covers __module__.__len__()==11 for several classes.
# These standalone invariants provide cross-namespace anchors from extra16.
# All four modules are 'http.client' (len 11).
# ---------------------------------------------------------------------------

table http_client_extra16.class_module_lengths:
  description: "len(__module__) == 11 for HTTPConnection/HTTPSConnection/HTTPResponse/HTTPException — cross-namespace anchors from extra16"
  kind: python_call_eq
  category: class_module
  id_prefix: cml16

  columns: [id, function, args, expected]
  rows:
    - [HTTPConnection,  HTTPConnection.__module__.__len__,  [], 11]
    - [HTTPSConnection, HTTPSConnection.__module__.__len__, [], 11]
    - [HTTPResponse,    HTTPResponse.__module__.__len__,    [], 11]
    - [HTTPException,   HTTPException.__module__.__len__,   [], 11]

# ---------------------------------------------------------------------------
# __name__.__len__() for HTTPConnection, HTTPSConnection, HTTPResponse,
# HTTPException
#
# http_client_extra9 covers __name__.__len__() for several classes.
# These standalone invariants collect the four primary classes together from
# the extra16 namespace.
# HTTPConnection: 14, HTTPSConnection: 15, HTTPResponse: 12, HTTPException: 13.
# ---------------------------------------------------------------------------

invariant http_client_extra16.HTTPConnection.name_len:
  description: "len(http.client.HTTPConnection.__name__) == 14 — len('HTTPConnection') == 14"
  category: class_names
  kind: python_call_eq
  function: HTTPConnection.__name__.__len__
  args: []
  expected: 14

invariant http_client_extra16.HTTPSConnection.name_len:
  description: "len(http.client.HTTPSConnection.__name__) == 15 — len('HTTPSConnection') == 15"
  category: class_names
  kind: python_call_eq
  function: HTTPSConnection.__name__.__len__
  args: []
  expected: 15

table http_client_extra16.response_exception_name_lengths:
  description: "len(__name__) for HTTPResponse (12) and HTTPException (13) — cross-namespace anchors from extra16"
  kind: python_call_eq
  category: class_names
  id_prefix: renl16

  columns: [id, function, args, expected]
  rows:
    - [HTTPResponse,  HTTPResponse.__name__.__len__,  [], 12]
    - [HTTPException, HTTPException.__name__.__len__, [], 13]

# ---------------------------------------------------------------------------
# http.client.HTTPConnection.__qualname__.__len__()
#
# http_client_extra10 covers __qualname__.__len__() for HTTPConnection (==14).
# This standalone invariant provides a cross-namespace anchor from extra16.
# HTTPConnection.__qualname__ == 'HTTPConnection' (len 14).
# ---------------------------------------------------------------------------

invariant http_client_extra16.HTTPConnection.qualname_len:
  description: "len(http.client.HTTPConnection.__qualname__) == 14 — len('HTTPConnection') == 14; cross-namespace anchor from extra16"
  category: class_qualnames
  kind: python_call_eq
  function: HTTPConnection.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# http.client.parse_headers — __name__ and __qualname__
#
# parse_headers is a module-level function in http.client that parses HTTP
# message headers. No prior spec checks any attribute of parse_headers.
# parse_headers.__name__ == 'parse_headers'; __qualname__ == 'parse_headers'.
# ---------------------------------------------------------------------------

invariant http_client_extra16.parse_headers.name_eq:
  description: "http.client.parse_headers.__name__ == 'parse_headers' — module-level HTTP header parser; no prior spec checks this"
  category: function_names
  kind: python_call_eq
  function: parse_headers.__name__.__eq__
  args: ["parse_headers"]
  expected: true

invariant http_client_extra16.parse_headers.name_len:
  description: "len(http.client.parse_headers.__name__) == 13 — len('parse_headers') == 13"
  category: function_names
  kind: python_call_eq
  function: parse_headers.__name__.__len__
  args: []
  expected: 13

invariant http_client_extra16.parse_headers.qualname_eq:
  description: "http.client.parse_headers.__qualname__ == 'parse_headers' — qualname equals name for module-level function"
  category: function_qualnames
  kind: python_call_eq
  function: parse_headers.__qualname__.__eq__
  args: ["parse_headers"]
  expected: true
