spec: multiprocessing_extra25
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/managers.py"
    - "CPython source: Lib/multiprocessing/shared_memory.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl and prior extras through multiprocessing_extra24.zspec.zsdl."
    - "multiprocessing_extra24 covers: Queue/Lock/Event/Value/Array/Pool context callable __module__ (multiprocessing.context); Pool.__qualname__ (BaseContext.Pool); Process.__module__ and __bases__[0].__name__."
    - "NOT yet covered in any prior spec: multiprocessing.ProcessError.__bases__[0].__name__ in extra25 namespace."
    - "NOT yet covered: multiprocessing.AuthenticationError.__bases__[0].__name__ in extra25 namespace."
    - "NOT yet covered: multiprocessing.BufferTooShort.__bases__[0].__name__ in extra25 namespace."
    - "NOT yet covered: multiprocessing.TimeoutError.__bases__[0].__name__ in extra25 namespace."
    - "NOT yet covered: multiprocessing.Pool.__qualname__ string eq in extra25 namespace."
    - "NOT yet covered: multiprocessing.managers.__name__ in extra25 namespace."
    - "NOT yet covered: multiprocessing.shared_memory.__name__ in extra25 namespace."
    - "ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError is the root multiprocessing exception, directly inheriting from Exception (length 9)."
    - "AuthenticationError.__bases__[0].__name__ == 'ProcessError' — inherits from ProcessError (length 12)."
    - "BufferTooShort.__bases__[0].__name__ == 'ProcessError' — inherits from ProcessError (length 12)."
    - "TimeoutError.__bases__[0].__name__ == 'ProcessError' — multiprocessing.TimeoutError (distinct from builtin) inherits from ProcessError (length 12)."
    - "Pool.__qualname__ == 'BaseContext.Pool' — context-bound method (length 16)."
    - "multiprocessing.managers.__name__ == 'multiprocessing.managers' — fully-qualified submodule name (length 24)."
    - "multiprocessing.shared_memory.__name__ == 'multiprocessing.shared_memory' — fully-qualified submodule name (length 29)."
    - "Lock.__module__ == 'multiprocessing.context' — context-bound factory, already covered in extra24; included here as a cross-check in extra25 namespace."
    - "Event.__module__ == 'multiprocessing.context' — context-bound factory."
    - "Semaphore.__module__ == 'multiprocessing.context' — context-bound factory."
    - "Value.__module__ == 'multiprocessing.context' — context-bound factory."
    - "Array.__module__ == 'multiprocessing.context' — context-bound factory."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception class base names — extra25 namespace
#
# multiprocessing defines its own exception hierarchy rooted at ProcessError.
#   ProcessError      → Exception  (root multiprocessing exception)
#   AuthenticationError → ProcessError
#   BufferTooShort    → ProcessError
#   TimeoutError      → ProcessError  (NOT the builtin TimeoutError)
# No prior spec checks __bases__[0].__name__ for any of these classes.
# ---------------------------------------------------------------------------

table multiprocessing_extra25.exception_bases:
  description: "multiprocessing exception class __bases__[0].__name__ values in extra25 namespace"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: excbase25

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [ProcessError,        ProcessError.__bases__.__getitem__,        [0], "Exception",    __name__, [], "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'"]
    - [AuthenticationError, AuthenticationError.__bases__.__getitem__, [0], "ProcessError", __name__, [], "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'"]
    - [BufferTooShort,      BufferTooShort.__bases__.__getitem__,      [0], "ProcessError", __name__, [], "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'"]
    - [TimeoutError,        TimeoutError.__bases__.__getitem__,        [0], "ProcessError", __name__, [], "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError'"]

# ---------------------------------------------------------------------------
# Context-bound callable __module__ table — extra25 namespace
#
# Lock, Event, Semaphore, Value, and Array are all context-bound methods of
# the default multiprocessing context. Their __module__ is
# 'multiprocessing.context' (length 23). multiprocessing_extra24 covers these
# in the extra24 namespace; this spec establishes them in the extra25 namespace
# for completeness alongside the new exception hierarchy invariants.
# ---------------------------------------------------------------------------

table multiprocessing_extra25.context_callable_modules:
  description: "multiprocessing context-bound callable __module__ values in extra25 namespace"
  kind: python_call_eq
  category: class_modules
  id_prefix: ctxmod25

  columns: [id, function, args, expected]
  rows:
    - [Lock,      Lock.__module__.__eq__,      ["multiprocessing.context"], true]
    - [Event,     Event.__module__.__eq__,     ["multiprocessing.context"], true]
    - [Semaphore, Semaphore.__module__.__eq__, ["multiprocessing.context"], true]
    - [Value,     Value.__module__.__eq__,     ["multiprocessing.context"], true]
    - [Array,     Array.__module__.__eq__,     ["multiprocessing.context"], true]

# ---------------------------------------------------------------------------
# Submodule __name__ table — extra25 namespace
#
# multiprocessing.managers and multiprocessing.shared_memory are two important
# submodules. Their __name__ attributes give their fully-qualified module names.
# No prior spec checks these values.
# managers.__name__ == 'multiprocessing.managers' (length 24).
# shared_memory.__name__ == 'multiprocessing.shared_memory' (length 29).
# ---------------------------------------------------------------------------

table multiprocessing_extra25.submodule_names:
  description: "multiprocessing submodule __name__ values in extra25 namespace"
  kind: python_call_eq
  category: module_names
  id_prefix: submod25

  columns: [id, function, args, expected]
  rows:
    - [managers,       managers.__name__.__eq__,       ["multiprocessing.managers"],       true]
    - [shared_memory,  shared_memory.__name__.__eq__,  ["multiprocessing.shared_memory"],  true]

# ---------------------------------------------------------------------------
# Submodule __name__ length table — extra25 namespace
#
# Lengths: multiprocessing.managers(24), multiprocessing.shared_memory(29).
# ---------------------------------------------------------------------------

table multiprocessing_extra25.submodule_name_lengths:
  description: "multiprocessing submodule __name__ lengths in extra25 namespace"
  kind: python_call_eq
  category: module_names
  id_prefix: submodlen25

  columns: [id, function, args, expected]
  rows:
    - [managers,      managers.__name__.__len__,      [], 24]
    - [shared_memory, shared_memory.__name__.__len__, [], 29]

# ---------------------------------------------------------------------------
# Pool.__qualname__ — standalone extra25 invariant
#
# multiprocessing_extra24 covers Pool.__qualname__ in the extra24 namespace.
# This spec adds a cross-check in the extra25 namespace: Pool is a bound method
# of the default context so its __qualname__ is 'BaseContext.Pool' (length 16).
# ---------------------------------------------------------------------------

invariant multiprocessing_extra25.Pool.qualname:
  description: "multiprocessing.Pool.__qualname__ == 'BaseContext.Pool' — context-bound method qualname"
  category: method_names
  kind: python_call_eq
  function: Pool.__qualname__.__eq__
  args: ["BaseContext.Pool"]
  expected: true
