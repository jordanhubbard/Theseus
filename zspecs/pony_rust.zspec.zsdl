spec: pony_rust
version: ">=3.9"
backend: rust_module(pony_rust)

docs: https://ponyorm.org/

provenance:
  derived_from:
    - "https://ponyorm.org/ — Pony ORM"
  notes:
    - "Pony ORM provides Python ORM with query syntax."
    - "pony.orm.Database is a class."
    - "pony.orm.db_session is a decorator."
    - "pony.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pony_rust.has_database:
  description: "pony.orm.Database is a class"
  category: presence
  kind: python_call_eq
  function: pony_has_database
  args: []
  expected: true

invariant pony_rust.has_db_session:
  description: "pony.orm.db_session is callable"
  category: presence
  kind: python_call_eq
  function: pony_has_db_session
  args: []
  expected: true

invariant pony_rust.version_nonempty:
  description: "pony.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pony_version_nonempty
  args: []
  expected: true

