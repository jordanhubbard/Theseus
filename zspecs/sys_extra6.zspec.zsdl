spec: sys_extra6
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sys.html — Python sys module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Python/sysmodule.c"
  notes:
    - "This spec extends sys.zspec.zsdl, sys_extra.zspec.zsdl, sys_extra2.zspec.zsdl, sys_extra3.zspec.zsdl, sys_extra4.zspec.zsdl, sys_extra5.zspec.zsdl."
    - "sys.zspec.zsdl covers version_info.major==3."
    - "sys_extra.zspec.zsdl covers version_info.major>=3, version_info.minor>=0, flags/__class__/__name__=='flags', implementation.name=='cpython'."
    - "sys_extra4.zspec.zsdl covers float_info/__class__/__name__=='float_info', int_info class name, hash_info class name, flags class name, implementation.name class name."
    - "sys_extra5.zspec.zsdl covers float_info class name, int_info class name, hash_info class name."
    - "This spec focuses on version_info indexing, length, micro/minor bounds, and implementation.name value."
    - "sys.version_info.__class__.__name__ == 'version_info' — the version_info named tuple type."
    - "sys.version_info.major == 3 — Python 3 major version."
    - "sys.version_info.minor >= 9 — this spec requires Python >=3.9."
    - "sys.version_info.micro >= 0 — micro version is always a non-negative integer."
    - "sys.version_info[0] == 3 — index access to the major version field."
    - "sys.version_info.__len__() == 5 — fields: major, minor, micro, releaselevel, serial."
    - "sys.implementation.name == 'cpython' — the CPython interpreter name."
    - "sys.implementation.name.__class__.__name__ == 'str' — implementation.name is always a str."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version_info struct names table
# Checks class names of the four struct-like objects: version_info, flags,
# float_info, int_info.  Only version_info is new here (the others appear
# in sys_extra4/sys_extra5 but we include them for a self-contained table).
# The key NEW invariant is version_info.__class__.__name__ == 'version_info'.
# ---------------------------------------------------------------------------

table sys_extra6.struct_class_names:
  kind: python_call_eq
  category: struct_names
  id_prefix: sname

  columns: [id, function, args, expected]
  rows:
    - [version_info, version_info.__class__.__name__.__eq__, ["version_info"], true]
    - [flags,        flags.__class__.__name__.__eq__,        ["flags"],        true]
    - [float_info,   float_info.__class__.__name__.__eq__,   ["float_info"],   true]
    - [int_info,     int_info.__class__.__name__.__eq__,     ["int_info"],     true]

# ---------------------------------------------------------------------------
# version_info.major — must equal 3
# sys.zspec.zsdl covers version_info.major == 3 as a table row; this is a
# standalone named invariant in the sys_extra6 namespace.
# ---------------------------------------------------------------------------

invariant sys_extra6.version_info.major_eq_3:
  description: "sys.version_info.major == 3 — Python major version is 3"
  category: version_info
  kind: python_call_eq
  function: version_info.major.__eq__
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# version_info.minor — must be >= 9 (this spec targets Python >=3.9)
# sys_extra covers >= 0; this tightens the bound to >= 9.
# ---------------------------------------------------------------------------

invariant sys_extra6.version_info.minor_ge_9:
  description: "sys.version_info.minor >= 9 — spec requires Python 3.9 or later"
  category: version_info
  kind: python_call_eq
  function: version_info.minor.__ge__
  args: [9]
  expected: true

# ---------------------------------------------------------------------------
# version_info.micro — must be >= 0
# ---------------------------------------------------------------------------

invariant sys_extra6.version_info.micro_ge_0:
  description: "sys.version_info.micro >= 0 — micro version is always non-negative"
  category: version_info
  kind: python_call_eq
  function: version_info.micro.__ge__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# version_info[0] — index access yields the major version
# ---------------------------------------------------------------------------

invariant sys_extra6.version_info.index_0_eq_3:
  description: "sys.version_info[0] == 3 — index 0 is the major version field"
  category: version_info
  kind: python_call_eq
  function: version_info.__getitem__
  args: [0]
  expected: 3

# ---------------------------------------------------------------------------
# version_info.__len__() == 5
# The tuple has five fields: major, minor, micro, releaselevel, serial.
# ---------------------------------------------------------------------------

invariant sys_extra6.version_info.len_eq_5:
  description: "sys.version_info.__len__() == 5 — five fields: major, minor, micro, releaselevel, serial"
  category: version_info
  kind: python_call_eq
  function: version_info.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# implementation.name — value and type
# sys_extra covers implementation.name == 'cpython' and sys_extra4 covers
# implementation.name class name; both are repeated here as named anchors
# in the sys_extra6 namespace.
# ---------------------------------------------------------------------------

invariant sys_extra6.implementation.name_eq_cpython:
  description: "sys.implementation.name == 'cpython'"
  category: implementation
  kind: python_call_eq
  function: implementation.name.__eq__
  args: ["cpython"]
  expected: true

invariant sys_extra6.implementation.name_class_str:
  description: "sys.implementation.name.__class__.__name__ == 'str'"
  category: implementation
  kind: python_call_eq
  function: implementation.name.__class__.__name__.__eq__
  args: ["str"]
  expected: true
