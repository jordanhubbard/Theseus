spec: uuid_extra127
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra126.zspec.zsdl — covers uuid.NAMESPACE_DNS/URL/OID/X500 __class__.__name__=='UUID' / NAMESPACE_DNS/URL/OID/X500 version==1 / NAMESPACE_DNS hex and hex length / NAMESPACE_X500 hex / NIL.int==0 (table + invariants)."
    - "uuid_extra125.zspec.zsdl — covers uuid.getnode __name__/__qualname__/__module__/co_argcount/co_name identity / uuid1/uuid3/uuid5/uuid4 co_varnames[0] / uuid.SafeUUID __name__/__qualname__/__module__/__class__.__name__/__bases__[0].__name__ (table + invariants)."
    - "uuid_extra124.zspec.zsdl — covers UUID property __class__.__name__ equality / UUID property fget __class__.__name__ and co_argcount / UUID.is_safe member_descriptor identity, qualname, and name (table + invariants)."
    - "uuid_extra123.zspec.zsdl — covers UUID.__slots__ class name/length/contains / UUID.__weakref__ descriptor / UUID.int member_descriptor identity / UUID.__hash__ code co_argcount (table + invariants)."
    - "uuid_extra122.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__eq__ co_varnames[0] ('self') and co_varnames.__len__() / co_argcount for __str__/__repr__/__eq__ (table + invariants)."
    - "uuid_extra121.zspec.zsdl — covers uuid6/uuid7/uuid8 function __name__/__qualname__/__module__/__code__.co_argcount identity / uuid.NIL and uuid.MAX sentinel UUID values (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ co_name/co_argcount/__qualname__ / UUID.__str__/__repr__/__eq__/__hash__/__lt__ method qualname equality (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__class__.__name__/__qualname__ (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior uuid spec files."
    - "Wave 354 theme: uuid.UUID dunder method __name__ equality / UUID.__init__/__str__/__repr__/__eq__/__hash__ __class__.__name__=='function' and __module__=='uuid' / UUID.__init__.__code__.co_varnames.__len__()==15 / UUID.__init__.__code__.co_argcount==7 / UUID.__new__ identity."
    - "uuid.UUID.__init__.__name__ == '__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__name__ == '__str__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__name__ == '__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__name__ == '__eq__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__name__ == '__hash__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__class__.__name__ == 'function'. All UUID dunders are pure-Python functions. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__repr__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_varnames.__len__() == 15. __init__ has 15 local variables including all keyword parameters and temporaries. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_argcount == 7. UUID.__init__ takes self + 6 optional keyword args (hex, bytes, bytes_le, fields, int, version) — is_safe is keyword-only. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__new__.__qualname__ == 'object.__new__'. UUID does not define __new__; it inherits from object. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__new__.__name__ == '__new__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid_extra99 anchors UUID.__str__/__repr__/__eq__/__hash__/__lt__ qualname equality. uuid_extra122 anchors co_varnames[0] ('self') and co_varnames.__len__() and co_argcount for some methods. This spec is the first to anchor UUID.__init__/__str__/__repr__/__eq__/__hash__ __name__ equality, __class__.__name__=='function', __module__=='uuid', UUID.__init__ co_argcount==7 and co_varnames.__len__()==15, and UUID.__new__ identity under uuidfn127."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__name__.__eq__('__init__')
# uuid.UUID.__str__.__name__.__eq__('__str__')
# uuid.UUID.__repr__.__name__.__eq__('__repr__')
# uuid.UUID.__eq__.__name__.__eq__('__eq__')
# uuid.UUID.__hash__.__name__.__eq__('__hash__')
#
# Wave 354 theme: uuid.UUID dunder method __name__ equality.
#
# uuid.UUID is a pure-Python class defined in Lib/uuid.py. All of its dunder
# methods (__init__, __str__, __repr__, __eq__, __hash__, __lt__, etc.) are
# plain Python functions. Their __name__ attributes return the short dunder
# name without the class prefix (e.g., '__init__' not 'UUID.__init__'). The
# __qualname__ attribute carries the class prefix (e.g., 'UUID.__init__'); uuid_extra99
# anchors those qualnames. This spec anchors the __name__ values via __eq__ for
# the first time under uuidfn127. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra127.UUID_dunder_names:
  description: "uuid.UUID/__init__/__name__.__eq__('__init__')==True / __str__/__name__.__eq__('__str__')==True / __repr__/__name__.__eq__('__repr__')==True / __eq__/__name__.__eq__('__eq__')==True / __hash__/__name__.__eq__('__hash__')==True — all UUID dunders are pure-Python functions; __name__ is the short name (no class prefix); extra99 anchors qualnames; first uuidfn127 anchor for UUID dunder __name__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidfn127

  columns: [id, function, args, expected, description]
  rows:
    - [init_name,   UUID.__init__.__name__.__eq__,  ["__init__"],  true, "UUID.__init__.__name__ is '__init__' (short name; qualname is 'UUID.__init__')"]
    - [str_name,    UUID.__str__.__name__.__eq__,   ["__str__"],   true, "UUID.__str__.__name__ is '__str__' (returns e.g. '6ba7b810-9dad-11d1-80b4-00c04fd430c8')"]
    - [repr_name,   UUID.__repr__.__name__.__eq__,  ["__repr__"],  true, "UUID.__repr__.__name__ is '__repr__' (returns 'UUID(...)' repr string)"]
    - [eq_name,     UUID.__eq__.__name__.__eq__,    ["__eq__"],    true, "UUID.__eq__.__name__ is '__eq__' (compares UUID instances by .int value)"]
    - [hash_name,   UUID.__hash__.__name__.__eq__,  ["__hash__"],  true, "UUID.__hash__.__name__ is '__hash__' (hashes .int value for dict/set use)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__class__.__name__.__eq__('function')
# uuid.UUID.__str__.__class__.__name__.__eq__('function')
# uuid.UUID.__repr__.__class__.__name__.__eq__('function')
# uuid.UUID.__eq__.__class__.__name__.__eq__('function')
# uuid.UUID.__hash__.__class__.__name__.__eq__('function')
#
# Wave 354 theme: uuid.UUID dunder methods are plain Python functions.
#
# Unlike struct.Struct dunders (which are wrapper_descriptor or method_descriptor
# because Struct is a C-extension type), uuid.UUID dunders are plain Python
# functions because uuid.UUID is defined in Lib/uuid.py. Their
# __class__.__name__ is 'function' (not 'wrapper_descriptor', 'method_descriptor',
# or 'builtin_function_or_method'). This is a key identity check confirming the
# pure-Python implementation of uuid.UUID. No prior uuid spec anchors these
# __class__.__name__ values via __eq__ under uuidfn127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra127.UUID_dunder_class_names:
  description: "uuid.UUID/__init__/__class__/__name__.__eq__('function')==True / __str__/__class__/__name__.__eq__('function')==True / __repr__/__class__/__name__.__eq__('function')==True / __eq__/__class__/__name__.__eq__('function')==True / __hash__/__class__/__name__.__eq__('function')==True — UUID dunders are pure-Python functions (not wrapper_descriptor like Struct dunders); confirms uuid.UUID is a pure-Python class; first uuidfn127 anchor for UUID dunder class names"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidfn127

  columns: [id, function, args, expected, description]
  rows:
    - [init_cls,   UUID.__init__.__class__.__name__.__eq__,  ["function"],  true, "UUID.__init__.__class__.__name__ is 'function' (pure Python, unlike Struct.__init__ which is wrapper_descriptor)"]
    - [str_cls,    UUID.__str__.__class__.__name__.__eq__,   ["function"],  true, "UUID.__str__.__class__.__name__ is 'function' (pure Python)"]
    - [repr_cls,   UUID.__repr__.__class__.__name__.__eq__,  ["function"],  true, "UUID.__repr__.__class__.__name__ is 'function' (pure Python)"]
    - [eq_cls,     UUID.__eq__.__class__.__name__.__eq__,    ["function"],  true, "UUID.__eq__.__class__.__name__ is 'function' (pure Python)"]
    - [hash_cls,   UUID.__hash__.__class__.__name__.__eq__,  ["function"],  true, "UUID.__hash__.__class__.__name__ is 'function' (pure Python)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_argcount.__eq__(7)
# uuid.UUID.__init__.__code__.co_varnames.__len__().__eq__(15)
# uuid.UUID.__new__.__qualname__.__eq__('object.__new__')
# uuid.UUID.__new__.__name__.__eq__('__new__')
# uuid.UUID.__new__.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 354 theme: UUID.__init__ code details and UUID.__new__ identity.
#
# uuid.UUID.__init__ takes 7 positional args: self plus 6 optional keyword
# parameters (hex, bytes, bytes_le, fields, int, version). The is_safe parameter
# is keyword-only (not counted in co_argcount). The __init__ code object has 15
# total co_varnames: the 7 formal parameters plus 8 additional local variables
# used in the body (time_low, time_mid, time_hi_version, clock_seq_hi_variant,
# clock_seq_low, node, clock_seq, and one more). UUID does NOT define __new__
# (it is a pure-Python class with no C tp_new slot override); UUID.__new__ is
# therefore inherited from object, giving __new__.__qualname__=='object.__new__'
# and __class__.__name__=='builtin_function_or_method'. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

table uuid_extra127.UUID_init_code_and_new_identity:
  description: "uuid.UUID/__init__/__code__/co_argcount.__eq__(7)==True / __init__/__code__/co_varnames/__len__()==15 / __new__/__qualname__.__eq__('object.__new__')==True / __new__/__name__.__eq__('__new__')==True / __new__/__class__/__name__.__eq__('builtin_function_or_method')==True — UUID.__init__ takes 7 positional args (self+6 optional keyword params); 15 co_varnames total; UUID inherits __new__ from object (qualname 'object.__new__'); first uuidfn127 anchor for these code and __new__ attrs"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidfn127

  columns: [id, function, args, expected, description]
  rows:
    - [init_argcount,   UUID.__init__.__code__.co_argcount.__eq__,             [7],                         true, "UUID.__init__.__code__.co_argcount is 7 (self + hex/bytes/bytes_le/fields/int/version; is_safe is keyword-only)"]
    - [init_varlen,     UUID.__init__.__code__.co_varnames.__len__,             [],                          15,   "UUID.__init__ has 15 co_varnames (7 params + 8 local temporaries)"]
    - [new_qualname,    UUID.__new__.__qualname__.__eq__,                       ["object.__new__"],          true, "UUID.__new__.__qualname__ is 'object.__new__' (UUID does not define __new__; inherits from object)"]
    - [new_name,        UUID.__new__.__name__.__eq__,                           ["__new__"],                 true, "UUID.__new__.__name__ is '__new__' (inherited builtin allocator)"]
    - [new_cls,         UUID.__new__.__class__.__name__.__eq__,                 ["builtin_function_or_method"], true, "UUID.__new__.__class__.__name__ is 'builtin_function_or_method' (object.__new__ is a C builtin)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__name__.__eq__('__init__') — standalone
#
# uuid.UUID.__init__.__name__ is '__init__'. uuid.UUID is a pure-Python class
# defined in Lib/uuid.py, so all its methods including __init__ are plain Python
# function objects. The __name__ attribute of a Python function is the function's
# short name as it appears in the def statement (without the class qualifier).
# uuid_extra99 anchors UUID.__init__.__qualname__ == 'UUID.__init__' (with class
# prefix); this standalone confirms the __name__ (without class prefix) via a
# separate access path. First standalone for UUID.__init__.__name__.__eq__ under
# uuidfn127. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra127.UUID_init_name:
  description: "uuid.UUID.__init__.__name__.__eq__('__init__') == True — UUID.__init__ is a pure-Python function (not wrapper_descriptor); __name__ is short form without class prefix; extra99 anchors UUID.__init__ qualname 'UUID.__init__'; first standalone for UUID.__init__.__name__.__eq__ under uuidfn127"
  category: type_identity
  kind: python_call_eq
  function: UUID.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__hash__.__class__.__name__.__eq__('function') — standalone
#
# uuid.UUID.__hash__.__class__.__name__ is 'function'. uuid.UUID defines its own
# __hash__ method in Lib/uuid.py — it is not inherited from object. The __hash__
# method returns hash(self.int), making UUID instances hashable and usable as
# dictionary keys or set members. Because uuid.UUID is a pure-Python class, its
# __hash__ is a plain Python function (not a wrapper_descriptor like Struct's
# inherited __hash__, which has __qualname__=='object.__hash__'). No prior uuid
# spec anchors UUID.__hash__.__class__.__name__.__eq__('function') as a standalone
# under uuidfn127. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra127.UUID_hash_class_function:
  description: "uuid.UUID.__hash__.__class__.__name__.__eq__('function') == True — UUID defines its own __hash__ (not inherited from object) returning hash(self.int); pure-Python function (unlike Struct.__hash__ which is a wrapper_descriptor from object); first standalone for UUID.__hash__.__class__.__name__.__eq__ under uuidfn127"
  category: type_identity
  kind: python_call_eq
  function: UUID.__hash__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_argcount.__eq__(7) — standalone
#
# uuid.UUID.__init__.__code__.co_argcount is 7. The UUID __init__ signature is:
#   __init__(self, hex=None, bytes=None, bytes_le=None, fields=None, int=None,
#            version=None, *, is_safe=SafeUUID.unknown)
# co_argcount counts the positional-or-keyword parameters: self, hex, bytes,
# bytes_le, fields, int, version = 7. The is_safe parameter is keyword-only
# (counted in co_kwonlyargcount, not co_argcount). uuid_extra122 anchors
# co_argcount for __str__, __repr__, __eq__ (which are 1, 1, 2 respectively);
# this standalone anchors co_argcount for __init__ (7) under uuidfn127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra127.UUID_init_co_argcount_7:
  description: "uuid.UUID.__init__.__code__.co_argcount.__eq__(7) == True — UUID.__init__ takes 7 positional-or-keyword args: self + hex/bytes/bytes_le/fields/int/version; is_safe is keyword-only (in co_kwonlyargcount, not co_argcount==7); extra122 anchors co_argcount for __str__(1)/__repr__(1)/__eq__(2); first standalone for __init__.co_argcount==7 under uuidfn127"
  category: type_identity
  kind: python_call_eq
  function: UUID.__init__.__code__.co_argcount.__eq__
  args: [7]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__new__.__qualname__.__eq__('object.__new__') — standalone
#
# uuid.UUID.__new__.__qualname__ is 'object.__new__'. uuid.UUID is implemented
# in pure Python and does not define a __new__ method — it relies entirely on
# __init__ for initialization after object allocation. The inherited
# object.__new__ is responsible for allocating the UUID instance. The qualname
# 'object.__new__' (not 'UUID.__new__') reveals that this is the unmodified
# inherited builtin allocator. This contrasts with C-extension types like
# struct.Struct which may define their own __new__ (Struct.__new__.__qualname__
# == 'Struct.__new__'). No prior uuid spec anchors UUID.__new__.__qualname__
# via __eq__ as a standalone under uuidfn127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra127.UUID_new_qualname_object:
  description: "uuid.UUID.__new__.__qualname__.__eq__('object.__new__') == True — UUID does not define __new__; inherits object.__new__ (qualname 'object.__new__'); contrasts with struct.Struct.__new__.__qualname__=='Struct.__new__' (C type defines its own); first standalone for UUID.__new__.__qualname__.__eq__ under uuidfn127"
  category: type_identity
  kind: python_call_eq
  function: UUID.__new__.__qualname__.__eq__
  args: ["object.__new__"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_varnames.__len__().__eq__(15) — standalone
#
# uuid.UUID.__init__.__code__.co_varnames.__len__() is 15. The co_varnames tuple
# contains all local variable names in the function scope: the 7 formal parameters
# (self, hex, bytes, bytes_le, fields, int, version) plus 8 local temporaries
# used in the __init__ body (time_low, time_mid, time_hi_version,
# clock_seq_hi_variant, clock_seq_low, node, clock_seq, and clock_seq). The
# large number of locals reflects UUID's multi-format constructor which unpacks
# fields tuple into named components. uuid_extra122 anchors co_varnames.__len__()
# for __str__(2)/__repr__(1)/__eq__(2)/__hash__(1) but not __init__. This is
# the first standalone for UUID.__init__.co_varnames.__len__()==15 under uuidfn127.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra127.UUID_init_co_varnames_len_15:
  description: "uuid.UUID.__init__.__code__.co_varnames.__len__() == 15 — 7 formal params (self+hex+bytes+bytes_le+fields+int+version) + 8 local temporaries (time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, node, clock_seq, clock_seq); extra122 anchors co_varnames len for __str__/__repr__/__eq__/__hash__; first standalone for __init__.co_varnames.__len__()==15 under uuidfn127"
  category: type_identity
  kind: python_call_eq
  function: UUID.__init__.__code__.co_varnames.__len__
  args: []
  expected: 15

