spec: multiprocessing_extra2641
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing classes documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.Process, multiprocessing.pool.Pool, multiprocessing.pool.AsyncResult __dict__ for __copy__, __deepcopy__, __sizeof__ presence (all false)"]
  created_at: "2026-04-13"
error_model: python_exceptions

table multiprocessing_extra2641.process_dict_presence:
  description: "multiprocessing.Process __dict__ does not contain __copy__, __deepcopy__, __sizeof__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: mp2641pd
  columns: [id, function, args, expected]
  rows:
    - ["mp2641pd001", multiprocessing.Process.__dict__.__contains__, ["__copy__"], false]
    - ["mp2641pd002", multiprocessing.Process.__dict__.__contains__, ["__deepcopy__"], false]
    - ["mp2641pd003", multiprocessing.Process.__dict__.__contains__, ["__sizeof__"], false]

