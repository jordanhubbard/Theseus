spec: decimal_extra74
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra73."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal.__dict__.__contains__ for arithmetic/conversion/comparison dunders; Decimal comparison/equality/hash wrapper_descriptor identity; Context.__dict__ class and membership; getcontext/setcontext __class__.__name__ and __module__."
    - "This spec covers: Decimal.__pow__/__class__.__name__; Decimal.__mod__/__class__.__name__; Decimal.__divmod__/__class__.__name__; Decimal.__truediv__/__class__.__name__; Decimal.__floordiv__/__class__.__name__; Decimal.__dict__.__contains__ for __pow__/__mod__/__divmod__/__truediv__/__floordiv__."
    - "decimal.Decimal.__pow__.__class__.__name__ == 'wrapper_descriptor' — __pow__ is a C slot wrapper defined in the Decimal C type."
    - "decimal.Decimal.__mod__.__class__.__name__ == 'wrapper_descriptor' — __mod__ is a C slot wrapper defined in the Decimal C type."
    - "decimal.Decimal.__divmod__.__class__.__name__ == 'wrapper_descriptor' — __divmod__ is a C slot wrapper defined in the Decimal C type."
    - "decimal.Decimal.__truediv__.__class__.__name__ == 'wrapper_descriptor' — __truediv__ is a C slot wrapper defined in the Decimal C type."
    - "decimal.Decimal.__floordiv__.__class__.__name__ == 'wrapper_descriptor' — __floordiv__ is a C slot wrapper defined in the Decimal C type."
    - "decimal.Decimal.__dict__.__contains__('__pow__') == True — __pow__ is defined directly in the Decimal C type, not inherited."
    - "decimal.Decimal.__dict__.__contains__('__mod__') == True — __mod__ is defined directly in the Decimal C type, not inherited."
    - "decimal.Decimal.__dict__.__contains__('__divmod__') == True — __divmod__ is defined directly in the Decimal C type, not inherited."
    - "decimal.Decimal.__dict__.__contains__('__truediv__') == True — __truediv__ is defined directly in the Decimal C type, not inherited."
    - "decimal.Decimal.__dict__.__contains__('__floordiv__') == True — __floordiv__ is defined directly in the Decimal C type, not inherited."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.__pow__ and Decimal.__mod__ wrapper_descriptor identity
# Both are C slot wrappers; __class__.__name__ == 'wrapper_descriptor'.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra74.Decimal_pow_mod_class:
  description: "Decimal.__pow__ and Decimal.__mod__ __class__.__name__ == 'wrapper_descriptor'"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalmore74

  columns: [id, function, args, expected]
  rows:
    - [pow_cls, Decimal.__pow__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [mod_cls, Decimal.__mod__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Decimal.__divmod__, __truediv__, __floordiv__ wrapper_descriptor identity
# All three are C slot wrappers; __class__.__name__ == 'wrapper_descriptor'.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra74.Decimal_divmod_truediv_floordiv_class:
  description: "Decimal.__divmod__, __truediv__, __floordiv__ __class__.__name__ == 'wrapper_descriptor'"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalmore74

  columns: [id, function, args, expected]
  rows:
    - [divmod_cls,   Decimal.__divmod__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [truediv_cls,  Decimal.__truediv__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [floordiv_cls, Decimal.__floordiv__.__class__.__name__.__eq__,["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Decimal.__dict__ membership for division and power dunders
# __pow__, __mod__, __divmod__, __truediv__, __floordiv__ are all defined
# directly in the Decimal C type and present in its __dict__.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra74.Decimal_dict_div_pow_ops:
  description: "Decimal.__dict__ contains __pow__, __mod__, __divmod__, __truediv__, __floordiv__"
  kind: python_call_eq
  category: class_dict
  id_prefix: decimalmore74

  columns: [id, function, args, expected]
  rows:
    - [has_pow,      "Decimal.__dict__.__contains__", ["__pow__"],      true]
    - [has_mod,      "Decimal.__dict__.__contains__", ["__mod__"],      true]
    - [has_divmod,   "Decimal.__dict__.__contains__", ["__divmod__"],   true]
    - [has_truediv,  "Decimal.__dict__.__contains__", ["__truediv__"],  true]
    - [has_floordiv, "Decimal.__dict__.__contains__", ["__floordiv__"], true]

# ---------------------------------------------------------------------------
# Combined class name check for all five division/power operators
# Reconfirms wrapper_descriptor identity in a single table.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra74.Decimal_all_div_pow_class:
  description: "All five division/power operators are wrapper_descriptor"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalmore74

  columns: [id, function, args, expected]
  rows:
    - [pow_cls2,      Decimal.__pow__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true]
    - [mod_cls2,      Decimal.__mod__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true]
    - [divmod_cls2,   Decimal.__divmod__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - [truediv_cls2,  Decimal.__truediv__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [floordiv_cls2, Decimal.__floordiv__.__class__.__name__.__eq__,["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra74.Decimal_pow.class_name:
  description: "decimal.Decimal.__pow__.__class__.__name__ == 'wrapper_descriptor'"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__pow__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra74.Decimal_mod.class_name:
  description: "decimal.Decimal.__mod__.__class__.__name__ == 'wrapper_descriptor'"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__mod__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra74.Decimal_dict.has_pow:
  description: "decimal.Decimal.__dict__.__contains__('__pow__') == True"
  category: class_dict
  kind: python_call_eq
  function: "Decimal.__dict__.__contains__"
  args: ["__pow__"]
  expected: true

invariant decimal_extra74.Decimal_dict.has_truediv:
  description: "decimal.Decimal.__dict__.__contains__('__truediv__') == True"
  category: class_dict
  kind: python_call_eq
  function: "Decimal.__dict__.__contains__"
  args: ["__truediv__"]
  expected: true

invariant decimal_extra74.Decimal_dict.has_divmod:
  description: "decimal.Decimal.__dict__.__contains__('__divmod__') == True"
  category: class_dict
  kind: python_call_eq
  function: "Decimal.__dict__.__contains__"
  args: ["__divmod__"]
  expected: true
