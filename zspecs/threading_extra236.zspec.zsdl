spec: threading_extra236
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading.RLock and threading.Lock class __doc__ contracts."
    - "threading.RLock is a Python function (factory), not a class. threading.RLock.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.RLock.__name__ == 'RLock' (len=5) — the factory function name. Verified with Python 3.14.3."
    - "threading.RLock.__module__ == 'threading' (len=9) — RLock is defined in Lib/threading.py. Verified with Python 3.14.3."
    - "threading.RLock.__doc__.__class__.__name__ == 'str' — the docstring is a plain str. Verified with Python 3.14.3."
    - "threading.RLock.__doc__.__contains__('reentrant') == True — docstring says 'reentrant lock'. Verified with Python 3.14.3."
    - "threading.RLock.__doc__.__contains__('Factory') == True — docstring starts with 'Factory function'. Verified with Python 3.14.3."
    - "threading.Lock is a C extension type (alias for _thread.lock). threading.Lock.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "threading.Lock.__name__ == 'lock' (len=4) — the C-level class name is lowercase 'lock'. Verified with Python 3.14.3."
    - "threading.Lock.__module__ == '_thread' (len=7) — Lock is defined in Modules/_threadmodule.c. Verified with Python 3.14.3."
    - "threading.Lock.__doc__.__contains__('synchronization') == True — docstring calls it a 'synchronization primitive'. Verified with Python 3.14.3."
    - "threading.Lock.__doc__.__contains__('acquire') == True — docstring lists acquire() as a method. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.RLock function identity and __doc__ contracts
#
# threading.RLock.__name__ == 'RLock' (len=5)
# threading.RLock.__module__ == 'threading' (len=9)
# threading.RLock.__class__.__name__ == 'function'
# threading.RLock.__doc__.__class__.__name__ == 'str'
# threading.RLock.__doc__.__contains__('reentrant') == True
#
# RLock is a Python factory function in Lib/threading.py. New to extra236.
# ---------------------------------------------------------------------------

table threading_extra236.rlock_identity_and_doc:
  description: "threading.RLock function identity: name, module, class is function; doc is str containing 'reentrant'; new to extra236"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra236rlockid

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_name_eq,
       RLock.__name__.__eq__,
       ["RLock"],
       true,
       "threading.RLock.__name__.__eq__('RLock') == True — RLock is a factory function in Lib/threading.py that returns a new reentrant lock; __name__ is 'RLock' (len=5); new to extra236"]
    - [rlock_name_len_5,
       RLock.__name__.__len__,
       [],
       5,
       "threading.RLock.__name__.__len__() == 5 — 'RLock' has exactly 5 characters (R-L-o-c-k); str.__len__() returns 5; new to extra236"]
    - [rlock_module_eq,
       RLock.__module__.__eq__,
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — RLock is defined in Lib/threading.py; __module__ is 'threading' (len=9); new to extra236"]
    - [rlock_class_is_function,
       RLock.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — RLock is a Python factory function, not a class; __class__.__name__ is 'function'; new to extra236"]
    - [rlock_doc_class_is_str,
       RLock.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "threading.RLock.__doc__.__class__.__name__.__eq__('str') == True — the RLock docstring is a plain Python str object; new to extra236"]

# ---------------------------------------------------------------------------
# Table 2: threading.RLock __doc__ content and __qualname__ contracts
#
# threading.RLock.__doc__.__contains__('reentrant') == True
# threading.RLock.__doc__.__contains__('Factory') == True
# threading.RLock.__qualname__ == 'RLock' (len=5)
# threading.RLock.__module__.__len__() == 9
# threading.RLock.__qualname__.__len__() == 5
#
# RLock docstring describes it as a factory returning a reentrant lock.
# New to extra236.
# ---------------------------------------------------------------------------

table threading_extra236.rlock_doc_and_qualname:
  description: "threading.RLock doc contains 'reentrant' and 'Factory'; qualname is 'RLock'; module length is 9; new to extra236"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra236rlockdocid

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_doc_contains_reentrant,
       RLock.__doc__.__contains__,
       ["reentrant"],
       true,
       "threading.RLock.__doc__.__contains__('reentrant') == True — docstring says 'returns a new reentrant lock'; str.__contains__('reentrant') returns True; new to extra236"]
    - [rlock_doc_contains_factory,
       RLock.__doc__.__contains__,
       ["Factory"],
       true,
       "threading.RLock.__doc__.__contains__('Factory') == True — docstring begins 'Factory function that returns a new reentrant lock'; str.__contains__('Factory') returns True; new to extra236"]
    - [rlock_qualname_eq,
       RLock.__qualname__.__eq__,
       ["RLock"],
       true,
       "threading.RLock.__qualname__.__eq__('RLock') == True — RLock is a top-level function with unqualified qualname 'RLock'; new to extra236"]
    - [rlock_module_len_9,
       RLock.__module__.__len__,
       [],
       9,
       "threading.RLock.__module__.__len__() == 9 — 'threading' has exactly 9 characters (t-h-r-e-a-d-i-n-g); str.__len__() returns 9; new to extra236"]
    - [rlock_qualname_len_5,
       RLock.__qualname__.__len__,
       [],
       5,
       "threading.RLock.__qualname__.__len__() == 5 — 'RLock' qualname has exactly 5 characters; str.__len__() returns 5; new to extra236"]

# ---------------------------------------------------------------------------
# Table 3: threading.Lock class identity and __doc__ contracts
#
# threading.Lock.__name__ == 'lock' (len=4)
# threading.Lock.__module__ == '_thread' (len=7)
# threading.Lock.__class__.__name__ == 'type'
# threading.Lock.__doc__.__contains__('synchronization') == True
# threading.Lock.__doc__.__contains__('acquire') == True
#
# threading.Lock is an alias for the C extension type _thread.lock.
# New to extra236.
# ---------------------------------------------------------------------------

table threading_extra236.lock_class_identity_and_doc:
  description: "threading.Lock class identity: name 'lock', module '_thread', metaclass type; doc contains 'synchronization' and 'acquire'; new to extra236"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra236lockclassid

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,
       Lock.__name__.__eq__,
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — threading.Lock is an alias for _thread.lock; the C-level class name is lowercase 'lock' (len=4); new to extra236"]
    - [lock_name_len_4,
       Lock.__name__.__len__,
       [],
       4,
       "threading.Lock.__name__.__len__() == 4 — 'lock' has exactly 4 characters (l-o-c-k); str.__len__() returns 4; new to extra236"]
    - [lock_module_eq,
       Lock.__module__.__eq__,
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — _thread.lock is defined in Modules/_threadmodule.c; __module__ is '_thread' (len=7); new to extra236"]
    - [lock_class_is_type,
       Lock.__class__.__name__.__eq__,
       ["type"],
       true,
       "threading.Lock.__class__.__name__.__eq__('type') == True — Lock is a C extension type; its metaclass is the built-in type; new to extra236"]
    - [lock_doc_contains_synchronization,
       Lock.__doc__.__contains__,
       ["synchronization"],
       true,
       "threading.Lock.__doc__.__contains__('synchronization') == True — docstring says 'A lock object is a synchronization primitive'; str.__contains__('synchronization') returns True; new to extra236"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra236
# ---------------------------------------------------------------------------

invariant threading_extra236.rlock_name_eq:
  description: "threading.RLock.__name__ == 'RLock' (len=5); new to extra236"
  kind: python_call_eq
  function: RLock.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra236.rlock_name_len_5:
  description: "threading.RLock.__name__.__len__() == 5 — 'RLock' has 5 characters; new to extra236"
  kind: python_call_eq
  function: RLock.__name__.__len__
  args: []
  expected: 5

invariant threading_extra236.rlock_module_eq:
  description: "threading.RLock.__module__ == 'threading'; new to extra236"
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra236.rlock_module_len_9:
  description: "threading.RLock.__module__.__len__() == 9 — 'threading' has 9 characters; new to extra236"
  kind: python_call_eq
  function: RLock.__module__.__len__
  args: []
  expected: 9

invariant threading_extra236.rlock_class_is_function:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a Python factory function; new to extra236"
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra236.rlock_qualname_eq:
  description: "threading.RLock.__qualname__ == 'RLock'; new to extra236"
  kind: python_call_eq
  function: RLock.__qualname__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra236.rlock_doc_class_is_str:
  description: "threading.RLock.__doc__.__class__.__name__ == 'str' — docstring is a plain str; new to extra236"
  kind: python_call_eq
  function: RLock.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant threading_extra236.rlock_doc_contains_reentrant:
  description: "threading.RLock.__doc__.__contains__('reentrant') == True; new to extra236"
  kind: python_call_eq
  function: RLock.__doc__.__contains__
  args: ["reentrant"]
  expected: true

invariant threading_extra236.rlock_doc_contains_factory:
  description: "threading.RLock.__doc__.__contains__('Factory') == True; new to extra236"
  kind: python_call_eq
  function: RLock.__doc__.__contains__
  args: ["Factory"]
  expected: true

invariant threading_extra236.lock_name_eq:
  description: "threading.Lock.__name__ == 'lock' (len=4) — C-level class name is lowercase; new to extra236"
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra236.lock_name_len_4:
  description: "threading.Lock.__name__.__len__() == 4 — 'lock' has 4 characters; new to extra236"
  kind: python_call_eq
  function: Lock.__name__.__len__
  args: []
  expected: 4

invariant threading_extra236.lock_module_eq:
  description: "threading.Lock.__module__ == '_thread'; new to extra236"
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra236.lock_class_is_type:
  description: "threading.Lock.__class__.__name__ == 'type' — Lock is a C extension type; new to extra236"
  kind: python_call_eq
  function: Lock.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant threading_extra236.lock_doc_contains_synchronization:
  description: "threading.Lock.__doc__.__contains__('synchronization') == True; new to extra236"
  kind: python_call_eq
  function: Lock.__doc__.__contains__
  args: ["synchronization"]
  expected: true

invariant threading_extra236.lock_doc_contains_acquire:
  description: "threading.Lock.__doc__.__contains__('acquire') == True; new to extra236"
  kind: python_call_eq
  function: Lock.__doc__.__contains__
  args: ["acquire"]
  expected: true
