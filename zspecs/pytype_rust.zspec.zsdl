spec: pytype_rust
version: ">=3.9"
backend: rust_module(pytype_rust)

docs: https://github.com/google/pytype

provenance:
  derived_from:
    - "https://github.com/google/pytype — pytype type checker"
  notes:
    - "pytype is Google's static type analyzer."
    - "pytype.__version__ is non-empty."
    - "pytype has version attribute."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pytype_rust.has_version:
  description: "pytype has version attribute"
  category: version
  kind: python_call_eq
  function: pytype_has_version
  args: []
  expected: true

invariant pytype_rust.version_is_string:
  description: "pytype.__version__ is a string"
  category: version
  kind: python_call_eq
  function: pytype_version_is_string
  args: []
  expected: true

invariant pytype_rust.version_nonempty:
  description: "pytype version string is non-empty"
  category: version
  kind: python_call_eq
  function: pytype_version_nonempty
  args: []
  expected: true

