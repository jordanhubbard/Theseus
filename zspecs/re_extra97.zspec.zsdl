spec: re_extra97
version: ">=3.9"
backend: python_module(re)
extends: re_extra96

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra96.zspec.zsdl."
    - "This spec covers: re.Pattern method class names, re.Pattern dunder method class names, re.Match method class names, and re.Pattern/re.Match class identity."
    - "re.Pattern is a C extension type from _re. Its regular methods (match, search, etc.) are 'method_descriptor' when accessed on the class."
    - "re.Pattern.__repr__, __hash__, __eq__, __ne__ are 'wrapper_descriptor' (slot wrappers on C extension types)."
    - "re.Match methods (group, groups, groupdict, start, end, span) are 'method_descriptor'; __repr__ and __getitem__ are 'wrapper_descriptor'."
    - "re.Pattern.__name__ = 'Pattern', re.Pattern.__module__ = 're', re.Pattern.__bases__[0].__name__ = 'object'."
    - "re.Pattern.__mro__.__len__() = 2 — MRO is [Pattern, object] (C extension type with direct object base)."
    - "re.Match.__name__ = 'Match', re.Match.__module__ = 're', re.Match.__mro__.__len__() = 2."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern method class names: match, search, fullmatch, findall, finditer, sub, subn, split
# All are method_descriptor (C extension methods accessed on the class).
# ---------------------------------------------------------------------------

table re_extra97.Pattern_main_methods_classname:
  description: "re.Pattern main methods (match, search, fullmatch, findall, finditer, sub, subn, split) __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: repatternmethods97

  columns: [id, function, args, expected]
  rows:
    - [pat_match_cls,     Pattern.match.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [pat_search_cls,    Pattern.search.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [pat_fullmatch_cls, Pattern.fullmatch.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [pat_findall_cls,   Pattern.findall.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [pat_finditer_cls,  Pattern.finditer.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [pat_sub_cls,       Pattern.sub.__class__.__name__.__eq__,       ["method_descriptor"], true]
    - [pat_subn_cls,      Pattern.subn.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [pat_split_cls,     Pattern.split.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [pat_match_not_wr,  Pattern.match.__class__.__name__.__eq__,     ["wrapper_descriptor"], false]

# ---------------------------------------------------------------------------
# re.Pattern dunder method class names: __repr__, __hash__, __eq__
# These are slot wrappers (wrapper_descriptor) on C extension types.
# __copy__ and __deepcopy__ are method_descriptor (regular C methods).
# ---------------------------------------------------------------------------

table re_extra97.Pattern_dunder_methods_classname:
  description: "re.Pattern dunder method class names: __repr__, __hash__, __eq__ are wrapper_descriptor; __copy__, __deepcopy__ are method_descriptor"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: repatternmethods97

  columns: [id, function, args, expected]
  rows:
    - [pat_repr_cls,      Pattern.__repr__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true]
    - [pat_hash_cls,      Pattern.__hash__.__class__.__name__.__eq__,     ["wrapper_descriptor"], true]
    - [pat_eq_cls,        Pattern.__eq__.__class__.__name__.__eq__,       ["wrapper_descriptor"], true]
    - [pat_copy_cls,      Pattern.__copy__.__class__.__name__.__eq__,     ["method_descriptor"],  true]
    - [pat_deepcopy_cls,  Pattern.__deepcopy__.__class__.__name__.__eq__, ["method_descriptor"],  true]
    - [pat_repr_not_meth, Pattern.__repr__.__class__.__name__.__eq__,     ["method_descriptor"],  false]

# ---------------------------------------------------------------------------
# re.Match method class names: group, groups, groupdict, start, end, span
# All are method_descriptor. __repr__ and __getitem__ are wrapper_descriptor.
# ---------------------------------------------------------------------------

table re_extra97.Match_methods_classname:
  description: "re.Match method class names: group, groups, groupdict, start, end, span are method_descriptor; __repr__, __getitem__ are wrapper_descriptor"
  kind: python_call_eq
  category: method_descriptor
  id_prefix: repatternmethods97

  columns: [id, function, args, expected]
  rows:
    - [match_group_cls,    Match.group.__class__.__name__.__eq__,      ["method_descriptor"],  true]
    - [match_groups_cls,   Match.groups.__class__.__name__.__eq__,     ["method_descriptor"],  true]
    - [match_groupd_cls,   Match.groupdict.__class__.__name__.__eq__,  ["method_descriptor"],  true]
    - [match_start_cls,    Match.start.__class__.__name__.__eq__,      ["method_descriptor"],  true]
    - [match_end_cls,      Match.end.__class__.__name__.__eq__,        ["method_descriptor"],  true]
    - [match_span_cls,     Match.span.__class__.__name__.__eq__,       ["method_descriptor"],  true]
    - [match_repr_cls,     Match.__repr__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [match_getitem_cls,  Match.__getitem__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# re.Pattern and re.Match class identity
# Pattern.__name__ == 'Pattern', Pattern.__module__ == 're'
# Pattern.__mro__.__len__() == 2 ([Pattern, object])
# Match.__name__ == 'Match', Match.__module__ == 're'
# Match.__mro__.__len__() == 2 ([Match, object])
# ---------------------------------------------------------------------------

table re_extra97.Pattern_Match_class_identity:
  description: "re.Pattern and re.Match class identity: __name__, __module__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: repatternmethods97

  columns: [id, function, args, expected]
  rows:
    - [pat_name_eq,      Pattern.__name__.__eq__,    ["Pattern"], true]
    - [pat_module_eq,    Pattern.__module__.__eq__,  ["re"],      true]
    - [pat_mro_len,      Pattern.__mro__.__len__,    [],          2]
    - [match_name_eq,    Match.__name__.__eq__,      ["Match"],   true]
    - [match_module_eq,  Match.__module__.__eq__,    ["re"],      true]
    - [match_mro_len,    Match.__mro__.__len__,      [],          2]
    - [pat_name_not_re,  Pattern.__name__.__eq__,    ["re"],      false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra97.Pattern.match_is_method_descriptor:
  description: "re.Pattern.match.__class__.__name__ == 'method_descriptor' (re.Pattern is a C extension type; its regular methods are method_descriptor when accessed on the class)"
  category: method_descriptor
  kind: python_call_eq
  function: Pattern.match.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant re_extra97.Pattern.repr_is_wrapper_descriptor:
  description: "re.Pattern.__repr__.__class__.__name__ == 'wrapper_descriptor' (slot wrappers like __repr__ on C extension types are wrapper_descriptor, not method_descriptor)"
  category: method_descriptor
  kind: python_call_eq
  function: Pattern.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant re_extra97.Match.group_is_method_descriptor:
  description: "re.Match.group.__class__.__name__ == 'method_descriptor' (re.Match is a C extension type; group() is a regular C method)"
  category: method_descriptor
  kind: python_call_eq
  function: Match.group.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant re_extra97.Pattern.mro_len_2:
  description: "re.Pattern.__mro__.__len__() == 2 (MRO is [Pattern, object]; re.Pattern is a C extension type with direct object base)"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__mro__.__len__
  args: []
  expected: 2

invariant re_extra97.Match.module_is_re:
  description: "re.Match.__module__ == 're' (re.Match is exposed through the re module, even though it is implemented in the C extension _sre)"
  category: class_identity
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true
