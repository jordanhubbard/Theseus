spec: functools_extra72
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra71.zspec.zsdl."
    - "Wave 233 theme: __defaults__ values for functools functions + lru_cache/cached_property identity."
    - "wraps.__defaults__.__class__.__name__ == 'tuple' — wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES) has 2 positional defaults; __defaults__ is a tuple. Verified with Python 3.14.3."
    - "wraps.__defaults__.__len__() == 2 — wraps has 2 default args: assigned and updated. Verified with Python 3.14.3."
    - "update_wrapper.__defaults__.__class__.__name__ == 'tuple' — update_wrapper(wrapper, wrapped, assigned=..., updated=...) has 2 positional defaults. Verified with Python 3.14.3."
    - "update_wrapper.__defaults__.__len__() == 2 — same count: 2 defaults. Verified with Python 3.14.3."
    - "lru_cache.__defaults__.__class__.__name__ == 'tuple' — lru_cache(maxsize=128, typed=False) has 2 positional defaults. Verified with Python 3.14.3."
    - "lru_cache.__defaults__.__len__() == 2 — maxsize and typed are the two defaults. Verified with Python 3.14.3."
    - "lru_cache.__defaults__[0].__class__.__name__ == 'int' — maxsize=128 is an int. Verified with Python 3.14.3."
    - "lru_cache.__defaults__[1].__class__.__name__ == 'bool' — typed=False is a bool. Verified with Python 3.14.3."
    - "cached_property.__class__.__name__ == 'type' — cached_property is a pure-Python class; its metaclass is type. Verified with Python 3.14.3."
    - "cached_property.__module__ == 'functools' — cached_property is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "cached_property.__qualname__ == 'cached_property' — top-level class so qualname equals simple name. Verified with Python 3.14.3."
    - "cached_property.__bases__[0].__name__ == 'object' — cached_property subclasses object directly. Verified with Python 3.14.3."
    - "Prior functools_extra68 covered __defaults__.__class__.__name__ == 'tuple' for wraps/update_wrapper/lru_cache. This spec adds __defaults__.__len__(), lru_cache.__defaults__[0]/__defaults__[1] element type checks, and cached_property identity attributes. All checks in this spec are new to extra72."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools __defaults__.__class__.__name__ — extra72
#
# Wave 233 theme: __defaults__ class name for wraps/update_wrapper/lru_cache.
#
# For Python functions, __defaults__ is a tuple of default values for
# positional parameters with defaults. All three functions have positional
# defaults so __defaults__.__class__.__name__ == 'tuple' for each.
#
# wraps(wrapped, assigned=..., updated=...)     → __defaults__ is 2-element tuple
# update_wrapper(wrapper, wrapped, ..., ...)    → __defaults__ is 2-element tuple
# lru_cache(maxsize=128, typed=False)           → __defaults__ == (128, False)
#
# Prior functools_extra68 already verified __defaults__.__class__.__name__.__eq__('tuple')
# for all three. This table is included here to anchor the id_prefix for this wave.
# The __len__ rows are new to extra72.
# ---------------------------------------------------------------------------

table functools_extra72.defaults_class_name:
  description: "functools function __defaults__.__class__.__name__.__eq__('tuple')==true — wraps/update_wrapper/lru_cache all have positional defaults so __defaults__ is a tuple; wave 233 __defaults__ checks; new to extra72"
  kind: python_call_eq
  category: defaults_type
  id_prefix: functoolsdef72

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_defaults_class_name_eq_tuple,
       wraps.__defaults__.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.wraps.__defaults__.__class__.__name__.__eq__('tuple') == True — wraps is a pure-Python decorator factory (Lib/functools.py) with signature wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES); both 'assigned' and 'updated' have positional defaults so __defaults__ is a 2-element tuple; tuple.__name__ == 'tuple'; __eq__ returns True; new anchor in extra72 id_prefix functoolsdef72; new to extra72"]
    - [update_wrapper_defaults_class_name_eq_tuple,
       update_wrapper.__defaults__.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.update_wrapper.__defaults__.__class__.__name__.__eq__('tuple') == True — update_wrapper(wrapper, wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES) has 2 positional defaults so __defaults__ is a 2-element tuple; tuple.__name__ == 'tuple'; __eq__ returns True; new anchor in extra72 id_prefix functoolsdef72; new to extra72"]
    - [lru_cache_defaults_class_name_eq_tuple,
       lru_cache.__defaults__.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.lru_cache.__defaults__.__class__.__name__.__eq__('tuple') == True — lru_cache(maxsize=128, typed=False) has 2 positional defaults so __defaults__ == (128, False), a 2-element tuple; tuple.__name__ == 'tuple'; __eq__ returns True; new anchor in extra72 id_prefix functoolsdef72; new to extra72"]

# ---------------------------------------------------------------------------
# functools __defaults__.__len__() — extra72
#
# Wave 233 theme: __defaults__ length for wraps/update_wrapper/lru_cache.
#
# Each function has exactly 2 positional default values:
#   wraps:          assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES → len=2
#   update_wrapper: assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES → len=2
#   lru_cache:      maxsize=128, typed=False → len=2
#
# No prior functools spec checks __defaults__.__len__() for any of these
# functions. New to extra72.
# ---------------------------------------------------------------------------

table functools_extra72.defaults_len:
  description: "functools function __defaults__.__len__()==2 — wraps/update_wrapper/lru_cache each have exactly 2 positional defaults; wave 233 __defaults__ length; new to extra72"
  kind: python_call_eq
  category: defaults_len
  id_prefix: functoolsdef72

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_defaults_len_eq_2,
       wraps.__defaults__.__len__,
       [],
       2,
       "functools.wraps.__defaults__.__len__() == 2 — wraps is a pure-Python decorator factory (Lib/functools.py) with signature wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES); 'assigned' and 'updated' are the two parameters with positional defaults; __defaults__ is therefore a 2-element tuple; tuple.__len__() returns 2; no prior functools spec checks __defaults__.__len__() for wraps; new to extra72"]
    - [update_wrapper_defaults_len_eq_2,
       update_wrapper.__defaults__.__len__,
       [],
       2,
       "functools.update_wrapper.__defaults__.__len__() == 2 — update_wrapper(wrapper, wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES) has 'assigned' and 'updated' as the two positional defaults; __defaults__ is a 2-element tuple; tuple.__len__() returns 2; no prior functools spec checks __defaults__.__len__() for update_wrapper; new to extra72"]
    - [lru_cache_defaults_len_eq_2,
       lru_cache.__defaults__.__len__,
       [],
       2,
       "functools.lru_cache.__defaults__.__len__() == 2 — lru_cache(maxsize=128, typed=False) has 'maxsize' and 'typed' as its two positional defaults; __defaults__ == (128, False), a 2-element tuple; tuple.__len__() returns 2; no prior functools spec checks __defaults__.__len__() for lru_cache; new to extra72"]

# ---------------------------------------------------------------------------
# lru_cache.__defaults__ element types — extra72
#
# Wave 233 theme: the types of the two elements in lru_cache.__defaults__.
#
# lru_cache.__defaults__ == (128, False)
#   lru_cache.__defaults__[0] is 128 → int  → __class__.__name__ == 'int'
#   lru_cache.__defaults__[1] is False → bool → __class__.__name__ == 'bool'
#
# Function values containing '[' MUST be double-quoted in table rows.
# No prior functools spec checks the types of lru_cache.__defaults__ elements.
# New to extra72.
# ---------------------------------------------------------------------------

table functools_extra72.lru_cache_defaults_types:
  description: "lru_cache.__defaults__[0]/__defaults__[1] element type checks — maxsize=128 is int, typed=False is bool; wave 233 __defaults__ element types; function values with '[' are double-quoted; new to extra72"
  kind: python_call_eq
  category: defaults_element_type
  id_prefix: functoolsdef72

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_defaults_0_class_name_eq_int,
       "lru_cache.__defaults__[0].__class__.__name__.__eq__",
       ["int"],
       true,
       "functools.lru_cache.__defaults__[0].__class__.__name__.__eq__('int') == True — lru_cache(maxsize=128, typed=False) has __defaults__ == (128, False); the first element __defaults__[0] is 128, an integer; 128.__class__ is the built-in int type; int.__name__ == 'int' (3 chars); __eq__ returns True; function value contains '[' so it is double-quoted in the table row; no prior functools spec checks lru_cache.__defaults__[0].__class__.__name__; new to extra72"]
    - [lru_cache_defaults_1_class_name_eq_bool,
       "lru_cache.__defaults__[1].__class__.__name__.__eq__",
       ["bool"],
       true,
       "functools.lru_cache.__defaults__[1].__class__.__name__.__eq__('bool') == True — lru_cache(maxsize=128, typed=False) has __defaults__ == (128, False); the second element __defaults__[1] is False, a boolean; False.__class__ is the built-in bool type; bool.__name__ == 'bool' (4 chars); __eq__ returns True; function value contains '[' so it is double-quoted in the table row; no prior functools spec checks lru_cache.__defaults__[1].__class__.__name__; new to extra72"]

# ---------------------------------------------------------------------------
# cached_property class identity — extra72
#
# Wave 233 theme: cached_property is a pure-Python class defined at module
# level in Lib/functools.py. Inspect its metaclass (__class__.__name__),
# module, qualname, and direct base class.
#
# cached_property.__class__.__name__ == 'type'    (metaclass is type)
# cached_property.__module__         == 'functools'
# cached_property.__qualname__       == 'cached_property'
# cached_property.__bases__[0].__name__ == 'object'  (direct base is object)
#
# Function values containing '[' MUST be double-quoted in table rows.
# No prior functools spec checks these cached_property identity attributes.
# New to extra72.
# ---------------------------------------------------------------------------

table functools_extra72.cached_property_identity:
  description: "cached_property class identity: __module__=='functools', __qualname__=='cached_property', __bases__[0].__name__=='object'; wave 233 cached_property identity; new to extra72"
  kind: python_call_eq
  category: cached_property_identity
  id_prefix: functoolsdef72

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_module_eq_functools,
       cached_property.__module__.__eq__,
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — cached_property is a pure-Python class defined in Lib/functools.py; its __module__ attribute is set to 'functools' when the module is imported; __eq__ on the str 'functools' returns True; no prior functools spec checks cached_property.__module__; new to extra72"]
    - [cached_property_qualname_eq_cached_property,
       cached_property.__qualname__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__.__eq__('cached_property') == True — cached_property is a top-level (non-nested) class in the functools module; its __qualname__ is therefore equal to its simple name 'cached_property' (15 chars); no intermediate class or function scope appears in the qualified name; __eq__ returns True; no prior functools spec checks cached_property.__qualname__; new to extra72"]
    - [cached_property_bases_0_name_eq_object,
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property is a pure-Python class that subclasses object directly (no intermediate base class); cached_property.__bases__ is a tuple with a single element, the built-in object type; object.__name__ == 'object' (6 chars); __eq__ returns True; function value contains '[' so it is double-quoted; no prior functools spec checks cached_property.__bases__[0].__name__; new to extra72"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra72
# ---------------------------------------------------------------------------

invariant functools_extra72.wraps_defaults_tuple:
  description: "functools.wraps.__defaults__.__class__.__name__.__eq__('tuple') == True — wraps has 2 positional defaults; __defaults__ is a tuple; wave 233 __defaults__ checks; new to extra72"
  kind: python_call_eq
  function: wraps.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra72.wraps_defaults_len_2:
  description: "functools.wraps.__defaults__.__len__() == 2 — wraps has exactly 2 positional defaults (assigned and updated); wave 233 __defaults__ length; new to extra72"
  kind: python_call_eq
  function: wraps.__defaults__.__len__
  args: []
  expected: 2

invariant functools_extra72.lru_cache_defaults_maxsize_int:
  description: "functools.lru_cache.__defaults__[0].__class__.__name__.__eq__('int') == True — maxsize=128 is an int; wave 233 __defaults__ element types; new to extra72"
  kind: python_call_eq
  function: "lru_cache.__defaults__[0].__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant functools_extra72.cached_property_module_functools:
  description: "functools.cached_property.__module__.__eq__('functools') == True — cached_property is defined in Lib/functools.py; wave 233 cached_property identity; new to extra72"
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra72.cached_property_bases_object:
  description: "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property subclasses object directly; wave 233 cached_property identity; new to extra72"
  kind: python_call_eq
  function: "cached_property.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
