spec: zlib_extra14
version: ">=3.9"
backend: python_module(zlib)

docs: https://docs.python.org/3/library/zlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zlib.html — Python zlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/zlibmodule.c"
    - "zlib_extra13.zspec.zsdl — covers compress/decompress/error __module__; error.__bases__[0].__name__; Z_NO_COMPRESSION/Z_DEFAULT_STRATEGY/MAX_WBITS/Z_NO_FLUSH/Z_SYNC_FLUSH/Z_FULL_FLUSH __class__.__name__ == 'int'."
    - "zlib_extra12.zspec.zsdl — covers Compress.compress/flush/copy and Decompress.decompress/flush/copy __qualname__ (extra12); Z_BEST_COMPRESSION/Z_BEST_SPEED __class__.__name__ == 'int' (extra12)."
    - "zlib_extra11.zspec.zsdl — covers compress/decompress/compressobj/decompressobj/crc32/adler32 __qualname__ standalone (extra11); error.__qualname__ standalone (extra11); zlib.__package__ (extra11); zlib._ZlibDecompressor.__qualname__ (extra11)."
    - "zlib_extra10.zspec.zsdl — covers compress/decompress/compressobj/decompressobj/crc32/adler32 __qualname__ standalone (extra10); error.__qualname__ standalone (extra10); zlib.__name__ standalone (extra10)."
    - "zlib_extra7.zspec.zsdl — covers Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int' (extra7 anchor)."
    - "zlib_extra3.zspec.zsdl — covers DEF_BUF_SIZE.__class__.__name__ == 'int'; DEF_BUF_SIZE value == 16384; DEFLATED value == 8."
    - "zlib_extra2.zspec.zsdl — covers Compress/Decompress type __name__; Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int'; Z_BEST_COMPRESSION value == 9; Z_BEST_SPEED value == 1."
    - "zlib_extra.zspec.zsdl — covers DEFLATED.__class__.__name__ == 'int'; Z_DEFAULT_COMPRESSION.__class__.__name__ == 'int'; function __name__ attrs; roundtrip."
  notes:
    - "This spec extends zlib through zlib_extra13; it does NOT duplicate invariants present in those files."
    - "Focus: crc32/__module__ and adler32/__module__ (novel — extra13 covers compress/decompress/error __module__ but not crc32/adler32); compressobj/__module__ and decompressobj/__module__ (novel); Compress/__module__ and Decompress/__module__ (novel C-type module affiliation); Compress/__bases__[0].__name__ and Decompress/__bases__[0].__name__ (novel hierarchy); novel int-type checks for Z_BLOCK, Z_FINISH, Z_PARTIAL_FLUSH, Z_TREES, Z_RLE, Z_HUFFMAN_ONLY; ZLIB_VERSION/__class__.__name__ == 'str'; DEF_MEM_LEVEL/__class__.__name__ == 'int'."
    - "zlib.crc32.__module__ == 'zlib': crc32 is a C builtin; extra13 covers compress/decompress/error __module__ but not crc32. Verified 2026-04-09."
    - "zlib.adler32.__module__ == 'zlib': same as crc32. Verified 2026-04-09."
    - "zlib.compressobj.__module__ == 'zlib': compressobj is a C builtin; extra13 does not cover it. Verified 2026-04-09."
    - "zlib.decompressobj.__module__ == 'zlib': same as compressobj. Verified 2026-04-09."
    - "Compress.__module__ == 'zlib': the internal C-level Compress type (returned by compressobj()) has __module__ == 'zlib'. No prior zlib spec checks this. Verified 2026-04-09."
    - "Decompress.__module__ == 'zlib': same as Compress. Verified 2026-04-09."
    - "Compress.__bases__[0].__name__ == 'object': Compress is a direct C extension subclass of object. No prior zlib spec checks this. Verified 2026-04-09."
    - "Decompress.__bases__[0].__name__ == 'object': same as Compress. Verified 2026-04-09."
    - "Z_BLOCK/Z_FINISH/Z_PARTIAL_FLUSH/Z_TREES/Z_RLE/Z_HUFFMAN_ONLY __class__.__name__ == 'int': extra13 covers Z_NO_FLUSH/Z_SYNC_FLUSH/Z_FULL_FLUSH; these six are novel. Verified 2026-04-09."
    - "ZLIB_VERSION.__class__.__name__ == 'str': the ZLIB_VERSION constant is a string. No prior zlib spec checks __class__.__name__ for this constant. Verified 2026-04-09."
    - "DEF_MEM_LEVEL.__class__.__name__ == 'int': no prior zlib spec checks DEF_MEM_LEVEL as an int-type (extra2 covers its value; extra3 covers DEF_BUF_SIZE). Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# crc32.__module__ == 'zlib' — novel, extra14 anchor
#
# zlib_extra13 covers compress/decompress/error __module__ but not crc32.
# zlib.crc32 is a C builtin whose __module__ is 'zlib'. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.crc32.module:
  description: "zlib.crc32.__module__ == 'zlib' — C builtin function's __module__ is 'zlib' (extra14)"
  category: module_affiliation
  kind: python_call_eq
  function: crc32.__module__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# adler32.__module__ == 'zlib' — novel, extra14 anchor
#
# No prior zlib spec checks adler32.__module__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.adler32.module:
  description: "zlib.adler32.__module__ == 'zlib' — C builtin function's __module__ is 'zlib' (extra14)"
  category: module_affiliation
  kind: python_call_eq
  function: adler32.__module__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# compressobj.__module__ == 'zlib' — novel, extra14 anchor
#
# No prior zlib spec checks compressobj.__module__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.compressobj.module:
  description: "zlib.compressobj.__module__ == 'zlib' — C builtin function's __module__ is 'zlib' (extra14)"
  category: module_affiliation
  kind: python_call_eq
  function: compressobj.__module__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# decompressobj.__module__ == 'zlib' — novel, extra14 anchor
#
# No prior zlib spec checks decompressobj.__module__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.decompressobj.module:
  description: "zlib.decompressobj.__module__ == 'zlib' — C builtin function's __module__ is 'zlib' (extra14)"
  category: module_affiliation
  kind: python_call_eq
  function: decompressobj.__module__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# Compress.__module__ == 'zlib' — novel, extra14 anchor
#
# No prior zlib spec checks the __module__ attribute of the internal Compress
# type (returned by zlib.compressobj()). Its __module__ is 'zlib'.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.Compress.module:
  description: "zlib.Compress.__module__ == 'zlib' — internal C-level Compress type's __module__ is 'zlib' (extra14)"
  category: module_affiliation
  kind: python_call_eq
  function: Compress.__module__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# Decompress.__module__ == 'zlib' — novel, extra14 anchor
#
# No prior zlib spec checks Decompress.__module__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.Decompress.module:
  description: "zlib.Decompress.__module__ == 'zlib' — internal C-level Decompress type's __module__ is 'zlib' (extra14)"
  category: module_affiliation
  kind: python_call_eq
  function: Decompress.__module__.__eq__
  args: ["zlib"]
  expected: true

# ---------------------------------------------------------------------------
# Compress.__bases__[0].__name__ == 'object' — novel, extra14 anchor
#
# No prior zlib spec checks Compress.__bases__[0].__name__. The internal
# Compress type is a direct C extension subclass of object. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.Compress.base_name:
  description: "zlib.Compress.__bases__[0].__name__ == 'object' — Compress directly subclasses object (extra14)"
  category: hierarchy
  kind: python_call_eq
  function: "Compress.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Decompress.__bases__[0].__name__ == 'object' — novel, extra14 anchor
#
# No prior zlib spec checks Decompress.__bases__[0].__name__. Same as
# Compress — a direct C extension subclass of object. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.Decompress.base_name:
  description: "zlib.Decompress.__bases__[0].__name__ == 'object' — Decompress directly subclasses object (extra14)"
  category: hierarchy
  kind: python_call_eq
  function: "Decompress.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Z_BLOCK.__class__.__name__ == 'int' — novel, extra14 anchor
#
# extra13 covers Z_NO_FLUSH/Z_SYNC_FLUSH/Z_FULL_FLUSH. Z_BLOCK is a distinct
# flush mode constant not covered in any prior zlib spec. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.Z_BLOCK.class_is_int:
  description: "zlib.Z_BLOCK.__class__.__name__ == 'int' — flush constant is a plain Python int (extra14)"
  category: type_identity
  kind: python_call_eq
  function: Z_BLOCK.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Z_FINISH.__class__.__name__ == 'int' — novel, extra14 anchor
#
# No prior zlib spec checks Z_FINISH.__class__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.Z_FINISH.class_is_int:
  description: "zlib.Z_FINISH.__class__.__name__ == 'int' — flush constant is a plain Python int (extra14)"
  category: type_identity
  kind: python_call_eq
  function: Z_FINISH.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Z_PARTIAL_FLUSH.__class__.__name__ == 'int' — novel, extra14 anchor
#
# No prior zlib spec checks Z_PARTIAL_FLUSH.__class__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.Z_PARTIAL_FLUSH.class_is_int:
  description: "zlib.Z_PARTIAL_FLUSH.__class__.__name__ == 'int' — flush constant is a plain Python int (extra14)"
  category: type_identity
  kind: python_call_eq
  function: Z_PARTIAL_FLUSH.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Z_TREES.__class__.__name__ == 'int' — novel, extra14 anchor
#
# No prior zlib spec checks Z_TREES.__class__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.Z_TREES.class_is_int:
  description: "zlib.Z_TREES.__class__.__name__ == 'int' — flush constant is a plain Python int (extra14)"
  category: type_identity
  kind: python_call_eq
  function: Z_TREES.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Z_RLE.__class__.__name__ == 'int' — novel, extra14 anchor
#
# No prior zlib spec checks Z_RLE.__class__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.Z_RLE.class_is_int:
  description: "zlib.Z_RLE.__class__.__name__ == 'int' — strategy constant is a plain Python int (extra14)"
  category: type_identity
  kind: python_call_eq
  function: Z_RLE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Z_HUFFMAN_ONLY.__class__.__name__ == 'int' — novel, extra14 anchor
#
# No prior zlib spec checks Z_HUFFMAN_ONLY.__class__.__name__. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.Z_HUFFMAN_ONLY.class_is_int:
  description: "zlib.Z_HUFFMAN_ONLY.__class__.__name__ == 'int' — strategy constant is a plain Python int (extra14)"
  category: type_identity
  kind: python_call_eq
  function: Z_HUFFMAN_ONLY.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# ZLIB_VERSION.__class__.__name__ == 'str' — novel, extra14 anchor
#
# No prior zlib spec checks ZLIB_VERSION.__class__.__name__. ZLIB_VERSION
# is a string constant (the version of the underlying zlib C library).
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.ZLIB_VERSION.class_is_str:
  description: "zlib.ZLIB_VERSION.__class__.__name__ == 'str' — version constant is a Python string (extra14)"
  category: type_identity
  kind: python_call_eq
  function: ZLIB_VERSION.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# DEF_MEM_LEVEL.__class__.__name__ == 'int' — novel, extra14 anchor
#
# zlib_extra2 covers DEF_MEM_LEVEL value but not its __class__.__name__.
# extra3 covers DEF_BUF_SIZE as int type; DEF_MEM_LEVEL is novel. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant zlib_extra14.DEF_MEM_LEVEL.class_is_int:
  description: "zlib.DEF_MEM_LEVEL.__class__.__name__ == 'int' — memory level constant is a plain Python int (extra14)"
  category: type_identity
  kind: python_call_eq
  function: DEF_MEM_LEVEL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table — crc32 + adler32 + compressobj + decompressobj
#                  + Compress + Decompress (extra14)
#
# No prior zlib spec presents these six module_affiliation checks in a table.
# This table anchors all six from the extra14 namespace.
# ---------------------------------------------------------------------------

table zlib_extra14.module_affiliations:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: mod14

  columns: [id, function, args, expected]
  rows:
    - [crc32,        crc32.__module__.__eq__,        ["zlib"], true]
    - [adler32,      adler32.__module__.__eq__,      ["zlib"], true]
    - [compressobj,  compressobj.__module__.__eq__,  ["zlib"], true]
    - [decompressobj, decompressobj.__module__.__eq__, ["zlib"], true]
    - [Compress,     Compress.__module__.__eq__,     ["zlib"], true]
    - [Decompress,   Decompress.__module__.__eq__,   ["zlib"], true]

# ---------------------------------------------------------------------------
# int type identity table — Z_BLOCK, Z_FINISH, Z_PARTIAL_FLUSH, Z_TREES,
#                           Z_RLE, Z_HUFFMAN_ONLY, DEF_MEM_LEVEL (extra14)
#
# No prior zlib spec presents these seven constants as int-type-identity checks.
# This table anchors all seven from the extra14 namespace.
# ---------------------------------------------------------------------------

table zlib_extra14.constant_int_types:
  kind: python_call_eq
  category: type_identity
  id_prefix: ci14

  columns: [id, function, args, expected]
  rows:
    - [Z_BLOCK,         Z_BLOCK.__class__.__name__.__eq__,         ["int"], true]
    - [Z_FINISH,        Z_FINISH.__class__.__name__.__eq__,        ["int"], true]
    - [Z_PARTIAL_FLUSH, Z_PARTIAL_FLUSH.__class__.__name__.__eq__, ["int"], true]
    - [Z_TREES,         Z_TREES.__class__.__name__.__eq__,         ["int"], true]
    - [Z_RLE,           Z_RLE.__class__.__name__.__eq__,           ["int"], true]
    - [Z_HUFFMAN_ONLY,  Z_HUFFMAN_ONLY.__class__.__name__.__eq__,  ["int"], true]
    - [DEF_MEM_LEVEL,   DEF_MEM_LEVEL.__class__.__name__.__eq__,   ["int"], true]
