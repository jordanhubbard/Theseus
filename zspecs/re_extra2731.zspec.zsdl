spec: re_extra2731
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
    - "re_extra2701.zspec.zsdl — covers __lshift__/__rshift__/__invert__ dict-presence"
    - "re_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 629 (re_extra2731) theme: __trunc__, __floor__, and __ceil__ dict-presence checks."
    - "Neither re.Pattern nor re.Match defines __trunc__, __floor__, or __ceil__ in its own __dict__."
    - "__trunc__ supports math.trunc(); regex objects are pattern-matching types, not numeric types."
    - "__floor__ supports math.floor(); regex objects do not implement floor-rounding numeric semantics."
    - "__ceil__ supports math.ceil(); regex objects do not implement ceiling-rounding numeric semantics."
    - "Covers re.Pattern (type(re.compile(''))) and re.Match (type(re.match('', '')))."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2731.no_trunc_in_re_classes:
  description: "__trunc__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the math.trunc() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2731

  columns: [id, function, args, expected]
  rows:
    - ["re2731001", "re.Pattern.__dict__.__contains__", ["__trunc__"], false]
    - ["re2731002", "re.Match.__dict__.__contains__",   ["__trunc__"], false]

# ---------------------------------------------------------------------------
# __floor__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2731.no_floor_in_re_classes:
  description: "__floor__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the math.floor() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2731

  columns: [id, function, args, expected]
  rows:
    - ["re2731003", "re.Pattern.__dict__.__contains__", ["__floor__"], false]
    - ["re2731004", "re.Match.__dict__.__contains__",   ["__floor__"], false]

# ---------------------------------------------------------------------------
# __ceil__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2731.no_ceil_in_re_classes:
  description: "__ceil__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the math.ceil() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2731

  columns: [id, function, args, expected]
  rows:
    - ["re2731005", "re.Pattern.__dict__.__contains__", ["__ceil__"], false]
    - ["re2731006", "re.Match.__dict__.__contains__",   ["__ceil__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern and re.Match have regex methods but not rounding numeric hooks
# Confirms that regex objects are pattern-matching types, not numeric types
# ---------------------------------------------------------------------------

table re_extra2731.re_has_regex_methods_not_rounding_numeric_hooks:
  description: "re.Pattern defines match/search/sub/findall but NOT __trunc__/__floor__/__ceil__; re.Match defines group/groups/start/end but NOT __trunc__/__floor__/__ceil__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2731

  columns: [id, function, args, expected]
  rows:
    - ["re2731007", "re.Pattern.__dict__.__contains__", ["match"],     true]
    - ["re2731008", "re.Pattern.__dict__.__contains__", ["search"],    true]
    - ["re2731009", "re.Pattern.__dict__.__contains__", ["sub"],       true]
    - ["re2731010", "re.Pattern.__dict__.__contains__", ["findall"],   true]
    - ["re2731011", "re.Pattern.__dict__.__contains__", ["__trunc__"], false]
    - ["re2731012", "re.Pattern.__dict__.__contains__", ["__floor__"], false]
    - ["re2731013", "re.Pattern.__dict__.__contains__", ["__ceil__"],  false]
    - ["re2731014", "re.Match.__dict__.__contains__",   ["group"],     true]
    - ["re2731015", "re.Match.__dict__.__contains__",   ["groups"],    true]
    - ["re2731016", "re.Match.__dict__.__contains__",   ["start"],     true]
    - ["re2731017", "re.Match.__dict__.__contains__",   ["end"],       true]
    - ["re2731018", "re.Match.__dict__.__contains__",   ["__trunc__"], false]
    - ["re2731019", "re.Match.__dict__.__contains__",   ["__floor__"], false]
    - ["re2731020", "re.Match.__dict__.__contains__",   ["__ceil__"],  false]
