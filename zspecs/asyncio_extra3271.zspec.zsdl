    - ["as3271010", operator.contains, [asyncio.LifoQueue.__dict__,        "__rand__"], false]

# ---------------------------------------------------------------------------
# __ror__ dict-presence — operator.contains(Cls.__dict__, '__ror__')
#
# All 10 asyncio classes return false for __ror__.
# Reflected bitwise OR (__ror__) is invoked when the left operand's __or__
#   returns NotImplemented — e.g., n | obj triggers obj.__ror__(n).
# asyncio types define no __or__ (confirmed false in wave 661), so
#   __ror__ is equally absent.
# Note: dict defines __or__ (PEP 584 merge, Python 3.9+) and __ror__, but
#   asyncio types are not dict subclasses and implement no dict-merge protocol.
# asyncio.Event/Lock/Condition/Semaphore/BoundedSemaphore: synchronization
#   primitives with no bitwise semantics from either side of |.
# asyncio.Task/Future: coroutine result handles; reflected bitwise OR has
#   no defined meaning for pending result objects.
# asyncio.Queue/PriorityQueue/LifoQueue: item stores; reflected OR is
#   entirely absent from their API.
# ---------------------------------------------------------------------------

