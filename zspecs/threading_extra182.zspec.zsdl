spec: threading_extra182
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.Timer and threading.local class identity — threading.Timer.__name__=='Timer' (len=5); threading.Timer.__module__=='threading'; threading.Timer.__qualname__=='Timer'; threading.Timer.__bases__[0].__name__=='Thread' (Timer inherits from Thread); threading.local.__name__=='_local' (len=6; the class is actually _thread._local aliased as threading.local); threading.local.__module__=='_thread'; threading.local.__qualname__=='_local'; threading.local.__bases__[0].__name__=='object'."
    - "threading.Timer.__name__ == 'Timer' — Timer is a Thread subclass in Lib/threading.py that runs a function after a delay; its __name__ is 'Timer', 5 characters. Verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading' — Timer is defined in Lib/threading.py; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.Timer.__qualname__ == 'Timer' — Timer is a module-level class, so __qualname__ equals __name__ 'Timer'. Verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits directly from Thread (the base threading class); its __bases__[0] is Thread; Thread.__name__ is 'Thread'. Verified with Python 3.14.3."
    - "threading.local.__name__ == '_local' — threading.local is actually _thread._local (a C-implemented thread-local storage class from the _thread module); its __name__ is '_local' (6 chars, with leading underscore), not 'local'. Verified with Python 3.14.3."
    - "threading.local.__module__ == '_thread' — threading.local is _thread._local, a C extension class in the _thread module; its __module__ is '_thread'. Verified with Python 3.14.3."
    - "threading.local.__qualname__ == '_local' — as a module-level C type in _thread, its __qualname__ equals its __name__ '_local'. Verified with Python 3.14.3."
    - "threading.local.__bases__[0].__name__ == 'object' — _local inherits directly from object (no intermediate base class); __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Timer __name__, __module__, __qualname__
#
# threading.Timer.__name__ == 'Timer'
# threading.Timer.__name__.__len__() == 5
# threading.Timer.__module__ == 'threading'
# threading.Timer.__qualname__ == 'Timer'
#
# Timer is a Thread subclass in Lib/threading.py that runs a function after
# a specified delay. Its __name__ is 'Timer' (5 chars). New to extra182.
# ---------------------------------------------------------------------------

table threading_extra182.timer_class_identity:
  description: "threading.Timer.__name__ 'Timer' len 5; __module__ 'threading'; __qualname__ 'Timer' equals __name__; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtimer182

  columns: [id, function, args, expected, description]
  rows:
    - [timer_name_eq,
       "Timer.__name__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — Timer is a Thread subclass in Lib/threading.py that runs a function after a specified delay; its __name__ is 'Timer'; str.__eq__('Timer') returns True; new to extra182"]
    - [timer_name_len_5,
       "Timer.__name__.__len__",
       [],
       5,
       "threading.Timer.__name__.__len__() == 5 — the name 'Timer' has exactly 5 characters: T-i-m-e-r; str.__len__() returns 5; new to extra182"]
    - [timer_module_eq,
       "Timer.__module__.__eq__",
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra182"]
    - [timer_qualname_eq,
       "Timer.__qualname__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__qualname__.__eq__('Timer') == True — Timer is a module-level class (not nested inside another class or function), so its __qualname__ equals its __name__ 'Timer'; str.__eq__('Timer') returns True; new to extra182"]

# ---------------------------------------------------------------------------
# Table 2: threading.Timer.__bases__[0] — inheritance from Thread
#
# threading.Timer.__bases__[0].__name__ == 'Thread'
#
# Timer directly inherits from Thread (the primary threading base class).
# __bases__ is a tuple of direct base classes; __bases__[0] is Thread.
# Thread.__name__ is 'Thread'. Any value containing [ must be double-quoted.
# New to extra182.
# ---------------------------------------------------------------------------

table threading_extra182.timer_bases_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits from Thread; __bases__[0] is the Thread class; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtimer182

  columns: [id, function, args, expected, description]
  rows:
    - [timer_base_is_thread,
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer's direct base class is Thread; __bases__[0] is the Thread class object; Thread.__name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra182"]
    - [timer_base_thread_len_6,
       "Timer.__bases__[0].__name__.__len__",
       [],
       6,
       "threading.Timer.__bases__[0].__name__.__len__() == 6 — the base class name 'Thread' has exactly 6 characters: T-h-r-e-a-d; str.__len__() returns 6; new to extra182"]
    - [timer_base_thread_module,
       "Timer.__bases__[0].__module__.__eq__",
       ["threading"],
       true,
       "threading.Timer.__bases__[0].__module__.__eq__('threading') == True — Thread is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra182"]
    - [timer_has_one_base,
       "Timer.__bases__.__len__",
       [],
       1,
       "threading.Timer.__bases__.__len__() == 1 — Timer has exactly one direct base class (Thread); tuple.__len__() returns 1; new to extra182"]

# ---------------------------------------------------------------------------
# Table 3: threading.local class identity
#
# threading.local.__name__ == '_local'
# threading.local.__name__.__len__() == 6
# threading.local.__module__ == '_thread'
# threading.local.__qualname__ == '_local'
# threading.local.__bases__[0].__name__ == 'object'
#
# threading.local is actually _thread._local, a C extension class. Its
# __name__ is '_local' (6 chars, with leading underscore), __module__ is
# '_thread', and it inherits directly from object. New to extra182.
# ---------------------------------------------------------------------------

table threading_extra182.local_class_identity:
  description: "threading.local.__name__ '_local' len 6; __module__ '_thread' (C ext); __qualname__ '_local'; __bases__[0].__name__ 'object'; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtimer182

  columns: [id, function, args, expected, description]
  rows:
    - [local_name_eq,
       "local.__name__.__eq__",
       ["_local"],
       true,
       "threading.local.__name__.__eq__('_local') == True — threading.local is actually _thread._local, a C-implemented thread-local storage class; its __name__ is '_local' (with leading underscore, 6 chars); str.__eq__('_local') returns True; new to extra182"]
    - [local_name_len_6,
       "local.__name__.__len__",
       [],
       6,
       "threading.local.__name__.__len__() == 6 — the name '_local' has exactly 6 characters: _-l-o-c-a-l; str.__len__() returns 6; new to extra182"]
    - [local_module_eq,
       "local.__module__.__eq__",
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — threading.local is _thread._local, a C extension class in the _thread module; its __module__ attribute is '_thread' (not 'threading'); str.__eq__('_thread') returns True; new to extra182"]
    - [local_qualname_eq,
       "local.__qualname__.__eq__",
       ["_local"],
       true,
       "threading.local.__qualname__.__eq__('_local') == True — _local is a module-level C type in _thread, so its __qualname__ equals its __name__ '_local'; str.__eq__('_local') returns True; new to extra182"]
    - [local_base_is_object,
       "local.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.local.__bases__[0].__name__.__eq__('object') == True — _local inherits directly from object with no intermediate base class; __bases__[0] is the object type; object.__name__ is 'object'; str.__eq__('object') returns True; new to extra182"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra182
# ---------------------------------------------------------------------------

invariant threading_extra182.timer_name_is_timer:
  description: "threading.Timer.__name__ == 'Timer' — Thread subclass in Lib/threading.py that runs a function after a delay with __name__ 'Timer' (5 chars); new to extra182"
  category: identity
  kind: python_call_eq
  function: Timer.__name__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra182.timer_module_is_threading:
  description: "threading.Timer.__module__ == 'threading' — Timer is defined in Lib/threading.py; its __module__ is 'threading'; new to extra182"
  category: identity
  kind: python_call_eq
  function: Timer.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra182.timer_qualname_equals_name:
  description: "threading.Timer.__qualname__ == 'Timer' — module-level class has __qualname__ == __name__ == 'Timer' (5 chars); new to extra182"
  category: identity
  kind: python_call_eq
  function: Timer.__qualname__.__eq__
  args: ["Timer"]
  expected: true

invariant threading_extra182.timer_base_is_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer's direct base class is Thread; new to extra182"
  category: identity
  kind: python_call_eq
  function: "Timer.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true

invariant threading_extra182.local_name_is_underscore_local:
  description: "threading.local.__name__ == '_local' — threading.local is _thread._local (C extension); its __name__ is '_local' (6 chars, leading underscore), not 'local'; new to extra182"
  category: identity
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra182.local_module_is_thread:
  description: "threading.local.__module__ == '_thread' — threading.local is _thread._local; its __module__ is '_thread' (the C extension), not 'threading'; new to extra182"
  category: identity
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra182.local_qualname_is_underscore_local:
  description: "threading.local.__qualname__ == '_local' — module-level C type in _thread has __qualname__ == __name__ == '_local'; new to extra182"
  category: identity
  kind: python_call_eq
  function: local.__qualname__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra182.local_base_is_object:
  description: "threading.local.__bases__[0].__name__ == 'object' — _local inherits directly from object with no intermediate base; new to extra182"
  category: identity
  kind: python_call_eq
  function: "local.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
