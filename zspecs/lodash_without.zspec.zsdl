spec: lodash_without
version: ">=4.0.0"
backend: node(lodash.without)

docs: https://lodash.com/docs/#without

provenance:
  derived_from:
    - "lodash.without README — https://www.npmjs.com/package/lodash.without"
    - "Test vectors verified with lodash.without@4.4.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.without exports the _.without function directly as module.exports."
    - "without(array, ...values) creates an array excluding specified values."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array without the specified values. No errors for array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_without.without:
  kind: node_module_call_eq
  function: ~
  category: without
  id_prefix: lwithout

  columns: [id, args, expected]
  rows:
    - [two_vals,  [[1, 2, 3, 4], 2, 3],  [1, 4]]
    - [one_val,   [[1, 2, 3], 2],         [1, 3]]
    - [no_match,  [[1, 2, 3], 5],         [1, 2, 3]]
