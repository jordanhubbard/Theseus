spec: concurrent_futures_extra234
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html#threadpoolexecutor

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html#threadpoolexecutor — ThreadPoolExecutor documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "concurrent.futures.ThreadPoolExecutor.submit.__name__ == 'submit' — 6 characters; qualname is 'ThreadPoolExecutor.submit' (25 chars); verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.shutdown.__name__ == 'shutdown' — 8 characters; qualname is 'ThreadPoolExecutor.shutdown' (27 chars); verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.map.__name__ == 'map' — 3 characters; qualname is 'Executor.map' (12 chars) — inherited from Executor; verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__qualname__ == 'ThreadPoolExecutor.__init__' — own __init__; verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__ == 'Executor.__enter__' — inherited from Executor; verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__exit__.__qualname__ == 'Executor.__exit__' — inherited from Executor; verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread' (25 chars); verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor method name contracts — extra234 namespace
#
# submit.__name__ == 'submit' (6 chars); qualname == 'ThreadPoolExecutor.submit' (25 chars).
# shutdown.__name__ == 'shutdown' (8 chars); qualname == 'ThreadPoolExecutor.shutdown' (27 chars).
# map.__name__ == 'map' (3 chars); qualname == 'Executor.map' (12 chars) — inherited.
# ---------------------------------------------------------------------------

table concurrent_futures_extra234.tpe_method_names:
  description: "concurrent.futures.ThreadPoolExecutor method __name__ and __qualname__ contracts in cf234tmn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: cf234tmn

  columns: [id, function, args, expected, description]
  rows:
    - [submit_name_eq,        ThreadPoolExecutor.submit.__name__.__eq__,        ["submit"],                       true, "concurrent.futures.ThreadPoolExecutor.submit.__name__ == 'submit'; verified with Python 3.14.3"]
    - [submit_name_len_6,     ThreadPoolExecutor.submit.__name__.__len__,       [],                               6,    "concurrent.futures.ThreadPoolExecutor.submit.__name__.__len__() == 6 — 'submit' has 6 characters; verified with Python 3.14.3"]
    - [submit_qualname_eq,    ThreadPoolExecutor.submit.__qualname__.__eq__,    ["ThreadPoolExecutor.submit"],    true, "concurrent.futures.ThreadPoolExecutor.submit.__qualname__ == 'ThreadPoolExecutor.submit'; verified with Python 3.14.3"]
    - [submit_qualname_len,   ThreadPoolExecutor.submit.__qualname__.__len__,   [],                               25,   "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__len__() == 25 — 'ThreadPoolExecutor.submit' has 25 characters; verified with Python 3.14.3"]
    - [shutdown_name_eq,      ThreadPoolExecutor.shutdown.__name__.__eq__,      ["shutdown"],                     true, "concurrent.futures.ThreadPoolExecutor.shutdown.__name__ == 'shutdown'; verified with Python 3.14.3"]
    - [shutdown_name_len_8,   ThreadPoolExecutor.shutdown.__name__.__len__,     [],                               8,    "concurrent.futures.ThreadPoolExecutor.shutdown.__name__.__len__() == 8 — 'shutdown' has 8 characters; verified with Python 3.14.3"]
    - [shutdown_qualname_eq,  ThreadPoolExecutor.shutdown.__qualname__.__eq__,  ["ThreadPoolExecutor.shutdown"],  true, "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__ == 'ThreadPoolExecutor.shutdown'; verified with Python 3.14.3"]
    - [map_name_eq,           ThreadPoolExecutor.map.__name__.__eq__,           ["map"],                          true, "concurrent.futures.ThreadPoolExecutor.map.__name__ == 'map'; verified with Python 3.14.3"]
    - [map_name_len_3,        ThreadPoolExecutor.map.__name__.__len__,          [],                               3,    "concurrent.futures.ThreadPoolExecutor.map.__name__.__len__() == 3 — 'map' has 3 characters; verified with Python 3.14.3"]
    - [map_qualname_eq,       ThreadPoolExecutor.map.__qualname__.__eq__,       ["Executor.map"],                 true, "concurrent.futures.ThreadPoolExecutor.map.__qualname__ == 'Executor.map' — inherited from Executor; verified with Python 3.14.3"]

