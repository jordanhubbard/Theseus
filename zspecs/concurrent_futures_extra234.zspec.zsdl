    - [exit_qualname_eq,   ThreadPoolExecutor.__exit__.__qualname__.__eq__,   ["Executor.__exit__"],           true, "concurrent.futures.ThreadPoolExecutor.__exit__.__qualname__ == 'Executor.__exit__' — inherited; verified with Python 3.14.3"]
