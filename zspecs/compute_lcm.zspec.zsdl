spec: compute_lcm
version: ">=1.1.2"
backend: node(compute-lcm)

docs: https://www.npmjs.com/package/compute-lcm

provenance:
  derived_from:
    - "compute-lcm README — https://www.npmjs.com/package/compute-lcm"
    - "Test vectors verified with compute-lcm via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "compute-lcm source"
  notes:
    - "compute-lcm is an npm package. Install: npm install compute-lcm"
    - "Returns the least common multiple of two integers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table compute_lcm.lcm:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: clcm

  columns: [id, args, expected]
  rows:
    - [four_six,   [4, 6],   12]
    - [three_five, [3, 5],   15]
    - [same,       [6, 6],   6]
