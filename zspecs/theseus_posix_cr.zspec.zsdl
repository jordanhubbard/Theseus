spec: theseus_posix_cr
version: ">=3.0"
backend: python_cleanroom(theseus_posix_cr)
blocks: posix

docs: https://docs.python.org/3/library/posix.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/posix.html"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
  notes:
    - "Clean-room posix module. Do NOT import posix."

error_model: python_exceptions

invariant theseus_posix_cr.posix2_getcwd:
  description: "getcwd() returns a non-empty string"
  category: behavior
  kind: python_call_eq
  function: posix2_getcwd
  args: []
  expected: true

invariant theseus_posix_cr.posix2_stat:
  description: "stat() returns stat result for /"
  category: behavior
  kind: python_call_eq
  function: posix2_stat
  args: []
  expected: true

invariant theseus_posix_cr.posix2_urandom:
  description: "urandom() returns bytes"
  category: behavior
  kind: python_call_eq
  function: posix2_urandom
  args: []
  expected: true
