spec: statistics_extra18
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics_extra through statistics_extra17."
    - "Prior specs cover __module__.__eq__ for all major statistics functions."
    - "statistics_extra17 covers mean/__qualname__, NormalDist/__qualname__, StatisticsError/__qualname__."
    - "No prior spec covers __qualname__.__eq__ for fmean, multimode, quantiles, pstdev, pvariance, variance, stdev, mode, median, median_low, median_high, median_grouped, geometric_mean, or harmonic_mean."
    - "All statistics module functions are top-level; __qualname__ equals the simple function name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ attributes — central/spread functions
#
# prior specs cover __module__ for all these functions.
# No prior spec records __qualname__ for fmean, stdev, variance, pstdev,
# pvariance, mode, or multimode.
# ---------------------------------------------------------------------------

table statistics_extra18.function_qualnames_central:
  kind: python_call_eq
  category: function_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [fmean,     fmean.__qualname__.__eq__,     ["fmean"],     true, "statistics.fmean.__qualname__ == 'fmean'"]
    - [stdev,     stdev.__qualname__.__eq__,     ["stdev"],     true, "statistics.stdev.__qualname__ == 'stdev'"]
    - [variance,  variance.__qualname__.__eq__,  ["variance"],  true, "statistics.variance.__qualname__ == 'variance'"]
    - [pstdev,    pstdev.__qualname__.__eq__,    ["pstdev"],    true, "statistics.pstdev.__qualname__ == 'pstdev'"]
    - [pvariance, pvariance.__qualname__.__eq__,  ["pvariance"], true, "statistics.pvariance.__qualname__ == 'pvariance'"]
    - [mode,      mode.__qualname__.__eq__,      ["mode"],      true, "statistics.mode.__qualname__ == 'mode'"]
    - [multimode, multimode.__qualname__.__eq__,  ["multimode"], true, "statistics.multimode.__qualname__ == 'multimode'"]

# ---------------------------------------------------------------------------
# Function __qualname__ attributes — median family and others
#
# No prior spec records __qualname__ for median, median_low, median_high,
# median_grouped, quantiles, geometric_mean, or harmonic_mean.
# ---------------------------------------------------------------------------

invariant statistics_extra18.median.qualname:
  description: "statistics.median.__qualname__ == 'median' — top-level function qualname"
  category: function_identity
  kind: python_call_eq
  function: median.__qualname__.__eq__
  args: ["median"]
  expected: true

invariant statistics_extra18.median_low.qualname:
  description: "statistics.median_low.__qualname__ == 'median_low' — top-level function qualname"
  category: function_identity
  kind: python_call_eq
  function: median_low.__qualname__.__eq__
  args: ["median_low"]
  expected: true

invariant statistics_extra18.median_high.qualname:
  description: "statistics.median_high.__qualname__ == 'median_high' — top-level function qualname"
  category: function_identity
  kind: python_call_eq
  function: median_high.__qualname__.__eq__
  args: ["median_high"]
  expected: true

invariant statistics_extra18.median_grouped.qualname:
  description: "statistics.median_grouped.__qualname__ == 'median_grouped' — top-level function qualname"
  category: function_identity
  kind: python_call_eq
  function: median_grouped.__qualname__.__eq__
  args: ["median_grouped"]
  expected: true

invariant statistics_extra18.quantiles.qualname:
  description: "statistics.quantiles.__qualname__ == 'quantiles' — top-level function qualname"
  category: function_identity
  kind: python_call_eq
  function: quantiles.__qualname__.__eq__
  args: ["quantiles"]
  expected: true

invariant statistics_extra18.geometric_mean.qualname:
  description: "statistics.geometric_mean.__qualname__ == 'geometric_mean' — top-level function qualname"
  category: function_identity
  kind: python_call_eq
  function: geometric_mean.__qualname__.__eq__
  args: ["geometric_mean"]
  expected: true

invariant statistics_extra18.harmonic_mean.qualname:
  description: "statistics.harmonic_mean.__qualname__ == 'harmonic_mean' — top-level function qualname"
  category: function_identity
  kind: python_call_eq
  function: harmonic_mean.__qualname__.__eq__
  args: ["harmonic_mean"]
  expected: true
