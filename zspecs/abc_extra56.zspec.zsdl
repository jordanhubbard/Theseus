spec: abc_extra56
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#qualname — Python __qualname__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra55.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all abc exports, abstractproperty/abstractclassmethod/abstractstaticmethod lengths/qualnames/bases, ABCMeta.register qualname lengths/equality, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2)/abstractproperty(3)/abstractclassmethod(3)/abstractstaticmethod(3), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() tables, ABCMeta/__dict__.__class__.__name__.__eq__('mappingproxy') (extra9), ABC/__dict__.__class__.__name__.__eq__('mappingproxy') (extra8), ABCMeta/__dict__.__class__.__qualname__ and ABC/__dict__.__class__.__qualname__ (extra49), abstractproperty/abstractclassmethod/abstractstaticmethod __dict__.__class__.__name__.__eq__('mappingproxy') (extra49), abc module __dict__.__class__.__name__/__qualname__ (extra49), abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta' (extra40), __class__.__qualname__ string equality for all abc exports (extra41-extra43), abstractmethod/__class__.__module__=='builtins', abstractproperty/__class__.__module__=='builtins', ABC/__class__.__module__=='abc', ABCMeta/__class__.__module__=='builtins', abstractclassmethod/__class__.__module__=='builtins', abstractstaticmethod/__class__.__module__=='builtins' (extra42), abstractproperty/__init__.__class__.__name__=='wrapper_descriptor', abstractmethod/__init__.__class__.__name__=='method-wrapper' (extra50), __class__.__module__.__len__() cross-checks (extra50), __repr__.__class__.__name__ for all abc objects (extra51), __weakref__.__class__.__name__ for abstractproperty/abstractclassmethod/abstractstaticmethod (extra51), ABCMeta.__instancecheck__/__subclasscheck__.__class__.__name__.__eq__('function') (extra52), ABC/ABCMeta __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra52), abc.__package__.__eq__('') (extra53), ABC/ABCMeta/abstractmethod/get_cache_token __doc__.__class__.__name__.__eq__('str') (extra53), ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') (extra53), __loader__.__class__.__name__.__eq__('type') (extra54), __loader__.__name__.__eq__('FrozenImporter') (extra54), __spec__.__class__.__name__.__eq__('ModuleSpec') (extra54), __file__.__class__.__name__.__eq__('str') (extra54), ABCMeta.__instancecheck__.__qualname__.__len__()==25 (extra54), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__name__.__len__() (extra55). ABCMeta.register.__qualname__.__eq__('ABCMeta.register') (extra19/extra38-extra39). ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__') (extra45). update_abstractmethods.__qualname__.__eq__('update_abstractmethods') (extra10/extra20)."
    - "This spec covers (abcqual56 namespace): wave 227 theme — class method __qualname__ string equality checks for public methods not yet covered. Coverage analysis: ABCMeta.register.__qualname__.__eq__('ABCMeta.register') — COVERED (extra19/extra38-extra39); ABCMeta.__instancecheck__.__qualname__.__eq__('ABCMeta.__instancecheck__') — COVERED (extra53); ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__') — COVERED (extra45); update_abstractmethods.__qualname__.__eq__('update_abstractmethods') — COVERED (extra10/extra20). NEW in extra56: abstractproperty.__init__.__qualname__.__eq__('property.__init__') — abstractproperty inherits __init__ from property (not defined on abstractproperty itself); therefore the qualname is 'property.__init__' (NOT 'abstractproperty.__init__'); no prior abc spec has captured this string equality check. All four task items (ABCMeta.register, ABCMeta.__instancecheck__, ABCMeta.__subclasscheck__, update_abstractmethods) are included in tables for wave 227 completeness even though their string equality was previously captured."
    - "abc.abstractproperty.__init__.__qualname__ == 'property.__init__'. abstractproperty is a subclass of property (abstractproperty.__bases__[0] is property). It does NOT override __init__; it inherits property's __init__ directly. Therefore abstractproperty.__init__.__qualname__ is 'property.__init__' (NOT 'abstractproperty.__init__'). Length is 17 chars ('property.__init__' = 8 + 1 + 8). The __class__.__name__ of abstractproperty.__init__ is 'wrapper_descriptor' (captured in extra50), but its __qualname__ has not been checked in any prior spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register'. ABCMeta defines register directly. Length 16 chars. String equality covered in extra19/extra38-extra39. Included in wave 227 table for completeness. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'. Covered in extra53. Length 25 chars. Included in wave 227 table for completeness. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'. Covered in extra45. Length 25 chars. Included in wave 227 table for completeness. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods'. Module-level function; qualname equals __name__ for top-level functions. Covered in extra10/extra20. Included in wave 227 table for completeness. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc ABCMeta method __qualname__ string equality — extra56
#
# Wave 227 theme: class method __qualname__ string equality checks for public
# methods not yet covered.
#
# Coverage analysis for items listed in the wave 227 task:
#   ABCMeta.register.__qualname__.__eq__('ABCMeta.register')         — COVERED extra19/extra38-39
#   ABCMeta.__instancecheck__.__qualname__.__eq__(...)                — COVERED extra53
#   ABCMeta.__subclasscheck__.__qualname__.__eq__(...)                — COVERED extra45
#   update_abstractmethods.__qualname__.__eq__(...)                   — COVERED extra10/extra20
#
# All four are included here for wave 227 table completeness.
# ---------------------------------------------------------------------------

table abc_extra56.abcmeta_method_qualnames:
  description: "abc ABCMeta method __qualname__ string equality checks in abcqual56 namespace — wave 227 theme: class method __qualname__ string equality; all four items (ABCMeta.register, ABCMeta.__instancecheck__, ABCMeta.__subclasscheck__, update_abstractmethods) previously covered in extra19/extra38-39/extra45/extra53/extra10/extra20; included here for wave 227 completeness; ABCMeta defines register/__instancecheck__/__subclasscheck__ directly in Lib/abc.py; update_abstractmethods is a top-level function (qualname equals __name__)"
  kind: python_call_eq
  category: qualname
  id_prefix: abcqual56

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_register,        ABCMeta.register.__qualname__.__eq__,        ["ABCMeta.register"],        true,  "ABCMeta.register.__qualname__ == 'ABCMeta.register' — ABCMeta defines register directly in Lib/abc.py; 16 chars; string equality previously covered in extra19/extra38-extra39; wave 227 table entry for completeness"]
    - [abcmeta_instancecheck,   ABCMeta.__instancecheck__.__qualname__.__eq__, ["ABCMeta.__instancecheck__"], true,  "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — ABCMeta overrides __instancecheck__ in pure Python (Lib/abc.py); 25 chars; string equality previously covered in extra53; wave 227 table entry for completeness"]
    - [abcmeta_subclasscheck,   ABCMeta.__subclasscheck__.__qualname__.__eq__, ["ABCMeta.__subclasscheck__"], true,  "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' — ABCMeta overrides __subclasscheck__ in pure Python (Lib/abc.py); 25 chars; string equality previously covered in extra45; wave 227 table entry for completeness"]
    - [update_abstractmethods,  update_abstractmethods.__qualname__.__eq__,   ["update_abstractmethods"],  true,  "update_abstractmethods.__qualname__ == 'update_abstractmethods' — module-level function; qualname equals __name__ for top-level functions; 22 chars; string equality previously covered in extra10/extra20; wave 227 table entry for completeness"]

# ---------------------------------------------------------------------------
# abc abstractproperty.__init__ __qualname__ string equality — extra56
#
# Wave 227 theme: class method __qualname__ string equality checks for public
# methods not yet covered.
#
# NEW: abstractproperty.__init__.__qualname__.__eq__('property.__init__')
#
# abstractproperty is a subclass of property. It does NOT override __init__.
# Therefore abstractproperty.__init__.__qualname__ == 'property.__init__'
# (NOT 'abstractproperty.__init__').
#
# extra50 captured abstractproperty.__init__.__class__.__name__ == 'wrapper_descriptor'
# but NO prior abc spec has captured the __qualname__ string equality.
# ---------------------------------------------------------------------------

table abc_extra56.abstractproperty_init_qualname:
  description: "abc abstractproperty.__init__.__qualname__ string equality check in abcqual56 namespace — wave 227 theme; abstractproperty inherits __init__ from property without override; therefore abstractproperty.__init__.__qualname__ == 'property.__init__' (NOT 'abstractproperty.__init__'); 17 chars ('property.__init__' = 8+1+8); extra50 captured __init__.__class__.__name__=='wrapper_descriptor' but no prior abc spec has captured the __qualname__ string equality; NEW in extra56: first abstractproperty.__init__.__qualname__.__eq__ check in any abc spec"
  kind: python_call_eq
  category: qualname
  id_prefix: abcqual56apinit

  columns: [id, function, args, expected, description]
  rows:
    - [ap_init_qualname, abstractproperty.__init__.__qualname__.__eq__, ["property.__init__"], true, "abstractproperty.__init__.__qualname__ == 'property.__init__' — abstractproperty inherits __init__ from property (its base class) without defining its own; Python records the qualname as the defining class's qualname 'property.__init__'; NOT 'abstractproperty.__init__'; 17 chars; extra50 captured __class__.__name__=='wrapper_descriptor' only; NEW in extra56: first __qualname__ string equality check for abstractproperty.__init__ in any abc spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra56
# ---------------------------------------------------------------------------

invariant abc_extra56.abstractproperty_init_qualname_eq:
  description: "abc.abstractproperty.__init__.__qualname__.__eq__('property.__init__') returns True — abstractproperty is a subclass of property and does NOT override __init__; Python's __qualname__ records the defining class so the qualname is 'property.__init__' (NOT 'abstractproperty.__init__'); 17 chars; no prior abc spec has captured this string equality (extra50 captured __class__.__name__=='wrapper_descriptor' only); NEW in extra56: wave 227 first abstractproperty.__init__ qualname string equality invariant in any abc spec; verified with Python 3.14.3"
  category: qualname
  kind: python_call_eq
  function: abstractproperty.__init__.__qualname__.__eq__
  args: ["property.__init__"]
  expected: true

invariant abc_extra56.abcmeta_register_qualname_eq:
  description: "abc.ABCMeta.register.__qualname__.__eq__('ABCMeta.register') returns True — ABCMeta defines register directly in Lib/abc.py; qualname carries the class prefix 'ABCMeta.' + 'register' (16 chars); string equality previously covered in extra19/extra38-extra39; wave 227 invariant for completeness"
  category: qualname
  kind: python_call_eq
  function: ABCMeta.register.__qualname__.__eq__
  args: ["ABCMeta.register"]
  expected: true

invariant abc_extra56.abcmeta_subclasscheck_qualname_eq:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__.__eq__('ABCMeta.__subclasscheck__') returns True — ABCMeta overrides __subclasscheck__ in pure Python (Lib/abc.py); 25 chars; string equality previously covered in extra45; wave 227 invariant for completeness; note: len==25 matches __instancecheck__ qualname len (both have 'ABCMeta.__' + different 13-char suffixes: 'instancecheck' has 13 chars, 'subclasscheck' has 13 chars)"
  category: qualname
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__qualname__.__eq__
  args: ["ABCMeta.__subclasscheck__"]
  expected: true
