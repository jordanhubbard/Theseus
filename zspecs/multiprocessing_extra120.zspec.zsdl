spec: multiprocessing_extra120
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra119.zspec.zsdl."
    - "This spec covers: wave 261 theme — multiprocessing.context.SpawnContext and ForkContext class identity checks not previously covered. Prior specs covered: extra43 covered SpawnContext/__name__ equality, __qualname__.__len__()==12, ForkContext/__name__ equality, __qualname__.__len__()==11, ForkServerContext/__name__ equality, all four context subclass __mro__.__len__()==3; extra44 covered SpawnContext/__qualname__ string equality, ForkContext/__qualname__ string equality, all four context subclass __module__ string equality and __module__.__len__()==23. NOT previously covered at element level: context.SpawnContext.__bases__[0].__name__.__eq__('BaseContext'); context.ForkContext.__bases__[0].__name__.__eq__('BaseContext'); context.ForkServerContext.__bases__[0].__name__.__eq__('BaseContext'); context.SpawnContext.__bases__[0].__module__.__eq__('multiprocessing.context'); context.ForkContext.__bases__[0].__module__.__eq__('multiprocessing.context'); SpawnContext/__name__.__len__()==12 and ForkContext/__name__.__len__()==11 and ForkServerContext/__name__.__len__()==17 as standalone invariants. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.context.SpawnContext.__bases__ == (<class 'multiprocessing.context.BaseContext'>,): len=1. __bases__[0].__name__=='BaseContext' (len=11). __bases__[0].__module__=='multiprocessing.context' (len=23). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.context.ForkContext.__bases__[0].__name__=='BaseContext' (len=11; tied with SpawnContext.__bases__[0].__name__='BaseContext'=11). ForkServerContext.__bases__[0].__name__=='BaseContext' (len=11; all three context subclasses inherit from BaseContext). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.context.SpawnContext.__name__.__len__()==12 ('SpawnContext'=12), ForkContext.__name__.__len__()==11 ('ForkContext'=11; tied with BaseContext=11), ForkServerContext.__name__.__len__()==17 ('ForkServerContext'=17: 'Fork'=4+'Server'=6+'Context'=7=17). SpawnContext is longer than ForkContext by 1 ('Spawn'=5 vs 'Fork'=4, diff=1). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.context SpawnContext and ForkContext __bases__[0].__name__ — extra120
#
# Wave 261 theme: SpawnContext, ForkContext, ForkServerContext __bases__[0].__name__ equality.
#
# context.SpawnContext.__bases__[0].__name__ == 'BaseContext'  (len=11)
# context.ForkContext.__bases__[0].__name__  == 'BaseContext'  (len=11, tied)
# context.ForkServerContext.__bases__[0].__name__ == 'BaseContext'  (len=11, tied)
# All three context subclasses inherit from BaseContext.
# ---------------------------------------------------------------------------

table multiprocessing_extra120.context_subclass_bases_name:
  description: "multiprocessing.context SpawnContext, ForkContext, ForkServerContext __bases__[0].__name__ equality checks in mpctx120 namespace — wave 261 theme: all three context subclasses inherit from BaseContext; context.SpawnContext.__bases__[0].__name__.__eq__('BaseContext')==True (len=11: SpawnContext inherits from BaseContext; BaseContext defines the core context API: Process, Queue, Pipe, Lock, Event, Semaphore, Value, Array, Manager, cpu_count, get_start_method, etc.; SpawnContext overrides start_method='spawn'; __bases__[0] is the only base (single inheritance); __bases__[0].__name__='BaseContext' is 11 chars: 'Base'=4+'Context'=7=11); context.ForkContext.__bases__[0].__name__.__eq__('BaseContext')==True (len=11: tied with SpawnContext.__bases__[0].__name__='BaseContext'=11; ForkContext overrides start_method='fork'; all three context subclasses share the same single base class BaseContext making their __bases__[0].__name__ values identical); context.ForkServerContext.__bases__[0].__name__.__eq__('BaseContext')==True (len=11: ForkServerContext overrides start_method='forkserver'; the forkserver start method requires a persistent server process to create new workers; same BaseContext base as Spawn and Fork); all three __bases__[0].__name__ values are 'BaseContext'=11 (uniform: the entire context subclass hierarchy is a flat star pattern with BaseContext at the center and Spawn/Fork/ForkServer/Default as the four leaves); compare: prior specs covered Process.__bases__[0].__name__=='BaseProcess' (len=11, tied with BaseContext=11 — both base class names have 11 chars); element length ordering: BaseContext=11 == BaseProcess=11 (tied); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpctx120

  columns: [id, function, args, expected, description]
  rows:
    - [spawn_b0_eq,    "context.SpawnContext.__bases__[0].__name__.__eq__",      ["BaseContext"], true, "SpawnContext.__bases__[0].__name__ == 'BaseContext' (len=11; single inheritance from BaseContext); verified with Python 3.14.3"]
    - [spawn_b0_len,   "context.SpawnContext.__bases__[0].__name__.__len__",      [],             11,   "SpawnContext.__bases__[0].__name__.__len__() == 11 ('BaseContext'=11: 'Base'=4+'Context'=7=11); verified with Python 3.14.3"]
    - [fork_b0_eq,     "context.ForkContext.__bases__[0].__name__.__eq__",        ["BaseContext"], true, "ForkContext.__bases__[0].__name__ == 'BaseContext' (len=11; tied with SpawnContext); verified with Python 3.14.3"]
    - [fork_b0_len,    "context.ForkContext.__bases__[0].__name__.__len__",        [],             11,   "ForkContext.__bases__[0].__name__.__len__() == 11 ('BaseContext'=11; tied with SpawnContext=11); verified with Python 3.14.3"]
    - [fsrv_b0_eq,     "context.ForkServerContext.__bases__[0].__name__.__eq__",  ["BaseContext"], true, "ForkServerContext.__bases__[0].__name__ == 'BaseContext' (len=11; all three subclasses share same base); verified with Python 3.14.3"]
    - [fsrv_b0_len,    "context.ForkServerContext.__bases__[0].__name__.__len__",  [],             11,   "ForkServerContext.__bases__[0].__name__.__len__() == 11 ('BaseContext'=11; tied with Spawn=11 and Fork=11); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.context SpawnContext and ForkContext __bases__[0].__module__ — extra120
#
# Wave 261 theme: SpawnContext and ForkContext __bases__[0].__module__ equality.
#
# context.SpawnContext.__bases__[0].__module__ == 'multiprocessing.context'  (len=23)
# context.ForkContext.__bases__[0].__module__  == 'multiprocessing.context'  (len=23, tied)
# BaseContext is defined in multiprocessing.context; all context subclasses share the same base module.
# ---------------------------------------------------------------------------

table multiprocessing_extra120.context_subclass_bases_module:
  description: "multiprocessing.context SpawnContext and ForkContext __bases__[0].__module__ equality checks in mpctx120a namespace — wave 261 theme: BaseContext is defined in multiprocessing.context; SpawnContext/__bases__[0].__module__.__eq__('multiprocessing.context')==True (len=23: BaseContext's module is 'multiprocessing.context'; extra44 covered SpawnContext/__module__.__eq__('multiprocessing.context') — this spec adds the __bases__[0].__module__ equality; SpawnContext's own module and its base class module are the same string 'multiprocessing.context'=23: all context classes including BaseContext are defined together in Lib/multiprocessing/context.py); ForkContext.__bases__[0].__module__.__eq__('multiprocessing.context')==True (len=23: tied with SpawnContext.__bases__[0].__module__=23; ForkContext.__module__=='multiprocessing.context' (extra44) and ForkContext.__bases__[0].__module__=='multiprocessing.context' are both the same value); ForkServerContext.__bases__[0].__module__.__eq__('multiprocessing.context')==True (len=23: all four context subclasses and their shared base class BaseContext are in the same module); BaseContext.__bases__[0].__name__=='object' (BaseContext inherits from object; not checked here since 'object' is not covered in this wave); __bases__[0].__module__.__len__()==23 (tied: 'multiprocessing.context'=23 for all context subclass __bases__[0] entries; same as their own __module__='multiprocessing.context'=23 covered in extra44; length ordering in context classes: SpawnContext=12 < ForkServerContext=17 < multiprocessing.context=23 (as a string)); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpctx120a

  columns: [id, function, args, expected, description]
  rows:
    - [spawn_b0_mod_eq,   "context.SpawnContext.__bases__[0].__module__.__eq__",      ["multiprocessing.context"], true, "SpawnContext.__bases__[0].__module__ == 'multiprocessing.context' (len=23; BaseContext defined in same module); verified with Python 3.14.3"]
    - [spawn_b0_mod_len,  "context.SpawnContext.__bases__[0].__module__.__len__",      [],                         23,   "SpawnContext.__bases__[0].__module__.__len__() == 23 ('multiprocessing.context'=23; same as SpawnContext.__module__=23); verified with Python 3.14.3"]
    - [fork_b0_mod_eq,    "context.ForkContext.__bases__[0].__module__.__eq__",        ["multiprocessing.context"], true, "ForkContext.__bases__[0].__module__ == 'multiprocessing.context' (len=23; tied with SpawnContext); verified with Python 3.14.3"]
    - [fork_b0_mod_len,   "context.ForkContext.__bases__[0].__module__.__len__",        [],                         23,   "ForkContext.__bases__[0].__module__.__len__() == 23 ('multiprocessing.context'=23; tied with SpawnContext); verified with Python 3.14.3"]
    - [fsrv_b0_mod_eq,    "context.ForkServerContext.__bases__[0].__module__.__eq__",  ["multiprocessing.context"], true, "ForkServerContext.__bases__[0].__module__ == 'multiprocessing.context' (len=23; same module for all context base classes); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.context SpawnContext/ForkContext/ForkServerContext name lengths — extra120
#
# Wave 261 theme: __name__.__len__() for context subclasses and length ordering.
#
# context.ForkContext.__name__.__len__()       == 11  ('ForkContext')
# context.SpawnContext.__name__.__len__()      == 12  ('SpawnContext')
# context.ForkServerContext.__name__.__len__() == 17  ('ForkServerContext')
# ---------------------------------------------------------------------------

table multiprocessing_extra120.context_subclass_name_lengths:
  description: "multiprocessing.context subclass __name__.__len__() cross-comparison in mpctx120b namespace — wave 261 theme: context subclass name length ordering; context.ForkContext.__name__.__len__()==11 ('ForkContext'=11: 'Fork'=4+'Context'=7=11; shortest of the three context subclasses covered here; also tied with BaseContext=11; extra43 covered ForkContext/__name__ equality and __qualname__.__len__()==11, but not __name__.__len__() as a distinct measurement); context.SpawnContext.__name__.__len__()==12 ('SpawnContext'=12: 'Spawn'=5+'Context'=7=12; 1 more than ForkContext=11 because 'Spawn'=5 vs 'Fork'=4; extra43 covered SpawnContext/__name__ equality and __qualname__.__len__()==12); context.ForkServerContext.__name__.__len__()==17 ('ForkServerContext'=17: 'Fork'=4+'Server'=6+'Context'=7=17; longest of the three: 5 more than SpawnContext=12 and 6 more than ForkContext=11; extra43 covered ForkServerContext/__name__ equality and __qualname__.__len__()==17; the 'Server' infix adds 6 chars to the 'ForkContext' base: 11+6=17); name length ordering: ForkContext=11 < SpawnContext=12 (diff=1: 'Spawn'=5 vs 'Fork'=4) < ForkServerContext=17 (diff=5 from SpawnContext: 'ForkServer'=10 vs 'Spawn'=5, a structural difference not just 1 extra char); BaseContext.__name__.__len__()==11 (tied with ForkContext=11: both are 4+7=11 where 4 is the prefix length: 'Base'=4='Fork'=4); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpctx120b

  columns: [id, function, args, expected, description]
  rows:
    - [fork_nm_len,    context.ForkContext.__name__.__len__,       [], 11, "ForkContext.__name__.__len__() == 11 ('ForkContext'=11; shortest; tied with BaseContext=11); verified with Python 3.14.3"]
    - [spawn_nm_len,   context.SpawnContext.__name__.__len__,      [], 12, "SpawnContext.__name__.__len__() == 12 ('SpawnContext'=12; 1 more than ForkContext=11); verified with Python 3.14.3"]
    - [fsrv_nm_len,    context.ForkServerContext.__name__.__len__,  [], 17, "ForkServerContext.__name__.__len__() == 17 ('ForkServerContext'=17; longest; 5 more than SpawnContext=12); verified with Python 3.14.3"]
    - [base_nm_len,    context.BaseContext.__name__.__len__,        [], 11, "BaseContext.__name__.__len__() == 11 ('BaseContext'=11; tied with ForkContext=11); verified with Python 3.14.3"]
    - [base_mod_len,   context.BaseContext.__module__.__len__,      [], 23, "BaseContext.__module__.__len__() == 23 ('multiprocessing.context'=23; same module as all context subclasses); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra120
# ---------------------------------------------------------------------------

invariant multiprocessing_extra120.SpawnContext_bases0_name_BaseContext:
  description: "multiprocessing.context.SpawnContext.__bases__[0].__name__.__eq__('BaseContext') returns True — SpawnContext.__bases__[0].__name__='BaseContext' (len=11); SpawnContext inherits from BaseContext (single inheritance: __bases__==(<class 'multiprocessing.context.BaseContext'>,)); BaseContext is the abstract base class for all multiprocessing context classes; it defines the full context API that subclasses override with start-method-specific implementations; SpawnContext uses the 'spawn' start method: each worker process is started as a fresh Python interpreter (the parent process spawns a new child); __bases__[0].__name__='BaseContext' is 11 chars: 'Base'=4+'Context'=7=11; compare: Process.__bases__[0].__name__=='BaseProcess' (len=11 — tied with 'BaseContext'=11: both base class names are 11 chars with 'Base'=4 prefix and a 7-char suffix: 'Context'=7=='Process'=7); __bases__[0].__module__=='multiprocessing.context' (len=23: BaseContext is defined in the same module as SpawnContext); SpawnContext.__module__=='multiprocessing.context' (extra44: same string as __bases__[0].__module__); first standalone SpawnContext.__bases__[0].__name__ equality invariant in mpctx120 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "context.SpawnContext.__bases__[0].__name__.__eq__"
  args: ["BaseContext"]
  expected: true

invariant multiprocessing_extra120.ForkContext_bases0_name_BaseContext:
  description: "multiprocessing.context.ForkContext.__bases__[0].__name__.__eq__('BaseContext') returns True — ForkContext.__bases__[0].__name__='BaseContext' (len=11; tied with SpawnContext.__bases__[0].__name__='BaseContext'=11); ForkContext uses the 'fork' start method: the parent process forks (os.fork()) to create child processes; forked processes inherit the parent's memory space (copy-on-write); ForkContext.__bases__[0].__name__='BaseContext' is the same string as SpawnContext.__bases__[0].__name__ (symmetric: all context subclasses share the same base); ForkContext.__name__='ForkContext'=11 chars (tied with 'BaseContext'=11: 'Fork'=4+'Context'=7=11, same structure as 'Base'=4+'Context'=7=11); ForkContext.__qualname__.__eq__('ForkContext')==True (covered in extra44); ForkContext.__module__.__eq__('multiprocessing.context')==True (covered in extra44; len=23); ForkContext.__mro__.__len__()==3 (covered in extra43: ForkContext -> BaseContext -> object); ForkContext.__bases__[0].__module__=='multiprocessing.context' (len=23: BaseContext and ForkContext are co-located in multiprocessing/context.py); first standalone ForkContext.__bases__[0].__name__ equality invariant in mpctx120 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "context.ForkContext.__bases__[0].__name__.__eq__"
  args: ["BaseContext"]
  expected: true

invariant multiprocessing_extra120.ForkServerContext_bases0_name_BaseContext:
  description: "multiprocessing.context.ForkServerContext.__bases__[0].__name__.__eq__('BaseContext') returns True — ForkServerContext.__bases__[0].__name__='BaseContext' (len=11; tied with SpawnContext and ForkContext: all three subclasses have __bases__[0].__name__='BaseContext'=11); ForkServerContext uses the 'forkserver' start method: when the program starts, a server process is spawned; subsequently, each new worker process is forked from that server process rather than from the main process; this avoids issues with forking a multithreaded parent; ForkServerContext.__name__='ForkServerContext'=17 (longest of the three context subclasses in this spec: 5 more than SpawnContext=12); __bases__[0].__name__='BaseContext'=11 is consistent across all three context subclasses (Spawn=11, Fork=11, ForkServer=11: the base is identical even though the subclass names differ greatly in length); ForkServerContext.__module__.__eq__('multiprocessing.context')==True (covered in extra44); ForkServerContext.__qualname__.__len__()==17 (covered in extra43); first standalone ForkServerContext.__bases__[0].__name__ equality invariant in mpctx120 namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "context.ForkServerContext.__bases__[0].__name__.__eq__"
  args: ["BaseContext"]
  expected: true

invariant multiprocessing_extra120.SpawnContext_bases0_module_multiprocessing_context:
  description: "multiprocessing.context.SpawnContext.__bases__[0].__module__.__eq__('multiprocessing.context') returns True — SpawnContext.__bases__[0].__module__='multiprocessing.context' (len=23); BaseContext (SpawnContext's single base class) is defined in the multiprocessing.context module (CPython: Lib/multiprocessing/context.py); SpawnContext.__module__=='multiprocessing.context' (covered in extra44: SpawnContext's own module is also 'multiprocessing.context'=23); __bases__[0].__module__ == __module__ for SpawnContext because both SpawnContext and its base class BaseContext are defined in the same file Lib/multiprocessing/context.py; this co-location makes __bases__[0].__module__ identical to SpawnContext.__module__ (both='multiprocessing.context'); the 23-char string 'multiprocessing.context': 'multiprocessing'=15+'.'=1+'context'=7=23; __bases__[0].__module__.__len__()==23 (tied with SpawnContext.__module__.__len__()==23 from extra44); ForkContext.__bases__[0].__module__=='multiprocessing.context' (same value: all context classes are in the same module); first standalone SpawnContext.__bases__[0].__module__ equality invariant in mpctx120a namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "context.SpawnContext.__bases__[0].__module__.__eq__"
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra120.ForkServerContext_name_len_17:
  description: "multiprocessing.context.ForkServerContext.__name__.__len__() == 17 — 'ForkServerContext'=17 chars: 'Fork'=4+'Server'=6+'Context'=7=17; ForkServerContext is the longest-named context subclass among Spawn(12)/Fork(11)/ForkServer(17); extra43 covered ForkServerContext/__name__ equality ('ForkServerContext') and __qualname__.__len__()==17; this spec provides __name__.__len__()==17 as a standalone invariant; 'ForkServerContext'=17 is 5 more than SpawnContext=12 and 6 more than ForkContext=11; the 'Server' infix (6 chars) distinguishes ForkServerContext from ForkContext (ForkContext=11+'Server'=6=17); compare: BaseContext=11 (tied with ForkContext=11: both have 'Context'=7 suffix and a 4-char prefix 'Base'='Fork'); SpawnContext=12 (1 more than ForkContext: 'Spawn'=5 vs 'Fork'=4, diff=1); ForkServerContext=17 is also the longest name among all context classes including BaseContext=11 and DefaultContext (len=14: 'Default'=7+'Context'=7=14); the length 17 matches ForkServerContext.__qualname__.__len__()==17 (covered in extra43: for a top-level class, qualname==name); first standalone ForkServerContext.__name__ length invariant in mpctx120b namespace; wave 261; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: context.ForkServerContext.__name__.__len__
  args: []
  expected: 17
