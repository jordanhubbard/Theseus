spec: decimal_extra2221
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2221 (decimal_extra2221): identity/display protocol dict-presence checks — __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__."
    - "decimal.Decimal is a C extension type that defines __hash__, __repr__, __str__, __doc__, and __module__ in its own __dict__; __qualname__ and __name__ are absent — C types do not store these in __dict__."
    - "decimal.Context is a C extension type that defines __repr__, __doc__, and __module__ in its own __dict__; __hash__, __str__, __qualname__, and __name__ are absent — Context objects are mutable and therefore unhashable, with no custom string coercion."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table decimal_extra2221.decimal_identity_display:
  description: "decimal.Decimal identity/display protocol dict-presence — C extension type defines __hash__, __repr__, __str__, __doc__, __module__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2221

  columns: [id, function, args, expected]
  rows:
    - ["dc2221001", "decimal.Decimal.__dict__.__contains__", ["__hash__"], true]
    - ["dc2221002", "decimal.Decimal.__dict__.__contains__", ["__repr__"], true]
    - ["dc2221003", "decimal.Decimal.__dict__.__contains__", ["__str__"], true]
    - ["dc2221004", "decimal.Decimal.__dict__.__contains__", ["__doc__"], true]
    - ["dc2221005", "decimal.Decimal.__dict__.__contains__", ["__module__"], true]
    - ["dc2221006", "decimal.Decimal.__dict__.__contains__", ["__qualname__"], false]
    - ["dc2221007", "decimal.Decimal.__dict__.__contains__", ["__name__"], false]

table decimal_extra2221.context_identity_display:
  description: "decimal.Context identity/display protocol dict-presence — mutable C type defines __repr__ but not __hash__ or __str__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2221

  columns: [id, function, args, expected]
  rows:
    - ["dc2221008", "decimal.Context.__dict__.__contains__", ["__hash__"], false]
    - ["dc2221009", "decimal.Context.__dict__.__contains__", ["__repr__"], true]
    - ["dc2221010", "decimal.Context.__dict__.__contains__", ["__str__"], false]
    - ["dc2221011", "decimal.Context.__dict__.__contains__", ["__doc__"], true]
    - ["dc2221012", "decimal.Context.__dict__.__contains__", ["__module__"], true]
    - ["dc2221013", "decimal.Context.__dict__.__contains__", ["__qualname__"], false]
    - ["dc2221014", "decimal.Context.__dict__.__contains__", ["__name__"], false]

table decimal_extra2221.cross_class_hash_survey:
  description: "Cross-class survey of __hash__ dict-presence — Decimal defines it (immutable); Context does not (mutable)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2221

  columns: [id, function, args, expected]
  rows:
    - ["dc2221015", "decimal.Decimal.__dict__.__contains__", ["__hash__"], true]
    - ["dc2221016", "decimal.Context.__dict__.__contains__", ["__hash__"], false]

table decimal_extra2221.cross_class_repr_survey:
  description: "Cross-class survey of __repr__ dict-presence — both Decimal and Context define it"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2221

  columns: [id, function, args, expected]
  rows:
    - ["dc2221017", "decimal.Decimal.__dict__.__contains__", ["__repr__"], true]
    - ["dc2221018", "decimal.Context.__dict__.__contains__", ["__repr__"], true]

table decimal_extra2221.cross_class_str_survey:
  description: "Cross-class survey of __str__ dict-presence — Decimal defines it; Context does not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2221

  columns: [id, function, args, expected]
  rows:
    - ["dc2221019", "decimal.Decimal.__dict__.__contains__", ["__str__"], true]
    - ["dc2221020", "decimal.Context.__dict__.__contains__", ["__str__"], false]

table decimal_extra2221.cross_class_doc_module_survey:
  description: "Cross-class survey of __doc__ and __module__ dict-presence — both Decimal and Context define them as C extension types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2221

  columns: [id, function, args, expected]
  rows:
    - ["dc2221021", "decimal.Decimal.__dict__.__contains__", ["__doc__"], true]
    - ["dc2221022", "decimal.Decimal.__dict__.__contains__", ["__module__"], true]
    - ["dc2221023", "decimal.Context.__dict__.__contains__", ["__doc__"], true]
    - ["dc2221024", "decimal.Context.__dict__.__contains__", ["__module__"], true]

table decimal_extra2221.cross_class_qualname_name_survey:
  description: "Cross-class survey of __qualname__ and __name__ dict-presence — absent from both C extension types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2221

  columns: [id, function, args, expected]
  rows:
    - ["dc2221025", "decimal.Decimal.__dict__.__contains__", ["__qualname__"], false]
    - ["dc2221026", "decimal.Decimal.__dict__.__contains__", ["__name__"], false]
    - ["dc2221027", "decimal.Context.__dict__.__contains__", ["__qualname__"], false]
    - ["dc2221028", "decimal.Context.__dict__.__contains__", ["__name__"], false]
