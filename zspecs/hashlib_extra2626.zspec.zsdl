spec: hashlib_extra2626
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 hashlib documentation — https://docs.python.org/3/library/hashlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "hashlib.zspec.zsdl — covers hash_object_attr for sha256/md5/sha1/sha512 digest_size/block_size/name"
    - "hashlib_extra262.zspec.zsdl — covers sha256/md5/sha1/sha512 constructor function identity and instance properties via python_call_eq"
    - "hashlib_extra269.zspec.zsdl — covers HASH method identity, sha3/shake module identity, file_digest identity"
  notes:
    - "Wave 622 (hashlib_extra2626) theme: __length_hint__, __missing__, and __reversed__ dict-presence checks."
    - "None of the hashlib classes (HASH, blake2b, blake2s) define __length_hint__, __missing__, or __reversed__ in their own __dict__."
    - "__length_hint__ is a protocol method for sized iterators; hash objects are not sized iterators."
    - "__missing__ is a dict subclass hook; hash objects are not dict subclasses."
    - "__reversed__ is an iterator protocol method; hash objects do not support reverse iteration."
    - "HASH, blake2b, and blake2s all DO define update/digest/hexdigest/copy/digest_size/block_size in their __dict__."
    - "type(hashlib.new('sha256')) returns the C-level HASH type from _hashlib."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — HASH, blake2b, blake2s
# ---------------------------------------------------------------------------

table hashlib_extra2626.no_length_hint_in_hash_classes:
  description: "__length_hint__ is absent from HASH/blake2b/blake2s __dict__s — hash objects are not sized iterators and do not implement the length-hint protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2626

  columns: [id, function, args, expected]
  rows:
    - ["hl2626001", "hashlib.HASH.__dict__.__contains__",   ["__length_hint__"], false]
    - ["hl2626002", "hashlib.blake2b.__dict__.__contains__", ["__length_hint__"], false]
    - ["hl2626003", "hashlib.blake2s.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# __missing__ dict-presence — HASH, blake2b, blake2s
# ---------------------------------------------------------------------------

table hashlib_extra2626.no_missing_in_hash_classes:
  description: "__missing__ is absent from HASH/blake2b/blake2s __dict__s — hash objects are not dict subclasses and do not implement missing-key lookup"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2626

  columns: [id, function, args, expected]
  rows:
    - ["hl2626004", "hashlib.HASH.__dict__.__contains__",    ["__missing__"], false]
    - ["hl2626005", "hashlib.blake2b.__dict__.__contains__", ["__missing__"], false]
    - ["hl2626006", "hashlib.blake2s.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — HASH, blake2b, blake2s
# ---------------------------------------------------------------------------

table hashlib_extra2626.no_reversed_in_hash_classes:
  description: "__reversed__ is absent from HASH/blake2b/blake2s __dict__s — hash objects do not support reverse iteration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2626

  columns: [id, function, args, expected]
  rows:
    - ["hl2626007", "hashlib.HASH.__dict__.__contains__",    ["__reversed__"], false]
    - ["hl2626008", "hashlib.blake2b.__dict__.__contains__", ["__reversed__"], false]
    - ["hl2626009", "hashlib.blake2s.__dict__.__contains__", ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Complementary: hash classes DO define their core hashing methods
# Confirms that the absence of __length_hint__/__missing__/__reversed__ is
# specific to those protocol methods, not a sign of an empty or missing class.
# ---------------------------------------------------------------------------

table hashlib_extra2626.hash_classes_have_core_methods:
  description: "HASH/blake2b/blake2s define update/digest/hexdigest/copy in __dict__ but NOT __length_hint__/__missing__/__reversed__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2626

  columns: [id, function, args, expected]
  rows:
    - ["hl2626010", "hashlib.HASH.__dict__.__contains__",    ["update"],          true]
    - ["hl2626011", "hashlib.HASH.__dict__.__contains__",    ["digest"],          true]
    - ["hl2626012", "hashlib.HASH.__dict__.__contains__",    ["hexdigest"],       true]
    - ["hl2626013", "hashlib.HASH.__dict__.__contains__",    ["copy"],            true]
    - ["hl2626014", "hashlib.HASH.__dict__.__contains__",    ["__length_hint__"], false]
    - ["hl2626015", "hashlib.HASH.__dict__.__contains__",    ["__missing__"],     false]
    - ["hl2626016", "hashlib.HASH.__dict__.__contains__",    ["__reversed__"],    false]
    - ["hl2626017", "hashlib.blake2b.__dict__.__contains__", ["update"],          true]
    - ["hl2626018", "hashlib.blake2b.__dict__.__contains__", ["digest"],          true]
    - ["hl2626019", "hashlib.blake2b.__dict__.__contains__", ["hexdigest"],       true]
    - ["hl2626020", "hashlib.blake2b.__dict__.__contains__", ["copy"],            true]
    - ["hl2626021", "hashlib.blake2b.__dict__.__contains__", ["__length_hint__"], false]
    - ["hl2626022", "hashlib.blake2b.__dict__.__contains__", ["__missing__"],     false]
    - ["hl2626023", "hashlib.blake2b.__dict__.__contains__", ["__reversed__"],    false]
