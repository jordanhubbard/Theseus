spec: clamp_number
version: ">=1.1.1"
backend: node(clamp-number)

docs: https://www.npmjs.com/package/clamp-number

provenance:
  derived_from:
    - "clamp-number README — https://www.npmjs.com/package/clamp-number"
    - "Test vectors verified with clamp-number via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "clamp-number source"
  notes:
    - "clamp-number is an npm package. Install: npm install clamp-number"
    - "Clamps a number between a minimum and maximum value."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table clamp_number.clamp:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: clamp

  columns: [id, args, expected]
  rows:
    - [in_range,  [5, 0, 10],   5]
    - [below_min, [-5, 0, 10],  0]
    - [above_max, [15, 0, 10],  10]
