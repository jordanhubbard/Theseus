spec: subprocess_extra7
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
  notes:
    - "This spec extends subprocess.zspec.zsdl and prior extras through subprocess_extra6.zspec.zsdl."
    - "subprocess.zspec.zsdl covers __name__ for all major classes and functions in tables."
    - "subprocess_extra covers __module__ for CompletedProcess/SubprocessError/CalledProcessError/TimeoutExpired; __bases__[0].__name__ for SubprocessError/CalledProcessError/TimeoutExpired."
    - "subprocess_extra2 covers Popen.__module__ and run.__module__."
    - "subprocess_extra4 covers check_call.__module__ and check_output.__module__; Popen.__name__ standalone; Popen.__bases__[0].__name__."
    - "subprocess_extra6 covers __qualname__ for CalledProcessError/TimeoutExpired/SubprocessError/getoutput/getstatusoutput/run/call/check_call/check_output/Popen/CompletedProcess."
    - "This spec adds: call.__module__ standalone; getoutput.__module__ and getstatusoutput.__module__ (not yet covered in any prior spec); __qualname__ for call/run/check_call/check_output as standalone invariants complementing subprocess_extra6 table coverage."
    - "subprocess.call.__module__ == 'subprocess' — call is defined in subprocess.py."
    - "subprocess.getoutput.__module__ == 'subprocess' — getoutput is defined in subprocess.py."
    - "subprocess.getstatusoutput.__module__ == 'subprocess' — getstatusoutput is defined in subprocess.py."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for subprocess functions not yet covered as standalone invariants
#
# subprocess_extra4 covers check_call.__module__ and check_output.__module__.
# subprocess_extra2 covers run.__module__ and Popen.__module__.
# subprocess_extra covers CompletedProcess/SubprocessError/CalledProcessError/
# TimeoutExpired __module__.
# This spec adds: call.__module__, getoutput.__module__, getstatusoutput.__module__
# — none covered in any prior subprocess spec.
# ---------------------------------------------------------------------------

invariant subprocess_extra7.call.module:
  description: "subprocess.call.__module__ == 'subprocess' — call is defined in subprocess.py"
  category: function_modules
  kind: python_call_eq
  function: call.__module__.__eq__
  args: ["subprocess"]
  expected: true

invariant subprocess_extra7.getoutput.module:
  description: "subprocess.getoutput.__module__ == 'subprocess' — getoutput convenience wrapper"
  category: function_modules
  kind: python_call_eq
  function: getoutput.__module__.__eq__
  args: ["subprocess"]
  expected: true

invariant subprocess_extra7.getstatusoutput.module:
  description: "subprocess.getstatusoutput.__module__ == 'subprocess' — getstatusoutput convenience wrapper"
  category: function_modules
  kind: python_call_eq
  function: getstatusoutput.__module__.__eq__
  args: ["subprocess"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table for subprocess functions covered as a group
#
# Provides a consolidated table view of __module__ == 'subprocess' for all
# major subprocess functions. This cross-cuts with the standalone invariants
# above and provides an independent multi-function vector.
# ---------------------------------------------------------------------------

table subprocess_extra7.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [run,              run.__module__.__eq__,              ["subprocess"], true]
    - [call,             call.__module__.__eq__,             ["subprocess"], true]
    - [check_call,       check_call.__module__.__eq__,       ["subprocess"], true]
    - [check_output,     check_output.__module__.__eq__,     ["subprocess"], true]
    - [getoutput,        getoutput.__module__.__eq__,        ["subprocess"], true]
    - [getstatusoutput,  getstatusoutput.__module__.__eq__,  ["subprocess"], true]

# ---------------------------------------------------------------------------
# __qualname__ standalone invariants for subprocess functions
#
# subprocess_extra6 covers run/call/check_call/check_output/Popen/
# CompletedProcess __qualname__ in a table, and CalledProcessError/
# TimeoutExpired/SubprocessError/getoutput/getstatusoutput as standalone
# invariants. This spec adds standalone invariants for call/run/check_call/
# check_output as independent named vectors.
# ---------------------------------------------------------------------------

invariant subprocess_extra7.call.qualname:
  description: "subprocess.call.__qualname__ == 'call'"
  category: function_qualnames
  kind: python_call_eq
  function: call.__qualname__.__eq__
  args: ["call"]
  expected: true

invariant subprocess_extra7.run.qualname:
  description: "subprocess.run.__qualname__ == 'run'"
  category: function_qualnames
  kind: python_call_eq
  function: run.__qualname__.__eq__
  args: ["run"]
  expected: true

invariant subprocess_extra7.check_call.qualname:
  description: "subprocess.check_call.__qualname__ == 'check_call'"
  category: function_qualnames
  kind: python_call_eq
  function: check_call.__qualname__.__eq__
  args: ["check_call"]
  expected: true

invariant subprocess_extra7.check_output.qualname:
  description: "subprocess.check_output.__qualname__ == 'check_output'"
  category: function_qualnames
  kind: python_call_eq
  function: check_output.__qualname__.__eq__
  args: ["check_output"]
  expected: true
