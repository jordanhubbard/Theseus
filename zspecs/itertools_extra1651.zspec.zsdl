spec: itertools_extra1651
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __init_subclass__ class creation hook"
    - "all itertools types are C extension types implemented in _itertoolsmodule.c"
    - "C extension types do not define __init_subclass__ in their own __dict__"
    - "they inherit the default no-op __init_subclass__ from object"
    - "itertools.chain is special: it defines __class_getitem__ for generic alias support (PEP 585)"
    - "most other itertools types do NOT define __class_getitem__ in their own __dict__"
    - "itertools types are not ABCs and do not define __subclasshook__, __instancecheck__, or __subclasscheck__"
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: itertools C extension types do not define __init_subclass__ in
# their own __dict__. Being C types, they cannot carry Python-level class
# creation hooks directly; they all inherit the default from object.
# ---------------------------------------------------------------------------

table itertools_extra1651.no_init_subclass:
  description: "itertools C types do not define __init_subclass__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1651ni

  columns: [id, function, args, expected]
  rows:
    - ["it1651ni001", "itertools.chain.__dict__.__contains__",                    ["__init_subclass__"], false]
    - ["it1651ni002", "itertools.islice.__dict__.__contains__",                   ["__init_subclass__"], false]
    - ["it1651ni003", "itertools.product.__dict__.__contains__",                  ["__init_subclass__"], false]
    - ["it1651ni004", "itertools.combinations.__dict__.__contains__",             ["__init_subclass__"], false]
    - ["it1651ni005", "itertools.permutations.__dict__.__contains__",             ["__init_subclass__"], false]
    - ["it1651ni006", "itertools.cycle.__dict__.__contains__",                    ["__init_subclass__"], false]
    - ["it1651ni007", "itertools.repeat.__dict__.__contains__",                   ["__init_subclass__"], false]
    - ["it1651ni008", "itertools.count.__dict__.__contains__",                    ["__init_subclass__"], false]
    - ["it1651ni009", "itertools.dropwhile.__dict__.__contains__",                ["__init_subclass__"], false]
    - ["it1651ni010", "itertools.takewhile.__dict__.__contains__",                ["__init_subclass__"], false]
    - ["it1651ni011", "itertools.filterfalse.__dict__.__contains__",              ["__init_subclass__"], false]
    - ["it1651ni012", "itertools.starmap.__dict__.__contains__",                  ["__init_subclass__"], false]
    - ["it1651ni013", "itertools.zip_longest.__dict__.__contains__",              ["__init_subclass__"], false]
    - ["it1651ni014", "itertools.accumulate.__dict__.__contains__",               ["__init_subclass__"], false]
    - ["it1651ni015", "itertools.compress.__dict__.__contains__",                 ["__init_subclass__"], false]
    - ["it1651ni016", "itertools.groupby.__dict__.__contains__",                  ["__init_subclass__"], false]
    - ["it1651ni017", "itertools.combinations_with_replacement.__dict__.__contains__", ["__init_subclass__"], false]
    - ["it1651ni018", "itertools.pairwise.__dict__.__contains__",                 ["__init_subclass__"], false]
    - ["it1651ni019", "object.__dict__.__contains__",                             ["__init_subclass__"], true]
    - ["it1651ni020", "itertools.chain.__dict__.__contains__",                    ["__subclasshook__"],  false]
    - ["it1651ni021", "itertools.islice.__dict__.__contains__",                   ["__subclasshook__"],  false]
    - ["it1651ni022", "itertools.product.__dict__.__contains__",                  ["__subclasshook__"],  false]
    - ["it1651ni023", "itertools.combinations.__dict__.__contains__",             ["__subclasshook__"],  false]
    - ["it1651ni024", "itertools.permutations.__dict__.__contains__",             ["__subclasshook__"],  false]
    - ["it1651ni025", "itertools.chain.__dict__.__contains__",                    ["__instancecheck__"], false]
    - ["it1651ni026", "itertools.chain.__dict__.__contains__",                    ["__subclasscheck__"], false]
    - ["it1651ni027", "itertools.cycle.__dict__.__contains__",                    ["__subclasshook__"],  false]
    - ["it1651ni028", "itertools.accumulate.__dict__.__contains__",               ["__subclasshook__"],  false]

# ---------------------------------------------------------------------------
# Table 2: __class_getitem__ support for generic alias syntax (PEP 585).
# itertools.chain defines __class_getitem__ and can be written as
# chain[int] in type hints. Most other itertools types do not define this
# method in their own __dict__ and rely on the inherited type.__class_getitem__
# or simply do not support the generic alias syntax directly.
# ---------------------------------------------------------------------------

table itertools_extra1651.class_getitem_support:
  description: "__class_getitem__ presence: chain has it; most other itertools types do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1651cg

  columns: [id, function, args, expected]
  rows:
    - ["it1651cg001", "itertools.chain.__dict__.__contains__",                    ["__class_getitem__"], true]
    - ["it1651cg002", "itertools.islice.__dict__.__contains__",                   ["__class_getitem__"], false]
    - ["it1651cg003", "itertools.product.__dict__.__contains__",                  ["__class_getitem__"], false]
    - ["it1651cg004", "itertools.combinations.__dict__.__contains__",             ["__class_getitem__"], false]
    - ["it1651cg005", "itertools.permutations.__dict__.__contains__",             ["__class_getitem__"], false]
    - ["it1651cg006", "itertools.cycle.__dict__.__contains__",                    ["__class_getitem__"], false]
    - ["it1651cg007", "itertools.repeat.__dict__.__contains__",                   ["__class_getitem__"], false]
    - ["it1651cg008", "itertools.count.__dict__.__contains__",                    ["__class_getitem__"], false]
    - ["it1651cg009", "itertools.dropwhile.__dict__.__contains__",                ["__class_getitem__"], false]
    - ["it1651cg010", "itertools.takewhile.__dict__.__contains__",                ["__class_getitem__"], false]
    - ["it1651cg011", "itertools.filterfalse.__dict__.__contains__",              ["__class_getitem__"], false]
    - ["it1651cg012", "itertools.starmap.__dict__.__contains__",                  ["__class_getitem__"], false]
    - ["it1651cg013", "itertools.zip_longest.__dict__.__contains__",              ["__class_getitem__"], false]
    - ["it1651cg014", "itertools.accumulate.__dict__.__contains__",               ["__class_getitem__"], false]
    - ["it1651cg015", "itertools.compress.__dict__.__contains__",                 ["__class_getitem__"], false]
    - ["it1651cg016", "itertools.groupby.__dict__.__contains__",                  ["__class_getitem__"], false]
    - ["it1651cg017", "itertools.combinations_with_replacement.__dict__.__contains__", ["__class_getitem__"], false]
    - ["it1651cg018", "itertools.pairwise.__dict__.__contains__",                 ["__class_getitem__"], false]
    - ["it1651cg019", "itertools.chain.__dict__.__contains__",                    ["__new__"],           true]
    - ["it1651cg020", "itertools.chain.__dict__.__contains__",                    ["from_iterable"],     true]
    - ["it1651cg021", "itertools.chain.__dict__.__contains__",                    ["__iter__"],          true]
    - ["it1651cg022", "itertools.chain.__dict__.__contains__",                    ["__next__"],          true]
    - ["it1651cg023", "itertools.cycle.__dict__.__contains__",                    ["__iter__"],          true]
    - ["it1651cg024", "itertools.cycle.__dict__.__contains__",                    ["__next__"],          true]
    - ["it1651cg025", "itertools.repeat.__dict__.__contains__",                   ["__iter__"],          true]
    - ["it1651cg026", "itertools.repeat.__dict__.__contains__",                   ["__next__"],          true]
    - ["it1651cg027", "itertools.count.__dict__.__contains__",                    ["__iter__"],          true]
    - ["it1651cg028", "itertools.count.__dict__.__contains__",                    ["__next__"],          true]
