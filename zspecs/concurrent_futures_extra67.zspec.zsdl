spec: concurrent_futures_extra67
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#executor-objects — Python concurrent.futures Executor documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra66.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor/CancelledError/TimeoutError/BrokenExecutor __name__/__module__/__qualname__, InvalidStateError/BrokenProcessPool identity and module, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values/__len__/__class__.__name__, class __dict__/__mro__/__all__ metadata, submit/shutdown qualname lens, Future method qualname lens, class __class__.__name__/__qualname__ equality, class __doc__/__init__/__repr__/__weakref__/__eq__ class names, cf.__all__ membership and length, __loader__/__spec__/__file__/__cached__ class names, __spec__ attributes, code object attribute chains, __defaults__/__kwdefaults__ class names, ThreadPoolExecutor.__doc__.__class__.__name__=='NoneType', Future/__doc__.__contains__('Represents'), exception hierarchy identity (__name__/__qualname__/__module__) for all cf exceptions."
    - "This spec covers (cfmore67 namespace): wave 236 theme — concurrent.futures Executor class doc content and exception hierarchy attributes. NEW in extra67: Executor.__doc__.__class__.__name__.__eq__('str'); Executor.__doc__.__contains__('Executor')==True; Future.__doc__.__contains__('cancel')==True; BrokenProcessPool.__bases__[0].__name__.__eq__('BrokenExecutor') [quoted]; BrokenProcessPool.__mro__.__len__()==6; ThreadPoolExecutor.__mro__.__len__()==3; ProcessPoolExecutor.__mro__.__len__()==3; Executor.__mro__.__len__()==2."
    - "concurrent.futures.Executor.__doc__.__class__.__name__ == 'str'. Executor is the abstract base class for executors; it has a docstring; Executor.__doc__.__class__.__name__ is 'str'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__doc__.__contains__('Executor') == True. Executor's docstring references the class name 'Executor'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__doc__.__contains__('cancel') == True. Future's docstring describes cancellation; Future.cancel() is a core method. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor'. BrokenProcessPool inherits directly from BrokenExecutor; BrokenProcessPool.__bases__[0] is BrokenExecutor; BrokenExecutor.__name__ is 'BrokenExecutor'. Function value contains '[' and MUST be double-quoted. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.BrokenProcessPool.__mro__.__len__() == 6. BrokenProcessPool's MRO is [BrokenProcessPool, BrokenExecutor, RuntimeError, Exception, BaseException, object], a six-element tuple. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3. ThreadPoolExecutor's MRO is [ThreadPoolExecutor, Executor, object], a three-element tuple. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3. ProcessPoolExecutor's MRO is [ProcessPoolExecutor, Executor, object], a three-element tuple. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__mro__.__len__() == 2. Executor's MRO is [Executor, object], a two-element tuple. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures Executor __doc__ checks — extra67
#
# Wave 236 theme: Executor abstract base class doc content.
#
# Executor.__doc__.__class__.__name__ == 'str'
# Executor.__doc__.__contains__('Executor') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra67.Executor_doc:
  description: "concurrent.futures Executor/__doc__.__class__.__name__ and __doc__.__contains__ checks in cfmore67 namespace — wave 236 theme: Executor abstract base class doc content; Executor.__doc__.__class__.__name__=='str' (Executor is an abstract base class with a docstring); Executor.__doc__.__contains__('Executor')==True (the docstring references the class name); NEW in extra67: first __doc__.__class__.__name__ and __doc__.__contains__ checks for Executor in the cfmore67 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc
  id_prefix: cfmore67

  columns: [id, function, args, expected, description]
  rows:
    - [executor_doc_class,   Executor.__doc__.__class__.__name__.__eq__, ["str"],      true, "Executor.__doc__.__class__.__name__ == 'str' — Executor is the abstract base class for concurrent.futures executors; it has a docstring; Executor.__doc__ is a str; __doc__.__class__.__name__ is 'str'; NEW in extra67: first __doc__.__class__.__name__.__eq__('str') check for Executor in the cfmore67 namespace; verified with Python 3.14.3"]
    - [executor_doc_content, Executor.__doc__.__contains__,              ["Executor"], true, "Executor.__doc__.__contains__('Executor') == True — Executor's docstring references the class name 'Executor'; __doc__.__contains__('Executor') returns True; NEW in extra67: first __doc__.__contains__('Executor') check for Executor in the cfmore67 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures Future __doc__ cancel check — extra67
#
# Wave 236 theme: Future class doc content.
#
# Future.__doc__.__contains__('cancel') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra67.Future_doc_cancel:
  description: "concurrent.futures Future/__doc__.__contains__('cancel') check in cfmore67 namespace — wave 236 theme: Future class doc content; Future.__doc__.__contains__('cancel')==True (Future's docstring describes the cancel() method which is a core Future operation); prior specs covered Future.__doc__.__contains__('Represents'); this is a distinct vector; NEW in extra67: first __doc__.__contains__('cancel') check for Future in the cfmore67 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: doc
  id_prefix: cfmore67a

  columns: [id, function, args, expected, description]
  rows:
    - [future_doc_cancel, Future.__doc__.__contains__, ["cancel"], true, "Future.__doc__.__contains__('cancel') == True — concurrent.futures.Future's docstring describes the cancel() method; Future.cancel() is a core method that attempts to cancel a pending future; __doc__.__contains__('cancel') returns True; NEW in extra67: first __doc__.__contains__('cancel') check for Future in the cfmore67 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures BrokenProcessPool hierarchy checks — extra67
#
# Wave 236 theme: BrokenProcessPool inheritance hierarchy.
#
# BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor'  (quoted: contains '[')
# BrokenProcessPool.__mro__.__len__() == 6
# ---------------------------------------------------------------------------

table concurrent_futures_extra67.BrokenProcessPool_hierarchy:
  description: "concurrent.futures BrokenProcessPool/__bases__[0].__name__ and __mro__.__len__() checks in cfmore67 namespace — wave 236 theme: BrokenProcessPool inheritance hierarchy; BrokenProcessPool.__bases__[0].__name__=='BrokenExecutor' (BrokenProcessPool inherits from BrokenExecutor; function value containing '[' is double-quoted per ZSDL rules); BrokenProcessPool.__mro__.__len__()==6 (MRO is [BrokenProcessPool, BrokenExecutor, RuntimeError, Exception, BaseException, object]); NEW in extra67: first __bases__[0].__name__ and __mro__.__len__() checks for BrokenProcessPool in the cfmore67 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfmore67b

  columns: [id, function, args, expected, description]
  rows:
    - ["bpp_bases_0", "BrokenProcessPool.__bases__[0].__name__.__eq__", ["BrokenExecutor"], true, "BrokenProcessPool.__bases__[0].__name__ == 'BrokenExecutor' — BrokenProcessPool inherits directly from BrokenExecutor; BrokenProcessPool.__bases__ is (BrokenExecutor,); BrokenProcessPool.__bases__[0] is BrokenExecutor; BrokenExecutor.__name__ is 'BrokenExecutor'; function value containing '[' is double-quoted per ZSDL rules; NEW in extra67: first __bases__[0].__name__.__eq__('BrokenExecutor') check for BrokenProcessPool in the cfmore67 namespace; verified with Python 3.14.3"]
    - [bpp_mro_len,  BrokenProcessPool.__mro__.__len__,                [],                6,    "BrokenProcessPool.__mro__.__len__() == 6 — BrokenProcessPool's MRO is [BrokenProcessPool, BrokenExecutor, RuntimeError, Exception, BaseException, object], a six-element tuple; __mro__.__len__() returns 6; NEW in extra67: first __mro__.__len__()==6 check for BrokenProcessPool in the cfmore67 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures executor MRO length checks — extra67
#
# Wave 236 theme: executor class MRO depth.
#
# ThreadPoolExecutor.__mro__.__len__() == 3  ([ThreadPoolExecutor, Executor, object])
# ProcessPoolExecutor.__mro__.__len__() == 3  ([ProcessPoolExecutor, Executor, object])
# Executor.__mro__.__len__() == 2             ([Executor, object])
# ---------------------------------------------------------------------------

table concurrent_futures_extra67.executor_mro_lengths:
  description: "concurrent.futures ThreadPoolExecutor/ProcessPoolExecutor/Executor __mro__.__len__() checks in cfmore67 namespace — wave 236 theme: executor class MRO depth; ThreadPoolExecutor.__mro__.__len__()==3 (MRO is [ThreadPoolExecutor, Executor, object]); ProcessPoolExecutor.__mro__.__len__()==3 (MRO is [ProcessPoolExecutor, Executor, object]); Executor.__mro__.__len__()==2 (MRO is [Executor, object]); NEW in extra67: first __mro__.__len__() checks for ThreadPoolExecutor/ProcessPoolExecutor/Executor in the cfmore67 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfmore67c

  columns: [id, function, args, expected, description]
  rows:
    - [threadpool_mro_len, ThreadPoolExecutor.__mro__.__len__, [], 3, "ThreadPoolExecutor.__mro__.__len__() == 3 — ThreadPoolExecutor's MRO is [ThreadPoolExecutor, Executor, object], a three-element tuple; ThreadPoolExecutor inherits directly from Executor; __mro__.__len__() returns 3; NEW in extra67: first __mro__.__len__()==3 check for ThreadPoolExecutor in the cfmore67 namespace; verified with Python 3.14.3"]
    - [processpool_mro_len, ProcessPoolExecutor.__mro__.__len__, [], 3, "ProcessPoolExecutor.__mro__.__len__() == 3 — ProcessPoolExecutor's MRO is [ProcessPoolExecutor, Executor, object], a three-element tuple; ProcessPoolExecutor inherits directly from Executor; __mro__.__len__() returns 3; NEW in extra67: first __mro__.__len__()==3 check for ProcessPoolExecutor in the cfmore67 namespace; verified with Python 3.14.3"]
    - [executor_mro_len,    Executor.__mro__.__len__,           [], 2, "Executor.__mro__.__len__() == 2 — Executor's MRO is [Executor, object], a two-element tuple; Executor is an abstract base class that inherits only from object; __mro__.__len__() returns 2; NEW in extra67: first __mro__.__len__()==2 check for Executor in the cfmore67 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra67
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra67.Executor_doc_str:
  description: "concurrent.futures.Executor.__doc__.__class__.__name__.__eq__('str') returns True — Executor is the abstract base class for concurrent.futures executors; it has a docstring; Executor.__doc__ is a str; __doc__.__class__.__name__.__eq__('str') returns True; NEW in extra67: first standalone __doc__.__class__.__name__.__eq__('str') invariant for Executor in the cfmore67 namespace; wave 236 first doc class name invariant for Executor; verified with Python 3.14.3"
  category: doc
  kind: python_call_eq
  function: Executor.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra67.Executor_doc_Executor:
  description: "concurrent.futures.Executor.__doc__.__contains__('Executor') returns True — Executor's docstring references the class name 'Executor'; __doc__.__contains__('Executor') returns True; NEW in extra67: first standalone __doc__.__contains__('Executor') invariant for Executor in the cfmore67 namespace; wave 236 first doc content invariant for Executor; verified with Python 3.14.3"
  category: doc
  kind: python_call_eq
  function: Executor.__doc__.__contains__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra67.BrokenProcessPool_mro_6:
  description: "concurrent.futures.BrokenProcessPool.__mro__.__len__() == 6 — BrokenProcessPool's MRO is [BrokenProcessPool, BrokenExecutor, RuntimeError, Exception, BaseException, object], a six-element tuple; __mro__.__len__() returns 6; NEW in extra67: first standalone __mro__.__len__()==6 invariant for BrokenProcessPool in the cfmore67 namespace; wave 236 first MRO length invariant for BrokenProcessPool; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BrokenProcessPool.__mro__.__len__
  args: []
  expected: 6

invariant concurrent_futures_extra67.ThreadPoolExecutor_mro_3:
  description: "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3 — ThreadPoolExecutor's MRO is [ThreadPoolExecutor, Executor, object], a three-element tuple; ThreadPoolExecutor inherits directly from Executor; __mro__.__len__() returns 3; NEW in extra67: first standalone __mro__.__len__()==3 invariant for ThreadPoolExecutor in the cfmore67 namespace; wave 236 first MRO length invariant for ThreadPoolExecutor; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__mro__.__len__
  args: []
  expected: 3

invariant concurrent_futures_extra67.Executor_mro_2:
  description: "concurrent.futures.Executor.__mro__.__len__() == 2 — Executor's MRO is [Executor, object], a two-element tuple; Executor is an abstract base class that inherits only from object; __mro__.__len__() returns 2; NEW in extra67: first standalone __mro__.__len__()==2 invariant for Executor in the cfmore67 namespace; wave 236 first MRO length invariant for Executor; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Executor.__mro__.__len__
  args: []
  expected: 2
