spec: inspect_extra1441
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra1426.zspec.zsdl — covers __format__ and __dir__ checks for inspect classes"
  notes:
    - "Wave 543 (_extra1441): focuses on __subclasshook__, __instancecheck__, and __subclasscheck__ ABC-machinery checks for inspect classes."
    - "inspect.Parameter.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — Parameter is a pure Python class with metaclass=type; __subclasshook__ inherited from object. Verified Python 3.14.3."
    - "inspect.Signature.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — Signature is a pure Python class with metaclass=type; __subclasshook__ inherited from object. Verified Python 3.14.3."
    - "inspect.BoundArguments.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — BoundArguments is a pure Python class with metaclass=type; __subclasshook__ inherited from object. Verified Python 3.14.3."
    - "None of Parameter, Signature, BoundArguments define '__subclasshook__', '__instancecheck__', or '__subclasscheck__' in their own __dict__. Verified Python 3.14.3."
    - "inspect.Parameter.__subclasscheck__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "inspect.Signature.__subclasscheck__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "inspect.BoundArguments.__subclasscheck__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect class __subclasshook__ method type checks
#
# Wave 543 theme: __subclasshook__.__class__.__name__ checks for inspect
# classes. Parameter, Signature, and BoundArguments are all pure-Python
# classes with metaclass=type. __subclasshook__ is inherited from object
# and resolves as 'builtin_function_or_method'. None override it.
# ---------------------------------------------------------------------------

table inspect_extra1441.subclasshook_class_name:
  description: "inspect classes: __subclasshook__.__class__.__name__ == 'builtin_function_or_method' for Parameter, Signature, BoundArguments; wave 543; new to extra1441"
  kind: python_call_eq
  category: subclasshook_class_name
  id_prefix: in1441sc

  columns: [id, function, args, expected, description]
  rows:
    - [in1441sc001,
       "Parameter.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.Parameter.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — Parameter is a pure Python class with metaclass=type; __subclasshook__ inherited from object; new to extra1441"]
    - [in1441sc002,
       "Signature.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.Signature.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — Signature is a pure Python class with metaclass=type; __subclasshook__ inherited from object; new to extra1441"]
    - [in1441sc003,
       "BoundArguments.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.BoundArguments.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — BoundArguments is a pure Python class with metaclass=type; __subclasshook__ inherited from object; new to extra1441"]
    - [in1441sc004,
       "Parameter.__subclasscheck__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.Parameter.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method') == True — Parameter inherits __subclasscheck__ from object; new to extra1441"]
    - [in1441sc005,
       "Signature.__subclasscheck__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.Signature.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method') == True — Signature inherits __subclasscheck__ from object; new to extra1441"]
    - [in1441sc006,
       "BoundArguments.__subclasscheck__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.BoundArguments.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method') == True — BoundArguments inherits __subclasscheck__ from object; new to extra1441"]
    - [in1441sc007,
       "Parameter.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.Parameter.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — cross-check: all three inspect classes share the same inherited hook type; new to extra1441"]
    - [in1441sc008,
       "BoundArguments.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.BoundArguments.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — cross-check redundant confirmation; new to extra1441"]

# ---------------------------------------------------------------------------
# Table 2: inspect class __subclasshook__ and __instancecheck__ dict absence
#
# Wave 543 theme: '__subclasshook__' and '__instancecheck__' not in own __dict__
# for inspect classes. None of Parameter, Signature, BoundArguments use ABC
# machinery; they are plain classes defined in inspect.py.
# ---------------------------------------------------------------------------

table inspect_extra1441.abc_hooks_dict_membership:
  description: "inspect classes: '__subclasshook__' and '__instancecheck__' not in own __dict__ for Parameter, Signature, BoundArguments; wave 543; new to extra1441"
  kind: python_call_eq
  category: abc_hooks_dict_membership
  id_prefix: in1441dm

  columns: [id, function, args, expected, description]
  rows:
    - [in1441dm001,
       "Parameter.__dict__.__contains__",
       ["__subclasshook__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__subclasshook__') == False — Parameter does not define __subclasshook__ in its own class __dict__; not an ABC subclass; new to extra1441"]
    - [in1441dm002,
       "Signature.__dict__.__contains__",
       ["__subclasshook__"],
       false,
       "inspect.Signature.__dict__.__contains__('__subclasshook__') == False — Signature does not define __subclasshook__ in its own class __dict__; not an ABC subclass; new to extra1441"]
    - [in1441dm003,
       "BoundArguments.__dict__.__contains__",
       ["__subclasshook__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__subclasshook__') == False — BoundArguments does not define __subclasshook__ in its own class __dict__; not an ABC subclass; new to extra1441"]
    - [in1441dm004,
       "Parameter.__dict__.__contains__",
       ["__instancecheck__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__instancecheck__') == False — Parameter does not define __instancecheck__ in its own class __dict__; new to extra1441"]
    - [in1441dm005,
       "Signature.__dict__.__contains__",
       ["__instancecheck__"],
       false,
       "inspect.Signature.__dict__.__contains__('__instancecheck__') == False — Signature does not define __instancecheck__ in its own class __dict__; new to extra1441"]
    - [in1441dm006,
       "BoundArguments.__dict__.__contains__",
       ["__instancecheck__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__instancecheck__') == False — BoundArguments does not define __instancecheck__ in its own class __dict__; new to extra1441"]
    - [in1441dm007,
       "Parameter.__dict__.__contains__",
       ["__subclasscheck__"],
       false,
       "inspect.Parameter.__dict__.__contains__('__subclasscheck__') == False — Parameter does not define __subclasscheck__ in its own class __dict__; new to extra1441"]
    - [in1441dm008,
       "Signature.__dict__.__contains__",
       ["__subclasscheck__"],
       false,
       "inspect.Signature.__dict__.__contains__('__subclasscheck__') == False — Signature does not define __subclasscheck__ in its own class __dict__; new to extra1441"]

# ---------------------------------------------------------------------------
# Table 3: inspect BoundArguments ABC hook dict absence and cross-checks
#
# Wave 543 theme: Confirms BoundArguments __subclasscheck__ absence plus
# cross-check confirmations that all three classes agree on having no
# custom ABC hooks in their own namespaces.
# ---------------------------------------------------------------------------

table inspect_extra1441.boundarguments_abc_hooks:
  description: "inspect.BoundArguments: ABC hook dict absence and cross-checks confirming no ABC machinery for Parameter, Signature, BoundArguments; wave 543; new to extra1441"
  kind: python_call_eq
  category: boundarguments_abc_hooks
  id_prefix: in1441ba

  columns: [id, function, args, expected, description]
  rows:
    - [in1441ba001,
       "BoundArguments.__dict__.__contains__",
       ["__subclasscheck__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__subclasscheck__') == False — BoundArguments does not define __subclasscheck__ in its own class __dict__; new to extra1441"]
    - [in1441ba002,
       "BoundArguments.__dict__.__contains__",
       ["__subclasshook__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__subclasshook__') == False — BoundArguments does not define __subclasshook__; cross-check of in1441dm003; new to extra1441"]
    - [in1441ba003,
       "BoundArguments.__dict__.__contains__",
       ["__instancecheck__"],
       false,
       "inspect.BoundArguments.__dict__.__contains__('__instancecheck__') == False — BoundArguments does not define __instancecheck__; cross-check of in1441dm006; new to extra1441"]
    - [in1441ba004,
       "Parameter.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.Parameter.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — cross-check in boundarguments table; new to extra1441"]
    - [in1441ba005,
       "Signature.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.Signature.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — cross-check in boundarguments table; new to extra1441"]
    - [in1441ba006,
       "BoundArguments.__subclasshook__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.BoundArguments.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') == True — cross-check in boundarguments table; new to extra1441"]
    - [in1441ba007,
       "Parameter.__subclasscheck__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.Parameter.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method') == True — cross-check: __subclasscheck__ type is builtin_function_or_method; new to extra1441"]
    - [in1441ba008,
       "BoundArguments.__subclasscheck__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "inspect.BoundArguments.__subclasscheck__.__class__.__name__.__eq__('builtin_function_or_method') == True — cross-check: __subclasscheck__ type is builtin_function_or_method; new to extra1441"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1441
# ---------------------------------------------------------------------------

invariant inspect_extra1441.Parameter_subclasshook_is_builtin:
  description: "inspect.Parameter.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — inherited from object; wave 543; new to extra1441"
  kind: python_call_eq
  function: Parameter.__subclasshook__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant inspect_extra1441.Parameter_subclasshook_not_in_dict:
  description: "'__subclasshook__' not in inspect.Parameter.__dict__ — Parameter does not override __subclasshook__; wave 543; new to extra1441"
  kind: python_call_eq
  function: Parameter.__dict__.__contains__
  args: ["__subclasshook__"]
  expected: false

invariant inspect_extra1441.Signature_instancecheck_not_in_dict:
  description: "'__instancecheck__' not in inspect.Signature.__dict__ — Signature does not define __instancecheck__; wave 543; new to extra1441"
  kind: python_call_eq
  function: Signature.__dict__.__contains__
  args: ["__instancecheck__"]
  expected: false

invariant inspect_extra1441.BoundArguments_subclasscheck_not_in_dict:
  description: "'__subclasscheck__' not in inspect.BoundArguments.__dict__ — BoundArguments does not define __subclasscheck__; wave 543; new to extra1441"
  kind: python_call_eq
  function: BoundArguments.__dict__.__contains__
  args: ["__subclasscheck__"]
  expected: false
