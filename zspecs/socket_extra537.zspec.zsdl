spec: socket_extra537
version: ">=3.9"
backend: python_module(socket)
docs: "Behavioral specs for socket.socket method __qualname__ identity"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: strict

table socket_extra537.socket_method_qualnames:
  description: "socket.socket method __qualname__ identity checks"
  kind: python_call_eq
  category: method_identity
  id_prefix: sockq
  columns: [id, function, args, expected]
  rows:
    - [sockq001, socket.socket.connect.__qualname__.__eq__, ["socket.connect"], true]
    - [sockq002, socket.socket.bind.__qualname__.__eq__, ["socket.bind"], true]
    - [sockq003, socket.socket.listen.__qualname__.__eq__, ["socket.listen"], true]
    - [sockq004, socket.socket.accept.__qualname__.__eq__, ["socket.accept"], true]
    - [sockq005, socket.socket.send.__qualname__.__eq__, ["socket.send"], true]
    - [sockq006, socket.socket.recv.__qualname__.__eq__, ["socket.recv"], true]
    - [sockq007, socket.socket.close.__qualname__.__eq__, ["socket.close"], true]
    - [sockq008, socket.socket.settimeout.__qualname__.__eq__, ["socket.settimeout"], true]
    - [sockq009, socket.socket.gettimeout.__qualname__.__eq__, ["socket.gettimeout"], true]
    - [sockq010, socket.socket.fileno.__qualname__.__eq__, ["socket.fileno"], true]
    - [sockq011, socket.socket.setsockopt.__qualname__.__eq__, ["socket.setsockopt"], true]
    - [sockq012, socket.socket.getsockopt.__qualname__.__eq__, ["socket.getsockopt"], true]
