spec: io_extra2086
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io.zspec.zsdl"
    - "_io.zspec.zsdl"
    - "_io_extra.zspec.zsdl"
  notes:
    - "Wave extra2086, theme: __format__ string formatting protocol dict-presence; __bytes__ bytes conversion dict-presence; __fspath__ filesystem path protocol dict-presence; __buffer__/__release_buffer__ buffer protocol dict-presence."
    - "io.IOBase, RawIOBase, BufferedIOBase, TextIOBase, StringIO, BytesIO, FileIO — none define __format__, __bytes__, __fspath__, __buffer__, or __release_buffer__ in their own __dict__."
    - "These are C-level abstract base classes; special format/bytes/path/buffer protocol methods are not injected at the io module level."
    - "All expected values verified by running Python 3.12 io module on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __format__ string formatting protocol dict-presence
# ---------------------------------------------------------------------------

table io_extra2086.format_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["io2086001", "io.IOBase.__dict__.__contains__", ["__format__"], false]
    - ["io2086002", "io.RawIOBase.__dict__.__contains__", ["__format__"], false]
    - ["io2086003", "io.BufferedIOBase.__dict__.__contains__", ["__format__"], false]
    - ["io2086004", "io.TextIOBase.__dict__.__contains__", ["__format__"], false]
    - ["io2086005", "io.StringIO.__dict__.__contains__", ["__format__"], false]
    - ["io2086006", "io.BytesIO.__dict__.__contains__", ["__format__"], false]
    - ["io2086007", "io.FileIO.__dict__.__contains__", ["__format__"], false]

