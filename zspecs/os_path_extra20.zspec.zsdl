spec: os_path_extra20
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py, Lib/genericpath.py"
    - "os_path_extra16.zspec.zsdl — covers __qualname__ for join/split/exists/isfile/isdir/basename/dirname; __module__ for those plus sameopenfile/samestat/getsize/getatime/getmtime/getctime."
    - "os_path_extra18.zspec.zsdl — covers __qualname__ and __module__ for splitext and normpath."
    - "os_path_extra19.zspec.zsdl — covers __module__ for realpath/sameopenfile/samestat/getsize/getatime/getmtime/getctime/lexists/islink/ismount; __qualname__ for ismount."
    - "os_path_extra6.zspec.zsdl — covers __qualname__ for join/split/basename/dirname/normpath/abspath/exists/isfile/isdir/isabs."
    - "os_path_extra8.zspec.zsdl — covers expanduser __qualname__ and related axes."
  notes:
    - "This spec extends os_path_extra19.zspec.zsdl."
    - "Focus: __qualname__ and __module__ for relpath, expandvars, commonpath, commonprefix, samefile, and isabs — none covered in prior specs as standalone invariants."
    - "os.path.relpath.__qualname__ == 'relpath' — top-level function in posixpath; qualname equals simple name. Verified."
    - "os.path.relpath.__module__ == 'posixpath' — relpath is a pure-Python function in posixpath.py. Verified."
    - "os.path.expandvars.__qualname__ == 'expandvars' — top-level function in posixpath. Verified."
    - "os.path.expandvars.__module__ == 'posixpath' — expandvars is defined in posixpath.py. Verified."
    - "os.path.commonpath.__qualname__ == 'commonpath' — top-level function in posixpath. Verified."
    - "os.path.commonpath.__module__ == 'posixpath' — commonpath is a POSIX-specific function. Verified."
    - "os.path.commonprefix.__qualname__ == 'commonprefix' — top-level function in genericpath. Verified."
    - "os.path.commonprefix.__module__ == 'genericpath' — commonprefix is cross-platform, defined in genericpath.py. Verified."
    - "os.path.samefile.__qualname__ == 'samefile' — top-level function in genericpath. Verified."
    - "os.path.samefile.__module__ == 'genericpath' — samefile is defined in the cross-platform genericpath module. Verified."
    - "os.path.isabs.__qualname__ == 'isabs' — covered in extra6 table; first standalone invariant in extra20 namespace for isabs.__module__."
    - "os.path.isabs.__module__ == 'posixpath' — isabs is a POSIX-specific function. Verified."
    - "len('relpath') == 7, len('expandvars') == 10, len('commonpath') == 10, len('commonprefix') == 12, len('samefile') == 8, len('isabs') == 5. All verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__ for os.path functions not yet covered as standalone invariants
#
# Prior specs cover __qualname__ for: join/split/exists/isfile/isdir/basename/
# dirname/abspath/expanduser/splitext/normpath/ismount/realpath.
# No prior spec covers __qualname__ for relpath, expandvars, commonpath,
# commonprefix, samefile, or isabs as a standalone invariant in any extra
# namespace (extra6 covers isabs in a table row, but not as standalone).
# All are top-level module functions — qualname equals simple function name.
# Verified: relpath='relpath', expandvars='expandvars', commonpath='commonpath',
#   commonprefix='commonprefix', samefile='samefile', isabs='isabs'.
# ---------------------------------------------------------------------------

table os_path_extra20.function_qualnames:
  description: "__qualname__ for os.path relpath/expandvars/commonpath/commonprefix/samefile/isabs"
  kind: python_call_eq
  category: function_identity
  id_prefix: fqn20

  columns: [id, function, args, expected]
  rows:
    - [relpath,      relpath.__qualname__.__eq__,      ["relpath"],      true]
    - [expandvars,   expandvars.__qualname__.__eq__,   ["expandvars"],   true]
    - [commonpath,   commonpath.__qualname__.__eq__,   ["commonpath"],   true]
    - [commonprefix, commonprefix.__qualname__.__eq__, ["commonprefix"], true]
    - [samefile,     samefile.__qualname__.__eq__,     ["samefile"],     true]
    - [isabs,        isabs.__qualname__.__eq__,        ["isabs"],        true]

# ---------------------------------------------------------------------------
# Table: __module__ for os.path relpath/expandvars/commonpath/commonprefix/samefile/isabs
#
# On POSIX, os.path is posixpath. Most functions live in posixpath.py, but
# cross-platform helpers (commonprefix, samefile) live in genericpath.
# No prior spec covers __module__ for relpath, expandvars, commonpath,
# commonprefix, samefile, or isabs.
# Verified: relpath='posixpath', expandvars='posixpath', commonpath='posixpath',
#   commonprefix='genericpath', samefile='genericpath', isabs='posixpath'.
# ---------------------------------------------------------------------------

table os_path_extra20.function_modules:
  description: "__module__ for os.path relpath/expandvars/commonpath/commonprefix/samefile/isabs — posixpath vs genericpath"
  kind: python_call_eq
  category: function_identity
  id_prefix: fmod20

  columns: [id, function, args, expected]
  rows:
    - [relpath,      relpath.__module__.__eq__,      ["posixpath"],   true]
    - [expandvars,   expandvars.__module__.__eq__,   ["posixpath"],   true]
    - [commonpath,   commonpath.__module__.__eq__,   ["posixpath"],   true]
    - [commonprefix, commonprefix.__module__.__eq__, ["genericpath"], true]
    - [samefile,     samefile.__module__.__eq__,     ["genericpath"], true]
    - [isabs,        isabs.__module__.__eq__,        ["posixpath"],   true]

# ---------------------------------------------------------------------------
# Table: __qualname__ string lengths for relpath/expandvars/commonpath/
#         commonprefix/samefile/isabs
#
# No prior os.path spec covers __qualname__.__len__() for any of these
# functions. Length checks provide an independent validation axis.
# Verified: relpath=7, expandvars=10, commonpath=10, commonprefix=12,
#   samefile=8, isabs=5.
# ---------------------------------------------------------------------------

table os_path_extra20.function_qualname_lengths:
  description: "__qualname__.__len__() for os.path relpath/expandvars/commonpath/commonprefix/samefile/isabs"
  kind: python_call_eq
  category: function_identity
  id_prefix: fqlen20

  columns: [id, function, args, expected]
  rows:
    - [relpath,      relpath.__qualname__.__len__,      [], 7]
    - [expandvars,   expandvars.__qualname__.__len__,   [], 10]
    - [commonpath,   commonpath.__qualname__.__len__,   [], 10]
    - [commonprefix, commonprefix.__qualname__.__len__, [], 12]
    - [samefile,     samefile.__qualname__.__len__,     [], 8]
    - [isabs,        isabs.__qualname__.__len__,        [], 5]

# ---------------------------------------------------------------------------
# Standalone: relpath.__qualname__ == 'relpath'
#
# relpath is a top-level pure-Python function in posixpath.py. Its qualname
# equals its simple name with no class prefix. No prior spec covers
# relpath.__qualname__ as a standalone invariant.
# Verified: os.path.relpath.__qualname__ == 'relpath'
# ---------------------------------------------------------------------------

invariant os_path_extra20.relpath.qualname:
  description: "os.path.relpath.__qualname__ == 'relpath' — top-level function in posixpath; qualname equals simple name"
  category: function_identity
  kind: python_call_eq
  function: relpath.__qualname__.__eq__
  args: ["relpath"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: commonprefix.__module__ == 'genericpath'
#
# commonprefix is a cross-platform string utility defined in genericpath.py,
# not in posixpath.py. This distinguishes it from other path functions that
# live in posixpath. No prior spec covers commonprefix.__module__.
# Verified: os.path.commonprefix.__module__ == 'genericpath'
# ---------------------------------------------------------------------------

invariant os_path_extra20.commonprefix.module:
  description: "os.path.commonprefix.__module__ == 'genericpath' — commonprefix is a cross-platform helper defined in genericpath.py"
  category: function_identity
  kind: python_call_eq
  function: commonprefix.__module__.__eq__
  args: ["genericpath"]
  expected: true
