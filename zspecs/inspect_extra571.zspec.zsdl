spec: inspect_extra571
version: ">=3.9"
backend: python_module(inspect)
docs: "Behavioral spec for inspect.BoundArguments method and attribute identity"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module reference, BoundArguments section"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers method __name__ identity, property class names, __qualname__, __module__, and base class name for BoundArguments"
  created_at: "2026-04-12T00:00:00Z"

table inspect_extra571.method_names:
  description: "Verify __name__ of BoundArguments methods"
  kind: python_call_eq
  category: method_identity
  id_prefix: INEX571
  columns: [id, function, args, expected]
  rows:
    - [INEX571001, inspect.BoundArguments.__init__.__name__.__eq__, ["__init__"], true]
    - [INEX571002, inspect.BoundArguments.__repr__.__name__.__eq__, ["__repr__"], true]
    - [INEX571003, inspect.BoundArguments.__eq__.__name__.__eq__, ["__eq__"], true]
    - [INEX571004, inspect.BoundArguments.apply_defaults.__name__.__eq__, ["apply_defaults"], true]
table inspect_extra571.property_class_names:
  description: "Verify __class__.__name__ of BoundArguments properties"
  kind: python_call_eq
  category: class_identity
  id_prefix: INEX571
  columns: [id, function, args, expected]
  rows:
    - [INEX571005, inspect.BoundArguments.args.__class__.__name__.__eq__, ["property"], true]
    - [INEX571006, inspect.BoundArguments.kwargs.__class__.__name__.__eq__, ["property"], true]
table inspect_extra571.class_identity:
  description: "Verify BoundArguments class-level identity attributes and base class"
  kind: python_call_eq
  category: class_identity
  id_prefix: INEX571
  columns: [id, function, args, expected]
  rows:
    - [INEX571007, inspect.BoundArguments.__qualname__.__eq__, ["BoundArguments"], true]
    - [INEX571008, inspect.BoundArguments.__module__.__eq__, ["inspect"], true]
    - ["INEX571009", "inspect.BoundArguments.__bases__[0].__name__.__eq__", ["object"], true]