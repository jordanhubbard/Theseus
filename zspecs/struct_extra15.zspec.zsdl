spec: struct_extra15
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct.zspec.zsdl — pack/unpack for B/b/H/h/I/i/Q/q/f/d/?/e/x; calcsize; roundtrip; error cases."
    - "struct_extra.zspec.zsdl — Struct format/size, calcsize extras, pack_into, unpack_from, iter_unpack, error name/bases."
    - "struct_extra2.zspec.zsdl — function __name__/__module__; pack(>H,256); unpack(>H); calcsize(>HHH); Struct base."
    - "struct_extra3.zspec.zsdl — pack/unpack/calcsize for !f/!d/!?; calcsize for !5s/!3p/!x/!5x."
    - "struct_extra4.zspec.zsdl — Struct.__name__; pack_into.__name__; function __qualname__ table; error.__qualname__; pack(>I,65536)/(<I,65536)/(>i,-256); calcsize(>i/<i/>I)."
    - "struct_extra5.zspec.zsdl — Struct.__qualname__; Struct('>I'/'>H') format/size; pack('>B',255); unpack('>B',xff); calcsize('>B'/'<B'/'>5s'); Struct('>I').pack(256)."
    - "struct_extra6.zspec.zsdl — pack/unpack('>b',127/-128); Struct('>b'/'>Q') format/size; pack/calcsize('<h'); unpack('<h')."
    - "struct_extra7.zspec.zsdl — pack/unpack/calcsize for '>l'/'>L'/'=H'/'>2B'; Struct('>l') format/size."
    - "struct_extra8.zspec.zsdl — function __module__ (all '_struct' except error 'struct'); pack return type/length for '>I'/'>H'; calcsize('>IHB'); unpack('>H',0100); Struct('>IHB') format/size; calcsize('>Q')."
    - "struct_extra9.zspec.zsdl — calcsize('c'/'P'); Struct method descriptor __qualname__/__name__ tables."
    - "struct_extra10.zspec.zsdl — pack/unpack('>BB',0,255); pack/unpack('<I',1); calcsize('<f'/'<d'); Struct('>BB') format/size; pack('>i',0/-1)."
    - "struct_extra11.zspec.zsdl — pack('>I',305419896); pack('<H',256); pack('!f',1.0) length; unpack('>I',12345678); calcsize('!BHI'/'3s'); Struct __name__/__module__; error.__module__; pack/unpack('>H',1000); pack('>B',127)."
    - "struct_extra12.zspec.zsdl — pack/unpack('<H' with 1/65535/256); unpack('>i',FFFFFFFF); calcsize('<H'/'<I'/'>i'/'>b'/'!H'); pack('>b',0)."
    - "struct_extra13.zspec.zsdl — calcsize('=H'/'=I'/'=c'/'3s'); pack/unpack('=H',1)/('>H',1000)/('c',b'A')/('3s',b'abc')."
    - "struct_extra14.zspec.zsdl — pack('>I',0)/('>I',1)/('>H',256) exact bytes; unpack('>I',00000000)/('>H',0100) exact values."
  notes:
    - "This spec extends struct.zspec.zsdl through struct_extra14.zspec.zsdl with new network-byte-order vectors."
    - "struct.calcsize('!BHI') == 7: network byte order, no padding: 1 (B) + 2 (H) + 4 (I) = 7. Verified."
    - "struct.calcsize('!BHIQ') == 15: network byte order, no padding: 1 + 2 + 4 + 8 = 15. Verified."
    - "struct.pack('!B', 255) == b'\\xff': unsigned byte 255 in network order is a single 0xff byte. Verified."
    - "struct.pack('!I', 16909060) == b'\\x01\\x02\\x03\\x04': 16909060 == 0x01020304. Verified."
    - "struct.unpack('!B', b'\\xff') == (255,): inverse of pack('!B', 255). Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize('!BHI') == 7
#
# Network byte order ('!') suppresses padding. The format '!BHI' packs:
#   B = 1 byte (unsigned char)
#   H = 2 bytes (unsigned short)
#   I = 4 bytes (unsigned int)
# Total = 7 bytes. struct_extra11 covers calcsize('!BHI') == 7 but from
# the extra11 namespace; this anchors the same fact from extra15.
# ---------------------------------------------------------------------------

invariant struct_extra15.calcsize.network_BHI:
  description: "struct.calcsize('!BHI') == 7 — network byte order: 1+2+4, no padding"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!BHI"]
  expected: 7

# ---------------------------------------------------------------------------
# struct.calcsize('!BHIQ') == 15
#
# Network byte order, no padding: B(1) + H(2) + I(4) + Q(8) = 15 bytes.
# No prior struct spec covers calcsize('!BHIQ').
# ---------------------------------------------------------------------------

invariant struct_extra15.calcsize.network_BHIQ:
  description: "struct.calcsize('!BHIQ') == 15 — network byte order: 1+2+4+8, no padding"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!BHIQ"]
  expected: 15

# ---------------------------------------------------------------------------
# struct.pack('!B', 255) == b'\xff'
#
# Packing unsigned byte 255 in network byte order yields a single 0xff byte.
# struct_extra5 covers pack('>B', 255) with exact bytes; no prior spec covers
# the '!' prefix variant pack('!B', 255) with exact byte result.
# ---------------------------------------------------------------------------

invariant struct_extra15.pack.network_B_255:
  description: "struct.pack('!B', 255) == b'\\xff' — network byte order unsigned byte 255"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: ["!B", 255]
  expected: !hex ff

# ---------------------------------------------------------------------------
# struct.pack('!I', 16909060) == b'\x01\x02\x03\x04'
#
# 16909060 == 0x01020304. Network byte order (big-endian) packs this as
# 01 02 03 04. No prior struct spec packs '!I' with value 16909060.
# ---------------------------------------------------------------------------

invariant struct_extra15.pack.network_I_16909060:
  description: "struct.pack('!I', 16909060) == b'\\x01\\x02\\x03\\x04' — 16909060 == 0x01020304 in network order"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: ["!I", 16909060]
  expected: !hex 01020304

# ---------------------------------------------------------------------------
# struct.unpack('!B', b'\xff') == (255,)
#
# Inverse of pack('!B', 255). Unpacking a single 0xff byte in network byte
# order yields the tuple (255,). No prior struct spec covers unpack('!B').
# ---------------------------------------------------------------------------

invariant struct_extra15.unpack.network_B_xff:
  description: "struct.unpack('!B', b'\\xff') == (255,) — network byte order unpack of 0xff"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: ["!B", !hex ff]
  expected: [255]
