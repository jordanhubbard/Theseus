spec: fcntl_extra4
version: ">=3.9"
backend: python_module(fcntl)

docs: https://docs.python.org/3/library/fcntl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fcntl.html — Python fcntl documentation"
    - "POSIX.1-2017 — fcntl(2): F_RDLCK=1, F_WRLCK=3, F_UNLCK=2 on macOS; F_DUPFD=0, F_GETOWN=5, F_SETOWN=6 on macOS"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/fcntlmodule.c"
  notes:
    - "This spec extends fcntl.zspec.zsdl through fcntl_extra3.zspec.zsdl."
    - "fcntl.zspec.zsdl: __name__ for all four functions, LOCK_SH/EX/NB/UN values, F_GETFL/SETFL/GETFD/SETFD/FD_CLOEXEC type checks, LOCK_SH|LOCK_NB==5."
    - "fcntl_extra: is_builtin for all four functions, LOCK_* type and value invariants."
    - "fcntl_extra2: F_GETLK/F_SETLK/F_SETLKW types, FD_CLOEXEC==1, LOCK_EX|LOCK_NB==6, LOCK_UN|LOCK_NB==12, LOCK_* type table, function __qualname__ table."
    - "fcntl_extra3: module __name__, function __module__ attributes, LOCK arithmetic (add/sub), F_GETFD/F_SETFD/F_GETFL/F_SETFL value pins."
    - "New here: F_RDLCK/F_WRLCK/F_UNLCK value pins on macOS (1/3/2); F_DUPFD value pin (0); F_GETOWN/F_SETOWN type checks; fcntl module __package__; module __loader__ class; LOCK_SH | LOCK_EX == 3 bitwise OR."
    - "F_RDLCK=1, F_WRLCK=3, F_UNLCK=2 on macOS (BSD record-lock type codes)."
    - "F_DUPFD=0 on macOS/BSD — lowest cmd number for the duplicating fd operation."
    - "F_GETOWN=5, F_SETOWN=6 on macOS — POSIX async I/O ownership constants."
    - "fcntl.__package__ == '' — fcntl is a top-level extension module with no parent package."
    - "fcntl.__loader__.__class__.__name__ == 'ExtensionFileLoader' — C-extension module loaded by importlib."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# F_RDLCK, F_WRLCK, F_UNLCK — record-lock type constants, value pins on macOS
# Prior specs cover F_GETLK/F_SETLK/F_SETLKW (type-only) but NOT these values.
# F_RDLCK=1, F_WRLCK=3, F_UNLCK=2 on macOS (BSD record-lock type codes).
# ---------------------------------------------------------------------------

invariant fcntl_extra4.F_RDLCK.value:
  description: "fcntl.F_RDLCK == 1 — read-lock type code (macOS/BSD)"
  category: constants
  kind: python_call_eq
  function: F_RDLCK.__eq__
  args: [1]
  expected: true

invariant fcntl_extra4.F_WRLCK.value:
  description: "fcntl.F_WRLCK == 3 — write-lock type code (macOS/BSD)"
  category: constants
  kind: python_call_eq
  function: F_WRLCK.__eq__
  args: [3]
  expected: true

invariant fcntl_extra4.F_UNLCK.value:
  description: "fcntl.F_UNLCK == 2 — unlock type code (macOS/BSD)"
  category: constants
  kind: python_call_eq
  function: F_UNLCK.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# F_RDLCK, F_WRLCK, F_UNLCK — type checks (int)
# ---------------------------------------------------------------------------

table fcntl_extra4.lock_type_constants.class_checks:
  kind: python_call_eq
  category: constants
  id_prefix: ltype_class

  columns: [id, function, args, expected]
  rows:
    - [F_RDLCK, F_RDLCK.__class__.__name__.__eq__, ["int"], true]
    - [F_WRLCK, F_WRLCK.__class__.__name__.__eq__, ["int"], true]
    - [F_UNLCK, F_UNLCK.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# F_DUPFD value pin — F_DUPFD=0 on macOS
# Not covered in any prior spec (no table or invariant for F_DUPFD).
# ---------------------------------------------------------------------------

invariant fcntl_extra4.F_DUPFD.value:
  description: "fcntl.F_DUPFD == 0 — duplicate fd command, lowest numbered fcntl cmd on macOS"
  category: constants
  kind: python_call_eq
  function: F_DUPFD.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# F_GETOWN, F_SETOWN — type checks (not pinned: values differ across platforms)
# Not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant fcntl_extra4.F_GETOWN.is_int:
  description: "fcntl.F_GETOWN is an int — get process or process group receiving SIGIO/SIGURG"
  category: constants
  kind: python_call_eq
  function: F_GETOWN.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant fcntl_extra4.F_SETOWN.is_int:
  description: "fcntl.F_SETOWN is an int — set process or process group to receive SIGIO/SIGURG"
  category: constants
  kind: python_call_eq
  function: F_SETOWN.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Module __package__ — not covered in any prior spec
# fcntl is a C-extension module at the top level; __package__ is empty string.
# ---------------------------------------------------------------------------

invariant fcntl_extra4.module.package:
  description: "fcntl.__package__ == '' — fcntl is a top-level module with no parent package"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# Module __loader__ class — not covered in any prior spec
# C-extension modules are loaded by ExtensionFileLoader.
# ---------------------------------------------------------------------------

invariant fcntl_extra4.module.loader_class:
  description: "fcntl.__loader__.__class__.__name__ == 'ExtensionFileLoader' — C extension module"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["ExtensionFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# LOCK_SH | LOCK_EX == 3 — bitwise OR of shared and exclusive flags
# fcntl.zspec covers LOCK_SH|LOCK_NB==5; fcntl_extra2 covers LOCK_EX|LOCK_NB==6.
# LOCK_SH(1) | LOCK_EX(2) == 3 — a new OR combination not in any prior spec.
# ---------------------------------------------------------------------------

invariant fcntl_extra4.constants.lock_sh_or_lock_ex:
  description: "fcntl.LOCK_SH | fcntl.LOCK_EX == 3 — bitwise OR of values 1 and 2"
  category: constants
  kind: python_call_eq
  function: LOCK_SH.__or__
  args: [2]
  expected: 3
