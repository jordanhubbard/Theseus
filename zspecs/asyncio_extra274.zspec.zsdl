spec: asyncio_extra274
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "asyncio.Semaphore, asyncio.Event, and asyncio.Condition are all defined in asyncio.locks; __module__ == 'asyncio.locks'."
    - "asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin' (internal mixin, not object)."
    - "asyncio.Event.__bases__[0].__name__ == '_LoopBoundMixin' (internal mixin)."
    - "asyncio.Condition.__bases__[0].__name__ == '_ContextManagerMixin'."
    - "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — it inherits from Semaphore."
    - "Semaphore method __qualname__ values are prefixed with 'Semaphore.' (acquire, release, locked)."
    - "Event method __qualname__ values are prefixed with 'Event.' (wait, set, clear, is_set)."
    - "Condition method __qualname__ values are prefixed with 'Condition.' (wait, notify, notify_all)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Semaphore class identity — table
#
# asyncio.Semaphore is defined in asyncio.locks and inherits from
# _ContextManagerMixin (an internal mixin class).
# ---------------------------------------------------------------------------

table asyncio_extra274.semaphore_identity:
  description: "asyncio.Semaphore class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: semid

  columns: [id, function, args, expected, description]
  rows:
    - [sem_name,        Semaphore.__name__.__eq__,          ["Semaphore"],       true, "asyncio.Semaphore.__name__ == 'Semaphore'"]
    - [sem_module,      Semaphore.__module__.__eq__,        ["asyncio.locks"],   true, "asyncio.Semaphore.__module__ == 'asyncio.locks'"]
    - [sem_acquire,     Semaphore.acquire.__name__.__eq__,  ["acquire"],         true, "asyncio.Semaphore.acquire.__name__ == 'acquire'"]
    - [sem_release,     Semaphore.release.__name__.__eq__,  ["release"],         true, "asyncio.Semaphore.release.__name__ == 'release'"]
    - [sem_locked,      Semaphore.locked.__name__.__eq__,   ["locked"],          true, "asyncio.Semaphore.locked.__name__ == 'locked'"]

# ---------------------------------------------------------------------------
# asyncio.Event class identity — table
#
# asyncio.Event is defined in asyncio.locks and inherits from _LoopBoundMixin.
# ---------------------------------------------------------------------------

table asyncio_extra274.event_identity:
  description: "asyncio.Event class identity and method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: evtid

  columns: [id, function, args, expected, description]
  rows:
    - [evt_name,     Event.__name__.__eq__,         ["Event"],          true, "asyncio.Event.__name__ == 'Event'"]
    - [evt_module,   Event.__module__.__eq__,        ["asyncio.locks"],  true, "asyncio.Event.__module__ == 'asyncio.locks'"]
    - [evt_wait,     Event.wait.__name__.__eq__,     ["wait"],           true, "asyncio.Event.wait.__name__ == 'wait'"]
    - [evt_set,      Event.set.__name__.__eq__,      ["set"],            true, "asyncio.Event.set.__name__ == 'set'"]
    - [evt_clear,    Event.clear.__name__.__eq__,    ["clear"],          true, "asyncio.Event.clear.__name__ == 'clear'"]
    - [evt_is_set,   Event.is_set.__name__.__eq__,   ["is_set"],         true, "asyncio.Event.is_set.__name__ == 'is_set'"]

# ---------------------------------------------------------------------------
# asyncio.Semaphore base class — standalone invariant
# ---------------------------------------------------------------------------

invariant asyncio_extra274.Semaphore.bases0_name:
  description: "asyncio.Semaphore.__bases__[0].__name__ == '_ContextManagerMixin'"
  category: identity
  kind: python_call_eq
  function: "Semaphore.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.Event base class — standalone invariant
# ---------------------------------------------------------------------------

invariant asyncio_extra274.Event.bases0_name:
  description: "asyncio.Event.__bases__[0].__name__ == '_LoopBoundMixin'"
  category: identity
  kind: python_call_eq
  function: "Event.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.Condition class identity — standalone invariants
#
# Condition is defined in asyncio.locks and inherits from _ContextManagerMixin.
# ---------------------------------------------------------------------------

invariant asyncio_extra274.Condition.name:
  description: "asyncio.Condition.__name__ == 'Condition'"
  category: identity
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant asyncio_extra274.Condition.module:
  description: "asyncio.Condition.__module__ == 'asyncio.locks'"
  category: identity
  kind: python_call_eq
  function: Condition.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra274.Condition.bases0_name:
  description: "asyncio.Condition.__bases__[0].__name__ == '_ContextManagerMixin'"
  category: identity
  kind: python_call_eq
  function: "Condition.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

invariant asyncio_extra274.Condition.wait_qualname:
  description: "asyncio.Condition.wait.__qualname__ == 'Condition.wait'"
  category: identity
  kind: python_call_eq
  function: Condition.wait.__qualname__.__eq__
  args: ["Condition.wait"]
  expected: true

invariant asyncio_extra274.Condition.notify_qualname:
  description: "asyncio.Condition.notify.__qualname__ == 'Condition.notify'"
  category: identity
  kind: python_call_eq
  function: Condition.notify.__qualname__.__eq__
  args: ["Condition.notify"]
  expected: true

invariant asyncio_extra274.Condition.notify_all_name:
  description: "asyncio.Condition.notify_all.__name__ == 'notify_all'"
  category: identity
  kind: python_call_eq
  function: Condition.notify_all.__name__.__eq__
  args: ["notify_all"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.BoundedSemaphore — name, module, and base class
#
# BoundedSemaphore inherits directly from Semaphore, not from _ContextManagerMixin.
# ---------------------------------------------------------------------------

invariant asyncio_extra274.BoundedSemaphore.name:
  description: "asyncio.BoundedSemaphore.__name__ == 'BoundedSemaphore'"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant asyncio_extra274.BoundedSemaphore.module:
  description: "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks'"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra274.BoundedSemaphore.bases0_name:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'"
  category: identity
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.Semaphore method __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant asyncio_extra274.Semaphore.acquire_qualname:
  description: "asyncio.Semaphore.acquire.__qualname__ == 'Semaphore.acquire'"
  category: identity
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__eq__
  args: ["Semaphore.acquire"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.Event method __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant asyncio_extra274.Event.wait_qualname:
  description: "asyncio.Event.wait.__qualname__ == 'Event.wait'"
  category: identity
  kind: python_call_eq
  function: Event.wait.__qualname__.__eq__
  args: ["Event.wait"]
  expected: true

invariant asyncio_extra274.Event.set_qualname:
  description: "asyncio.Event.set.__qualname__ == 'Event.set'"
  category: identity
  kind: python_call_eq
  function: Event.set.__qualname__.__eq__
  args: ["Event.set"]
  expected: true

invariant asyncio_extra274.Event.is_set_qualname:
  description: "asyncio.Event.is_set.__qualname__ == 'Event.is_set'"
  category: identity
  kind: python_call_eq
  function: Event.is_set.__qualname__.__eq__
