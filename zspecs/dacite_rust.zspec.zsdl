spec: dacite_rust
version: ">=3.9"
backend: rust_module(dacite_rust)

docs: https://github.com/konradhalas/dacite

provenance:
  derived_from:
    - "https://github.com/konradhalas/dacite — dacite documentation"
  not_derived_from:
    - "dacite source: dacite/core.py"
  notes:
    - "dacite simplifies creation of data classes from dicts."
    - "@dataclass class Point: x: int; y: int."
    - "dacite.from_dict(Point, {'x': 1, 'y': 2}).x == 1."
    - "dacite.from_dict(Point, {'x': 3, 'y': 4}).y == 4."
    - "Expose dacite_from_dict_x(d) -> int: dacite.from_dict(Point, d).x."
    - "Expose dacite_from_dict_y(d) -> int: dacite.from_dict(Point, d).y."
    - "All test vectors verified against dacite 1.8.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# dacite_from_dict_x — x field via from_dict
table dacite_rust.from_dict.x_field:
  kind: python_call_eq
  category: x_field
  id_prefix: dac_x
  function: dacite_from_dict_x

  columns: [id, args, expected]
  rows:
    - [one,   [{"x": 1, "y": 2}], 1]
    - [three, [{"x": 3, "y": 4}], 3]

# dacite_from_dict_y — y field via from_dict
table dacite_rust.from_dict.y_field:
  kind: python_call_eq
  category: y_field
  id_prefix: dac_y
  function: dacite_from_dict_y

  columns: [id, args, expected]
  rows:
    - [two,  [{"x": 1, "y": 2}], 2]
    - [four, [{"x": 3, "y": 4}], 4]

