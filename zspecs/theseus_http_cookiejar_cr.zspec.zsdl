spec: theseus_http_cookiejar_cr
version: ">=3.8"
backend: python_cleanroom(theseus_http_cookiejar_cr)
blocks: http.cookiejar

docs: https://docs.python.org/3/library/http.cookiejar.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/http.cookiejar.html"
  not_derived_from:
    - "CPython source: Lib/http/cookiejar.py"
  notes:
    - "Clean-room http.cookiejar module. Do NOT import http.cookiejar."
    - "CookieJar, FileCookieJar, Cookie, DefaultCookiePolicy."

error_model: python_exceptions

invariant theseus_http_cookiejar_cr.cookiejar2_create:
  description: "CookieJar can be created and is empty initially"
  category: creation
  kind: python_call_eq
  function: cookiejar2_create
  args: []
  expected: true

invariant theseus_http_cookiejar_cr.cookiejar2_cookie:
  description: "Cookie object can be created with required attributes"
  category: creation
  kind: python_call_eq
  function: cookiejar2_cookie
  args: []
  expected: true

invariant theseus_http_cookiejar_cr.cookiejar2_set_cookie:
  description: "CookieJar.set_cookie adds cookie to jar"
  category: behavior
  kind: python_call_eq
  function: cookiejar2_set_cookie
  args: []
  expected: true
