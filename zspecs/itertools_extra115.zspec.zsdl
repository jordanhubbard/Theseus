spec: itertools_extra115
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra114.zspec.zsdl."
    - "This spec covers: itertools.combinations_with_replacement and itertools.pairwise C-extension type attributes not yet covered — __bases__[0].__name__, __basicsize__, __bases__.__len__(), __qualname__.__len__() for both types; wave 266."
    - "itertools.combinations_with_replacement.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__basicsize__ == 56. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__bases__.__len__() == 1. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__qualname__.__len__() == 29. Verified with Python 3.14.3."
    - "itertools.pairwise.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "itertools.pairwise.__basicsize__ == 40. Verified with Python 3.14.3."
    - "itertools.pairwise.__bases__.__len__() == 1. Verified with Python 3.14.3."
    - "itertools.pairwise.__qualname__.__len__() == 8. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.combinations_with_replacement C-extension type bases
#
# Wave 266 theme: itertools.combinations_with_replacement is a C-extension
# type defined in Modules/itertoolsmodule.c. It directly inherits from
# object (__bases__ has exactly one entry: object). The __basicsize__ is 56
# bytes, reflecting the C struct for the combinations_with_replacement iterator
# state. The __qualname__ matches __name__ for a module-level C type and has
# length 29 — the longest itertools type name.
#
# combinations_with_replacement.__bases__[0].__name__ == 'object'
# combinations_with_replacement.__bases__.__len__() == 1
# combinations_with_replacement.__basicsize__ == 56
# combinations_with_replacement.__qualname__.__len__() == 29
#
# Previously covered: __name__, __qualname__, __module__, __name__.__len__,
# __qualname__.__len__ (sort of), __mro__.__len__, __sizeof__.__qualname__.__len__,
# __init__.__class__.__name__, __new__.__class__.__name__.
# New to extra115: __bases__[0].__name__, __bases__.__len__, __basicsize__.
# ---------------------------------------------------------------------------

table itertools_extra115.combinations_with_replacement_bases:
  description: "itertools.combinations_with_replacement C-extension type: __bases__[0].__name__='object', __bases__ len=1, __basicsize__=56, __qualname__ len=29; single-parent C type; wave 266; new to extra115"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolscwrb115

  columns: [id, function, args, expected, description]
  rows:
    - [cwr_bases0_name,
       "combinations_with_replacement.__bases__.__getitem__",
       [0],
       "object",
       "itertools.combinations_with_replacement.__bases__[0].__name__ == 'object' — C-extension types that do not inherit from a custom base directly inherit from object; tuple.__getitem__(0).__name__ returns 'object'; new to extra115"]
    - [cwr_bases_len,
       "combinations_with_replacement.__bases__.__len__",
       [],
       1,
       "itertools.combinations_with_replacement.__bases__.__len__() == 1 — the type has exactly one direct base class (object); tuple.__len__() returns 1; new to extra115"]
    - [cwr_basicsize,
       "combinations_with_replacement.__basicsize__.__eq__",
       [56],
       true,
       "itertools.combinations_with_replacement.__basicsize__.__eq__(56) == True — the C struct for the cwr iterator state occupies 56 bytes; int.__eq__(56) returns True; new to extra115"]
    - [cwr_qualname_len,
       "combinations_with_replacement.__qualname__.__len__",
       [],
       29,
       "itertools.combinations_with_replacement.__qualname__.__len__() == 29 — 'combinations_with_replacement' has 29 chars; the longest name among itertools types; str.__len__() returns 29; new to extra115"]
    - [cwr_name_len,
       "combinations_with_replacement.__name__.__len__",
       [],
       29,
       "itertools.combinations_with_replacement.__name__.__len__() == 29 — __name__ and __qualname__ are equal for a module-level C type; both are 29 chars; str.__len__() returns 29; new to extra115"]

# ---------------------------------------------------------------------------
# Table 2: itertools.pairwise C-extension type bases and basicsize
#
# Wave 266 theme: itertools.pairwise was added in Python 3.10. It is a
# C-extension type that also directly inherits from object. Its __basicsize__
# is 40 bytes — smaller than combinations_with_replacement (56), reflecting
# simpler internal state (just the previous element). The __qualname__ length
# is 8 (matching __name__ 'pairwise'). __bases__ has one entry.
#
# pairwise.__bases__[0].__name__ == 'object'
# pairwise.__bases__.__len__() == 1
# pairwise.__basicsize__ == 40
# pairwise.__qualname__.__len__() == 8
#
# Previously covered: __name__, __qualname__, __module__, __mro__.__len__,
# __name__.__len__, __init__.__class__.__name__, __new__.__qualname__.
# New to extra115: __bases__[0].__name__, __bases__.__len__, __basicsize__.
# ---------------------------------------------------------------------------

table itertools_extra115.pairwise_bases:
  description: "itertools.pairwise C-extension type: __bases__[0].__name__='object', __bases__ len=1, __basicsize__=40, __qualname__ len=8; Python 3.10+ type; smaller footprint than cwr; wave 266; new to extra115"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolspwb115

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise_bases0_name,
       "pairwise.__bases__.__getitem__",
       [0],
       "object",
       "itertools.pairwise.__bases__[0].__name__ == 'object' — pairwise directly inherits from object; tuple.__getitem__(0).__name__ returns 'object'; new to extra115"]
    - [pairwise_bases_len,
       "pairwise.__bases__.__len__",
       [],
       1,
       "itertools.pairwise.__bases__.__len__() == 1 — pairwise has exactly one direct base class (object); tuple.__len__() returns 1; new to extra115"]
    - [pairwise_basicsize,
       "pairwise.__basicsize__.__eq__",
       [40],
       true,
       "itertools.pairwise.__basicsize__.__eq__(40) == True — the C struct for the pairwise iterator occupies 40 bytes; smaller than combinations_with_replacement (56); int.__eq__(40) returns True; new to extra115"]
    - [pairwise_qualname_len,
       "pairwise.__qualname__.__len__",
       [],
       8,
       "itertools.pairwise.__qualname__.__len__() == 8 — 'pairwise' has 8 chars: p-a-i-r-w-i-s-e; str.__len__() returns 8; new to extra115"]
    - [pairwise_module_eq,
       "pairwise.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.pairwise.__module__.__eq__('itertools') == True — pairwise is defined in the itertools module; str.__eq__('itertools') returns True; new to extra115"]

# ---------------------------------------------------------------------------
# Table 3: Comparing combinations_with_replacement and pairwise sizes
#
# Wave 266 theme: Both combinations_with_replacement and pairwise inherit
# directly from object (bases length 1). Their __basicsize__ values differ:
# 56 vs 40. The __mro__ length for both is 2 (the type itself + object).
# combinations_with_replacement has a much longer __name__ (29 chars) compared
# to pairwise (8 chars). Both have __module__ == 'itertools'.
#
# combinations_with_replacement.__mro__.__len__() == 2  (already covered)
# pairwise.__mro__.__len__() == 2  (already covered)
# Both __bases__.__len__() == 1
# cwr.__basicsize__ == 56  vs  pairwise.__basicsize__ == 40
#
# New to extra115: cwr.__bases__.__len__ and pairwise.__bases__.__len__
# together; cwr and pairwise module name lengths.
# ---------------------------------------------------------------------------

table itertools_extra115.cwr_pairwise_comparison:
  description: "combinations_with_replacement vs pairwise: both bases len=1, cwr basicsize=56 > pairwise basicsize=40, cwr name len=29 vs pairwise name len=8; both module='itertools'; wave 266; new to extra115"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolscpc115

  columns: [id, function, args, expected, description]
  rows:
    - [cwr_bases_len_1,
       "combinations_with_replacement.__bases__.__len__",
       [],
       1,
       "itertools.combinations_with_replacement.__bases__.__len__() == 1 — single direct base class; tuple.__len__() returns 1; new to extra115"]
    - [pairwise_bases_len_1,
       "pairwise.__bases__.__len__",
       [],
       1,
       "itertools.pairwise.__bases__.__len__() == 1 — single direct base class; tuple.__len__() returns 1; new to extra115"]
    - [cwr_module_len,
       "combinations_with_replacement.__module__.__len__",
       [],
       9,
       "itertools.combinations_with_replacement.__module__.__len__() == 9 — 'itertools' has 9 chars: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; new to extra115"]
    - [pairwise_module_len,
       "pairwise.__module__.__len__",
       [],
       9,
       "itertools.pairwise.__module__.__len__() == 9 — 'itertools' has 9 chars; same as combinations_with_replacement.__module__.__len__(); str.__len__() returns 9; new to extra115"]
    - [cwr_basicsize_gt_pairwise,
       "combinations_with_replacement.__basicsize__.__eq__",
       [56],
       true,
       "itertools.combinations_with_replacement.__basicsize__.__eq__(56) == True — cwr stores more internal state (56 bytes) than pairwise (40 bytes); int.__eq__(56) returns True; new to extra115"]
    - [pairwise_basicsize_40,
       "pairwise.__basicsize__.__eq__",
       [40],
       true,
       "itertools.pairwise.__basicsize__.__eq__(40) == True — pairwise stores the previous element in a simpler 40-byte struct; int.__eq__(40) returns True; new to extra115"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra115
# ---------------------------------------------------------------------------

invariant itertools_extra115.cwr_bases0_name:
  description: "itertools.combinations_with_replacement.__bases__[0].__name__ == 'object' — C-extension type inherits directly from object; wave 266; new to extra115"
  kind: python_call_eq
  function: "combinations_with_replacement.__bases__.__getitem__"
  args: [0]
  expected: "object"

invariant itertools_extra115.pairwise_basicsize:
  description: "itertools.pairwise.__basicsize__ == 40 — pairwise iterator C struct occupies 40 bytes; smaller than cwr (56); wave 266; new to extra115"
  kind: python_call_eq
  function: pairwise.__basicsize__.__eq__
  args: [40]
  expected: true

invariant itertools_extra115.cwr_basicsize:
  description: "itertools.combinations_with_replacement.__basicsize__ == 56 — cwr iterator C struct occupies 56 bytes; larger than pairwise (40); wave 266; new to extra115"
  kind: python_call_eq
  function: combinations_with_replacement.__basicsize__.__eq__
  args: [56]
  expected: true

invariant itertools_extra115.cwr_qualname_len:
  description: "len(itertools.combinations_with_replacement.__qualname__) == 29 — longest itertools type name; 29 chars; wave 266; new to extra115"
  kind: python_call_eq
  function: combinations_with_replacement.__qualname__.__len__
  args: []
  expected: 29

invariant itertools_extra115.pairwise_qualname_len:
  description: "len(itertools.pairwise.__qualname__) == 8 — 'pairwise' has 8 chars; wave 266; new to extra115"
  kind: python_call_eq
  function: pairwise.__qualname__.__len__
  args: []
  expected: 8
