spec: re_extra348
version: ">=3.7"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern and re.Match class identity — __qualname__ attributes
# ---------------------------------------------------------------------------

invariant re.Pattern.qualname:
  description: "re.Pattern.__qualname__ == 'Pattern'"
  category: class_metadata
  kind: python_call_eq
  function: Pattern.__qualname__.__eq__
  args: ["Pattern"]
  expected: true

invariant re.Match.qualname:
  description: "re.Match.__qualname__ == 'Match'"
  category: class_metadata
  kind: python_call_eq
  function: Match.__qualname__.__eq__
  args: ["Match"]
  expected: true

invariant re.Pattern.match.qualname:
  description: "re.Pattern.match.__qualname__ == 'Pattern.match'"
  category: class_metadata
  kind: python_call_eq
  function: Pattern.match.__qualname__.__eq__
  args: ["Pattern.match"]
  expected: true

invariant re.Pattern.search.qualname:
  description: "re.Pattern.search.__qualname__ == 'Pattern.search'"
  category: class_metadata
  kind: python_call_eq
  function: Pattern.search.__qualname__.__eq__
  args: ["Pattern.search"]
  expected: true

invariant re.Pattern.findall.qualname:
  description: "re.Pattern.findall.__qualname__ == 'Pattern.findall'"
  category: class_metadata
  kind: python_call_eq
  function: Pattern.findall.__qualname__.__eq__
  args: ["Pattern.findall"]
  expected: true

invariant re.Pattern.sub.qualname:
  description: "re.Pattern.sub.__qualname__ == 'Pattern.sub'"
  category: class_metadata
  kind: python_call_eq
  function: Pattern.sub.__qualname__.__eq__
  args: ["Pattern.sub"]
  expected: true

invariant re.Pattern.split.qualname:
  description: "re.Pattern.split.__qualname__ == 'Pattern.split'"
  category: class_metadata
  kind: python_call_eq
  function: Pattern.split.__qualname__.__eq__
  args: ["Pattern.split"]
  expected: true

invariant re.Pattern.finditer.qualname:
  description: "re.Pattern.finditer.__qualname__ == 'Pattern.finditer'"
  category: class_metadata
  kind: python_call_eq
  function: Pattern.finditer.__qualname__.__eq__
  args: ["Pattern.finditer"]
  expected: true
