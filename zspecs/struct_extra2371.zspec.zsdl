spec: struct_extra2371
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2371 (_extra2371): __class__.__name__ of module-level objects."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct and struct.error are Python type objects; __class__.__name__ == 'type'."
    - "struct.pack, unpack, pack_into, unpack_from, iter_unpack, calcsize are C-level builtin functions; __class__.__name__ == 'builtin_function_or_method'."
  created_at: "2026-04-12"

table struct_extra2371.object_types:
  description: "struct module-level object type classification via __class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: st2371
  columns: [id, function, args, expected]
  rows:
    - ["st2371001", "struct.Struct.__class__.__name__", [], "type"]
    - ["st2371002", "struct.error.__class__.__name__", [], "type"]
    - ["st2371003", "struct.pack.__class__.__name__", [], "builtin_function_or_method"]
    - ["st2371004", "struct.unpack.__class__.__name__", [], "builtin_function_or_method"]
    - ["st2371005", "struct.pack_into.__class__.__name__", [], "builtin_function_or_method"]
    - ["st2371006", "struct.unpack_from.__class__.__name__", [], "builtin_function_or_method"]
    - ["st2371007", "struct.iter_unpack.__class__.__name__", [], "builtin_function_or_method"]
    - ["st2371008", "struct.calcsize.__class__.__name__", [], "builtin_function_or_method"]

table struct_extra2371.type_eq_checks:
  description: "struct type objects: confirm __class__.__name__ == 'type' via equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: st2371
  columns: [id, function, args, expected]
  rows:
    - ["st2371009", "struct.Struct.__class__.__name__.__eq__", ["type"], true]
    - ["st2371010", "struct.error.__class__.__name__.__eq__", ["type"], true]

table struct_extra2371.builtin_eq_checks:
  description: "struct builtin functions: confirm __class__.__name__ == 'builtin_function_or_method' via equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: st2371
  columns: [id, function, args, expected]
  rows:
    - ["st2371011", "struct.pack.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st2371012", "struct.unpack.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st2371013", "struct.pack_into.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st2371014", "struct.unpack_from.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st2371015", "struct.iter_unpack.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["st2371016", "struct.calcsize.__class__.__name__.__eq__", ["builtin_function_or_method"], true]

table struct_extra2371.module_name_checks:
  description: "struct type objects have expected __module__ and __name__ attributes"
  kind: python_call_eq
  category: type_identity
  id_prefix: st2371
  columns: [id, function, args, expected]
  rows:
    - ["st2371017", "struct.Struct.__name__.__eq__", ["Struct"], true]
    - ["st2371018", "struct.error.__name__.__eq__", ["error"], true]
    - ["st2371019", "struct.Struct.__module__.__eq__", ["struct"], true]
    - ["st2371020", "struct.error.__module__.__eq__", ["struct"], true]
