spec: theseus_smtplib_cr
version: ">=3.8"
backend: python_cleanroom(theseus_smtplib_cr)
blocks: smtplib

docs: https://docs.python.org/3/library/smtplib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/smtplib.html"
  not_derived_from:
    - "CPython source: Lib/smtplib.py"
  notes:
    - "Clean-room smtplib module. Do NOT import smtplib."
    - "SMTP client with exception classes."

error_model: python_exceptions

invariant theseus_smtplib_cr.smtplib2_exceptions:
  description: "smtplib exception classes exist and inherit correctly"
  category: exceptions
  kind: python_call_eq
  function: smtplib2_exceptions
  args: []
  expected: true

invariant theseus_smtplib_cr.smtplib2_quoteaddr:
  description: "quoteaddr wraps email address in angle brackets"
  category: formatting
  kind: python_call_eq
  function: smtplib2_quoteaddr
  args: []
  expected: true

invariant theseus_smtplib_cr.smtplib2_quotedata:
  description: "quotedata doubles leading dots in SMTP data"
  category: formatting
  kind: python_call_eq
  function: smtplib2_quotedata
  args: []
  expected: true
