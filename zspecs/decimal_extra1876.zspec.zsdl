    - ["dc1876-ip-005", "decimal.DecimalException.__dict__.__contains__", ["__dir__"], false]
    - ["dc1876-ip-006", "decimal.Decimal.__dict__.__contains__", ["__slots__"], false]
    - ["dc1876-ip-007", "decimal.Context.__dict__.__contains__", ["__slots__"], false]
    - ["dc1876-ip-008", "decimal.DecimalException.__dict__.__contains__", ["__slots__"], false]

