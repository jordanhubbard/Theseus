spec: decimal_extra1876
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "decimal module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party decimal extensions"
  notes:
    - "Tests attribute access protocol membership in decimal types"
    - "decimal.Decimal and decimal.Context are C types; __getattr__/__setattr__/__delattr__ are not in their __dict__"
    - "decimal.Decimal.__dict__ contains to_eng_string, to_integral, to_integral_value, to_integral_exact, normalize, quantize, same_quantum and related methods"
  created_at: "2026-04-12"

table decimal_extra1876.attr_access_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["dc1876-aa-001", "decimal.Decimal.__dict__.__contains__", ["__getattr__"], false]
    - ["dc1876-aa-002", "decimal.Decimal.__dict__.__contains__", ["__setattr__"], false]
    - ["dc1876-aa-003", "decimal.Decimal.__dict__.__contains__", ["__delattr__"], false]
    - ["dc1876-aa-004", "decimal.Decimal.__dict__.__contains__", ["__getattribute__"], false]
    - ["dc1876-aa-005", "decimal.Context.__dict__.__contains__", ["__getattr__"], false]
    - ["dc1876-aa-006", "decimal.Context.__dict__.__contains__", ["__setattr__"], false]
    - ["dc1876-aa-007", "decimal.Context.__dict__.__contains__", ["__getattribute__"], false]
    - ["dc1876-aa-008", "decimal.DecimalException.__dict__.__contains__", ["__getattr__"], false]

