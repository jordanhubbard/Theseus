spec: pathlib_extra1396
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 540 (_extra1396): focuses on __class_getitem__ and __init_subclass__ method checks for pathlib module classes."
    - "None of the pathlib path classes (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath) have '__class_getitem__' in their own __dict__; the attribute is not present via inheritance either (object does not define __class_getitem__)."
    - "None of the pathlib path classes have '__init_subclass__' in their own __dict__; all inherit __init_subclass__ from object; the inherited __init_subclass__.__class__.__name__ is 'builtin_function_or_method' for all pathlib classes; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "pathlib.PurePath.__dict__.__contains__('__class_getitem__') == False and pathlib.PurePath.__dict__.__contains__('__init_subclass__') == False for all five path classes; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1396.purepath_classes_no_class_getitem:
  description: "pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath __dict__ lacks __class_getitem__ — wave 540 theme: none of the three pure-path classes have '__class_getitem__' in their own __dict__; pure path classes are pure-Python and do not define __class_getitem__; verified with Python 3.12"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: pl1396pp
  columns: [id, function, args, expected, description]
  rows:
    - [pl1396pp001, pathlib.PurePath.__dict__.__contains__,          ["__class_getitem__"], false, "pathlib.PurePath.__dict__.__contains__('__class_getitem__') == False (PurePath has no __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [pl1396pp002, pathlib.PurePosixPath.__dict__.__contains__,     ["__class_getitem__"], false, "pathlib.PurePosixPath.__dict__.__contains__('__class_getitem__') == False (PurePosixPath has no __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [pl1396pp003, pathlib.PureWindowsPath.__dict__.__contains__,   ["__class_getitem__"], false, "pathlib.PureWindowsPath.__dict__.__contains__('__class_getitem__') == False (PureWindowsPath has no __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [pl1396pp004, pathlib.PurePath.__dict__.__contains__,          ["__class_getitem__"], false, "pathlib.PurePath.__dict__.__contains__('__class_getitem__') == False (cross-check anchor: base pure-path class absent); verified with Python 3.12"]
    - [pl1396pp005, pathlib.PurePosixPath.__dict__.__contains__,     ["__class_getitem__"], false, "pathlib.PurePosixPath.__dict__.__contains__('__class_getitem__') == False (cross-check: POSIX pure-path class absent); verified with Python 3.12"]
    - [pl1396pp006, pathlib.PureWindowsPath.__dict__.__contains__,   ["__class_getitem__"], false, "pathlib.PureWindowsPath.__dict__.__contains__('__class_getitem__') == False (cross-check: Windows pure-path class absent); verified with Python 3.12"]
    - [pl1396pp007, pathlib.PurePath.__dict__.__contains__,          ["__init_subclass__"], false, "pathlib.PurePath.__dict__.__contains__('__init_subclass__') == False (cross-check: __init_subclass__ also absent from dict for PurePath); verified with Python 3.12"]

table pathlib_extra1396.path_classes_no_class_getitem:
  description: "pathlib.Path and pathlib.PosixPath __dict__ lacks __class_getitem__ — wave 540 theme: neither of the concrete path classes has '__class_getitem__' in its own __dict__; consistent with the pure-path hierarchy; all five pathlib path classes uniformly lack this method; verified with Python 3.12"
  kind: python_call_eq
  category: class_getitem_checks
  id_prefix: pl1396ph
  columns: [id, function, args, expected, description]
  rows:
    - [pl1396ph001, pathlib.Path.__dict__.__contains__,       ["__class_getitem__"], false, "pathlib.Path.__dict__.__contains__('__class_getitem__') == False (Path has no __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [pl1396ph002, pathlib.PosixPath.__dict__.__contains__,  ["__class_getitem__"], false, "pathlib.PosixPath.__dict__.__contains__('__class_getitem__') == False (PosixPath has no __class_getitem__ in own __dict__); verified with Python 3.12"]
    - [pl1396ph003, pathlib.Path.__dict__.__contains__,       ["__class_getitem__"], false, "pathlib.Path.__dict__.__contains__('__class_getitem__') == False (cross-check: concrete Path class absent); verified with Python 3.12"]
    - [pl1396ph004, pathlib.PosixPath.__dict__.__contains__,  ["__class_getitem__"], false, "pathlib.PosixPath.__dict__.__contains__('__class_getitem__') == False (cross-check: concrete PosixPath class absent); verified with Python 3.12"]
    - [pl1396ph005, pathlib.Path.__dict__.__contains__,       ["__init_subclass__"], false, "pathlib.Path.__dict__.__contains__('__init_subclass__') == False (cross-check: __init_subclass__ also absent from dict for Path); verified with Python 3.12"]
    - [pl1396ph006, pathlib.PosixPath.__dict__.__contains__,  ["__init_subclass__"], false, "pathlib.PosixPath.__dict__.__contains__('__init_subclass__') == False (cross-check: __init_subclass__ also absent from dict for PosixPath); verified with Python 3.12"]
    - [pl1396ph007, pathlib.PurePath.__dict__.__contains__,   ["__class_getitem__"], false, "pathlib.PurePath.__dict__.__contains__('__class_getitem__') == False (final cross-check: all five pathlib path classes uniformly lack __class_getitem__); verified with Python 3.12"]

table pathlib_extra1396.all_classes_init_subclass_type:
  description: "All pathlib path classes __init_subclass__ type check — wave 540 theme: all five pathlib path classes inherit __init_subclass__ from object; the inherited method's __class__.__name__ is 'builtin_function_or_method' for every path class; none register __init_subclass__ in their own __dict__; verified with Python 3.12"
  kind: python_call_eq
  category: init_subclass_checks
  id_prefix: pl1396is
  columns: [id, function, args, expected, description]
  rows:
    - [pl1396is001, pathlib.PurePath.__init_subclass__.__class__.__name__.__eq__,        ["builtin_function_or_method"], true, "pathlib.PurePath.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [pl1396is002, pathlib.PurePosixPath.__init_subclass__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true, "pathlib.PurePosixPath.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [pl1396is003, pathlib.PureWindowsPath.__init_subclass__.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "pathlib.PureWindowsPath.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [pl1396is004, pathlib.Path.__init_subclass__.__class__.__name__.__eq__,            ["builtin_function_or_method"], true, "pathlib.Path.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [pl1396is005, pathlib.PosixPath.__init_subclass__.__class__.__name__.__eq__,       ["builtin_function_or_method"], true, "pathlib.PosixPath.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (inherited from object); verified with Python 3.12"]
    - [pl1396is006, pathlib.PurePath.__dict__.__contains__,       ["__init_subclass__"], false, "pathlib.PurePath.__dict__.__contains__('__init_subclass__') == False (inherited not owned by PurePath); verified with Python 3.12"]
    - [pl1396is007, pathlib.Path.__dict__.__contains__,           ["__init_subclass__"], false, "pathlib.Path.__dict__.__contains__('__init_subclass__') == False (inherited not owned by Path); verified with Python 3.12"]
    - [pl1396is008, pathlib.PosixPath.__dict__.__contains__,      ["__init_subclass__"], false, "pathlib.PosixPath.__dict__.__contains__('__init_subclass__') == False (inherited not owned by PosixPath); verified with Python 3.12"]
