provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Checks multiprocessing.Process, multiprocessing.pool.Pool, multiprocessing.pool.AsyncResult __dict__ for __contains__, __add__, __mul__ presence (all false)"]
  created_at: "2026-04-13"
error_model: python_exceptions

table multiprocessing_extra2656.process_dict_presence:
  description: "multiprocessing.Process __dict__ does not contain __contains__, __add__, __mul__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: mp2656pd
  columns: [id, function, args, expected]
  rows:
    - ["mp2656pd001", multiprocessing.Process.__dict__.__contains__, ["__contains__"], false]
    - ["mp2656pd002", multiprocessing.Process.__dict__.__contains__, ["__add__"], false]
    - ["mp2656pd003", multiprocessing.Process.__dict__.__contains__, ["__mul__"], false]

