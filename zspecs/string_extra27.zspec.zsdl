spec: string_extra27
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/string.py"
    - "string_extra26.zspec.zsdl — covers Template/Formatter __module__.__len__()/__name__.__len__()/__qualname__.__len__(); capwords.__module__/__qualname__/__module__.__len__()/__name__.__len__(); Template.substitute/__qualname__, Template.safe_substitute/__qualname__."
  notes:
    - "This spec extends string_extra26.zspec.zsdl."
    - "Prior specs covered: Template/__name__/__module__/__qualname__/__module__.__len__()/__name__.__len__()/__qualname__.__len__(), Formatter/__name__/__module__/__qualname__/__module__.__len__()/__name__.__len__()/__qualname__.__len__(), capwords/__name__/__module__/__qualname__/__module__.__len__()/__name__.__len__(), Template/Formatter __bases__[0].__name__, Template.substitute/safe_substitute/__name__/__qualname__, Template.flags==None, Formatter method __name__ and __qualname__ (format/vformat/parse/get_field/get_value/check_unused_args/format_field/convert_field), Template.__init__.__name__/__qualname__."
    - "This spec covers: string.Formatter.format.__qualname__.__len__(); string.Formatter.vformat.__qualname__.__len__(); string.Formatter.parse.__qualname__.__len__(); string.Formatter.get_field.__qualname__.__len__(); string.Formatter.format_field.__qualname__.__len__(); string.Formatter.convert_field.__qualname__.__len__(); string.Formatter.check_unused_args.__qualname__.__len__(); string.Formatter.get_value.__qualname__.__len__(); string.Template.substitute.__qualname__.__len__(); string.Template.safe_substitute.__qualname__.__len__(); string.capwords.__qualname__.__len__()."
    - "string.Formatter.format.__qualname__ == 'Formatter.format' — len 16. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "string.Formatter.vformat.__qualname__ == 'Formatter.vformat' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "string.Formatter.parse.__qualname__ == 'Formatter.parse' — len 15. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "string.Formatter.get_field.__qualname__ == 'Formatter.get_field' — len 19. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "string.Formatter.format_field.__qualname__ == 'Formatter.format_field' — len 22. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "string.Formatter.convert_field.__qualname__ == 'Formatter.convert_field' — len 23. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "string.Formatter.check_unused_args.__qualname__ == 'Formatter.check_unused_args' — len 27. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "string.Formatter.get_value.__qualname__ == 'Formatter.get_value' — len 19. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "string.Template.substitute.__qualname__ == 'Template.substitute' — len 19. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "string.Template.safe_substitute.__qualname__ == 'Template.safe_substitute' — len 24. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "string.capwords.__qualname__ == 'capwords' — len 8. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# string.Formatter method __qualname__.__len__() values
#
# Prior specs verify __qualname__.__eq__ for Formatter methods. No prior spec
# checks __qualname__.__len__() for any Formatter method.
# format(16), vformat(17), parse(15), get_field(19), format_field(22),
# convert_field(23).
# ---------------------------------------------------------------------------

table string_extra27.Formatter_method_qualname_lengths_a:
  description: "string.Formatter method __qualname__.__len__() — format/vformat/parse/get_field"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fmqla27

  columns: [id, function, args, expected, description]
  rows:
    - [format,
       Formatter.format.__qualname__.__len__,
       [],
       16,
       "len('Formatter.format') == 16"]
    - [vformat,
       Formatter.vformat.__qualname__.__len__,
       [],
       17,
       "len('Formatter.vformat') == 17"]
    - [parse,
       Formatter.parse.__qualname__.__len__,
       [],
       15,
       "len('Formatter.parse') == 15"]
    - [get_field,
       Formatter.get_field.__qualname__.__len__,
       [],
       19,
       "len('Formatter.get_field') == 19"]

table string_extra27.Formatter_method_qualname_lengths_b:
  description: "string.Formatter method __qualname__.__len__() — format_field/convert_field/check_unused_args/get_value"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fmqlb27

  columns: [id, function, args, expected, description]
  rows:
    - [format_field,
       Formatter.format_field.__qualname__.__len__,
       [],
       22,
       "len('Formatter.format_field') == 22"]
    - [convert_field,
       Formatter.convert_field.__qualname__.__len__,
       [],
       23,
       "len('Formatter.convert_field') == 23"]
    - [check_unused_args,
       Formatter.check_unused_args.__qualname__.__len__,
       [],
       27,
       "len('Formatter.check_unused_args') == 27"]
    - [get_value,
       Formatter.get_value.__qualname__.__len__,
       [],
       19,
       "len('Formatter.get_value') == 19"]

# ---------------------------------------------------------------------------
# string.Template method __qualname__.__len__() values
#
# string_extra26 covers Template.substitute/__qualname__.__eq__ and
# safe_substitute/__qualname__.__eq__. No prior spec checks
# __qualname__.__len__() for either.
# substitute.__qualname__ == 'Template.substitute' (len 19);
# safe_substitute.__qualname__ == 'Template.safe_substitute' (len 24).
# ---------------------------------------------------------------------------

invariant string_extra27.Template.substitute_qualname_len:
  description: "len(string.Template.substitute.__qualname__) == 19 — len('Template.substitute') == 19"
  category: function_qualnames
  kind: python_call_eq
  function: Template.substitute.__qualname__.__len__
  args: []
  expected: 19

invariant string_extra27.Template.safe_substitute_qualname_len:
  description: "len(string.Template.safe_substitute.__qualname__) == 24 — len('Template.safe_substitute') == 24"
  category: function_qualnames
  kind: python_call_eq
  function: Template.safe_substitute.__qualname__.__len__
  args: []
  expected: 24

# ---------------------------------------------------------------------------
# string.capwords.__qualname__.__len__()
#
# string_extra26 covers capwords.__qualname__.__eq__('capwords').
# No prior spec checks capwords.__qualname__.__len__().
# capwords.__qualname__ == 'capwords' (len 8).
# ---------------------------------------------------------------------------

invariant string_extra27.capwords.qualname_len:
  description: "len(string.capwords.__qualname__) == 8 — len('capwords') == 8"
  category: function_qualnames
  kind: python_call_eq
  function: capwords.__qualname__.__len__
  args: []
  expected: 8
