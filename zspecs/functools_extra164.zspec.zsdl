# ---------------------------------------------------------------------------
# Table 1: functools.reduce class name and module
#
# Wave 288 theme: functools.reduce identity — class name and module.
#
# functools.reduce.__class__.__name__ == 'builtin_function_or_method'
# functools.reduce.__module__ == '_functools'
#
# functools.reduce is a C builtin function defined in Modules/_functoolsmodule.c.
# It applies a function of two arguments cumulatively to items of an iterable,
# reducing the iterable to a single value. Its class is the C type
# builtin_function_or_method, and its __module__ is '_functools' (the
# underlying C extension module, not the 'functools' Python wrapper). New to
# extra164.
# ---------------------------------------------------------------------------

table functools_extra164.reduce_class_and_module:
  description: "functools.reduce: __class__.__name__ 'builtin_function_or_method', __module__ '_functools'; reduce is a C builtin in _functoolsmodule.c; wave 288; new to extra164"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsredcm164

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_cls_name_eq,
       "reduce.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — reduce is a C builtin function defined in Modules/_functoolsmodule.c; it applies a two-argument function cumulatively to items of an iterable; its __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra164"]
    - [reduce_module_eq_functools_c,
       "reduce.__module__.__eq__",
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in the C extension module _functoolsmodule.c; its __module__ attribute is '_functools' (the underlying C module), not 'functools' (the Python wrapper module); str.__eq__('_functools') returns True; new to extra164"]
    - [reduce_cls_name_class_eq_str,
       "reduce.__class__.__name__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__class__.__name__.__class__.__name__.__eq__('str') == True — the __class__.__name__ attribute of reduce is a str object recording the C type name; __class__.__name__ of that string is 'str'; str.__eq__('str') returns True; new to extra164"]
    - [reduce_module_class_eq_str,
       "reduce.__module__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.reduce.__module__.__class__.__name__.__eq__('str') == True — the __module__ attribute of reduce is a str recording the module where it is defined; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra164"]

# ---------------------------------------------------------------------------
# Table 2: functools.wraps code attributes and WRAPPER_ASSIGNMENTS identity
#
# Wave 288 theme: functools.wraps __code__ attributes and
# functools.WRAPPER_ASSIGNMENTS class and length.
#
# functools.wraps.__code__.co_argcount == 3
# functools.wraps.__code__.co_varnames[0] == 'wrapped'
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# functools.WRAPPER_ASSIGNMENTS.__len__() == 6
#
# functools.wraps(wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES)
# is a decorator factory defined in Lib/functools.py. It takes 3 positional-or-
# keyword arguments; co_argcount is 3 and co_varnames[0] is 'wrapped'. The
# WRAPPER_ASSIGNMENTS constant is a tuple of 6 attribute name strings that wraps
# copies from the wrapped function to the wrapper function. In Python 3.14 the
# tuple contains '__module__', '__name__', '__qualname__', '__doc__',
# '__annotate__', and '__type_params__'. New to extra164.
# ---------------------------------------------------------------------------

