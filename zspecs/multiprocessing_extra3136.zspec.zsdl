spec: mp3136
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 656 (mp3136): __call__, __len__, __getitem__ dict-presence for multiprocessing types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, multiprocessing.pool.Pool, multiprocessing.pool.AsyncResult, multiprocessing.pool.MapResult, multiprocessing.managers.SyncManager, multiprocessing.managers.BaseListProxy, multiprocessing.managers._BaseDictProxy, multiprocessing.managers._BaseSetProxy."
    - "Key finding (__call__): all 8 multiprocessing classes return false for __call__. No class defines __call__ in its own __dict__. multiprocessing.Process exposes start()/join()/run() but is not callable in the Python data-model sense. Pool, AsyncResult, MapResult, and SyncManager are similarly not callable objects. The manager proxy classes forward attribute access to the managed server process but do not define __call__ themselves."
    - "Key finding (__len__): multiprocessing.managers.BaseListProxy defines __len__ (true). multiprocessing.managers._BaseDictProxy defines __len__ (true). multiprocessing.managers._BaseSetProxy defines __len__ (true). These three proxy classes delegate len() to the managed collection in the server process. All other 5 classes return false for __len__."
    - "Key finding (__getitem__): multiprocessing.managers.BaseListProxy defines __getitem__ (true). multiprocessing.managers._BaseDictProxy defines __getitem__ (true). These two proxy classes support index/key access, forwarding [] to the server-side list or dict. multiprocessing.managers._BaseSetProxy does NOT define __getitem__ (false) — sets are not subscriptable. All other 5 classes return false."
    - "The proxy class findings are as expected from collection semantics: list and dict support both len() and []; set supports len() but not []; other types support neither."
    - "multiprocessing.pool.Pool defines __repr__ (confirmed in wave 655) but none of the three methods in this wave — Pool is a task dispatcher, not a collection."
    - "multiprocessing.pool.AsyncResult and MapResult provide poll/wait/get interfaces; they are not collections and define no __len__ or __getitem__."
    - "_BaseSetProxy: __len__ true (sets have a cardinality), __getitem__ false (sets are not subscriptable). This is consistent with Python's set semantics — len(s) works, s[0] raises TypeError."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __call__ dict-presence — operator.contains(Cls.__dict__, '__call__')
#
# All 8 multiprocessing classes return false for __call__.
# multiprocessing.Process: not callable — use start()/run().
# Pool, AsyncResult, MapResult: task dispatch objects, not callables.
# SyncManager: a server process manager, not callable.
# BaseListProxy, _BaseDictProxy, _BaseSetProxy: proxy the managed collection
#   interface but do not define __call__ in their own __dict__.
# ---------------------------------------------------------------------------

table mp3136.call:
  description: "multiprocessing types __call__ dict-presence checks; wave 656"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3136

  columns: [id, function, args, expected]
  rows:
    - ["mp3136001", operator.contains, [multiprocessing.Process.__dict__,                  "__call__"], false]
    - ["mp3136002", operator.contains, [multiprocessing.pool.Pool.__dict__,                "__call__"], false]
    - ["mp3136003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,         "__call__"], false]
    - ["mp3136004", operator.contains, [multiprocessing.pool.MapResult.__dict__,           "__call__"], false]
    - ["mp3136005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,     "__call__"], false]
    - ["mp3136006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,   "__call__"], false]
    - ["mp3136007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__call__"], false]
    - ["mp3136008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__call__"], false]

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# multiprocessing.managers.BaseListProxy: TRUE — proxies len() to the
#   managed list in the server process, enabling len(proxy_list).
# multiprocessing.managers._BaseDictProxy: TRUE — proxies len() to the
#   managed dict in the server process, enabling len(proxy_dict).
# multiprocessing.managers._BaseSetProxy: TRUE — proxies len() to the
#   managed set in the server process, enabling len(proxy_set).
# All other 5 classes: false — Process, Pool, AsyncResult, MapResult,
#   and SyncManager have no sized collection semantics.
# ---------------------------------------------------------------------------

table mp3136.len:
  description: "multiprocessing types __len__ dict-presence checks; wave 656"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3136

  columns: [id, function, args, expected]
  rows:
    - ["mp3136009",  operator.contains, [multiprocessing.Process.__dict__,                  "__len__"], false]
    - ["mp3136010", operator.contains, [multiprocessing.pool.Pool.__dict__,                "__len__"], false]
    - ["mp3136011", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,         "__len__"], false]
    - ["mp3136012", operator.contains, [multiprocessing.pool.MapResult.__dict__,           "__len__"], false]
    - ["mp3136013", operator.contains, [multiprocessing.managers.SyncManager.__dict__,     "__len__"], false]
    - ["mp3136014", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,   "__len__"], true]
    - ["mp3136015", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__len__"], true]
    - ["mp3136016", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__len__"], true]

# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# multiprocessing.managers.BaseListProxy: TRUE — proxies [] access to the
#   managed list in the server process, supporting both index and slice access.
# multiprocessing.managers._BaseDictProxy: TRUE — proxies [] access to the
#   managed dict in the server process, supporting key-based access.
# multiprocessing.managers._BaseSetProxy: FALSE — sets are not subscriptable;
#   _BaseSetProxy defines __len__ but not __getitem__ (consistent with set semantics).
# All other 5 classes: false — no subscript access defined.
# ---------------------------------------------------------------------------

table mp3136.getitem:
  description: "multiprocessing types __getitem__ dict-presence checks; wave 656"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3136

  columns: [id, function, args, expected]
  rows:
    - ["mp3136017", operator.contains, [multiprocessing.Process.__dict__,                  "__getitem__"], false]
    - ["mp3136018", operator.contains, [multiprocessing.pool.Pool.__dict__,                "__getitem__"], false]
    - ["mp3136019", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,         "__getitem__"], false]
    - ["mp3136020", operator.contains, [multiprocessing.pool.MapResult.__dict__,           "__getitem__"], false]
    - ["mp3136021", operator.contains, [multiprocessing.managers.SyncManager.__dict__,     "__getitem__"], false]
    - ["mp3136022", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,   "__getitem__"], true]
    - ["mp3136023", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__getitem__"], true]
    - ["mp3136024", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__getitem__"], false]

# ---------------------------------------------------------------------------
# combined — __call__, __len__, __getitem__ across all 8 multiprocessing subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __call__:    false for all 8 — no callable protocol defined.
# __len__:     true for BaseListProxy, _BaseDictProxy, _BaseSetProxy; false for all others.
# __getitem__: true for BaseListProxy, _BaseDictProxy; false for _BaseSetProxy and all others.
# Key structural insight: the manager proxy classes expose the Python collection protocol
# of their underlying type. List and dict support both len() and subscript; set supports
# only len(). This creates an asymmetry: _BaseSetProxy.__len__=true but __getitem__=false.
# Notable cross-wave patterns for manager proxy classes:
#   Wave 655 (mp3121): __ge__ true for _BaseSetProxy only (set ordering); others false.
#   Wave 656 (mp3136): __len__ true for all 3 proxies; __getitem__ true for list+dict, false for set.
# The proxy pattern faithfully mirrors the standard Python collection interface:
#   - list:   len(), []  — BaseListProxy: __len__=true, __getitem__=true
#   - dict:   len(), []  — _BaseDictProxy: __len__=true, __getitem__=true
#   - set:    len(), no []  — _BaseSetProxy: __len__=true, __getitem__=false
# Cross-wave summary for mp subjects:
#   Wave 652 (mp3076): __get__/__set__/__delete__ — all false for all 8.
#   Wave 653 (mp3091): __hash__/__eq__/__bool__ — all false for all 8.
#   Wave 654 (mp3106): __lt__/__le__/__gt__ — _BaseSetProxy true; others false.
#   Wave 655 (mp3121): __ge__ — _BaseSetProxy true; __repr__ — Pool true; __str__ all false.
#   Wave 656 (mp3136): __call__ all false; __len__ — 3 proxies true; __getitem__ — list+dict proxies true.
# ---------------------------------------------------------------------------

