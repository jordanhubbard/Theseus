spec: subprocess_extra19
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
    - "subprocess_extra.zspec.zsdl — covers PIPE/STDOUT/DEVNULL __class__.__name__ == 'int'; NOT their integer values."
    - "subprocess_extra6.zspec.zsdl — covers __qualname__ for Popen/CompletedProcess/CalledProcessError class-level; NOT __init__/__qualname__ for CompletedProcess/CalledProcessError/TimeoutExpired."
    - "subprocess_extra16.zspec.zsdl — covers __qualname__ for Popen instance methods communicate/wait/poll/kill/terminate/send_signal."
    - "subprocess_extra17.zspec.zsdl — covers Popen.__init__.__qualname__ and Popen.__repr__.__qualname__; PIPE/STDOUT/DEVNULL __class__.__qualname__."
    - "subprocess_extra18.zspec.zsdl — covers __module__ for subprocess classes and functions; exception __bases__[0].__name__."
  notes:
    - "This spec extends subprocess.zspec.zsdl and all prior subprocess_extra specs through subprocess_extra18.zspec.zsdl."
    - "Focus: __init__.__qualname__ for CompletedProcess, CalledProcessError, and TimeoutExpired; and the exact integer values of the PIPE, STDOUT, and DEVNULL sentinel constants."
    - "subprocess.CompletedProcess.__init__.__qualname__ == 'CompletedProcess.__init__' — dotted qualname for dunder constructor; subprocess_extra17 covers only Popen.__init__.__qualname__, not CompletedProcess.__init__.__qualname__."
    - "subprocess.CalledProcessError.__init__.__qualname__ == 'CalledProcessError.__init__' — not covered in any prior subprocess spec."
    - "subprocess.TimeoutExpired.__init__.__qualname__ == 'TimeoutExpired.__init__' — not covered in any prior subprocess spec."
    - "subprocess.PIPE == -1 — PIPE is a sentinel int with value -1; prior specs check its class name and class qualname but no prior spec checks its integer value."
    - "subprocess.STDOUT == -2 — STDOUT sentinel int value; not covered in any prior subprocess spec."
    - "subprocess.DEVNULL == -3 — DEVNULL sentinel int value; not covered in any prior subprocess spec."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# CompletedProcess, CalledProcessError, TimeoutExpired — __init__.__qualname__
#
# subprocess_extra17 covers Popen.__init__.__qualname__ == 'Popen.__init__'.
# No prior subprocess spec covers __init__.__qualname__ for CompletedProcess,
# CalledProcessError, or TimeoutExpired. For methods defined directly on a
# class, __qualname__ takes the form 'ClassName.__init__'.
# ---------------------------------------------------------------------------

table subprocess_extra19.init_qualnames:
  description: "__init__.__qualname__ for subprocess classes (dotted 'ClassName.__init__' form)"
  kind: python_call_eq
  category: function_attrs
  id_prefix: initqn19

  columns: [id, function, args, expected]
  rows:
    - [CompletedProcess,  CompletedProcess.__init__.__qualname__.__eq__,  ["CompletedProcess.__init__"],  true]
    - [CalledProcessError, CalledProcessError.__init__.__qualname__.__eq__, ["CalledProcessError.__init__"], true]
    - [TimeoutExpired,    TimeoutExpired.__init__.__qualname__.__eq__,    ["TimeoutExpired.__init__"],    true]

# ---------------------------------------------------------------------------
# PIPE, STDOUT, DEVNULL — exact integer values
#
# subprocess_extra.zspec.zsdl covers __class__.__name__ == 'int' for PIPE,
# STDOUT, and DEVNULL. subprocess_extra17 covers __class__.__qualname__ == 'int'
# for all three. No prior subprocess spec checks the actual integer values.
# CPython defines: PIPE = -1, STDOUT = -2, DEVNULL = -3. These values are
# part of the stable subprocess API and are consistent across all platforms.
# ---------------------------------------------------------------------------

table subprocess_extra19.sentinel_values:
  description: "PIPE == -1, STDOUT == -2, DEVNULL == -3 — exact integer values of subprocess sentinel constants"
  kind: python_call_eq
  category: constants
  id_prefix: sentinel19

  columns: [id, function, args, expected]
  rows:
    - [PIPE_value,   PIPE.__eq__,   [-1], true]
    - [STDOUT_value, STDOUT.__eq__, [-2], true]
    - [DEVNULL_value, DEVNULL.__eq__, [-3], true]

# ---------------------------------------------------------------------------
# Standalone invariants — __init__.__qualname__
# ---------------------------------------------------------------------------

invariant subprocess_extra19.CompletedProcess.init_qualname:
  description: "subprocess.CompletedProcess.__init__.__qualname__ == 'CompletedProcess.__init__' — dotted qualname for constructor"
  category: function_attrs
  kind: python_call_eq
  function: CompletedProcess.__init__.__qualname__.__eq__
  args: ["CompletedProcess.__init__"]
  expected: true

invariant subprocess_extra19.CalledProcessError.init_qualname:
  description: "subprocess.CalledProcessError.__init__.__qualname__ == 'CalledProcessError.__init__' — dotted qualname for exception constructor"
  category: function_attrs
  kind: python_call_eq
  function: CalledProcessError.__init__.__qualname__.__eq__
  args: ["CalledProcessError.__init__"]
  expected: true

invariant subprocess_extra19.TimeoutExpired.init_qualname:
  description: "subprocess.TimeoutExpired.__init__.__qualname__ == 'TimeoutExpired.__init__' — dotted qualname for exception constructor"
  category: function_attrs
  kind: python_call_eq
  function: TimeoutExpired.__init__.__qualname__.__eq__
  args: ["TimeoutExpired.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — PIPE/STDOUT/DEVNULL integer values
# ---------------------------------------------------------------------------

invariant subprocess_extra19.PIPE.value:
  description: "subprocess.PIPE == -1 — PIPE sentinel constant has integer value -1"
  category: constants
  kind: python_call_eq
  function: PIPE.__eq__
  args: [-1]
  expected: true

invariant subprocess_extra19.STDOUT.value:
  description: "subprocess.STDOUT == -2 — STDOUT sentinel constant has integer value -2"
  category: constants
  kind: python_call_eq
  function: STDOUT.__eq__
  args: [-2]
  expected: true

invariant subprocess_extra19.DEVNULL.value:
  description: "subprocess.DEVNULL == -3 — DEVNULL sentinel constant has integer value -3"
  category: constants
  kind: python_call_eq
  function: DEVNULL.__eq__
  args: [-3]
  expected: true
