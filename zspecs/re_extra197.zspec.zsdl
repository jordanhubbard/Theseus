spec: re_extra197
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers re module structure attributes not covered by prior re_extra specs."
    - "re.__name__ == 're' (len=2); the module's own __name__ attribute; confirmed Python 3.14.3 macOS."
    - "re.__package__ == 're' (len=2); re is a package (has __init__.py); confirmed Python 3.14.3 macOS."
    - "re.__spec__.name == 're' (len=2); ModuleSpec uses .name not .__name__; confirmed Python 3.14.3 macOS."
    - "re.compile.__name__ == 'compile' (len=7); the built-in function name; confirmed Python 3.14.3 macOS."
    - "re.compile.__module__ == 're' (len=2); compile is defined in the re module; confirmed Python 3.14.3 macOS."
    - "re.compile.__qualname__ == 'compile' (len=7); same as __name__ for a module-level function; confirmed Python 3.14.3 macOS."
    - "re.compile.__class__.__name__ == 'function' (len=8); re.compile is a plain Python function; confirmed Python 3.14.3 macOS."
    - "re.NOFLAG.__class__.__name__ == 'RegexFlag' (len=9); NOFLAG is an IntFlag enum member; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re module-level identity — __name__, __package__, __spec__.name
# __name__=='re'(2), __package__=='re'(2), __spec__.name=='re'(2)
# ---------------------------------------------------------------------------

table re_extra197.module_identity:
  description: "re module identity: __name__='re'(2), __package__='re'(2), __spec__.name='re'(2)"
  kind: python_call_eq
  category: identity
  id_prefix: remodule197

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,    re.__name__.__eq__,        ["re"], true, "re.__name__ == 're' (len=2); the module's own __name__ attribute; confirmed Python 3.14.3 macOS"]
    - [module_package_eq, re.__package__.__eq__,     ["re"], true, "re.__package__ == 're' (len=2); re is a package; confirmed Python 3.14.3 macOS"]
    - [spec_name_eq,      re.__spec__.name.__eq__,   ["re"], true, "re.__spec__.name == 're' (len=2); ModuleSpec.name confirms the import name; confirmed Python 3.14.3 macOS"]
    - [module_name_len,   re.__name__.__len__,        [],    2,    "re.__name__.__len__() == 2 — r(1)e(2); confirmed Python 3.14.3 macOS"]
    - [spec_name_len,     re.__spec__.name.__len__,   [],    2,    "re.__spec__.name.__len__() == 2 — r(1)e(2); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.compile function identity
# __name__=='compile'(7), __module__=='re'(2), __qualname__=='compile'(7)
# ---------------------------------------------------------------------------

table re_extra197.compile_identity:
  description: "re.compile function identity: __name__='compile'(7), __module__='re'(2), __qualname__='compile'(7)"
  kind: python_call_eq
  category: identity
  id_prefix: remodule197

  columns: [id, function, args, expected, description]
  rows:
    - [compile_name_eq,     re.compile.__name__.__eq__,         ["compile"], true, "re.compile.__name__ == 'compile' (len=7); the function name; confirmed Python 3.14.3 macOS"]
    - [compile_module_eq,   re.compile.__module__.__eq__,       ["re"],      true, "re.compile.__module__ == 're' (len=2); compile is defined in the re module; confirmed Python 3.14.3 macOS"]
    - [compile_qualname_eq, re.compile.__qualname__.__eq__,     ["compile"], true, "re.compile.__qualname__ == 'compile' (len=7); same as __name__ for a module-level function; confirmed Python 3.14.3 macOS"]
    - [compile_name_len,    re.compile.__name__.__len__,         [],         7,    "re.compile.__name__.__len__() == 7 — c(1)o(2)m(3)p(4)i(5)l(6)e(7); confirmed Python 3.14.3 macOS"]
    - [compile_module_len,  re.compile.__module__.__len__,       [],         2,    "re.compile.__module__.__len__() == 2 — r(1)e(2); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.compile class name and re.NOFLAG class name
# compile.__class__.__name__=='function'(8), NOFLAG.__class__.__name__=='RegexFlag'(9)
# ---------------------------------------------------------------------------

table re_extra197.compile_class_and_noflag:
  description: "re.compile class name and re.NOFLAG class: compile.__class__.__name__='function'(8), NOFLAG.__class__.__name__='RegexFlag'(9)"
  kind: python_call_eq
  category: identity
  id_prefix: remodule197

  columns: [id, function, args, expected, description]
  rows:
    - [compile_class_eq,     re.compile.__class__.__name__.__eq__,   ["function"],  true, "re.compile.__class__.__name__ == 'function' (len=8); re.compile is a plain Python function; confirmed Python 3.14.3 macOS"]
    - [noflag_class_eq,      re.NOFLAG.__class__.__name__.__eq__,    ["RegexFlag"], true, "re.NOFLAG.__class__.__name__ == 'RegexFlag' (len=9); NOFLAG is an IntFlag enum member; confirmed Python 3.14.3 macOS"]
    - [compile_class_len,    re.compile.__class__.__name__.__len__,   [],           8,    "re.compile.__class__.__name__.__len__() == 8 — f(1)u(2)n(3)c(4)t(5)i(6)o(7)n(8); confirmed Python 3.14.3 macOS"]
    - [noflag_class_len,     re.NOFLAG.__class__.__name__.__len__,    [],           9,    "re.NOFLAG.__class__.__name__.__len__() == 9 — R(1)e(2)g(3)e(4)x(5)F(6)l(7)a(8)g(9); confirmed Python 3.14.3 macOS"]
    - [compile_qualname_len, re.compile.__qualname__.__len__,         [],           7,    "re.compile.__qualname__.__len__() == 7; same as __name__ length; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra197.module_name_eq:
  description: "re.__name__ == 're' — the module's own __name__ attribute (len=2); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.__name__.__eq__
  args: ["re"]
  expected: true

invariant re_extra197.module_package_eq:
  description: "re.__package__ == 're' — re is a top-level package; __package__ equals __name__ (len=2); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.__package__.__eq__
  args: ["re"]
  expected: true

invariant re_extra197.spec_name_eq:
  description: "re.__spec__.name == 're' — ModuleSpec.name confirms the module import name (len=2); note: ModuleSpec uses .name not .__name__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.__spec__.name.__eq__
  args: ["re"]
  expected: true

invariant re_extra197.compile_name_eq:
  description: "re.compile.__name__ == 'compile' — the function's __name__ attribute (len=7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.compile.__name__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra197.compile_module_eq:
  description: "re.compile.__module__ == 're' — compile is defined in the re module (len=2); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.compile.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra197.compile_qualname_eq:
  description: "re.compile.__qualname__ == 'compile' — same as __name__ for a module-level function (len=7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.compile.__qualname__.__eq__
  args: ["compile"]
  expected: true

invariant re_extra197.compile_class_name_eq:
  description: "re.compile.__class__.__name__ == 'function' — re.compile is a plain Python function, not a builtin_function_or_method (len=8); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.compile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant re_extra197.noflag_class_name_eq:
  description: "re.NOFLAG.__class__.__name__ == 'RegexFlag' — NOFLAG is an IntFlag enum member; its class is RegexFlag (len=9); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.NOFLAG.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true
