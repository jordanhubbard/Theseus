spec: concurrent_futures_extra1231
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures.__dict__.__contains__ for Future, Executor, wait, as_completed, FIRST_COMPLETED, ALL_COMPLETED, FIRST_EXCEPTION, CancelledError, TimeoutError, BrokenExecutor, InvalidStateError; also ThreadPoolExecutor/ProcessPoolExecutor absent from top-level __dict__ (they live in submodules)"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures.__dict__.__contains__ for top-level names; ThreadPoolExecutor and ProcessPoolExecutor are FALSE (only accessible via submodule import) while Future, Executor, wait, as_completed, constants, and error classes are TRUE — behaviors not covered by extra1201 (__bases__.__len__) or extra1216 (__mro__.__len__)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1231.dict_contains_classes_and_functions:
  description: "concurrent.futures.__dict__ contains Future, Executor, wait, as_completed, CancelledError, TimeoutError, BrokenExecutor, InvalidStateError"
  kind: python_call_eq
  category: module_interface
  id_prefix: cf1231dc
  columns: [id, function, args, expected]
  rows:
    - [cf1231dc001, concurrent.futures.__dict__.__contains__, ["Future"],          true]
    - [cf1231dc002, concurrent.futures.__dict__.__contains__, ["Executor"],        true]
    - [cf1231dc003, concurrent.futures.__dict__.__contains__, ["wait"],            true]
    - [cf1231dc004, concurrent.futures.__dict__.__contains__, ["as_completed"],    true]
    - [cf1231dc005, concurrent.futures.__dict__.__contains__, ["CancelledError"],  true]
    - [cf1231dc006, concurrent.futures.__dict__.__contains__, ["TimeoutError"],    true]
    - [cf1231dc007, concurrent.futures.__dict__.__contains__, ["BrokenExecutor"],  true]
    - [cf1231dc008, concurrent.futures.__dict__.__contains__, ["InvalidStateError"], true]

table concurrent_futures_extra1231.dict_contains_constants:
  description: "concurrent.futures.__dict__ contains wait constants FIRST_COMPLETED, ALL_COMPLETED, FIRST_EXCEPTION; absent names Thread, Lock, Queue, Process"
  kind: python_call_eq
  category: module_interface
  id_prefix: cf1231cc
  columns: [id, function, args, expected]
  rows:
    - [cf1231cc001, concurrent.futures.__dict__.__contains__, ["FIRST_COMPLETED"],    true]
    - [cf1231cc002, concurrent.futures.__dict__.__contains__, ["ALL_COMPLETED"],      true]
    - [cf1231cc003, concurrent.futures.__dict__.__contains__, ["FIRST_EXCEPTION"],    true]
    - [cf1231cc004, concurrent.futures.__dict__.__contains__, ["Thread"],             false]
    - [cf1231cc005, concurrent.futures.__dict__.__contains__, ["Lock"],               false]
    - [cf1231cc006, concurrent.futures.__dict__.__contains__, ["Queue"],              false]
    - [cf1231cc007, concurrent.futures.__dict__.__contains__, ["Process"],            false]
    - [cf1231cc008, concurrent.futures.__dict__.__contains__, ["nonexistent"],        false]

table concurrent_futures_extra1231.executor_subclass_absent_and_name_eq:
  description: "ThreadPoolExecutor and ProcessPoolExecutor are absent from concurrent.futures top-level __dict__; Future.__class__.__name__ and Executor.__class__.__name__ are 'type'"
  kind: python_call_eq
  category: module_interface
  id_prefix: cf1231ea
  columns: [id, function, args, expected]
  rows:
    - [cf1231ea001, concurrent.futures.__dict__.__contains__, ["ThreadPoolExecutor"],  false]
    - [cf1231ea002, concurrent.futures.__dict__.__contains__, ["ProcessPoolExecutor"], false]
    - [cf1231ea003, concurrent.futures.Future.__class__.__name__.__eq__,   ["type"], true]
    - [cf1231ea004, concurrent.futures.Executor.__class__.__name__.__eq__, ["type"], true]
    - [cf1231ea005, concurrent.futures.Future.__name__.__eq__,             ["Future"],   true]
    - [cf1231ea006, concurrent.futures.Executor.__name__.__eq__,           ["Executor"], true]
    - [cf1231ea007, concurrent.futures.CancelledError.__name__.__eq__,     ["CancelledError"], true]
    - [cf1231ea008, concurrent.futures.TimeoutError.__name__.__eq__,       ["TimeoutError"],   true]
    - [cf1231ea009, concurrent.futures.BrokenExecutor.__name__.__eq__,     ["BrokenExecutor"], true]
    - [cf1231ea010, concurrent.futures.__name__.__eq__,                    ["concurrent.futures"], true]
    - [cf1231ea011, concurrent.futures.__name__.__len__.__eq__,            [18], true]
