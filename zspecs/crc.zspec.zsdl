spec: crc
version: ">=3.0.0"
backend: node(crc)

docs: https://www.npmjs.com/package/crc

provenance:
  derived_from:
    - "crc README — https://www.npmjs.com/package/crc"
    - "Test vectors verified with crc via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "crc source"
  notes:
    - "crc is an npm package. Install: npm install crc"
    - "crc.crc32(str) returns the CRC-32 checksum as an unsigned 32-bit integer."
    - "crc.crc16(str) returns the CRC-16 checksum."
    - "crc.crc8(str) returns the CRC-8 checksum."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns checksum as integer."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table crc.crc32:
  kind: node_module_call_eq
  function: crc32
  category: crc32
  id_prefix: crc32

  columns: [id, args, expected]
  rows:
    - [hello,   ["hello"], 907060870]
    - [abc,     ["abc"],   891568578]
    - [empty,   [""],      0]

table crc.crc16:
  kind: node_module_call_eq
  function: crc16
  category: crc16
  id_prefix: crc16

  columns: [id, args, expected]
  rows:
    - [hello, ["hello"], 13522]

table crc.crc8:
  kind: node_module_call_eq
  function: crc8
  category: crc8
  id_prefix: crc8

  columns: [id, args, expected]
  rows:
    - [hello, ["hello"], 146]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T11:39:31Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
