spec: inspect_extra178
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.stack and frame functions — inspect.stack.__name__=='stack' (len=5); inspect.stack.__module__=='inspect'; inspect.currentframe.__name__=='currentframe' (len=12); inspect.getframeinfo.__name__=='getframeinfo' (len=12; same as currentframe); inspect.getouterframes.__name__=='getouterframes' (len=14); inspect.getinnerframes.__name__=='getinnerframes' (len=14; same as getouterframes); inspect.trace.__name__=='trace' (len=5; same as stack); inspect.getlineno.__name__=='getlineno' (len=9)."
    - "inspect.stack.__name__ == 'stack' — stack is a Python function in Lib/inspect.py returning a list of frame records for the caller's stack; its __name__ is 'stack', 5 characters. Verified with Python 3.14.3."
    - "inspect.stack.__module__ == 'inspect' — stack is defined in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.currentframe.__name__ == 'currentframe' — currentframe is a built-in function returning the current stack frame; its __name__ is 'currentframe', 12 characters. Verified with Python 3.14.3."
    - "inspect.getframeinfo.__name__ == 'getframeinfo' — getframeinfo is a Python function in Lib/inspect.py returning a named tuple Traceback with file, lineno, function, code_context, and index; its __name__ is 'getframeinfo', 12 characters, same length as 'currentframe'. Verified with Python 3.14.3."
    - "inspect.getouterframes.__name__ == 'getouterframes' — getouterframes is a Python function in Lib/inspect.py returning a list of FrameInfo named tuples for a frame and all outer frames; its __name__ is 'getouterframes', 14 characters. Verified with Python 3.14.3."
    - "inspect.getinnerframes.__name__ == 'getinnerframes' — getinnerframes is a Python function in Lib/inspect.py returning a list of FrameInfo named tuples for a traceback's frames; its __name__ is 'getinnerframes', 14 characters, same length as 'getouterframes'. Verified with Python 3.14.3."
    - "inspect.trace.__name__ == 'trace' — trace is a Python function in Lib/inspect.py returning a list of frame records for the stack between the current frame and the frame in which an exception was raised; its __name__ is 'trace', 5 characters, same length as 'stack'. Verified with Python 3.14.3."
    - "inspect.getlineno.__name__ == 'getlineno' — getlineno is a Python function in Lib/inspect.py returning the line number of the current line of a frame; its __name__ is 'getlineno', 9 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.stack __name__ and __module__ and inspect.currentframe __name__
#
# inspect.stack.__name__ == 'stack'
# inspect.stack.__name__.__len__() == 5
# inspect.stack.__module__ == 'inspect'
# inspect.currentframe.__name__ == 'currentframe'
#
# inspect.stack is a Python function in Lib/inspect.py that returns a list of
# frame records for the caller's stack; its __name__ is 'stack' (5 chars) and
# its __module__ is 'inspect'. currentframe is a C builtin whose __name__ is
# 'currentframe' (12 chars). New to extra178.
# ---------------------------------------------------------------------------

table inspect_extra178.stack_name_module_and_currentframe_name:
  description: "inspect.stack.__name__ 'stack' len 5; __module__ 'inspect'; currentframe.__name__ 'currentframe' len 12; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: inspectstack178

  columns: [id, function, args, expected, description]
  rows:
    - [stack_name_eq,
       "stack.__name__.__eq__",
       ["stack"],
       true,
       "inspect.stack.__name__.__eq__('stack') == True — inspect.stack is a Python function in Lib/inspect.py that returns a list of FrameInfo named tuples representing the call stack of the caller; its __name__ is 'stack'; str.__eq__('stack') returns True; new to extra178"]
    - [stack_name_len_5,
       "stack.__name__.__len__",
       [],
       5,
       "inspect.stack.__name__.__len__() == 5 — the name 'stack' has exactly 5 characters: s-t-a-c-k; str.__len__() returns 5; new to extra178"]
    - [stack_module_inspect,
       "stack.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.stack.__module__.__eq__('inspect') == True — inspect.stack is a Python function defined in Lib/inspect.py; its __module__ is the string 'inspect'; str.__eq__('inspect') returns True; new to extra178"]
    - [currentframe_name_eq,
       "currentframe.__name__.__eq__",
       ["currentframe"],
       true,
       "inspect.currentframe.__name__.__eq__('currentframe') == True — inspect.currentframe is a built-in function (exposed via the _thread or sys C extension) returning the current execution frame; its __name__ is 'currentframe'; str.__eq__('currentframe') returns True; new to extra178"]

# ---------------------------------------------------------------------------
# Table 2: inspect.currentframe name length and inspect.getframeinfo __name__
#
# inspect.currentframe.__name__.__len__() == 12
# inspect.getframeinfo.__name__ == 'getframeinfo'
# inspect.getframeinfo.__name__.__len__() == 12
# inspect.getframeinfo.__module__ == 'inspect'
#
# currentframe has __name__ 'currentframe' (12 chars). getframeinfo is a Python
# function whose __name__ is 'getframeinfo' (12 chars — same length as
# 'currentframe'). Its __module__ is 'inspect'. New to extra178.
# ---------------------------------------------------------------------------

table inspect_extra178.currentframe_len_and_getframeinfo_name:
  description: "inspect.currentframe.__name__ len 12; getframeinfo.__name__ 'getframeinfo' len 12 (same); __module__ 'inspect'; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: inspectstack178

  columns: [id, function, args, expected, description]
  rows:
    - [currentframe_name_len_12,
       "currentframe.__name__.__len__",
       [],
       12,
       "inspect.currentframe.__name__.__len__() == 12 — the name 'currentframe' has exactly 12 characters: c-u-r-r-e-n-t-f-r-a-m-e; str.__len__() returns 12; new to extra178"]
    - [getframeinfo_name_eq,
       "getframeinfo.__name__.__eq__",
       ["getframeinfo"],
       true,
       "inspect.getframeinfo.__name__.__eq__('getframeinfo') == True — inspect.getframeinfo is a Python function in Lib/inspect.py that returns a Traceback named tuple (file, lineno, function, code_context, index) for a frame or traceback object; its __name__ is 'getframeinfo'; str.__eq__('getframeinfo') returns True; new to extra178"]
    - [getframeinfo_name_len_12,
       "getframeinfo.__name__.__len__",
       [],
       12,
       "inspect.getframeinfo.__name__.__len__() == 12 — the name 'getframeinfo' has exactly 12 characters: g-e-t-f-r-a-m-e-i-n-f-o; same length as 'currentframe' (12); str.__len__() returns 12; new to extra178"]
    - [getframeinfo_module_inspect,
       "getframeinfo.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getframeinfo.__module__.__eq__('inspect') == True — inspect.getframeinfo is a Python function defined in Lib/inspect.py; its __module__ is the string 'inspect'; str.__eq__('inspect') returns True; new to extra178"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getouterframes and inspect.getinnerframes __name__
#
# inspect.getouterframes.__name__ == 'getouterframes'
# inspect.getouterframes.__name__.__len__() == 14
# inspect.getinnerframes.__name__ == 'getinnerframes'
# inspect.getinnerframes.__name__.__len__() == 14
#
# getouterframes has __name__ 'getouterframes' (14 chars). getinnerframes has
# __name__ 'getinnerframes' (14 chars — same length as 'getouterframes').
# New to extra178.
# ---------------------------------------------------------------------------

table inspect_extra178.getouterframes_and_getinnerframes_name:
  description: "inspect.getouterframes.__name__ 'getouterframes' len 14; getinnerframes.__name__ 'getinnerframes' len 14 (same); new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: inspectstack178

  columns: [id, function, args, expected, description]
  rows:
    - [getouterframes_name_eq,
       "getouterframes.__name__.__eq__",
       ["getouterframes"],
       true,
       "inspect.getouterframes.__name__.__eq__('getouterframes') == True — inspect.getouterframes is a Python function in Lib/inspect.py returning a list of FrameInfo named tuples for a frame and all outer (caller) frames; its __name__ is 'getouterframes'; str.__eq__('getouterframes') returns True; new to extra178"]
    - [getouterframes_name_len_14,
       "getouterframes.__name__.__len__",
       [],
       14,
       "inspect.getouterframes.__name__.__len__() == 14 — the name 'getouterframes' has exactly 14 characters: g-e-t-o-u-t-e-r-f-r-a-m-e-s; str.__len__() returns 14; new to extra178"]
    - [getinnerframes_name_eq,
       "getinnerframes.__name__.__eq__",
       ["getinnerframes"],
       true,
       "inspect.getinnerframes.__name__.__eq__('getinnerframes') == True — inspect.getinnerframes is a Python function in Lib/inspect.py returning a list of FrameInfo named tuples for a traceback object's frames (the inner frames leading to the exception); its __name__ is 'getinnerframes'; str.__eq__('getinnerframes') returns True; new to extra178"]
    - [getinnerframes_name_len_14,
       "getinnerframes.__name__.__len__",
       [],
       14,
       "inspect.getinnerframes.__name__.__len__() == 14 — the name 'getinnerframes' has exactly 14 characters: g-e-t-i-n-n-e-r-f-r-a-m-e-s; same length as 'getouterframes' (14); str.__len__() returns 14; new to extra178"]

# ---------------------------------------------------------------------------
# Table 4: inspect.trace __name__ and inspect.getlineno __name__
#
# inspect.trace.__name__ == 'trace'
# inspect.trace.__name__.__len__() == 5
# inspect.getlineno.__name__ == 'getlineno'
# inspect.getlineno.__name__.__len__() == 9
#
# trace has __name__ 'trace' (5 chars — same length as 'stack'). getlineno has
# __name__ 'getlineno' (9 chars). New to extra178.
# ---------------------------------------------------------------------------

table inspect_extra178.trace_name_and_getlineno_name:
  description: "inspect.trace.__name__ 'trace' len 5 (same as stack); getlineno.__name__ 'getlineno' len 9; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: inspectstack178

  columns: [id, function, args, expected, description]
  rows:
    - [trace_name_eq,
       "trace.__name__.__eq__",
       ["trace"],
       true,
       "inspect.trace.__name__.__eq__('trace') == True — inspect.trace is a Python function in Lib/inspect.py returning a list of FrameInfo named tuples for the stack between the current frame and the frame where an exception was raised; its __name__ is 'trace'; str.__eq__('trace') returns True; new to extra178"]
    - [trace_name_len_5,
       "trace.__name__.__len__",
       [],
       5,
       "inspect.trace.__name__.__len__() == 5 — the name 'trace' has exactly 5 characters: t-r-a-c-e; same length as 'stack' (5); str.__len__() returns 5; new to extra178"]
    - [getlineno_name_eq,
       "getlineno.__name__.__eq__",
       ["getlineno"],
       true,
       "inspect.getlineno.__name__.__eq__('getlineno') == True — inspect.getlineno is a Python function in Lib/inspect.py returning the line number for an object (frame, code, or traceback); its __name__ is 'getlineno'; str.__eq__('getlineno') returns True; new to extra178"]
    - [getlineno_name_len_9,
       "getlineno.__name__.__len__",
       [],
       9,
       "inspect.getlineno.__name__.__len__() == 9 — the name 'getlineno' has exactly 9 characters: g-e-t-l-i-n-e-n-o; str.__len__() returns 9; new to extra178"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra178
# ---------------------------------------------------------------------------

invariant inspect_extra178.stack_name_stack:
  description: "inspect.stack.__name__ == 'stack' — Python function in Lib/inspect.py with __name__ 'stack' (5 chars); new to extra178"
  kind: python_call_eq
  function: stack.__name__.__eq__
  args: ["stack"]
  expected: true

invariant inspect_extra178.stack_name_len_5:
  description: "inspect.stack.__name__.__len__() == 5 — 'stack' is 5 characters long; new to extra178"
  kind: python_call_eq
  function: stack.__name__.__len__
  args: []
  expected: 5

invariant inspect_extra178.stack_module_inspect:
  description: "inspect.stack.__module__ == 'inspect' — stack is defined in Lib/inspect.py; new to extra178"
  kind: python_call_eq
  function: stack.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra178.currentframe_name_currentframe:
  description: "inspect.currentframe.__name__ == 'currentframe' — built-in function with __name__ 'currentframe' (12 chars); new to extra178"
  kind: python_call_eq
  function: currentframe.__name__.__eq__
  args: ["currentframe"]
  expected: true

invariant inspect_extra178.getframeinfo_name_getframeinfo:
  description: "inspect.getframeinfo.__name__ == 'getframeinfo' — Python function in Lib/inspect.py with __name__ 'getframeinfo' (12 chars, same as currentframe); new to extra178"
  kind: python_call_eq
  function: getframeinfo.__name__.__eq__
  args: ["getframeinfo"]
  expected: true

invariant inspect_extra178.getouterframes_name_getouterframes:
  description: "inspect.getouterframes.__name__ == 'getouterframes' — Python function in Lib/inspect.py with __name__ 'getouterframes' (14 chars); new to extra178"
  kind: python_call_eq
  function: getouterframes.__name__.__eq__
  args: ["getouterframes"]
  expected: true

invariant inspect_extra178.getinnerframes_name_getinnerframes:
  description: "inspect.getinnerframes.__name__ == 'getinnerframes' — Python function in Lib/inspect.py with __name__ 'getinnerframes' (14 chars, same as getouterframes); new to extra178"
  kind: python_call_eq
  function: getinnerframes.__name__.__eq__
  args: ["getinnerframes"]
  expected: true

invariant inspect_extra178.trace_name_trace:
  description: "inspect.trace.__name__ == 'trace' — Python function in Lib/inspect.py with __name__ 'trace' (5 chars, same as stack); new to extra178"
  kind: python_call_eq
  function: trace.__name__.__eq__
  args: ["trace"]
  expected: true

invariant inspect_extra178.getlineno_name_getlineno:
  description: "inspect.getlineno.__name__ == 'getlineno' — Python function in Lib/inspect.py with __name__ 'getlineno' (9 chars); new to extra178"
  kind: python_call_eq
  function: getlineno.__name__.__eq__
  args: ["getlineno"]
  expected: true

invariant inspect_extra178.getlineno_name_len_9:
  description: "inspect.getlineno.__name__.__len__() == 9 — 'getlineno' is 9 characters long; new to extra178"
  kind: python_call_eq
  function: getlineno.__name__.__len__
  args: []
  expected: 9
