spec: theseus_xml_et_cr
version: ">=3.9"
backend: python_cleanroom(theseus_xml_et_cr)
blocks: xml

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xml.etree.elementtree.html"
  notes:
    - "Clean-room minimal XML ElementTree parser. Do NOT import xml, xml.etree, or any xml submodule."
    - "Element(tag, attrib={}): XML element with tag, attrib dict, text, tail, children."
    - "SubElement(parent, tag): create child element appended to parent."
    - "fromstring(xml_str): parse XML string into Element tree."
    - "tostring(element): serialize Element back to bytes/string."
    - "xml_et_tag(): fromstring('<root/>').tag == 'root'."
    - "xml_et_attrib(): fromstring('<a x=\"1\"/>').attrib['x'] == '1'."
    - "xml_et_child_count(): fromstring('<r><a/><b/></r>') has 2 children."
    - "Export: Element, SubElement, fromstring, tostring."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_xml_et_cr.tag:
  description: "fromstring('<root/>').tag == 'root'"
  category: parse
  kind: python_call_eq
  function: xml_et_tag
  args: []
  expected: "root"

invariant theseus_xml_et_cr.attrib:
  description: "fromstring('<a x=\"1\"/>').attrib['x'] == '1'"
  category: parse
  kind: python_call_eq
  function: xml_et_attrib
  args: []
  expected: "1"

invariant theseus_xml_et_cr.child_count:
  description: "fromstring('<r><a/><b/></r>') has 2 children"
  category: children
  kind: python_call_eq
  function: xml_et_child_count
  args: []
  expected: 2
