spec: theseus_pathlib_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_pathlib_cr2)
blocks: pathlib

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html"
  notes:
    - "Extended clean-room path manipulation. Do NOT import pathlib, os, or os.path."
    - "PurePath(parts...) / operator joins path segments."
    - "PurePath('/foo/bar/baz.txt').suffix == '.txt'."
    - "PurePath('/foo/bar/baz.txt').stem == 'baz'."
    - "PurePath('/foo/bar').parent == PurePath('/foo')."
    - "PurePath('a/b') / 'c' == PurePath('a/b/c')."
    - "Export: PurePath class with name, stem, suffix, parent, parts, / operator."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_pathlib_cr2.suffix:
  description: "PurePath('/foo/bar/baz.txt').suffix == '.txt'"
  category: parts
  kind: python_call_eq
  function: pathlib_suffix
  args: []
  expected: ".txt"

invariant theseus_pathlib_cr2.stem:
  description: "PurePath('/foo/bar/baz.txt').stem == 'baz'"
  category: parts
  kind: python_call_eq
  function: pathlib_stem
  args: []
  expected: "baz"

invariant theseus_pathlib_cr2.join:
  description: "PurePath('a/b') / 'c' == 'a/b/c'"
  category: join
  kind: python_call_eq
  function: pathlib_join
  args: []
  expected: "a/b/c"
