spec: html_to_text
version: ">=9.0.0"
backend: node(html-to-text)

docs: https://www.npmjs.com/package/html-to-text

provenance:
  derived_from:
    - "html-to-text README — https://www.npmjs.com/package/html-to-text"
    - "Test vectors verified with html-to-text via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "html-to-text source"
  notes:
    - "html-to-text is an npm package. Install: npm install html-to-text"
    - "htmlToText(html) converts HTML to plain text."
    - "Default: headings are uppercased; <a> tags include the URL in brackets."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns plain text string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table html_to_text.htmlToText:
  kind: node_module_call_eq
  function: htmlToText
  category: htmlToText
  id_prefix: h2t

  columns: [id, args, expected]
  rows:
    - [paragraph, ["<p>Hello World</p>"],    "Hello World"]
    - [heading,   ["<h1>Title</h1>"],        "TITLE"]
    - [linebreak, ["line1<br>line2"],        "line1\nline2"]
    - [div,       ["<div>just text</div>"],  "just text"]
