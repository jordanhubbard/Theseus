spec: lodash_isarray
version: ">=4.0.0"
backend: node(lodash.isarray)

docs: https://lodash.com/docs/#isArray

provenance:
  derived_from:
    - "lodash.isarray README — https://www.npmjs.com/package/lodash.isarray"
    - "Test vectors verified with lodash.isarray@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isarray exports the _.isArray function directly as module.exports."
    - "isArray checks if value is classified as an Array object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isarray.isarray:
  kind: node_module_call_eq
  function: ~
  category: isarray
  id_prefix: lisa

  columns: [id, args, expected]
  rows:
    - [yes_arr,   [[1, 2, 3]],    true]
    - [empty_arr, [[]],           true]
    - [string,    ["hello"],      false]
    - [object,    [{"a": 1}],    false]
    - [number,    [42],           false]
    - [null_val,  [null],         false]
