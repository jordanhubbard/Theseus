  description: "multiprocessing types __gt__ dict-presence checks; wave 676"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3436

  columns: [id, function, args, expected]
  rows:
    - ["mp3436009",  operator.contains, [multiprocessing.Process.__dict__,                 "__gt__"], false]
    - ["mp3436010",  operator.contains, [multiprocessing.pool.Pool.__dict__,               "__gt__"], false]
    - ["mp3436011",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__gt__"], false]
    - ["mp3436012",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__gt__"], false]
    - ["mp3436013",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__gt__"], false]
    - ["mp3436014",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__gt__"], false]
    - ["mp3436015",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__gt__"], false]
    - ["mp3436016",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__gt__"], false]

# ---------------------------------------------------------------------------
# __ge__ dict-presence — operator.contains(Cls.__dict__, '__ge__')
#
# All 8 multiprocessing classes return false for __ge__.
# >= delegates to __ge__ when defined in the class's own __dict__.
# None of the 8 multiprocessing classes define a Python-level __ge__
#   in their own __dict__.
# managers.BaseListProxy key note: BaseListProxy defines __getitem__,
#   __setitem__, __delitem__, __len__, __contains__, __add__, __mul__,
#   and other collection protocol methods in its __dict__, but __ge__
#   is not among them. List ordering is not proxied through __ge__.
# managers._BaseDictProxy: defines dict proxy methods in its __dict__,
#   but not __ge__.
# managers._BaseSetProxy: defines set proxy methods in its __dict__,
#   but not __ge__.
# multiprocessing.Process: no __ge__ defined; processes are not ordered.
# pool.Pool/AsyncResult/MapResult/SyncManager: no __ge__ in their own
#   __dict__; ordering falls back to inherited behavior (raises TypeError
#   at runtime since object has no __ge__).
# ---------------------------------------------------------------------------

