    - ["mp3436019",  operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__ge__"], false]
    - ["mp3436020",  operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__ge__"], false]
    - ["mp3436021",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__ge__"], false]
    - ["mp3436022",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__ge__"], false]
    - ["mp3436023",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__ge__"], false]
    - ["mp3436024",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__ge__"], false]

# ---------------------------------------------------------------------------
# combined — __le__, __gt__, __ge__ across all 8 mp subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __le__: false for all 8 — not in any type's own __dict__.
# __gt__: false for all 8 — not in any type's own __dict__.
# __ge__: false for all 8 — not in any type's own __dict__.
# All 24 values are false.
# The proxy types (_BaseSetProxy, _BaseDictProxy, BaseListProxy) are the most
#   analytically interesting subjects here. BaseListProxy proxies list and does
#   define some collection protocol methods (__add__, __mul__, __getitem__, etc.)
#   in its own __dict__ — but __le__, __gt__, and __ge__ are not among them.
#   _BaseDictProxy and _BaseSetProxy similarly define proxy dispatch methods but
#   not ordering dunders. The proxy types relay operations to a managed server
#   process via IPC; ordering comparison is not part of the proxy protocol.
# multiprocessing is a process-based concurrency library; its types interact
#   exclusively through explicit method calls, subprocess lifecycle management,
#   and IPC — not through ordering protocol overrides in any class __dict__.
# ---------------------------------------------------------------------------

