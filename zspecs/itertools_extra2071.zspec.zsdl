spec: itertools_extra2071
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "itertools C types (count, cycle, chain, islice, zip_longest, product, combinations, permutations) all define __getattribute__ in their __dict__ — they are C extension types."
    - "None of the itertools C types define __pos__, __neg__, __reduce__, __reduce_ex__, __copy__, or __deepcopy__ in their own __dict__."
    - "Pickling of itertools iterators is not supported via __reduce__/__reduce_ex__ in __dict__; the types are not generally picklable."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __pos__ / __neg__ dict-presence for itertools C types
#
# All itertools types are iterator types, not numeric; none define __pos__
# or __neg__ in their own __dict__.
# ---------------------------------------------------------------------------

table itertools_extra2071.unary_sign_protocol:
  description: "itertools C types __pos__/__neg__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2071

  columns: [id, function, args, expected]
  rows:
    - ["it2071001", "itertools.count.__dict__.__contains__", ["__pos__"], false]
    - ["it2071002", "itertools.count.__dict__.__contains__", ["__neg__"], false]
    - ["it2071003", "itertools.cycle.__dict__.__contains__", ["__pos__"], false]
    - ["it2071004", "itertools.cycle.__dict__.__contains__", ["__neg__"], false]
    - ["it2071005", "itertools.chain.__dict__.__contains__", ["__pos__"], false]
    - ["it2071006", "itertools.chain.__dict__.__contains__", ["__neg__"], false]
    - ["it2071007", "itertools.islice.__dict__.__contains__", ["__pos__"], false]
    - ["it2071008", "itertools.islice.__dict__.__contains__", ["__neg__"], false]

# ---------------------------------------------------------------------------
# Table 2: __getattribute__ dict-presence for itertools C types
#
# All itertools C extension types define __getattribute__ in their own
# __dict__ because CPython registers it for C types at the C level.
# Verified for all 8 types.
# ---------------------------------------------------------------------------

table itertools_extra2071.getattribute_protocol:
  description: "itertools C types __getattribute__ dict-presence — all True"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2071

  columns: [id, function, args, expected]
  rows:
    - ["it2071009", "itertools.count.__dict__.__contains__", ["__getattribute__"], true]
    - ["it2071010", "itertools.cycle.__dict__.__contains__", ["__getattribute__"], true]
    - ["it2071011", "itertools.chain.__dict__.__contains__", ["__getattribute__"], true]
    - ["it2071012", "itertools.islice.__dict__.__contains__", ["__getattribute__"], true]
    - ["it2071013", "itertools.zip_longest.__dict__.__contains__", ["__getattribute__"], true]
    - ["it2071014", "itertools.product.__dict__.__contains__", ["__getattribute__"], true]
    - ["it2071015", "itertools.combinations.__dict__.__contains__", ["__getattribute__"], true]
    - ["it2071016", "itertools.permutations.__dict__.__contains__", ["__getattribute__"], true]

# ---------------------------------------------------------------------------
# Table 3: __reduce__ / __reduce_ex__ dict-presence for itertools C types
#
# None of the itertools C types define __reduce__ or __reduce_ex__ in their
# own __dict__. Pickle support is not exposed via these dunder overrides.
# ---------------------------------------------------------------------------

table itertools_extra2071.pickle_protocol:
  description: "itertools C types __reduce__/__reduce_ex__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2071

  columns: [id, function, args, expected]
  rows:
    - ["it2071017", "itertools.count.__dict__.__contains__", ["__reduce__"], false]
    - ["it2071018", "itertools.count.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["it2071019", "itertools.cycle.__dict__.__contains__", ["__reduce__"], false]
    - ["it2071020", "itertools.cycle.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["it2071021", "itertools.product.__dict__.__contains__", ["__reduce__"], false]
    - ["it2071022", "itertools.product.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["it2071023", "itertools.combinations.__dict__.__contains__", ["__reduce__"], false]
    - ["it2071024", "itertools.permutations.__dict__.__contains__", ["__reduce__"], false]

# ---------------------------------------------------------------------------
# Table 4: __copy__ / __deepcopy__ dict-presence for itertools C types
#
# None of the itertools C types define __copy__ or __deepcopy__ in their
# own __dict__. Copy support is not provided via these dunder overrides.
# ---------------------------------------------------------------------------

