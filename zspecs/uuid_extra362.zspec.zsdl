spec: uuid_extra362
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "str(uuid.NAMESPACE_DNS) == '6ba7b810-9dad-11d1-80b4-00c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "str(uuid.NAMESPACE_URL) == '6ba7b811-9dad-11d1-80b4-00c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "str(uuid.NAMESPACE_OID) == '6ba7b812-9dad-11d1-80b4-00c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "str(uuid.NAMESPACE_X500) == '6ba7b814-9dad-11d1-80b4-00c04fd430c8'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All four NAMESPACE constants are instances of uuid.UUID — pre-defined constants from RFC 4122 Appendix C."
    - "Note: NAMESPACE_DNS is for generating UUIDs within the DNS namespace (e.g., FQDNs). Its value is fixed by RFC 4122."
    - "Note: NAMESPACE_URL is for generating UUIDs within the URL namespace. Its value is fixed by RFC 4122."
    - "Note: NAMESPACE_OID is for generating UUIDs within the ISO OID namespace. Its value is fixed by RFC 4122."
    - "Note: NAMESPACE_X500 is for generating UUIDs within the X.500 DN namespace. Its value is fixed by RFC 4122."
    - "Note: uuid.UUID.__doc__ is a string (str) — the docstring for the UUID class, which is a Python str at runtime."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'
# uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'
# uuid.NAMESPACE_OID.__class__.__name__ == 'UUID'
# uuid.NAMESPACE_X500.__class__.__name__ == 'UUID'
#
# Wave 362 theme: uuid NAMESPACE constants are UUID instances.
#
# The four RFC 4122 NAMESPACE constants are pre-defined UUID instances.
# NAMESPACE_DNS (6ba7b810-...) is used with uuid3/uuid5 for DNS names.
# NAMESPACE_URL (6ba7b811-...) is used for URLs.
# NAMESPACE_OID (6ba7b812-...) is used for ISO OIDs.
# NAMESPACE_X500 (6ba7b814-...) is used for X.500 Distinguished Names.
# All four constants are instances of the uuid.UUID class; their
# __class__.__name__ is 'UUID'. Values defined in RFC 4122 Appendix C.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra362.namespace_constants_class_identity:
  description: "NAMESPACE_DNS.__class__.__name__.__eq__('UUID')==True / NAMESPACE_URL.__class__.__name__.__eq__('UUID')==True / NAMESPACE_OID.__class__.__name__.__eq__('UUID')==True / NAMESPACE_X500.__class__.__name__.__eq__('UUID')==True — all four RFC 4122 NAMESPACE constants are uuid.UUID instances; __class__.__name__ is 'UUID' for each; used as namespace argument to uuid3() and uuid5(); first uuidnsid362 anchor for namespace constant class identity"
  kind: python_call_eq
  category: namespace_constants
  id_prefix: uuidnsid362

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_class,   "NAMESPACE_DNS.__class__.__name__.__eq__",   ["UUID"], true, "uuid.NAMESPACE_DNS.__class__.__name__ is 'UUID' — DNS namespace constant ('6ba7b810-9dad-11d1-80b4-00c04fd430c8') is a UUID instance (RFC 4122 Appendix C)"]
    - [ns_url_class,   "NAMESPACE_URL.__class__.__name__.__eq__",   ["UUID"], true, "uuid.NAMESPACE_URL.__class__.__name__ is 'UUID' — URL namespace constant ('6ba7b811-9dad-11d1-80b4-00c04fd430c8') is a UUID instance (RFC 4122 Appendix C)"]
    - [ns_oid_class,   "NAMESPACE_OID.__class__.__name__.__eq__",   ["UUID"], true, "uuid.NAMESPACE_OID.__class__.__name__ is 'UUID' — ISO OID namespace constant ('6ba7b812-9dad-11d1-80b4-00c04fd430c8') is a UUID instance (RFC 4122 Appendix C)"]
    - [ns_x500_class,  "NAMESPACE_X500.__class__.__name__.__eq__",  ["UUID"], true, "uuid.NAMESPACE_X500.__class__.__name__ is 'UUID' — X.500 DN namespace constant ('6ba7b814-9dad-11d1-80b4-00c04fd430c8') is a UUID instance (RFC 4122 Appendix C)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__doc__.__class__.__name__ == 'str'
#
# Wave 362 theme: uuid.UUID.__doc__ is a Python str.
#
# uuid.UUID is a pure-Python class with a docstring defined in Lib/uuid.py.
# Its __doc__ attribute is a standard Python string (str). This is the
# expected behavior for pure-Python classes — the docstring is stored as a
# plain str in the class's __doc__ attribute. Verified Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

invariant uuid_extra362.UUID_doc_class_is_str:
  description: "uuid.UUID.__doc__.__class__.__name__.__eq__('str') == True — uuid.UUID is a pure-Python class (Lib/uuid.py) with a string docstring; __doc__.__class__.__name__ is 'str' (standard Python docstring storage); confirms UUID is not a C extension type (C types may have no __doc__ or different doc types); first standalone for UUID.__doc__ class identity under uuidnsid362"
  category: class_identity
  kind: python_call_eq
  function: UUID.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — standalone
#
# uuid.NAMESPACE_DNS.__class__.__name__ is 'UUID'. NAMESPACE_DNS is the
# UUID constant '6ba7b810-9dad-11d1-80b4-00c04fd430c8' defined in RFC 4122
# Appendix C as the namespace UUID for DNS names. It is used as the first
# argument to uuid.uuid3() and uuid.uuid5() when generating UUIDs from
# fully-qualified domain names (FQDNs). The constant is a uuid.UUID instance
# created at module load time in Lib/uuid.py.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra362.NAMESPACE_DNS_class_is_UUID:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — NAMESPACE_DNS is '6ba7b810-9dad-11d1-80b4-00c04fd430c8' (RFC 4122 Appendix C DNS namespace); uuid.UUID instance created at module load in Lib/uuid.py; used as namespace arg to uuid3() and uuid5() for DNS-based UUIDs; first standalone for NAMESPACE_DNS class identity under uuidnsid362"
  category: namespace_constants
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' — standalone
#
# uuid.NAMESPACE_OID.__class__.__name__ is 'UUID'. NAMESPACE_OID is the
# UUID constant '6ba7b812-9dad-11d1-80b4-00c04fd430c8' defined in RFC 4122
# Appendix C as the namespace UUID for ISO Object Identifiers (OIDs). OIDs
# are hierarchical identifiers defined in ISO/IEC 8824 (ASN.1) and used
# extensively in X.509 certificates, SNMP, and LDAP. NAMESPACE_OID enables
# deterministic UUID generation from OID strings via uuid3() and uuid5().
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra362.NAMESPACE_OID_class_is_UUID:
  description: "uuid.NAMESPACE_OID.__class__.__name__.__eq__('UUID') == True — NAMESPACE_OID is '6ba7b812-9dad-11d1-80b4-00c04fd430c8' (RFC 4122 Appendix C ISO OID namespace); uuid.UUID instance; used as namespace arg to uuid3() and uuid5() for ISO OID-based deterministic UUIDs; OIDs used in X.509, SNMP, LDAP; first standalone for NAMESPACE_OID class identity under uuidnsid362"
  category: namespace_constants
  kind: python_call_eq
  function: NAMESPACE_OID.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true
