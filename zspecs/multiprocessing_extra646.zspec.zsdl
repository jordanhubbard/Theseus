spec: multiprocessing_extra646
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#managers — multiprocessing.managers: BaseManager, SyncManager, BaseProxy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers identity checks for multiprocessing.managers module classes: BaseManager, SyncManager, BaseProxy"
  created_at: "2026-04-12T00:00:00Z"

table multiprocessing_extra646.manager_class_identity:
  description: "Identity checks for multiprocessing.managers BaseManager, SyncManager, and BaseProxy"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp646dc
  columns: [id, function, args, expected]
  rows:
    - [mp646dc001, multiprocessing.managers.BaseManager.__qualname__.__eq__, ["BaseManager"], true]
    - [mp646dc002, multiprocessing.managers.BaseManager.__module__.__eq__, ["multiprocessing.managers"], true]
    - [mp646dc003, multiprocessing.managers.SyncManager.__qualname__.__eq__, ["SyncManager"], true]
    - [mp646dc004, multiprocessing.managers.SyncManager.__module__.__eq__, ["multiprocessing.managers"], true]
    - [mp646dc005, multiprocessing.managers.BaseProxy.__qualname__.__eq__, ["BaseProxy"], true]
    - [mp646dc006, multiprocessing.managers.BaseProxy.__module__.__eq__, ["multiprocessing.managers"], true]
    - [mp646dc007, multiprocessing.managers.BaseManager.__class__.__name__.__eq__, ["type"], true]
    - [mp646dc008, multiprocessing.managers.SyncManager.__class__.__name__.__eq__, ["type"], true]
    - [mp646dc009, multiprocessing.managers.BaseProxy.__class__.__name__.__eq__, ["type"], true]

table multiprocessing_extra646.manager_method_identity:
  description: "Identity checks for multiprocessing.managers BaseManager methods and doc"
  kind: python_call_eq
  category: method_identity
  id_prefix: mp646qn
  columns: [id, function, args, expected]
  rows:
    - [mp646qn001, multiprocessing.managers.BaseManager.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [mp646qn002, multiprocessing.managers.BaseManager.__init__.__qualname__.__eq__, ["BaseManager.__init__"], true]
    - [mp646qn003, multiprocessing.managers.BaseManager.start.__qualname__.__eq__, ["BaseManager.start"], true]
