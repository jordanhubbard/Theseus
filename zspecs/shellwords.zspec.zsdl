spec: shellwords
version: ">=0.1.0"
backend: node(shellwords)

docs: https://github.com/jimmycuadra/shellwords#readme

provenance:
  derived_from:
    - "shellwords README — https://github.com/jimmycuadra/shellwords#readme"
    - "POSIX shell word splitting — IEEE Std 1003.1-2017 §2.3"
    - "Test vectors verified with shellwords via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "shellwords source"
  notes:
    - "Split / join / escape strings the way the Bourne shell would."
    - "Install: npm install shellwords"
    - "v0.1 CJS; named exports split, join, escape."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "split() throws on unbalanced quotes; escape/join never throw."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant shellwords.has_split:
  description: "split() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "split.constructor.name"}
  expected: "Function"

invariant shellwords.has_escape:
  description: "escape() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "escape.constructor.name"}
  expected: "Function"

invariant shellwords.has_join:
  description: "join() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "join.constructor.name"}
  expected: "Function"

invariant shellwords.split_simple_words:
  description: "split('foo bar baz') is ['foo','bar','baz']"
  category: split
  kind: node_chain_eq
  entry: named
  function: split
  entry_args: ["foo bar baz"]
  chain: []
  expected: ["foo", "bar", "baz"]

invariant shellwords.split_double_quoted:
  description: "split('foo \"hello world\"') groups the quoted segment"
  category: split
  kind: node_chain_eq
  entry: named
  function: split
  entry_args: ["foo \"hello world\""]
  chain: []
  expected: ["foo", "hello world"]

invariant shellwords.escape_space:
  description: "escape('hello world') escapes the space"
  category: escape
  kind: node_chain_eq
  entry: named
  function: escape
  entry_args: ["hello world"]
  chain: []
  expected: "hello\\ world"

invariant shellwords.split_empty_returns_empty:
  description: "split('') returns []"
  category: edge
  kind: node_chain_eq
  entry: named
  function: split
  entry_args: [""]
  chain: []
  expected: []

invariant shellwords.split_single_word:
  description: "split('foo') returns ['foo']"
  category: split
  kind: node_chain_eq
  entry: named
  function: split
  entry_args: ["foo"]
  chain: []
  expected: ["foo"]
