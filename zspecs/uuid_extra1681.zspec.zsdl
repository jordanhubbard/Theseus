spec: uuid_extra1681
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 559 (_extra1681): __call__ callable protocol dict-presence checks."
    - "uuid.UUID is a pure Python class using __slots__; instances are NOT callable — __call__ not in dict → False."
    - "uuid.UUID defines rich comparison methods (__eq__, __lt__, __hash__) and protocol methods (__str__, __repr__, __int__) in its own __dict__."
    - "uuid.UUID.__dict__.__contains__('__slots__') == True — uuid.UUID uses __slots__ for memory efficiency."
    - "uuid.UUID.__dict__.__contains__('__bytes__') may or may not be defined (bytes() uses __int__ and struct packing internally)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: callable_protocol
#
# uuid.UUID is a pure Python class.  It does not define __call__ in its
# own __dict__; UUID instances represent RFC 4122 UUIDs and are not callable.
# ---------------------------------------------------------------------------

table uuid_extra1681.callable_protocol:
  description: "uuid.UUID __call__ dict-presence checks (wave 559 _extra1681) — uuid.UUID.__dict__.__contains__('__call__')==False (UUID is a pure-Python class; it does not define __call__ in its own class dict; UUID instances represent RFC 4122 identifiers and are not designed to be called as functions); verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1681

  columns: [id, function, args, expected]
  rows:
    - ["uu1681001", "uuid.UUID.__dict__.__contains__", ["__call__"],  false]
    - ["uu1681002", "uuid.UUID.__dict__.__contains__", ["__slots__"], true]
    - ["uu1681003", "uuid.UUID.__dict__.__contains__", ["__str__"],   true]
    - ["uu1681004", "uuid.UUID.__dict__.__contains__", ["__repr__"],  true]
    - ["uu1681005", "uuid.UUID.__dict__.__contains__", ["__eq__"],    true]

# ---------------------------------------------------------------------------
# Table 2: comparison_and_protocol_attrs
#
# uuid.UUID implements full ordering (Comparable) and several numeric/bytes
# protocol methods.  __hash__ is defined because UUID is immutable (frozen
# by __slots__ and no __setattr__).  __int__ is defined for int(uuid).
# ---------------------------------------------------------------------------

table uuid_extra1681.comparison_and_protocol_attrs:
  description: "uuid.UUID comparison and protocol attribute dict-presence checks (wave 559 _extra1681) — uuid.UUID defines __eq__, __lt__, __hash__, __int__, __str__, __repr__ in its own __dict__; uuid.UUID does NOT define __call__ (not callable), __add__, or __iter__ (UUID is not a sequence or numeric type); __hash__ is defined because UUID is immutable; __int__ is defined to allow int(uuid_instance) to return the 128-bit integer; verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1681

  columns: [id, function, args, expected]
  rows:
    - ["uu1681010", "uuid.UUID.__dict__.__contains__", ["__call__"],  false]
    - ["uu1681011", "uuid.UUID.__dict__.__contains__", ["__eq__"],    true]
    - ["uu1681012", "uuid.UUID.__dict__.__contains__", ["__lt__"],    true]
    - ["uu1681013", "uuid.UUID.__dict__.__contains__", ["__hash__"],  true]
    - ["uu1681014", "uuid.UUID.__dict__.__contains__", ["__int__"],   true]
    - ["uu1681015", "uuid.UUID.__dict__.__contains__", ["__str__"],   true]
    - ["uu1681016", "uuid.UUID.__dict__.__contains__", ["__repr__"],  true]
    - ["uu1681017", "uuid.UUID.__dict__.__contains__", ["__add__"],   false]
    - ["uu1681018", "uuid.UUID.__dict__.__contains__", ["__iter__"],  false]
    - ["uu1681019", "uuid.UUID.__dict__.__contains__", ["__slots__"], true]

# ---------------------------------------------------------------------------
# Table 3: uuid_type_identity
#
# Verifies module and metatype identity for uuid.UUID.
# UUID is a pure-Python class; __module__ == 'uuid'.
# ---------------------------------------------------------------------------

table uuid_extra1681.uuid_type_identity:
  description: "uuid.UUID module and metatype identity checks (wave 559 _extra1681) — verifies __name__, __module__, and __class__.__name__ for uuid.UUID; UUID.__module__ == 'uuid' because it is defined in the pure-Python uuid module; UUID.__class__.__name__ == 'type' confirming it is a regular Python type object; UUID does not define __call__ in its own dict; verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1681

  columns: [id, function, args, expected]
  rows:
    - ["uu1681020", "uuid.UUID.__dict__.__contains__", ["__call__"],    false]
    - ["uu1681021", "uuid.UUID.__name__.__eq__",        ["UUID"],        true]
    - ["uu1681022", "uuid.UUID.__module__.__eq__",      ["uuid"],        true]
    - ["uu1681023", "uuid.UUID.__class__.__name__.__eq__", ["type"],     true]
