spec: threading_extra105
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra99

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra99.zspec.zsdl."
    - "This spec covers: threading.Condition and threading.Barrier method __qualname__ strings and lengths; all methods accessed via the class __dict__ to get unbound function qualnames (Wave 257)."
    - "threading.Condition.wait.__qualname__ == 'Condition.wait', len 14. Verified with Python 3.14.3."
    - "threading.Condition.wait_for.__qualname__ == 'Condition.wait_for', len 18. Verified with Python 3.14.3."
    - "threading.Condition.notify.__qualname__ == 'Condition.notify', len 16. Verified with Python 3.14.3."
    - "threading.Condition.notify_all.__qualname__ == 'Condition.notify_all', len 20. Verified with Python 3.14.3."
    - "threading.Condition.__init__.__qualname__ == 'Condition.__init__', len 18. Verified with Python 3.14.3."
    - "threading.Condition.__enter__.__qualname__ == 'Condition.__enter__', len 19. Verified with Python 3.14.3."
    - "threading.Condition.__exit__.__qualname__ == 'Condition.__exit__', len 18. Verified with Python 3.14.3."
    - "threading.Barrier.wait.__qualname__ == 'Barrier.wait', len 12. Verified with Python 3.14.3."
    - "threading.Barrier.reset.__qualname__ == 'Barrier.reset', len 13. Verified with Python 3.14.3."
    - "threading.Barrier.abort.__qualname__ == 'Barrier.abort', len 13. Verified with Python 3.14.3."
    - "threading.Barrier.__init__.__qualname__ == 'Barrier.__init__', len 16. Verified with Python 3.14.3."
    - "Note: Condition does not define acquire/release directly — those are delegated to the underlying lock; the wait/wait_for/notify/notify_all/__init__/__enter__/__exit__ methods are defined on Condition itself. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

