spec: multiprocessing_extra178
version: ">=3.9"
backend: python_module(multiprocessing.connection)

docs: https://docs.python.org/3/library/multiprocessing.html#connection-objects

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#connection-objects — Python multiprocessing connection documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/connection.py"
  notes:
    - "This spec covers: multiprocessing.connection module — multiprocessing.connection.Connection.__name__=='Connection' (len=10); multiprocessing.connection.Connection.__module__=='multiprocessing.connection'; multiprocessing.connection.Connection.__mro__.__len__()==3 (Connection > _ConnectionBase > object); multiprocessing.connection.Listener.__name__=='Listener' (len=8); multiprocessing.connection.Listener.__module__=='multiprocessing.connection'; multiprocessing.connection.Client.__name__=='Client' (len=6); multiprocessing.connection.Client.__class__.__name__=='function'."
    - "multiprocessing.connection.Connection.__name__ == 'Connection' (len=10: C-o-n-n-e-c-t-i-o-n). Connection wraps an OS-level connection handle and provides send/recv over IPC. Its MRO is [Connection, _ConnectionBase, object] giving __mro__.__len__()==3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.connection.Listener.__name__ == 'Listener' (len=8: L-i-s-t-e-n-e-r). Listener is a wrapper for a bound socket or named pipe which 'listens' for connections. Its MRO is [Listener, object] giving __mro__.__len__()==2. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.connection.Client is a function (not a class). Client.__name__ == 'Client' (len=6). Client.__class__.__name__ == 'function'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.connection.Connection class identity
#
# Connection.__name__ == 'Connection' (len=10)
# Connection.__module__ == 'multiprocessing.connection'
# Connection.__mro__.__len__() == 3  (Connection > _ConnectionBase > object)
#
# Connection subclasses _ConnectionBase which subclasses object, giving MRO
# depth of 3. New to extra178.
# ---------------------------------------------------------------------------

table multiprocessing_extra178.connection_identity:
  description: "Connection.__name__ 'Connection' len 10; __module__ 'multiprocessing.connection'; __mro__.__len__()==3; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: mpconnection178

  columns: [id, function, args, expected, description]
  rows:
    - [conn_name_eq,
       Connection.__name__.__eq__,
       ["Connection"],
       true,
       "multiprocessing.connection.Connection.__name__.__eq__('Connection') == True — Connection wraps an OS-level connection handle (file descriptor or Windows handle) and provides send/recv/poll for IPC; its __name__ is 'Connection' (10 chars: C-o-n-n-e-c-t-i-o-n); str.__eq__('Connection') returns True; new to extra178"]
    - [conn_name_len_10,
       Connection.__name__.__len__,
       [],
       10,
       "multiprocessing.connection.Connection.__name__.__len__() == 10 — 'Connection' has 10 characters: C-o-n-n-e-c-t-i-o-n; longer than 'Listener'=8 and 'Client'=6; NAME LENGTHS: Client=6 < Listener=8 < Connection=10; str.__len__() returns 10; new to extra178"]
    - [conn_module_eq,
       Connection.__module__.__eq__,
       ["multiprocessing.connection"],
       true,
       "multiprocessing.connection.Connection.__module__.__eq__('multiprocessing.connection') == True — Connection is defined in the multiprocessing.connection submodule; its __module__ is 'multiprocessing.connection'; str.__eq__('multiprocessing.connection') returns True; new to extra178"]
    - [conn_mro_len_3,
       Connection.__mro__.__len__,
       [],
       3,
       "multiprocessing.connection.Connection.__mro__.__len__() == 3 — MRO is [Connection, _ConnectionBase, object]; Connection subclasses _ConnectionBase which subclasses object; __mro__.__len__() returns 3; new to extra178"]
    - [conn_module_len,
       Connection.__module__.__len__,
       [],
       26,
       "multiprocessing.connection.Connection.__module__.__len__() == 26 — 'multiprocessing.connection' has 26 characters: multiprocessing=15 + '.'=1 + connection=10 = 26; str.__len__() returns 26; new to extra178"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.connection.Listener class identity
#
# Listener.__name__ == 'Listener' (len=8)
# Listener.__module__ == 'multiprocessing.connection'
# Listener.__mro__.__len__() == 2  (Listener > object)
#
# Listener is a direct subclass of object with MRO depth 2.
# New to extra178.
# ---------------------------------------------------------------------------

table multiprocessing_extra178.listener_identity:
  description: "Listener.__name__ 'Listener' len 8; __module__ 'multiprocessing.connection'; __mro__.__len__()==2; new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: mpconnection178

  columns: [id, function, args, expected, description]
  rows:
    - [listener_name_eq,
       Listener.__name__.__eq__,
       ["Listener"],
       true,
       "multiprocessing.connection.Listener.__name__.__eq__('Listener') == True — Listener is a wrapper for a bound socket or Windows named pipe that listens for incoming connections; its __name__ is 'Listener' (8 chars: L-i-s-t-e-n-e-r); str.__eq__('Listener') returns True; new to extra178"]
    - [listener_name_len_8,
       Listener.__name__.__len__,
       [],
       8,
       "multiprocessing.connection.Listener.__name__.__len__() == 8 — 'Listener' has 8 characters: L-i-s-t-e-n-e-r; NAME LENGTHS: Client=6 < Listener=8 < Connection=10; str.__len__() returns 8; new to extra178"]
    - [listener_module_eq,
       Listener.__module__.__eq__,
       ["multiprocessing.connection"],
       true,
       "multiprocessing.connection.Listener.__module__.__eq__('multiprocessing.connection') == True — Listener is defined in the same multiprocessing.connection submodule as Connection; its __module__ is 'multiprocessing.connection'; str.__eq__('multiprocessing.connection') returns True; new to extra178"]
    - [listener_mro_len_2,
       Listener.__mro__.__len__,
       [],
       2,
       "multiprocessing.connection.Listener.__mro__.__len__() == 2 — MRO is [Listener, object]; Listener is a direct subclass of object with no intermediate base class; shallower than Connection=3; __mro__.__len__() returns 2; new to extra178"]
    - [listener_shorter_than_connection,
       Listener.__name__.__len__,
       [],
       8,
       "multiprocessing.connection.Listener.__name__.__len__() == 8 confirming Listener (8) < Connection (10); NAME LENGTHS: Client=6 < Listener=8 < Connection=10; new to extra178"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.connection.Client function identity
#
# Client.__name__ == 'Client' (len=6)
# Client.__class__.__name__ == 'function'
#
# Client is a module-level function (not a class) that returns a Connection.
# New to extra178.
# ---------------------------------------------------------------------------

table multiprocessing_extra178.client_function_identity:
  description: "Client.__name__ 'Client' len 6; Client.__class__.__name__=='function' (not a class); new to extra178"
  kind: python_call_eq
  category: identity
  id_prefix: mpconnection178

  columns: [id, function, args, expected, description]
  rows:
    - [client_name_eq,
       Client.__name__.__eq__,
       ["Client"],
       true,
       "multiprocessing.connection.Client.__name__.__eq__('Client') == True — Client is a module-level factory function (not a class) that establishes a connection to a Listener and returns a Connection object; its __name__ is 'Client' (6 chars: C-l-i-e-n-t); str.__eq__('Client') returns True; new to extra178"]
    - [client_name_len_6,
       Client.__name__.__len__,
       [],
       6,
       "multiprocessing.connection.Client.__name__.__len__() == 6 — 'Client' has 6 characters: C-l-i-e-n-t; shortest name in this spec; NAME LENGTHS: Client=6 < Listener=8 < Connection=10; str.__len__() returns 6; new to extra178"]
    - [client_class_name_eq,
       Client.__class__.__name__.__eq__,
       ["function"],
       true,
       "multiprocessing.connection.Client.__class__.__name__.__eq__('function') == True — Client is a plain function, not a class; type(Client).__name__ is 'function'; str.__eq__('function') returns True; new to extra178"]
    - [client_class_name_len_8,
       Client.__class__.__name__.__len__,
       [],
       8,
       "multiprocessing.connection.Client.__class__.__name__.__len__() == 8 — 'function' has 8 characters: f-u-n-c-t-i-o-n; same length as 'Listener'=8; str.__len__() returns 8; new to extra178"]
    - [client_module_eq,
       Client.__module__.__eq__,
       ["multiprocessing.connection"],
       true,
       "multiprocessing.connection.Client.__module__.__eq__('multiprocessing.connection') == True — the Client function is defined in the multiprocessing.connection submodule alongside Connection and Listener; its __module__ is 'multiprocessing.connection'; str.__eq__('multiprocessing.connection') returns True; new to extra178"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra178
# ---------------------------------------------------------------------------

invariant multiprocessing_extra178.connection_name_eq:
  description: "multiprocessing.connection.Connection.__name__ == 'Connection' — IPC connection class; name len=10; new to extra178"
  category: identity
  kind: python_call_eq
  function: Connection.__name__.__eq__
  args: ["Connection"]
  expected: true

invariant multiprocessing_extra178.connection_module_eq:
  description: "multiprocessing.connection.Connection.__module__ == 'multiprocessing.connection' — defined in the connection submodule; new to extra178"
  category: identity
  kind: python_call_eq
  function: Connection.__module__.__eq__
  args: ["multiprocessing.connection"]
  expected: true

invariant multiprocessing_extra178.connection_mro_len_3:
  description: "multiprocessing.connection.Connection.__mro__.__len__() == 3 — MRO is [Connection, _ConnectionBase, object]; deeper than Listener=2; new to extra178"
  category: identity
  kind: python_call_eq
  function: Connection.__mro__.__len__
  args: []
  expected: 3

invariant multiprocessing_extra178.listener_name_len_8:
  description: "multiprocessing.connection.Listener.__name__.__len__() == 8 — 'Listener' has 8 chars; NAME LENGTHS: Client=6 < Listener=8 < Connection=10; new to extra178"
  category: identity
  kind: python_call_eq
  function: Listener.__name__.__len__
  args: []
  expected: 8

invariant multiprocessing_extra178.listener_mro_len_2:
  description: "multiprocessing.connection.Listener.__mro__.__len__() == 2 — MRO is [Listener, object]; direct subclass of object; shallower than Connection=3; new to extra178"
  category: identity
  kind: python_call_eq
  function: Listener.__mro__.__len__
  args: []
  expected: 2

invariant multiprocessing_extra178.client_name_len_6:
  description: "multiprocessing.connection.Client.__name__.__len__() == 6 — 'Client' has 6 chars; shortest name in spec; new to extra178"
  category: identity
  kind: python_call_eq
  function: Client.__name__.__len__
  args: []
  expected: 6

invariant multiprocessing_extra178.client_class_function:
  description: "multiprocessing.connection.Client.__class__.__name__ == 'function' — Client is a function not a class; new to extra178"
  category: identity
  kind: python_call_eq
  function: Client.__class__.__name__.__eq__
  args: ["function"]
  expected: true
