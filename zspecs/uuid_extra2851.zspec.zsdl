spec: uuid_extra2851
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 637 (_extra2851): __rlshift__, __rrshift__, __rpow__ dict-presence checks for uuid types."
    - "uuid.UUID is the primary type; uuid.SafeUUID is an Enum (not IntEnum) subclass."
    - "uuid.RFC_4122, uuid.RESERVED_NCS, uuid.RESERVED_MICROSOFT, uuid.RESERVED_FUTURE are plain str constants, not types."
    - "None of uuid.UUID, uuid.SafeUUID define reflected shift or power operators in their own __dict__."
    - "uuid.SafeUUID inherits from Enum (not int), so it does not pick up int's shift operators."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table uu2851.rlshift:
  description: "uuid types __rlshift__ dict-presence checks; wave 637"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2851
  columns: [id, function, args, expected]
  rows:
    - ["uu2851001", "uuid.UUID.__dict__.__contains__",     ["__rlshift__"], false]
    - ["uu2851002", "uuid.SafeUUID.__dict__.__contains__", ["__rlshift__"], false]
    - ["uu2851003", "type(uuid.uuid4()).__dict__.__contains__", ["__rlshift__"], false]
    - ["uu2851004", "type(uuid.uuid1()).__dict__.__contains__", ["__rlshift__"], false]
    - ["uu2851005", "type(uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org')).__dict__.__contains__", ["__rlshift__"], false]
    - ["uu2851006", "type(uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org')).__dict__.__contains__", ["__rlshift__"], false]

