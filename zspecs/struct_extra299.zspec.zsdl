spec: struct_extra299
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "This spec extends struct.zspec.zsdl and struct_extra.zspec.zsdl; it does NOT duplicate invariants already present in those files."
    - "struct.Struct.__name__ == 'Struct' — the class is named 'Struct'."
    - "struct.Struct.__module__ == '_struct' — the class lives in the '_struct' C extension, not the 'struct' wrapper module."
    - "struct.Struct.__bases__[0].__name__ == 'object' — Struct inherits directly from object."
    - "struct.Struct('>I').size == 4 — big-endian uint32 is 4 bytes."
    - "struct.Struct('>II').size == 8 — two big-endian uint32 fields are 8 bytes total."
    - "struct.Struct('>IH').size == 6 — uint32 (4 bytes) + uint16 (2 bytes) = 6 bytes total."
    - "struct.Struct('>I').format == '>I' — format string is stored as given."
    - "struct.iter_unpack.__name__ == 'iter_unpack' and __module__ == '_struct' (C extension)."
    - "struct.pack_into.__name__ == 'pack_into' and __module__ == '_struct' (C extension)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct class identity
# ---------------------------------------------------------------------------

invariant struct_extra299.Struct.class_name:
  description: "struct.Struct.__name__ == 'Struct'"
  category: class_metadata
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra299.Struct.module:
  description: "struct.Struct.__module__ == '_struct' — class lives in the C extension module"
  category: class_metadata
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra299.Struct.base_class_name:
  description: "struct.Struct.__bases__[0].__name__ == 'object' — Struct inherits directly from object"
  category: class_metadata
  kind: python_call_eq
  function: "Struct.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct instance — .size attribute
# ---------------------------------------------------------------------------

invariant struct_extra299.Struct.size_I:
  description: "struct.Struct('>I').size == 4 — big-endian uint32 is 4 bytes"
  category: instance_attributes
  kind: python_call_eq
  function: Struct
  args: [">I"]
  method: size.__eq__
  method_args: [4]
  expected: true

invariant struct_extra299.Struct.size_II:
  description: "struct.Struct('>II').size == 8 — two uint32 fields are 8 bytes"
  category: instance_attributes
  kind: python_call_eq
  function: Struct
  args: [">II"]
  method: size.__eq__
  method_args: [8]
  expected: true

invariant struct_extra299.Struct.size_IH:
  description: "struct.Struct('>IH').size == 6 — uint32 (4 bytes) + uint16 (2 bytes) = 6 bytes"
  category: instance_attributes
  kind: python_call_eq
  function: Struct
  args: [">IH"]
  method: size.__eq__
  method_args: [6]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct instance — .format attribute
# ---------------------------------------------------------------------------

invariant struct_extra299.Struct.format_attr:
  description: "struct.Struct('>I').format == '>I' — format string preserved as given"
  category: instance_attributes
  kind: python_call_eq
  function: Struct
  args: [">I"]
  method: format.__eq__
  method_args: [">I"]
  expected: true

# ---------------------------------------------------------------------------
# struct.iter_unpack — function identity
# ---------------------------------------------------------------------------

invariant struct_extra299.iter_unpack.name:
  description: "struct.iter_unpack.__name__ == 'iter_unpack'"
  category: function_identity
  kind: python_call_eq
  function: iter_unpack.__name__.__eq__
  args: ["iter_unpack"]
  expected: true

invariant struct_extra299.iter_unpack.module:
  description: "struct.iter_unpack.__module__ == '_struct' — lives in C extension"
  category: function_identity
  kind: python_call_eq
  function: iter_unpack.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack_into — function identity
# ---------------------------------------------------------------------------

invariant struct_extra299.pack_into.name:
  description: "struct.pack_into.__name__ == 'pack_into'"
  category: function_identity
  kind: python_call_eq
  function: pack_into.__name__.__eq__
  args: ["pack_into"]
  expected: true

invariant struct_extra299.pack_into.module:
  description: "struct.pack_into.__module__ == '_struct' — lives in C extension"
  category: function_identity
  kind: python_call_eq
  function: pack_into.__module__.__eq__
  args: ["_struct"]
  expected: true
