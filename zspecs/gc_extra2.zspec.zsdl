spec: gc_extra2
version: ">=3.4"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/gc.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "gc source: internal CPython generational GC implementation details"
    - "gc_extra.zspec.zsdl — covers collect return type, get_threshold len/value, get_objects type/nonempty, enable/disable returns None, get_count type, freeze, garbage"
  notes:
    - "This spec extends gc_extra.zspec.zsdl with coverage not already present there."
    - "gc.collect.__name__ == 'collect' — the builtin function's __name__ attribute."
    - "gc.disable.__name__ == 'disable' — verified via the attribute chain."
    - "gc.enable.__name__ == 'enable' — gc C-level built-in function name."
    - "gc.isenabled.__name__ == 'isenabled' — C-level built-in function name."
    - "gc.get_count.__name__ == 'get_count' — C-level built-in function name."
    - "gc.get_threshold.__name__ == 'get_threshold' — C-level built-in function name."
    - "gc.get_objects.__name__ == 'get_objects' — C-level built-in function name."
    - "gc.isenabled() returns a bool; __class__.__name__ == 'bool'."
    - "gc.get_count() returns a tuple; __class__.__name__ == 'tuple'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks — gc C-level built-in functions
# ---------------------------------------------------------------------------

table gc_extra2.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [collect,       collect.__name__.__eq__,       ["collect"],       true]
    - [disable,       disable.__name__.__eq__,       ["disable"],       true]
    - [enable,        enable.__name__.__eq__,        ["enable"],        true]
    - [isenabled,     isenabled.__name__.__eq__,     ["isenabled"],     true]
    - [get_count,     get_count.__name__.__eq__,     ["get_count"],     true]
    - [get_threshold, get_threshold.__name__.__eq__, ["get_threshold"], true]
    - [get_objects,   get_objects.__name__.__eq__,   ["get_objects"],   true]

# ---------------------------------------------------------------------------
# isenabled() — return type is bool
# ---------------------------------------------------------------------------

invariant gc_extra2.isenabled.return_type:
  description: "gc.isenabled().__class__.__name__ == 'bool'"
  category: isenabled
  kind: python_call_eq
  function: isenabled().__class__.__name__.__eq__
  args: ["bool"]
  expected: true

# ---------------------------------------------------------------------------
# get_count() — return type is tuple
# ---------------------------------------------------------------------------

invariant gc_extra2.get_count.return_type:
  description: "gc.get_count().__class__.__name__ == 'tuple'"
  category: get_count
  kind: python_call_eq
  function: get_count().__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
