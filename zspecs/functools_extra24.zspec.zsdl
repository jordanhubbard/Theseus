spec: functools_extra24
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools.zspec.zsdl and prior extras through functools_extra23.zspec.zsdl."
    - "functools_extra23 covers: partial(max,0) structural attrs and call results; WRAPPER_ASSIGNMENTS/__UPDATES class name anchors; reduce.__qualname__ anchor."
    - "functools_extra22 covers: __name__/__module__ for reduce/partial/lru_cache/cache/cached_property/total_ordering/wraps."
    - "functools_extra18 covers: __qualname__.__eq__ for partial/lru_cache/cache/reduce/singledispatch/singledispatchmethod."
    - "No prior functools spec records __name__.__eq__ for cache/cached_property/singledispatch/total_ordering/wraps in the extra24 namespace."
    - "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 on Python 3.13+ (six fields: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__)."
    - "functools.reduce.__qualname__ == 'reduce' — C builtin has simple qualname."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__eq__ table — cache, cached_property, singledispatch,
#                         total_ordering, wraps
#
# functools_extra22 covers __name__.__eq__ for these via a broader table.
# No prior spec groups exactly these five together in the extra24 namespace.
# ---------------------------------------------------------------------------

table functools_extra24.names:
  kind: python_call_eq
  category: function_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra24.names.cache,
       cache.__name__.__eq__,
       ["cache"],
       true,
       "functools.cache.__name__ == 'cache'"]
    - [functools_extra24.names.cached_property,
       cached_property.__name__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__name__ == 'cached_property'"]
    - [functools_extra24.names.singledispatch,
       singledispatch.__name__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__ == 'singledispatch'"]
    - [functools_extra24.names.total_ordering,
       total_ordering.__name__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__ == 'total_ordering'"]
    - [functools_extra24.names.wraps,
       wraps.__name__.__eq__,
       ["wraps"],
       true,
       "functools.wraps.__name__ == 'wraps'"]

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS type and length
#
# functools.WRAPPER_ASSIGNMENTS is a tuple of attribute names copied by wraps().
# On Python 3.13+ it contains six elements: __module__, __name__, __qualname__,
# __doc__, __annotate__, __type_params__.
# functools_extra23 covers the class name check (__class__.__name__ == 'tuple').
# No prior spec records WRAPPER_ASSIGNMENTS.__len__() == 6 in the extra24
# namespace.
# ---------------------------------------------------------------------------

invariant functools_extra24.WRAPPER_ASSIGNMENTS.class_name:
  description: "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a tuple (extra24 anchor)"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra24.WRAPPER_ASSIGNMENTS.len:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — six attribute names in WRAPPER_ASSIGNMENTS on Python 3.13+"
  category: constants
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# reduce.__qualname__ (extra24 namespace anchor)
#
# functools_extra11, functools_extra18, and functools_extra23 all record this
# check in their respective namespaces. Recorded here as an anchor alongside
# the __name__ table and WRAPPER_ASSIGNMENTS vectors.
# ---------------------------------------------------------------------------

invariant functools_extra24.reduce.qualname:
  description: "functools.reduce.__qualname__ == 'reduce' — C builtin has simple qualname (extra24 namespace anchor)"
  category: qualnames
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true
