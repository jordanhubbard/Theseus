spec: itertools_extra165
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.islice.__bases__[0].__name__ 'object'; itertools.starmap.__bases__[0].__name__ 'object'; itertools.compress.__bases__[0].__name__ 'object'; itertools.accumulate.__bases__[0].__name__ 'object'; itertools.islice.__name__ 'islice'; itertools.starmap.__name__ 'starmap'; itertools.compress.__name__ 'compress'; itertools.accumulate.__name__ 'accumulate' (Wave 294)."
    - "itertools.islice.__bases__[0].__name__ == 'object' — itertools.islice is a C extension type in itertoolsmodule.c that makes an iterator that returns selected elements from an iterable; it inherits directly from object; its __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "itertools.starmap.__bases__[0].__name__ == 'object' — itertools.starmap is a C extension type that applies a function to each element of an iterable using argument unpacking (equivalent to (func(*args) for args in iterable)); it inherits directly from object; its __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "itertools.compress.__bases__[0].__name__ == 'object' — itertools.compress is a C extension type that filters data by selectors (returning only elements where the corresponding selector is true); it inherits directly from object; its __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "itertools.accumulate.__bases__[0].__name__ == 'object' — itertools.accumulate is a C extension type that produces running totals or other accumulated results; it inherits directly from object; its __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.islice and itertools.starmap class identity and __bases__
#
# Wave 294 theme: itertools.islice and itertools.starmap C extension type
# identity — __bases__, __name__, and __module__.
#
# itertools.islice.__bases__[0].__name__ == 'object'
# itertools.islice.__name__ == 'islice'
# itertools.islice.__module__ == 'itertools'
# itertools.starmap.__bases__[0].__name__ == 'object'
# itertools.starmap.__name__ == 'starmap'
#
# itertools.islice(iterable, stop) or islice(iterable, start, stop[, step])
# makes an iterator that returns selected elements from an iterable. Like a
# slice of a list but works on any iterable. It is a C extension type in
# itertoolsmodule.c that inherits directly from object.
# itertools.starmap(function, iterable) applies the function to each tuple
# of arguments taken from the iterable; equivalent to
# (func(*args) for args in iterable). Also a C extension type inheriting from
# object. New to extra165.
# ---------------------------------------------------------------------------

table itertools_extra165.islice_and_starmap_identity:
  description: "itertools: islice.__bases__[0].__name__ 'object', islice.__name__ 'islice', islice.__module__ 'itertools', starmap.__bases__[0].__name__ 'object', starmap.__name__ 'starmap'; wave 294; new to extra165"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsisi165

  columns: [id, function, args, expected, description]
  rows:
    - ["islice_bases_0_object",
       "islice.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.islice.__bases__[0].__name__.__eq__('object') == True — islice is a C extension type in itertoolsmodule.c that returns selected elements from an iterable using start/stop/step semantics without materializing the full sequence; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra165"]
    - [islice_name_eq_islice,
       "islice.__name__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — islice is a C extension type in itertoolsmodule.c; its type __name__ attribute is 'islice'; str.__eq__('islice') returns True; new to extra165"]
    - [islice_module_eq_itertools,
       "islice.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.islice.__module__.__eq__('itertools') == True — islice is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra165"]
    - ["starmap_bases_0_object",
       "starmap.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.starmap.__bases__[0].__name__.__eq__('object') == True — starmap is a C extension type in itertoolsmodule.c that applies a function to each tuple of arguments from an iterable using argument unpacking (equivalent to func(*args) for args in iterable); it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra165"]
    - [starmap_name_eq_starmap,
       "starmap.__name__.__eq__",
       ["starmap"],
       true,
       "itertools.starmap.__name__.__eq__('starmap') == True — starmap is a C extension type in itertoolsmodule.c; its type __name__ attribute is 'starmap'; str.__eq__('starmap') returns True; new to extra165"]

# ---------------------------------------------------------------------------
# Table 2: itertools.compress and itertools.accumulate class identity and __bases__
#
# Wave 294 theme: itertools.compress and itertools.accumulate C extension type
# identity — __bases__, __name__, __module__, and __class__.
#
# itertools.compress.__bases__[0].__name__ == 'object'
# itertools.compress.__name__ == 'compress'
# itertools.compress.__module__ == 'itertools'
# itertools.accumulate.__bases__[0].__name__ == 'object'
# itertools.accumulate.__name__ == 'accumulate'
#
# itertools.compress(data, selectors) filters data by selectors, returning only
# elements where the corresponding selector evaluates as true; equivalent to
# (d for d, s in zip(data, selectors) if s). It is a C extension type in
# itertoolsmodule.c that inherits directly from object.
# itertools.accumulate(iterable[, func, *, initial=None]) produces cumulative
# results of a binary function (default: addition), generating running totals
# or other accumulated values. Also a C extension type inheriting from object.
# New to extra165.
# ---------------------------------------------------------------------------

table itertools_extra165.compress_and_accumulate_identity:
  description: "itertools: compress.__bases__[0].__name__ 'object', compress.__name__ 'compress', compress.__module__ 'itertools', accumulate.__bases__[0].__name__ 'object', accumulate.__name__ 'accumulate'; wave 294; new to extra165"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscai165

  columns: [id, function, args, expected, description]
  rows:
    - ["compress_bases_0_object",
       "compress.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.compress.__bases__[0].__name__.__eq__('object') == True — compress is a C extension type in itertoolsmodule.c that filters data by selectors returning only elements where the corresponding selector is true; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra165"]
    - [compress_name_eq_compress,
       "compress.__name__.__eq__",
       ["compress"],
       true,
       "itertools.compress.__name__.__eq__('compress') == True — compress is a C extension type in itertoolsmodule.c; its type __name__ attribute is 'compress'; str.__eq__('compress') returns True; new to extra165"]
    - [compress_module_eq_itertools,
       "compress.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.compress.__module__.__eq__('itertools') == True — compress is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra165"]
    - ["accumulate_bases_0_object",
       "accumulate.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.accumulate.__bases__[0].__name__.__eq__('object') == True — accumulate is a C extension type in itertoolsmodule.c that produces running totals or other accumulated results using a binary function; it inherits directly from object; its __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra165"]
    - [accumulate_name_eq_accumulate,
       "accumulate.__name__.__eq__",
       ["accumulate"],
       true,
       "itertools.accumulate.__name__.__eq__('accumulate') == True — accumulate is a C extension type in itertoolsmodule.c; its type __name__ attribute is 'accumulate'; str.__eq__('accumulate') returns True; new to extra165"]

