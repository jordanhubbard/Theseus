spec: io_extra751
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

docs:
  summary: Verifies __qualname__ attributes of io.IOBase methods
  tags: [io, qualname, stdlib]

provenance:
  derived_from:
    - https://docs.python.org/3/library/io.html#io.IOBase
  not_derived_from: []
  notes:
    - Covers IOBase method qualnames to detect renaming or refactoring in CPython
  created_at: "2026-04-12"

table io_extra751.name:
  description: io.IOBase method __qualname__ equality checks
  kind: python_call_eq
  category: qualname
  id_prefix: io751xx
  columns: [id, function, args, expected]
  rows:
    - [io751xx001, io.IOBase.close.__qualname__.__eq__, ["IOBase.close"], true]
    - [io751xx002, io.IOBase.flush.__qualname__.__eq__, ["IOBase.flush"], true]
    - [io751xx003, io.IOBase.readable.__qualname__.__eq__, ["IOBase.readable"], true]
    - [io751xx004, io.IOBase.readline.__qualname__.__eq__, ["IOBase.readline"], true]
    - [io751xx005, io.IOBase.readlines.__qualname__.__eq__, ["IOBase.readlines"], true]
    - [io751xx006, io.IOBase.seek.__qualname__.__eq__, ["IOBase.seek"], true]
    - [io751xx007, io.IOBase.seekable.__qualname__.__eq__, ["IOBase.seekable"], true]
    - [io751xx008, io.IOBase.tell.__qualname__.__eq__, ["IOBase.tell"], true]
    - [io751xx009, io.IOBase.truncate.__qualname__.__eq__, ["IOBase.truncate"], true]
    - [io751xx010, io.IOBase.writable.__qualname__.__eq__, ["IOBase.writable"], true]
    - [io751xx011, io.IOBase.writelines.__qualname__.__eq__, ["IOBase.writelines"], true]
    - [io751xx012, io.IOBase.__del__.__qualname__.__eq__, ["IOBase.__del__"], true]
