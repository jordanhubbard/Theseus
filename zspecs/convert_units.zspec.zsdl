spec: convert_units
version: ">=2.3.0"
backend: node(convert-units)

docs: https://github.com/convert-units/convert-units#readme

provenance:
  derived_from:
    - "convert-units README — https://github.com/convert-units/convert-units#readme"
    - "Test vectors verified with convert-units via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "convert-units source"
  notes:
    - "Unit-conversion library covering length, volume, mass, time, temperature, pressure, current, and more."
    - "Install: npm install convert-units"
    - "Pattern: convert(N).from(unit).to(targetUnit) — three-step chain returning a number."
    - "Module export IS the converter factory; v2 is ESM with a CJS shim under .default."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Throws on unknown units; pure conversion otherwise."
  stderr: "null"
  stickiness: "N/A — each chain is a fresh conversion."
  codes: {}

# Length
invariant convert_units.km_to_m:
  description: "1 km == 1000 m"
  category: length
  kind: node_chain_eq
  entry: module

  entry_args: [1]
  chain:
    - {method: from, args: ["km"]}
    - {method: to, args: ["m"]}
  expected: 1000

invariant convert_units.cm_to_m:
  description: "100 cm == 1 m"
  category: length
  kind: node_chain_eq
  entry: module

  entry_args: [100]
  chain:
    - {method: from, args: ["cm"]}
    - {method: to, args: ["m"]}
  expected: 1

invariant convert_units.mile_to_km:
  description: "1 mile ≈ 1.6093 km (4 decimals — float arithmetic adds tail digits)"
  category: length
  kind: node_chain_eq
  entry: module
  entry_args: [1]
  chain:
    - {method: from, args: ["mi"]}
    - {method: to, args: ["km"]}
    - {method: toFixed, args: [4]}
  expected: "1.6093"

# Time
invariant convert_units.hour_to_seconds:
  description: "1 hour == 3600 s"
  category: time
  kind: node_chain_eq
  entry: module

  entry_args: [1]
  chain:
    - {method: from, args: ["h"]}
    - {method: to, args: ["s"]}
  expected: 3600

invariant convert_units.day_to_hours:
  description: "1 day == 24 h"
  category: time
  kind: node_chain_eq
  entry: module

  entry_args: [1]
  chain:
    - {method: from, args: ["d"]}
    - {method: to, args: ["h"]}
  expected: 24

# Temperature — non-linear
invariant convert_units.celsius_zero_fahrenheit:
  description: "0°C == 32°F"
  category: temperature
  kind: node_chain_eq
  entry: module

  entry_args: [0]
  chain:
    - {method: from, args: ["C"]}
    - {method: to, args: ["F"]}
  expected: 32

invariant convert_units.celsius_hundred_fahrenheit:
  description: "100°C == 212°F"
  category: temperature
  kind: node_chain_eq
  entry: module

  entry_args: [100]
  chain:
    - {method: from, args: ["C"]}
    - {method: to, args: ["F"]}
  expected: 212

invariant convert_units.celsius_to_kelvin:
  description: "0°C == 273.15 K"
  category: temperature
  kind: node_chain_eq
  entry: module

  entry_args: [0]
  chain:
    - {method: from, args: ["C"]}
    - {method: to, args: ["K"]}
  expected: 273.15

# Mass
invariant convert_units.lb_to_kg:
  description: "1 lb ≈ 0.4536 kg (4 decimals)"
  category: mass
  kind: node_chain_eq
  entry: module

  entry_args: [1]
  chain:
    - {method: from, args: ["lb"]}
    - {method: to, args: ["kg"]}
    - {method: toFixed, args: [4]}
  expected: "0.4536"

invariant convert_units.kg_to_g:
  description: "1 kg == 1000 g"
  category: mass
  kind: node_chain_eq
  entry: module

  entry_args: [1]
  chain:
    - {method: from, args: ["kg"]}
    - {method: to, args: ["g"]}
  expected: 1000

# Pressure
invariant convert_units.bar_to_pascal:
  description: "1 bar == 100,000 Pa"
  category: pressure
  kind: node_chain_eq
  entry: module

  entry_args: [1]
  chain:
    - {method: from, args: ["bar"]}
    - {method: to, args: ["Pa"]}
  expected: 100000

# Identity
invariant convert_units.same_unit_identity:
  description: "Same-unit conversion is identity"
  category: identity
  kind: node_chain_eq
  entry: module

  entry_args: [42]
  chain:
    - {method: from, args: ["m"]}
    - {method: to, args: ["m"]}
  expected: 42

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T08:27:16Z
  iterations: 1
  pass_count: 12
  fail_count: 0
  total_invariants: 12
  notes: Synthesis succeeded in 1 iteration(s). 12 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
