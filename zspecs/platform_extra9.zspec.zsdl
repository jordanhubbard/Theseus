spec: platform_extra9
version: ">=3.9"
backend: python_module(platform)

docs: https://docs.python.org/3/library/platform.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/platform.html — Python platform documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/platform.py"
  notes:
    - "This spec extends platform_extra8.zspec.zsdl."
    - "Prior specs covered: function __name__ equality and __module__ lengths for all major callables; __qualname__ equality (extra4); return types for system/machine/processor/release/version/python_implementation; uname_result type/field types; python_build shape; uname().__class__.__name__ == 'uname_result' (extra8 standalone)."
    - "This spec covers: platform.__name__.__len__()==8 ('platform'); function __qualname__.__len__() for system/node/release/version/machine/processor/python_version/python_implementation (all novel __len__ checks); platform.uname_result.__dict__.__class__.__name__.__len__()==12 ('mappingproxy'); platform.uname_result.__mro__.__len__()==4 (SURPRISE: includes uname_result_base intermediate); platform.uname_result.__bases__[0].__name__.__len__()==17 ('uname_result_base' — SURPRISE: not 11); platform.uname().__class__.__name__.__len__()==12 ('uname_result' — SURPRISE: 12 not 11); platform.system().__class__.__name__.__len__()==3 ('str'); platform.python_version().__class__.__name__.__len__()==3 ('str')."
    - "SURPRISE 1: platform.uname_result.__mro__.__len__() == 4, not 3. The MRO is: uname_result → uname_result_base → tuple → object (4 elements). Python 3.12 introduced an intermediate base class uname_result_base."
    - "SURPRISE 2: platform.uname_result.__bases__[0].__name__ == 'uname_result_base' (len 17), not 'uname_result' or anything of length 11 as the prompt suggested."
    - "SURPRISE 3: platform.uname().__class__.__name__ == 'uname_result' — len is 12, not 11 as suggested. Counted: u-n-a-m-e-_-r-e-s-u-l-t = 12 characters."
    - "platform.__name__ == 'platform' (len 8). Verified."
    - "platform.system.__qualname__ == 'system' (len 6). Verified."
    - "platform.node.__qualname__ == 'node' (len 4). Verified."
    - "platform.release.__qualname__ == 'release' (len 7). Verified."
    - "platform.version.__qualname__ == 'version' (len 7). Verified."
    - "platform.machine.__qualname__ == 'machine' (len 7). Verified."
    - "platform.processor.__qualname__ == 'processor' (len 9). Verified."
    - "platform.python_version.__qualname__ == 'python_version' (len 14). Verified."
    - "platform.python_implementation.__qualname__ == 'python_implementation' (len 21). Verified."
    - "platform.uname_result.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Verified."
    - "platform.uname_result.__mro__.__len__() == 4. Verified. MRO: uname_result → uname_result_base → tuple → object."
    - "platform.uname_result.__bases__[0].__name__ == 'uname_result_base' (len 17). Verified."
    - "platform.uname().__class__.__name__ == 'uname_result' (len 12). Verified."
    - "platform.system().__class__.__name__ == 'str' (len 3). Verified."
    - "platform.python_version().__class__.__name__ == 'str' (len 3). Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: function __qualname__.__len__() for 8 platform callables
#
# Prior specs (extra4) check __qualname__ equality for these functions.
# No prior platform spec checks __qualname__.__len__() for any of them.
# Lengths: system(6), node(4), release(7), version(7), machine(7),
#          processor(9), python_version(14), python_implementation(21).
# All verified at runtime.
# ---------------------------------------------------------------------------

table platform_extra9.function_qualname_lengths:
  description: "platform function __qualname__.__len__() for 8 callables — system/node/release/version/machine/processor/python_version/python_implementation"
  kind: python_call_eq
  category: function_attrs
  id_prefix: pfql9

  columns: [id, function, args, expected]
  rows:
    - [system,                system.__qualname__.__len__,                [], 6]
    - [node,                  node.__qualname__.__len__,                  [], 4]
    - [release,               release.__qualname__.__len__,               [], 7]
    - [version,               version.__qualname__.__len__,               [], 7]
    - [machine,               machine.__qualname__.__len__,               [], 7]
    - [processor,             processor.__qualname__.__len__,             [], 9]
    - [python_version,        python_version.__qualname__.__len__,        [], 14]
    - [python_implementation, python_implementation.__qualname__.__len__, [], 21]

# ---------------------------------------------------------------------------
# Table: return type __class__.__name__.__len__() for runtime call results
#
# platform.system() and platform.python_version() both return str (len 3).
# platform.uname() returns uname_result (len 12).
# No prior platform spec checks __class__.__name__.__len__() on these
# call results. Verified at runtime.
# ---------------------------------------------------------------------------

table platform_extra9.return_class_name_lengths:
  description: "Return type __class__.__name__.__len__() for system() (3,'str'), python_version() (3,'str'), uname() (12,'uname_result')"
  kind: python_call_eq
  category: runtime
  id_prefix: prcnl9

  columns: [id, function, args, expected]
  rows:
    - [system_cls,          "system().__class__.__name__.__len__",          [], 3]
    - [python_version_cls,  "python_version().__class__.__name__.__len__",  [], 3]
    - [uname_cls,           "uname().__class__.__name__.__len__",           [], 12]

# ---------------------------------------------------------------------------
# Standalone: platform.__name__.__len__() == 8
#
# platform.__name__ == 'platform'. len('platform') == 8. No prior platform
# spec checks __name__.__len__() on the module itself. Verified.
# ---------------------------------------------------------------------------

invariant platform_extra9.module_name_len:
  description: "platform.__name__.__len__() == 8 — the module name 'platform' has 8 characters"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Standalone: platform.uname_result.__dict__.__class__.__name__.__len__() == 12
#
# The class dict of a C-adjacent/named-tuple derived class is a mappingproxy.
# len('mappingproxy') == 12. No prior platform spec checks __dict__.__class__
# .__name__.__len__() for uname_result. Verified.
# ---------------------------------------------------------------------------

invariant platform_extra9.uname_result.dict_class_name_len:
  description: "platform.uname_result.__dict__.__class__.__name__.__len__() == 12 — class dict is a 'mappingproxy' (len 12)"
  category: type_attrs
  kind: python_call_eq
  function: uname_result.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Standalone: platform.uname_result.__mro__.__len__() == 4
#
# SURPRISE: uname_result.__mro__ has 4 entries, not 3. In Python 3.12,
# platform introduces uname_result_base as an intermediate base:
# uname_result → uname_result_base → tuple → object. Verified.
# ---------------------------------------------------------------------------

invariant platform_extra9.uname_result.mro_len:
  description: "platform.uname_result.__mro__.__len__() == 4 — MRO is uname_result → uname_result_base → tuple → object"
  category: type_attrs
  kind: python_call_eq
  function: uname_result.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: platform.uname_result.__bases__[0].__name__.__len__() == 17
#
# SURPRISE: uname_result.__bases__[0] is uname_result_base, not tuple.
# len('uname_result_base') == 17. The prompt suggested 11 — actual is 17.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant platform_extra9.uname_result.base_name_len:
  description: "platform.uname_result.__bases__[0].__name__.__len__() == 17 — base is 'uname_result_base' (17 chars, not tuple)"
  category: type_attrs
  kind: python_call_eq
  "function": "uname_result.__bases__[0].__name__.__len__"
  args: []
  expected: 17
