spec: hashlib_extra269
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha3module.c"
    - "hashlib_extra268.zspec.zsdl — covers sha3_256/sha3_512/shake_128/shake_256 constructor __name__ and __class__.__name__; scrypt/pbkdf2_hmac kdf identity; algorithms_available/algorithms_guaranteed class names."
    - "hashlib_extra267.zspec.zsdl — covers sha256/sha512/md5/sha1 constructor __name__ and __class__.__name__; hexdigest length; known test vectors."
    - "hashlib_extra266.zspec.zsdl — covers hashlib module identity (__name__, __package__, __spec__, __loader__), __all__ type, and new/__hash_new function identity."
    - "hashlib_extra107.zspec.zsdl — covers HASH class identity, HASH method qualname lengths, hash algorithm digest_size and block_size values."
    - "hashlib.zspec.zsdl — covers sha256/sha1/md5/sha512/sha3_256/sha3_512/blake2b/blake2s known vectors."
  notes:
    - "type(hashlib.sha256()).__name__ == 'HASH' — the C-level HASH class returned by sha256(). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "type(hashlib.sha256()).update.__name__ == 'update' and __class__.__name__ == 'method_descriptor' — HASH.update is a C method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "type(hashlib.sha256()).digest.__name__ == 'digest' and __class__.__name__ == 'method_descriptor' — HASH.digest is a C method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "type(hashlib.sha256()).hexdigest.__name__ == 'hexdigest' and __class__.__name__ == 'method_descriptor' — HASH.hexdigest is a C method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "type(hashlib.sha256()).copy.__name__ == 'copy' and __class__.__name__ == 'method_descriptor' — HASH.copy is a C method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.new.__name__ == '__hash_new' — hashlib.new is a wrapped function whose __name__ is '__hash_new', not 'new'. __module__ == 'hashlib', __class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha3_256.__module__ == '_hashlib' — SHA-3 variants are backed by OpenSSL (_hashlib C extension). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.file_digest.__name__ == 'file_digest' and __module__ == 'hashlib' and __class__.__name__ == 'function' — file_digest is a pure-Python function added in Python 3.11. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HASH class method identity — update, digest, hexdigest, copy
# All four are method_descriptor objects on the HASH C-level type from _hashlib.
# Accessed via type(hashlib.sha256()).method — the HASH class itself.
# HASH.__name__ == 'HASH', HASH.__module__ == '_hashlib'.
# ---------------------------------------------------------------------------

table hashlib_extra269.HASH_method_name_identity:
  description: "HASH class method __name__ equality — update/digest/hexdigest/copy all have __name__ equal to their method name; all are C-level method_descriptor objects on the HASH type from _hashlib; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashHASH269

  columns: [id, function, args, expected, description]
  rows:
    - [update_name,    sha256.__class__.update.__name__.__eq__,    ["update"],    true, "HASH.update.__name__ == 'update' — C method_descriptor on HASH class"]
    - [digest_name,    sha256.__class__.digest.__name__.__eq__,    ["digest"],    true, "HASH.digest.__name__ == 'digest' — C method_descriptor on HASH class"]
    - [hexdigest_name, sha256.__class__.hexdigest.__name__.__eq__, ["hexdigest"], true, "HASH.hexdigest.__name__ == 'hexdigest' — C method_descriptor on HASH class"]
    - [copy_name,      sha256.__class__.copy.__name__.__eq__,      ["copy"],      true, "HASH.copy.__name__ == 'copy' — C method_descriptor on HASH class"]
    - [update_class,   sha256.__class__.update.__class__.__name__.__eq__, ["method_descriptor"], true, "HASH.update.__class__.__name__ == 'method_descriptor' — C-level descriptor"]

# ---------------------------------------------------------------------------
# SHA-3 and SHAKE constructor __module__ identity — all from _hashlib
# sha3_256, sha3_512, shake_128, shake_256 are OpenSSL-backed builtins
# with __module__ == '_hashlib' (the C extension module).
# ---------------------------------------------------------------------------

table hashlib_extra269.sha3_shake_module_identity:
  description: "hashlib sha3_256/sha3_512/shake_128/shake_256 constructor __module__ == '_hashlib' — all OpenSSL-backed C builtins from the _hashlib extension; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashsha3mod269

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_module,  sha3_256.__module__.__eq__,  ["_hashlib"], true, "hashlib.sha3_256.__module__ == '_hashlib' — OpenSSL-backed SHA-3/256 from C extension"]
    - [sha3_512_module,  sha3_512.__module__.__eq__,  ["_hashlib"], true, "hashlib.sha3_512.__module__ == '_hashlib' — OpenSSL-backed SHA-3/512 from C extension"]
    - [shake_128_module, shake_128.__module__.__eq__, ["_hashlib"], true, "hashlib.shake_128.__module__ == '_hashlib' — OpenSSL-backed SHAKE-128 from C extension"]
    - [shake_256_module, shake_256.__module__.__eq__, ["_hashlib"], true, "hashlib.shake_256.__module__ == '_hashlib' — OpenSSL-backed SHAKE-256 from C extension"]
    - [sha3_256_class,   sha3_256.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "hashlib.sha3_256.__class__.__name__ == 'builtin_function_or_method' — C-level constructor"]

# ---------------------------------------------------------------------------
# hashlib.new identity — hashlib.new.__name__ == '__hash_new'
# hashlib.new is a wrapper function in Lib/hashlib.py; its __name__ is
# '__hash_new' (not 'new') because it is defined as __hash_new internally.
# __module__ == 'hashlib', __class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

invariant hashlib_extra269.new_name_eq:
  description: "hashlib.new.__name__ == '__hash_new' — hashlib.new is a Python wrapper function whose internal __name__ is '__hash_new'; not 'new'; __module__ == 'hashlib'; __class__.__name__ == 'function'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: new.__name__.__eq__
  args: ["__hash_new"]
  expected: true

invariant hashlib_extra269.new_module_eq:
  description: "hashlib.new.__module__ == 'hashlib' — the new/__hash_new wrapper is defined in Lib/hashlib.py; pure-Python function in the hashlib module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra269.new_class_eq:
  description: "hashlib.new.__class__.__name__ == 'function' — hashlib.new/__hash_new is a pure-Python function (not a C builtin); __class__.__name__ is 'function'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: new.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest identity (Python 3.11+)
# hashlib.file_digest is a pure-Python function in Lib/hashlib.py.
# __name__ == 'file_digest', __module__ == 'hashlib',
# __class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

invariant hashlib_extra269.file_digest_name_eq:
  description: "hashlib.file_digest.__name__ == 'file_digest' — pure-Python function added in Python 3.11 in Lib/hashlib.py; hashes a file object using a given digest; __name__ matches 'file_digest'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: file_digest.__name__.__eq__
  args: ["file_digest"]
  expected: true

invariant hashlib_extra269.file_digest_module_eq:
  description: "hashlib.file_digest.__module__ == 'hashlib' — file_digest is defined in Lib/hashlib.py; not in the _hashlib C extension; __module__ is 'hashlib'; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: file_digest.__module__.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra269.file_digest_class_eq:
  description: "hashlib.file_digest.__class__.__name__ == 'function' — file_digest is a pure-Python function (not a C builtin); added in Python 3.11 to hash file-like objects; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: file_digest.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# HASH method qualname identity — HASH.update/digest/hexdigest/copy
# All have qualname == 'HASH.<method>' confirming the HASH class prefix.
# ---------------------------------------------------------------------------

invariant hashlib_extra269.HASH_update_qualname_eq:
  description: "HASH.update.__qualname__ == 'HASH.update' — C method_descriptor qualname on the HASH class from _hashlib; 'HASH.' prefix confirms class membership; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha256.__class__.update.__qualname__.__eq__
  args: ["HASH.update"]
  expected: true

invariant hashlib_extra269.HASH_digest_qualname_eq:
  description: "HASH.digest.__qualname__ == 'HASH.digest' — C method_descriptor qualname on the HASH class from _hashlib; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha256.__class__.digest.__qualname__.__eq__
  args: ["HASH.digest"]
  expected: true

invariant hashlib_extra269.HASH_hexdigest_qualname_eq:
  description: "HASH.hexdigest.__qualname__ == 'HASH.hexdigest' — C method_descriptor qualname on the HASH class from _hashlib; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha256.__class__.hexdigest.__qualname__.__eq__
  args: ["HASH.hexdigest"]
  expected: true

invariant hashlib_extra269.HASH_copy_qualname_eq:
  description: "HASH.copy.__qualname__ == 'HASH.copy' — C method_descriptor qualname on the HASH class from _hashlib; copy() returns an independent clone of the hash state; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha256.__class__.copy.__qualname__.__eq__
  args: ["HASH.copy"]
  expected: true
