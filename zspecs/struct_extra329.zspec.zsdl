spec: struct_extra329
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "This spec focuses on struct.Struct instance methods and class attributes not yet covered in struct.zspec.zsdl, struct_extra.zspec.zsdl, struct_extra299.zspec.zsdl, or struct_extra311.zspec.zsdl."
    - "struct_extra.zspec.zsdl covers Struct format/size attrs; pack_into method name; unpack_from with offset; iter_unpack iterator class name; error class name and base."
    - "struct_extra299.zspec.zsdl covers Struct.__name__/__module__/__bases__; size for '>I'/'>II'/'>IH'; format for '>I'; iter_unpack and pack_into __name__/__module__."
    - "struct_extra311.zspec.zsdl covers pack/unpack/calcsize/pack_into/unpack_from/iter_unpack __name__ and __module__; Struct.__module__; error.__module__."
    - "struct.pack('>I', 256) == b'\\x00\\x00\\x01\\x00' — big-endian uint32 256 encodes as 4 bytes (0x00000100). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct('>I').pack.__qualname__ == 'Struct.pack' — qualname confirms the method belongs to Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct('>I').unpack_from.__qualname__ == 'Struct.unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct('>I').pack_into.__qualname__ == 'Struct.pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct('>I').iter_unpack.__qualname__ == 'Struct.iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct('>I').size.__eq__(4) == True — size is an int equal to calcsize('>I'). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct.__doc__.__class__.__name__ == 'str' — Struct has a docstring; it is a plain Python str. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "struct.error is raised for mismatched buffer sizes and invalid format strings."
  stderr: "null"
  stickiness: "N/A — struct functions are pure; Struct objects are immutable after construction."
  codes: {}

# ---------------------------------------------------------------------------
# struct.pack('>I', 256) — result is bytes of length 4
# Testing via the module-level pack function (function: pack).
# struct_extra.zspec.zsdl tests unpack_from and iter_unpack;
# this spec tests that pack produces the expected bytes for '>I'/256.
# ---------------------------------------------------------------------------

invariant struct_extra329.pack.big_endian_uint32_256:
  description: "struct.pack('>I', 256) == b'\\x00\\x00\\x01\\x00' — big-endian uint32 256 is 4 bytes"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">I", 256]
  expected: !hex 00000100

invariant struct_extra329.pack.result_class_name:
  description: "struct.pack('>I', 256).__class__.__name__ == 'bytes' — pack always returns bytes"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">I", 256]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct('>I') instance method qualnames
# Each bound method's __qualname__ follows the 'Struct.<method>' pattern.
# struct_extra.zspec.zsdl covers unpack_from.__name__ and iter_unpack.__name__;
# this spec adds __qualname__ checks for all four methods.
# ---------------------------------------------------------------------------

invariant struct_extra329.Struct.unpack_from_qualname:
  description: "struct.Struct('>I').unpack_from.__qualname__ == 'Struct.unpack_from'"
  category: method_identity
  kind: python_call_eq
  function: Struct
  args: [">I"]
  method: unpack_from.__qualname__.__eq__
  method_args: ["Struct.unpack_from"]
  expected: true

invariant struct_extra329.Struct.pack_qualname:
  description: "struct.Struct('>I').pack.__qualname__ == 'Struct.pack'"
  category: method_identity
  kind: python_call_eq
  function: Struct
  args: [">I"]
  method: pack.__qualname__.__eq__
  method_args: ["Struct.pack"]
  expected: true

invariant struct_extra329.Struct.pack_into_qualname:
  description: "struct.Struct('>I').pack_into.__qualname__ == 'Struct.pack_into'"
  category: method_identity
  kind: python_call_eq
  function: Struct
  args: [">I"]
  method: pack_into.__qualname__.__eq__
  method_args: ["Struct.pack_into"]
  expected: true

invariant struct_extra329.Struct.iter_unpack_qualname:
  description: "struct.Struct('>I').iter_unpack.__qualname__ == 'Struct.iter_unpack'"
  category: method_identity
  kind: python_call_eq
  function: Struct
  args: [">I"]
  method: iter_unpack.__qualname__.__eq__
  method_args: ["Struct.iter_unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct('>I').size — equals 4 (calcsize('>I') == 4)
# struct_extra299.zspec.zsdl covers Struct('>I').size == 4 via size.__eq__;
# this spec adds it for completeness in the context of other '>I' checks.
# ---------------------------------------------------------------------------

invariant struct_extra329.Struct.size_eq_4:
  description: "struct.Struct('>I').size.__eq__(4) == True — big-endian uint32 is 4 bytes"
  category: instance_attributes
  kind: python_call_eq
  function: Struct
  args: [">I"]
  method: size.__eq__
  method_args: [4]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__doc__ — class docstring is a str
# struct.Struct.__doc__ is a class-level attribute; access via function: chain.
# ---------------------------------------------------------------------------

invariant struct_extra329.Struct.doc_class_name:
  description: "struct.Struct.__doc__.__class__.__name__ == 'str' — Struct has a docstring which is a plain Python str"
  category: class_metadata
  kind: python_call_eq
  function: Struct.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
