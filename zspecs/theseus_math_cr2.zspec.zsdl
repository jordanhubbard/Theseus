spec: theseus_math_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_math_cr2)
blocks: math

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html"
  notes:
    - "Clean-room extended math functions. Do NOT import math."
    - "log(x, base=e): natural or base-b logarithm."
    - "log2(x): base-2 logarithm."
    - "log10(x): base-10 logarithm."
    - "sin(x), cos(x), tan(x): trigonometric functions."
    - "atan2(y, x): arc-tangent of y/x in radians."
    - "math2_log_e(): abs(log(math.e) - 1.0) < 1e-9."
    - "math2_log2_eight(): log2(8) == 3.0."
    - "math2_atan2_one_one(): abs(atan2(1.0, 1.0) - pi/4) < 1e-9."
    - "Export: log, log2, log10, sin, cos, tan, atan2, pi, e (extending theseus_math)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_math_cr2.log2_eight:
  description: "log2(8) == 3.0"
  category: log
  kind: python_call_eq
  function: math2_log2_eight
  args: []
  expected: 3.0

invariant theseus_math_cr2.log10_thousand:
  description: "log10(1000) == 3.0"
  category: log
  kind: python_call_eq
  function: math2_log10_thousand
  args: []
  expected: 3.0

invariant theseus_math_cr2.sin_pi_half:
  description: "abs(sin(pi/2) - 1.0) < 1e-9"
  category: trig
  kind: python_call_eq
  function: math2_sin_pi_half
  args: []
  expected: true
