spec: inspect_extra272
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.currentframe.__class__.__name__ == 'function' — currentframe is a Python-level function in inspect."
    - "inspect.currentframe.__module__ == 'inspect' — module is inspect, not _thread or builtins."
    - "inspect.stack, getouterframes, getinnerframes, getframeinfo, getlineno are all 'function' class with __module__ == 'inspect'."
    - "inspect.getfile, getsource, getsourcelines are also 'function' class with __module__ == 'inspect'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect stack and frame functions — identity (currentframe, stack, getouterframes)
#
# currentframe.__name__ == 'currentframe'; __module__ == 'inspect'; __class__.__name__ == 'function'.
# stack.__name__ == 'stack'; getouterframes.__name__ == 'getouterframes'.
# getinnerframes.__name__ == 'getinnerframes'; getframeinfo.__name__ == 'getframeinfo'.
# ---------------------------------------------------------------------------

table inspect_extra272.frame_functions_identity:
  description: "inspect stack and frame function identity — currentframe, stack, getouterframes, getinnerframes, getframeinfo, getlineno; all 'function' class with module 'inspect'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex272ff

  columns: [id, function, args, expected, description]
  rows:
    - [cf_name_eq,               currentframe.__name__.__eq__,                ["currentframe"],               true, "inspect.currentframe.__name__ == 'currentframe'; verified with Python 3.14.3"]
    - [cf_mod_eq,                currentframe.__module__.__eq__,              ["inspect"],                    true, "inspect.currentframe.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [cf_cls_eq,                currentframe.__class__.__name__.__eq__,      ["function"],                   true, "inspect.currentframe.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [st_name_eq,               stack.__name__.__eq__,                       ["stack"],                      true, "inspect.stack.__name__ == 'stack'; verified with Python 3.14.3"]
    - [st_mod_eq,                stack.__module__.__eq__,                     ["inspect"],                    true, "inspect.stack.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [st_cls_eq,                stack.__class__.__name__.__eq__,             ["function"],                   true, "inspect.stack.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [go_name_eq,               getouterframes.__name__.__eq__,              ["getouterframes"],             true, "inspect.getouterframes.__name__ == 'getouterframes'; verified with Python 3.14.3"]
    - [go_mod_eq,                getouterframes.__module__.__eq__,            ["inspect"],                    true, "inspect.getouterframes.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [go_cls_eq,                getouterframes.__class__.__name__.__eq__,    ["function"],                   true, "inspect.getouterframes.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [gi_name_eq,               getinnerframes.__name__.__eq__,              ["getinnerframes"],             true, "inspect.getinnerframes.__name__ == 'getinnerframes'; verified with Python 3.14.3"]
    - [gi_mod_eq,                getinnerframes.__module__.__eq__,            ["inspect"],                    true, "inspect.getinnerframes.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gi_cls_eq,                getinnerframes.__class__.__name__.__eq__,    ["function"],                   true, "inspect.getinnerframes.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [gf_name_eq,               getframeinfo.__name__.__eq__,                ["getframeinfo"],               true, "inspect.getframeinfo.__name__ == 'getframeinfo'; verified with Python 3.14.3"]
    - [gf_mod_eq,                getframeinfo.__module__.__eq__,              ["inspect"],                    true, "inspect.getframeinfo.__module__ == 'inspect'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect source and lineno functions — identity (getlineno, getfile, getsource)
#
# getlineno.__name__ == 'getlineno'; getfile.__name__ == 'getfile'.
# getsource.__name__ == 'getsource'; getsourcelines.__name__ == 'getsourcelines'.
# All have __module__ == 'inspect' and __class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

table inspect_extra272.source_functions_identity:
  description: "inspect source and lineno function identity — getlineno, getfile, getsource, getsourcelines; all 'function' class with __module__ == 'inspect'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex272sf

  columns: [id, function, args, expected, description]
  rows:
    - [gl_name_eq,               getlineno.__name__.__eq__,                   ["getlineno"],                  true, "inspect.getlineno.__name__ == 'getlineno'; verified with Python 3.14.3"]
    - [gl_mod_eq,                getlineno.__module__.__eq__,                 ["inspect"],                    true, "inspect.getlineno.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gl_cls_eq,                getlineno.__class__.__name__.__eq__,         ["function"],                   true, "inspect.getlineno.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [gfi_name_eq,              getfile.__name__.__eq__,                     ["getfile"],                    true, "inspect.getfile.__name__ == 'getfile'; verified with Python 3.14.3"]
    - [gfi_mod_eq,               getfile.__module__.__eq__,                   ["inspect"],                    true, "inspect.getfile.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gfi_cls_eq,               getfile.__class__.__name__.__eq__,           ["function"],                   true, "inspect.getfile.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [gs_name_eq,               getsource.__name__.__eq__,                   ["getsource"],                  true, "inspect.getsource.__name__ == 'getsource'; verified with Python 3.14.3"]
    - [gs_mod_eq,                getsource.__module__.__eq__,                 ["inspect"],                    true, "inspect.getsource.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gs_cls_eq,                getsource.__class__.__name__.__eq__,         ["function"],                   true, "inspect.getsource.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [gsl_name_eq,              getsourcelines.__name__.__eq__,              ["getsourcelines"],             true, "inspect.getsourcelines.__name__ == 'getsourcelines'; verified with Python 3.14.3"]
    - [gsl_mod_eq,               getsourcelines.__module__.__eq__,            ["inspect"],                    true, "inspect.getsourcelines.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gsl_cls_eq,               getsourcelines.__class__.__name__.__eq__,    ["function"],                   true, "inspect.getsourcelines.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra272
# ---------------------------------------------------------------------------

invariant inspect_extra272.currentframe_name:
  description: "inspect.currentframe.__name__ == 'currentframe'"
  category: identity
  kind: python_call_eq
  function: currentframe.__name__.__eq__
  args: ["currentframe"]
  expected: true

invariant inspect_extra272.currentframe_module_is_inspect:
  description: "inspect.currentframe.__module__ == 'inspect' — defined in inspect, not _thread"
  category: identity
  kind: python_call_eq
  function: currentframe.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra272.currentframe_class_is_function:
  description: "inspect.currentframe.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: currentframe.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra272.stack_module_is_inspect:
  description: "inspect.stack.__module__ == 'inspect'"
  category: identity
  kind: python_call_eq
  function: stack.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra272.getouterframes_name:
  description: "inspect.getouterframes.__name__ == 'getouterframes'"
  category: identity
  kind: python_call_eq
  function: getouterframes.__name__.__eq__
  args: ["getouterframes"]
  expected: true

invariant inspect_extra272.getinnerframes_name:
  description: "inspect.getinnerframes.__name__ == 'getinnerframes'"
  category: identity
  kind: python_call_eq
  function: getinnerframes.__name__.__eq__
  args: ["getinnerframes"]
  expected: true

invariant inspect_extra272.getsource_module_is_inspect:
  description: "inspect.getsource.__module__ == 'inspect'"
  category: identity
  kind: python_call_eq
  function: getsource.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra272.getsourcelines_class_is_function:
  description: "inspect.getsourcelines.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: getsourcelines.__class__.__name__.__eq__
  args: ["function"]
  expected: true
