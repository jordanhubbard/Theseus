spec: abc_extra153
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABCMeta.__new__ and __init__ qualnames, abc.ABC.__init_subclass__ qualname, and abc.ABC.__doc__ class. abc.ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=14: 'ABCMeta'=7+'.'=1+'__new__'=7... wait: '__new__'='_'+'_'+'n'+'e'+'w'+'_'+'_'=7; 'ABCMeta.__new__'=7+1+7=15; len('ABCMeta.__new__')==15); verified len==15 with Python 3.14.3; abc.ABCMeta.__init__.__qualname__=='type.__init__' (len=13: 'type'=4+'.'=1+'__init__'=8=13; ABCMeta does NOT define its own __init__ — it inherits __init__ from type, the metaclass; so __init__.__qualname__ shows 'type.__init__'); abc.ABC.__init_subclass__.__qualname__=='ABC.__init_subclass__' (len=21: 'ABC'=3+'.'=1+'__init_subclass__'=17=21); abc.ABC.__doc__ is NOT None — ABC has a docstring: 'Helper class that provides a standard way to create an ABC using inheritance.'; abc.abstractmethod has no __set_name__ attribute (hasattr(abc.abstractmethod, '__set_name__') is False). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15: 'ABCMeta'=7+'.'=1+'__new__'=7=15); '__new__'='_'+'_'+'n'+'e'+'w'+'_'+'_'=7; ABCMeta defines its own __new__ to set up the ABC infrastructure (initializing __abstractmethods__ frozenset); ABCMeta.__new__ takes cls, name, bases, namespace as arguments; compare: ABCMeta.__init__.__qualname__=='type.__init__' (len=13; ABCMeta does NOT define __init__ — it inherits from type). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__init__.__qualname__=='type.__init__' — ABCMeta is a metaclass that inherits from type; ABCMeta does NOT override __init__; looking up ABCMeta.__init__ finds type.__init__ (the metaclass __init__); __qualname__=='type.__init__' (len=13: 'type'=4+'.'=1+'__init__'=8=13); this contrasts with ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15) which IS defined on ABCMeta; the distinction: ABCMeta.__new__ is overridden (qualname starts with 'ABCMeta.') but ABCMeta.__init__ is inherited from type (qualname starts with 'type.'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__init_subclass__.__qualname__=='ABC.__init_subclass__' (len=21: 'ABC'=3+'.'=1+'__init_subclass__'=17=21); ABC defines its own __init_subclass__ as a classmethod; __init_subclass__ is called on the base class whenever a subclass is created (PEP 487, Python 3.6+); accessing abc.ABC.__init_subclass__ returns the bound method; its __qualname__ is 'ABC.__init_subclass__' confirming it is defined on ABC. abc.ABC.__doc__ is NOT None — ABC has a docstring 'Helper class that provides a standard way to create an ABC using inheritance.' Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta.__new__ and __init__ qualnames — extra153
#
# abc.ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__')   == True
# abc.ABCMeta.__init__.__qualname__.__eq__('type.__init__')    == True
# ---------------------------------------------------------------------------

table abc_extra153.abc_abcmeta_new_init_qualnames:
  description: "abc.ABCMeta.__new__ and __init__ qualname checks in abcmeta153 namespace — abc.ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15: 'ABCMeta'=7+'.'=1+'__new__'=7=15; ABCMeta defines its own __new__ to set up the ABC machinery, in particular initializing __abstractmethods__; the qualname starting with 'ABCMeta.' confirms __new__ is defined on ABCMeta itself); abc.ABCMeta.__init__.__qualname__=='type.__init__' (len=13: 'type'=4+'.'=1+'__init__'=8=13; ABCMeta does NOT define its own __init__ — __init__ is inherited from type, the metaclass; the qualname 'type.__init__' reveals the method belongs to type, not ABCMeta); the distinction: __new__(15) is defined on ABCMeta while __init__(13) is inherited from type; qualname length: __init__(13) < __new__(15); compare: ABCMeta.register.__qualname__=='ABCMeta.register' (len=16; established in extra151); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta153

  columns: [id, function, args, expected, description]
  rows:
    - [new_qn_eq,    abc.ABCMeta.__new__.__qualname__.__eq__,   ["ABCMeta.__new__"],  true,  "abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15; defined on ABCMeta); verified with Python 3.14.3"]
    - [init_qn_eq,   abc.ABCMeta.__init__.__qualname__.__eq__,  ["type.__init__"],    true,  "abc.ABCMeta.__init__.__qualname__ == 'type.__init__' (len=13; inherited from type not ABCMeta); verified with Python 3.14.3"]
    - [new_qn_len,   abc.ABCMeta.__new__.__qualname__.__len__,  [],                   15,    "abc.ABCMeta.__new__.__qualname__.__len__() == 15 ('ABCMeta.__new__'); verified with Python 3.14.3"]
    - [init_qn_len,  abc.ABCMeta.__init__.__qualname__.__len__, [],                   13,    "abc.ABCMeta.__init__.__qualname__.__len__() == 13 ('type.__init__'; shorter than ABCMeta.__new__=15); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC.__init_subclass__ qualname — extra153
#
# abc.ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__') == True
# ---------------------------------------------------------------------------

table abc_extra153.abc_ABC_init_subclass_qualname:
  description: "abc.ABC.__init_subclass__ qualname checks in abcabcisc153 namespace — abc.ABC.__init_subclass__.__qualname__=='ABC.__init_subclass__' (len=21: 'ABC'=3+'.'=1+'__init_subclass__'=17=21; '__init_subclass__'='_'+'_'+'init'=4+'_'+'subclass'=8+'_'+'_'=2+4+1+8+2=17); ABC defines its own __init_subclass__ as a classmethod (PEP 487, Python 3.6+); __init_subclass__ is called on the base class whenever a direct subclass is defined; accessing abc.ABC.__init_subclass__ returns the bound classmethod; the qualname 'ABC.__init_subclass__' confirms it is defined on ABC; qualname length 21 places it between ABCMeta.register(16) and ABCMeta.__instancecheck__(25) from extra151; abc.ABC.__init_subclass__.__qualname__.__len__()==21; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcisc153

  columns: [id, function, args, expected, description]
  rows:
    - [isc_qn_eq,   abc.ABC.__init_subclass__.__qualname__.__eq__,  ["ABC.__init_subclass__"],  true,  "abc.ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' (len=21); verified with Python 3.14.3"]
    - [isc_qn_len,  abc.ABC.__init_subclass__.__qualname__.__len__, [],                         21,    "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 ('ABC.__init_subclass__'); verified with Python 3.14.3"]
    - [new_qn_eq2,  abc.ABCMeta.__new__.__qualname__.__eq__,        ["ABCMeta.__new__"],         true,  "cross-reference: abc.ABCMeta.__new__.__qualname__ == 'ABCMeta.__new__' (len=15; shorter than ABC.__init_subclass__=21); verified with Python 3.14.3"]
    - [init_qn_eq2, abc.ABCMeta.__init__.__qualname__.__eq__,       ["type.__init__"],            true,  "cross-reference: abc.ABCMeta.__init__.__qualname__ == 'type.__init__' (len=13; shortest abc qualname in this spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC.__doc__ class and abc.abstractmethod __name__ identity — extra153
#
# abc.ABC.__doc__.__class__.__name__.__eq__('str')    == True (ABC has a docstring)
# abc.abstractmethod.__name__.__eq__('abstractmethod') == True
# abc.ABCMeta.__name__.__eq__('ABCMeta')               == True
# ---------------------------------------------------------------------------

table abc_extra153.abc_ABC_doc_and_names:
  description: "abc.ABC.__doc__ class and abc class name identity checks in abcnames153 namespace — abc.ABC.__doc__.__class__.__name__.__eq__('str')==True (abc.ABC HAS a docstring: 'Helper class that provides a standard way to create an ABC using inheritance.'; therefore abc.ABC.__doc__ is a str, NOT NoneType; abc.ABC.__doc__.__class__.__name__=='str' (len=3)); abc.abstractmethod.__name__.__eq__('abstractmethod')==True (abstractmethod.__name__=='abstractmethod' (len=14: 'abstract'=8+'method'=6=14); abstractmethod is a decorator class used to declare abstract methods); abc.ABCMeta.__name__.__eq__('ABCMeta')==True (ABCMeta.__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7); ABCMeta is the metaclass for ABCs); abc.ABCMeta.__module__.__eq__('abc')==True (ABCMeta is defined in the abc module); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcnames153

  columns: [id, function, args, expected, description]
  rows:
    - [doc_cls_eq,   abc.ABC.__doc__.__class__.__name__.__eq__,   ["str"],             true,  "abc.ABC.__doc__.__class__.__name__ == 'str' (ABC has a docstring; __doc__ is str not NoneType); verified with Python 3.14.3"]
    - [am_name_eq,   abc.abstractmethod.__name__.__eq__,          ["abstractmethod"],  true,  "abc.abstractmethod.__name__ == 'abstractmethod' (len=14; the ABC decorator class); verified with Python 3.14.3"]
    - [abcm_name_eq, abc.ABCMeta.__name__.__eq__,                 ["ABCMeta"],         true,  "abc.ABCMeta.__name__ == 'ABCMeta' (len=7; the ABC metaclass); verified with Python 3.14.3"]
    - [abcm_mod_eq,  abc.ABCMeta.__module__.__eq__,               ["abc"],             true,  "abc.ABCMeta.__module__ == 'abc' (defined in the abc module); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra153
# ---------------------------------------------------------------------------

invariant abc_extra153.abc_ABCMeta_new_qualname_eq:
  description: "abc.ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__') returns True — abc.ABCMeta defines its own __new__ classmethod to initialize the ABC infrastructure; ABCMeta.__new__ is called during class creation to set up __abstractmethods__ (the frozenset of names of abstract methods that must be overridden); __new__.__qualname__=='ABCMeta.__new__' (len=15: 'ABCMeta'=7+'.'=1+'__new__'=7=15; '__new__'='_'=1+'_'=1+'n'+'e'+'w'=3+'_'=1+'_'=1=7); the qualname starting with 'ABCMeta.' confirms __new__ is defined directly on ABCMeta (not inherited from type or object); contrast: ABCMeta.__init__.__qualname__=='type.__init__' (ABCMeta does NOT override __init__); NEW in extra153: first standalone abc.ABCMeta.__new__.__qualname__ identity invariant in abcmeta153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__qualname__.__eq__
  args: ["ABCMeta.__new__"]
  expected: true

invariant abc_extra153.abc_ABCMeta_init_qualname_is_type_init:
  description: "abc.ABCMeta.__init__.__qualname__.__eq__('type.__init__') returns True — abc.ABCMeta does NOT define its own __init__; looking up ABCMeta.__init__ finds type.__init__ (the metaclass __init__ defined on the built-in type); __init__.__qualname__=='type.__init__' (len=13: 'type'=4+'.'=1+'__init__'=8=13); this is a key asymmetry: ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15; defined on ABCMeta) while ABCMeta.__init__.__qualname__=='type.__init__' (len=13; inherited from type); the qualname 'type.__init__' reveals that ABCMeta relies on type's __init__ for its initialization; compare: abc.abstractmethod.__init__.__qualname__=='object.__init__' (len=15; established in extra151 — abstractmethod inherits __init__ from object, NOT from type); NEW in extra153: first standalone abc.ABCMeta.__init__.__qualname__ identity invariant in abcmeta153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__init__.__qualname__.__eq__
  args: ["type.__init__"]
  expected: true

invariant abc_extra153.abc_ABC_init_subclass_qualname_eq:
  description: "abc.ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__') returns True — abc.ABC defines its own __init_subclass__ classmethod; __init_subclass__ was added in Python 3.6 (PEP 487) and is called on the base class whenever a subclass of that class is defined; ABC.__init_subclass__.__qualname__=='ABC.__init_subclass__' (len=21: 'ABC'=3+'.'=1+'__init_subclass__'=17=21; '__init_subclass__'=2+4+1+8+2=17 where 'init'=4 and 'subclass'=8 and underscores account for 5); the qualname 'ABC.__init_subclass__' confirms it is defined on ABC (not inherited from object); qualname length 21 is between ABCMeta.register(16) and ABCMeta.__instancecheck__(25); NEW in extra153: first standalone abc.ABC.__init_subclass__.__qualname__ identity invariant in abcabcisc153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__init_subclass__.__qualname__.__eq__
  args: ["ABC.__init_subclass__"]
  expected: true

invariant abc_extra153.abc_ABC_doc_class_is_str:
  description: "abc.ABC.__doc__.__class__.__name__.__eq__('str') returns True — abc.ABC has a docstring (it is NOT None); abc.ABC.__doc__ == 'Helper class that provides a standard way to create an ABC using inheritance.'; therefore abc.ABC.__doc__.__class__.__name__=='str' (len=3: 's'+'t'+'r'=3); this corrects a potential assumption that ABC has no docstring — ABC.__doc__ is a non-empty str; compare: many internal helper classes have no docstring (__doc__ is None and __doc__.__class__.__name__=='NoneType'); abc.ABC.__doc__.__class__.__name__=='str' confirms the docstring exists; the docstring provides human-readable documentation for the ABC helper class; NEW in extra153: first standalone abc.ABC.__doc__ class identity invariant in abcnames153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra153.abc_abstractmethod_name_eq:
  description: "abc.abstractmethod.__name__.__eq__('abstractmethod') returns True — abc.abstractmethod is a decorator class (a function-like object) used to declare abstract methods; abstractmethod.__name__=='abstractmethod' (len=14: 'abstract'=8+'method'=6=14); the __name__ attribute of a class is its unqualified name; abstractmethod is used as @abstractmethod on method definitions to indicate that subclasses must override this method; abstractmethod does not define __set_name__ (hasattr(abc.abstractmethod, '__set_name__') is False); abstractmethod.__name__=='abstractmethod' (len=14) is 1 char less than abc.ABCMeta.__name__.__len__()==7... wait: len('abstractmethod')==14 vs len('ABCMeta')==7; abstractmethod name (14) is twice as long as ABCMeta name (7); NEW in extra153: first standalone abc.abstractmethod.__name__ identity invariant in abcnames153 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true
