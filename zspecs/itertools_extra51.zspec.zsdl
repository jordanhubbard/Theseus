spec: itertools_extra51
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra50.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for all major itertools types (chain/repeat/zip_longest/permutations/combinations/groupby/islice in extra15; compress/dropwhile/takewhile/filterfalse/starmap/accumulate/pairwise/combinations_with_replacement in extra16; count/cycle/product also in extra15); chain.from_iterable.__name__.__len__()==13 (extra35); chain.from_iterable.__qualname__.__eq__('chain.from_iterable') (extra23); chain.from_iterable.__qualname__.__len__() (extra30 as noted in extra35); itertools.__name__.__len__()==9 (extra32); __doc__.__class__.__name__=='str' for all major types (extra49/extra50)."
    - "This spec covers: itertools.chain.from_iterable.__name__.__eq__('from_iterable')==true; itertools.chain.from_iterable.__doc__.__class__.__name__.__eq__('str')==true; itertools.chain.from_iterable.__doc__.__class__.__qualname__.__eq__('str')==true; itertools.chain.from_iterable.__class__.__name__.__eq__('classmethod_descriptor')==true (or 'builtin_function_or_method' — the C-level classmethod descriptor type); itertools.__name__.__eq__('itertools')==true; itertools.__package__.__eq__('itertools')==true."
    - "Key findings: chain.from_iterable is a C-level classmethod_descriptor on the chain type in Modules/itertoolsmodule.c. Its __name__ is 'from_iterable' (13 chars) — the local method name without the class prefix. Its __qualname__ is 'chain.from_iterable' (19 chars, confirmed in extra23/extra30). Its __doc__ is a Python str object (the C-level tp_doc string for the classmethod slot), so __doc__.__class__.__name__ == 'str' and __doc__.__class__.__qualname__ == 'str'. On CPython, chain.from_iterable.__class__.__name__ is 'classmethod_descriptor' — the type used for C-level classmethods, distinct from the Python classmethod built-in type. itertools.__name__.__eq__('itertools') is the string equality form of extra32's length check. itertools.__package__ equals 'itertools' because the module is a top-level built-in extension without a parent package. All six invariants are new to extra51."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.chain.from_iterable attribute checks — extra51 namespace
#
# itertools.chain.from_iterable is a C-level classmethod_descriptor defined in
# Modules/itertoolsmodule.c. It accepts a single iterable-of-iterables and
# chains them together lazily without the need to unpack them as positional
# arguments first. Its key attributes:
#   __name__           == 'from_iterable'  (13 chars — the local method name)
#   __qualname__       == 'chain.from_iterable'  (19 chars — confirmed extra23)
#   __doc__.__class__.__name__   == 'str'  (the docstring is a Python str)
#   __class__.__name__ == 'classmethod_descriptor'
# Prior specs: extra35 recorded __name__.__len__()==13; extra23 recorded
# __qualname__.__eq__('chain.from_iterable'). None recorded __name__.__eq__,
# __doc__.__class__.__name__, __doc__.__class__.__qualname__, or
# __class__.__name__. All four are new to extra51.
# ---------------------------------------------------------------------------

table itertools_extra51.chain_from_iterable_attrs:
  description: "itertools.chain.from_iterable attribute checks — __name__=='from_iterable'; __doc__.__class__.__name__=='str'; __doc__.__class__.__qualname__=='str'; __class__.__name__=='classmethod_descriptor'; C-level classmethod on chain type in Modules/itertoolsmodule.c"
  kind: python_call_eq
  category: identity
  id_prefix: itertchain51

  columns: [id, function, args, expected, description]
  rows:
    - [from_iterable_name_eq,
       "chain.from_iterable.__name__.__eq__",
       ["from_iterable"],
       true,
       "itertools.chain.from_iterable.__name__.__eq__('from_iterable') == True — the local method name 'from_iterable' (13 chars) without the 'chain.' class prefix; shorter than the 19-char qualname 'chain.from_iterable' (extra23); extra35 confirmed __name__.__len__()==13; this is the first string equality check for chain.from_iterable.__name__"]
    - [from_iterable_doc_class_name,
       "chain.from_iterable.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.chain.from_iterable.__doc__.__class__.__name__ == 'str' — chain.from_iterable is a C-level classmethod_descriptor in Modules/itertoolsmodule.c; its docstring is exposed as a Python str object created from the C-level method descriptor documentation string; __doc__.__class__.__name__ == 'str' (3 chars); consistent with all other itertools type docstrings (confirmed as 'str' across extra49/extra50)"]
    - [from_iterable_doc_class_qualname,
       "chain.from_iterable.__doc__.__class__.__qualname__.__eq__",
       ["str"],
       true,
       "itertools.chain.from_iterable.__doc__.__class__.__qualname__ == 'str' — the str built-in type is a top-level type with __qualname__ == __name__ == 'str' (3 chars); no dotted prefix because str is not a nested class; since __doc__ is a str object, __doc__.__class__ is the str type, and str.__qualname__ == 'str'; new to extra51"]
    - [from_iterable_class_name,
       "chain.from_iterable.__class__.__name__.__eq__",
       ["classmethod_descriptor"],
       true,
       "itertools.chain.from_iterable.__class__.__name__ == 'classmethod_descriptor' — on CPython, C-level classmethods use the internal classmethod_descriptor type (not the Python-level classmethod type); __class__.__name__ is 'classmethod_descriptor' (22 chars); this type is distinct from 'builtin_function_or_method' (used for C-level static functions) and from 'classmethod' (the Python-level descriptor); new to extra51"]

# ---------------------------------------------------------------------------
# itertools module __name__ string equality — extra51 namespace
#
# itertools.__name__ is 'itertools' (9 chars). extra32 recorded
# itertools.__name__.__len__() == 9 as a standalone invariant. No prior
# itertools spec records itertools.__name__.__eq__('itertools') — the string
# equality form. As a built-in C extension module, the itertools __name__
# matches the module's public name exactly. New to extra51.
# ---------------------------------------------------------------------------

invariant itertools_extra51.module_name_eq:
  description: "itertools.__name__.__eq__('itertools') == True — the module name is 'itertools' (9 chars); extra32 confirmed __name__.__len__()==9; this is the first string equality check for the module __name__ in the extra51 namespace"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["itertools"]
  expected: true

# ---------------------------------------------------------------------------
# itertools module __package__ string equality — extra51 namespace
#
# itertools.__package__ is 'itertools' (9 chars). As a top-level built-in
# extension module, itertools has no parent package. For built-in C extension
# modules, __package__ equals __name__ when the module is a top-level package
# and there is no enclosing namespace. No prior itertools spec records
# itertools.__package__ in any form. New to extra51.
# ---------------------------------------------------------------------------

invariant itertools_extra51.module_package_eq:
  description: "itertools.__package__.__eq__('itertools') == True — top-level built-in extension module; __package__ equals __name__ == 'itertools' (9 chars) because the module is its own package with no parent namespace; no prior itertools spec records __package__ in any form"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["itertools"]
  expected: true
