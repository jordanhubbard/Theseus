    - [sm_var_len,   shared_memory.SharedMemory.__init__.__code__.co_varnames.__len__,   [],                          10,   "SharedMemory.__init__ co_varnames.__len__() == 10 (most in spec: 4 params + keyword-only + locals); verified with Python 3.14.3"]
