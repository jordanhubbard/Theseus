spec: multiprocessing_extra117
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.shared_memory.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.shared_memory.html — Python multiprocessing.shared_memory documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/shared_memory.py"
  notes:
    - "This spec extends multiprocessing_extra116.zspec.zsdl."
    - "This spec covers: wave 259 theme — multiprocessing.shared_memory module class identity not previously covered. Prior specs covered: extra25 covered shared_memory.__name__.__eq__('multiprocessing.shared_memory')==True and shared_memory.__name__.__len__()==29. NOT previously covered: SharedMemory.__name__, SharedMemory.__module__, SharedMemory.__qualname__, SharedMemory.__mro__.__len__(), SharedMemory.__bases__[0].__name__, ShareableList.__name__, ShareableList.__module__, ShareableList.__mro__.__len__(), SharedMemory.__init__ code attrs, ShareableList.__init__ code attrs. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.shared_memory.SharedMemory.__name__ == 'SharedMemory' (len=12). __module__ == 'multiprocessing.shared_memory' (len=29). __qualname__ == 'SharedMemory' (len=12). __mro__.__len__() == 2 ([SharedMemory, object]; inherits directly from object). __bases__[0].__name__ == 'object'. SharedMemory.__init__.__code__.co_qualname == 'SharedMemory.__init__' (len=21). co_argcount == 4 (self, name, create, size). co_varnames.__len__() == 10. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.shared_memory.ShareableList.__name__ == 'ShareableList' (len=13). __module__ == 'multiprocessing.shared_memory' (len=29, same as SharedMemory). __qualname__ == 'ShareableList' (len=13). __mro__.__len__() == 2 ([ShareableList, object]; inherits directly from object). __bases__[0].__name__ == 'object'. ShareableList.__init__.__code__.co_qualname == 'ShareableList.__init__' (len=22). co_argcount == 2 (self, sequence). co_varnames.__len__() == 9. Compare: ShareableList name len=13 > SharedMemory name len=12 (1 more: 'ShareableList'=13 vs 'SharedMemory'=12); ShareableList init co_qualname len=22 > SharedMemory init co_qualname len=21 (1 more: same reason). Both share __module__ 'multiprocessing.shared_memory' (len=29). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.shared_memory.SharedMemory class identity — extra117
#
# Wave 259 theme: SharedMemory class identity attributes (first coverage).
#
# SharedMemory.__name__.__len__()              == 12  ('SharedMemory')
# SharedMemory.__module__.__len__()            == 29  ('multiprocessing.shared_memory')
# SharedMemory.__mro__.__len__()               == 2   ([SharedMemory, object])
# SharedMemory.__bases__[0].__name__           == 'object'
# SharedMemory.__init__.__code__.co_qualname   == 'SharedMemory.__init__' (len=21)
# ---------------------------------------------------------------------------

table multiprocessing_extra117.mp_shared_memory_class_identity:
  description: "multiprocessing.shared_memory.SharedMemory class identity checks in mpshm117 namespace — wave 259 theme: first coverage of SharedMemory class attributes; SharedMemory.__name__.__eq__('SharedMemory')==True (len=12: 'Shared'=6+'Memory'=6=12; SharedMemory provides access to a named shared memory block that can be shared between processes; not a subclass of any existing Python class); SharedMemory.__name__.__len__()==12; SharedMemory.__qualname__.__eq__('SharedMemory')==True (__qualname__==__name__ for top-level class; len=12); SharedMemory.__qualname__.__len__()==12; SharedMemory.__module__.__eq__('multiprocessing.shared_memory')==True (len=29: 'multiprocessing.'=16+'shared_memory'=13=29; same value as the module's __name__ covered in extra25); SharedMemory.__module__.__len__()==29; SharedMemory.__mro__.__len__()==2 ([SharedMemory, object]: inherits directly from object; minimal MRO depth=2); SharedMemory.__bases__[0].__name__.__eq__('object')==True (only base class is object; SharedMemory does not inherit from any abstract base); SharedMemory.__bases__[0].__name__.__len__()==6; compare: SharedMemory.__name__.__len__()==12 (half of module len=29: not exactly but note 'Shared'=6+'Memory'=6=12 has two equal halves); SharedMemory.__module__.__len__()==29 == shared_memory module __name__.__len__()==29 (SharedMemory's module equals the module it is defined in); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpshm117

  columns: [id, function, args, expected, description]
  rows:
    - [sm_name_eq,   shared_memory.SharedMemory.__name__.__eq__,              ["SharedMemory"],               true, "SharedMemory.__name__ == 'SharedMemory' (len=12); verified with Python 3.14.3"]
    - [sm_name_len,  shared_memory.SharedMemory.__name__.__len__,             [],                             12,   "SharedMemory.__name__.__len__() == 12 ('SharedMemory'=12); verified with Python 3.14.3"]
    - [sm_qn_eq,     shared_memory.SharedMemory.__qualname__.__eq__,          ["SharedMemory"],               true, "SharedMemory.__qualname__ == 'SharedMemory' (__qualname__==__name__ for top-level class); verified with Python 3.14.3"]
    - [sm_qn_len,    shared_memory.SharedMemory.__qualname__.__len__,         [],                             12,   "SharedMemory.__qualname__.__len__() == 12 (tied with __name__ len=12); verified with Python 3.14.3"]
    - [sm_mod_eq,    shared_memory.SharedMemory.__module__.__eq__,            ["multiprocessing.shared_memory"], true, "SharedMemory.__module__ == 'multiprocessing.shared_memory' (len=29); verified with Python 3.14.3"]
    - [sm_mod_len,   shared_memory.SharedMemory.__module__.__len__,           [],                             29,   "SharedMemory.__module__.__len__() == 29 (same as module __name__ len=29); verified with Python 3.14.3"]
    - [sm_mro_len,   shared_memory.SharedMemory.__mro__.__len__,              [],                             2,    "SharedMemory.__mro__.__len__() == 2 ([SharedMemory, object]); verified with Python 3.14.3"]
    - [sm_base_eq,   "shared_memory.SharedMemory.__bases__[0].__name__.__eq__", ["object"],                  true, "SharedMemory.__bases__[0].__name__ == 'object' (inherits directly from object); verified with Python 3.14.3"]
    - [sm_base_len,  "shared_memory.SharedMemory.__bases__[0].__name__.__len__", [],                         6,    "SharedMemory.__bases__[0].__name__.__len__() == 6 ('object'=6); verified with Python 3.14.3"]

