invariant multiprocessing_extra117.ShareableList_init_co_varnames_len_9:
  description: "multiprocessing.shared_memory.ShareableList.__init__.__code__.co_varnames.__len__() == 9 — co_varnames==('self','sequence','name','item','_formats','offset','fmt','_recreation_codes','requested_size'): 2 positional params (self, sequence) + 1 keyword-only (name) + 6 local variables (item, _formats, offset, fmt, _recreation_codes, requested_size); ShareableList.__init__.__code__.co_argcount==2 (self and sequence; name is keyword-only not counted in co_argcount); co_varnames.__len__()==9 is 1 fewer than SharedMemory.__init__.__code__.co_varnames.__len__()==10; the locals reflect ShareableList's complexity: it must pack items as C structs (using _formats to track the struct format for each element, offset to track byte positions, and fmt to build the full struct format string); ShareableList.__init__.__code__.co_qualname.__len__()==22; ShareableList.__name__.__len__()==13; ShareableList.__module__.__len__()==29; first standalone ShareableList.__init__ co_varnames length invariant in mpshm117 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
