table multiprocessing_extra117.mp_shareable_list_class_identity:
  description: "multiprocessing.shared_memory.ShareableList class identity checks in mpshm117 namespace — wave 259 theme: first coverage of ShareableList class attributes; ShareableList.__name__.__eq__('ShareableList')==True (len=13: 'Shareable'=9+'List'=4=13; ShareableList is a mutable list-like object stored in shared memory that can be shared between processes; it stores items of fixed-size built-in types); ShareableList.__name__.__len__()==13; ShareableList.__qualname__.__eq__('ShareableList')==True (__qualname__==__name__ for top-level class; len=13); ShareableList.__qualname__.__len__()==13; ShareableList.__module__.__eq__('multiprocessing.shared_memory')==True (len=29: same module as SharedMemory; both ShareableList and SharedMemory are defined in the same file Lib/multiprocessing/shared_memory.py); ShareableList.__module__.__len__()==29; ShareableList.__mro__.__len__()==2 ([ShareableList, object]: inherits directly from object; same minimal MRO depth as SharedMemory); ShareableList.__bases__[0].__name__.__eq__('object')==True; compare: ShareableList.__name__.__len__()==13 > SharedMemory.__name__.__len__()==12 (1 more: 'ShareableList'=13 vs 'SharedMemory'=12); ShareableList.__module__.__len__()==29 == SharedMemory.__module__.__len__()==29 (tied: both in same module); ShareableList.__mro__.__len__()==2 == SharedMemory.__mro__.__len__()==2 (tied: both inherit directly from object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpshm117a

  columns: [id, function, args, expected, description]
  rows:
    - [sl_name_eq,   shared_memory.ShareableList.__name__.__eq__,              ["ShareableList"],              true, "ShareableList.__name__ == 'ShareableList' (len=13); verified with Python 3.14.3"]
    - [sl_name_len,  shared_memory.ShareableList.__name__.__len__,             [],                             13,   "ShareableList.__name__.__len__() == 13 (1 more than SharedMemory=12); verified with Python 3.14.3"]
    - [sl_qn_eq,     shared_memory.ShareableList.__qualname__.__eq__,          ["ShareableList"],              true, "ShareableList.__qualname__ == 'ShareableList' (__qualname__==__name__ for top-level class); verified with Python 3.14.3"]
    - [sl_qn_len,    shared_memory.ShareableList.__qualname__.__len__,         [],                             13,   "ShareableList.__qualname__.__len__() == 13 (tied with __name__ len=13); verified with Python 3.14.3"]
    - [sl_mod_eq,    shared_memory.ShareableList.__module__.__eq__,            ["multiprocessing.shared_memory"], true, "ShareableList.__module__ == 'multiprocessing.shared_memory' (len=29, same as SharedMemory); verified with Python 3.14.3"]
    - [sl_mod_len,   shared_memory.ShareableList.__module__.__len__,           [],                             29,   "ShareableList.__module__.__len__() == 29 (tied with SharedMemory module len=29); verified with Python 3.14.3"]
    - [sl_mro_len,   shared_memory.ShareableList.__mro__.__len__,              [],                             2,    "ShareableList.__mro__.__len__() == 2 (tied with SharedMemory mro len=2; both inherit from object); verified with Python 3.14.3"]
    - [sl_base_eq,   "shared_memory.ShareableList.__bases__[0].__name__.__eq__", ["object"],                  true, "ShareableList.__bases__[0].__name__ == 'object' (inherits directly from object); verified with Python 3.14.3"]

