# ShareableList.__init__.__code__.co_varnames.__len__() == 9
# ---------------------------------------------------------------------------

table multiprocessing_extra117.mp_shm_init_code_attrs:
  description: "multiprocessing.shared_memory SharedMemory and ShareableList __init__ code attr checks in mpshm117 namespace — wave 259 theme: SharedMemory.__init__ and ShareableList.__init__ co_qualname and co_varnames; SharedMemory.__init__.__code__.co_qualname.__eq__('SharedMemory.__init__')==True (len=21: 'SharedMemory.'=13+'__init__'=8=21; SharedMemory.__init__ takes self, name, create, size as positional params plus track and stats as keyword-only; co_argcount==4); SharedMemory.__init__.__code__.co_qualname.__len__()==21; SharedMemory.__init__.__code__.co_argcount.__eq__(4)==True (4 positional params: self, name, create, size); SharedMemory.__init__.__code__.co_varnames.__len__()==10 (('self','name','create','size','track','stats','temp_name','h_map','last_error_code','p_buf'): 4 positional params + keyword-only + locals; most co_varnames in this spec); ShareableList.__init__.__code__.co_qualname.__eq__('ShareableList.__init__')==True (len=22: 'ShareableList.'=14+'__init__'=8=22; 1 more than SharedMemory init=21); ShareableList.__init__.__code__.co_qualname.__len__()==22; ShareableList.__init__.__code__.co_argcount.__eq__(2)==True (2 positional params: self, sequence; name is keyword-only); ShareableList.__init__.__code__.co_varnames.__len__()==9 (('self','sequence','name','item','_formats','offset','fmt','_recreation_codes','requested_size'): 2 positional + 1 keyword-only + locals; 1 fewer than SharedMemory=10); compare co_qualname lengths: SharedMemory.__init__=21 < ShareableList.__init__=22 (diff=1: 'SharedMemory'=12 vs 'ShareableList'=13, diff=1); compare co_varnames: ShareableList=9 < SharedMemory=10 (SharedMemory has platform-specific locals like h_map and last_error_code that add complexity on Windows); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: mpshm117b

  columns: [id, function, args, expected, description]
  rows:
    - [sm_coq_eq,    shared_memory.SharedMemory.__init__.__code__.co_qualname.__eq__,    ["SharedMemory.__init__"],   true, "SharedMemory.__init__.__code__.co_qualname == 'SharedMemory.__init__' (len=21); verified with Python 3.14.3"]
    - [sm_coq_len,   shared_memory.SharedMemory.__init__.__code__.co_qualname.__len__,   [],                          21,   "SharedMemory.__init__ co_qualname.__len__() == 21 ('SharedMemory.'=13+'__init__'=8=21); verified with Python 3.14.3"]
