spec: inspect_extra92
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra91

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra91.zspec.zsdl."
    - "This spec covers: inspect predicate and utility function __code__.co_argcount values grouped by count (Wave 252)."
    - "inspect.currentframe.__code__.co_argcount == 0 — currentframe takes no positional/keyword parameters. Verified with Python 3.14.3."
    - "inspect.ismodule.__code__.co_argcount == 1 — takes a single object parameter. Verified with Python 3.14.3."
    - "inspect.isclass.__code__.co_argcount == 1 — takes a single object parameter. Verified with Python 3.14.3."
    - "inspect.isfunction.__code__.co_argcount == 1 — takes a single object parameter. Verified with Python 3.14.3."
    - "inspect.ismethod.__code__.co_argcount == 1 — takes a single object parameter. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__code__.co_argcount == 1 — takes a single object parameter. Verified with Python 3.14.3."
    - "inspect.isgenerator.__code__.co_argcount == 1 — takes a single object parameter. Verified with Python 3.14.3."
    - "inspect.iscoroutine.__code__.co_argcount == 1 — takes a single object parameter. Verified with Python 3.14.3."
    - "inspect.isawaitable.__code__.co_argcount == 1 — takes a single object parameter. Verified with Python 3.14.3."
    - "inspect.isasyncgen.__code__.co_argcount == 1 — takes a single object parameter. Verified with Python 3.14.3."
    - "inspect.isframe.__code__.co_argcount == 1 — takes a single object parameter. Verified with Python 3.14.3."
    - "inspect.iscode.__code__.co_argcount == 1 — takes a single object parameter. Verified with Python 3.14.3."
    - "inspect.isroutine.__code__.co_argcount == 1 — takes a single object parameter. Verified with Python 3.14.3."
    - "inspect.isabstract.__code__.co_argcount == 1 — takes a single object parameter. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_argcount == 1 — takes obj parameter. Verified with Python 3.14.3."
    - "inspect.getdoc.__code__.co_argcount == 1 — takes object parameter. Verified with Python 3.14.3."
    - "inspect.getfile.__code__.co_argcount == 1 — takes object parameter. Verified with Python 3.14.3."
    - "inspect.getsource.__code__.co_argcount == 1 — takes object parameter. Verified with Python 3.14.3."
    - "inspect.getsourcelines.__code__.co_argcount == 1 — takes object parameter. Verified with Python 3.14.3."
    - "inspect.getfullargspec.__code__.co_argcount == 1 — takes func parameter. Verified with Python 3.14.3."
    - "inspect.stack.__code__.co_argcount == 1 — takes context parameter. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_argcount == 2 — takes object and predicate parameters. Verified with Python 3.14.3."
    - "inspect.getmodule.__code__.co_argcount == 2 — takes object and _filename parameters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: co_argcount == 0 (currentframe)
#
# Wave 252 theme: inspect functions with __code__.co_argcount == 0.
#
# inspect.currentframe.__code__.co_argcount.__eq__(0) == True
#
# currentframe takes no positional/keyword parameters; it returns the frame of the calling scope.
# Prior spec extra91 checked __module__; this spec (extra92) checks __code__.co_argcount. New to extra92.
# ---------------------------------------------------------------------------

table inspect_extra92.co_argcount_zero:
  description: "inspect functions with __code__.co_argcount == 0; currentframe takes no positional/keyword parameters; wave 252; new to extra92"
  kind: python_call_eq
  category: integer_identity
  id_prefix: inspectcoargcount92

  columns: [id, function, args, expected, description]
  rows:
    - [currentframe_co_argcount_eq_0,
       "currentframe.__code__.co_argcount.__eq__",
       [0],
       true,
       "inspect.currentframe.__code__.co_argcount.__eq__(0) == True — currentframe is a pure-Python wrapper in Lib/inspect.py that takes no positional/keyword parameters; co_argcount counts positional-or-keyword parameters excluding *args and **kwargs; co_argcount is 0 because currentframe uses no positional parameters; int.__eq__(0) returns True; prior spec extra91 checked __module__; this spec (extra92) checks __code__.co_argcount; new to extra92"]

# ---------------------------------------------------------------------------
# Table 2: co_argcount == 1 — predicate functions
#
# Wave 252 theme: inspect predicate functions with __code__.co_argcount == 1.
#
# inspect.ismodule.__code__.co_argcount.__eq__(1)    == True
# inspect.isclass.__code__.co_argcount.__eq__(1)     == True
# inspect.isfunction.__code__.co_argcount.__eq__(1)  == True
# inspect.ismethod.__code__.co_argcount.__eq__(1)    == True
# inspect.isbuiltin.__code__.co_argcount.__eq__(1)   == True
# inspect.isgenerator.__code__.co_argcount.__eq__(1) == True
# inspect.iscoroutine.__code__.co_argcount.__eq__(1) == True
# inspect.isawaitable.__code__.co_argcount.__eq__(1) == True
# inspect.isasyncgen.__code__.co_argcount.__eq__(1)  == True
# inspect.isframe.__code__.co_argcount.__eq__(1)     == True
# inspect.iscode.__code__.co_argcount.__eq__(1)      == True
# inspect.isroutine.__code__.co_argcount.__eq__(1)   == True
# inspect.isabstract.__code__.co_argcount.__eq__(1)  == True
#
# All 'is*' predicates take exactly one object parameter. New to extra92.
# ---------------------------------------------------------------------------

table inspect_extra92.co_argcount_one_predicates:
  description: "inspect is* predicate functions with __code__.co_argcount == 1; each takes a single object parameter; wave 252; new to extra92"
  kind: python_call_eq
  category: integer_identity
  id_prefix: inspectcoargcount92

  columns: [id, function, args, expected, description]
  rows:
    - [ismodule_co_argcount_eq_1,
       "ismodule.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.ismodule.__code__.co_argcount.__eq__(1) == True — ismodule takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [isclass_co_argcount_eq_1,
       "isclass.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isclass.__code__.co_argcount.__eq__(1) == True — isclass takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [isfunction_co_argcount_eq_1,
       "isfunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isfunction.__code__.co_argcount.__eq__(1) == True — isfunction takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [ismethod_co_argcount_eq_1,
       "ismethod.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.ismethod.__code__.co_argcount.__eq__(1) == True — ismethod takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [isbuiltin_co_argcount_eq_1,
       "isbuiltin.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isbuiltin.__code__.co_argcount.__eq__(1) == True — isbuiltin takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [isgenerator_co_argcount_eq_1,
       "isgenerator.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isgenerator.__code__.co_argcount.__eq__(1) == True — isgenerator takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [iscoroutine_co_argcount_eq_1,
       "iscoroutine.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.iscoroutine.__code__.co_argcount.__eq__(1) == True — iscoroutine takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [isawaitable_co_argcount_eq_1,
       "isawaitable.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isawaitable.__code__.co_argcount.__eq__(1) == True — isawaitable takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [isasyncgen_co_argcount_eq_1,
       "isasyncgen.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isasyncgen.__code__.co_argcount.__eq__(1) == True — isasyncgen takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [isframe_co_argcount_eq_1,
       "isframe.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isframe.__code__.co_argcount.__eq__(1) == True — isframe takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [iscode_co_argcount_eq_1,
       "iscode.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.iscode.__code__.co_argcount.__eq__(1) == True — iscode takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [isroutine_co_argcount_eq_1,
       "isroutine.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isroutine.__code__.co_argcount.__eq__(1) == True — isroutine takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [isabstract_co_argcount_eq_1,
       "isabstract.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isabstract.__code__.co_argcount.__eq__(1) == True — isabstract takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]

# ---------------------------------------------------------------------------
# Table 3: co_argcount == 1 — utility functions
#
# Wave 252 theme: inspect utility functions with __code__.co_argcount == 1.
#
# inspect.signature.__code__.co_argcount.__eq__(1)      == True
# inspect.getdoc.__code__.co_argcount.__eq__(1)         == True
# inspect.getfile.__code__.co_argcount.__eq__(1)        == True
# inspect.getsource.__code__.co_argcount.__eq__(1)      == True
# inspect.getsourcelines.__code__.co_argcount.__eq__(1) == True
# inspect.getfullargspec.__code__.co_argcount.__eq__(1) == True
# inspect.stack.__code__.co_argcount.__eq__(1)          == True
#
# inspect utility functions that take a single primary argument. New to extra92.
# ---------------------------------------------------------------------------

table inspect_extra92.co_argcount_one_utilities:
  description: "inspect utility functions with __code__.co_argcount == 1; each takes a single primary parameter; wave 252; new to extra92"
  kind: python_call_eq
  category: integer_identity
  id_prefix: inspectcoargcount92

  columns: [id, function, args, expected, description]
  rows:
    - [signature_co_argcount_eq_1,
       "signature.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.signature.__code__.co_argcount.__eq__(1) == True — signature takes a single obj parameter as its primary positional-or-keyword argument; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [getdoc_co_argcount_eq_1,
       "getdoc.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getdoc.__code__.co_argcount.__eq__(1) == True — getdoc takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [getfile_co_argcount_eq_1,
       "getfile.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getfile.__code__.co_argcount.__eq__(1) == True — getfile takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [getsource_co_argcount_eq_1,
       "getsource.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getsource.__code__.co_argcount.__eq__(1) == True — getsource takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [getsourcelines_co_argcount_eq_1,
       "getsourcelines.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getsourcelines.__code__.co_argcount.__eq__(1) == True — getsourcelines takes a single object parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [getfullargspec_co_argcount_eq_1,
       "getfullargspec.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.getfullargspec.__code__.co_argcount.__eq__(1) == True — getfullargspec takes a single func parameter; co_argcount is 1; int.__eq__(1) returns True; new to extra92"]
    - [stack_co_argcount_eq_1,
       "stack.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.stack.__code__.co_argcount.__eq__(1) == True — stack takes a single context parameter with a default value; co_argcount counts positional/keyword parameters regardless of defaults, so co_argcount is 1; int.__eq__(1) returns True; new to extra92"]

# ---------------------------------------------------------------------------
# Table 4: co_argcount == 2 — multi-parameter utilities
#
# Wave 252 theme: inspect utility functions with __code__.co_argcount == 2.
#
# inspect.getmembers.__code__.co_argcount.__eq__(2) == True
# inspect.getmodule.__code__.co_argcount.__eq__(2)  == True
#
# getmembers takes object and predicate; getmodule takes object and _filename.
# These are the only functions in the tested set with co_argcount == 2. New to extra92.
# ---------------------------------------------------------------------------

table inspect_extra92.co_argcount_two:
  description: "inspect.getmembers and getmodule with __code__.co_argcount == 2; take two positional/keyword parameters; wave 252; new to extra92"
  kind: python_call_eq
  category: integer_identity
  id_prefix: inspectcoargcount92

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_co_argcount_eq_2,
       "getmembers.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — getmembers takes object and predicate as positional-or-keyword parameters; co_argcount is 2; int.__eq__(2) returns True; getmembers differs from the single-argument predicates and utility functions tested above; new to extra92"]
    - [getmodule_co_argcount_eq_2,
       "getmodule.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmodule.__code__.co_argcount.__eq__(2) == True — getmodule takes object and _filename as positional-or-keyword parameters; co_argcount is 2; int.__eq__(2) returns True; new to extra92"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra92
# ---------------------------------------------------------------------------

invariant inspect_extra92.currentframe_co_argcount_eq_0:
  description: "inspect.currentframe.__code__.co_argcount == 0 — currentframe takes no positional/keyword parameters; wave 252; new to extra92"
  kind: python_call_eq
  function: currentframe.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant inspect_extra92.ismodule_co_argcount_eq_1:
  description: "inspect.ismodule.__code__.co_argcount == 1 — ismodule takes a single object parameter; wave 252; new to extra92"
  kind: python_call_eq
  function: ismodule.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra92.getmembers_co_argcount_eq_2:
  description: "inspect.getmembers.__code__.co_argcount == 2 — getmembers takes object and predicate parameters; wave 252; new to extra92"
  kind: python_call_eq
  function: getmembers.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra92.signature_co_argcount_eq_1:
  description: "inspect.signature.__code__.co_argcount == 1 — signature takes a single obj parameter; wave 252; new to extra92"
  kind: python_call_eq
  function: signature.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant inspect_extra92.getmodule_co_argcount_eq_2:
  description: "inspect.getmodule.__code__.co_argcount == 2 — getmodule takes object and _filename parameters; wave 252; new to extra92"
  kind: python_call_eq
  function: getmodule.__code__.co_argcount.__eq__
  args: [2]
  expected: true
