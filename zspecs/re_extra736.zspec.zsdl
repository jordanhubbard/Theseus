spec: re_extra736
version: ">=3.9"
backend: python_module(re)
docs: "re.Match method qualnames and re class introspection"
provenance:
  derived_from:
    - python_stdlib_re
  not_derived_from: []
  notes: "Covers Match method qualnames, Pattern/Match/error class names, and doc string types"
  created_at: "2026-04-12"
error_model: python_exceptions

table re_extra736.match_method_qualnames:
  description: "re.Match method __qualname__ values and re class identity checks"
  kind: python_call_eq
  category: stdlib_introspection
  id_prefix: re736xx
  columns: [id, function, args, expected]
  rows:
    - [re736xx001, re.Match.start.__qualname__.__eq__, ["Match.start"], true]
    - [re736xx002, re.Match.end.__qualname__.__eq__, ["Match.end"], true]
    - [re736xx003, re.Match.expand.__qualname__.__eq__, ["Match.expand"], true]
    - [re736xx004, re.Match.__getitem__.__qualname__.__eq__, ["Match.__getitem__"], true]
    - [re736xx005, re.Match.__repr__.__qualname__.__eq__, ["Match.__repr__"], true]
    - [re736xx006, re.Pattern.__class__.__name__.__eq__, ["type"], true]
    - [re736xx007, re.Match.__class__.__name__.__eq__, ["type"], true]
    - [re736xx008, re.error.__class__.__name__.__eq__, ["type"], true]
    - [re736xx009, re.Pattern.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re736xx010, re.Match.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re736xx011, re.error.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [re736xx012, re.compile.__doc__.__class__.__name__.__eq__, ["str"], true]
