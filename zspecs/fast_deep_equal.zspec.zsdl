spec: fast_deep_equal
version: ">=3.0.0"
backend: node(fast-deep-equal)

docs: https://github.com/epoberezkin/fast-deep-equal#readme

provenance:
  derived_from:
    - "fast-deep-equal README — https://github.com/epoberezkin/fast-deep-equal#readme"
    - "Test vectors verified with fast-deep-equal@3.1.3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "fast-deep-equal source: index.js"
  notes:
    - "fast-deep-equal exports the equal function as the module default (CJS)."
    - "require('fast-deep-equal') returns the function directly; fn_name is null."
    - "Returns true if two values are deeply equal, false otherwise."
    - "Performs strict deep equality (similar to JSON.stringify comparison for plain objects)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean. No errors."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table fast_deep_equal.equal:
  kind: node_module_call_eq
  function: ~
  category: equal
  id_prefix: fde

  columns: [id, args, expected]
  rows:
    - [obj_eq,    [{"a": 1}, {"a": 1}],  true]
    - [obj_ne,    [{"a": 1}, {"a": 2}],  false]
    - [arr_eq,    [[1, 2, 3], [1, 2, 3]], true]
    - [arr_ne,    [[1, 2], [1, 3]],       false]
    - [num_eq,    [1, 1],                 true]
    - [str_ne,    ["a", "b"],             false]
    - [nested,    [{"a": {"b": 1}}, {"a": {"b": 1}}], true]
