spec: fast_deep_equal
version: ">=3.0.0"
backend: node(fast-deep-equal)

docs: https://www.npmjs.com/package/fast-deep-equal

provenance:
  derived_from:
    - "fast-deep-equal README — https://www.npmjs.com/package/fast-deep-equal"
    - "Test vectors verified with fast-deep-equal via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "fast-deep-equal source"
  notes:
    - "fast-deep-equal is an npm package. Install: npm install fast-deep-equal"
    - "equal(a, b) returns true if a and b are deeply equal."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table fast_deep_equal.equal:
  kind: node_module_call_eq
  function: ~
  category: compare
  id_prefix: fdeq

  columns: [id, args, expected]
  rows:
    - [obj_equal,   [{"a": 1, "b": [2, 3]}, {"a": 1, "b": [2, 3]}], true]
    - [obj_not_eq,  [{"a": 1}, {"a": 2}],                            false]
    - [arr_equal,   [[1, 2, 3], [1, 2, 3]],                          true]
    - [arr_not_eq,  [[1, 2, 3], [1, 2, 4]],                          false]
