spec: concurrent_futures_extra2641
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures classes documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures Future, ThreadPoolExecutor, ProcessPoolExecutor, Executor __dict__ for __copy__, __deepcopy__, __sizeof__ presence (all false)"]
  created_at: "2026-04-13"
error_model: python_exceptions

table concurrent_futures_extra2641.future_dict_presence:
  description: "concurrent.futures.Future __dict__ does not contain __copy__, __deepcopy__, __sizeof__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: cf2641fd
  columns: [id, function, args, expected]
  rows:
    - ["cf2641fd001", concurrent.futures.Future.__dict__.__contains__, ["__copy__"], false]
    - ["cf2641fd002", concurrent.futures.Future.__dict__.__contains__, ["__deepcopy__"], false]
    - ["cf2641fd003", concurrent.futures.Future.__dict__.__contains__, ["__sizeof__"], false]

