spec: numbers_extra21
version: ">=3.9"
backend: python_module(numbers)

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html — Python numbers module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/numbers.py"
  notes:
    - "This spec extends numbers_extra20.zspec.zsdl."
    - "Prior specs covered: __name__/__module__/__qualname__ and their lengths for all 5 ABCs, __mro__.__len__() table and standalone invariants for all 5 ABCs, Real/Rational/Integral.__abstractmethods__.__len__() standalone invariants, __qualname__.__len__() for Complex/Real/Rational."
    - "This spec covers: __abstractmethods__.__len__() combined table for all 5 ABCs; __bases__[0].__name__ and __bases__[0].__name__.__len__() for all 5 ABCs; Complex.__abstractmethods__.__len__() and Number.__abstractmethods__.__len__() standalone invariants not yet recorded."
    - "Number.__abstractmethods__ == frozenset() (length 0) — Number is the root ABC with no abstract methods."
    - "Complex.__abstractmethods__.__len__() == 16; these 16 methods define the complex number contract."
    - "Integral.__abstractmethods__.__len__() == 34 — the most abstract methods of any ABC in the numbers tower; adds bitwise operations like __and__, __or__, __xor__, __lshift__, __rshift__, __invert__."
    - "Base class names along the chain: Number→object, Complex→Number, Real→Complex, Rational→Real, Integral→Rational."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __abstractmethods__.__len__() table — abstract method counts for all 5 ABCs
#
# The numbers tower accumulates abstract methods as you descend the hierarchy.
# Number (root) declares none. Complex declares 16. Real adds 7 more (23).
# Rational adds 1 more for numerator/denominator properties (24). Integral
# adds 10 more for bitwise operations (34). This table records all five counts
# together. No prior numbers spec records all five in a single combined table.
# ---------------------------------------------------------------------------

table numbers_extra21.abc_abstractmethods_lens:
  description: "__abstractmethods__.__len__() for all 5 numbers ABCs"
  kind: python_call_eq
  category: class_identity
  id_prefix: abstractmethods_len

  columns: [id, function, args, expected, description]
  rows:
    - [Number,
       Number.__abstractmethods__.__len__,
       [],
       0,
       "len(numbers.Number.__abstractmethods__) == 0 — root ABC declares no abstract methods"]
    - [Complex,
       Complex.__abstractmethods__.__len__,
       [],
       16,
       "len(numbers.Complex.__abstractmethods__) == 16 — defines the complex number contract"]
    - [Real,
       Real.__abstractmethods__.__len__,
       [],
       23,
       "len(numbers.Real.__abstractmethods__) == 23 — adds trunc/floor/ceil/round and real arithmetic"]
    - [Rational,
       Rational.__abstractmethods__.__len__,
       [],
       24,
       "len(numbers.Rational.__abstractmethods__) == 24 — adds numerator and denominator properties"]
    - [Integral,
       Integral.__abstractmethods__.__len__,
       [],
       34,
       "len(numbers.Integral.__abstractmethods__) == 34 — adds bitwise ops: and/or/xor/lshift/rshift/invert"]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() table — base class name lengths
#
# Each ABC in the numbers tower has a single direct base. The base class names
# form the chain: object (6) → Number (6) → Complex (7) → Real (4) → Rational (8).
# Reading upward: Number's base is object (6 chars); Complex's base is Number
# (6); Real's base is Complex (7); Rational's base is Real (4); Integral's base
# is Rational (8). No prior numbers spec records __bases__[0].__name__.__len__()
# for any ABC in a combined table.
# ---------------------------------------------------------------------------

table numbers_extra21.abc_bases0_name_lens:
  description: "__bases__[0].__name__.__len__() for all 5 numbers ABCs"
  kind: python_call_eq
  category: class_identity
  id_prefix: bases0_name_len

  columns: [id, function, args, expected, description]
  rows:
    - [Number,
       "Number.__bases__[0].__name__.__len__",
       [],
       6,
       "numbers.Number.__bases__[0].__name__ == 'object' (6 chars)"]
    - [Complex,
       "Complex.__bases__[0].__name__.__len__",
       [],
       6,
       "numbers.Complex.__bases__[0].__name__ == 'Number' (6 chars)"]
    - [Real,
       "Real.__bases__[0].__name__.__len__",
       [],
       7,
       "numbers.Real.__bases__[0].__name__ == 'Complex' (7 chars)"]
    - [Rational,
       "Rational.__bases__[0].__name__.__len__",
       [],
       4,
       "numbers.Rational.__bases__[0].__name__ == 'Real' (4 chars)"]
    - [Integral,
       "Integral.__bases__[0].__name__.__len__",
       [],
       8,
       "numbers.Integral.__bases__[0].__name__ == 'Rational' (8 chars)"]

# ---------------------------------------------------------------------------
# Number.__abstractmethods__.__len__() == 0 — standalone
#
# numbers.Number is the root of the numeric tower. Unlike Complex and its
# descendants, Number declares no abstract methods; it exists purely to
# establish the type identity used by isinstance() checks. Its
# __abstractmethods__ frozenset is empty (length 0). No prior numbers spec
# records this as a standalone invariant.
# ---------------------------------------------------------------------------

invariant numbers_extra21.Number.abstractmethods_len:
  description: "len(numbers.Number.__abstractmethods__) == 0 — Number is the root ABC with no required methods"
  category: class_identity
  kind: python_call_eq
  function: Number.__abstractmethods__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# Complex.__abstractmethods__.__len__() == 16 — standalone
#
# numbers.Complex defines 16 abstract methods including __complex__, __abs__,
# __add__, __mul__, __truediv__, __pow__, __neg__, __pos__, real, imag,
# conjugate, and their reflected variants. This is the first level of the
# tower to impose concrete requirements. No prior numbers spec records
# Complex.__abstractmethods__.__len__() as a standalone invariant.
# ---------------------------------------------------------------------------

invariant numbers_extra21.Complex.abstractmethods_len:
  description: "len(numbers.Complex.__abstractmethods__) == 16 — Complex defines 16 abstract methods"
  category: class_identity
  kind: python_call_eq
  function: Complex.__abstractmethods__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# Integral.__abstractmethods__.__len__() == 34 — standalone
#
# numbers.Integral defines 34 abstract methods — the most of any ABC in the
# numbers tower. It adds bitwise operations (__and__, __or__, __xor__,
# __lshift__, __rshift__, __invert__) and their reflected variants, plus
# __int__. No prior numbers spec records Integral.__abstractmethods__.__len__()
# as a standalone invariant (extra20 recorded Real=23 and Rational=24 but
# not Integral separately).
# ---------------------------------------------------------------------------

invariant numbers_extra21.Integral.abstractmethods_len:
  description: "len(numbers.Integral.__abstractmethods__) == 34 — Integral adds bitwise ops for maximum abstract method count"
  category: class_identity
  kind: python_call_eq
  function: Integral.__abstractmethods__.__len__
  args: []
  expected: 34

# ---------------------------------------------------------------------------
# Integral.__bases__[0].__name__ == 'Rational' — standalone
#
# numbers.Integral directly subclasses numbers.Rational. Its base class name
# is 'Rational' (8 chars) — the longest base class name in the numbers chain
# (compared to 'object'=6, 'Number'=6, 'Complex'=7, 'Real'=4). No prior
# numbers spec records this as a standalone invariant.
# ---------------------------------------------------------------------------

invariant numbers_extra21.Integral.bases0_name:
  description: "numbers.Integral.__bases__[0].__name__ == 'Rational'"
  category: class_identity
  kind: python_call_eq
  function: "Integral.__bases__[0].__name__.__eq__"
  args: ["Rational"]
  expected: true

# ---------------------------------------------------------------------------
# Complex.__bases__[0].__name__ == 'Number' — standalone
#
# numbers.Complex directly subclasses numbers.Number, the root of the numeric
# tower. Its base class name is 'Number' (6 chars). This confirms the direct
# parent-child link between the root ABC and the first concrete-contract ABC.
# No prior numbers spec records this as a standalone invariant.
# ---------------------------------------------------------------------------

invariant numbers_extra21.Complex.bases0_name:
  description: "numbers.Complex.__bases__[0].__name__ == 'Number'"
  category: class_identity
  kind: python_call_eq
  function: "Complex.__bases__[0].__name__.__eq__"
  args: ["Number"]
  expected: true
