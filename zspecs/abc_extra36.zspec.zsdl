spec: abc_extra36
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra35.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token/update_abstractmethods, abstractproperty lengths, ABCMeta.register qualname lengths, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__(), ABCMeta/__subclasshook__/__qualname__.__len__()==24, update_abstractmethods/__qualname__.__len__()==22, ABC/__abstractmethods__/__class__/__name__.__len__()==9, ABC/__name__.__len__()==3, abstractmethod/__name__.__len__()==14, get_cache_token/__name__.__len__()==15, abc/__name__.__len__()==3, ABCMeta mro entry name/qualname lengths, ABC/__subclasshook__/__qualname__.__len__()==20, issubclass/isinstance behavioral invariants, abstractmethod/__class__/__name__.__len__()==8, ABC/__doc__/__class__/__name__.__len__()==3, ABCMeta/__prepare__/__qualname__.__len__()==19, ABCMeta/__init__/__qualname__.__len__()==13, ABCMeta/__getattribute__/__qualname__.__len__()==21, ABCMeta/__call__/__repr__/__qualname__.__len__()==13, ABCMeta/__setattr__/__delattr__/__qualname__.__len__()==16, abstractmethod/__code__/__class__/__name__.__len__()==4, ABC/__init_subclass__/__qualname__/__len__()==21, metaclass chain tables, abstractmethod/__annotations__/__class__/__name__.__len__()==4, get_cache_token/__class__/__name__.__len__()==26, ABCMeta/__bases__[0]/__module__/__qualname__.__len__(), ABC/__bases__[0]/__module__/__qualname__.__len__(), abstractmethod/__class__/__module__.__len__()==8, abc/__spec__/__class__/__name__.__len__()==10, ABCMeta MRO __module__/__qualname__.__len__() tables, abstractmethod/__name__=='abstractmethod' (extra34), get_cache_token/__module__=='_abc' (extra34), ABC/__name__=='ABC' (extra34), ABC/__bases__[0].__name__=='object' (extra34), ABCMeta/__name__=='ABCMeta'/__module__=='abc'/__bases__[0].__name__=='type' (extra35), ABCMeta.register.__qualname__.__len__()==16 (extra35), ABCMeta/__mro__.__len__()==3, ABC/__mro__.__len__()==2, ABC/__mro__[1].__name__=='object' (extra35)."
    - "This spec covers: ABCMeta.__mro__[0].__name__=='ABCMeta' (self); ABCMeta.__mro__[1].__name__=='type'; ABCMeta.__mro__[2].__name__=='object'; ABC.__mro__[0].__name__=='ABC' (self); abstractmethod.__qualname__.__len__()==14 ('abstractmethod'); abstractproperty.__name__=='abstractproperty'; abstractproperty.__module__=='abc'; abstractclassmethod.__name__=='abstractclassmethod'."
    - "abc.ABCMeta.__mro__ == [ABCMeta, type, object]. Each MRO entry can be checked by index: __mro__[0] is ABCMeta itself (the class), __mro__[1] is type (the metaclass root), __mro__[2] is object (the universal base). Indexing into __mro__ is a novel form vs measuring the overall __mro__.__len__()==3 (captured in extra35)."
    - "abc.ABC.__mro__[0].__name__ == 'ABC'. The self-entry in a class's own MRO is always the class itself. For ABC, __mro__[0] is ABC and __mro__[1] is object (extra35 captured the [1] index; extra36 captures the [0] index as a complementary self-reference check)."
    - "abc.abstractmethod.__qualname__ == 'abstractmethod' (14 chars). The __qualname__ equals the __name__ for top-level classes (no enclosing class or function scope). Both are 'abstractmethod' — the same 14-character string. Prior specs measured __qualname__.__len__() as an integer in other namespaces; extra36 captures it in this namespace."
    - "abc.abstractproperty is deprecated since Python 3.3 but still present in the module as of Python 3.14. abstractproperty.__name__ == 'abstractproperty' (16 chars) and abstractproperty.__module__ == 'abc' (3 chars). The class remains in the module for backward compatibility."
    - "abc.abstractclassmethod is deprecated since Python 3.3 but still present in the module as of Python 3.14. abstractclassmethod.__name__ == 'abstractclassmethod' (19 chars) and abstractclassmethod.__module__ == 'abc' (3 chars). Both deprecated abstract decorator classes remain in 'abc' for backward compatibility."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta MRO entry names by index — extra36 namespace
#
# ABCMeta.__mro__ == [ABCMeta, type, object]:
#   ABCMeta.__mro__[0].__name__ == 'ABCMeta'  (self — the class itself)
#   ABCMeta.__mro__[1].__name__ == 'type'     (the root metaclass)
#   ABCMeta.__mro__[2].__name__ == 'object'   (the universal base)
# Extra35 captured __mro__.__len__()==3 and __bases__[0].__name__=='type'.
# Extra36 captures the individual MRO entries by index — confirming both
# the self-entry at [0] and the full chain to object at [2].
# ---------------------------------------------------------------------------

table abc_extra36.ABCMeta_mro_entries:
  description: "abc.ABCMeta MRO entry names by index in extra36 namespace — ABCMeta(0), type(1), object(2)"
  kind: python_call_eq
  category: class_names
  id_prefix: abcmetamroent36

  columns: [id, function, args, expected, description]
  rows:
    - [mro0, "ABCMeta.__mro__[0].__name__.__eq__", ["ABCMeta"], true, "ABCMeta.__mro__[0].__name__ == 'ABCMeta' — the class itself is always first in its own MRO"]
    - [mro1, "ABCMeta.__mro__[1].__name__.__eq__", ["type"],    true, "ABCMeta.__mro__[1].__name__ == 'type' — ABCMeta extends the root Python metaclass"]
    - [mro2, "ABCMeta.__mro__[2].__name__.__eq__", ["object"],  true, "ABCMeta.__mro__[2].__name__ == 'object' — the universal base at the end of every MRO"]

# ---------------------------------------------------------------------------
# abc.ABC MRO self-entry — extra36 namespace
#
# ABC.__mro__[0].__name__ == 'ABC'
# A class is always the first entry in its own MRO. For ABC, the MRO is
# [ABC, object], so __mro__[0] is ABC itself. Extra35 captured __mro__[1]
# ('object'); extra36 captures __mro__[0] ('ABC') as the complementary check.
# ---------------------------------------------------------------------------

invariant abc_extra36.ABC_mro0_name_eq:
  description: "abc.ABC.__mro__[0].__name__ == 'ABC' — the first MRO entry is always the class itself; confirms ABC's self-reference in its own MRO"
  category: class_names
  kind: python_call_eq
  function: "ABC.__mro__[0].__name__.__eq__"
  args: ["ABC"]
  expected: true

# ---------------------------------------------------------------------------
# abc.abstractmethod __qualname__ length — extra36 namespace
#
# abstractmethod.__qualname__ == 'abstractmethod' (14 chars)
# For top-level classes, __qualname__ equals __name__. Both are 'abstractmethod'
# (14 chars). Prior specs measured __qualname__.__len__()==14 in other namespaces;
# extra36 establishes it in this namespace.
# ---------------------------------------------------------------------------

invariant abc_extra36.abstractmethod_qualname_len:
  description: "abc.abstractmethod.__qualname__.__len__() == 14 — 'abstractmethod' has 14 characters; __qualname__ equals __name__ for top-level classes"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# abc deprecated abstract decorator classes — extra36 namespace
#
# Two deprecated abstract decorator classes still present in Python 3.14:
#   abstractproperty.__name__        == 'abstractproperty'    (16 chars)
#   abstractproperty.__module__      == 'abc'                 ( 3 chars)
#   abstractclassmethod.__name__     == 'abstractclassmethod' (19 chars)
#   abstractclassmethod.__module__   == 'abc'                 ( 3 chars)
# Both have been deprecated since Python 3.3 in favor of combining
# @abstractmethod with @property or @classmethod. They remain in the module
# for backward compatibility. Both live in the 'abc' module (3 chars).
# ---------------------------------------------------------------------------

table abc_extra36.deprecated_abstract_decorators:
  description: "abc deprecated abstract decorator class identity in extra36 namespace — abstractproperty and abstractclassmethod"
  kind: python_call_eq
  category: class_names
  id_prefix: abcdeprabsdec36

  columns: [id, function, args, expected, description]
  rows:
    - [abstractproperty_name,      abstractproperty.__name__.__eq__,      ["abstractproperty"],    true, "abstractproperty.__name__ == 'abstractproperty' (16 chars) — deprecated since Python 3.3"]
    - [abstractproperty_module,    abstractproperty.__module__.__eq__,    ["abc"],                 true, "abstractproperty.__module__ == 'abc' (3 chars)"]
    - [abstractclassmethod_name,   abstractclassmethod.__name__.__eq__,   ["abstractclassmethod"], true, "abstractclassmethod.__name__ == 'abstractclassmethod' (19 chars) — deprecated since Python 3.3"]
    - [abstractclassmethod_module, abstractclassmethod.__module__.__eq__, ["abc"],                 true, "abstractclassmethod.__module__ == 'abc' (3 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra36
# ---------------------------------------------------------------------------

invariant abc_extra36.ABCMeta_mro0_name_eq:
  description: "abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta' — the first MRO entry is the class itself; ABCMeta's MRO begins with ABCMeta at index 0"
  category: class_names
  kind: python_call_eq
  function: "ABCMeta.__mro__[0].__name__.__eq__"
  args: ["ABCMeta"]
  expected: true

invariant abc_extra36.ABCMeta_mro1_name_eq:
  description: "abc.ABCMeta.__mro__[1].__name__ == 'type' — ABCMeta extends the root Python metaclass 'type'; MRO index 1 is 'type'"
  category: class_names
  kind: python_call_eq
  function: "ABCMeta.__mro__[1].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra36.ABCMeta_mro2_name_eq:
  description: "abc.ABCMeta.__mro__[2].__name__ == 'object' — the universal base class terminates every MRO; ABCMeta's MRO ends with 'object' at index 2"
  category: class_names
  kind: python_call_eq
  function: "ABCMeta.__mro__[2].__name__.__eq__"
  args: ["object"]
  expected: true

invariant abc_extra36.abstractproperty_name_eq:
  description: "abc.abstractproperty.__name__ == 'abstractproperty' — deprecated abstract property decorator; still present in Python 3.14 for backward compatibility (16 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractproperty.__name__.__eq__
  args: ["abstractproperty"]
  expected: true

invariant abc_extra36.abstractproperty_module_eq:
  description: "abc.abstractproperty.__module__ == 'abc' — the deprecated abstractproperty class is defined in the abc module (3 chars)"
  category: module_names
  kind: python_call_eq
  function: abstractproperty.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra36.abstractclassmethod_name_eq:
  description: "abc.abstractclassmethod.__name__ == 'abstractclassmethod' — deprecated abstract classmethod decorator; still present in Python 3.14 for backward compatibility (19 chars)"
  category: class_names
  kind: python_call_eq
  function: abstractclassmethod.__name__.__eq__
  args: ["abstractclassmethod"]
  expected: true
