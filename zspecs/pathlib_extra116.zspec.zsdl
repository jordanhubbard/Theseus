spec: pathlib_extra116
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra115.zspec.zsdl."
    - "This spec covers: pathlib.Path.lstat, readlink, owner, group, walk, iterdir, match, and as_uri method qualnames and co_argcounts."
    - "pathlib.Path.lstat.__qualname__ == 'Path.lstat' (len 10); co_argcount == 1 (self only)."
    - "pathlib.Path.readlink.__qualname__ == 'Path.readlink' (len 13); co_argcount == 1 (self only)."
    - "pathlib.Path.owner.__qualname__ == 'Path.owner' (len 10); co_argcount == 1 (self only)."
    - "pathlib.Path.group.__qualname__ == 'Path.group' (len 10); co_argcount == 1 (self only)."
    - "pathlib.Path.walk.__qualname__ == 'Path.walk' (len 9); co_argcount == 4 (self, top_down, on_error, follow_symlinks); added in Python 3.12."
    - "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir' (len 12); co_argcount == 1 (self only)."
    - "pathlib.Path.match.__qualname__ == 'PurePath.match' (len 14); co_argcount == 2 (self, pattern); defined on PurePath."
    - "pathlib.Path.as_uri.__qualname__ == 'Path.as_uri' (len 11); co_argcount == 1 (self only)."
    - "lstat/readlink/owner/group/iterdir/as_uri use 'Path.' prefix (defined on Path)."
    - "walk uses 'Path.' prefix (defined on Path); match uses 'PurePath.' prefix (defined on PurePath)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.lstat, owner, group qualnames and co_argcounts
# All three are defined on Path (use 'Path.' prefix).
# lstat: 'Path.lstat' (10 chars); co_argcount == 1 (self only).
# owner: 'Path.owner' (10 chars); co_argcount == 1 (self only).
# group: 'Path.group' (10 chars); co_argcount == 1 (self only).
# All three share the same qualname length of 10 chars.
# ---------------------------------------------------------------------------

table pathlib_extra116.Path_lstat_owner_group_qualnames:
  description: "pathlib.Path lstat/owner/group __qualname__: all 'Path.<method>'(10 chars each); co_argcount == 1 for all; lstat returns stat without following symlinks"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn116a

  columns: [id, function, args, expected, description]
  rows:
    - [lstat_qn_eq,       "Path.lstat.__qualname__.__eq__",           ["Path.lstat"],   true,  "pathlib.Path.lstat.__qualname__ == 'Path.lstat' (defined on Path; lstat does not follow symlinks)"]
    - [lstat_qn_len,      "Path.lstat.__qualname__.__len__",          [],               10,    "pathlib.Path.lstat.__qualname__.__len__() == 10 ('Path.lstat' has 10 chars)"]
    - [lstat_argcount,    "Path.lstat.__code__.co_argcount.__eq__",   [1],              true,  "pathlib.Path.lstat.__code__.co_argcount == 1 (self only; unlike stat there is no follow_symlinks param)"]
    - [owner_qn_eq,       "Path.owner.__qualname__.__eq__",           ["Path.owner"],   true,  "pathlib.Path.owner.__qualname__ == 'Path.owner' (defined on Path; returns file owner name)"]
    - [owner_qn_len,      "Path.owner.__qualname__.__len__",          [],               10,    "pathlib.Path.owner.__qualname__.__len__() == 10 ('Path.owner' has 10 chars; same length as lstat)"]
    - [owner_argcount,    "Path.owner.__code__.co_argcount.__eq__",   [1],              true,  "pathlib.Path.owner.__code__.co_argcount == 1 (self only; uses pwd module on Unix)"]
    - [group_qn_eq,       "Path.group.__qualname__.__eq__",           ["Path.group"],   true,  "pathlib.Path.group.__qualname__ == 'Path.group' (defined on Path; returns file group name)"]
    - [group_qn_len,      "Path.group.__qualname__.__len__",          [],               10,    "pathlib.Path.group.__qualname__.__len__() == 10 ('Path.group' has 10 chars; same length as lstat and owner)"]
    - [group_argcount,    "Path.group.__code__.co_argcount.__eq__",   [1],              true,  "pathlib.Path.group.__code__.co_argcount == 1 (self only; uses grp module on Unix)"]
    - [lstat_eq_owner_len, "Path.lstat.__qualname__.__len__.__eq__",  [10],             true,  "len('Path.lstat') == len('Path.owner') == len('Path.group') == 10 (all share identical qualname length)"]

# ---------------------------------------------------------------------------
# pathlib.Path.readlink, iterdir, as_uri qualnames and co_argcounts
# readlink: 'Path.readlink' (13 chars); co_argcount == 1.
# iterdir: 'Path.iterdir' (12 chars); co_argcount == 1.
# as_uri: 'Path.as_uri' (11 chars); co_argcount == 1.
# All are defined on Path (use 'Path.' prefix).
# ---------------------------------------------------------------------------

table pathlib_extra116.Path_readlink_iterdir_asuri_qualnames:
  description: "pathlib.Path readlink/iterdir/as_uri __qualname__: readlink='Path.readlink'(13), iterdir='Path.iterdir'(12), as_uri='Path.as_uri'(11); co_argcount == 1 for all three"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn116b

  columns: [id, function, args, expected, description]
  rows:
    - [readlink_qn_eq,    "Path.readlink.__qualname__.__eq__",           ["Path.readlink"],  true,  "pathlib.Path.readlink.__qualname__ == 'Path.readlink' (defined on Path; available Python 3.9+)"]
    - [readlink_qn_len,   "Path.readlink.__qualname__.__len__",          [],                 13,    "pathlib.Path.readlink.__qualname__.__len__() == 13 ('Path.readlink' has 13 chars)"]
    - [readlink_argcount, "Path.readlink.__code__.co_argcount.__eq__",   [1],                true,  "pathlib.Path.readlink.__code__.co_argcount == 1 (self only; returns the target of a symbolic link)"]
    - [iterdir_qn_eq,     "Path.iterdir.__qualname__.__eq__",            ["Path.iterdir"],   true,  "pathlib.Path.iterdir.__qualname__ == 'Path.iterdir' (defined on Path; yields directory contents)"]
    - [iterdir_qn_len,    "Path.iterdir.__qualname__.__len__",           [],                 12,    "pathlib.Path.iterdir.__qualname__.__len__() == 12 ('Path.iterdir' has 12 chars)"]
    - [iterdir_argcount,  "Path.iterdir.__code__.co_argcount.__eq__",    [1],                true,  "pathlib.Path.iterdir.__code__.co_argcount == 1 (self only; yields Path objects for directory entries)"]
    - [asuri_qn_eq,       "Path.as_uri.__qualname__.__eq__",             ["Path.as_uri"],    true,  "pathlib.Path.as_uri.__qualname__ == 'Path.as_uri' (defined on Path; represents path as file:// URI)"]
    - [asuri_qn_len,      "Path.as_uri.__qualname__.__len__",            [],                 11,    "pathlib.Path.as_uri.__qualname__.__len__() == 11 ('Path.as_uri' has 11 chars)"]
    - [asuri_argcount,    "Path.as_uri.__code__.co_argcount.__eq__",     [1],                true,  "pathlib.Path.as_uri.__code__.co_argcount == 1 (self only; requires path to be absolute)"]
    - [readlink_gt_iterdir, "Path.readlink.__qualname__.__len__.__gt__", [12],               true,  "len('Path.readlink') > len('Path.iterdir') (13 > 12; readlink is one char longer)"]

# ---------------------------------------------------------------------------
# pathlib.Path.walk and pathlib.Path.match qualnames and co_argcounts
# walk: 'Path.walk' (9 chars); co_argcount == 4 (self, top_down, on_error, follow_symlinks).
# match: 'PurePath.match' (14 chars); co_argcount == 2 (self, pattern); defined on PurePath.
# walk was added in Python 3.12; match uses 'PurePath.' prefix since defined on PurePath.
# ---------------------------------------------------------------------------

table pathlib_extra116.Path_walk_match_qualnames:
  description: "pathlib.Path walk/match __qualname__: walk='Path.walk'(9) with co_argcount=4, match='PurePath.match'(14) with co_argcount=2; walk added in 3.12; match defined on PurePath"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibqn116c

  columns: [id, function, args, expected, description]
  rows:
    - [walk_qn_eq,        "Path.walk.__qualname__.__eq__",              ["Path.walk"],      true,  "pathlib.Path.walk.__qualname__ == 'Path.walk' (defined on Path; added in Python 3.12; dir tree generator)"]
    - [walk_qn_len,       "Path.walk.__qualname__.__len__",             [],                 9,     "pathlib.Path.walk.__qualname__.__len__() == 9 ('Path.walk' has 9 chars; shortest qualname in this group)"]
    - [walk_argcount,     "Path.walk.__code__.co_argcount.__eq__",      [4],                true,  "pathlib.Path.walk.__code__.co_argcount == 4 (self, top_down, on_error, follow_symlinks)"]
    - [match_qn_eq,       "Path.match.__qualname__.__eq__",             ["PurePath.match"], true,  "pathlib.Path.match.__qualname__ == 'PurePath.match' (defined on PurePath; uses 'PurePath.' prefix)"]
    - [match_qn_len,      "Path.match.__qualname__.__len__",            [],                 14,    "pathlib.Path.match.__qualname__.__len__() == 14 ('PurePath.match' has 14 chars; longest in this group)"]
    - [match_argcount,    "Path.match.__code__.co_argcount.__eq__",     [2],                true,  "pathlib.Path.match.__code__.co_argcount == 2 (self, pattern; matches path components against glob pattern)"]
    - [match_ne_path_prefix, "Path.match.__qualname__.__eq__",          ["Path.match"],     false, "pathlib.Path.match.__qualname__ != 'Path.match' (qualname uses 'PurePath.' prefix because match is defined on PurePath)"]
    - [walk_lt_match,     "Path.walk.__qualname__.__len__.__lt__",      [14],               true,  "len('Path.walk') < len('PurePath.match') (9 < 14)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra116.Path.lstat_qualname:
  description: "pathlib.Path.lstat.__qualname__ == 'Path.lstat' (length 10; lstat is defined on Path and uses the 'Path.' prefix; co_argcount == 1 taking only self; lstat returns the stat of the symlink itself rather than its target, unlike stat() which follows symlinks)"
  category: qualnames
  kind: python_call_eq
  function: "Path.lstat.__qualname__.__eq__"
  args: ["Path.lstat"]
  expected: true

invariant pathlib_extra116.Path.readlink_qualname_len:
  description: "pathlib.Path.readlink.__qualname__.__len__() == 13 ('Path.readlink' has 13 characters; readlink is defined on Path with co_argcount == 1; it returns a new Path object representing the symlink target; available since Python 3.9)"
  category: qualnames
  kind: python_call_eq
  function: "Path.readlink.__qualname__.__len__"
  args: []
  expected: 13

invariant pathlib_extra116.Path.walk_argcount_4:
  description: "pathlib.Path.walk.__code__.co_argcount == 4 (walk takes self, top_down, on_error, and follow_symlinks; it is a generator that yields (dirpath, dirnames, filenames) tuples for each directory in the tree; added in Python 3.12 as a pathlib equivalent of os.walk)"
  category: qualnames
  kind: python_call_eq
  function: "Path.walk.__code__.co_argcount.__eq__"
  args: [4]
  expected: true

invariant pathlib_extra116.Path.match_purepath_qualname:
  description: "pathlib.Path.match.__qualname__ == 'PurePath.match' (length 14; match is inherited from PurePath so its qualname carries the 'PurePath.' prefix; co_argcount == 2 for self and pattern; contrast with lstat/owner/group/as_uri which use the 'Path.' prefix)"
  category: qualnames
  kind: python_call_eq
  function: "Path.match.__qualname__.__eq__"
  args: ["PurePath.match"]
  expected: true

invariant pathlib_extra116.Path.walk_qualname_len:
  description: "pathlib.Path.walk.__qualname__.__len__() == 9 ('Path.walk' has 9 characters; it is the shortest Path method qualname among those examined in this spec; 'Path.' (5) + 'walk' (4) == 9)"
  category: qualnames
  kind: python_call_eq
  function: "Path.walk.__qualname__.__len__"
  args: []
  expected: 9

