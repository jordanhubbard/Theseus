spec: click_extra2_rust
version: ">=3.9"
backend: rust_module(click_extra2_rust)

docs: https://click.palletsprojects.com/en/latest/api/

provenance:
  derived_from:
    - "https://click.palletsprojects.com/en/latest/api/ — Click API"
  not_derived_from:
    - "click source: src/click/__init__.py"
  notes:
    - "Click is a Python composable command line interface toolkit."
    - "click.echo('hello', err=False) writes to stdout."
    - "click.format_filename('/path/to/file') == '/path/to/file'."
    - "click.format_filename(b'/bytes/path') == '/bytes/path'."
    - "click.types.STRING is an instance of click.STRING."
    - "click.types.INT is an instance of click.INT."
    - "Expose click2_format_filename(fn) -> str: click.format_filename(fn)."
    - "Expose click2_string_type_name() -> str: click.STRING.name."
    - "Expose click2_int_type_name() -> str: click.INT.name."
    - "All test vectors verified against click 8.1.8."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# click2_format_filename — format_filename roundtrip
table click_extra2_rust.utils.format_filename:
  kind: python_call_eq
  category: format_filename
  id_prefix: ck2_ff
  function: click2_format_filename

  columns: [id, args, expected]
  rows:
    - [path,  ["/path/to/file"], "/path/to/file"]
    - [simple, ["file.txt"],     "file.txt"]

# click2_string_type_name — STRING type name
invariant click_extra2_rust.types.string_name:
  description: "click.STRING.name == 'TEXT'"
  category: types
  kind: python_call_eq
  function: click2_string_type_name
  args: []
  expected: "TEXT"

# click2_int_type_name — INT type name
invariant click_extra2_rust.types.int_name:
  description: "click.INT.name == 'INTEGER'"
  category: types
  kind: python_call_eq
  function: click2_int_type_name
  args: []
  expected: "INTEGER"

