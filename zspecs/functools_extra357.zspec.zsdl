spec: functools_extra357
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.partialmethod.__name__ == 'partialmethod' — verified with Python 3.14.3."
    - "functools.partialmethod.__module__ == 'functools' — verified with Python 3.14.3."
    - "functools.partialmethod.__qualname__ == 'partialmethod' — verified with Python 3.14.3."
    - "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod inherits directly from object. Verified with Python 3.14.3."
    - "functools.partialmethod.__doc__.__class__.__name__ == 'str' — the docstring is a str. Verified with Python 3.14.3."
    - "functools.partialmethod.__doc__.__len__() == 178 — docstring length verified on Python 3.14.3 macOS."
    - "functools.singledispatchmethod.__name__ == 'singledispatchmethod' — verified with Python 3.14.3."
    - "functools.singledispatchmethod.__module__ == 'functools' — verified with Python 3.14.3."
    - "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — singledispatchmethod inherits directly from object. Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partialmethod class identity
#
# functools.partialmethod.__name__ == 'partialmethod'
# functools.partialmethod.__module__ == 'functools'
# functools.partialmethod.__qualname__ == 'partialmethod'
# functools.partialmethod.__bases__[0].__name__ == 'object'
# functools.partialmethod.__doc__.__class__.__name__ == 'str'
# functools.partialmethod.__doc__.__len__() == 178
#
# partialmethod is a pure-Python class defined in Lib/functools.py.
# It inherits directly from object; MRO is [partialmethod, object].
# ---------------------------------------------------------------------------

table functools_extra357.partialmethod_identity:
  description: "functools.partialmethod class identity: __name__, __module__, __qualname__, __bases__[0].__name__, __doc__ class and length; new to extra357"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspm357

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_name_eq,
       "partialmethod.__name__.__eq__",
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — partialmethod is a pure-Python class defined in Lib/functools.py; its __name__ attribute is 'partialmethod'; str.__eq__('partialmethod') returns True; new to extra357"]
    - [partialmethod_module_eq,
       "partialmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra357"]
    - [partialmethod_qualname_eq,
       "partialmethod.__qualname__.__eq__",
       ["partialmethod"],
       true,
       "functools.partialmethod.__qualname__.__eq__('partialmethod') == True — partialmethod is a top-level class in functools; its __qualname__ equals its __name__, 'partialmethod'; str.__eq__('partialmethod') returns True; new to extra357"]
    - [partialmethod_bases_first_eq_object,
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__.__eq__('object') == True — partialmethod inherits directly from object with no intermediate base class; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra357"]
    - [partialmethod_doc_class_name_eq_str,
       "partialmethod.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.partialmethod.__doc__.__class__.__name__.__eq__('str') == True — the docstring of partialmethod is a Python str object; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra357"]
    - [partialmethod_doc_len_eq_178,
       "partialmethod.__doc__.__len__",
       [],
       178,
       "functools.partialmethod.__doc__.__len__() == 178 — the docstring of partialmethod has length 178 characters as verified on Python 3.14.3 macOS; new to extra357"]

# ---------------------------------------------------------------------------
# Table 2: functools.singledispatchmethod class identity
#
# functools.singledispatchmethod.__name__ == 'singledispatchmethod'
# functools.singledispatchmethod.__module__ == 'functools'
# functools.singledispatchmethod.__bases__[0].__name__ == 'object'
#
# singledispatchmethod is a pure-Python class defined in Lib/functools.py.
# It wraps singledispatch for use on class/instance methods. Added in Python 3.8.
# ---------------------------------------------------------------------------

table functools_extra357.singledispatchmethod_identity:
  description: "functools.singledispatchmethod class identity: __name__, __module__, __bases__[0].__name__; new to extra357"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolssdm357

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatchmethod_name_eq,
       "singledispatchmethod.__name__.__eq__",
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__name__.__eq__('singledispatchmethod') == True — singledispatchmethod is a pure-Python class defined in Lib/functools.py; its __name__ attribute is 'singledispatchmethod'; str.__eq__('singledispatchmethod') returns True; new to extra357"]
    - [singledispatchmethod_module_eq,
       "singledispatchmethod.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatchmethod.__module__.__eq__('functools') == True — singledispatchmethod is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra357"]
    - [singledispatchmethod_bases_first_eq_object,
       "singledispatchmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.singledispatchmethod.__bases__[0].__name__.__eq__('object') == True — singledispatchmethod inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra357"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra357
# ---------------------------------------------------------------------------

invariant functools_extra357.partialmethod_name:
  description: "functools.partialmethod.__name__ == 'partialmethod' — pure-Python class in Lib/functools.py; new to extra357"
  kind: python_call_eq
  function: partialmethod.__name__.__eq__
  args: ["partialmethod"]
  expected: true

invariant functools_extra357.partialmethod_module:
  description: "functools.partialmethod.__module__ == 'functools' — defined in Lib/functools.py; new to extra357"
  kind: python_call_eq
  function: partialmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra357.partialmethod_qualname:
  description: "functools.partialmethod.__qualname__ == 'partialmethod' — top-level class, qualname equals name; new to extra357"
  kind: python_call_eq
  function: partialmethod.__qualname__.__eq__
  args: ["partialmethod"]
  expected: true

invariant functools_extra357.partialmethod_bases_object:
  description: "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod inherits directly from object; new to extra357"
  kind: python_call_eq
  function: partialmethod.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant functools_extra357.partialmethod_doc_class:
  description: "functools.partialmethod.__doc__.__class__.__name__ == 'str' — docstring is a str; new to extra357"
  kind: python_call_eq
  function: partialmethod.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra357.partialmethod_doc_len:
  description: "functools.partialmethod.__doc__.__len__() == 178 — docstring length verified on Python 3.14.3 macOS; new to extra357"
  kind: python_call_eq
  function: partialmethod.__doc__.__len__
  args: []
  expected: 178

invariant functools_extra357.singledispatchmethod_name:
  description: "functools.singledispatchmethod.__name__ == 'singledispatchmethod' — pure-Python class in Lib/functools.py; new to extra357"
  kind: python_call_eq
  function: singledispatchmethod.__name__.__eq__
  args: ["singledispatchmethod"]
  expected: true

invariant functools_extra357.singledispatchmethod_module:
  description: "functools.singledispatchmethod.__module__ == 'functools' — defined in Lib/functools.py; new to extra357"
  kind: python_call_eq
  function: singledispatchmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra357.singledispatchmethod_bases_object:
  description: "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — singledispatchmethod inherits directly from object; new to extra357"
  kind: python_call_eq
  function: singledispatchmethod.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true
