spec: multiprocessing_extra362
version: ">=3.9"
backend: python_module(multiprocessing.managers)
docs: https://docs.python.org/3/library/multiprocessing.html#managers
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#managers — multiprocessing managers documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "BaseManager and BaseProxy both derive directly from object"
    - "SyncManager derives from BaseManager"
    - "All three classes live in module multiprocessing.managers"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra362.manager_names:
  description: "Verify __name__ attribute of multiprocessing.managers classes"
  kind: python_call_eq
  category: identity
  id_prefix: mp362n

  columns: [id, function, args, expected]
  rows:
    - [mp362n001, multiprocessing.managers.BaseManager.__name__.__eq__, ["BaseManager"], true]
    - [mp362n002, multiprocessing.managers.SyncManager.__name__.__eq__, ["SyncManager"], true]
    - [mp362n003, multiprocessing.managers.BaseProxy.__name__.__eq__, ["BaseProxy"], true]

table multiprocessing_extra362.manager_modules:
  description: "Verify __module__ attribute of multiprocessing.managers classes"
  kind: python_call_eq
  category: identity
  id_prefix: mp362m

  columns: [id, function, args, expected]
  rows:
    - [mp362m001, multiprocessing.managers.BaseManager.__module__.__eq__, ["multiprocessing.managers"], true]
    - [mp362m002, multiprocessing.managers.SyncManager.__module__.__eq__, ["multiprocessing.managers"], true]
    - [mp362m003, multiprocessing.managers.BaseProxy.__module__.__eq__, ["multiprocessing.managers"], true]

table multiprocessing_extra362.manager_bases:
  description: "Verify __bases__[0].__name__ (immediate base class name) of multiprocessing.managers classes"
  kind: python_call_eq
  category: identity
  id_prefix: mp362b

  columns: [id, function, args, expected]
  rows:
    - ["mp362b001", "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__", ["object"], true]
    - ["mp362b002", "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__", ["BaseManager"], true]
    - ["mp362b003", "multiprocessing.managers.BaseProxy.__bases__[0].__name__.__eq__", ["object"], true]
