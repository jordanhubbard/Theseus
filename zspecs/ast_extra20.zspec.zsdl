spec: ast_extra20
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "ast_extra19.zspec.zsdl — covers NodeVisitor/NodeTransformer base classes; FunctionDef/ClassDef/Constant node_bases table; FunctionDef/ClassDef __module__; walk/fix_missing_locations/copy_location/increment_lineno/get_docstring __qualname__; walk/copy_location __module__"
    - "ast_extra18.zspec.zsdl — covers parse/__name__/__qualname__/__module__; dump/__name__/__qualname__/__module__; literal_eval round-trips; parse returns Module"
    - "ast_extra17.zspec.zsdl — covers Module/__qualname__; literal_eval/__name__ and unparse/__name__; AST/__module__; Module/Expression/Interactive __bases__[0].__name__"
    - "ast_extra16.zspec.zsdl — covers parse() with explicit mode args; NodeVisitor/__qualname__; NodeTransformer/__qualname__/__bases__"
    - "ast_extra14.zspec.zsdl — covers literal_eval value/type checks; function_names table; NodeVisitor/NodeTransformer/AST __name__; dump __module__"
  notes:
    - "This spec extends ast_extra19.zspec.zsdl."
    - "Focus: __qualname__.__len__() for ast functions; stmt-subclass node qualnames (Assign/Return/If/For/While/Import); expr-subclass node qualnames (Call/Name/Attribute/BinOp); NodeVisitor/NodeTransformer __qualname__.__len__() and __module__."
    - "ast.Assign/__qualname__ == 'Assign', ast.Return/__qualname__ == 'Return', etc. — no prior ast spec verifies these in a combined qualname table."
    - "All common stmt-subclass nodes have __qualname__ equal to their class name and __module__ == 'ast'."
    - "ast.NodeVisitor.__qualname__.__len__() == 11; ast.NodeTransformer.__qualname__.__len__() == 15."
    - "ast.parse.__qualname__.__len__() == 5; ast.dump.__qualname__.__len__() == 4; ast.literal_eval.__qualname__.__len__() == 12."
    - "ast.unparse.__qualname__ == 'unparse' — not covered as a __qualname__ standalone in any prior spec namespace (ast_extra18 covers __name__ for unparse)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# stmt-subclass node __qualname__ table
# (ast_extra20 namespace)
#
# No prior ast spec covers Assign/Return/If/For/While/Import/ImportFrom
# __qualname__ in a combined table. Each node class has a qualname matching
# its class name. All are subclasses of stmt.
# ---------------------------------------------------------------------------

table ast_extra20.stmt_node_qualnames:
  description: "__qualname__ for common ast stmt-subclass node types"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: stmtqualname

  columns: [id, function, args, expected]
  rows:
    - [Assign,     Assign.__qualname__.__eq__,     ["Assign"],     true]
    - [Return,     Return.__qualname__.__eq__,     ["Return"],     true]
    - [If,         If.__qualname__.__eq__,         ["If"],         true]
    - [For,        For.__qualname__.__eq__,        ["For"],        true]
    - [While,      While.__qualname__.__eq__,      ["While"],      true]
    - [Import,     Import.__qualname__.__eq__,     ["Import"],     true]
    - [ImportFrom, ImportFrom.__qualname__.__eq__, ["ImportFrom"], true]

# ---------------------------------------------------------------------------
# expr-subclass node __qualname__ table
# (ast_extra20 namespace)
#
# No prior ast spec covers Call/Name/Attribute/BinOp/UnaryOp __qualname__
# in a combined table. Each is an expr subclass.
# ---------------------------------------------------------------------------

table ast_extra20.expr_node_qualnames:
  description: "__qualname__ for common ast expr-subclass node types"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: exprqualname

  columns: [id, function, args, expected]
  rows:
    - [Call,      Call.__qualname__.__eq__,      ["Call"],      true]
    - [Name,      Name.__qualname__.__eq__,      ["Name"],      true]
    - [Attribute, Attribute.__qualname__.__eq__, ["Attribute"], true]
    - [BinOp,     BinOp.__qualname__.__eq__,     ["BinOp"],     true]
    - [UnaryOp,   UnaryOp.__qualname__.__eq__,   ["UnaryOp"],   true]

# ---------------------------------------------------------------------------
# Core function __qualname__.__len__() — standalone invariants
# (ast_extra20 namespace)
#
# ast_extra18 covers parse/__qualname__.__eq__ and dump/__qualname__.__eq__.
# No prior ast spec measures __qualname__.__len__() for parse, dump, or
# literal_eval as standalone invariants.
# ---------------------------------------------------------------------------

invariant ast_extra20.parse.qualname_len:
  description: "ast.parse.__qualname__.__len__() == 5 — qualname 'parse' has 5 characters"
  category: function_qualname_lengths
  kind: python_call_eq
  function: parse.__qualname__.__len__
  args: []
  expected: 5

invariant ast_extra20.dump.qualname_len:
  description: "ast.dump.__qualname__.__len__() == 4 — qualname 'dump' has 4 characters"
  category: function_qualname_lengths
  kind: python_call_eq
  function: dump.__qualname__.__len__
  args: []
  expected: 4

invariant ast_extra20.literal_eval.qualname_len:
  description: "ast.literal_eval.__qualname__.__len__() == 12 — qualname 'literal_eval' has 12 characters"
  category: function_qualname_lengths
  kind: python_call_eq
  function: literal_eval.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# NodeVisitor and NodeTransformer __qualname__.__len__() and __module__
# (ast_extra20 namespace)
#
# ast_extra16 covers NodeVisitor/__qualname__.__eq__ and NodeTransformer/__qualname__.__eq__.
# No prior ast spec covers __qualname__.__len__() for either class.
# NodeVisitor.__qualname__ == 'NodeVisitor' (len 11);
# NodeTransformer.__qualname__ == 'NodeTransformer' (len 15).
# ---------------------------------------------------------------------------

invariant ast_extra20.NodeVisitor.qualname_len:
  description: "ast.NodeVisitor.__qualname__.__len__() == 11"
  category: class_qualname_lengths
  kind: python_call_eq
  function: NodeVisitor.__qualname__.__len__
  args: []
  expected: 11

invariant ast_extra20.NodeTransformer.qualname_len:
  description: "ast.NodeTransformer.__qualname__.__len__() == 15"
  category: class_qualname_lengths
  kind: python_call_eq
  function: NodeTransformer.__qualname__.__len__
  args: []
  expected: 15

invariant ast_extra20.NodeVisitor.module:
  description: "ast.NodeVisitor.__module__ == 'ast'"
  category: module_attrs
  kind: python_call_eq
  function: NodeVisitor.__module__.__eq__
  args: ["ast"]
  expected: true

# ---------------------------------------------------------------------------
# unparse __qualname__ — standalone invariant
# (ast_extra20 namespace)
#
# ast_extra18 covers unparse.__name__ (== 'unparse'). No prior ast spec covers
# unparse.__qualname__ as a standalone invariant. For simple module-level
# functions __qualname__ == __name__, so both equal 'unparse'.
# ---------------------------------------------------------------------------

invariant ast_extra20.unparse.qualname:
  description: "ast.unparse.__qualname__ == 'unparse'"
  category: function_qualnames
  kind: python_call_eq
  function: unparse.__qualname__.__eq__
  args: ["unparse"]
  expected: true
