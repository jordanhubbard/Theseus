spec: functools_extra2656
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 624 theme: __contains__, __add__, and __mul__ dict-presence checks (container membership and sequence arithmetic)."
    - "functools.partial is a callable wrapper; it does not implement container membership (__contains__) or sequence arithmetic (__add__, __mul__)."
    - "functools.partialmethod is a descriptor; it similarly defines none of these protocols."
    - "functools.cached_property is a data descriptor (defines __get__, __set__, __delete__) but not __contains__, __add__, or __mul__."
    - "functools.singledispatchmethod is a descriptor wrapper; it does not define __contains__, __add__, or __mul__."
    - "None of the functools public classes define __contains__, __add__, or __mul__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __contains__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2656.contains_protocol:
  description: "__contains__ is absent from all functools class __dict__s — none implement container membership"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2656

  columns: [id, function, args, expected]
  rows:
    - ["ft2656001", "functools.partial.__dict__.__contains__",             ["__contains__"], false]
    - ["ft2656002", "functools.partialmethod.__dict__.__contains__",       ["__contains__"], false]
    - ["ft2656003", "functools.cached_property.__dict__.__contains__",     ["__contains__"], false]
    - ["ft2656004", "functools.singledispatchmethod.__dict__.__contains__", ["__contains__"], false]

# ---------------------------------------------------------------------------
# __add__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2656.add_protocol:
  description: "__add__ is absent from all functools class __dict__s — none implement sequence concatenation"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2656

  columns: [id, function, args, expected]
  rows:
    - ["ft2656005", "functools.partial.__dict__.__contains__",             ["__add__"], false]
    - ["ft2656006", "functools.partialmethod.__dict__.__contains__",       ["__add__"], false]
    - ["ft2656007", "functools.cached_property.__dict__.__contains__",     ["__add__"], false]
    - ["ft2656008", "functools.singledispatchmethod.__dict__.__contains__", ["__add__"], false]

# ---------------------------------------------------------------------------
# __mul__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2656.mul_protocol:
  description: "__mul__ is absent from all functools class __dict__s — none implement sequence repetition"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2656

  columns: [id, function, args, expected]
  rows:
    - ["ft2656009", "functools.partial.__dict__.__contains__",             ["__mul__"], false]
    - ["ft2656010", "functools.partialmethod.__dict__.__contains__",       ["__mul__"], false]
    - ["ft2656011", "functools.cached_property.__dict__.__contains__",     ["__mul__"], false]
    - ["ft2656012", "functools.singledispatchmethod.__dict__.__contains__", ["__mul__"], false]

# ---------------------------------------------------------------------------
# Combined view — partial and partialmethod vs. all three protocols
# ---------------------------------------------------------------------------

table functools_extra2656.partial_arithmetic_combined:
  description: "functools.partial and functools.partialmethod define none of __contains__, __add__, __mul__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2656

  columns: [id, function, args, expected]
  rows:
    - ["ft2656013", "functools.partial.__dict__.__contains__",       ["__contains__"], false]
    - ["ft2656014", "functools.partial.__dict__.__contains__",       ["__add__"],      false]
    - ["ft2656015", "functools.partial.__dict__.__contains__",       ["__mul__"],      false]
    - ["ft2656016", "functools.partialmethod.__dict__.__contains__", ["__contains__"], false]
    - ["ft2656017", "functools.partialmethod.__dict__.__contains__", ["__add__"],      false]
    - ["ft2656018", "functools.partialmethod.__dict__.__contains__", ["__mul__"],      false]
