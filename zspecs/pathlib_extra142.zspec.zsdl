# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra142.PurePath.name_is_PurePath:
  description: "pathlib.PurePath.__name__ == 'PurePath' (length 8; the root abstract pure-path class in the pathlib module)"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra142.PurePath.base_is_object:
  description: "pathlib.PurePath.__bases__[0].__name__ == 'object' (length 6; PurePath directly subclasses object with no intermediate ABCs in its bases)"
  category: class_identity
  kind: python_call_eq
  function: "PurePath.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant pathlib_extra142.PurePath.mro_len_2:
  description: "pathlib.PurePath.__mro__.__len__() == 2 (MRO is [PurePath, object]; the minimal possible MRO for a class that directly subclasses object)"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__mro__.__len__
  args: []
  expected: 2

invariant pathlib_extra142.PurePosixPath.base_is_PurePath:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' (length 8; PurePosixPath extends PurePath directly, forming a 3-entry MRO)"
  category: class_identity
  kind: python_call_eq
  function: "PurePosixPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra142.PureWindowsPath.base_is_PurePath:
  description: "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' (length 8; PureWindowsPath extends PurePath directly, mirroring PurePosixPath's inheritance)"
  category: class_identity
  kind: python_call_eq
  function: "PureWindowsPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

