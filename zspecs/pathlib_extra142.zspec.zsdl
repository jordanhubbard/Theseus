spec: pathlib_extra142
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec covers: pathlib.PurePath, pathlib.PurePosixPath, and pathlib.PureWindowsPath class identity (__name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(), __class__.__name__) and method identity (__class__.__name__ and __qualname__) for key PurePath pure-Python methods."
    - "pathlib.PurePath.__name__ == 'PurePath' (length 8) — the root pure-path ABC."
    - "pathlib.PurePath.__module__ == 'pathlib' (length 7) — pure Python module."
    - "pathlib.PurePath.__bases__[0].__name__ == 'object' (length 6) — PurePath directly subclasses object (no intermediate ABCs)."
    - "pathlib.PurePath.__mro__.__len__() == 2 — MRO is [PurePath, object]."
    - "pathlib.PurePath.__class__.__name__ == 'type' — PurePath is a standard Python class with metaclass 'type'."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' (length 8) — PurePosixPath extends PurePath directly."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' (length 8) — PureWindowsPath extends PurePath directly."
    - "PurePosixPath.__mro__.__len__() == 3 and PureWindowsPath.__mro__.__len__() == 3 — [Subclass, PurePath, object]."
    - "PurePath methods (__str__, __repr__, __eq__, __hash__, with_name, with_suffix, joinpath) are all pure Python 'function' instances with qualnames prefixed 'PurePath.'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath class identity
# PurePath is the root abstract pure-path class.
# __name__ == 'PurePath' (8), __module__ == 'pathlib' (7),
# __qualname__ == 'PurePath' (8).
# __bases__[0].__name__ == 'object' (6). MRO length == 2.
# __class__.__name__ == 'type' (standard metaclass).
# ---------------------------------------------------------------------------

table pathlib_extra142.PurePath_class_identity:
  description: "pathlib.PurePath class identity: __name__='PurePath' (8), __module__='pathlib' (7), __qualname__='PurePath' (8), __bases__[0].__name__='object' (6), __mro__.__len__()==2, __class__.__name__='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: plpp142

  columns: [id, function, args, expected]
  rows:
    - [pp_name_eq,      PurePath.__name__.__eq__,                   ["PurePath"], true]
    - [pp_name_len,     PurePath.__name__.__len__,                  [],           8]
    - [pp_module_eq,    PurePath.__module__.__eq__,                 ["pathlib"],  true]
    - [pp_module_len,   PurePath.__module__.__len__,                [],           7]
    - [pp_qualname_eq,  PurePath.__qualname__.__eq__,               ["PurePath"], true]
    - [pp_qualname_len, PurePath.__qualname__.__len__,              [],           8]
    - [pp_base_eq,      "PurePath.__bases__[0].__name__.__eq__",    ["object"],   true]
    - [pp_base_len,     "PurePath.__bases__[0].__name__.__len__",   [],           6]
    - [pp_mro_len,      PurePath.__mro__.__len__,                   [],           2]
    - [pp_cls_eq,       PurePath.__class__.__name__.__eq__,         ["type"],     true]

