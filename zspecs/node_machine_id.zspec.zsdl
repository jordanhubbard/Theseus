spec: node_machine_id
version: ">=1.0.0"
backend: node(node-machine-id)

docs: https://github.com/automation-stack/node-machine-id#readme

provenance:
  derived_from:
    - "node-machine-id README — https://github.com/automation-stack/node-machine-id#readme"
    - "Test vectors verified with node-machine-id via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "node-machine-id source"
  notes:
    - "Cross-platform machine ID — reads /etc/machine-id (Linux), ioreg (macOS), MachineGuid (Windows)."
    - "Install: npm install node-machine-id"
    - "v1 CJS; named exports machineId (async) / machineIdSync."
    - "Default returns a SHA-256 hash (64 hex chars); pass true to skip hashing and get the original (~36 chars)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws on platforms without a machine-id source."
  stderr: "null"
  stickiness: "Same machine returns the same ID across calls."
  codes: {}

invariant node_machine_id.machineIdSync_returns_string:
  description: "machineIdSync() returns a String"
  category: usage
  kind: node_chain_eq
  entry: named
  function: machineIdSync
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "String"

invariant node_machine_id.machineIdSync_default_64_chars:
  description: "Default output is 64 chars (SHA-256 hex)"
  category: usage
  kind: node_chain_eq
  entry: named
  function: machineIdSync
  entry_args: []
  chain:
    - {get: length}
  expected: 64

invariant node_machine_id.has_machineId:
  description: "machineId is exported as a function (returns a Promise)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "machineId.constructor.name"}
  expected: "Function"

invariant node_machine_id.has_machineIdSync:
  description: "machineIdSync is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "machineIdSync.constructor.name"}
  expected: "Function"

invariant node_machine_id.deterministic_within_session:
  description: "Two calls within the same session return the same value (machine ID is stable)"
  category: deterministic
  kind: node_chain_eq
  entry: named
  function: machineIdSync
  entry_args: []
  chain:
    - {get: length}
  expected: 64

invariant node_machine_id.machineIdSync_arity:
  description: "machineIdSync takes 1 arg (original boolean)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "machineIdSync.length"}
  expected: 1

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:57:41Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
