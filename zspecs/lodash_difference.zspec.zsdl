spec: lodash_difference
version: ">=4.0.0"
backend: node(lodash.difference)

docs: https://lodash.com/docs/#difference

provenance:
  derived_from:
    - "lodash.difference README — https://www.npmjs.com/package/lodash.difference"
    - "Test vectors verified with lodash.difference@4.5.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.difference exports the _.difference function directly as module.exports."
    - "difference(array, values) returns elements in the first array not in values."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns new array with values array elements removed. No errors for array inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_difference.diff:
  kind: node_module_call_eq
  function: ~
  category: diff
  id_prefix: ldiff

  columns: [id, args, expected]
  rows:
    - [remove_one,  [[1, 2, 3], [2]],       [1, 3]]
    - [remove_two,  [[1, 2, 3, 4], [2, 4]],  [1, 3]]
    - [no_match,    [[1, 2, 3], [5, 6]],    [1, 2, 3]]
