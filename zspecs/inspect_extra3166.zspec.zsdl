spec: in3166
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 658 (in3166): __add__, __sub__, __mul__ dict-presence checks for inspect types."
    - "No inspect type defines __add__, __sub__, or __mul__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "None of these types implement arithmetic protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3166.add:
  description: "inspect types __add__ dict-presence checks; wave 658"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in3166
  columns: [id, function, args, expected]
  rows:
    - ["in3166001", operator.contains, [inspect.Parameter.__dict__,           "__add__"], false]
    - ["in3166002", operator.contains, [inspect.Signature.__dict__,           "__add__"], false]
    - ["in3166003", operator.contains, [inspect.BoundArguments.__dict__,      "__add__"], false]
    - ["in3166004", operator.contains, [inspect.FrameInfo.__dict__,           "__add__"], false]
    - ["in3166005", operator.contains, [inspect.ArgInfo.__dict__,             "__add__"], false]
    - ["in3166006", operator.contains, [inspect.FullArgSpec.__dict__,         "__add__"], false]
    - ["in3166007", operator.contains, [inspect.Attribute.__dict__,           "__add__"], false]
    - ["in3166008", operator.contains, [inspect.ClassFoundException.__dict__, "__add__"], false]
    - ["in3166009", operator.contains, [inspect.EndOfBlock.__dict__,          "__add__"], false]

