spec: functools_extra1186
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks functools.cache.__doc__.__class__.__name__, functools.__spec__.__class__.__name__, functools.reduce.__doc__.__class__.__name__, functools.singledispatch.dispatch.__qualname__, functools.WRAPPER_ASSIGNMENTS.__iter__.__qualname__, functools.lru_cache.__doc__.__class__.__name__, functools.total_ordering.__qualname__, functools.cmp_to_key.__module__ — not covered in _extra1156/_extra1171"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1186.spec_and_doc_class_names:
  description: "functools.__spec__ class name and reduce/lru_cache __doc__ class name identity"
  kind: python_call_eq
  category: spec_and_doc_class_names
  id_prefix: fn1186sd
  columns: [id, function, args, expected]
  rows:
    - [fn1186sd001, functools.__spec__.__class__.__name__.__eq__,              ["ModuleSpec"],   true]
    - [fn1186sd002, functools.__spec__.name.__eq__,                            ["functools"],    true]
    - [fn1186sd003, functools.__spec__.origin.__class__.__name__.__eq__,       ["str"],          true]
    - [fn1186sd004, functools.reduce.__doc__.__class__.__name__.__eq__,        ["str"],          true]
    - [fn1186sd005, functools.lru_cache.__doc__.__class__.__name__.__eq__,     ["str"],          true]
    - [fn1186sd006, functools.cache.__doc__.__class__.__name__.__eq__,         ["str"],          true]
    - [fn1186sd007, functools.__spec__.submodule_search_locations.__eq__,      [null],           true]
    - [fn1186sd008, functools.__spec__.has_location.__eq__,                    [true],           true]

table functools_extra1186.singledispatch_dispatch_qualname:
  description: "functools.singledispatch.dispatch and register __qualname__ identity"
  kind: python_call_eq
  category: singledispatch_dispatch_qualname
  id_prefix: fn1186dq
  columns: [id, function, args, expected]
  rows:
    - [fn1186dq001, functools.singledispatch.dispatch.__qualname__.__eq__,     ["singledispatch.<locals>.dispatch"],    true]
    - [fn1186dq002, functools.singledispatch.dispatch.__class__.__name__.__eq__, ["function"],                          true]
    - [fn1186dq003, functools.singledispatch.dispatch.__module__.__eq__,       ["functools"],                           true]
    - [fn1186dq004, functools.singledispatch.register.__qualname__.__eq__,     ["singledispatch.<locals>.register"],    true]
    - [fn1186dq005, functools.singledispatch.register.__class__.__name__.__eq__, ["function"],                          true]
    - [fn1186dq006, functools.singledispatch.register.__module__.__eq__,       ["functools"],                           true]
    - [fn1186dq007, functools.singledispatch.dispatch_cache_clear.__qualname__.__eq__, ["singledispatch.<locals>.dispatch_cache_clear"],  true]
    - [fn1186dq008, functools.singledispatch.dispatch_cache_clear.__class__.__name__.__eq__, ["function"],              true]

table functools_extra1186.wrapper_assignments_and_cmp_to_key:
  description: "functools.WRAPPER_ASSIGNMENTS iter qualname, total_ordering and cmp_to_key identity"
  kind: python_call_eq
  category: wrapper_assignments_and_cmp_to_key
  id_prefix: fn1186wa
  columns: [id, function, args, expected]
  rows:
    - [fn1186wa001, functools.WRAPPER_ASSIGNMENTS.__iter__.__qualname__.__eq__, ["tuple_iterator.__iter__"],   true]
    - [fn1186wa002, functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,   ["tuple"],                     true]
    - [fn1186wa003, functools.WRAPPER_ASSIGNMENTS.__contains__,                ["__module__"],                 true]
    - [fn1186wa004, functools.WRAPPER_ASSIGNMENTS.__contains__,                ["__qualname__"],               true]
    - [fn1186wa005, functools.WRAPPER_ASSIGNMENTS.__contains__,                ["__doc__"],                    true]
    - [fn1186wa006, functools.total_ordering.__qualname__.__eq__,              ["total_ordering"],             true]
    - [fn1186wa007, functools.cmp_to_key.__module__.__eq__,                    ["functools"],                  true]
    - [fn1186wa008, functools.cmp_to_key.__class__.__name__.__eq__,            ["builtin_function_or_method"], true]
