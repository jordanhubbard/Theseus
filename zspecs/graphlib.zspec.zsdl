spec: graphlib
version: ">=2.0.0"
backend: node(graphlib)

docs: https://github.com/dagrejs/graphlib#readme

provenance:
  derived_from:
    - "graphlib README — https://github.com/dagrejs/graphlib#readme"
    - "Test vectors verified with graphlib via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "graphlib source"
  notes:
    - "graphlib is the graph data-structure library underlying Dagre (DAG layout)."
    - "Install: npm install graphlib"
    - "Pattern: const {Graph} = require('graphlib'); new Graph().setNode(...).setEdge(...)"
    - "Default Graph is directed and forbids parallel edges."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Mutators return `this` (chainable); predicates return booleans; never throw on basic operations."
  stderr: "null"
  stickiness: "Each invariant constructs a fresh Graph."
  codes: {}

# Counts
invariant graphlib.fresh_node_count_zero:
  description: "Fresh graph has nodeCount 0"
  category: counts
  kind: node_chain_eq
  entry: constructor
  class: Graph
  entry_args: []
  chain:
    - {method: nodeCount, args: []}
  expected: 0

invariant graphlib.fresh_edge_count_zero:
  description: "Fresh graph has edgeCount 0"
  category: counts
  kind: node_chain_eq
  entry: constructor
  class: Graph
  entry_args: []
  chain:
    - {method: edgeCount, args: []}
  expected: 0

invariant graphlib.node_count_after_two_setnode:
  description: "After 2 setNode calls, nodeCount is 2"
  category: counts
  kind: node_chain_eq
  entry: constructor
  class: Graph
  entry_args: []
  chain:
    - {method: setNode, args: ["a"]}
    - {method: setNode, args: ["b"]}
    - {method: nodeCount, args: []}
  expected: 2

invariant graphlib.edge_count_after_setedge:
  description: "setEdge increases edgeCount by 1"
  category: counts
  kind: node_chain_eq
  entry: constructor
  class: Graph
  entry_args: []
  chain:
    - {method: setNode, args: ["a"]}
    - {method: setNode, args: ["b"]}
    - {method: setEdge, args: ["a", "b"]}
    - {method: edgeCount, args: []}
  expected: 1

# Predicates
invariant graphlib.has_node_after_set:
  description: "hasNode returns true after setNode"
  category: predicates
  kind: node_chain_eq
  entry: constructor
  class: Graph
  entry_args: []
  chain:
    - {method: setNode, args: ["a"]}
    - {method: hasNode, args: ["a"]}
  expected: true

invariant graphlib.has_edge_after_set:
  description: "hasEdge returns true after setEdge"
  category: predicates
  kind: node_chain_eq
  entry: constructor
  class: Graph
  entry_args: []
  chain:
    - {method: setNode, args: ["a"]}
    - {method: setNode, args: ["b"]}
    - {method: setEdge, args: ["a", "b"]}
    - {method: hasEdge, args: ["a", "b"]}
  expected: true

invariant graphlib.directed_no_reverse_edge:
  description: "Default Graph is directed: hasEdge('b','a') is false after setEdge('a','b')"
  category: predicates
  kind: node_chain_eq
  entry: constructor
  class: Graph
  entry_args: []
  chain:
    - {method: setNode, args: ["a"]}
    - {method: setNode, args: ["b"]}
    - {method: setEdge, args: ["a", "b"]}
    - {method: hasEdge, args: ["b", "a"]}
  expected: false

# nodes() returns array of node ids
invariant graphlib.nodes_array_length:
  description: "nodes() returns an array whose length matches nodeCount"
  category: nodes
  kind: node_chain_eq
  entry: constructor
  class: Graph
  entry_args: []
  chain:
    - {method: setNode, args: ["a"]}
    - {method: setNode, args: ["b"]}
    - {method: setNode, args: ["c"]}
    - {method: nodes, args: []}
    - {get: length}
  expected: 3

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:40:23Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
