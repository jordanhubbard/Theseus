invariant decimal_extra243.Decimal.ln.one_eq_zero:
  description: "Decimal('1').ln().__eq__(Decimal('0')) == True — the natural logarithm of 1 is exactly 0; verified Python 3.14.3 macOS"
  category: ln
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: ln
  method_chain: __eq__
  method_chain_args: ["0"]
  expected: true

invariant decimal_extra243.Decimal.ln.returns_decimal:
  description: "Decimal('1').ln().__class__.__name__ == 'Decimal' — ln() returns a Decimal object; verified Python 3.14.3 macOS"
  category: ln
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: ln
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["Decimal"]
  expected: true

