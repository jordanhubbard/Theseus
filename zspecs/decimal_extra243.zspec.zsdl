# ---------------------------------------------------------------------------

invariant decimal_extra243.Decimal.exp.zero_eq_one:
  description: "Decimal('0').exp().__eq__(Decimal('1')) == True — e^0 is exactly 1 in Decimal arithmetic; verified Python 3.14.3 macOS"
  category: exp
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: exp
  method_chain: __eq__
  method_chain_args: ["1"]
  expected: true

invariant decimal_extra243.Decimal.exp.returns_decimal:
  description: "Decimal('1').exp().__class__.__name__ == 'Decimal' — exp() returns a Decimal object; verified Python 3.14.3 macOS"
  category: exp
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: exp
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["Decimal"]
  expected: true
