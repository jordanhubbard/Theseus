spec: decimal_extra243
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic Specification, Version 1.72"
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl — covers str_repr, is_finite, is_nan, is_infinite, is_zero, is_signed, is_normal, as_tuple, class_name, getcontext.prec"
    - "decimal_extra.zspec.zsdl — covers is_nan/is_infinite/is_zero/is_signed, to_eng_string, Context class names, ROUND_* constants"
    - "decimal_extra242.zspec.zsdl — covers is_signed, is_normal, is_subnormal behavioral contracts"
  notes:
    - "This spec covers: Decimal.sqrt, Decimal.ln, Decimal.log10, Decimal.exp behavioral contracts."
    - "Decimal('4').sqrt().__eq__(Decimal('2')) == True — sqrt of 4 is exactly 2 in Decimal arithmetic; verified Python 3.14.3 macOS."
    - "Decimal('9').sqrt().__eq__(Decimal('3')) == True — sqrt of 9 is exactly 3; verified Python 3.14.3 macOS."
    - "Decimal('1').sqrt().__eq__(Decimal('1')) == True — sqrt of 1 is exactly 1; verified Python 3.14.3 macOS."
    - "Decimal('16').sqrt().__eq__(Decimal('4')) == True — sqrt of 16 is exactly 4; verified Python 3.14.3 macOS."
    - "Decimal('1').exp().__class__.__name__ == 'Decimal' — exp() returns a Decimal object; verified Python 3.14.3 macOS."
    - "Decimal('0').exp().__eq__(Decimal('1')) == True — e^0 == 1; verified Python 3.14.3 macOS."
    - "Decimal('10').log10().__eq__(Decimal('1')) == True — log10(10) == 1; verified Python 3.14.3 macOS."
    - "Decimal('100').log10().__eq__(Decimal('2')) == True — log10(100) == 2; verified Python 3.14.3 macOS."
    - "Decimal('1').log10().__eq__(Decimal('0')) == True — log10(1) == 0; verified Python 3.14.3 macOS."
    - "Decimal('1').ln().__eq__(Decimal('0')) == True — ln(1) == 0; verified Python 3.14.3 macOS."
    - "Decimal.sqrt.__name__ == 'sqrt', Decimal.log10.__name__ == 'log10', Decimal.ln.__name__ == 'ln', Decimal.exp.__name__ == 'exp'; verified Python 3.14.3 macOS."
    - "All sqrt/log10/ln/exp results are is_finite() == True for these finite inputs; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal.sqrt() exact equality contracts
# sqrt() returns a Decimal. For perfect squares the result is exact.
# Tested via __eq__ with the expected Decimal value.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra243.sqrt_exact:
  description: "Decimal.sqrt() exact equality for perfect squares; verified Python 3.14.3"
  kind: python_call_eq
  category: sqrt
  id_prefix: decmath243
  function: Decimal
  method: sqrt
  method_chain: __eq__

  columns: [id, args, method_chain_args, expected]
  rows:
    - [sqrt_4_eq_2,  ["4"],  ["2"],  true]
    - [sqrt_9_eq_3,  ["9"],  ["3"],  true]
    - [sqrt_1_eq_1,  ["1"],  ["1"],  true]
    - [sqrt_16_eq_4, ["16"], ["4"],  true]

# ---------------------------------------------------------------------------
# Decimal.log10() exact equality contracts
# log10(10) == 1, log10(100) == 2, log10(1) == 0 are exact.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra243.log10_exact:
  description: "Decimal.log10() exact equality for powers of 10; verified Python 3.14.3"
  kind: python_call_eq
  category: log10
  id_prefix: decmath243
  function: Decimal
  method: log10
  method_chain: __eq__

  columns: [id, args, method_chain_args, expected]
  rows:
    - [log10_10_eq_1,   ["10"],  ["1"],  true]
    - [log10_100_eq_2,  ["100"], ["2"],  true]
    - [log10_1_eq_0,    ["1"],   ["0"],  true]

# ---------------------------------------------------------------------------
# Decimal.ln() exact equality contract
# ln(1) == 0 exactly.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra243.ln_exact:
  description: "Decimal.ln() exact equality — ln(1)==0; verified Python 3.14.3"
  kind: python_call_eq
  category: ln
  id_prefix: decmath243
  function: Decimal
  method: ln
  method_chain: __eq__

  columns: [id, args, method_chain_args, expected]
  rows:
    - [ln_1_eq_0, ["1"], ["0"], true]

# ---------------------------------------------------------------------------
# Decimal.exp() exact equality and class contracts
# exp(0) == 1 exactly; exp() returns a Decimal.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra243.exp_exact:
  description: "Decimal.exp() exact equality for exp(0)==1; verified Python 3.14.3"
  kind: python_call_eq
  category: exp
  id_prefix: decmath243
  function: Decimal
  method: exp
  method_chain: __eq__

  columns: [id, args, method_chain_args, expected]
  rows:
    - [exp_0_eq_1, ["0"], ["1"], true]

# ---------------------------------------------------------------------------
# Return type checks — all math methods return Decimal
# Each method on a Decimal returns another Decimal instance.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra243.math_return_types:
  description: "Decimal sqrt/ln/log10/exp return Decimal; __class__.__name__ == 'Decimal'; verified Python 3.14.3"
  kind: python_call_eq
  category: return_types
  id_prefix: decmath243
  function: Decimal
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["Decimal"]

  columns: [id, args, method, expected]
  rows:
    - [sqrt_returns_decimal,  ["4"],  sqrt,  true]
    - [log10_returns_decimal, ["10"], log10, true]
    - [ln_returns_decimal,    ["1"],  ln,    true]
    - [exp_returns_decimal,   ["1"],  exp,   true]

# ---------------------------------------------------------------------------
# Method name identity — sqrt, log10, ln, exp
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table decimal_extra243.math_method_names:
  description: "Decimal.sqrt/log10/ln/exp __name__ string equality; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: decmath243

  columns: [id, function, args, expected]
  rows:
    - [sqrt_name_eq,  Decimal.sqrt.__name__.__eq__,  ["sqrt"],  true]
    - [log10_name_eq, Decimal.log10.__name__.__eq__,  ["log10"], true]
    - [ln_name_eq,    Decimal.ln.__name__.__eq__,    ["ln"],    true]
    - [exp_name_eq,   Decimal.exp.__name__.__eq__,   ["exp"],   true]

# ---------------------------------------------------------------------------
# Standalone invariants — sqrt
# ---------------------------------------------------------------------------

invariant decimal_extra243.Decimal.sqrt.four_eq_two:
  description: "Decimal('4').sqrt().__eq__(Decimal('2')) == True — the square root of 4 is exactly 2 in Decimal arithmetic; verified Python 3.14.3 macOS"
  category: sqrt
  kind: python_call_eq
  function: Decimal
  args: ["4"]
  method: sqrt
  method_chain: __eq__
  method_chain_args: ["2"]
  expected: true

invariant decimal_extra243.Decimal.sqrt.nine_eq_three:
  description: "Decimal('9').sqrt().__eq__(Decimal('3')) == True — the square root of 9 is exactly 3 in Decimal arithmetic; verified Python 3.14.3 macOS"
  category: sqrt
  kind: python_call_eq
  function: Decimal
  args: ["9"]
  method: sqrt
  method_chain: __eq__
  method_chain_args: ["3"]
  expected: true

invariant decimal_extra243.Decimal.sqrt.one_eq_one:
  description: "Decimal('1').sqrt().__eq__(Decimal('1')) == True — the square root of 1 is exactly 1; verified Python 3.14.3 macOS"
  category: sqrt
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: sqrt
  method_chain: __eq__
  method_chain_args: ["1"]
  expected: true

invariant decimal_extra243.Decimal.sqrt.returns_decimal:
  description: "Decimal('4').sqrt().__class__.__name__ == 'Decimal' — sqrt() returns a Decimal object; verified Python 3.14.3 macOS"
  category: sqrt
  kind: python_call_eq
  function: Decimal
  args: ["4"]
  method: sqrt
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["Decimal"]
  expected: true

