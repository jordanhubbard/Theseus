# Standalone invariants — log10
# ---------------------------------------------------------------------------

invariant decimal_extra243.Decimal.log10.ten_eq_one:
  description: "Decimal('10').log10().__eq__(Decimal('1')) == True — log base 10 of 10 is exactly 1; verified Python 3.14.3 macOS"
  category: log10
  kind: python_call_eq
  function: Decimal
  args: ["10"]
  method: log10
  method_chain: __eq__
  method_chain_args: ["1"]
  expected: true

invariant decimal_extra243.Decimal.log10.hundred_eq_two:
  description: "Decimal('100').log10().__eq__(Decimal('2')) == True — log base 10 of 100 is exactly 2; verified Python 3.14.3 macOS"
  category: log10
  kind: python_call_eq
  function: Decimal
  args: ["100"]
  method: log10
  method_chain: __eq__
  method_chain_args: ["2"]
  expected: true

invariant decimal_extra243.Decimal.log10.one_eq_zero:
  description: "Decimal('1').log10().__eq__(Decimal('0')) == True — log base 10 of 1 is exactly 0; verified Python 3.14.3 macOS"
  category: log10
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: log10
  method_chain: __eq__
  method_chain_args: ["0"]
  expected: true

