spec: sqlite3_extra20
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra19.zspec.zsdl."
    - "sqlite3_extra19 covers: Connection execute/executemany/executescript/cursor/commit/rollback/close __qualname__; Cursor execute/fetchone/fetchall __qualname__."
    - "sqlite3_extra18 covers: __qualname__.__class__.__name__ type axis for Connection, Cursor, Row, Error, OperationalError, connect; __class__.__qualname__ for sqlite_version and sqlite_version_info."
    - "sqlite3_extra14 covers: Connection/__qualname__; Cursor/__qualname__; Row/__qualname__; connect/__qualname__."
    - "sqlite3_extra5 covers: Error/__qualname__; OperationalError/__qualname__; IntegrityError/__qualname__."
    - "Focus: __qualname__ for Connection.create_function and Connection.create_aggregate; DatabaseError.__qualname__; Cursor.rowcount descriptor __class__.__name__."
    - "No prior sqlite3 spec checks Connection.create_function.__qualname__."
    - "No prior sqlite3 spec checks Connection.create_aggregate.__qualname__."
    - "No prior sqlite3 spec checks DatabaseError.__qualname__."
    - "No prior sqlite3 spec checks Cursor.rowcount.__class__.__name__ (member_descriptor at class level)."
    - "sqlite3.Connection.create_function.__qualname__ == 'Connection.create_function' — C-accelerated method; compound dotted qualname."
    - "sqlite3.Connection.create_aggregate.__qualname__ == 'Connection.create_aggregate' — C-accelerated method; compound dotted qualname."
    - "sqlite3.DatabaseError.__qualname__ == 'DatabaseError' — top-level exception class."
    - "sqlite3.Cursor.rowcount.__class__.__name__ == 'member_descriptor' — class-level descriptor wrapping the C-level rowcount slot."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Connection.create_function and create_aggregate __qualname__ values
#
# sqlite3_extra14 checks Connection.__qualname__ == 'Connection' for the class.
# sqlite3_extra19 checks execute, executemany, executescript, cursor, commit,
# rollback, and close __qualname__ values.
# No prior sqlite3 spec checks create_function or create_aggregate __qualname__.
# These are C-accelerated methods whose __qualname__ uses the compound dotted
# form 'Connection.method'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra20.Connection.create_function.qualname:
  description: "sqlite3.Connection.create_function.__qualname__ == 'Connection.create_function' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: Connection.create_function.__qualname__.__eq__
  args: ["Connection.create_function"]
  expected: true

invariant sqlite3_extra20.Connection.create_aggregate.qualname:
  description: "sqlite3.Connection.create_aggregate.__qualname__ == 'Connection.create_aggregate' — compound method qualname"
  category: method_attrs
  kind: python_call_eq
  function: Connection.create_aggregate.__qualname__.__eq__
  args: ["Connection.create_aggregate"]
  expected: true

# ---------------------------------------------------------------------------
# DatabaseError.__qualname__
#
# sqlite3_extra5 checks Error.__qualname__, OperationalError.__qualname__, and
# IntegrityError.__qualname__.  No prior sqlite3 spec checks
# DatabaseError.__qualname__.  DatabaseError is the direct subclass of Error
# and the base for all data-related exceptions.
# ---------------------------------------------------------------------------

invariant sqlite3_extra20.DatabaseError.qualname:
  description: "sqlite3.DatabaseError.__qualname__ == 'DatabaseError' — top-level exception class qualname"
  category: exception_qualnames
  kind: python_call_eq
  function: DatabaseError.__qualname__.__eq__
  args: ["DatabaseError"]
  expected: true

# ---------------------------------------------------------------------------
# Cursor.rowcount class-level descriptor type
#
# At the class level, sqlite3.Cursor.rowcount is a member_descriptor (C slot
# wrapper), not an int.  No prior sqlite3 spec checks this axis.
# ---------------------------------------------------------------------------

invariant sqlite3_extra20.Cursor.rowcount.descriptor_class_name:
  description: "sqlite3.Cursor.rowcount.__class__.__name__ == 'member_descriptor' — C slot descriptor at class level"
  category: descriptor_types
  kind: python_call_eq
  function: Cursor.rowcount.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table: create_function, create_aggregate, DatabaseError, rowcount
#
# All four invariants are first covered in this spec (sqlite3_extra20).
# ---------------------------------------------------------------------------

table sqlite3_extra20.new_attrs:
  description: "sqlite3 additional method __qualname__, exception __qualname__, and descriptor type checks"
  kind: python_call_eq
  category: method_attrs
  id_prefix: sq20na

  columns: [id, function, args, expected]
  rows:
    - [create_function_qn,       Connection.create_function.__qualname__.__eq__,   ["Connection.create_function"],  true]
    - [create_aggregate_qn,      Connection.create_aggregate.__qualname__.__eq__,  ["Connection.create_aggregate"], true]
    - [DatabaseError_qn,         DatabaseError.__qualname__.__eq__,                ["DatabaseError"],               true]
    - [rowcount_descriptor_type, Cursor.rowcount.__class__.__name__.__eq__,        ["member_descriptor"],           true]
