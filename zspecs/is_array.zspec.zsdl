provenance:
  derived_from:
    - "is-array README — https://www.npmjs.com/package/is-array"
    - "Test vectors verified with is-array via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-array source"
  notes:
    - "is-array is an npm package. Install: npm install is-array"
    - "Returns true only for arrays; plain objects return false."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_array.isArray:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: isarr

  columns: [id, args, expected]
  rows:
    - [array,      [[1, 2, 3]],  true]
    - [empty,      [[]],         true]
    - [object,     [{"a": 1}],   false]
    - [string,     ["hi"],       false]
    - [number,     [42],         false]

