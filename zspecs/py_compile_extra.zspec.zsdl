spec: py_compile_extra
version: ">=3.9"
backend: python_module(py_compile)

docs: https://docs.python.org/3/library/py_compile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/py_compile.html — Python py_compile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/py_compile.py"
  notes:
    - "This spec extends py_compile.zspec.zsdl with additional identity and enum-membership invariants not covered there."
    - "py_compile.compile.__name__ == 'compile' and py_compile.compile.__module__ == 'py_compile'."
    - "py_compile.PycInvalidationMode is an IntEnum with members TIMESTAMP (1), CHECKED_HASH (2), UNCHECKED_HASH (3)."
    - "PycInvalidationMode.TIMESTAMP.__class__.__name__ == 'PycInvalidationMode' — member is an instance of its own enum."
    - "PycInvalidationMode.TIMESTAMP.value == 1, CHECKED_HASH.value == 2, UNCHECKED_HASH.value == 3."
    - "py_compile.PyCompileError.__name__ == 'PyCompileError' and its base class is Exception."
    - "py_compile.PyCompileError.__module__ == 'py_compile'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# compile() function name and module affiliation
# ---------------------------------------------------------------------------

invariant py_compile_extra.names.compile:
  description: "py_compile.compile.__name__ == 'compile'"
  category: names
  kind: python_call_eq
  function: compile.__name__.__eq__
  args: ["compile"]
  expected: true

invariant py_compile_extra.modules.compile:
  description: "py_compile.compile.__module__ == 'py_compile'"
  category: modules
  kind: python_call_eq
  function: compile.__module__.__eq__
  args: ["py_compile"]
  expected: true

# ---------------------------------------------------------------------------
# PycInvalidationMode class name
# ---------------------------------------------------------------------------

invariant py_compile_extra.names.PycInvalidationMode:
  description: "py_compile.PycInvalidationMode.__name__ == 'PycInvalidationMode'"
  category: names
  kind: python_call_eq
  function: PycInvalidationMode.__name__.__eq__
  args: ["PycInvalidationMode"]
  expected: true

# ---------------------------------------------------------------------------
# PyCompileError class name, module affiliation, and hierarchy
# ---------------------------------------------------------------------------

invariant py_compile_extra.names.PyCompileError:
  description: "py_compile.PyCompileError.__name__ == 'PyCompileError'"
  category: names
  kind: python_call_eq
  function: PyCompileError.__name__.__eq__
  args: ["PyCompileError"]
  expected: true

invariant py_compile_extra.modules.PyCompileError:
  description: "py_compile.PyCompileError.__module__ == 'py_compile'"
  category: modules
  kind: python_call_eq
  function: PyCompileError.__module__.__eq__
  args: ["py_compile"]
  expected: true

invariant py_compile_extra.hierarchy.PyCompileError_base:
  description: "py_compile.PyCompileError.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: PyCompileError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# PycInvalidationMode enum member — TIMESTAMP
# ---------------------------------------------------------------------------

invariant py_compile_extra.enum_members.TIMESTAMP_class:
  description: "py_compile.PycInvalidationMode.TIMESTAMP.__class__.__name__ == 'PycInvalidationMode'"
  category: enum_members
  kind: python_call_eq
  function: PycInvalidationMode.TIMESTAMP.__class__.__name__.__eq__
  args: ["PycInvalidationMode"]
  expected: true

invariant py_compile_extra.enum_members.TIMESTAMP_value:
  description: "py_compile.PycInvalidationMode.TIMESTAMP.value == 1"
  category: enum_members
  kind: python_call_eq
  function: PycInvalidationMode.TIMESTAMP.value.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# PycInvalidationMode enum member — CHECKED_HASH
# ---------------------------------------------------------------------------

invariant py_compile_extra.enum_members.CHECKED_HASH_class:
  description: "py_compile.PycInvalidationMode.CHECKED_HASH.__class__.__name__ == 'PycInvalidationMode'"
  category: enum_members
  kind: python_call_eq
  function: PycInvalidationMode.CHECKED_HASH.__class__.__name__.__eq__
  args: ["PycInvalidationMode"]
  expected: true

invariant py_compile_extra.enum_members.CHECKED_HASH_value:
  description: "py_compile.PycInvalidationMode.CHECKED_HASH.value == 2"
  category: enum_members
  kind: python_call_eq
  function: PycInvalidationMode.CHECKED_HASH.value.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# PycInvalidationMode enum member — UNCHECKED_HASH
# ---------------------------------------------------------------------------

invariant py_compile_extra.enum_members.UNCHECKED_HASH_class:
  description: "py_compile.PycInvalidationMode.UNCHECKED_HASH.__class__.__name__ == 'PycInvalidationMode'"
  category: enum_members
  kind: python_call_eq
  function: PycInvalidationMode.UNCHECKED_HASH.__class__.__name__.__eq__
  args: ["PycInvalidationMode"]
  expected: true

invariant py_compile_extra.enum_members.UNCHECKED_HASH_value:
  description: "py_compile.PycInvalidationMode.UNCHECKED_HASH.value == 3"
  category: enum_members
  kind: python_call_eq
  function: PycInvalidationMode.UNCHECKED_HASH.value.__eq__
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# PycInvalidationMode enum member ordering — TIMESTAMP < CHECKED_HASH < UNCHECKED_HASH
# ---------------------------------------------------------------------------

invariant py_compile_extra.enum_members.TIMESTAMP_lt_CHECKED_HASH:
  description: "PycInvalidationMode.TIMESTAMP.value < PycInvalidationMode.CHECKED_HASH.value"
  category: enum_members
  kind: python_call_eq
  function: PycInvalidationMode.TIMESTAMP.value.__lt__
  args: [2]
  expected: true

invariant py_compile_extra.enum_members.CHECKED_HASH_lt_UNCHECKED_HASH:
  description: "PycInvalidationMode.CHECKED_HASH.value < PycInvalidationMode.UNCHECKED_HASH.value"
  category: enum_members
  kind: python_call_eq
  function: PycInvalidationMode.CHECKED_HASH.value.__lt__
  args: [3]
  expected: true
