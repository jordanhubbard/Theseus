# ---------------------------------------------------------------------------
# Standalone invariants — extra127
# ---------------------------------------------------------------------------

invariant asyncio_extra127.Lock_module_is_asyncio_locks:
  description: "asyncio.Lock.__module__.__eq__('asyncio.locks') returns True — asyncio.Lock is a pure-Python class defined in Lib/asyncio/locks.py; its __module__ is 'asyncio.locks' (the submodule name), contrasting with asyncio.Task and asyncio.Future whose __module__ is '_asyncio' (C extension with underscore prefix); Lock.__bases__[0].__name__ is '_ContextManagerMixin' (not 'object' directly); Lock.__mro__.__len__() is 4 ([Lock, _ContextManagerMixin, _LoopBoundMixin, object]); the 4-element MRO makes Lock's hierarchy deeper than asyncio.Task (len=3) or asyncio.Future (len=2); Lock.acquire.__class__.__name__ is 'function' (Python-level), unlike Task.cancel which is 'method_descriptor' (C-level); NEW in extra127: first standalone Lock module invariant in asynciolockident127 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra127.Lock_mro_len_is_4:
  description: "asyncio.Lock.__mro__.__len__() == 4 — asyncio.Lock.__mro__ is [Lock, _ContextManagerMixin, _LoopBoundMixin, object]; this 4-element MRO is longer than asyncio.Task's (len=3: [Task, Future, object]) and asyncio.Future's (len=2: [Future, object]); the extra depth comes from the two mixin classes: _ContextManagerMixin (adds async context manager protocol) and _LoopBoundMixin (binds the lock to the running event loop); asyncio.Lock.__bases__[0].__name__ is '_ContextManagerMixin' (direct base); asyncio.Lock.__mro__[2].__name__ is '_LoopBoundMixin' (third in MRO); asyncio.Semaphore.__mro__.__len__() is also 4 (same structure); NEW in extra127: first standalone Lock MRO length invariant in asynciolockident127 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra127.Lock_acquire_qualname_len_12:
  description: "asyncio.Lock.acquire.__qualname__.__len__() == 12 — asyncio.Lock.acquire.__qualname__ is 'Lock.acquire' (12 chars: 'Lock.'=5 + 'acquire'=7 = 12); this is the longest method qualname in the Lock table (tied with release=12, both longer than locked=11); compare with Semaphore.acquire.__qualname__.__len__()==17 ('Semaphore.'=10+'acquire'=7=17), which is 5 chars longer due to the extra chars in 'Semaphore' vs 'Lock'; asyncio.Lock.acquire.__class__.__name__ is 'function' (pure-Python); asyncio.Lock.acquire.__code__.co_argcount is 1 (self only); asyncio.Lock.acquire.__code__.co_name is 'acquire' (len=7); NEW in extra127: first standalone Lock.acquire qualname length invariant in asynciolockident127 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Lock.acquire.__qualname__.__len__
  args: []
  expected: 12

invariant asyncio_extra127.Semaphore_mro_len_is_4:
  description: "asyncio.Semaphore.__mro__.__len__() == 4 — asyncio.Semaphore.__mro__ is [Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]; this is identical in structure to asyncio.Lock.__mro__ (also len=4), with the same two mixin classes appearing in the same positions; Semaphore.__bases__[0].__name__ is '_ContextManagerMixin' (same as Lock's direct base); Semaphore.__module__ is 'asyncio.locks' (same as Lock); the shared MRO structure confirms both Lock and Semaphore are built from the same mixin pattern in Lib/asyncio/locks.py; asyncio.BoundedSemaphore.__mro__.__len__() is 5 (BoundedSemaphore adds one more level: [BoundedSemaphore, Semaphore, _ContextManagerMixin, _LoopBoundMixin, object]); NEW in extra127: first standalone Semaphore MRO length invariant in asynciolockident127 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.__mro__.__len__
  args: []
  expected: 4

invariant asyncio_extra127.Semaphore_acquire_qualname_len_17:
  description: "asyncio.Semaphore.acquire.__qualname__.__len__() == 17 — asyncio.Semaphore.acquire.__qualname__ is 'Semaphore.acquire' (17 chars: 'Semaphore.'=10 + 'acquire'=7 = 17); this is 5 chars longer than asyncio.Lock.acquire.__qualname__.__len__()==12 ('Lock.'=5+'acquire'=7=12); the 5-char difference equals the length difference between 'Semaphore' (9 chars) and 'Lock' (4 chars); Semaphore.acquire is tied with Semaphore.release at len=17; Semaphore.locked.__qualname__.__len__() is 16 (one shorter because 'locked'=6 < 'acquire'=7); asyncio.Semaphore.acquire.__class__.__name__ is 'function'; asyncio.Semaphore.acquire.__code__.co_argcount is 1 (self only); NEW in extra127: first standalone Semaphore.acquire qualname length invariant in asynciolockident127 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Semaphore.acquire.__qualname__.__len__
  args: []
  expected: 17
