spec: asyncio_extra127
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec covers: wave 255 theme — asyncio.Lock and asyncio.Semaphore class hierarchy identity. NEW in extra127: asyncio.Lock.__name__=='Lock' (len=4); asyncio.Lock.__module__=='asyncio.locks'; asyncio.Lock.__bases__[0].__name__=='_ContextManagerMixin'; asyncio.Lock.__mro__.__len__()==4 (MRO=[Lock, _ContextManagerMixin, _LoopBoundMixin, object]); asyncio.Semaphore.__name__=='Semaphore' (len=9); asyncio.Semaphore.__module__=='asyncio.locks'; asyncio.Semaphore.__bases__[0].__name__=='_ContextManagerMixin'; asyncio.Semaphore.__mro__.__len__()==4 (same structure as Lock); asyncio.Lock.acquire.__qualname__=='Lock.acquire' (len=12); asyncio.Lock.release.__qualname__=='Lock.release' (len=12); asyncio.Lock.locked.__qualname__=='Lock.locked' (len=11); asyncio.Semaphore.acquire.__qualname__=='Semaphore.acquire' (len=17); asyncio.Semaphore.release.__qualname__=='Semaphore.release' (len=17); asyncio.Semaphore.locked.__qualname__=='Semaphore.locked' (len=16). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin'. asyncio.Lock is a pure-Python class defined in Lib/asyncio/locks.py; it inherits from _ContextManagerMixin (adding async context manager support) then _LoopBoundMixin then object; the MRO has 4 elements, unlike asyncio.Task (MRO len=3) and asyncio.Future (MRO len=2) which are C extension classes. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Lock.acquire.__code__.co_argcount == 1. Lock.acquire is defined as 'async def acquire(self)' with only self as positional param; co_varnames has 2 entries (self plus local 'fut' for the waiting future). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Semaphore.acquire.__qualname__.__len__() == 17. 'Semaphore.acquire' is 17 chars: 'Semaphore.'=10 + 'acquire'=7 = 17; contrast with Lock.acquire.__qualname__.__len__()==12 ('Lock.'=5+'acquire'=7=12); the 5-char difference exactly reflects the extra characters in 'Semaphore' vs 'Lock'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Lock class hierarchy identity — extra127
#
# Wave 255 theme: asyncio.Lock and asyncio.Semaphore class hierarchy identity.
#
# asyncio.Lock.__name__              == 'Lock'                  (len=4)
# asyncio.Lock.__module__            == 'asyncio.locks'
# asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin'
# asyncio.Lock.__mro__.__len__()     == 4   [Lock, _ContextManagerMixin, _LoopBoundMixin, object]
# asyncio.Lock.__qualname__          == 'Lock'                  (len=4)
# asyncio.Lock.__class__.__name__    == 'type'
# ---------------------------------------------------------------------------

table asyncio_extra127.asyncio_lock_class_identity:
  description: "asyncio.Lock class hierarchy identity checks in asynciolockident127 namespace — wave 255 theme: asyncio.Lock is a pure-Python class defined in Lib/asyncio/locks.py; it differs from C extension asyncio.Task and asyncio.Future (module='_asyncio') because Lock.__module__=='asyncio.locks' (not '_asyncio'); asyncio.Lock.__name__.__eq__('Lock')==True (len=4: 'Lock'=4); asyncio.Lock.__module__.__eq__('asyncio.locks')==True (defined in Lib/asyncio/locks.py); asyncio.Lock.__bases__[0].__name__.__eq__('_ContextManagerMixin')==True (Lock inherits from _ContextManagerMixin, not directly from object; _ContextManagerMixin provides async context manager __aenter__ and __aexit__); asyncio.Lock.__mro__.__len__()==4 (MRO is [Lock, _ContextManagerMixin, _LoopBoundMixin, object]: 4-element chain, one more than asyncio.Task's 3-element chain and two more than asyncio.Future's 2-element chain); asyncio.Lock.__qualname__.__eq__('Lock')==True (len=4, module-level class qualname equals name); asyncio.Lock.__class__.__name__.__eq__('type')==True (Lock is a regular class with metaclass type, unlike asyncio.ABC subclasses with ABCMeta); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolockident127

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,   asyncio.Lock.__name__.__eq__,                            ["Lock"],                 true, "asyncio.Lock.__name__ == 'Lock' (len=4); verified with Python 3.14.3"]
    - [lock_name_len,  asyncio.Lock.__name__.__len__,                           [],                       4,    "asyncio.Lock.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [lock_module,    asyncio.Lock.__module__.__eq__,                          ["asyncio.locks"],         true, "asyncio.Lock.__module__ == 'asyncio.locks' (pure-Python, defined in Lib/asyncio/locks.py); verified with Python 3.14.3"]
    - [lock_base0,     "asyncio.Lock.__bases__[0].__name__.__eq__",             ["_ContextManagerMixin"],  true, "asyncio.Lock.__bases__[0].__name__ == '_ContextManagerMixin' (provides async context manager support); verified with Python 3.14.3"]
    - [lock_mro_len,   asyncio.Lock.__mro__.__len__,                            [],                       4,    "asyncio.Lock.__mro__.__len__() == 4 (MRO: [Lock, _ContextManagerMixin, _LoopBoundMixin, object]); verified with Python 3.14.3"]
    - [lock_mro1,      "asyncio.Lock.__mro__[1].__name__.__eq__",               ["_ContextManagerMixin"],  true, "asyncio.Lock.__mro__[1].__name__ == '_ContextManagerMixin' (second in MRO after Lock); verified with Python 3.14.3"]
    - [lock_mro2,      "asyncio.Lock.__mro__[2].__name__.__eq__",               ["_LoopBoundMixin"],       true, "asyncio.Lock.__mro__[2].__name__ == '_LoopBoundMixin' (third in MRO); verified with Python 3.14.3"]
    - [lock_qualname,  asyncio.Lock.__qualname__.__eq__,                        ["Lock"],                  true, "asyncio.Lock.__qualname__ == 'Lock' (len=4, module-level class); verified with Python 3.14.3"]
    - [lock_cls_eq,    asyncio.Lock.__class__.__name__.__eq__,                  ["type"],                  true, "asyncio.Lock.__class__.__name__ == 'type' (Lock metaclass is regular type, not ABCMeta); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Lock method qualnames — extra127
#
# asyncio.Lock.acquire.__qualname__  == 'Lock.acquire'  (len=12)
# asyncio.Lock.release.__qualname__  == 'Lock.release'  (len=12)
# asyncio.Lock.locked.__qualname__   == 'Lock.locked'   (len=11)
# asyncio.Lock.acquire.__class__.__name__  == 'function'
# asyncio.Lock.acquire.__code__.co_argcount == 1
# ---------------------------------------------------------------------------

table asyncio_extra127.asyncio_lock_method_qualnames:
  description: "asyncio.Lock method __qualname__ checks in asynciolockident127 namespace — wave 255 theme: asyncio.Lock methods are pure-Python functions (class='function') because Lock is a Python-level class (unlike asyncio.Task/Future which are C extension classes with 'method_descriptor' methods); asyncio.Lock.acquire.__qualname__.__eq__('Lock.acquire')==True (len=12: 'Lock.'=5+'acquire'=7=12); asyncio.Lock.acquire.__qualname__.__len__()==12; asyncio.Lock.release.__qualname__.__eq__('Lock.release')==True (len=12: 'Lock.'=5+'release'=7=12, tied with acquire at 12); asyncio.Lock.release.__qualname__.__len__()==12; asyncio.Lock.locked.__qualname__.__eq__('Lock.locked')==True (len=11: 'Lock.'=5+'locked'=6=11, one shorter than acquire/release because 'locked'=6 < 'acquire'/'release'=7); asyncio.Lock.locked.__qualname__.__len__()==11; asyncio.Lock.acquire.__class__.__name__.__eq__('function')==True (Python-level function, not C method_descriptor); asyncio.Lock.acquire.__code__.co_argcount.__eq__(1)==True (acquire takes only self as positional param; no other positional args); asyncio.Lock.release.__code__.co_argcount.__eq__(1)==True (release takes only self); asyncio.Lock.locked.__code__.co_argcount.__eq__(1)==True (locked takes only self); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciolockident127a

  columns: [id, function, args, expected, description]
  rows:
    - [acq_qn_eq,   asyncio.Lock.acquire.__qualname__.__eq__,          ["Lock.acquire"],  true, "asyncio.Lock.acquire.__qualname__ == 'Lock.acquire' (len=12); verified with Python 3.14.3"]
    - [acq_qn_len,  asyncio.Lock.acquire.__qualname__.__len__,         [],                12,   "asyncio.Lock.acquire.__qualname__.__len__() == 12 ('Lock.'=5+'acquire'=7=12); verified with Python 3.14.3"]
    - [rel_qn_eq,   asyncio.Lock.release.__qualname__.__eq__,          ["Lock.release"],  true, "asyncio.Lock.release.__qualname__ == 'Lock.release' (len=12, tied with acquire); verified with Python 3.14.3"]
    - [rel_qn_len,  asyncio.Lock.release.__qualname__.__len__,         [],                12,   "asyncio.Lock.release.__qualname__.__len__() == 12 (tied with acquire at 12); verified with Python 3.14.3"]
    - [lkd_qn_eq,   asyncio.Lock.locked.__qualname__.__eq__,           ["Lock.locked"],   true, "asyncio.Lock.locked.__qualname__ == 'Lock.locked' (len=11, shorter than acquire/release); verified with Python 3.14.3"]
    - [lkd_qn_len,  asyncio.Lock.locked.__qualname__.__len__,          [],                11,   "asyncio.Lock.locked.__qualname__.__len__() == 11 ('Lock.'=5+'locked'=6=11); verified with Python 3.14.3"]
    - [acq_cls,     asyncio.Lock.acquire.__class__.__name__.__eq__,    ["function"],      true, "asyncio.Lock.acquire.__class__.__name__ == 'function' (Python-level, not C method_descriptor); verified with Python 3.14.3"]
    - [acq_argc,    asyncio.Lock.acquire.__code__.co_argcount.__eq__,  [1],               true, "asyncio.Lock.acquire.__code__.co_argcount == 1 (self only as positional param); verified with Python 3.14.3"]
    - [rel_argc,    asyncio.Lock.release.__code__.co_argcount.__eq__,  [1],               true, "asyncio.Lock.release.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]

