spec: sys_platform
version: ">=3.9"
backend: python_module(sys)

docs: https://docs.python.org/3/library/sys.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/sys.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "sys source: built-in module (PSF; source inspection permitted)"
  not_derived_from:
    - "sys source: internal CPython implementation details"
    - "sys version/encoding attributes — covered in sys.zspec.zsdl"
  notes:
    - "sys.platform == 'darwin' on macOS; 'linux' on Linux; 'win32' on Windows (even 64-bit)."
    - "sys.version is a human-readable str starting with the major.minor.micro version number."
    - "sys.version_info is a named tuple with fields major, minor, micro, releaselevel, serial."
    - "sys.maxsize == 9223372036854775807 on 64-bit platforms (2^63 - 1)."
    - "sys.maxunicode == 1114111 (0x10FFFF) on all Python 3 builds — UCS-4 / wide Unicode."
    - "sys.float_info.max >= 1.7976931348623157e+308 — IEEE 754 double maximum."
    - "sys.float_info.epsilon <= 2.220446049250313e-16 — IEEE 754 double machine epsilon."
    - "sys.int_info.bits_per_digit == 30 on 64-bit CPython builds."
    - "sys.path is a list (mutable sequence) of str entries."
    - "sys.modules is a dict; 'sys' and 'builtins' are always present."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Attribute access on sys raises AttributeError for missing attributes; functions raise TypeError/ValueError for bad args."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# sys.platform — platform identifier string
# ---------------------------------------------------------------------------

invariant sys_platform.platform_is_str:
  description: "sys.platform.__class__.__name__ == 'str'"
  category: platform
  kind: python_call_eq
  function: platform.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sys_platform.platform_nonempty:
  description: "len(sys.platform) > 0 — platform string is always non-empty"
  category: platform
  kind: python_call_eq
  function: platform.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

invariant sys_platform.platform_darwin:
  description: "sys.platform == 'darwin' on macOS (POSIX CI target)"
  category: platform
  kind: python_call_eq
  function: platform.__eq__
  args: ["darwin"]
  expected: true

# ---------------------------------------------------------------------------
# sys.version — human-readable version string
# ---------------------------------------------------------------------------

invariant sys_platform.version_is_str:
  description: "sys.version.__class__.__name__ == 'str'"
  category: version
  kind: python_call_eq
  function: version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sys_platform.version_starts_with_3:
  description: "sys.version starts with '3.' — this is a Python 3 interpreter"
  category: version
  kind: python_call_eq
  function: version.__getitem__
  args: [0]
  method: __eq__
  method_args: ["3"]
  expected: true

# ---------------------------------------------------------------------------
# sys.version_info — named tuple fields
# (major/minor/class already in sys.zspec.zsdl; this spec adds minor, releaselevel, serial)
# ---------------------------------------------------------------------------

invariant sys_platform.version_info_minor_ge_9:
  description: "sys.version_info.minor >= 9 — Python 3.9 or newer"
  category: version_info
  kind: python_call_eq
  function: version_info.minor.__ge__
  args: [9]
  expected: true

invariant sys_platform.version_info_releaselevel_is_str:
  description: "sys.version_info.releaselevel.__class__.__name__ == 'str'"
  category: version_info
  kind: python_call_eq
  function: version_info.releaselevel.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# sys.maxunicode — must be 1114111 on all Python 3 builds
# ---------------------------------------------------------------------------

invariant sys_platform.maxunicode_value:
  description: "sys.maxunicode == 1114111 (0x10FFFF) — full UCS-4 Unicode range"
  category: limits
  kind: python_call_eq
  function: maxunicode.__eq__
  args: [1114111]
  expected: true

# ---------------------------------------------------------------------------
# sys.float_info — IEEE 754 double bounds
# ---------------------------------------------------------------------------

invariant sys_platform.float_info_max_ge:
  description: "sys.float_info.max >= 1.7976931348623157e+308"
  category: float_info
  kind: python_call_eq
  function: float_info.max.__ge__
  args: [1.7976931348623157e+308]
  expected: true

invariant sys_platform.float_info_epsilon_le:
  description: "sys.float_info.epsilon <= 2.220446049250313e-16 — machine epsilon"
  category: float_info
  kind: python_call_eq
  function: float_info.epsilon.__le__
  args: [2.220446049250313e-16]
  expected: true

# ---------------------------------------------------------------------------
# sys.int_info — bits per digit (30 on 64-bit CPython)
# ---------------------------------------------------------------------------

invariant sys_platform.int_info_bits_per_digit:
  description: "sys.int_info.bits_per_digit == 30 on 64-bit CPython"
  category: int_info
  kind: python_call_eq
  function: int_info.bits_per_digit.__eq__
  args: [30]
  expected: true

# ---------------------------------------------------------------------------
# sys.path — mutable list of str entries
# ---------------------------------------------------------------------------

invariant sys_platform.path_is_list:
  description: "sys.path.__class__.__name__ == 'list'"
  category: path
  kind: python_call_eq
  function: path.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant sys_platform.path_nonempty:
  description: "len(sys.path) >= 1 — sys.path always has at least one entry"
  category: path
  kind: python_call_eq
  function: path.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# sys.modules — always contains 'sys' and 'builtins'
# ---------------------------------------------------------------------------

invariant sys_platform.modules_is_dict:
  description: "sys.modules.__class__.__name__ == 'dict'"
  category: modules
  kind: python_call_eq
  function: modules.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant sys_platform.modules_contains_sys:
  description: "'sys' in sys.modules — sys is always already imported"
  category: modules
  kind: python_call_eq
  function: modules.__contains__
  args: ["sys"]
  expected: true

invariant sys_platform.modules_contains_builtins:
  description: "'builtins' in sys.modules — builtins is always already imported"
  category: modules
  kind: python_call_eq
  function: modules.__contains__
  args: ["builtins"]
  expected: true

