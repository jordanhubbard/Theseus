spec: re_extra18
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra17.zspec.zsdl."
    - "re_extra17 covers: escape brackets/star; split escaped-dot and digit-runs; findall three words; match group(3) and three-group len; match named group by string key; compile groupindex two named groups."
    - "re_extra14 covers: compile(r'[a-z]+').pattern; compile groupindex one named group; RegexFlag name/qualname/module/base."
    - "re_extra7 covers: RegexFlag IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII/NOFLAG .value attributes."
    - "NOT yet covered: re.compile(r'\\d+').pattern == '\\d+' — digit-pattern string preserved in .pattern."
    - "NOT yet covered: re.compile(r'(\\w+)').groups == 1 — number of capturing groups on compiled Pattern."
    - "NOT yet covered: re.compile(r'(\\w+) (\\w+)').groups == 2 — two capturing groups."
    - "NOT yet covered: re.compile(r'hello').groups == 0 — no capturing groups."
    - "NOT yet covered: re.compile(r'(?P<word>\\w+)').groupindex.__len__() == 1 — one named group (extra17 covers length 2, extra11 covers length 0)."
    - "NOT yet covered: re.IGNORECASE.__int__() == 2 — integer value via __int__() call."
    - "NOT yet covered: re.MULTILINE.__int__() == 8 — MULTILINE integer value."
    - "NOT yet covered: re.DOTALL.__int__() == 16 — DOTALL integer value."
    - "NOT yet covered: re.compile(r'\\w+').pattern.__eq__('\\w+') via method chain."
    - "re.compile(r'\\d+').pattern == '\\d+' — digit quantifier pattern string preserved verbatim."
    - "re.compile(r'(\\w+)').groups == 1 — Pattern.groups attribute counts capturing groups."
    - "re.compile(r'(\\w+) (\\w+)').groups == 2 — two capturing groups gives groups == 2."
    - "re.compile(r'hello').groups == 0 — no capturing groups gives groups == 0."
    - "re.compile(r'(?P<word>\\w+)').groupindex.__len__() == 1 — single named group in groupindex."
    - "re.IGNORECASE.__int__() == 2 — IGNORECASE has integer value 2."
    - "re.MULTILINE.__int__() == 8 — MULTILINE has integer value 8."
    - "re.DOTALL.__int__() == 16 — DOTALL has integer value 16."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile — .pattern attribute for digit pattern
#
# re_extra14 covers compile(r'[a-z]+').pattern == '[a-z]+'.
# re_extra17 covers no new compile .pattern vectors.
# No prior spec tests compile(r'\d+').pattern == '\d+' (the digit quantifier
# pattern). This verifies the source string is stored verbatim for a different
# input.
# ---------------------------------------------------------------------------

invariant re_extra18.compile.pattern_digit_quantifier:
  description: "re.compile(r'\\d+').pattern == '\\d+' — digit-quantifier pattern preserved in .pattern"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["\\d+"]
  method: pattern.__eq__
  method_args: ["\\d+"]
  expected: true

invariant re_extra18.compile.pattern_word_quantifier:
  description: "re.compile(r'\\w+').pattern == '\\w+' — word-character quantifier pattern preserved"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["\\w+"]
  method: pattern.__eq__
  method_args: ["\\w+"]
  expected: true

# ---------------------------------------------------------------------------
# re.compile — .groups attribute (number of capturing groups)
#
# Pattern.groups is an integer attribute giving the number of capturing groups
# in the pattern. No prior spec (through re_extra17) tests this attribute.
# re_extra14/extra17 test .groupindex (a dict of named groups) but not .groups.
# re.compile(r'hello').groups == 0; r'(\w+)' gives 1; r'(\w+) (\w+)' gives 2.
# ---------------------------------------------------------------------------

invariant re_extra18.compile.groups_zero:
  description: "re.compile(r'hello').groups == 0 — no capturing groups"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["hello"]
  method: groups.__eq__
  method_args: [0]
  expected: true

invariant re_extra18.compile.groups_one:
  description: "re.compile(r'(\\w+)').groups == 1 — one capturing group"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["(\\w+)"]
  method: groups.__eq__
  method_args: [1]
  expected: true

invariant re_extra18.compile.groups_two:
  description: "re.compile(r'(\\w+) (\\w+)').groups == 2 — two capturing groups"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["(\\w+) (\\w+)"]
  method: groups.__eq__
  method_args: [2]
  expected: true

# ---------------------------------------------------------------------------
# re.compile — groupindex with one named group
#
# re_extra11 covers groupindex with 0 named groups (length 0).
# re_extra17 covers groupindex with 2 named groups (length 2).
# No prior spec covers exactly 1 named group.
# re.compile(r'(?P<word>\w+)').groupindex.__len__() == 1.
# ---------------------------------------------------------------------------

invariant re_extra18.compile.groupindex_one_named:
  description: "re.compile(r'(?P<word>\\w+)').groupindex.__len__() == 1 — single named group"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["(?P<word>\\w+)"]
  method: groupindex.__len__
  expected: 1

# ---------------------------------------------------------------------------
# re.IGNORECASE, re.MULTILINE, re.DOTALL — __int__() integer values
#
# re_extra7 covers IGNORECASE/MULTILINE/DOTALL via the .value attribute.
# No prior spec calls .__int__() on RegexFlag members. __int__() is the
# standard integer coercion protocol and must equal .value for IntFlag members.
# IGNORECASE == 2, MULTILINE == 8, DOTALL == 16.
# ---------------------------------------------------------------------------

invariant re_extra18.IGNORECASE.int_value:
  description: "re.IGNORECASE.__int__() == 2 — IGNORECASE integer coercion via __int__()"
  category: RegexFlag
  kind: python_call_eq
  function: IGNORECASE.__int__
  args: []
  expected: 2

invariant re_extra18.MULTILINE.int_value:
  description: "re.MULTILINE.__int__() == 8 — MULTILINE integer coercion via __int__()"
  category: RegexFlag
  kind: python_call_eq
  function: MULTILINE.__int__
  args: []
  expected: 8

invariant re_extra18.DOTALL.int_value:
  description: "re.DOTALL.__int__() == 16 — DOTALL integer coercion via __int__()"
  category: RegexFlag
  kind: python_call_eq
  function: DOTALL.__int__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# Table: compile .groups attribute — zero, one, and two capturing groups
#
# No prior spec provides a table for the Pattern.groups count attribute.
# Groups all three group-count vectors in one indexed table.
# ---------------------------------------------------------------------------

table re_extra18.compile_groups_count:
  description: "re.compile .groups attribute for zero, one, and two capturing groups"
  kind: python_call_eq
  category: compile
  id_prefix: cg

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [zero_groups, compile, ["hello"],          groups.__eq__, [0], true]
    - [one_group,   compile, ["(\\w+)"],         groups.__eq__, [1], true]
    - [two_groups,  compile, ["(\\w+) (\\w+)"],  groups.__eq__, [2], true]

# ---------------------------------------------------------------------------
# Table: RegexFlag __int__() values
#
# No prior spec groups IGNORECASE/MULTILINE/DOTALL integer coercion in a table.
# ---------------------------------------------------------------------------

table re_extra18.RegexFlag_int_values:
  description: "RegexFlag member __int__() coercion values — IGNORECASE/MULTILINE/DOTALL"
  kind: python_call_eq
  category: RegexFlag
  id_prefix: rfiv

  columns: [id, function, args, expected]
  rows:
    - [ignorecase, IGNORECASE.__int__, [], 2]
    - [multiline,  MULTILINE.__int__,  [], 8]
    - [dotall,     DOTALL.__int__,     [], 16]
