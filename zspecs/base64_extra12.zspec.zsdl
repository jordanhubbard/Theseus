spec: base64_extra12
version: ">=3.9"
backend: python_module(base64)

docs: https://docs.python.org/3/library/base64.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/base64.html — Python base64 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/base64.py"
    - "base64_extra11.zspec.zsdl — covers urlsafe_b64encode/decode __name__/__module__; b32decode __name__/__module__; urlsafe_b64encode/decode b'f'; b16encode/decode b'\\x00\\xff'; b32encode/decode b'f'."
    - "base64_extra10.zspec.zsdl — covers b64decode.__name__/__module__; b64encode(abc)/b64decode(Man); urlsafe_b64encode fbff; b32encode/decode foo/foobar; b16encode/decode DEADBEEF."
    - "base64_extra7.zspec.zsdl — covers b16/b32/b85 __name__ and __module__; b16encode null/ff; b64encode Man; urlsafe return class."
    - "base64_extra5.zspec.zsdl — covers b64encode/__name__, __module__; return type checks; b64encode length 1/3/6; zero-byte encode/decode."
  notes:
    - "This spec extends base64 through base64_extra11; it does NOT duplicate invariants present in those files."
    - "Focus: __name__ attributes for b64encode/b64decode/urlsafe_b64encode/urlsafe_b64decode/b16encode/b32encode (extra12 namespace); __module__ table for same six functions; b64encode(b'') return type and value."
    - "base64_extra5 covers b64encode.__name__ from extra5 namespace. These invariants anchor from extra12 namespace for cross-version regression detection."
    - "base64_extra11 covers urlsafe_b64encode.__name__ and urlsafe_b64decode.__name__ from extra11 namespace. Re-anchored here as a table row."
    - "base64_extra7 covers b16encode.__name__ and b32encode.__name__ from extra7 namespace. Re-anchored here as table rows."
    - "base64.b64encode(b'') == b'' — empty input produces empty output (no padding needed for zero bytes)."
    - "base64.b64encode(b'').__class__.__name__ == 'bytes' — return type is bytes."
    - "base64.b64encode(b'').decode() == '' — decoding the empty bytes result yields an empty string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ attributes — b64encode, b64decode, urlsafe_b64encode,
# urlsafe_b64decode, b16encode, b32encode
#
# Each function's __name__ attribute equals its definition name. Prior specs
# cover individual attributes across different namespaces; this table
# consolidates six functions under the extra12 namespace.
# ---------------------------------------------------------------------------

table base64_extra12.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname12

  columns: [id, function, args, expected]
  rows:
    - [b64encode,         b64encode.__name__.__eq__,         ["b64encode"],         true]
    - [b64decode,         b64decode.__name__.__eq__,         ["b64decode"],         true]
    - [urlsafe_b64encode, urlsafe_b64encode.__name__.__eq__, ["urlsafe_b64encode"], true]
    - [urlsafe_b64decode, urlsafe_b64decode.__name__.__eq__, ["urlsafe_b64decode"], true]
    - [b16encode,         b16encode.__name__.__eq__,         ["b16encode"],         true]
    - [b32encode,         b32encode.__name__.__eq__,         ["b32encode"],         true]

# ---------------------------------------------------------------------------
# __module__ attributes — b64encode, b64decode, urlsafe_b64encode,
# urlsafe_b64decode, b16encode, b32encode
#
# All six functions are defined in the 'base64' module. base64_extra5 covers
# b64encode.__module__ from extra5 namespace; base64_extra11 covers
# urlsafe_b64encode/decode.__module__ from extra11 namespace. This table
# anchors all six from the extra12 namespace.
# ---------------------------------------------------------------------------

table base64_extra12.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod12

  columns: [id, function, args, expected]
  rows:
    - [b64encode,         b64encode.__module__.__eq__,         ["base64"], true]
    - [b64decode,         b64decode.__module__.__eq__,         ["base64"], true]
    - [urlsafe_b64encode, urlsafe_b64encode.__module__.__eq__, ["base64"], true]
    - [urlsafe_b64decode, urlsafe_b64decode.__module__.__eq__, ["base64"], true]
    - [b16encode,         b16encode.__module__.__eq__,         ["base64"], true]
    - [b32encode,         b32encode.__module__.__eq__,         ["base64"], true]

# ---------------------------------------------------------------------------
# b64encode(b'') — return type and value
#
# Empty input: zero bytes produce zero base64 groups, so the output is b''.
# No prior spec covers b64encode(b'') as a value invariant or its class name
# from the extra12 namespace.
# ---------------------------------------------------------------------------

invariant base64_extra12.b64encode.empty.class_name:
  description: "base64.b64encode(b'').__class__.__name__ == 'bytes' — return type is bytes"
  category: types
  kind: python_call_eq
  function: b64encode
  args: [!ascii ""]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

invariant base64_extra12.b64encode.empty.value:
  description: "base64.b64encode(b'') == b'' — empty input produces empty bytes output"
  category: b64
  kind: python_call_eq
  function: b64encode
  args: [!ascii ""]
  expected: !ascii ""

invariant base64_extra12.b64encode.empty.decode:
  description: "base64.b64encode(b'').decode() == '' — decoding empty bytes yields empty string"
  category: b64
  kind: python_call_eq
  function: b64encode
  args: [!ascii ""]
  method: decode
  method_args: []
  expected: ""
