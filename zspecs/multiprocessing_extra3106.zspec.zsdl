spec: mp3106
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 654 (mp3106): __lt__, __le__, __gt__ dict-presence for multiprocessing types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: multiprocessing.Process, multiprocessing.pool.Pool, multiprocessing.pool.AsyncResult, multiprocessing.pool.MapResult, multiprocessing.managers.SyncManager, multiprocessing.managers.BaseListProxy, multiprocessing.managers._BaseDictProxy, multiprocessing.managers._BaseSetProxy."
    - "Key finding: multiprocessing.managers._BaseSetProxy defines __lt__, __le__, and __gt__ in its own __dict__ (all true). These are forwarded set-comparison methods: set ordering (<, <=, >) tests subset/superset relationships, and _BaseSetProxy exposes them to proxy these operations to the managed set in the server process."
    - "All other 7 multiprocessing classes return false for __lt__, __le__, and __gt__ in their own __dict__."
    - "multiprocessing.Process, Pool, AsyncResult, MapResult, and SyncManager are process-management and work-distribution primitives; no ordering semantics apply."
    - "BaseListProxy and _BaseDictProxy do not define ordering operators: list comparison would require element-wise ordering (not proxied), and dict comparison is not supported at all in Python 3."
    - "Wave 653 (mp3091) confirmed all 8 classes return false for __hash__, __eq__, and __bool__. _BaseSetProxy being the sole outlier for ordering mirrors the fact that set ordering is mathematically meaningful (subset/superset), whereas other proxy types lack a canonical ordering."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __lt__ dict-presence — operator.contains(Cls.__dict__, '__lt__')
#
# multiprocessing.managers._BaseSetProxy: TRUE — defines __lt__ to proxy the
#   managed set's proper-subset test (a < b means a is a proper subset of b).
# All other 7 multiprocessing classes: false — none define __lt__ in their
#   own __dict__; process and pool objects have no ordering semantics, and
#   the list and dict proxies do not expose list/dict ordering via __lt__.
# ---------------------------------------------------------------------------

table mp3106.lt:
  description: "multiprocessing types __lt__ dict-presence checks; wave 654"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3106

  columns: [id, function, args, expected]
  rows:
    - ["mp3106001", operator.contains, [multiprocessing.Process.__dict__,                  "__lt__"], false]
    - ["mp3106002", operator.contains, [multiprocessing.pool.Pool.__dict__,                "__lt__"], false]
    - ["mp3106003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,         "__lt__"], false]
    - ["mp3106004", operator.contains, [multiprocessing.pool.MapResult.__dict__,           "__lt__"], false]
    - ["mp3106005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,     "__lt__"], false]
    - ["mp3106006", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,   "__lt__"], false]
    - ["mp3106007", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__lt__"], false]
    - ["mp3106008", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__lt__"], true]

# ---------------------------------------------------------------------------
# __le__ dict-presence — operator.contains(Cls.__dict__, '__le__')
