spec: theseus_compression_zlib_cr
version: ">=3.14"
backend: python_cleanroom(theseus_compression_zlib_cr)
blocks: compression.zlib

docs: https://docs.python.org/3/library/compression.zlib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/compression.zlib.html"
  not_derived_from:
    - "CPython source: Lib/compression/zlib.py"
  notes:
    - "Clean-room compression.zlib module (Python 3.14+). Do NOT import compression.zlib."

error_model: python_exceptions

invariant theseus_compression_zlib_cr.czlib2_compress:
  description: "compress/decompress roundtrip works"
  category: behavior
  kind: python_call_eq
  function: czlib2_compress
  args: []
  expected: true

invariant theseus_compression_zlib_cr.czlib2_constants:
  description: "zlib constants are exposed"
  category: behavior
  kind: python_call_eq
  function: czlib2_constants
  args: []
  expected: true

invariant theseus_compression_zlib_cr.czlib2_open:
  description: "open() function creates a writable compressed file"
  category: behavior
  kind: python_call_eq
  function: czlib2_open
  args: []
  expected: true
