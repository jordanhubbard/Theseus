spec: abc_extra171
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABC class attribute identity — abc.ABC.__name__=='ABC' (len=3); abc.ABC.__module__=='abc' (len=3; same length as __name__); abc.ABC.__abstractmethods__.__class__.__name__=='frozenset' (ABC itself has no abstract methods, but __abstractmethods__ exists as an empty frozenset); abc.ABC.__abstractmethods__.__len__()==0; abc.ABCMeta.__name__=='ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7); abc.ABCMeta.__qualname__=='ABCMeta' (len=7; qualname equals name — not nested); abc.ABC.__class__.__name__=='ABCMeta' (ABC's metaclass is ABCMeta). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__name__ == 'ABC' (len=3). abc.ABC is a convenience class defined in Lib/abc.py that makes use of ABCMeta as its metaclass; to create an abstract base class simply subclass abc.ABC. __name__ is 'ABC', 3 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__module__ == 'abc' (len=3). abc.ABC is defined in Lib/abc.py; its __module__ is 'abc' (same 3 chars as __name__='ABC'). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__abstractmethods__ is a frozenset of length 0. abc.ABC itself declares no abstract methods; the frozenset exists but is empty. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__name__ == 'ABCMeta' (len=7: 'ABC'=3+'Meta'=4=7). ABCMeta is the metaclass that adds the abstract method machinery. abc.ABC.__class__.__name__ == 'ABCMeta' — ABC's metaclass is ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__qualname__ == 'ABCMeta' (len=7). ABCMeta is a top-level class; qualname equals name (not a nested class). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABC __name__ and __module__ identity
#
# abc.ABC.__name__ == 'ABC' (len=3)
# abc.ABC.__module__ == 'abc' (len=3; same as __name__)
# abc.ABC.__class__.__name__ == 'ABCMeta'
#
# abc.ABC is a helper class that uses ABCMeta as its metaclass. Subclassing
# abc.ABC is the idiomatic way to define abstract base classes. It is defined
# in Lib/abc.py. __name__='ABC' and __module__='abc' both have length 3.
# New to extra171.
# ---------------------------------------------------------------------------

table abc_extra171.abc_name_module_metaclass:
  description: "abc.ABC.__name__ 'ABC' len 3; __module__ 'abc' len 3 (same as name); __class__.__name__ 'ABCMeta'; new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: abcattrs171

  columns: [id, function, args, expected, description]
  rows:
    - [abc_name_eq,
       ABC.__name__.__eq__,
       ["ABC"],
       true,
       "abc.ABC.__name__.__eq__('ABC') == True — abc.ABC is a convenience class in Lib/abc.py that uses ABCMeta as its metaclass; its __name__ is 'ABC' (3 chars: A-B-C); str.__eq__('ABC') returns True; new to extra171"]
    - [abc_name_len_3,
       ABC.__name__.__len__,
       [],
       3,
       "abc.ABC.__name__.__len__() == 3 — the name 'ABC' has exactly 3 characters: A-B-C; same length as __module__='abc' (3 chars); str.__len__() returns 3; new to extra171"]
    - [abc_module_eq,
       ABC.__module__.__eq__,
       ["abc"],
       true,
       "abc.ABC.__module__.__eq__('abc') == True — abc.ABC is defined in Lib/abc.py; its __module__ is 'abc' (3 chars: a-b-c; same length as __name__='ABC'); str.__eq__('abc') returns True; new to extra171"]
    - [abc_module_len_3,
       ABC.__module__.__len__,
       [],
       3,
       "abc.ABC.__module__.__len__() == 3 — the module name 'abc' has exactly 3 characters: a-b-c; same length as __name__='ABC' (3 chars); str.__len__() returns 3; new to extra171"]
    - [abc_metaclass_abcmeta,
       ABC.__class__.__name__.__eq__,
       ["ABCMeta"],
       true,
       "abc.ABC.__class__.__name__.__eq__('ABCMeta') == True — abc.ABC uses ABCMeta as its metaclass; ABC.__class__ is ABCMeta; __class__.__name__ is 'ABCMeta' (7 chars: 'ABC'=3+'Meta'=4=7); str.__eq__('ABCMeta') returns True; new to extra171"]

# ---------------------------------------------------------------------------
# Table 2: abc.ABC.__abstractmethods__ is an empty frozenset
#
# abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset'
# abc.ABC.__abstractmethods__.__len__() == 0
#
# Every class created with ABCMeta gets an __abstractmethods__ frozenset.
# For abc.ABC itself, this frozenset is empty (len 0) because ABC declares
# no abstract methods of its own. New to extra171.
# ---------------------------------------------------------------------------

table abc_extra171.abc_abstractmethods_frozenset:
  description: "abc.ABC.__abstractmethods__ is a frozenset of len 0 (ABC has no abstract methods itself); new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: abcattrs171

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethods_class_frozenset,
       "ABC.__abstractmethods__.__class__.__name__.__eq__",
       ["frozenset"],
       true,
       "abc.ABC.__abstractmethods__.__class__.__name__.__eq__('frozenset') == True — abc.ABC is created via ABCMeta which sets __abstractmethods__ to a frozenset; ABC itself declares no abstract methods so the frozenset is empty; __class__.__name__ is 'frozenset'; str.__eq__('frozenset') returns True; new to extra171"]
    - [abstractmethods_len_0,
       "ABC.__abstractmethods__.__len__",
       [],
       0,
       "abc.ABC.__abstractmethods__.__len__() == 0 — abc.ABC has no abstract methods declared on it; the frozenset is empty; frozenset.__len__() returns 0; new to extra171"]
    - [abstractmethods_not_set,
       "ABC.__abstractmethods__.__class__.__name__.__eq__",
       ["set"],
       false,
       "abc.ABC.__abstractmethods__.__class__.__name__.__eq__('set') == False — __abstractmethods__ is a frozenset, not a mutable set; ABCMeta specifically uses frozenset for immutability; __class__.__name__ is 'frozenset', not 'set'; str.__eq__('set') returns False; new to extra171"]
    - [abstractmethods_class_name_len,
       "ABC.__abstractmethods__.__class__.__name__.__len__",
       [],
       9,
       "abc.ABC.__abstractmethods__.__class__.__name__.__len__() == 9 — the type name 'frozenset' has 9 characters: f-r-o-z-e-n-s-e-t; str.__len__() returns 9; new to extra171"]

# ---------------------------------------------------------------------------
# Table 3: abc.ABCMeta __name__ and __qualname__ identity
#
# abc.ABCMeta.__name__ == 'ABCMeta' (len=7)
# abc.ABCMeta.__qualname__ == 'ABCMeta' (len=7; qualname == name for top-level class)
#
# ABCMeta is the metaclass that provides the abstract method enforcement
# machinery. It is a top-level class in Lib/abc.py, so __qualname__ == __name__
# (not nested inside any other class or function). New to extra171.
# ---------------------------------------------------------------------------

table abc_extra171.abcmeta_name_qualname:
  description: "abc.ABCMeta.__name__ 'ABCMeta' len 7; __qualname__ 'ABCMeta' len 7 (equals name — top-level class); new to extra171"
  kind: python_call_eq
  category: identity
  id_prefix: abcattrs171

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_name_eq,
       ABCMeta.__name__.__eq__,
       ["ABCMeta"],
       true,
       "abc.ABCMeta.__name__.__eq__('ABCMeta') == True — abc.ABCMeta is the metaclass that provides abstract method enforcement; its __name__ is 'ABCMeta' (7 chars: 'ABC'=3+'Meta'=4=7); str.__eq__('ABCMeta') returns True; new to extra171"]
    - [abcmeta_name_len_7,
       ABCMeta.__name__.__len__,
       [],
       7,
       "abc.ABCMeta.__name__.__len__() == 7 — the name 'ABCMeta' has exactly 7 characters: A-B-C-M-e-t-a; 'ABC'=3+'Meta'=4=7; str.__len__() returns 7; new to extra171"]
    - [abcmeta_qualname_eq,
       ABCMeta.__qualname__.__eq__,
       ["ABCMeta"],
       true,
       "abc.ABCMeta.__qualname__.__eq__('ABCMeta') == True — ABCMeta is a top-level class in Lib/abc.py; its __qualname__ equals its __name__ ('ABCMeta') because it is not nested inside another class or function; str.__eq__('ABCMeta') returns True; new to extra171"]
    - [abcmeta_qualname_len_7,
       ABCMeta.__qualname__.__len__,
       [],
       7,
       "abc.ABCMeta.__qualname__.__len__() == 7 — __qualname__=='ABCMeta' has 7 characters; equals __name__.__len__()==7; str.__len__() returns 7; new to extra171"]
    - [abcmeta_qualname_eq_name,
       ABCMeta.__qualname__.__eq__,
       ["ABCMeta"],
       true,
       "abc.ABCMeta.__qualname__ == abc.ABCMeta.__name__ == 'ABCMeta' — both are 'ABCMeta' (7 chars); for top-level (non-nested) classes qualname always equals name; new to extra171"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra171
# ---------------------------------------------------------------------------

invariant abc_extra171.abc_name_abc:
  description: "abc.ABC.__name__ == 'ABC' — convenience class using ABCMeta; __name__ is 'ABC' (3 chars); new to extra171"
  category: identity
  kind: python_call_eq
  function: ABC.__name__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra171.abc_module_abc:
  description: "abc.ABC.__module__ == 'abc' — defined in Lib/abc.py; __module__ is 'abc' (3 chars; same length as __name__='ABC'); new to extra171"
  category: identity
  kind: python_call_eq
  function: ABC.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra171.abc_abstractmethods_frozenset:
  description: "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset' — ABCMeta sets __abstractmethods__ as a frozenset; ABC's own frozenset is empty (len=0); new to extra171"
  category: identity
  kind: python_call_eq
  function: "ABC.__abstractmethods__.__class__.__name__.__eq__"
  args: ["frozenset"]
  expected: true

invariant abc_extra171.abc_abstractmethods_len_0:
  description: "abc.ABC.__abstractmethods__.__len__() == 0 — ABC declares no abstract methods; __abstractmethods__ frozenset is empty; new to extra171"
  category: identity
  kind: python_call_eq
  function: "ABC.__abstractmethods__.__len__"
  args: []
  expected: 0

invariant abc_extra171.abcmeta_name_abcmeta:
  description: "abc.ABCMeta.__name__ == 'ABCMeta' — metaclass providing abstract method enforcement; __name__ is 'ABCMeta' (7 chars: 'ABC'=3+'Meta'=4=7); new to extra171"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra171.abcmeta_qualname_abcmeta:
  description: "abc.ABCMeta.__qualname__ == 'ABCMeta' — top-level class; qualname equals name (7 chars); not nested; new to extra171"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__qualname__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra171.abc_class_is_abcmeta:
  description: "abc.ABC.__class__.__name__ == 'ABCMeta' — ABC's metaclass is ABCMeta; __class__.__name__ is 'ABCMeta' (7 chars); new to extra171"
  category: identity
  kind: python_call_eq
  function: ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true
