spec: comma_separated_tokens
version: ">=2.0.3"
backend: node(comma-separated-tokens)

docs: https://www.npmjs.com/package/comma-separated-tokens

provenance:
  derived_from:
    - "comma-separated-tokens README — https://www.npmjs.com/package/comma-separated-tokens"
    - "Test vectors verified with comma-separated-tokens via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "comma-separated-tokens source"
  notes:
    - "comma-separated-tokens is an npm package. Install: npm install comma-separated-tokens"
    - "Parses and stringifies comma-separated token strings (as used in HTML attribute values)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array (parse) or string (stringify)."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table comma_separated_tokens.parse:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: cstparse

  columns: [id, args, expected]
  rows:
    - [three,    ["a, b, c"],  ["a", "b", "c"]]
    - [two,      ["foo,bar"],  ["foo", "bar"]]
    - [one,      ["hello"],    ["hello"]]

table comma_separated_tokens.stringify:
  kind: node_module_call_eq
  function: stringify
  category: format
  id_prefix: cststringify

  columns: [id, args, expected]
  rows:
    - [three,  [["a", "b", "c"]],  "a, b, c"]
    - [two,    [["foo", "bar"]],   "foo, bar"]
