spec: hmac_extra4
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
  notes:
    - "This spec extends prior hmac specs."
    - "Focus: __module__ and __name__ for hmac functions; HMAC object attributes."
    - "hmac.new(b'key', b'message', 'sha256') returns an HMAC object."
    - "hmac.new(b'key', b'message', 'sha256').digest_size == 32."
    - "hmac.compare_digest.__name__ == 'compare_digest'."
    - "hmac.HMAC.__name__ == 'HMAC'."
    - "hmac.digest.__name__ == 'digest' (Python 3.7+)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table hmac_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [new,             new.__name__.__eq__,             ["new"],             true]
    - [compare_digest,  compare_digest.__name__.__eq__,  ["compare_digest"],  true]
    - [digest,          digest.__name__.__eq__,          ["digest"],          true]

invariant hmac_extra4.HMAC.class_name:
  description: "hmac.HMAC.__name__ == 'HMAC'"
  category: class_names
  kind: python_call_eq
  function: HMAC.__name__.__eq__
  args: ["HMAC"]
  expected: true

invariant hmac_extra4.HMAC.module:
  description: "hmac.HMAC.__module__ == 'hmac'"
  category: module
  kind: python_call_eq
  function: HMAC.__module__.__eq__
  args: ["hmac"]
  expected: true

invariant hmac_extra4.new.digest_size_sha256:
  description: "hmac.new(b'key', b'msg', 'sha256').digest_size == 32"
  category: new
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha256"]
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hmac_extra4.new.digest_size_md5:
  description: "hmac.new(b'key', b'msg', 'md5').digest_size == 16"
  category: new
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "md5"]
  method: digest_size.__eq__
  method_args: [16]
  expected: true

invariant hmac_extra4.new.instance_class:
  description: "hmac.new(b'key', b'msg', 'sha256').__class__.__name__ == 'HMAC'"
  category: new
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha256"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["HMAC"]
  expected: true

invariant hmac_extra4.compare_digest.equal_strings:
  description: "hmac.compare_digest('abc', 'abc') == True"
  category: compare_digest
  kind: python_call_eq
  function: compare_digest
  args: ["abc", "abc"]
  expected: true

invariant hmac_extra4.compare_digest.unequal_strings:
  description: "hmac.compare_digest('abc', 'xyz') == False"
  category: compare_digest
  kind: python_call_eq
  function: compare_digest
  args: ["abc", "xyz"]
  expected: false

invariant hmac_extra4.new.name_attr:
  description: "hmac.new(b'key', b'msg', 'sha256').name == 'hmac-sha256'"
  category: new
  kind: python_call_eq
  function: new
  args: [!hex 6b6579, !hex 6d7367, "sha256"]
  method: name.__eq__
  method_args: ["hmac-sha256"]
  expected: true
