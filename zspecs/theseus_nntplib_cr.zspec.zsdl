spec: theseus_nntplib_cr
version: ">=3.8"
backend: python_cleanroom(theseus_nntplib_cr)
blocks: nntplib

docs: https://docs.python.org/3/library/nntplib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/nntplib.html"
  not_derived_from:
    - "CPython source: Lib/nntplib.py"
  notes:
    - "Clean-room nntplib module. Do NOT import nntplib."
    - "NNTPError base class and subclasses."
    - "GroupInfo namedtuple."

error_model: python_exceptions

invariant theseus_nntplib_cr.nntplib2_exceptions:
  description: "NNTP exception hierarchy exists"
  category: exceptions
  kind: python_call_eq
  function: nntplib2_exceptions
  args: []
  expected: true

invariant theseus_nntplib_cr.nntplib2_groupinfo:
  description: "GroupInfo namedtuple has expected fields"
  category: types
  kind: python_call_eq
  function: nntplib2_groupinfo
  args: []
  expected: true

invariant theseus_nntplib_cr.nntplib2_articleinfo:
  description: "ArticleInfo namedtuple has expected fields"
  category: types
  kind: python_call_eq
  function: nntplib2_articleinfo
  args: []
  expected: true
