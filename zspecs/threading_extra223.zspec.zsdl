spec: threading_extra223
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading class and method __qualname__ identity contracts."
    - "threading.Thread.__qualname__ == 'Thread'. Verified with Python 3.14.3."
    - "threading.Semaphore.__qualname__ == 'Semaphore'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__qualname__ == 'BoundedSemaphore'. Verified with Python 3.14.3."
    - "threading.Condition.__qualname__ == 'Condition'. Verified with Python 3.14.3."
    - "threading.Event.__qualname__ == 'Event'. Verified with Python 3.14.3."
    - "threading.Timer.__qualname__ == 'Timer'. Verified with Python 3.14.3."
    - "threading.Barrier.__qualname__ == 'Barrier'. Verified with Python 3.14.3."
    - "threading.Thread.start.__qualname__ == 'Thread.start'. Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__ == 'Thread.join'. Verified with Python 3.14.3."
    - "threading.Thread.run.__qualname__ == 'Thread.run'. Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire'. Verified with Python 3.14.3."
    - "threading.Semaphore.release.__qualname__ == 'Semaphore.release'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading class __qualname__ identity checks
#
# Verified with Python 3.14.3:
#   Thread.__qualname__ == 'Thread'
#   Semaphore.__qualname__ == 'Semaphore'
#   BoundedSemaphore.__qualname__ == 'BoundedSemaphore'
#   Condition.__qualname__ == 'Condition'
#   Event.__qualname__ == 'Event'
#   Timer.__qualname__ == 'Timer'
#   Barrier.__qualname__ == 'Barrier'
# ---------------------------------------------------------------------------

table threading_extra223.class_qualnames:
  description: "threading class __qualname__ identity checks; new to extra223"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra223classqualname

  columns: [id, function, args, expected, description]
  rows:
    - [thread_qualname_eq,
       Thread.__qualname__.__eq__,
       ["Thread"],
       true,
       "threading.Thread.__qualname__.__eq__('Thread') == True — Thread is a top-level class defined at module scope in Lib/threading.py; __qualname__ is the simple class name 'Thread'; str.__eq__('Thread') returns True; new to extra223"]
    - [semaphore_qualname_eq,
       Semaphore.__qualname__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__qualname__.__eq__('Semaphore') == True — Semaphore is defined at module scope in Lib/threading.py; __qualname__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra223"]
    - [bounded_semaphore_qualname_eq,
       BoundedSemaphore.__qualname__.__eq__,
       ["BoundedSemaphore"],
       true,
       "threading.BoundedSemaphore.__qualname__.__eq__('BoundedSemaphore') == True — BoundedSemaphore is defined at module scope in Lib/threading.py; __qualname__ is 'BoundedSemaphore'; str.__eq__('BoundedSemaphore') returns True; new to extra223"]
    - [condition_qualname_eq,
       Condition.__qualname__.__eq__,
       ["Condition"],
       true,
       "threading.Condition.__qualname__.__eq__('Condition') == True — Condition is defined at module scope in Lib/threading.py; __qualname__ is 'Condition'; str.__eq__('Condition') returns True; new to extra223"]
    - [event_qualname_eq,
       Event.__qualname__.__eq__,
       ["Event"],
       true,
       "threading.Event.__qualname__.__eq__('Event') == True — Event is defined at module scope in Lib/threading.py; __qualname__ is 'Event'; str.__eq__('Event') returns True; new to extra223"]
    - [timer_qualname_eq,
       Timer.__qualname__.__eq__,
       ["Timer"],
       true,
       "threading.Timer.__qualname__.__eq__('Timer') == True — Timer is defined at module scope in Lib/threading.py; __qualname__ is 'Timer'; str.__eq__('Timer') returns True; new to extra223"]
    - [barrier_qualname_eq,
       Barrier.__qualname__.__eq__,
       ["Barrier"],
       true,
       "threading.Barrier.__qualname__.__eq__('Barrier') == True — Barrier is defined at module scope in Lib/threading.py; __qualname__ is 'Barrier'; str.__eq__('Barrier') returns True; new to extra223"]

# ---------------------------------------------------------------------------
# Table 2: threading method __qualname__ checks
#
# Verified with Python 3.14.3:
#   Thread.start.__qualname__ == 'Thread.start'
#   Thread.join.__qualname__ == 'Thread.join'
#   Thread.run.__qualname__ == 'Thread.run'
#   Semaphore.acquire.__qualname__ == 'Semaphore.acquire'
#   Semaphore.release.__qualname__ == 'Semaphore.release'
# ---------------------------------------------------------------------------

table threading_extra223.method_qualnames:
  description: "threading method __qualname__ identity checks with dotted scope prefix; new to extra223"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra223methodqualname

  columns: [id, function, args, expected, description]
  rows:
    - [thread_start_qualname_eq,
       Thread.start.__qualname__.__eq__,
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — Thread.start is a method of Thread defined in Lib/threading.py; __qualname__ includes the enclosing class prefix 'Thread.start'; str.__eq__('Thread.start') returns True; new to extra223"]
    - [thread_join_qualname_eq,
       Thread.join.__qualname__.__eq__,
       ["Thread.join"],
       true,
       "threading.Thread.join.__qualname__.__eq__('Thread.join') == True — Thread.join is a method of Thread defined in Lib/threading.py; __qualname__ is 'Thread.join'; str.__eq__('Thread.join') returns True; new to extra223"]
    - [thread_run_qualname_eq,
       Thread.run.__qualname__.__eq__,
       ["Thread.run"],
       true,
       "threading.Thread.run.__qualname__.__eq__('Thread.run') == True — Thread.run is the method subclasses override to define thread activity; __qualname__ is 'Thread.run'; str.__eq__('Thread.run') returns True; new to extra223"]
    - [semaphore_acquire_qualname_eq,
       Semaphore.acquire.__qualname__.__eq__,
       ["Semaphore.acquire"],
       true,
       "threading.Semaphore.acquire.__qualname__.__eq__('Semaphore.acquire') == True — Semaphore.acquire acquires the semaphore; __qualname__ is 'Semaphore.acquire'; str.__eq__('Semaphore.acquire') returns True; new to extra223"]
    - [semaphore_release_qualname_eq,
       Semaphore.release.__qualname__.__eq__,
       ["Semaphore.release"],
       true,
       "threading.Semaphore.release.__qualname__.__eq__('Semaphore.release') == True — Semaphore.release releases the semaphore; __qualname__ is 'Semaphore.release'; str.__eq__('Semaphore.release') returns True; new to extra223"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra223
# ---------------------------------------------------------------------------

invariant threading_extra223.thread_qualname:
  description: "threading.Thread.__qualname__.__eq__('Thread') == True — Thread __qualname__ is 'Thread'; new to extra223"
  kind: python_call_eq
  function: Thread.__qualname__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra223.semaphore_qualname:
  description: "threading.Semaphore.__qualname__.__eq__('Semaphore') == True — Semaphore __qualname__ is 'Semaphore'; new to extra223"
  kind: python_call_eq
  function: Semaphore.__qualname__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra223.bounded_semaphore_qualname:
  description: "threading.BoundedSemaphore.__qualname__.__eq__('BoundedSemaphore') == True — BoundedSemaphore __qualname__ is 'BoundedSemaphore'; new to extra223"
  kind: python_call_eq
  function: BoundedSemaphore.__qualname__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

