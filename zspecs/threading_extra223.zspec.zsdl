  description: "threading.Semaphore.acquire.__qualname__.__eq__('Semaphore.acquire') == True — Semaphore.acquire __qualname__ is 'Semaphore.acquire'; new to extra223"
  kind: python_call_eq
  function: Semaphore.acquire.__qualname__.__eq__
