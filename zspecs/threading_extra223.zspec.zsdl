  expected: true

invariant threading_extra223.barrier_qualname:
  description: "threading.Barrier.__qualname__.__eq__('Barrier') == True — Barrier __qualname__ is 'Barrier'; new to extra223"
  kind: python_call_eq
  function: Barrier.__qualname__.__eq__
  args: ["Barrier"]
  expected: true

invariant threading_extra223.thread_start_qualname:
  description: "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — Thread.start __qualname__ is 'Thread.start'; new to extra223"
  kind: python_call_eq
  function: Thread.start.__qualname__.__eq__
  args: ["Thread.start"]
  expected: true

invariant threading_extra223.thread_join_qualname:
  description: "threading.Thread.join.__qualname__.__eq__('Thread.join') == True — Thread.join __qualname__ is 'Thread.join'; new to extra223"
