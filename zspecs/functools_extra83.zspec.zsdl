spec: functools_extra83
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec extends functools_extra82.zspec.zsdl."
    - "This spec covers: functools partial/partialmethod code attributes via pure-Python methods + cached_property code attrs + total_ordering + WRAPPER_ASSIGNMENTS (Wave 244)."
    - "partial.__init__.__class__.__name__ == 'wrapper_descriptor' — partial is a C type; its __init__ is a wrapper_descriptor (no __code__). Verified with Python 3.14.3."
    - "partialmethod.__get__.__code__.co_name == '__get__' — partialmethod.__get__ is a pure-Python method. Verified with Python 3.14.3."
    - "partialmethod.__get__.__code__.co_argcount == 3 — partialmethod.__get__(self, obj, cls). Verified with Python 3.14.3."
    - "cached_property.__init__.__code__.co_name == '__init__' — cached_property is pure Python. Verified with Python 3.14.3."
    - "cached_property.__init__.__code__.co_argcount == 2 — self + func. Verified with Python 3.14.3."
    - "cached_property.__set_name__.__code__.co_name == '__set_name__' — code object name matches method name. Verified with Python 3.14.3."
    - "cached_property.__set_name__.__code__.co_argcount == 3 — self + owner + name. Verified with Python 3.14.3."
    - "total_ordering.__code__.co_varnames.__class__.__name__ == 'tuple' — code object co_varnames is always a tuple. Verified with Python 3.14.3."
    - "total_ordering.__code__.co_argcount == 1 — total_ordering(cls) takes one argument. Verified with Python 3.14.3."
    - "WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a tuple constant. Verified with Python 3.14.3."
    - "WRAPPER_ASSIGNMENTS.__len__() == 6 — in Python 3.14.3 WRAPPER_ASSIGNMENTS has 6 elements: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# partial.__init__ class name — extra83
#
# Wave 244 theme: partial is a C type; __init__ is a wrapper_descriptor.
#
# functools.partial.__init__.__class__.__name__ == 'wrapper_descriptor'
#
# No prior functools spec checks partial.__init__.__class__.__name__ via functoolsmore83. New to extra83.
# ---------------------------------------------------------------------------

table functools_extra83.partial_init_class_name:
  description: "partial.__init__.__class__.__name__=='wrapper_descriptor'; wave 244 partial C type __init__; new to extra83"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore83

  columns: [id, function, args, expected, description]
  rows:
    - [partial_init_class_name_eq_wrapper_descriptor,
       partial.__init__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true,
       "functools.partial.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial is a C extension type defined in Modules/_functoolsmodule.c; its __init__ slot is exposed as a wrapper_descriptor (a C-level slot wrapper); __init__.__class__.__name__ == 'wrapper_descriptor' (18 chars); str.__eq__('wrapper_descriptor') returns True; no prior functools spec checks partial.__init__.__class__.__name__ via functoolsmore83; new to extra83"]

# ---------------------------------------------------------------------------
# partialmethod.__get__ code object — extra83
#
# Wave 244 theme: partialmethod.__get__ is a pure-Python method with a code object.
#
# functools.partialmethod.__get__.__code__.co_name     == '__get__'
# functools.partialmethod.__get__.__code__.co_argcount == 3
#
# No prior functools spec checks partialmethod.__get__.__code__ via functoolsmore83. New to extra83.
# ---------------------------------------------------------------------------

table functools_extra83.partialmethod_get_code:
  description: "partialmethod.__get__.__code__.co_name=='__get__', co_argcount==3; wave 244 partialmethod pure-Python __get__ code attrs; new to extra83"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore83

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_get_code_co_name_eq_get,
       partialmethod.__get__.__code__.co_name.__eq__,
       ["__get__"],
       true,
       "functools.partialmethod.__get__.__code__.co_name.__eq__('__get__') == True — partialmethod.__get__ is a pure-Python descriptor method defined in Lib/functools.py; its code object's co_name attribute records the method name '__get__' (7 chars); str.__eq__('__get__') returns True; no prior functools spec checks partialmethod.__get__.__code__.co_name via functoolsmore83; new to extra83"]
    - [partialmethod_get_code_co_argcount_eq_3,
       partialmethod.__get__.__code__.co_argcount.__eq__,
       [3],
       true,
       "functools.partialmethod.__get__.__code__.co_argcount.__eq__(3) == True — partialmethod.__get__(self, obj, cls) takes three positional arguments: self, the object instance, and the owner class; the code object's co_argcount is 3; int.__eq__(3) returns True; no prior functools spec checks partialmethod.__get__.__code__.co_argcount via functoolsmore83; new to extra83"]

# ---------------------------------------------------------------------------
# cached_property __init__ and __set_name__ code objects — extra83
#
# Wave 244 theme: cached_property is pure Python; code attrs for __init__ and __set_name__.
#
# functools.cached_property.__init__.__code__.co_name       == '__init__'
# functools.cached_property.__init__.__code__.co_argcount   == 2
# functools.cached_property.__set_name__.__code__.co_name   == '__set_name__'
# functools.cached_property.__set_name__.__code__.co_argcount == 3
#
# No prior functools spec checks cached_property code objects via functoolsmore83. New to extra83.
# ---------------------------------------------------------------------------

table functools_extra83.cached_property_code:
  description: "cached_property.__init__.__code__.co_name=='__init__', co_argcount==2; __set_name__ co_name=='__set_name__', co_argcount==3; wave 244 cached_property code attrs; new to extra83"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore83

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_init_code_co_name_eq_init,
       cached_property.__init__.__code__.co_name.__eq__,
       ["__init__"],
       true,
       "functools.cached_property.__init__.__code__.co_name.__eq__('__init__') == True — cached_property is a pure-Python class defined in Lib/functools.py; its __init__ method's code object co_name records the method name '__init__' (8 chars); str.__eq__('__init__') returns True; no prior functools spec checks cached_property.__init__.__code__.co_name via functoolsmore83; new to extra83"]
    - [cached_property_init_code_co_argcount_eq_2,
       cached_property.__init__.__code__.co_argcount.__eq__,
       [2],
       true,
       "functools.cached_property.__init__.__code__.co_argcount.__eq__(2) == True — cached_property.__init__(self, func) takes two positional arguments: self and func (the wrapped function); the code object's co_argcount is 2; int.__eq__(2) returns True; no prior functools spec checks cached_property.__init__.__code__.co_argcount via functoolsmore83; new to extra83"]
    - [cached_property_set_name_code_co_name_eq_set_name,
       cached_property.__set_name__.__code__.co_name.__eq__,
       ["__set_name__"],
       true,
       "functools.cached_property.__set_name__.__code__.co_name.__eq__('__set_name__') == True — cached_property.__set_name__ is a pure-Python method defined in Lib/functools.py that stores the attribute name on the descriptor; its code object's co_name is '__set_name__' (12 chars); str.__eq__('__set_name__') returns True; no prior functools spec checks cached_property.__set_name__.__code__.co_name via functoolsmore83; new to extra83"]
    - [cached_property_set_name_code_co_argcount_eq_3,
       cached_property.__set_name__.__code__.co_argcount.__eq__,
       [3],
       true,
       "functools.cached_property.__set_name__.__code__.co_argcount.__eq__(3) == True — cached_property.__set_name__(self, owner, name) takes three positional arguments: self, the owner class, and the attribute name; the code object's co_argcount is 3; int.__eq__(3) returns True; no prior functools spec checks cached_property.__set_name__.__code__.co_argcount via functoolsmore83; new to extra83"]

# ---------------------------------------------------------------------------
# total_ordering and WRAPPER_ASSIGNMENTS — extra83
#
# Wave 244 theme: total_ordering code attrs; WRAPPER_ASSIGNMENTS is a 6-element tuple.
#
# functools.total_ordering.__code__.co_varnames.__class__.__name__ == 'tuple'
# functools.total_ordering.__code__.co_argcount == 1
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# functools.WRAPPER_ASSIGNMENTS.__len__() == 6
#
# No prior functools spec checks these via functoolsmore83. New to extra83.
# ---------------------------------------------------------------------------

table functools_extra83.total_ordering_WRAPPER_ASSIGNMENTS:
  description: "total_ordering.__code__.co_varnames.__class__.__name__=='tuple', co_argcount==1; WRAPPER_ASSIGNMENTS.__class__.__name__=='tuple', __len__()==6; wave 244 total_ordering/WRAPPER_ASSIGNMENTS; new to extra83"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore83

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_code_co_varnames_class_name_eq_tuple,
       total_ordering.__code__.co_varnames.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.total_ordering.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — total_ordering is a pure-Python decorator function defined in Lib/functools.py; its code object's co_varnames attribute is a tuple of local variable names; __class__.__name__ == 'tuple' (5 chars); str.__eq__('tuple') returns True; no prior functools spec checks total_ordering.__code__.co_varnames.__class__.__name__ via functoolsmore83; new to extra83"]
    - [total_ordering_code_co_argcount_eq_1,
       total_ordering.__code__.co_argcount.__eq__,
       [1],
       true,
       "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — total_ordering(cls) takes exactly one positional argument, the class to be decorated; the code object's co_argcount is 1; int.__eq__(1) returns True; no prior functools spec checks total_ordering.__code__.co_argcount via functoolsmore83; new to extra83"]
    - [WRAPPER_ASSIGNMENTS_class_name_eq_tuple,
       WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple constant defined in Lib/functools.py listing the attributes to copy from the wrapped function; __class__.__name__ == 'tuple' (5 chars); str.__eq__('tuple') returns True; no prior functools spec checks WRAPPER_ASSIGNMENTS.__class__.__name__ via functoolsmore83; new to extra83"]
    - [WRAPPER_ASSIGNMENTS_len_eq_6,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — in Python 3.14.3 WRAPPER_ASSIGNMENTS contains 6 elements: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'; the __annotate__ and __type_params__ entries were added in Python 3.14; tuple.__len__() returns 6; no prior functools spec checks WRAPPER_ASSIGNMENTS.__len__ via functoolsmore83; new to extra83"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra83
# ---------------------------------------------------------------------------

invariant functools_extra83.partial_init_class_name:
  description: "functools.partial.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — partial is a C type; its __init__ is a wrapper_descriptor; wave 244 partial C type attrs; new to extra83"
  kind: python_call_eq
  function: partial.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant functools_extra83.partialmethod_get_code_co_argcount:
  description: "functools.partialmethod.__get__.__code__.co_argcount.__eq__(3) == True — partialmethod.__get__(self, obj, cls) has 3 positional args; wave 244 partialmethod code attrs; new to extra83"
  kind: python_call_eq
  function: partialmethod.__get__.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant functools_extra83.cached_property_init_code_co_argcount:
  description: "functools.cached_property.__init__.__code__.co_argcount.__eq__(2) == True — cached_property.__init__(self, func) has 2 positional args; wave 244 cached_property code attrs; new to extra83"
  kind: python_call_eq
  function: cached_property.__init__.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant functools_extra83.cached_property_set_name_code_co_argcount:
  description: "functools.cached_property.__set_name__.__code__.co_argcount.__eq__(3) == True — cached_property.__set_name__(self, owner, name) has 3 positional args; wave 244 cached_property code attrs; new to extra83"
  kind: python_call_eq
  function: cached_property.__set_name__.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant functools_extra83.WRAPPER_ASSIGNMENTS_len:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS has 6 elements in Python 3.14.3; wave 244 WRAPPER_ASSIGNMENTS constant; new to extra83"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6
