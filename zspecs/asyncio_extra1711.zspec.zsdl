spec: asyncio_extra1711
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 561 (_extra1711): __init__ protocol dict-presence checks."
    - "All asyncio synchronization and task types covered here are pure Python classes defined in asyncio/locks.py, asyncio/queues.py, and asyncio/tasks.py."
    - "asyncio.Future defines __init__ in its own __dict__ (pure Python class in asyncio/futures.py) -> True."
    - "asyncio.Task is a pure Python subclass of Future; it overrides __init__ to accept loop, name, eager_start, and other params -> True."
    - "asyncio.Lock defines __init__ in its own __dict__ (initializes internal state) -> True."
    - "asyncio.Event defines __init__ in its own __dict__ (initializes _value and _waiters) -> True."
    - "asyncio.Semaphore defines __init__ in its own __dict__ (accepts value param) -> True."
    - "asyncio.Queue defines __init__ in its own __dict__ (accepts maxsize param) -> True."
    - "asyncio.Condition defines __init__ in its own __dict__ (accepts optional lock param) -> True."
    - "Cross-checks: asyncio sync primitives do NOT define __new__ in their own __dict__ (inherited from object) -> False."
    - "__init_subclass__ is defined on object and inherited; none of the asyncio classes add it to their own __dict__ -> False."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __init__ dict-presence checks
#
# Wave 561 theme: which asyncio types define __init__ in their own __dict__.
#
# All seven asyncio classes listed here are pure Python and each defines
# __init__ directly on the class to initialize instance state. None of them
# rely on __new__ for construction logic; they all use __init__.
# ---------------------------------------------------------------------------

table asyncio_extra1711.init_protocol:
  description: "asyncio types: __init__ dict-presence via __dict__.__contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1711

  columns: [id, function, args, expected]
  rows:
    - ["as1711001", "asyncio.Future.__dict__.__contains__",    ["__init__"], true]
    - ["as1711002", "asyncio.Task.__dict__.__contains__",      ["__init__"], true]
    - ["as1711003", "asyncio.Lock.__dict__.__contains__",      ["__init__"], true]
    - ["as1711004", "asyncio.Event.__dict__.__contains__",     ["__init__"], true]
    - ["as1711005", "asyncio.Semaphore.__dict__.__contains__", ["__init__"], true]
    - ["as1711006", "asyncio.Queue.__dict__.__contains__",     ["__init__"], true]
    - ["as1711007", "asyncio.Condition.__dict__.__contains__", ["__init__"], true]

# ---------------------------------------------------------------------------
# Table 2: __new__ dict-presence cross-checks
#
# Wave 561 cross-check: pure Python classes inherit __new__ from object and
# do NOT define it in their own __dict__. All asyncio sync primitives and
# task classes are pure Python, so none define __new__ in their own __dict__.
# This is the inverse of the C extension type pattern seen in functools_extra1711
# where C types DO have __new__ in their __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra1711.new_protocol:
  description: "asyncio types: __new__ dict-presence cross-check (all pure Python — none define __new__ in own __dict__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1711

  columns: [id, function, args, expected]
  rows:
    - ["as1711008",  "asyncio.Future.__dict__.__contains__",    ["__new__"], false]
    - ["as1711009",  "asyncio.Task.__dict__.__contains__",      ["__new__"], false]
    - ["as1711010",  "asyncio.Lock.__dict__.__contains__",      ["__new__"], false]
    - ["as1711011",  "asyncio.Event.__dict__.__contains__",     ["__new__"], false]
    - ["as1711012",  "asyncio.Semaphore.__dict__.__contains__", ["__new__"], false]
    - ["as1711013",  "asyncio.Queue.__dict__.__contains__",     ["__new__"], false]
    - ["as1711014",  "asyncio.Condition.__dict__.__contains__", ["__new__"], false]

# ---------------------------------------------------------------------------
# Table 3: __init_subclass__ and __class_getitem__ dict-presence cross-checks
#
# Wave 561 extension: related dunder attributes. __init_subclass__ is defined
# on object and inherited by all classes; asyncio classes do not override it
# in their own __dict__. __class_getitem__ supports generic syntax (PEP 560);
# asyncio synchronization and task types do not support generic syntax and
# do not define __class_getitem__ in their own __dict__.
# ---------------------------------------------------------------------------

table asyncio_extra1711.related_dunder_protocol:
  description: "asyncio types: __init_subclass__ and __class_getitem__ dict-presence (both inherited, not in own __dict__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1711

  columns: [id, function, args, expected]
  rows:
    - ["as1711015", "asyncio.Future.__dict__.__contains__",    ["__init_subclass__"], false]
    - ["as1711016", "asyncio.Task.__dict__.__contains__",      ["__init_subclass__"], false]
    - ["as1711017", "asyncio.Lock.__dict__.__contains__",      ["__init_subclass__"], false]
    - ["as1711018", "asyncio.Event.__dict__.__contains__",     ["__init_subclass__"], false]
    - ["as1711019", "asyncio.Semaphore.__dict__.__contains__", ["__init_subclass__"], false]
    - ["as1711020", "asyncio.Queue.__dict__.__contains__",     ["__init_subclass__"], false]
    - ["as1711021", "asyncio.Condition.__dict__.__contains__", ["__init_subclass__"], false]
    - ["as1711022", "asyncio.Future.__dict__.__contains__",    ["__class_getitem__"], false]
    - ["as1711023", "asyncio.Task.__dict__.__contains__",      ["__class_getitem__"], false]
    - ["as1711024", "asyncio.Lock.__dict__.__contains__",      ["__class_getitem__"], false]
    - ["as1711025", "asyncio.Queue.__dict__.__contains__",     ["__class_getitem__"], false]
