spec: functools_extra2431
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — partial, partialmethod, cached_property, _lru_cache_wrapper async iteration protocol dict-presence"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/functools.py, Modules/_functoolsmodule.c"
  notes:
    - "Theme: __aiter__ and __anext__ async iteration protocol dict-presence for functools types."
    - "functools.partial is a C-implemented type; it has no __aiter__ or __anext__ in its __dict__."
    - "functools.partialmethod is a pure Python class; it has no __aiter__ or __anext__ in its __dict__."
    - "functools.cached_property is a descriptor class; it has no __aiter__ or __anext__ in its __dict__."
    - "functools._lru_cache_wrapper is a C-implemented type wrapping lru_cache results; no async protocol."
    - "None of these functools types define sync iteration (__iter__/__next__) in their own __dict__ either."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

table functools_extra2431.async_iter_absent:
  description: "functools types do not define __aiter__ or __anext__ in their class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2431

  columns: [id, function, args, expected]
  rows:
    - ["ft2431001", "functools.partial.__dict__.__contains__", ["__aiter__"], false]
    - ["ft2431002", "functools.partial.__dict__.__contains__", ["__anext__"], false]
    - ["ft2431003", "functools.partialmethod.__dict__.__contains__", ["__aiter__"], false]
    - ["ft2431004", "functools.partialmethod.__dict__.__contains__", ["__anext__"], false]
    - ["ft2431005", "functools.cached_property.__dict__.__contains__", ["__aiter__"], false]
    - ["ft2431006", "functools.cached_property.__dict__.__contains__", ["__anext__"], false]
    - ["ft2431007", "functools._lru_cache_wrapper.__dict__.__contains__", ["__aiter__"], false]
    - ["ft2431008", "functools._lru_cache_wrapper.__dict__.__contains__", ["__anext__"], false]

table functools_extra2431.sync_iter_also_absent:
  description: "functools types do not define __iter__ or __next__ in their class __dict__ either — confirming they are neither sync nor async iterators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2431

  columns: [id, function, args, expected]
  rows:
    - ["ft2431009", "functools.partial.__dict__.__contains__", ["__iter__"], false]
    - ["ft2431010", "functools.partial.__dict__.__contains__", ["__next__"], false]
    - ["ft2431011", "functools.partialmethod.__dict__.__contains__", ["__iter__"], false]
    - ["ft2431012", "functools.partialmethod.__dict__.__contains__", ["__next__"], false]
    - ["ft2431013", "functools.cached_property.__dict__.__contains__", ["__iter__"], false]
    - ["ft2431014", "functools.cached_property.__dict__.__contains__", ["__next__"], false]
    - ["ft2431015", "functools._lru_cache_wrapper.__dict__.__contains__", ["__iter__"], false]
    - ["ft2431016", "functools._lru_cache_wrapper.__dict__.__contains__", ["__next__"], false]

table functools_extra2431.async_iter_negative_crosscheck:
  description: "Cross-checks: async protocol is absent from functools types whether queried individually or compared"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2431

  columns: [id, function, args, expected]
  rows:
    - ["ft2431017", "functools.partial.__dict__.__contains__", ["__aiter__"], false]
    - ["ft2431018", "functools.cached_property.__dict__.__contains__", ["__aiter__"], false]
    - ["ft2431019", "functools._lru_cache_wrapper.__dict__.__contains__", ["__anext__"], false]
    - ["ft2431020", "functools.partialmethod.__dict__.__contains__", ["__anext__"], false]
