spec: logging_extra21
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra20.zspec.zsdl."
    - "logging_extra20 covers: BaseRotatingHandler/TimedRotatingFileHandler __name__/__qualname__/__module__/__class__.__name__/__bases__[0].__name__; SocketHandler/SysLogHandler __bases__[0].__name__; handler base class table."
    - "logging_extra17 covers: getLevelNamesMapping/addLevelName identity attributes (__name__/__qualname__/__module__/__class__.__name__)."
    - "logging_extra13 covers: getLogger/basicConfig/disable/captureWarnings __name__."
    - "logging_extra9 covers: makeLogRecord/disable/captureWarnings/addLevelName __qualname__."
    - "logging_extra6 covers: getLogger/__qualname__."
    - "NOT yet covered in any prior spec: debug/__qualname__ as a standalone invariant."
    - "NOT yet covered in any prior spec: info/__qualname__ as a standalone invariant."
    - "NOT yet covered in any prior spec: warning/__qualname__ as a standalone invariant."
    - "NOT yet covered in any prior spec: error/__qualname__ as a standalone invariant."
    - "NOT yet covered in any prior spec: critical/__qualname__ as a standalone invariant."
    - "NOT yet covered in any prior spec: exception/__qualname__ as a standalone invariant."
    - "NOT yet covered in any prior spec: log/__qualname__ as a standalone invariant."
    - "The seven module-level convenience functions (debug/info/warning/error/critical/exception/log) are wrappers around the root logger; all are top-level functions so __qualname__ == __name__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level logging convenience functions — __qualname__ standalone invariants
#
# logging_extra9 covers makeLogRecord/disable/captureWarnings/addLevelName
# __qualname__. logging_extra6 covers getLogger/__qualname__. No prior spec
# records __qualname__ as a standalone invariant for the seven core convenience
# functions: debug, info, warning, error, critical, exception, log.
# All are top-level functions, so __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant logging_extra21.debug.qualname:
  description: "logging.debug.__qualname__ == 'debug' — module-level convenience function"
  category: function_identity
  kind: python_call_eq
  function: debug.__qualname__.__eq__
  args: ["debug"]
  expected: true

invariant logging_extra21.info.qualname:
  description: "logging.info.__qualname__ == 'info' — module-level convenience function"
  category: function_identity
  kind: python_call_eq
  function: info.__qualname__.__eq__
  args: ["info"]
  expected: true

invariant logging_extra21.warning.qualname:
  description: "logging.warning.__qualname__ == 'warning' — module-level convenience function"
  category: function_identity
  kind: python_call_eq
  function: warning.__qualname__.__eq__
  args: ["warning"]
  expected: true

invariant logging_extra21.error.qualname:
  description: "logging.error.__qualname__ == 'error' — module-level convenience function"
  category: function_identity
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

invariant logging_extra21.critical.qualname:
  description: "logging.critical.__qualname__ == 'critical' — module-level convenience function"
  category: function_identity
  kind: python_call_eq
  function: critical.__qualname__.__eq__
  args: ["critical"]
  expected: true

invariant logging_extra21.exception.qualname:
  description: "logging.exception.__qualname__ == 'exception' — module-level convenience function"
  category: function_identity
  kind: python_call_eq
  function: exception.__qualname__.__eq__
  args: ["exception"]
  expected: true

invariant logging_extra21.log.qualname:
  description: "logging.log.__qualname__ == 'log' — module-level convenience function"
  category: function_identity
  kind: python_call_eq
  function: log.__qualname__.__eq__
  args: ["log"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level logging convenience functions — __qualname__ table
#
# Consolidates all seven convenience function qualname checks in a single
# table. For top-level Python functions, __qualname__ always equals __name__.
# ---------------------------------------------------------------------------

table logging_extra21.convenience_function_qualnames:
  description: "__qualname__ for the seven module-level logging convenience functions"
  kind: python_call_eq
  category: function_identity

  columns: [id, function, args, expected]
  rows:
    - [debug,     debug.__qualname__.__eq__,     ["debug"],     true]
    - [info,      info.__qualname__.__eq__,      ["info"],      true]
    - [warning,   warning.__qualname__.__eq__,   ["warning"],   true]
    - [error,     error.__qualname__.__eq__,     ["error"],     true]
    - [critical,  critical.__qualname__.__eq__,  ["critical"],  true]
    - [exception, exception.__qualname__.__eq__, ["exception"], true]
    - [log,       log.__qualname__.__eq__,       ["log"],       true]
