spec: operator_extra_rust
version: ">=3.9"
backend: rust_module(operator_extra_rust)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator documentation"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "Clean-room Rust reimplementation of Python operator.itemgetter and operator.methodcaller, exposed via PyO3."
    - "itemgetter(key) returns a callable that retrieves key from its operand."
    - "itemgetter(0)([10,20,30]) == 10 — index 0 of list."
    - "itemgetter(1)([10,20,30]) == 20 — index 1 of list."
    - "methodcaller(name)(*args) calls name(*args) on its operand."
    - "methodcaller('upper')('hello') == 'HELLO'."
    - "methodcaller('strip')('  hi  ') == 'hi'."
    - "All test vectors verified against Python 3.14.3 operator module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# itemgetter — callable that retrieves items by index or key
table operator_extra_rust.itemgetter.index:
  kind: python_call_eq
  category: itemgetter
  id_prefix: ig_idx
  function: itemgetter
  method: __call__

  columns: [id, args, method_args, expected]
  rows:
    - [idx0, [0], [[10, 20, 30]], 10]
    - [idx1, [1], [[10, 20, 30]], 20]
    - [idx2, [2], [[10, 20, 30]], 30]

# itemgetter — additional tests via top-level invariants
invariant operator_extra_rust.itemgetter.call_0:
  description: "itemgetter(0)([10,20,30]) == 10"
  category: itemgetter
  kind: python_call_eq
  function: itemgetter
  args: [0]
  method: __call__
  method_args: [[10, 20, 30]]
  expected: 10

invariant operator_extra_rust.itemgetter.call_2:
  description: "itemgetter(2)([10,20,30]) == 30"
  category: itemgetter
  kind: python_call_eq
  function: itemgetter
  args: [2]
  method: __call__
  method_args: [[10, 20, 30]]
  expected: 30

# methodcaller — callable that invokes a named method
invariant operator_extra_rust.methodcaller.upper:
  description: "methodcaller('upper')('hello') == 'HELLO'"
  category: methodcaller
  kind: python_call_eq
  function: methodcaller
  args: ["upper"]
  method: __call__
  method_args: ["hello"]
  expected: "HELLO"

invariant operator_extra_rust.methodcaller.lower:
  description: "methodcaller('lower')('WORLD') == 'world'"
  category: methodcaller
  kind: python_call_eq
  function: methodcaller
  args: ["lower"]
  method: __call__
  method_args: ["WORLD"]
  expected: "world"

invariant operator_extra_rust.methodcaller.strip:
  description: "methodcaller('strip')('  hi  ') == 'hi'"
  category: methodcaller
  kind: python_call_eq
  function: methodcaller
  args: ["strip"]
  method: __call__
  method_args: ["  hi  "]
  expected: "hi"

invariant operator_extra_rust.methodcaller.len_method:
  description: "methodcaller('__len__')([1,2,3]) == 3"
  category: methodcaller
  kind: python_call_eq
  function: methodcaller
  args: ["__len__"]
  method: __call__
  method_args: [[1, 2, 3]]
  expected: 3

