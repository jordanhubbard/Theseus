spec: pathlib_extra164
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.PurePath method __qualname__ values for dunder methods and is_relative_to."
    - "All PurePath method qualnames follow the 'PurePath.<method>' pattern. The 'PurePath.' prefix is 9 characters."
    - "pathlib.PurePath.__str__.__qualname__ == 'PurePath.__str__' (len=16; 'PurePath.' (9) + '__str__' (7) = 16)."
    - "pathlib.PurePath.__repr__.__qualname__ == 'PurePath.__repr__' (len=17; 'PurePath.' (9) + '__repr__' (8) = 17; tied with __hash__ at 17)."
    - "pathlib.PurePath.__hash__.__qualname__ == 'PurePath.__hash__' (len=17; 'PurePath.' (9) + '__hash__' (8) = 17; tied with __repr__ at 17)."
    - "pathlib.PurePath.__eq__.__qualname__ == 'PurePath.__eq__' (len=15; 'PurePath.' (9) + '__eq__' (6) = 15; tied with __lt__ at 15)."
    - "pathlib.PurePath.__lt__.__qualname__ == 'PurePath.__lt__' (len=15; 'PurePath.' (9) + '__lt__' (6) = 15; tied with __eq__ at 15)."
    - "pathlib.PurePath.__truediv__.__qualname__ == 'PurePath.__truediv__' (len=20; 'PurePath.' (9) + '__truediv__' (11) = 20)."
    - "pathlib.PurePath.__rtruediv__.__qualname__ == 'PurePath.__rtruediv__' (len=21; 'PurePath.' (9) + '__rtruediv__' (12) = 21; the longest dunder qualname in this spec)."
    - "pathlib.PurePath.is_relative_to.__qualname__ == 'PurePath.is_relative_to' (len=23; 'PurePath.' (9) + 'is_relative_to' (14) = 23; the longest qualname in this spec overall)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath dunder method __qualname__ values (group 1)
# __str__, __repr__, __hash__, __eq__, __lt__
# __eq__ and __lt__ tied at 15; __repr__ and __hash__ tied at 17.
# All use 'PurePath.' prefix (9 characters).
# ---------------------------------------------------------------------------

table pathlib_extra164.PurePath_dunder_qualnames_group1:
  description: "pathlib.PurePath dunder __qualname__ values: __eq__=__lt__='PurePath.__*__' (len=15), __str__='PurePath.__str__' (len=16), __repr__=__hash__='PurePath.__*__' (len=17); all use public 'PurePath.' prefix"
  kind: python_call_eq
  category: qualname
  id_prefix: purpathq164

  columns: [id, function, args, expected, description]
  rows:
    - [str_qeq,   "PurePath.__str__.__qualname__.__eq__",   ["PurePath.__str__"],   true, "pathlib.PurePath.__str__.__qualname__ == 'PurePath.__str__' (PurePath.__str__() returns the string representation of the path, using the OS-native separator; 'PurePath.__str__' has 16 characters: 'PurePath.' (9) + '__str__' (7) = 16; this is the method called by str() on a PurePath object; its qualname uses the public class name 'PurePath' — consistent with all other PurePath method qualnames; __str__ is fundamental to pathlib's usability as a drop-in for string paths)"]
    - [repr_qeq,  "PurePath.__repr__.__qualname__.__eq__",  ["PurePath.__repr__"],  true, "pathlib.PurePath.__repr__.__qualname__ == 'PurePath.__repr__' (PurePath.__repr__() returns a developer-friendly representation like PurePosixPath('foo/bar'); 'PurePath.__repr__' has 17 characters: 'PurePath.' (9) + '__repr__' (8) = 17; one character longer than 'PurePath.__str__' (16) because '__repr__' (8 chars) is one character longer than '__str__' (7 chars); tied with 'PurePath.__hash__' at length 17)"]
    - [hash_qeq,  "PurePath.__hash__.__qualname__.__eq__",  ["PurePath.__hash__"],  true, "pathlib.PurePath.__hash__.__qualname__ == 'PurePath.__hash__' (PurePath.__hash__() returns the hash of the path, enabling paths to be used as dict keys and in sets; 'PurePath.__hash__' has 17 characters: 'PurePath.' (9) + '__hash__' (8) = 17; tied with 'PurePath.__repr__' (also 17); both __hash__ and __repr__ have 8-character dunder names; PurePath hashing is case-sensitive on POSIX but case-insensitive on Windows)"]
    - [eq_qeq,    "PurePath.__eq__.__qualname__.__eq__",    ["PurePath.__eq__"],    true, "pathlib.PurePath.__eq__.__qualname__ == 'PurePath.__eq__' (PurePath.__eq__() compares two paths for equality using the path string; 'PurePath.__eq__' has 15 characters: 'PurePath.' (9) + '__eq__' (6) = 15; tied with 'PurePath.__lt__' (also 15) — both __eq__ and __lt__ have 6-character dunder names; equality comparison in PurePath is case-sensitive on POSIX and case-insensitive on Windows; comparing paths of different flavors (POSIX vs Windows) always returns False)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath method __qualname__ values (group 2)
# __lt__, __truediv__, __rtruediv__, is_relative_to
# __lt__=15, __truediv__=20, __rtruediv__=21, is_relative_to=23
# is_relative_to is the longest qualname in this spec.
# ---------------------------------------------------------------------------

table pathlib_extra164.PurePath_operator_qualnames_group2:
  description: "pathlib.PurePath method __qualname__ values: __lt__='PurePath.__lt__' (len=15), __truediv__='PurePath.__truediv__' (len=20), __rtruediv__='PurePath.__rtruediv__' (len=21), is_relative_to='PurePath.is_relative_to' (len=23); is_relative_to is the longest"
  kind: python_call_eq
  category: qualname
  id_prefix: purpathq164

  columns: [id, function, args, expected, description]
  rows:
    - [lt_qeq,             "PurePath.__lt__.__qualname__.__eq__",          ["PurePath.__lt__"],          true, "pathlib.PurePath.__lt__.__qualname__ == 'PurePath.__lt__' (PurePath.__lt__() implements the less-than comparison operator for path ordering; paths are ordered lexicographically; 'PurePath.__lt__' has 15 characters: 'PurePath.' (9) + '__lt__' (6) = 15; tied with 'PurePath.__eq__' (also 15) — both comparison dunders have 6-character names; __lt__ enables PurePath objects to be sorted; PurePath also defines __le__, __gt__, __ge__ via the total_ordering mixin pattern)"]
    - [truediv_qeq,        "PurePath.__truediv__.__qualname__.__eq__",      ["PurePath.__truediv__"],     true, "pathlib.PurePath.__truediv__.__qualname__ == 'PurePath.__truediv__' (PurePath.__truediv__() implements the / operator for path joining — it is the primary way to append path components in pathlib (e.g., Path('/etc') / 'init.d'); 'PurePath.__truediv__' has 20 characters: 'PurePath.' (9) + '__truediv__' (11) = 20; one character shorter than 'PurePath.__rtruediv__' (21); the / operator is the defining syntactic feature of pathlib)"]
    - [rtruediv_qeq,       "PurePath.__rtruediv__.__qualname__.__eq__",     ["PurePath.__rtruediv__"],    true, "pathlib.PurePath.__rtruediv__.__qualname__ == 'PurePath.__rtruediv__' (PurePath.__rtruediv__() is the reflected division operator, enabling path joining when the left operand is a string (e.g., '/etc' / Path('init.d')); 'PurePath.__rtruediv__' has 21 characters: 'PurePath.' (9) + '__rtruediv__' (12) = 21; the longest dunder qualname in this spec; '__rtruediv__' (12 chars) is one character longer than '__truediv__' (11 chars) due to the 'r' reflected-operation prefix)"]
    - [is_relative_to_qeq, "PurePath.is_relative_to.__qualname__.__eq__",  ["PurePath.is_relative_to"], true, "pathlib.PurePath.is_relative_to.__qualname__ == 'PurePath.is_relative_to' (is_relative_to() returns True if the path is relative to the given other path; added in Python 3.9; 'PurePath.is_relative_to' has 23 characters: 'PurePath.' (9) + 'is_relative_to' (14) = 23; the longest qualname in this spec; 'is_relative_to' (14 chars) is the longest method name in this spec; it is the non-raising counterpart to relative_to(), which raises ValueError if the path is not relative to the argument)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra164.PurePath_str_qualname_eq:
  description: "pathlib.PurePath.__str__.__qualname__ == 'PurePath.__str__' — __str__() is the foundational string conversion method for PurePath; it returns the OS-native path string used by open(), os.path functions, and subprocess; its qualname uses the public class name 'PurePath' (not a private name); 'PurePath.__str__' has 16 characters: 'PurePath.' (9) + '__str__' (7) = 16; the 'PurePath.' prefix of 9 characters is fixed across all PurePath method qualnames; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "PurePath.__str__.__qualname__.__eq__"
  args: ["PurePath.__str__"]
  expected: true

invariant pathlib_extra164.PurePath_repr_hash_tied_at_17:
  description: "pathlib.PurePath.__repr__.__qualname__.__len__() == 17 — 'PurePath.__repr__' has 17 characters: 'PurePath.' (9) + '__repr__' (8) = 17; tied with 'PurePath.__hash__' (also 17: 'PurePath.' (9) + '__hash__' (8) = 17); both __repr__ and __hash__ have 8-character dunder names producing the same qualname length; one character longer than 'PurePath.__str__' (16) because '__repr__' (8) > '__str__' (7); confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "PurePath.__repr__.__qualname__.__len__"
  args: []
  expected: 17

invariant pathlib_extra164.PurePath_is_relative_to_qualname_longest_at_23:
  description: "pathlib.PurePath.is_relative_to.__qualname__.__len__() == 23 — 'PurePath.is_relative_to' has 23 characters: 'PurePath.' (9) + 'is_relative_to' (14) = 23; the longest qualname in this spec; 'is_relative_to' (14 chars) is the longest method name covered here for PurePath; the complete length ranking for this spec: __eq__=__lt__=15, __str__=16, __repr__=__hash__=17, __truediv__=20, __rtruediv__=21, is_relative_to=23; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: "PurePath.is_relative_to.__qualname__.__len__"
  args: []
  expected: 23

