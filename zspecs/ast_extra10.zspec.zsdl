spec: ast_extra10
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "CPython source: Python/Python-ast.c"
    - "ast.zspec.zsdl — covers literal_eval primitives/containers/tuple-access, error cases, literal_eval.__name__, arithmetic/statement node classnames (Add,Sub,Mult,Div,Module,Constant,Expr,Name,FunctionDef,ClassDef,If,For,Import,Call)"
    - "ast_extra.zspec.zsdl — covers parse/__name__/__module__/returns_module_node, dump/__name__, get_docstring/__name__, fix_missing_locations/__name__, NodeVisitor/__name__, NodeTransformer/__name__/__bases__[0], AST/__name__, literal_eval standalone round-trips"
    - "ast_extra2.zspec.zsdl — covers literal_eval value checks for int/str/list/dict/bool/None"
    - "ast_extra3.zspec.zsdl — covers __module__ for parse/dump/literal_eval/get_docstring/fix_missing_locations/walk/NodeVisitor/NodeTransformer/Module/FunctionDef/Constant/Name/AST/Expr/ClassDef"
    - "ast_extra4.zspec.zsdl — covers __qualname__ for literal_eval/get_docstring/dump/walk/fix_missing_locations/NodeVisitor/NodeTransformer/AST/Module/Constant/parse; literal_eval type checks"
    - "ast_extra5.zspec.zsdl — covers __qualname__ for FunctionDef/Expr/ClassDef/Name/If/For/Import/Call/Assign/Return/AsyncFunctionDef/AsyncFor/AsyncWith/With/Delete; unparse/__qualname__/__module__, copy_location/__qualname__/__module__, increment_lineno/__qualname__/__module__"
    - "ast_extra6.zspec.zsdl — covers __name__ for Module/Constant/Name/Expr/FunctionDef/ClassDef/If/Return/Assign/Call/Import/For (table); walk.__name__; NodeVisitor.__bases__[0]; AST.__bases__[0]; AsyncFunctionDef/__name__, With/__name__, Delete/__name__"
    - "ast_extra7.zspec.zsdl — covers abstract bases mod/stmt/expr/__name__; BinOp/While/Tuple/List/Try/Raise/Pass/Break/Continue __name__/__qualname__; BinOp/While/Tuple __module__; Module MRO[0]/MRO[2]; parse body __len__"
    - "ast_extra8.zspec.zsdl — covers operator/cmpop/boolop/unaryop/expr_context abstract base __name__; Add/Sub/Mult/Div/Mod/Pow/FloorDiv operator node __name__; Eq/NotEq/Lt/LtE/Gt/GtE cmpop node __name__; And/Or boolop __name__; Not/UAdd/USub unaryop __name__; PyCF_ONLY_AST value; NodeTransformer MRO[1].__name__; parse mode='eval' returns Expression"
    - "ast_extra9.zspec.zsdl — covers NodeVisitor/NodeTransformer __name__.__eq__; get_source_segment.__module__; BitAnd/BitOr/BitXor/LShift/RShift/MatMult/Invert bitwise operator __name__; Is/IsNot/In/NotIn cmpop __name__; Load/Store/Del expr_context __name__; parse/dump __module__.__eq__"
  notes:
    - "This spec covers AST helper node class names not tested in any prior ast spec."
    - "ast.arg.__name__ == 'arg' — the node for function argument names; not covered in any prior spec."
    - "ast.arguments.__name__ == 'arguments' — the node holding all argument specifications; not covered."
    - "ast.keyword.__name__ == 'keyword' — the node for keyword call arguments; not covered."
    - "ast.alias.__name__ == 'alias' — the node for import aliases; not covered."
    - "ast.withitem.__name__ == 'withitem' — the node for items in a 'with' statement; not covered."
    - "ast.Global.__name__ == 'Global' — statement node for 'global' declarations; not covered."
    - "ast.Nonlocal.__name__ == 'Nonlocal' — statement node for 'nonlocal' declarations; not covered."
    - "ast.Yield.__name__ == 'Yield' — expression node for 'yield'; not covered."
    - "ast.YieldFrom.__name__ == 'YieldFrom' — expression node for 'yield from'; not covered."
    - "ast.Await.__name__ == 'Await' — expression node for 'await'; not covered."
    - "ast.Subscript.__name__ == 'Subscript' — expression node for subscript access; not covered."
    - "ast.Attribute.__name__ == 'Attribute' — expression node for attribute access; not covered."
    - "ast.arg.__module__ == 'ast', ast.alias.__module__ == 'ast' — helper node __module__ not covered."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Helper/auxiliary node class __name__ checks
# These are the 'helper' nodes in the AST grammar: arg, arguments, keyword,
# alias, withitem. No prior ast spec covers any of these as __name__ invariants.
# ---------------------------------------------------------------------------

table ast_extra10.helper_node_names:
  kind: python_call_eq
  category: class_names
  id_prefix: hname

  columns: [id, function, args, expected]
  rows:
    - [arg,      arg.__name__.__eq__,      ["arg"],      true]
    - [arguments, arguments.__name__.__eq__, ["arguments"], true]
    - [keyword,  keyword.__name__.__eq__,  ["keyword"],  true]
    - [alias,    alias.__name__.__eq__,    ["alias"],    true]
    - [withitem, withitem.__name__.__eq__, ["withitem"], true]

# ---------------------------------------------------------------------------
# Statement node __name__ checks: Global and Nonlocal
# ast_extra6 covers AsyncFunctionDef/With/Delete; ast_extra7 covers
# BinOp/While/Tuple/List/Try/Raise/Pass/Break/Continue.
# Global and Nonlocal are not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant ast_extra10.Global.name:
  description: "ast.Global.__name__ == 'Global' — 'global x' statement node"
  category: class_names
  kind: python_call_eq
  function: Global.__name__.__eq__
  args: ["Global"]
  expected: true

invariant ast_extra10.Nonlocal.name:
  description: "ast.Nonlocal.__name__ == 'Nonlocal' — 'nonlocal x' statement node"
  category: class_names
  kind: python_call_eq
  function: Nonlocal.__name__.__eq__
  args: ["Nonlocal"]
  expected: true

# ---------------------------------------------------------------------------
# Async/generator expression node __name__ checks
# Yield and YieldFrom are expr nodes; Await is an expr node for coroutines.
# None of these appear as standalone __name__ invariants in any prior spec.
# ---------------------------------------------------------------------------

invariant ast_extra10.Yield.name:
  description: "ast.Yield.__name__ == 'Yield' — 'yield val' expression node"
  category: class_names
  kind: python_call_eq
  function: Yield.__name__.__eq__
  args: ["Yield"]
  expected: true

invariant ast_extra10.YieldFrom.name:
  description: "ast.YieldFrom.__name__ == 'YieldFrom' — 'yield from iterable' expression node"
  category: class_names
  kind: python_call_eq
  function: YieldFrom.__name__.__eq__
  args: ["YieldFrom"]
  expected: true

invariant ast_extra10.Await.name:
  description: "ast.Await.__name__ == 'Await' — 'await expr' expression node (Python 3.5+)"
  category: class_names
  kind: python_call_eq
  function: Await.__name__.__eq__
  args: ["Await"]
  expected: true

# ---------------------------------------------------------------------------
# Access expression node __name__ checks
# Subscript (a[i]), Attribute (a.b), Starred (*a) — none covered in any prior spec.
# ---------------------------------------------------------------------------

invariant ast_extra10.Subscript.name:
  description: "ast.Subscript.__name__ == 'Subscript' — subscript access expression node"
  category: class_names
  kind: python_call_eq
  function: Subscript.__name__.__eq__
  args: ["Subscript"]
  expected: true

invariant ast_extra10.Attribute.name:
  description: "ast.Attribute.__name__ == 'Attribute' — attribute access expression node"
  category: class_names
  kind: python_call_eq
  function: Attribute.__name__.__eq__
  args: ["Attribute"]
  expected: true

invariant ast_extra10.Starred.name:
  description: "ast.Starred.__name__ == 'Starred' — starred expression node (*x)"
  category: class_names
  kind: python_call_eq
  function: Starred.__name__.__eq__
  args: ["Starred"]
  expected: true

# ---------------------------------------------------------------------------
# Helper node __module__ checks
# ast_extra3 covers __module__ for many function/class names; helper nodes
# (arg, alias, Global, keyword) have never been checked.
# ---------------------------------------------------------------------------

invariant ast_extra10.arg.module:
  description: "ast.arg.__module__ == 'ast' — helper node is defined in the ast module"
  category: module_attrs
  kind: python_call_eq
  function: arg.__module__.__eq__
  args: ["ast"]
  expected: true

invariant ast_extra10.alias.module:
  description: "ast.alias.__module__ == 'ast' — alias node is defined in the ast module"
  category: module_attrs
  kind: python_call_eq
  function: alias.__module__.__eq__
  args: ["ast"]
  expected: true
