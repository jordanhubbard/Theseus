spec: socks_proxy_agent
version: ">=8.0.0"
backend: node(socks-proxy-agent)

docs: https://github.com/TooTallNate/proxy-agents/tree/main/packages/socks-proxy-agent#readme

provenance:
  derived_from:
    - "socks-proxy-agent README — https://github.com/TooTallNate/proxy-agents/tree/main/packages/socks-proxy-agent#readme"
    - "Test vectors verified with socks-proxy-agent via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "socks-proxy-agent source"
  notes:
    - "http(s).Agent that tunnels traffic through a SOCKS4/4a/5 proxy."
    - "Install: npm install socks-proxy-agent"
    - "v8 CJS; named export SocksProxyAgent (extends agent-base.Agent)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Connection errors propagate via the http request object."
  stderr: "null"
  stickiness: "Each agent instance owns its own connection-pool state."
  codes: {}

invariant socks_proxy_agent.has_SocksProxyAgent:
  description: "SocksProxyAgent class exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "SocksProxyAgent.constructor.name"}
  expected: "Function"

invariant socks_proxy_agent.SocksProxyAgent_name:
  description: "SocksProxyAgent.name is 'SocksProxyAgent'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "SocksProxyAgent.name"}
  expected: "SocksProxyAgent"

invariant socks_proxy_agent.proto_has_connect:
  description: "SocksProxyAgent.prototype.connect defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "SocksProxyAgent.prototype.connect.constructor.name"}
  expected: "AsyncFunction"
