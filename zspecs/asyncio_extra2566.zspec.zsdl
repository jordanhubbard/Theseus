spec: asyncio_extra2566
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/asyncio.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "Wave 2566 theme: __getattr__, __setattr__, __delattr__ dict-presence — custom attribute access protocol."
    - "asyncio.Queue, asyncio.Task, asyncio.Future, asyncio.Lock, asyncio.Event define NONE of __getattr__, __setattr__, or __delattr__ in their own __dict__."
    - "asyncio.Semaphore and asyncio.Condition likewise define none of these three dunders in their class __dict__."
    - "All asyncio sync primitives and async-queue classes rely on the default object attribute access machinery."
    - "asyncio.Queue.__dict__ does contain __init__, __repr__, put, get, qsize, empty, full among others."
    - "asyncio.Task.__dict__ contains __iter__, cancel, and other coroutine-task methods but not attribute-access overrides."
    - "asyncio.Future.__dict__ contains result, cancel, done, set_result, set_exception but not __getattr__/__setattr__/__delattr__."
    - "asyncio.Lock.__dict__ contains acquire, release and related primitives but no attribute-access protocol."
    - "asyncio.Event.__dict__ contains set, clear, wait, is_set but no attribute-access overrides."
    - "asyncio.Condition.__dict__ contains wait, notify, notify_all but not acquire or release (those are inherited)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# asyncio.Queue — attribute access protocol absent, normal API present
# ---------------------------------------------------------------------------

table asyncio_extra2566.queue_attr_protocol:
  description: "asyncio.Queue defines none of __getattr__, __setattr__, __delattr__ in its class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2566

  columns: [id, function, args, expected]
  rows:
    - ["as2566001", "asyncio.Queue.__dict__.__contains__", ["__getattr__"], false]
    - ["as2566002", "asyncio.Queue.__dict__.__contains__", ["__setattr__"], false]
    - ["as2566003", "asyncio.Queue.__dict__.__contains__", ["__delattr__"], false]

# ---------------------------------------------------------------------------
# asyncio.Queue — positive presence of core queue API in __dict__
# ---------------------------------------------------------------------------

table asyncio_extra2566.queue_dict_positive:
  description: "asyncio.Queue core methods are defined directly in the class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2566

  columns: [id, function, args, expected]
  rows:
    - ["as2566004", "asyncio.Queue.__dict__.__contains__", ["__init__"],  true]
    - ["as2566005", "asyncio.Queue.__dict__.__contains__", ["__repr__"],  true]
    - ["as2566006", "asyncio.Queue.__dict__.__contains__", ["put"],       true]
    - ["as2566007", "asyncio.Queue.__dict__.__contains__", ["get"],       true]
    - ["as2566008", "asyncio.Queue.__dict__.__contains__", ["qsize"],     true]
    - ["as2566009", "asyncio.Queue.__dict__.__contains__", ["empty"],     true]
    - ["as2566010", "asyncio.Queue.__dict__.__contains__", ["full"],      true]

# ---------------------------------------------------------------------------
# asyncio.Task — attribute access protocol absent
# ---------------------------------------------------------------------------

table asyncio_extra2566.task_attr_protocol:
  description: "asyncio.Task defines none of __getattr__, __setattr__, __delattr__ in its class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2566

  columns: [id, function, args, expected]
  rows:
    - ["as2566011", "asyncio.Task.__dict__.__contains__", ["__getattr__"], false]
    - ["as2566012", "asyncio.Task.__dict__.__contains__", ["__setattr__"], false]
    - ["as2566013", "asyncio.Task.__dict__.__contains__", ["__delattr__"], false]
    - ["as2566014", "asyncio.Task.__dict__.__contains__", ["__iter__"],    true]
    - ["as2566015", "asyncio.Task.__dict__.__contains__", ["cancel"],      true]

# ---------------------------------------------------------------------------
# asyncio.Future — attribute access protocol absent
# ---------------------------------------------------------------------------

table asyncio_extra2566.future_attr_protocol:
  description: "asyncio.Future defines none of __getattr__, __setattr__, __delattr__ in its class __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2566

  columns: [id, function, args, expected]
  rows:
    - ["as2566016", "asyncio.Future.__dict__.__contains__", ["__getattr__"], false]
    - ["as2566017", "asyncio.Future.__dict__.__contains__", ["__setattr__"], false]
    - ["as2566018", "asyncio.Future.__dict__.__contains__", ["__delattr__"], false]
    - ["as2566019", "asyncio.Future.__dict__.__contains__", ["result"],      true]

# ---------------------------------------------------------------------------
# asyncio.Lock and asyncio.Event — attribute access protocol absent
# ---------------------------------------------------------------------------

table asyncio_extra2566.lock_event_attr_protocol:
  description: "asyncio.Lock and asyncio.Event define none of the three attribute-access dunders"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2566

  columns: [id, function, args, expected]
  rows:
    - ["as2566020", "asyncio.Lock.__dict__.__contains__",  ["__getattr__"], false]
    - ["as2566021", "asyncio.Lock.__dict__.__contains__",  ["__setattr__"], false]
    - ["as2566022", "asyncio.Lock.__dict__.__contains__",  ["__delattr__"], false]
    - ["as2566023", "asyncio.Lock.__dict__.__contains__",  ["acquire"],     true]
    - ["as2566024", "asyncio.Event.__dict__.__contains__", ["__getattr__"], false]
    - ["as2566025", "asyncio.Event.__dict__.__contains__", ["__setattr__"], false]
    - ["as2566026", "asyncio.Event.__dict__.__contains__", ["__delattr__"], false]
    - ["as2566027", "asyncio.Event.__dict__.__contains__", ["set"],         true]
    - ["as2566028", "asyncio.Event.__dict__.__contains__", ["clear"],       true]
    - ["as2566029", "asyncio.Event.__dict__.__contains__", ["wait"],        true]
    - ["as2566030", "asyncio.Event.__dict__.__contains__", ["is_set"],      true]
