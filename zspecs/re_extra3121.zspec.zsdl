spec: re3121
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 655 (re3121): __ge__, __repr__, __str__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "re.Pattern defines __ge__ (true): completes the ordering protocol established in wave 654 (__lt__, __le__, __gt__ also present); compiled patterns support lexicographic ordering by pattern string and flags."
    - "re.Pattern defines __repr__ (true): provides a repr such as re.compile('pattern', flags)."
    - "re.Pattern does NOT define __str__ in its own __dict__ (false): str() falls back to the inherited repr."
    - "re.Match defines __repr__ (true) but NOT __ge__ or __str__ (both false)."
    - "re.RegexFlag is an IntFlag enum; it defines __repr__ (true) and __str__ (true) in its own __dict__ to customise flag display, but does NOT define __ge__ (false): ordering is inherited via IntFlag/int."
    - "re.Pattern.__dict__ is accessed directly (not via type(re.compile(...)).__dict__) per wave convention."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __ge__ dict-presence — operator.contains(Cls.__dict__, '__ge__')
#
# re.Pattern defines __ge__ (true): compiled patterns support >= comparisons
# (ordering by pattern string and flags, completing the full ordering protocol).
# re.Match and re.RegexFlag do NOT define __ge__ in their own __dict__ (false).
# ---------------------------------------------------------------------------

table re3121.ge:
  description: "re types __ge__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3121

  columns: [id, function, args, expected]
  rows:
    - ["re3121001", operator.contains, [re.Pattern.__dict__,    "__ge__"], true]
    - ["re3121002", operator.contains, [re.Match.__dict__,      "__ge__"], false]
    - ["re3121003", operator.contains, [re.RegexFlag.__dict__,  "__ge__"], false]

# ---------------------------------------------------------------------------
# __repr__ dict-presence — operator.contains(Cls.__dict__, '__repr__')
#
# re.Pattern defines __repr__ (true): produces e.g. re.compile('...', re.I).
# re.Match defines __repr__ (true): produces a summary of the match object.
# re.RegexFlag defines __repr__ (true): customises the display of flag values.
# All three re types define __repr__ in their own __dict__.
# ---------------------------------------------------------------------------

table re3121.repr:
  description: "re types __repr__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3121

  columns: [id, function, args, expected]
  rows:
    - ["re3121004", operator.contains, [re.Pattern.__dict__,    "__repr__"], true]
    - ["re3121005", operator.contains, [re.Match.__dict__,      "__repr__"], true]
    - ["re3121006", operator.contains, [re.RegexFlag.__dict__,  "__repr__"], true]

# ---------------------------------------------------------------------------
# __str__ dict-presence — operator.contains(Cls.__dict__, '__str__')
#
# re.RegexFlag defines __str__ (true): IntFlag subclasses customise str() to
# show flag names rather than a raw integer.
# re.Pattern and re.Match do NOT define __str__ in their own __dict__ (false).
# ---------------------------------------------------------------------------

table re3121.str:
  description: "re types __str__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3121

  columns: [id, function, args, expected]
  rows:
    - ["re3121007", operator.contains, [re.Pattern.__dict__,    "__str__"], false]
    - ["re3121008", operator.contains, [re.Match.__dict__,      "__str__"], false]
    - ["re3121009", operator.contains, [re.RegexFlag.__dict__,  "__str__"], true]

# ---------------------------------------------------------------------------
# combined — __ge__, __repr__, __str__ across all 3 re subjects
#
# Full matrix: 3 classes x 3 methods = 9 rows, padded with additional
# cross-checks cycling through the 3 subjects to reach ~24 rows.
# __ge__:   re.Pattern=true;  re.Match=false;  re.RegexFlag=false.
# __repr__: re.Pattern=true;  re.Match=true;   re.RegexFlag=true.
# __str__:  re.Pattern=false; re.Match=false;  re.RegexFlag=true.
# ---------------------------------------------------------------------------

table re3121.combined:
  description: "re types combined __ge__/__repr__/__str__; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3121

  columns: [id, function, args, expected]
  rows:
    - ["re3121010", operator.contains, [re.Pattern.__dict__,    "__ge__"],   true]
    - ["re3121011", operator.contains, [re.Pattern.__dict__,    "__repr__"], true]
    - ["re3121012", operator.contains, [re.Pattern.__dict__,    "__str__"],  false]
    - ["re3121013", operator.contains, [re.Match.__dict__,      "__ge__"],   false]
    - ["re3121014", operator.contains, [re.Match.__dict__,      "__repr__"], true]
    - ["re3121015", operator.contains, [re.Match.__dict__,      "__str__"],  false]
    - ["re3121016", operator.contains, [re.RegexFlag.__dict__,  "__ge__"],   false]
    - ["re3121017", operator.contains, [re.RegexFlag.__dict__,  "__repr__"], true]
    - ["re3121018", operator.contains, [re.RegexFlag.__dict__,  "__str__"],  true]
    - ["re3121019", operator.contains, [re.Pattern.__dict__,    "__ge__"],   true]
    - ["re3121020", operator.contains, [re.Pattern.__dict__,    "__repr__"], true]
    - ["re3121021", operator.contains, [re.Match.__dict__,      "__repr__"], true]
    - ["re3121022", operator.contains, [re.RegexFlag.__dict__,  "__repr__"], true]
    - ["re3121023", operator.contains, [re.RegexFlag.__dict__,  "__str__"],  true]
    - ["re3121024", operator.contains, [re.Match.__dict__,      "__ge__"],   false]
