spec: io_extra2596
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
    - "io_extra2581.zspec.zsdl — covers __call__ dict-presence"
  notes:
    - "Wave 2596 theme: __get__/__set__/__delete__ descriptor protocol dict-presence."
    - "None of the io classes define __get__, __set__, or __delete__ in their own __dict__."
    - "io stream classes are I/O objects, not descriptors — they do not participate in the descriptor protocol."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase are abstract base classes; none define descriptor methods."
    - "io.BytesIO, io.StringIO, io.FileIO define read/write/seek methods but NOT descriptor protocol methods."
    - "io.BufferedReader, io.BufferedWriter, io.TextIOWrapper define stream methods but NOT descriptor protocol methods."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __get__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2596.no_get_in_io_classes:
  description: "__get__ is absent from all io class __dict__s — io stream classes are not descriptors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2596

  columns: [id, function, args, expected]
  rows:
    - ["io2596001", "io.IOBase.__dict__.__contains__",       ["__get__"], false]
    - ["io2596002", "io.RawIOBase.__dict__.__contains__",    ["__get__"], false]
    - ["io2596003", "io.BufferedIOBase.__dict__.__contains__", ["__get__"], false]
    - ["io2596004", "io.TextIOBase.__dict__.__contains__",   ["__get__"], false]
    - ["io2596005", "io.BytesIO.__dict__.__contains__",      ["__get__"], false]
    - ["io2596006", "io.StringIO.__dict__.__contains__",     ["__get__"], false]

# ---------------------------------------------------------------------------
# __set__ dict-presence — io concrete I/O classes
# ---------------------------------------------------------------------------

table io_extra2596.no_set_in_io_classes:
  description: "__set__ is absent from all io class __dict__s — io stream classes do not implement the data descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2596

  columns: [id, function, args, expected]
  rows:
    - ["io2596007", "io.IOBase.__dict__.__contains__",        ["__set__"], false]
    - ["io2596008", "io.BytesIO.__dict__.__contains__",       ["__set__"], false]
    - ["io2596009", "io.StringIO.__dict__.__contains__",      ["__set__"], false]
    - ["io2596010", "io.FileIO.__dict__.__contains__",        ["__set__"], false]
    - ["io2596011", "io.BufferedReader.__dict__.__contains__", ["__set__"], false]
    - ["io2596012", "io.BufferedWriter.__dict__.__contains__", ["__set__"], false]

# ---------------------------------------------------------------------------
# __delete__ dict-presence — io concrete I/O classes
# ---------------------------------------------------------------------------

table io_extra2596.no_delete_in_io_classes:
  description: "__delete__ is absent from all io class __dict__s — io stream classes do not implement the deletion descriptor protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2596

  columns: [id, function, args, expected]
  rows:
    - ["io2596013", "io.IOBase.__dict__.__contains__",         ["__delete__"], false]
    - ["io2596014", "io.BytesIO.__dict__.__contains__",        ["__delete__"], false]
    - ["io2596015", "io.StringIO.__dict__.__contains__",       ["__delete__"], false]
    - ["io2596016", "io.FileIO.__dict__.__contains__",         ["__delete__"], false]
    - ["io2596017", "io.BufferedRandom.__dict__.__contains__", ["__delete__"], false]
    - ["io2596018", "io.TextIOWrapper.__dict__.__contains__",  ["__delete__"], false]

# ---------------------------------------------------------------------------
# Complementary: io.BytesIO and io.StringIO HAVE normal I/O methods but NOT descriptor methods
# Confirms that io classes define domain-specific methods, never descriptor protocol methods
# ---------------------------------------------------------------------------

table io_extra2596.io_has_stream_methods_not_descriptor:
  description: "io.BytesIO and io.StringIO define read/write/seek but NOT __get__/__set__/__delete__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2596

  columns: [id, function, args, expected]
  rows:
    - ["io2596019", "io.BytesIO.__dict__.__contains__",  ["read"],     true]
    - ["io2596020", "io.BytesIO.__dict__.__contains__",  ["write"],    true]
    - ["io2596021", "io.BytesIO.__dict__.__contains__",  ["__get__"],  false]
    - ["io2596022", "io.StringIO.__dict__.__contains__", ["getvalue"], true]
    - ["io2596023", "io.StringIO.__dict__.__contains__", ["readline"], true]
    - ["io2596024", "io.StringIO.__dict__.__contains__", ["__set__"],  false]
