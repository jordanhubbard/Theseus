spec: os_extra10
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
  notes:
    - "This spec extends os.zspec.zsdl and prior extras through os_extra9.zspec.zsdl."
    - "os_extra7 covers stat_result.__name__ and stat_result.__module__; no prior spec covers stat_result.__qualname__."
    - "os_extra7 covers DirEntry.__name__; no prior spec covers DirEntry.__qualname__ or DirEntry.__module__."
    - "os_extra7 covers terminal_size.__name__; no prior spec covers terminal_size.__qualname__ or terminal_size.__module__."
    - "os_extra6 covers PathLike.__name__ and os_extra7 covers PathLike.__module__; no prior spec covers PathLike.__qualname__."
    - "No prior spec covers os.name (the OS family name — 'posix' on macOS/Linux/FreeBSD)."
    - "No prior spec covers os.path.__name__ (which is 'posixpath' on POSIX systems)."
    - "No prior spec covers os.sep.isascii() or os.curdir.isascii() or os.pardir.isascii()."
    - "No prior spec covers os.getlogin.__name__."
    - "os.name == 'posix' on all POSIX platforms (macOS, Linux, FreeBSD, etc.)."
    - "os.path.__name__ == 'posixpath' on POSIX systems."
    - "os.stat_result.__qualname__ == 'stat_result' — qualname equals name for a top-level C-extension type."
    - "os.DirEntry.__qualname__ == 'DirEntry' — qualname equals name for a top-level C-extension type."
    - "os.terminal_size.__qualname__ == 'terminal_size' — qualname equals name."
    - "os.PathLike.__qualname__ == 'PathLike' — qualname equals name."
    - "os.sep.isascii() == True — the path separator '/' is a pure ASCII character."
    - "os.curdir.isascii() == True — '.' is ASCII."
    - "os.pardir.isascii() == True — '..' is ASCII."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# os.name — OS family constant
#
# 'posix' on all POSIX systems (macOS, Linux, FreeBSD).
# Not covered in any prior os spec.
# ---------------------------------------------------------------------------

invariant os_extra10.name.eq_posix:
  description: "os.name == 'posix' on all POSIX platforms (macOS, Linux, FreeBSD)"
  category: constants
  kind: python_call_eq
  function: name.__eq__
  args: ["posix"]
  expected: true

invariant os_extra10.name.class_name:
  description: "os.name.__class__.__name__ == 'str' — os.name is always a str"
  category: constants
  kind: python_call_eq
  function: name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# os.path.__name__ — the underlying path module on POSIX
#
# On POSIX systems, os.path is the posixpath module.
# Not covered in any prior os spec.
# ---------------------------------------------------------------------------

invariant os_extra10.path.module_name:
  description: "os.path.__name__ == 'posixpath' on POSIX systems"
  category: path_module
  kind: python_call_eq
  function: path.__name__.__eq__
  args: ["posixpath"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks for os C-extension types
#
# os_extra7 covers __name__ for stat_result/DirEntry/terminal_size/PathLike.
# os_extra8 covers __qualname__ for function objects.
# No prior spec covers __qualname__ for these type objects.
# ---------------------------------------------------------------------------

table os_extra10.type_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [stat_result,   stat_result.__qualname__.__eq__,   ["stat_result"],   true]
    - [DirEntry,      DirEntry.__qualname__.__eq__,      ["DirEntry"],      true]
    - [terminal_size, terminal_size.__qualname__.__eq__, ["terminal_size"], true]
    - [PathLike,      PathLike.__qualname__.__eq__,      ["PathLike"],      true]

# ---------------------------------------------------------------------------
# DirEntry and terminal_size — __module__ checks
#
# os_extra7 covers DirEntry.__name__ and terminal_size.__name__.
# No prior spec covers their __module__ attributes.
# ---------------------------------------------------------------------------

invariant os_extra10.DirEntry.module:
  description: "os.DirEntry.__module__ == 'os' — DirEntry is exported from the os module"
  category: class_metadata
  kind: python_call_eq
  function: DirEntry.__module__.__eq__
  args: ["os"]
  expected: true

invariant os_extra10.terminal_size.module:
  description: "os.terminal_size.__module__ == 'os' — terminal_size is exported from the os module"
  category: class_metadata
  kind: python_call_eq
  function: terminal_size.__module__.__eq__
  args: ["os"]
  expected: true

# ---------------------------------------------------------------------------
# os.sep, os.curdir, os.pardir — isascii() checks
#
# os_extra9 covers __len__ for these constants.
# No prior spec checks isascii() — a distinct string-quality axis.
# ---------------------------------------------------------------------------

invariant os_extra10.sep.isascii:
  description: "os.sep.isascii() == True — '/' is a pure ASCII character"
  category: constants
  kind: python_call_eq
  function: sep.isascii
  args: []
  expected: true

invariant os_extra10.curdir.isascii:
  description: "os.curdir.isascii() == True — '.' is a pure ASCII character"
  category: constants
  kind: python_call_eq
  function: curdir.isascii
  args: []
  expected: true

invariant os_extra10.pardir.isascii:
  description: "os.pardir.isascii() == True — '..' is composed of pure ASCII characters"
  category: constants
  kind: python_call_eq
  function: pardir.isascii
  args: []
  expected: true

# ---------------------------------------------------------------------------
# os.getlogin — __name__ check
#
# No prior os spec covers os.getlogin.__name__.
# ---------------------------------------------------------------------------

invariant os_extra10.getlogin.name:
  description: "os.getlogin.__name__ == 'getlogin'"
  category: function_names
  kind: python_call_eq
  function: getlogin.__name__.__eq__
  args: ["getlogin"]
  expected: true
