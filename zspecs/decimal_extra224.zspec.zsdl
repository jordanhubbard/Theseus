spec: decimal_extra224
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal comparison and rounding contracts — __gt__, __lt__, __eq__, __ne__, quantize, to_integral_value, and as_tuple."
    - "Decimal('1.5').__gt__(Decimal('1.0')) == True — verified Python 3.14.3 macOS."
    - "Decimal('1.0').__lt__(Decimal('2.0')) == True — verified Python 3.14.3 macOS."
    - "Decimal('1.0').__eq__(Decimal('1.0')) == True — verified Python 3.14.3 macOS."
    - "Decimal('1.5').__ne__(Decimal('1.0')) == True — verified Python 3.14.3 macOS."
    - "Decimal('3.14159').quantize(Decimal('0.01')) str == '3.14' — rounds to 2 decimal places; verified Python 3.14.3 macOS."
    - "Decimal('1.005').quantize(Decimal('0.01')) str == '1.00' — banker's rounding: 1.005 rounds to 1.00 (nearest even); verified Python 3.14.3 macOS."
    - "Decimal('2.5').to_integral_value() str == '2' — banker's rounding: 2.5 rounds to 2 (nearest even integer); verified Python 3.14.3 macOS."
    - "Decimal('1.5').to_integral_value() str == '2' — banker's rounding: 1.5 rounds to 2 (nearest even integer); verified Python 3.14.3 macOS."
    - "Decimal('1.23').as_tuple().__class__.__name__ == 'DecimalTuple' — as_tuple returns a named tuple; verified Python 3.14.3 macOS."
    - "Decimal('1.23').as_tuple().sign == 0 — positive number has sign 0; verified Python 3.14.3 macOS."
    - "Decimal('-3').as_tuple().sign == 1 — negative number has sign 1; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal comparison behavioral contracts
# Integer operands used in method_args since JSON cannot serialize Decimal.
# Decimal accepts int operands for all comparison operators.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra224.Decimal.gt_true:
  description: "decimal.Decimal('1.5').__gt__(1) == True — Decimal('1.5') > 1 is True; int operand used; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: __gt__
  method_args: [1]
  expected: true

invariant decimal_extra224.Decimal.lt_true:
  description: "decimal.Decimal('1.0').__lt__(2) == True — Decimal('1.0') < 2 is True; int operand used; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["1.0"]
  method: __lt__
  method_args: [2]
  expected: true

invariant decimal_extra224.Decimal.eq_true:
  description: "decimal.Decimal('1.0').__eq__(1) == True — Decimal('1.0') == 1 is True; int operand used; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["1.0"]
  method: __eq__
  method_args: [1]
  expected: true

invariant decimal_extra224.Decimal.ne_true:
  description: "decimal.Decimal('1.5').__ne__(1) == True — Decimal('1.5') != 1 is True; int operand used; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: __ne__
  method_args: [1]
  expected: true

invariant decimal_extra224.Decimal.gt_false:
  description: "decimal.Decimal('1.0').__gt__(2) == False — Decimal('1.0') > 2 is False; int operand used; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["1.0"]
  method: __gt__
  method_args: [2]
  expected: false

# ---------------------------------------------------------------------------
# decimal.Decimal quantize rounding behavioral contracts
# Default rounding mode is ROUND_HALF_EVEN (banker's rounding).
# 3.14159 quantized to 0.01 -> '3.14'.
# 1.005 quantized to 0.01 -> '1.00' (banker's rounding rounds to even 0).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra224.Decimal.quantize_pi:
  description: "decimal.Decimal('3.14159').quantize(Decimal('0.01')) str == '3.14' — quantize to 2 decimal places rounds 3.14159 to 3.14; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["3.14159"]
  method: quantize
  method_args: ["0.01"]
  method_chain: __str__
  expected: "3.14"

invariant decimal_extra224.Decimal.quantize_bankers_1005:
  description: "decimal.Decimal('1.005').quantize(Decimal('0.01')) str == '1.00' — banker's rounding ROUND_HALF_EVEN: 1.005 rounds to 1.00 (nearest even at 2 decimal places is .00); verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["1.005"]
  method: quantize
  method_args: ["0.01"]
  method_chain: __str__
  expected: "1.00"

invariant decimal_extra224.Decimal.quantize_1015:
  description: "decimal.Decimal('1.015').quantize(Decimal('0.01')) str == '1.02' — banker's rounding ROUND_HALF_EVEN: 1.015 rounds to 1.02 (nearest even at 2 decimal places is .02); verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["1.015"]
  method: quantize
  method_args: ["0.01"]
  method_chain: __str__
  expected: "1.02"

# ---------------------------------------------------------------------------
# decimal.Decimal to_integral_value banker's rounding behavioral contracts
# Default rounding mode is ROUND_HALF_EVEN (banker's rounding).
# 2.5 -> '2' (rounds to even 2); 1.5 -> '2' (rounds to even 2).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra224.Decimal.to_integral_2_5:
  description: "decimal.Decimal('2.5').to_integral_value() str == '2' — banker's rounding: 2.5 is halfway between 2 and 3; nearest even integer is 2; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["2.5"]
  method: to_integral_value
  method_args: []
  method_chain: __str__
  expected: "2"

invariant decimal_extra224.Decimal.to_integral_1_5:
  description: "decimal.Decimal('1.5').to_integral_value() str == '2' — banker's rounding: 1.5 is halfway between 1 and 2; nearest even integer is 2; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["1.5"]
  method: to_integral_value
  method_args: []
  method_chain: __str__
  expected: "2"

# ---------------------------------------------------------------------------
# decimal.Decimal as_tuple behavioral contracts
# as_tuple returns a DecimalTuple named tuple with fields: sign, digits, exponent.
# Positive numbers have sign == 0; negative numbers have sign == 1.
# Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant decimal_extra224.Decimal.as_tuple_class_name:
  description: "decimal.Decimal('1.23').as_tuple().__class__.__name__ == 'DecimalTuple' — as_tuple returns a named tuple of type DecimalTuple; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["1.23"]
  method: as_tuple().__class__.__name__.__eq__
  method_args: ["DecimalTuple"]
  expected: true

invariant decimal_extra224.Decimal.as_tuple_sign_positive:
  description: "decimal.Decimal('1.23').as_tuple().sign == 0 — positive Decimal has sign field 0 in DecimalTuple; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["1.23"]
  method: as_tuple().sign.__eq__
  method_args: [0]
  expected: true

invariant decimal_extra224.Decimal.as_tuple_sign_negative:
  description: "decimal.Decimal('-3').as_tuple().sign == 1 — negative Decimal has sign field 1 in DecimalTuple; verified Python 3.14.3 macOS"
  category: behavioral
  kind: python_call_eq
  function: Decimal
  args: ["-3"]
  method: as_tuple().sign.__eq__
  method_args: [1]
  expected: true
