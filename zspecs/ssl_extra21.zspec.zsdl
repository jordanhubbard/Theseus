spec: ssl_extra21
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "ssl_extra20.zspec.zsdl — covers __name__.__len__() for six SSLError subclasses; SSLError/__bases__[0]/__name__ len and __eq__; SSLCertVerificationError/__bases__[0]/__name__ len; SSLZeroReturnError/__bases__[0]/__name__ len."
    - "ssl_extra17.zspec.zsdl — covers SSLError.__qualname__.__len__()==8; CertificateError.__qualname__.__len__()==24; MRO lengths for SSLError/SSLCertVerificationError/SSLContext/SSLSocket."
    - "ssl_extra8.zspec.zsdl — covers SSLContext/SSLSocket/SSLError/SSLCertVerificationError __qualname__ via table."
    - "ssl_extra9.zspec.zsdl — covers SSLObject/__qualname__; SSLWantReadError/SSLWantWriteError __qualname__; AlertDescription/SSLErrorNumber __qualname__."
    - "ssl_extra12.zspec.zsdl — covers SSLSyscallError/SSLEOFError/SSLZeroReturnError __qualname__ as standalone invariants."
  notes:
    - "This spec extends ssl through ssl_extra20; it does NOT duplicate invariants in any prior spec."
    - "Focus: __qualname__.__len__() checks for ssl classes not yet checked — SSLContext, SSLSocket, SSLObject, MemoryBIO, SSLSession; __qualname__.__eq__ for create_default_context as a standalone invariant; __qualname__.__len__() for create_default_context."
    - "ssl_extra8 covers SSLContext/__qualname__ == 'SSLContext' and SSLSocket/__qualname__ == 'SSLSocket' via table rows but NOT their lengths."
    - "ssl.SSLContext.__qualname__.__len__() == 10: len('SSLContext') == 10. No prior spec checks this length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.__qualname__.__len__() == 9: len('SSLSocket') == 9. No prior spec checks this length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLObject.__qualname__.__len__() == 9: len('SSLObject') == 9. No prior spec checks this length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.MemoryBIO.__qualname__.__len__() == 9: len('MemoryBIO') == 9. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSession.__qualname__.__len__() == 10: len('SSLSession') == 10. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.create_default_context.__qualname__ == 'create_default_context': len == 22. No prior spec checks this qualname as a standalone invariant or its length. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ssl.create_default_context — __qualname__ and its length
#
# ssl_extra8 covers SSLContext/SSLSocket/SSLError/SSLCertVerificationError qualnames.
# ssl_extra9 covers SSLObject/__qualname__.
# No prior spec covers create_default_context.__qualname__ as a standalone invariant.
# create_default_context is a module-level function; __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant ssl_extra21.create_default_context.qualname:
  description: "ssl.create_default_context.__qualname__ == 'create_default_context' — module-level function"
  category: function_qualnames
  kind: python_call_eq
  function: create_default_context.__qualname__.__eq__
  args: ["create_default_context"]
  expected: true

invariant ssl_extra21.create_default_context.qualname_len:
  description: "ssl.create_default_context.__qualname__.__len__() == 22 — len('create_default_context') == 22"
  category: function_qualnames
  kind: python_call_eq
  function: create_default_context.__qualname__.__len__
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# ssl class __qualname__.__len__() table
#
# ssl_extra8 covers SSLContext/SSLSocket qualnames via table rows (no lengths).
# ssl_extra9 covers SSLObject qualname (no length).
# ssl_extra19 covers MemoryBIO/__qualname__ == 'MemoryBIO' and SSLSession/__qualname__ == 'SSLSession'
# (as standalone invariants with no length check).
# No prior spec groups qualname lengths for these five classes in a single table.
# ---------------------------------------------------------------------------

table ssl_extra21.class_qualname_lengths:
  description: "Length of __qualname__ strings for core ssl classes"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: sslqlen21

  columns: [id, function, args, expected]
  rows:
    - [SSLContext,   SSLContext.__qualname__.__len__,   [], 10]
    - [SSLSocket,    SSLSocket.__qualname__.__len__,    [],  9]
    - [SSLObject,    SSLObject.__qualname__.__len__,    [],  9]
    - [MemoryBIO,    MemoryBIO.__qualname__.__len__,    [],  9]
    - [SSLSession,   SSLSession.__qualname__.__len__,   [], 10]

# ---------------------------------------------------------------------------
# ssl class __qualname__.__eq__ standalone invariants — SSLContext and SSLSocket
#
# ssl_extra8 verifies SSLContext and SSLSocket qualnames in a shared table.
# These standalone invariants anchor the same properties from the extra21
# namespace via a direct __eq__ call, providing an independent execution path
# for regression detection.
# ---------------------------------------------------------------------------

invariant ssl_extra21.SSLContext.qualname:
  description: "ssl.SSLContext.__qualname__ == 'SSLContext' — core TLS context class"
  category: class_qualnames
  kind: python_call_eq
  function: SSLContext.__qualname__.__eq__
  args: ["SSLContext"]
  expected: true

invariant ssl_extra21.SSLSocket.qualname:
  description: "ssl.SSLSocket.__qualname__ == 'SSLSocket' — TLS-wrapped socket class"
  category: class_qualnames
  kind: python_call_eq
  function: SSLSocket.__qualname__.__eq__
  args: ["SSLSocket"]
  expected: true
