spec: struct_extra452
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct format character native sizes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "calcsize uses standard mode (no prefix) which returns native sizes; values shown are for LP64 platforms"
    - "'l' (long) is 4 bytes in standard size mode regardless of platform word size"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

invariant struct_extra452.calcsize_b:
  description: "signed byte is 1 byte"
  kind: python_call_eq
  function: struct.calcsize
  args: ["b"]
  method: __eq__
  method_args: [1]
  expected: true

invariant struct_extra452.calcsize_B:
  description: "unsigned byte is 1 byte"
  kind: python_call_eq
  function: struct.calcsize
  args: ["B"]
  method: __eq__
  method_args: [1]
  expected: true

invariant struct_extra452.calcsize_h:
  description: "signed short is 2 bytes"
  kind: python_call_eq
  function: struct.calcsize
  args: ["h"]
  method: __eq__
  method_args: [2]
  expected: true

invariant struct_extra452.calcsize_H:
  description: "unsigned short is 2 bytes"
  kind: python_call_eq
  function: struct.calcsize
  args: ["H"]
  method: __eq__
  method_args: [2]
  expected: true

invariant struct_extra452.calcsize_i:
  description: "signed int is 4 bytes"
  kind: python_call_eq
  function: struct.calcsize
  args: ["i"]
  method: __eq__
  method_args: [4]
  expected: true

invariant struct_extra452.calcsize_I:
  description: "unsigned int is 4 bytes"
  kind: python_call_eq
  function: struct.calcsize
  args: ["I"]
  method: __eq__
  method_args: [4]
  expected: true

invariant struct_extra452.calcsize_l:
  description: "signed long is 4 bytes in standard size mode"
  kind: python_call_eq
  function: struct.calcsize
  args: ["l"]
  method: __eq__
  method_args: [4]
  expected: true

invariant struct_extra452.calcsize_q:
  description: "signed long long is 8 bytes"
  kind: python_call_eq
  function: struct.calcsize
  args: ["q"]
  method: __eq__
  method_args: [8]
  expected: true

invariant struct_extra452.calcsize_Q:
  description: "unsigned long long is 8 bytes"
  kind: python_call_eq
  function: struct.calcsize
  args: ["Q"]
  method: __eq__
  method_args: [8]
  expected: true

invariant struct_extra452.calcsize_f:
  description: "float is 4 bytes"
  kind: python_call_eq
  function: struct.calcsize
  args: ["f"]
  method: __eq__
  method_args: [4]
  expected: true

invariant struct_extra452.calcsize_d:
  description: "double is 8 bytes"
  kind: python_call_eq
  function: struct.calcsize
  args: ["d"]
  method: __eq__
  method_args: [8]
  expected: true
