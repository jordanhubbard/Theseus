spec: flatted
version: ">=3.0.0"
backend: node(flatted)

docs: https://github.com/WebReflection/flatted#readme

provenance:
  derived_from:
    - "flatted README — https://github.com/WebReflection/flatted#readme"
    - "Test vectors verified with flatted@3.4.2 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "flatted source: esm/index.js"
  notes:
    - "flatted exports an object with stringify() and parse() methods."
    - "stringify() wraps the value in an array to handle circular references."
    - "A plain object {a:1} stringifies to '[{\"a\":1}]' (outer array wrapper)."
    - "parse(stringify(value)) round-trips correctly for non-circular values."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "stringify returns string; parse returns value. No errors for non-circular inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table flatted.stringify:
  kind: node_module_call_eq
  function: stringify
  category: stringify
  id_prefix: flat_str

  columns: [id, args, expected]
  rows:
    - [object,  [{"a": 1}],    "[{\"a\":1}]"]
    - [array,   [[1, 2, 3]],   "[[1,2,3]]"]
    - [number,  [42],          "[42]"]

table flatted.parse:
  kind: node_module_call_eq
  function: parse
  category: parse
  id_prefix: flat_parse

  columns: [id, args, expected]
  rows:
    - [object,  ["[{\"a\":1}]"],    {"a": 1}]
    - [array,   ["[[1,2,3]]"],      [1, 2, 3]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:15:43Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
