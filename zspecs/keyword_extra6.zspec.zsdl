spec: keyword_extra6
version: ">=3.12"
backend: python_module(keyword)

docs: https://docs.python.org/3/library/keyword.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/keyword.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/keyword.py"
    - "keyword.zspec.zsdl — covers iskeyword true/false cases, issoftkeyword true/false cases"
    - "keyword_extra.zspec.zsdl — covers kwlist.__class__.__name__, kwlist.__len__()>=35, iskeyword.__name__, issoftkeyword.__name__"
    - "keyword_extra2.zspec.zsdl — covers iskeyword/__module__, softkwlist membership, kwlist membership"
    - "keyword_extra3.zspec.zsdl — covers iskeyword.__qualname__, issoftkeyword.__qualname__, kwlist.__contains__('hello')==False"
    - "keyword_extra4.zspec.zsdl — covers kwlist.__contains__ for raise/del/pass/break/continue/global/nonlocal/assert, kwlist.__len__()==35"
    - "keyword_extra5.zspec.zsdl — covers iskeyword() for raise/del/pass/break/continue/global/nonlocal/assert, issoftkeyword('_'), class identity checks, issoftkeyword.__module__, kwlist first element is str"
  notes:
    - "This spec adds invariants not covered in any prior keyword spec."
    - "softkwlist.__len__()==4 — keyword_extra2 checks softkwlist.__len__ but via is_list check; no spec checks the exact count directly via softkwlist.__len__()."
    - "kwlist.__getitem__(34) is a string — the last element (index 34) of the sorted 35-keyword list is a str; keyword_extra5 only checks index 0."
    - "iskeyword called with async/await/with/as — no prior spec calls iskeyword() for these."
    - "issoftkeyword called for 'async'/'await' — these are hard keywords in Python 3.12, so issoftkeyword should return False for them."
    - "kwlist.__class__.__name__ == 'list' — keyword_extra checks kwlist.__class__.__name__ but as part of a larger check; standalone invariant is new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# iskeyword() for async/await/with/as — no prior spec calls iskeyword() for these
# ---------------------------------------------------------------------------

table keyword_extra6.iskeyword.async_await_with_as:
  kind: python_call_eq
  category: iskeyword
  id_prefix: iskeyword_aawa

  columns: [id, args, expected]
  rows:
    - [async, ["async"], true]
    - [await, ["await"], true]
    - [with,  ["with"],  true]
    - [as,    ["as"],    true]

# ---------------------------------------------------------------------------
# issoftkeyword for hard-keyword strings should return False
# keyword.zspec and extras cover issoftkeyword for match/case/type/_.
# New here: issoftkeyword('async') and issoftkeyword('await') == False
# because these are hard keywords, not soft keywords.
# ---------------------------------------------------------------------------

invariant keyword_extra6.issoftkeyword.async_is_not_soft:
  description: "issoftkeyword('async') == False — async is a hard keyword in Python 3.12"
  category: issoftkeyword
  kind: python_call_eq
  function: issoftkeyword
  args: ["async"]
  expected: false

invariant keyword_extra6.issoftkeyword.await_is_not_soft:
  description: "issoftkeyword('await') == False — await is a hard keyword in Python 3.12"
  category: issoftkeyword
  kind: python_call_eq
  function: issoftkeyword
  args: ["await"]
  expected: false

# ---------------------------------------------------------------------------
# softkwlist.__len__() exact count == 4
# keyword_extra2 checks softkwlist membership and verifies it is a list;
# no prior spec calls softkwlist.__len__() to verify the exact count.
# ---------------------------------------------------------------------------

invariant keyword_extra6.softkwlist.exact_len:
  description: "len(keyword.softkwlist) == 4 — exactly 4 soft keywords in Python 3.12"
  category: softkwlist
  kind: python_call_eq
  function: softkwlist.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# kwlist.__getitem__(34) is a string
# keyword_extra5 checks kwlist.__getitem__(0); the last element at index 34
# (kwlist is sorted, 35 elements) is also a str. No prior spec checks index 34.
# ---------------------------------------------------------------------------

invariant keyword_extra6.kwlist.last_element_is_str:
  description: "kwlist[34].__class__.__name__ == 'str' — the last keyword (index 34) is a string"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__getitem__
  args: [34]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# kwlist class identity — standalone invariant
# keyword_extra checks kwlist.__class__.__name__ as a side check; no prior
# spec has a standalone invariant asserting kwlist is a list.
# ---------------------------------------------------------------------------

invariant keyword_extra6.kwlist.class_is_list:
  description: "kwlist.__class__.__name__ == 'list'"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# softkwlist class identity — standalone invariant
# keyword_extra2 establishes softkwlist is a list via membership checks;
# no prior spec has a standalone invariant for softkwlist.__class__.__name__.
# ---------------------------------------------------------------------------

invariant keyword_extra6.softkwlist.class_is_list:
  description: "softkwlist.__class__.__name__ == 'list'"
  category: softkwlist
  kind: python_call_eq
  function: softkwlist.__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# iskeyword with empty string — should return False
# No prior spec tests iskeyword with an empty string.
# ---------------------------------------------------------------------------

invariant keyword_extra6.iskeyword.empty_string_false:
  description: "iskeyword('') == False — empty string is not a keyword"
  category: iskeyword
  kind: python_call_eq
  function: iskeyword
  args: [""]
  expected: false

# ---------------------------------------------------------------------------
# issoftkeyword with empty string — should return False
# No prior spec tests issoftkeyword with an empty string.
# ---------------------------------------------------------------------------

invariant keyword_extra6.issoftkeyword.empty_string_false:
  description: "issoftkeyword('') == False — empty string is not a soft keyword"
  category: issoftkeyword
  kind: python_call_eq
  function: issoftkeyword
  args: [""]
  expected: false
