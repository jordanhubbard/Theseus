spec: itertools_extra83
version: ">=3.10"
backend: python_module(itertools)
extends: itertools_extra82

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra82.zspec.zsdl."
    - "This spec covers: itertools C type __module__ values — all 16 types have __module__ == 'itertools' (Wave 247)."
    - "count.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "cycle.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "repeat.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "accumulate.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "chain.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "compress.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "dropwhile.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "filterfalse.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "groupby.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "islice.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "pairwise.__module__ == 'itertools' — C extension type added in Python 3.10; module attribute. Verified with Python 3.14.3."
    - "permutations.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "product.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "starmap.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "takewhile.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "zip_longest.__module__ == 'itertools' — C extension type; module attribute. Verified with Python 3.14.3."
    - "version set to >=3.10 because pairwise was added in Python 3.10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# count/cycle/repeat/accumulate __module__ == 'itertools' — extra83
#
# Wave 247 theme: all itertools C types have __module__ == 'itertools'.
#
# itertools.count.__module__       == 'itertools'
# itertools.cycle.__module__       == 'itertools'
# itertools.repeat.__module__      == 'itertools'
# itertools.accumulate.__module__  == 'itertools'
#
# No prior itertools spec checks count/cycle/repeat/accumulate __module__ via itrtoolsextra83. New to extra83.
# ---------------------------------------------------------------------------

table itertools_extra83.module_group1:
  description: "count/cycle/repeat/accumulate __module__=='itertools'; wave 247 itertools C type __module__ values; new to extra83"
  kind: python_call_eq
  category: type_identity
  id_prefix: itrtoolsextra83

  columns: [id, function, args, expected, description]
  rows:
    - [count_module_eq_itertools,
       count.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — count is a C extension type defined in Modules/itertoolsmodule.c; its __module__ attribute records 'itertools' (9 chars) — the module where it is exposed; str.__eq__('itertools') returns True; no prior itertools spec checks count.__module__ via itrtoolsextra83; new to extra83"]
    - [cycle_module_eq_itertools,
       cycle.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.cycle.__module__.__eq__('itertools') == True — cycle is a C extension type defined in Modules/itertoolsmodule.c; its __module__ attribute records 'itertools' (9 chars); str.__eq__('itertools') returns True; no prior itertools spec checks cycle.__module__ via itrtoolsextra83; new to extra83"]
    - [repeat_module_eq_itertools,
       repeat.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.repeat.__module__.__eq__('itertools') == True — repeat is a C extension type defined in Modules/itertoolsmodule.c; its __module__ attribute records 'itertools' (9 chars); str.__eq__('itertools') returns True; no prior itertools spec checks repeat.__module__ via itrtoolsextra83; new to extra83"]
    - [accumulate_module_eq_itertools,
       accumulate.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.accumulate.__module__.__eq__('itertools') == True — accumulate is a C extension type defined in Modules/itertoolsmodule.c; its __module__ attribute records 'itertools' (9 chars); str.__eq__('itertools') returns True; no prior itertools spec checks accumulate.__module__ via itrtoolsextra83; new to extra83"]

