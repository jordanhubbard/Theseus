spec: struct_extra1981
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#object.__sizeof__"
    - "https://docs.python.org/3/reference/datamodel.html#object.__length_hint__"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "struct.Struct DOES define __sizeof__ in its own dict for accurate C-level memory reporting."
    - "struct.error does not define __sizeof__ in its own dict — it is an Exception subclass."
    - "Neither struct.Struct nor struct.error define __length_hint__ — they are not iterators."
    - "The _struct.unpack_iterator type (returned by struct.iter_unpack) DOES define __length_hint__ in its own dict."
    - "None of the struct types define __floor__, __ceil__, or __trunc__ — struct is not a numeric type."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra1981.sizeof_protocol:
  description: "struct types __sizeof__ dict-presence checks — struct.Struct defines it; struct.error does not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1981
  columns: [id, function, args, expected]
  rows:
    - ["st1981001", "struct.Struct.__dict__.__contains__", ["__sizeof__"], true]
    - ["st1981002", "struct.error.__dict__.__contains__",  ["__sizeof__"], false]

table struct_extra1981.length_hint_protocol:
  description: "struct types __length_hint__ dict-presence checks — none define __length_hint__ in own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1981
  columns: [id, function, args, expected]
  rows:
    - ["st1981003", "struct.Struct.__dict__.__contains__", ["__length_hint__"], false]
    - ["st1981004", "struct.error.__dict__.__contains__",  ["__length_hint__"], false]

