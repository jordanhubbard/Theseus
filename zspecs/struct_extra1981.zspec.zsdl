  rows:
    - ["st1981009", "struct.Struct.__dict__.__contains__", ["__trunc__"], false]
    - ["st1981010", "struct.error.__dict__.__contains__",  ["__trunc__"], false]

table struct_extra1981.struct_all_memory_math_attrs:
  description: "struct.Struct — __sizeof__ present; __length_hint__/__floor__/__ceil__/__trunc__ absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1981
  columns: [id, function, args, expected]
  rows:
    - ["st1981011", "struct.Struct.__dict__.__contains__", ["__sizeof__"],      true]
    - ["st1981012", "struct.Struct.__dict__.__contains__", ["__length_hint__"], false]
    - ["st1981013", "struct.Struct.__dict__.__contains__", ["__floor__"],       false]
    - ["st1981014", "struct.Struct.__dict__.__contains__", ["__ceil__"],        false]
    - ["st1981015", "struct.Struct.__dict__.__contains__", ["__trunc__"],       false]

table struct_extra1981.error_all_memory_math_attrs:
  description: "struct.error — all five memory/math protocol attrs absent from own dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1981
  columns: [id, function, args, expected]
  rows:
    - ["st1981016", "struct.error.__dict__.__contains__", ["__sizeof__"],      false]
    - ["st1981017", "struct.error.__dict__.__contains__", ["__length_hint__"], false]
    - ["st1981018", "struct.error.__dict__.__contains__", ["__floor__"],       false]
    - ["st1981019", "struct.error.__dict__.__contains__", ["__ceil__"],        false]
    - ["st1981020", "struct.error.__dict__.__contains__", ["__trunc__"],       false]

table struct_extra1981.struct_cross_protocol_summary:
  description: "struct types cross-protocol summary — struct.Struct defines only __sizeof__; struct.error defines none"
  kind: python_call_eq
  category: dict_contains
