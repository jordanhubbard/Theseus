  columns: [id, function, args, expected]
  rows:
    - ["st1981021", "struct.Struct.__dict__.__contains__", ["__sizeof__"],      true]
    - ["st1981022", "struct.Struct.__dict__.__contains__", ["__length_hint__"], false]
    - ["st1981023", "struct.Struct.__dict__.__contains__", ["__floor__"],       false]
    - ["st1981024", "struct.Struct.__dict__.__contains__", ["__ceil__"],        false]
    - ["st1981025", "struct.Struct.__dict__.__contains__", ["__trunc__"],       false]
    - ["st1981026", "struct.error.__dict__.__contains__",  ["__sizeof__"],      false]
    - ["st1981027", "struct.error.__dict__.__contains__",  ["__length_hint__"], false]
    - ["st1981028", "struct.error.__dict__.__contains__",  ["__floor__"],       false]
    - ["st1981029", "struct.error.__dict__.__contains__",  ["__ceil__"],        false]
    - ["st1981030", "struct.error.__dict__.__contains__",  ["__trunc__"],       false]
