spec: functools_extra78
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra77.zspec.zsdl."
    - "Wave 239 theme: functools partial class deeper introspection."
    - "partial.__name__ == 'partial' — partial is a C extension type in _functoolsmodule.c; its __name__ is the string 'partial'. Verified with Python 3.14.3."
    - "partial.__module__ == 'functools' — partial's __module__ attribute is 'functools'. Verified with Python 3.14.3."
    - "partial.__qualname__ == 'partial' — partial is a top-level C type; its __qualname__ equals its simple name. Verified with Python 3.14.3."
    - "partial.__doc__.__class__.__name__ == 'str' — partial has a str docstring. Verified with Python 3.14.3."
    - "partial.__doc__.__contains__('partial') == True — the partial docstring reads 'Create a new function with partial application of the given arguments and keywords.' and contains the word 'partial'. Verified with Python 3.14.3."
    - "partial.__dict__.__class__.__name__ == 'mappingproxy' — partial is a C extension type so its __dict__ is a mappingproxy. Verified with Python 3.14.3."
    - "partial.__dict__.__contains__('__doc__') == True — the mappingproxy for partial contains the key '__doc__'. Verified with Python 3.14.3."
    - "partial.__mro__.__len__() == 2 — partial inherits directly from object; MRO is [partial, object]. Verified with Python 3.14.3."
    - "partial.__bases__[0].__name__ == 'object' — partial's only base class is object. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# partial class identity — extra78
#
# Wave 239 theme: partial.__name__, __module__, __qualname__.
#
# functools.partial is a C extension type defined in Modules/_functoolsmodule.c.
# partial.__name__     == 'partial'
# partial.__module__   == 'functools'
# partial.__qualname__ == 'partial'
#
# No prior functools spec checks partial class identity via functoolsmore78. New to extra78.
# ---------------------------------------------------------------------------

table functools_extra78.partial_identity:
  description: "partial.__name__=='partial', __module__=='functools', __qualname__=='partial'; wave 239 partial class identity; new to extra78"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore78

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq_partial,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is a C extension type in Modules/_functoolsmodule.c; its __name__ attribute stores the class name as a str 'partial' (7 chars); str.__eq__('partial') returns True; no prior functools spec checks partial.__name__ via functoolsmore78; new to extra78"]
    - [partial_module_eq_functools,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial is a C extension type defined in _functoolsmodule.c and exposed in the functools package; its __module__ attribute records the module name as the str 'functools' (9 chars); str.__eq__('functools') returns True; no prior functools spec checks partial.__module__ via functoolsmore78; new to extra78"]
    - [partial_qualname_eq_partial,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — partial is a top-level C extension type (not nested inside another class or function); __qualname__ for a top-level class equals its simple name 'partial' (7 chars); str.__eq__('partial') returns True; no prior functools spec checks partial.__qualname__ via functoolsmore78; new to extra78"]

# ---------------------------------------------------------------------------
# partial __doc__ content — extra78
#
# Wave 239 theme: partial docstring is a str and contains 'partial'.
#
# partial.__doc__.__class__.__name__ == 'str'
# partial.__doc__.__contains__('partial') == True
#   The docstring reads: 'Create a new function with partial application
#   of the given arguments and keywords.'
#
# No prior functools spec checks partial.__doc__ content via functoolsmore78. New to extra78.
# ---------------------------------------------------------------------------

table functools_extra78.partial_doc:
  description: "partial.__doc__.__class__.__name__=='str', __contains__('partial')==True; wave 239 partial __doc__; new to extra78"
  kind: python_call_eq
  category: type_doc
  id_prefix: functoolsmore78

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_class_name_eq_str,
       partial.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — partial is a C extension type in _functoolsmodule.c; its tp_doc slot docstring is accessible as __doc__ and is a Python str object; str.__name__ == 'str' (3 chars); str.__eq__('str') returns True; no prior functools spec checks partial.__doc__.__class__.__name__ via functoolsmore78; new to extra78"]
    - [partial_doc_contains_partial,
       partial.__doc__.__contains__,
       ["partial"],
       true,
       "functools.partial.__doc__.__contains__('partial') == True — the partial docstring reads 'Create a new function with partial application of the given arguments and keywords.' and contains the word 'partial' (7 chars) in 'partial application'; str.__contains__('partial') returns True; no prior functools spec checks partial.__doc__.__contains__ via functoolsmore78; new to extra78"]

# ---------------------------------------------------------------------------
# partial __dict__ — extra78
#
# Wave 239 theme: partial.__dict__ is a mappingproxy containing '__doc__'.
#
# partial.__dict__.__class__.__name__    == 'mappingproxy'
# partial.__dict__.__contains__('__doc__') == True
#
# No prior functools spec checks partial.__dict__ via functoolsmore78. New to extra78.
# ---------------------------------------------------------------------------

table functools_extra78.partial_dict:
  description: "partial.__dict__.__class__.__name__=='mappingproxy', __contains__('__doc__')==True; wave 239 partial __dict__; new to extra78"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore78

  columns: [id, function, args, expected, description]
  rows:
    - [partial_dict_class_name_eq_mappingproxy,
       partial.__dict__.__class__.__name__.__eq__,
       ["mappingproxy"],
       true,
       "functools.partial.__dict__.__class__.__name__.__eq__('mappingproxy') == True — partial is a C extension type so its __dict__ attribute is a types.MappingProxyType object (a read-only view of the type's namespace); mappingproxy.__name__ == 'mappingproxy' (12 chars); str.__eq__('mappingproxy') returns True; no prior functools spec checks partial.__dict__.__class__.__name__ via functoolsmore78; new to extra78"]
    - [partial_dict_contains_doc,
       partial.__dict__.__contains__,
       ["__doc__"],
       true,
       "functools.partial.__dict__.__contains__('__doc__') == True — partial's type namespace (its __dict__ mappingproxy) contains the key '__doc__' which holds the type's docstring; mappingproxy.__contains__('__doc__') returns True; no prior functools spec checks partial.__dict__.__contains__ via functoolsmore78; new to extra78"]

# ---------------------------------------------------------------------------
# partial MRO and base class — extra78
#
# Wave 239 theme: partial MRO is [partial, object] with length 2.
#
# partial.__mro__.__len__()     == 2
# partial.__bases__[0].__name__ == 'object'
#
# No prior functools spec checks partial MRO via functoolsmore78. New to extra78.
# ---------------------------------------------------------------------------

table functools_extra78.partial_mro:
  description: "partial.__mro__.__len__()==2, partial.__bases__[0].__name__=='object'; wave 239 partial MRO; new to extra78"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsmore78

  columns: [id, function, args, expected, description]
  rows:
    - [partial_mro_len_eq_2,
       partial.__mro__.__len__,
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — partial is a C extension type that inherits directly from object with no intermediate base classes; the MRO is therefore [partial, object] with exactly 2 entries; tuple.__len__() returns 2; no prior functools spec checks partial.__mro__.__len__ via functoolsmore78; new to extra78"]
    - [partial_bases0_name_eq_object,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — partial inherits directly from object; __bases__ is a tuple of direct base classes and __bases__[0] is object; object.__name__ == 'object' (6 chars); str.__eq__('object') returns True; no prior functools spec checks partial.__bases__[0].__name__ via functoolsmore78; new to extra78"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra78
# ---------------------------------------------------------------------------

invariant functools_extra78.partial_name:
  description: "functools.partial.__name__.__eq__('partial') == True — partial class name is 'partial'; wave 239 partial class identity; new to extra78"
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra78.partial_module:
  description: "functools.partial.__module__.__eq__('functools') == True — partial.__module__ is 'functools'; wave 239 partial class identity; new to extra78"
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra78.partial_doc_contains_partial:
  description: "functools.partial.__doc__.__contains__('partial') == True — 'partial' appears in the partial docstring via 'partial application'; wave 239 partial __doc__; new to extra78"
  kind: python_call_eq
  function: partial.__doc__.__contains__
  args: ["partial"]
  expected: true

invariant functools_extra78.partial_dict_mappingproxy:
  description: "functools.partial.__dict__.__class__.__name__.__eq__('mappingproxy') == True — partial.__dict__ is a mappingproxy; wave 239 partial __dict__; new to extra78"
  kind: python_call_eq
  function: partial.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant functools_extra78.partial_mro_len:
  description: "functools.partial.__mro__.__len__() == 2 — partial MRO is [partial, object] with 2 entries; wave 239 partial MRO; new to extra78"
  kind: python_call_eq
  function: partial.__mro__.__len__
  args: []
  expected: 2
