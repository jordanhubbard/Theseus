spec: struct_extra2641
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 623: checks struct.Struct and struct.error __dict__ for __copy__, __deepcopy__, __sizeof__ presence. struct.Struct.__sizeof__ is True (Struct defines __sizeof__ in its own __dict__); all others are False. struct.error.__sizeof__ is False."]
  created_at: "2026-04-13"
error_model: python_exceptions

table struct_extra2641.Struct_dict_presence:
  description: "struct.Struct __dict__ presence: __copy__=false, __deepcopy__=false, __sizeof__=true (Struct defines __sizeof__ in its own __dict__)"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2641sd
  columns: [id, function, args, expected]
  rows:
    - ["st2641sd001", struct.Struct.__dict__.__contains__, ["__copy__"],     false]
    - ["st2641sd002", struct.Struct.__dict__.__contains__, ["__deepcopy__"], false]
    - ["st2641sd003", struct.Struct.__dict__.__contains__, ["__sizeof__"],   true]

table struct_extra2641.error_dict_presence:
  description: "struct.error __dict__ does not contain __copy__, __deepcopy__, or __sizeof__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2641ed
  columns: [id, function, args, expected]
  rows:
    - ["st2641ed001", struct.error.__dict__.__contains__, ["__copy__"],     false]
    - ["st2641ed002", struct.error.__dict__.__contains__, ["__deepcopy__"], false]
    - ["st2641ed003", struct.error.__dict__.__contains__, ["__sizeof__"],   false]

table struct_extra2641.Struct_error_cross:
  description: "Cross-checks: struct.Struct and struct.error __dict__ presence for __copy__, __deepcopy__, __sizeof__; Struct.__sizeof__=true is the unique positive result in this spec"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2641cx
  columns: [id, function, args, expected]
  rows:
    - ["st2641cx001", struct.Struct.__dict__.__contains__, ["__copy__"],     false]
    - ["st2641cx002", struct.error.__dict__.__contains__,  ["__deepcopy__"], false]
    - ["st2641cx003", struct.Struct.__dict__.__contains__, ["__sizeof__"],   true]
    - ["st2641cx004", struct.error.__dict__.__contains__,  ["__sizeof__"],   false]
    - ["st2641cx005", struct.Struct.__dict__.__contains__, ["__deepcopy__"], false]
    - ["st2641cx006", struct.error.__dict__.__contains__,  ["__copy__"],     false]

table struct_extra2641.Struct_error_all_dunders:
  description: "Exhaustive: struct.Struct and struct.error __dict__ for all three dunders — full 3x2 coverage; Struct.__sizeof__=true is the only positive"
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2641al
  columns: [id, function, args, expected]
  rows:
    - ["st2641al001", struct.Struct.__dict__.__contains__, ["__copy__"],     false]
    - ["st2641al002", struct.Struct.__dict__.__contains__, ["__deepcopy__"], false]
    - ["st2641al003", struct.Struct.__dict__.__contains__, ["__sizeof__"],   true]
    - ["st2641al004", struct.error.__dict__.__contains__,  ["__copy__"],     false]
    - ["st2641al005", struct.error.__dict__.__contains__,  ["__deepcopy__"], false]
    - ["st2641al006", struct.error.__dict__.__contains__,  ["__sizeof__"],   false]
