table hashlib_extra2671.hash_types_cross:
  description: "Cross-checks: HASH class, blake2b, blake2s __dict__ do not contain __sub__, __floordiv__, __mod__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2671cx
  columns: [id, function, args, expected]
  rows:
    - ["hl2671cx001", hashlib.new("sha256").__class__.__dict__.__contains__, ["__sub__"],      false]
    - ["hl2671cx002", hashlib.blake2b.__dict__.__contains__,                 ["__floordiv__"], false]
    - ["hl2671cx003", hashlib.blake2s.__dict__.__contains__,                 ["__mod__"],      false]
    - ["hl2671cx004", hashlib.new("sha256").__class__.__dict__.__contains__, ["__mod__"],      false]
    - ["hl2671cx005", hashlib.blake2b.__dict__.__contains__,                 ["__mod__"],      false]
    - ["hl2671cx006", hashlib.blake2s.__dict__.__contains__,                 ["__sub__"],      false]
