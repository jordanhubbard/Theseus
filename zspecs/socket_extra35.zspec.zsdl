spec: socket_extra35
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra34.zspec.zsdl — covers socket.socket close/setblocking/getsockname/fileno/detach/shutdown/sendall __name__.__len__()."
    - "socket_extra33.zspec.zsdl — covers htonl/htons/ntohl/ntohs __name__.__len__()==5; create_server/gethostbyname __name__.__len__()==13; socket.__dict__['family'/'type'] descriptor class name len (8)."
    - "socket_extra32.zspec.zsdl — covers recvfrom/sendto/makefile/recvfrom_into/recv_into/connect_ex __qualname__.__len__(); getaddrinfo/getnameinfo/setdefaulttimeout/getdefaulttimeout/create_connection __name__.__len__()."
    - "socket_extra31.zspec.zsdl — covers close/setblocking/getsockname/fileno/detach/shutdown/sendall __qualname__.__len__()."
    - "socket_extra30.zspec.zsdl — covers socket.__all__.__len__()==238; AF_INET/AF_INET6 __class__.__name__=='AddressFamily'; SOCK_STREAM/SOCK_DGRAM __class__.__name__=='SocketKind'."
    - "socket_extra24.zspec.zsdl — covers AddressFamily/__qualname__.__len__()==13; SocketKind/__qualname__.__len__()==10; AF_INET.__class__.__qualname__.__eq__('AddressFamily'); SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind')."
    - "socket_extra16.zspec.zsdl — covers AddressFamily/__name__.__len__()==13; SocketKind/__name__.__len__()==10; AF_INET6/__class__.__name__.__len__()==13; SOCK_DGRAM/__class__.__name__.__len__()==10."
    - "socket_extra5.zspec.zsdl — covers socket.socket/__init__.__name__=='__init__' (string equality check)."
  notes:
    - "This spec extends socket through socket_extra34; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: socket.socket.__init__.__name__=='__init__' via __eq__ (extra5); AddressFamily.__name__.__len__()==13 (extra16); SocketKind.__name__.__len__()==10 (extra16); AddressFamily.__qualname__.__len__()==13 (extra24); SocketKind.__qualname__.__len__()==10 (extra24); AF_INET.__class__.__qualname__.__eq__('AddressFamily') via __eq__ (extra24); SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind') via __eq__ (extra24); AF_INET/__class__.__name__.__len__()==13 (extra30); SOCK_STREAM/__class__.__name__.__len__()==10 (extra30)."
    - "This spec covers: socket.socket.__init__.__qualname__.__len__() (NOVEL — extra5 checks __init__.__name__=='__init__' via __eq__; no prior spec checks __init__.__qualname__.__len__(); socket.socket.__init__.__qualname__ == 'socket.__init__' has 15 chars); socket.socket.__repr__.__qualname__.__len__() (NOVEL — no prior spec checks __repr__.__qualname__.__len__(); 'socket.__repr__' has 15 chars); socket.socket.__enter__.__qualname__.__len__() (NOVEL — no prior spec checks __enter__.__qualname__.__len__(); 'socket.__enter__' has 16 chars); socket.socket.__exit__.__qualname__.__len__() (NOVEL — no prior spec checks __exit__.__qualname__.__len__(); 'socket.__exit__' has 15 chars); socket.AddressFamily.__mro__.__len__() (NOVEL — extra13/extra18 cover herror/gaierror __mro__ items by index; no prior spec checks AddressFamily.__mro__.__len__()==6; AddressFamily MRO: AddressFamily, IntEnum, int, ReprEnum, Enum, object); socket.SocketKind.__mro__.__len__() (NOVEL — same gap; SocketKind MRO is identical depth 6); socket.AF_INET.__class__.__qualname__.__len__() (NOVEL — extra24 covers AF_INET.__class__.__qualname__.__eq__('AddressFamily') via __eq__; no prior spec checks __class__.__qualname__.__len__()==13 for AF_INET); socket.SOCK_STREAM.__class__.__qualname__.__len__() (NOVEL — extra24 covers SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind') via __eq__; no prior spec checks __class__.__qualname__.__len__()==10 for SOCK_STREAM)."
    - "socket.socket.__init__.__qualname__ == 'socket.__init__' (len 15). extra5 checks __init__.__name__=='__init__' via __eq__; no prior spec checks __init__.__qualname__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.__repr__.__qualname__ == 'socket.__repr__' (len 15). No prior spec checks __repr__.__qualname__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.__enter__.__qualname__ == 'socket.__enter__' (len 16). No prior spec checks __enter__.__qualname__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.__exit__.__qualname__ == 'socket.__exit__' (len 15). No prior spec checks __exit__.__qualname__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.AddressFamily.__mro__.__len__() == 6. MRO: (AddressFamily, IntEnum, int, ReprEnum, Enum, object). extra18 covers herror.__mro__ items by index; no prior spec checks AddressFamily.__mro__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.SocketKind.__mro__.__len__() == 6. MRO: (SocketKind, IntEnum, int, ReprEnum, Enum, object). Same depth as AddressFamily. No prior spec checks SocketKind.__mro__.__len__(). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__qualname__.__len__() == 13. extra24 checks AF_INET.__class__.__qualname__.__eq__('AddressFamily') via __eq__; no prior spec checks __class__.__qualname__.__len__() for AF_INET. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__qualname__.__len__() == 10. extra24 checks SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind') via __eq__; no prior spec checks __class__.__qualname__.__len__() for SOCK_STREAM. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket dunder method __qualname__.__len__()
#
# socket.socket.__init__.__qualname__ == 'socket.__init__' (len 15)
# socket.socket.__repr__.__qualname__ == 'socket.__repr__' (len 15)
# socket.socket.__enter__.__qualname__ == 'socket.__enter__' (len 16)
# socket.socket.__exit__.__qualname__ == 'socket.__exit__' (len 15)
#
# extra5 checks socket.socket.__init__.__name__ == '__init__' via __eq__.
# extra31/extra32/extra34 cover __qualname__.__len__() for instance methods
# (close/setblocking/bind/connect/etc.) but none cover the dunder protocol
# methods __init__/__repr__/__enter__/__exit__.
# ---------------------------------------------------------------------------

table socket_extra35.socket_dunder_qualname_lens:
  description: "socket.socket __init__/__repr__/__enter__/__exit__ __qualname__.__len__() — novel; extra5 covers __init__.__name__.__eq__ only; no prior spec checks qualname lens for these dunder methods"
  kind: python_call_eq
  category: function_names
  id_prefix: sdql35

  columns: [id, function, args, expected]
  rows:
    - [init_qualname_len,   "socket.__init__.__qualname__.__len__",   [], 15]
    - [repr_qualname_len,   "socket.__repr__.__qualname__.__len__",   [], 15]
    - [enter_qualname_len,  "socket.__enter__.__qualname__.__len__",  [], 16]
    - [exit_qualname_len,   "socket.__exit__.__qualname__.__len__",   [], 15]

# ---------------------------------------------------------------------------
# AddressFamily and SocketKind __mro__.__len__()
#
# Both AddressFamily and SocketKind are IntEnum subclasses with MRO depth 6:
#   (AddressFamily/SocketKind, IntEnum, int, ReprEnum, Enum, object)
#
# extra13/extra18 cover herror/gaierror __mro__ items by index (not __len__()).
# No prior spec checks AddressFamily.__mro__.__len__() or SocketKind.__mro__.__len__().
# ---------------------------------------------------------------------------

table socket_extra35.enum_mro_lens:
  description: "socket.AddressFamily/SocketKind __mro__.__len__()==6 — IntEnum subclass MRO depth 6; novel: no prior spec checks AddressFamily or SocketKind __mro__.__len__()"
  kind: python_call_eq
  category: class_introspection
  id_prefix: emrol35

  columns: [id, function, args, expected]
  rows:
    - [AddressFamily_mro_len, AddressFamily.__mro__.__len__, [], 6]
    - [SocketKind_mro_len,    SocketKind.__mro__.__len__,    [], 6]

# ---------------------------------------------------------------------------
# AF_INET and SOCK_STREAM __class__.__qualname__.__len__()
#
# AF_INET.__class__.__qualname__ == 'AddressFamily' (len 13)
# SOCK_STREAM.__class__.__qualname__ == 'SocketKind' (len 10)
#
# extra24 checks AF_INET.__class__.__qualname__.__eq__('AddressFamily') and
# SOCK_STREAM.__class__.__qualname__.__eq__('SocketKind') via __eq__.
# extra30 checks AF_INET/__class__.__name__.__len__()==13 (via __name__ not __qualname__).
# No prior spec checks __class__.__qualname__.__len__() for AF_INET or SOCK_STREAM.
# ---------------------------------------------------------------------------

table socket_extra35.enum_member_class_qualname_lens:
  description: "socket.AF_INET/SOCK_STREAM __class__.__qualname__.__len__() — novel __len__() axis; extra24 covers __class__.__qualname__.__eq__ only; extra30 covers __class__.__name__.__len__()"
  kind: python_call_eq
  category: class_introspection
  id_prefix: emcql35

  columns: [id, function, args, expected]
  rows:
    - [AF_INET_class_qualname_len,     AF_INET.__class__.__qualname__.__len__,     [], 13]
    - [SOCK_STREAM_class_qualname_len, SOCK_STREAM.__class__.__qualname__.__len__, [], 10]
