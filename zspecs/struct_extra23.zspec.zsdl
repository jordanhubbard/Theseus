spec: struct_extra23
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra4.zspec.zsdl — covers __qualname__ equality for pack/unpack/pack_into/unpack_from/calcsize/iter_unpack; Struct.__qualname__=='Struct'; error.__qualname__=='error'."
    - "struct_extra9.zspec.zsdl — covers __qualname__ for Struct.pack/unpack/pack_into/unpack_from/iter_unpack."
    - "struct_extra20.zspec.zsdl — covers __qualname__.__len__() for pack/unpack/pack_into/unpack_from/calcsize/iter_unpack; __qualname__.__class__.__name__ for pack/unpack."
    - "struct_extra21.zspec.zsdl — covers Struct.__init__/__repr__ __qualname__; __len__() for Struct method qualnames."
    - "struct_extra22.zspec.zsdl — covers __module__ for Struct/pack/unpack/calcsize/error; __bases__[0].__name__; __module__.__class__.__name__ checks; Struct/error module __len__()."
  notes:
    - "This spec extends struct_extra22.zspec.zsdl."
    - "Focus: __module__ for pack_into/unpack_from/iter_unpack (not covered in extra22); __qualname__.__class__.__name__ for calcsize/pack_into/unpack_from/iter_unpack; Struct.__new__ and Struct.__sizeof__ __qualname__ (novel dunder methods)."
    - "struct.pack_into.__module__ == '_struct' — extra22 covers pack/unpack/calcsize __module__ but NOT pack_into. Verified."
    - "struct.unpack_from.__module__ == '_struct' — extra22 covers unpack but not unpack_from. Verified."
    - "struct.iter_unpack.__module__ == '_struct' — not covered in extra22. Verified."
    - "struct.calcsize.__qualname__.__class__.__name__ == 'str' — extra20 checks this for pack/unpack only. Calcsize is novel. Verified."
    - "struct.pack_into.__qualname__.__class__.__name__ == 'str' — not covered in extra20. Verified."
    - "struct.unpack_from.__qualname__.__class__.__name__ == 'str' — not covered in extra20. Verified."
    - "struct.iter_unpack.__qualname__.__class__.__name__ == 'str' — not covered in extra20. Verified."
    - "struct.Struct.__new__.__qualname__ == 'Struct.__new__' — no prior spec covers Struct.__new__. Verified."
    - "struct.Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__' — no prior spec covers Struct.__sizeof__. Verified."
    - "len('Struct.__new__') == 14, len('Struct.__sizeof__') == 17. Verified."
    - "pack_into/__module__.__len__() == 7 — len('_struct') == 7. Verified."
    - "unpack_from/__module__.__len__() == 7 — len('_struct') == 7. Verified."
    - "iter_unpack/__module__.__len__() == 7 — len('_struct') == 7. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __module__ for pack_into/unpack_from/iter_unpack
#
# struct_extra22 covers __module__ for Struct, pack, unpack, and calcsize
# (all '_struct'), and error ('struct'). It does NOT cover pack_into,
# unpack_from, or iter_unpack. All three are C builtins in _struct, so their
# __module__ is '_struct'. This fills the gap left by extra22.
# Verified: pack_into='_struct', unpack_from='_struct', iter_unpack='_struct'.
# ---------------------------------------------------------------------------

table struct_extra23.remaining_function_modules:
  description: "__module__ == '_struct' for struct pack_into/unpack_from/iter_unpack — C extension functions not covered in extra22"
  kind: python_call_eq
  category: module_identity
  id_prefix: rfmod23

  columns: [id, function, args, expected]
  rows:
    - [pack_into,   pack_into.__module__.__eq__,   ["_struct"], true]
    - [unpack_from, unpack_from.__module__.__eq__, ["_struct"], true]
    - [iter_unpack, iter_unpack.__module__.__eq__, ["_struct"], true]

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for pack_into/unpack_from/iter_unpack
#
# No prior spec covers __module__.__len__() for pack_into/unpack_from/iter_unpack.
# extra22 covers this length only for Struct and error. '_struct' has 7 chars.
# Provides a length cross-check independent of string equality.
# Verified: all three have __module__.__len__() == 7.
# ---------------------------------------------------------------------------

table struct_extra23.remaining_function_module_lengths:
  description: "__module__.__len__() == 7 for pack_into/unpack_from/iter_unpack — len('_struct') == 7"
  kind: python_call_eq
  category: module_identity
  id_prefix: rfmlen23

  columns: [id, function, args, expected]
  rows:
    - [pack_into,   pack_into.__module__.__len__,   [], 7]
    - [unpack_from, unpack_from.__module__.__len__, [], 7]
    - [iter_unpack, iter_unpack.__module__.__len__, [], 7]

# ---------------------------------------------------------------------------
# Table: __qualname__.__class__.__name__ for calcsize/pack_into/unpack_from/iter_unpack
#
# struct_extra20 checks __qualname__.__class__.__name__ == 'str' for pack and
# unpack only. No prior spec checks this for calcsize, pack_into, unpack_from,
# or iter_unpack. All function __qualname__ values are plain str objects.
# Verified: all four yield 'str'.
# ---------------------------------------------------------------------------

table struct_extra23.function_qualname_class_names:
  description: "__qualname__.__class__.__name__ == 'str' for calcsize/pack_into/unpack_from/iter_unpack"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqcn23

  columns: [id, function, args, expected]
  rows:
    - [calcsize,    calcsize.__qualname__.__class__.__name__.__eq__,    ["str"], true]
    - [pack_into,   pack_into.__qualname__.__class__.__name__.__eq__,   ["str"], true]
    - [unpack_from, unpack_from.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [iter_unpack, iter_unpack.__qualname__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# Standalone: struct.Struct.__new__.__qualname__ == 'Struct.__new__'
#
# struct_extra21 covers Struct.__init__ and Struct.__repr__ __qualname__.
# struct_extra9 covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack.
# No prior spec covers Struct.__new__.__qualname__. For a C extension type,
# __new__ is defined at the class level and its qualname includes the class
# prefix 'Struct.'. Verified: struct.Struct.__new__.__qualname__ == 'Struct.__new__'.
# ---------------------------------------------------------------------------

invariant struct_extra23.Struct.new_qualname:
  description: "struct.Struct.__new__.__qualname__ == 'Struct.__new__' — C extension class dunder; qualname includes class prefix"
  category: method_qualnames
  kind: python_call_eq
  function: Struct.__new__.__qualname__.__eq__
  args: ["Struct.__new__"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: struct.Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__'
#
# No prior spec covers Struct.__sizeof__.__qualname__. __sizeof__ returns the
# size of the Struct object in bytes and is defined on the Struct C type.
# Its qualname includes the class prefix. len('Struct.__sizeof__') == 17.
# Verified: struct.Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__'.
# ---------------------------------------------------------------------------

invariant struct_extra23.Struct.sizeof_qualname:
  description: "struct.Struct.__sizeof__.__qualname__ == 'Struct.__sizeof__' — memory-size dunder method on Struct C type; len == 17"
  category: method_qualnames
  kind: python_call_eq
  function: Struct.__sizeof__.__qualname__.__eq__
  args: ["Struct.__sizeof__"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: struct.pack_into.__module__ == '_struct'
#
# pack_into writes packed bytes into a mutable buffer at a given offset.
# extra22 covers pack/unpack/calcsize/Struct __module__ but not pack_into.
# This standalone invariant anchors pack_into's C extension origin.
# Verified: struct.pack_into.__module__ == '_struct'.
# ---------------------------------------------------------------------------

invariant struct_extra23.pack_into.module:
  description: "struct.pack_into.__module__ == '_struct' — pack_into is a C builtin in the _struct extension; not covered in extra22"
  category: module_identity
  kind: python_call_eq
  function: pack_into.__module__.__eq__
  args: ["_struct"]
  expected: true
