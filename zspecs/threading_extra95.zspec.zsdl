spec: threading_extra95
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra94

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra94.zspec.zsdl."
    - "This spec covers: threading module identity (__name__, __package__, __loader__, __spec__) + threading.Timer class identity + threading.Barrier class identity + threading.BrokenBarrierError (Wave 254)."
    - "threading.__name__ == 'threading'. Verified with Python 3.14.3."
    - "threading.__package__ == '' (empty string). Verified with Python 3.14.3."
    - "threading.__loader__.__class__.__name__ == 'SourceFileLoader' — threading is a pure-Python module. Verified with Python 3.14.3."
    - "threading.__spec__.__class__.__name__ == 'ModuleSpec'. Verified with Python 3.14.3."
    - "threading.Timer.__name__ == 'Timer'. Verified with Python 3.14.3."
    - "threading.Timer.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Timer.__qualname__ == 'Timer'. Verified with Python 3.14.3."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits from Thread. Verified with Python 3.14.3."
    - "threading.Timer.__mro__.__len__() == 3 — mro is [Timer, Thread, object]. Verified with Python 3.14.3."
    - "threading.Barrier.__name__ == 'Barrier'. Verified with Python 3.14.3."
    - "threading.Barrier.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier has no custom base. Verified with Python 3.14.3."
    - "threading.Barrier.__mro__.__len__() == 2. Verified with Python 3.14.3."
    - "threading.BrokenBarrierError.__name__ == 'BrokenBarrierError'. Verified with Python 3.14.3."
    - "threading.BrokenBarrierError.__bases__[0].__name__ == 'RuntimeError'. Verified with Python 3.14.3."
    - "threading.BrokenBarrierError.__mro__.__len__() == 5 — mro is [BrokenBarrierError, RuntimeError, Exception, BaseException, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading module identity (__name__, __package__, __loader__, __spec__)
#
# Wave 254 theme: threading module string identity and import machinery.
#
# threading.__name__.__eq__('threading') == True
# threading.__package__.__eq__('') == True
# threading.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True
# threading.__spec__.__class__.__name__.__eq__('ModuleSpec') == True
#
# threading is a top-level pure-Python module; __package__ is empty string.
# Loader is SourceFileLoader; __spec__ is a ModuleSpec. New to extra95.
# ---------------------------------------------------------------------------

table threading_extra95.module_identity:
  description: "threading.__name__, __package__, __loader__/__spec__ class names; top-level pure-Python stdlib module; wave 254; new to extra95"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmodule95

  columns: [id, function, args, expected, description]
  rows:
    - [threading_name_eq_threading,
       "__name__.__eq__",
       ["threading"],
       true,
       "threading.__name__.__eq__('threading') == True — threading is a pure-Python module defined in Lib/threading.py; its __name__ attribute is 'threading'; str.__eq__('threading') returns True; prior spec extra94 checked Lock/Thread method class names; this spec (extra95) checks module identity and Timer/Barrier/BrokenBarrierError class identity; new to extra95"]
    - [threading_package_eq_empty,
       "__package__.__eq__",
       [""],
       true,
       "threading.__package__.__eq__('') == True — threading is a top-level module not inside any package; its __package__ attribute is the empty string ''; str.__eq__('') returns True; new to extra95"]
    - [threading_loader_class_name_eq_SourceFileLoader,
       "__loader__.__class__.__name__.__eq__",
       ["SourceFileLoader"],
       true,
       "threading.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — threading is a pure-Python source module (Lib/threading.py); it is loaded by importlib.machinery.SourceFileLoader; __loader__.__class__.__name__ is 'SourceFileLoader'; str.__eq__('SourceFileLoader') returns True; new to extra95"]
    - [threading_spec_class_name_eq_ModuleSpec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "threading.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — every importable module has a __spec__ that is an importlib.machinery.ModuleSpec instance; __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra95"]

# ---------------------------------------------------------------------------
# Table 2: threading.Timer class identity
#
# Wave 254 theme: threading.Timer class identity attributes.
#
# threading.Timer.__name__.__eq__('Timer') == True
# threading.Timer.__module__.__eq__('threading') == True
# threading.Timer.__qualname__.__eq__('Timer') == True
# threading.Timer.__bases__[0].__name__.__eq__('Thread') == True
# threading.Timer.__mro__.__len__().__eq__(3) == True
#
# Timer is a Thread subclass; mro is [Timer, Thread, object] (length 3). New to extra95.
# ---------------------------------------------------------------------------

table threading_extra95.timer_class_identity:
  description: "threading.Timer __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__(); Thread subclass; wave 254; new to extra95"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmodule95

  columns: [id, function, args, expected, description]
  rows:
    - [timer_name_eq_Timer,
       "Timer.__name__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — Timer is a pure-Python class defined with 'class Timer(Thread):' in Lib/threading.py; __name__ is 'Timer'; str.__eq__('Timer') returns True; new to extra95"]
    - [timer_module_eq_threading,
       "Timer.__module__.__eq__",
       ["threading"],
       true,
       "threading.Timer.__module__.__eq__('threading') == True — Timer is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra95"]
    - [timer_qualname_eq_Timer,
       "Timer.__qualname__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__qualname__.__eq__('Timer') == True — Timer is defined at module scope in Lib/threading.py; its __qualname__ is the simple class name 'Timer' with no enclosing scope prefix; str.__eq__('Timer') returns True; new to extra95"]
    - [timer_bases0_eq_Thread,
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer inherits from Thread; class Timer(Thread) in Lib/threading.py; __bases__[0] is threading.Thread; __name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra95"]
    - [timer_mro_len_eq_3,
       "Timer.__mro__.__len__",
       [],
       3,
       "threading.Timer.__mro__.__len__() == 3 — Timer's mro is [Timer, Thread, object]; Thread has only object as its base; tuple.__len__() returns 3; new to extra95"]

# ---------------------------------------------------------------------------
# Table 3: threading.Barrier class identity
#
# Wave 254 theme: threading.Barrier class identity attributes.
#
# threading.Barrier.__name__.__eq__('Barrier') == True
# threading.Barrier.__module__.__eq__('threading') == True
# threading.Barrier.__bases__[0].__name__.__eq__('object') == True
# threading.Barrier.__mro__.__len__().__eq__(2) == True
#
# Barrier is a pure-Python class with no custom base; mro is [Barrier, object]. New to extra95.
# ---------------------------------------------------------------------------

table threading_extra95.barrier_class_identity:
  description: "threading.Barrier __name__, __module__, __bases__[0].__name__, __mro__.__len__(); pure-Python class with no custom base; wave 254; new to extra95"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmodule95

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_name_eq_Barrier,
       "Barrier.__name__.__eq__",
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — Barrier is a pure-Python class defined with 'class Barrier:' in Lib/threading.py (no explicit base class); __name__ is 'Barrier'; str.__eq__('Barrier') returns True; new to extra95"]
    - [barrier_module_eq_threading,
       "Barrier.__module__.__eq__",
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — Barrier is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra95"]
    - [barrier_bases0_eq_object,
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — Barrier has no explicit base class so it inherits from object; __bases__[0] is <class 'object'>; __name__ is 'object'; str.__eq__('object') returns True; new to extra95"]
    - [barrier_mro_len_eq_2,
       "Barrier.__mro__.__len__",
       [],
       2,
       "threading.Barrier.__mro__.__len__() == 2 — Barrier's mro is [Barrier, object]; no intermediate base classes; tuple.__len__() returns 2; new to extra95"]

# ---------------------------------------------------------------------------
# Table 4: threading.BrokenBarrierError class identity
#
# Wave 254 theme: threading.BrokenBarrierError class identity.
#
# threading.BrokenBarrierError.__name__.__eq__('BrokenBarrierError') == True
# threading.BrokenBarrierError.__bases__[0].__name__.__eq__('RuntimeError') == True
# threading.BrokenBarrierError.__mro__.__len__().__eq__(5) == True
#
# BrokenBarrierError inherits from RuntimeError; mro is
# [BrokenBarrierError, RuntimeError, Exception, BaseException, object] (length 5). New to extra95.
# ---------------------------------------------------------------------------

table threading_extra95.broken_barrier_error_identity:
  description: "threading.BrokenBarrierError __name__, __bases__[0].__name__, __mro__.__len__(); RuntimeError subclass; wave 254; new to extra95"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingmodule95

  columns: [id, function, args, expected, description]
  rows:
    - [broken_barrier_name_eq,
       "BrokenBarrierError.__name__.__eq__",
       ["BrokenBarrierError"],
       true,
       "threading.BrokenBarrierError.__name__.__eq__('BrokenBarrierError') == True — BrokenBarrierError is a pure-Python exception class defined in Lib/threading.py; it is raised when a Barrier is broken; __name__ is 'BrokenBarrierError'; str.__eq__('BrokenBarrierError') returns True; new to extra95"]
    - [broken_barrier_bases0_eq_RuntimeError,
       "BrokenBarrierError.__bases__[0].__name__.__eq__",
       ["RuntimeError"],
       true,
       "threading.BrokenBarrierError.__bases__[0].__name__.__eq__('RuntimeError') == True — BrokenBarrierError inherits from RuntimeError; __bases__[0] is <class 'RuntimeError'>; __name__ is 'RuntimeError'; str.__eq__('RuntimeError') returns True; new to extra95"]
    - [broken_barrier_mro_len_eq_5,
       "BrokenBarrierError.__mro__.__len__",
       [],
       5,
       "threading.BrokenBarrierError.__mro__.__len__() == 5 — BrokenBarrierError's mro is [BrokenBarrierError, RuntimeError, Exception, BaseException, object]; tuple.__len__() returns 5; new to extra95"]
    - [broken_barrier_module_eq_threading,
       "BrokenBarrierError.__module__.__eq__",
       ["threading"],
       true,
       "threading.BrokenBarrierError.__module__.__eq__('threading') == True — BrokenBarrierError is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra95"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra95
# ---------------------------------------------------------------------------

invariant threading_extra95.threading_name_eq_threading:
  description: "threading.__name__ == 'threading' — top-level stdlib module identity; wave 254; new to extra95"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra95.threading_loader_class_name:
  description: "threading.__loader__.__class__.__name__ == 'SourceFileLoader' — pure-Python source module; wave 254; new to extra95"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant threading_extra95.timer_bases0_eq_Thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits from Thread; wave 254; new to extra95"
  kind: python_call_eq
  function: Timer.__bases__[0].__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra95.barrier_mro_len_eq_2:
  description: "threading.Barrier.__mro__.__len__() == 2 — mro is [Barrier, object]; wave 254; new to extra95"
  kind: python_call_eq
  function: Barrier.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra95.broken_barrier_mro_len_eq_5:
  description: "threading.BrokenBarrierError.__mro__.__len__() == 5 — RuntimeError subclass with full exception mro; wave 254; new to extra95"
  kind: python_call_eq
  function: BrokenBarrierError.__mro__.__len__
  args: []
  expected: 5
