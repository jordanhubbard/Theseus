spec: concurrent_futures_extra285
version: ">=3.9"
backend: python_module(concurrent.futures)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — ThreadPoolExecutor, ProcessPoolExecutor, wait, as_completed"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py, Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py"
  notes:
    - "ThreadPoolExecutor.map.__qualname__ is 'Executor.map' (inherited from Executor base, not overridden)"
    - "ProcessPoolExecutor.map.__qualname__ is 'ProcessPoolExecutor.map' (overrides Executor.map)"
    - "wait and as_completed __module__ is 'concurrent.futures._base'"
    - "ProcessPoolExecutor.submit is overridden: qualname is 'ProcessPoolExecutor.submit'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra285.threadpool_qualnames:
  description: "ThreadPoolExecutor method __qualname__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: cf285t

  columns: [id, function, args, expected, description]
  rows:
    - [cf285t_001, concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__, ["ThreadPoolExecutor.submit"], true, "ThreadPoolExecutor.submit qualname"]
    - [cf285t_002, concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__, ["Executor.map"], true, "ThreadPoolExecutor.map qualname is inherited Executor.map"]
    - [cf285t_003, concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__eq__, ["ThreadPoolExecutor.shutdown"], true, "ThreadPoolExecutor.shutdown qualname"]
    - [cf285t_004, concurrent.futures.ThreadPoolExecutor.__init__.__qualname__.__eq__, ["ThreadPoolExecutor.__init__"], true, "ThreadPoolExecutor.__init__ qualname"]

table concurrent_futures_extra285.processpool_and_helpers:
  description: "ProcessPoolExecutor method qualnames and wait/as_completed helper qualnames and modules"
  kind: python_call_eq
  category: identity
  id_prefix: cf285p

  columns: [id, function, args, expected, description]
  rows:
    - [cf285p_001, concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__eq__, ["ProcessPoolExecutor.submit"], true, "ProcessPoolExecutor.submit qualname"]
    - [cf285p_002, concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__eq__, ["ProcessPoolExecutor.shutdown"], true, "ProcessPoolExecutor.shutdown qualname"]
    - [cf285p_003, concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__, ["ProcessPoolExecutor.__init__"], true, "ProcessPoolExecutor.__init__ qualname"]
    - [cf285p_004, concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__, ["ProcessPoolExecutor.map"], true, "ProcessPoolExecutor.map is overridden (not Executor.map)"]
    - [cf285p_005, concurrent.futures.wait.__qualname__.__eq__, ["wait"], true, "wait function qualname"]
    - [cf285p_006, concurrent.futures.as_completed.__qualname__.__eq__, ["as_completed"], true, "as_completed function qualname"]
    - [cf285p_007, concurrent.futures.wait.__module__.__eq__, ["concurrent.futures._base"], true, "wait lives in concurrent.futures._base"]
    - [cf285p_008, concurrent.futures.as_completed.__module__.__eq__, ["concurrent.futures._base"], true, "as_completed lives in concurrent.futures._base"]

invariant concurrent_futures_extra285.threadpool_submit_qualname:
  description: "ThreadPoolExecutor.submit qualname confirmed as ThreadPoolExecutor.submit"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__
  args: ["ThreadPoolExecutor.submit"]
  expected: true

invariant concurrent_futures_extra285.threadpool_map_inherits_executor:
  description: "ThreadPoolExecutor.map is NOT overridden — qualname is Executor.map"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__
  args: ["Executor.map"]
  expected: true

invariant concurrent_futures_extra285.wait_module_is_base:
  description: "concurrent.futures.wait __module__ is concurrent.futures._base"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.wait.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true
