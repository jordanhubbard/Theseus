spec: concurrent_futures_extra170
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers: concurrent.futures.Future.__mro__.__len__()==2 (Future > object); concurrent.futures.Executor.__mro__.__len__()==2 (Executor > object); concurrent.futures.ThreadPoolExecutor.__mro__.__len__()==3 (TPE > Executor > object); concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3 (PPE > Executor > object); concurrent.futures.BrokenExecutor.__mro__.__len__()==5 (BrokenExecutor > RuntimeError > Exception > BaseException > object). KEY FINDINGS: all five classes have MRO lengths 2, 2, 3, 3, 5; the two base classes Future and Executor both have minimal MRO len=2 (no intermediate bases); the two executor subclasses TPE and PPE both have MRO len=3 (one intermediate: Executor); BrokenExecutor has the longest MRO at 5 (exception hierarchy: BrokenExecutor > RuntimeError > Exception > BaseException > object). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.__mro__.__len__()==2: Future is defined in concurrent.futures._base and inherits directly from object; MRO: [concurrent.futures._base.Future, object]. Verified with Python 3.14.3."
    - "concurrent.futures.Executor.__mro__.__len__()==2: Executor is the abstract base for thread and process pool executors; inherits directly from object; MRO: [concurrent.futures._base.Executor, object]. Verified with Python 3.14.3."
    - "concurrent.futures.ThreadPoolExecutor.__mro__.__len__()==3: MRO: [concurrent.futures.thread.ThreadPoolExecutor, concurrent.futures._base.Executor, object]. Verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3: MRO: [concurrent.futures.process.ProcessPoolExecutor, concurrent.futures._base.Executor, object]. Verified with Python 3.14.3."
    - "concurrent.futures.BrokenExecutor.__mro__.__len__()==5: BrokenExecutor subclasses RuntimeError; MRO: [BrokenExecutor, RuntimeError, Exception, BaseException, object]. 5 entries = full Python exception chain. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future and Executor MRO lengths — extra170
#
# concurrent.futures.Future.__mro__.__len__()   == 2
# concurrent.futures.Executor.__mro__.__len__() == 2
# ---------------------------------------------------------------------------

table concurrent_futures_extra170.cf_future_and_executor_mro_len:
  description: "concurrent.futures.Future and Executor MRO length checks in cffutexecmro170 namespace — concurrent.futures.Future.__mro__.__len__()==2 (concurrent.futures.Future is a pure Python class defined in concurrent.futures._base; it inherits directly from object with no intermediate bases; MRO: [concurrent.futures._base.Future, object]; Future.__mro__[0].__name__=='Future' (the class itself) and Future.__mro__[1].__name__=='object'); concurrent.futures.Executor.__mro__.__len__()==2 (Executor is also defined in concurrent.futures._base and inherits directly from object; MRO: [concurrent.futures._base.Executor, object]; Executor.__mro__[0].__name__=='Executor'; KEY: both Future and Executor have minimal 2-entry MROs — they are root classes with no common ancestor beyond object); concurrent.futures.ThreadPoolExecutor.__mro__.__len__()==3 (cross-check: TPE > Executor > object — adds one entry over Executor's MRO); concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3 (cross-check: PPE > Executor > object — same length as TPE); MRO ORDERING: Future(2) == Executor(2) < TPE(3) == PPE(3) < BrokenExecutor(5); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutexecmro170

  columns: [id, function, args, expected, description]
  rows:
    - [cf_fut_mro_len,    concurrent.futures.Future.__mro__.__len__,    [],         2,  "Future.__mro__.__len__() == 2 (Python class; Future > object; minimal MRO; no intermediate bases); verified with Python 3.14.3"]
    - [cf_exec_mro_len,   concurrent.futures.Executor.__mro__.__len__,  [],         2,  "Executor.__mro__.__len__() == 2 (Python class; Executor > object; equal to Future MRO len); verified with Python 3.14.3"]
    - [cf_tpe_mro_xchk,   concurrent.futures.ThreadPoolExecutor.__mro__.__len__,  [],  3,  "TPE.__mro__.__len__() == 3 (cross-check; TPE > Executor > object; one more than Executor=2); verified with Python 3.14.3"]
    - [cf_ppe_mro_xchk,   concurrent.futures.ProcessPoolExecutor.__mro__.__len__, [],  3,  "PPE.__mro__.__len__() == 3 (cross-check; PPE > Executor > object; equals TPE MRO len); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor MRO — extra170
#
# concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3
# MRO: [TPE, Executor, object]
# ---------------------------------------------------------------------------

table concurrent_futures_extra170.cf_tpe_mro_len:
  description: "concurrent.futures.ThreadPoolExecutor MRO length and entry name checks in cftpemro170 namespace — concurrent.futures.ThreadPoolExecutor.__mro__.__len__()==3 (ThreadPoolExecutor is defined in concurrent.futures.thread and inherits from concurrent.futures._base.Executor; MRO: [concurrent.futures.thread.ThreadPoolExecutor, concurrent.futures._base.Executor, object]; 3 entries: TPE itself, Executor, object); concurrent.futures.ThreadPoolExecutor.__mro__[0].__name__.__eq__('ThreadPoolExecutor')==True (entry 0 is TPE itself; 'ThreadPoolExecutor'=18: 'Thread'=6+'Pool'=4+'Executor'=8=18); concurrent.futures.ThreadPoolExecutor.__mro__[1].__name__.__eq__('Executor')==True (entry 1 is the base Executor class from _base; 'Executor'=8); concurrent.futures.ThreadPoolExecutor.__mro__[2].__name__.__eq__('object')==True (entry 2 is object); concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3 (cross-check: PPE also has a 3-entry MRO through the same Executor base; TPE and PPE have identical MRO structure — both are Executor > object with themselves at index 0); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpemro170

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_mro_len,    concurrent.futures.ThreadPoolExecutor.__mro__.__len__,              [],                     3,     "TPE.__mro__.__len__() == 3 (MRO: ThreadPoolExecutor > Executor > object); verified with Python 3.14.3"]
    - [tpe_mro0_name,  "concurrent.futures.ThreadPoolExecutor.__mro__[0].__name__.__eq__",   ["ThreadPoolExecutor"], true,  "TPE.__mro__[0].__name__ == 'ThreadPoolExecutor' (len=18; TPE itself at index 0); verified with Python 3.14.3"]
    - [tpe_mro1_name,  "concurrent.futures.ThreadPoolExecutor.__mro__[1].__name__.__eq__",   ["Executor"],           true,  "TPE.__mro__[1].__name__ == 'Executor' (the base Executor class at index 1); verified with Python 3.14.3"]
    - [tpe_mro2_name,  "concurrent.futures.ThreadPoolExecutor.__mro__[2].__name__.__eq__",   ["object"],             true,  "TPE.__mro__[2].__name__ == 'object' (universal base at index 2 of 3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor MRO — extra170
#
# concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3
