table concurrent_futures_extra170.cf_ppe_mro_len:
  description: "concurrent.futures.ProcessPoolExecutor MRO length and entry name checks in cfppemro170 namespace — concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3 (ProcessPoolExecutor is defined in concurrent.futures.process and inherits from concurrent.futures._base.Executor; MRO: [concurrent.futures.process.ProcessPoolExecutor, concurrent.futures._base.Executor, object]; 3 entries: PPE itself, Executor, object); concurrent.futures.ProcessPoolExecutor.__mro__[0].__name__.__eq__('ProcessPoolExecutor')==True (entry 0; 'ProcessPoolExecutor'=19: 'Process'=7+'Pool'=4+'Executor'=8=19; 1 char longer than 'ThreadPoolExecutor'=18 because 'Process'=7 > 'Thread'=6 by 1); concurrent.futures.ProcessPoolExecutor.__mro__[1].__name__.__eq__('Executor')==True (entry 1 is the same Executor base as in TPE's MRO — both TPE and PPE share Executor as their immediate base); concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3 is equal to TPE.__mro__.__len__()==3 — both executors have identical MRO structure despite very different implementations (threads vs processes); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfppemro170

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_mro_len,    concurrent.futures.ProcessPoolExecutor.__mro__.__len__,              [],                     3,     "PPE.__mro__.__len__() == 3 (MRO: ProcessPoolExecutor > Executor > object; equals TPE MRO len); verified with Python 3.14.3"]
    - [ppe_mro0_name,  "concurrent.futures.ProcessPoolExecutor.__mro__[0].__name__.__eq__",   ["ProcessPoolExecutor"], true,  "PPE.__mro__[0].__name__ == 'ProcessPoolExecutor' (len=19; 1 longer than ThreadPoolExecutor=18); verified with Python 3.14.3"]
    - [ppe_mro1_name,  "concurrent.futures.ProcessPoolExecutor.__mro__[1].__name__.__eq__",   ["Executor"],           true,  "PPE.__mro__[1].__name__ == 'Executor' (same base as TPE at index 1; both share this base); verified with Python 3.14.3"]
    - [ppe_mro2_name,  "concurrent.futures.ProcessPoolExecutor.__mro__[2].__name__.__eq__",   ["object"],             true,  "PPE.__mro__[2].__name__ == 'object' (universal base at index 2 of 3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.BrokenExecutor MRO — extra170
#
# concurrent.futures.BrokenExecutor.__mro__.__len__() == 5
# MRO: [BrokenExecutor, RuntimeError, Exception, BaseException, object]
# ---------------------------------------------------------------------------

table concurrent_futures_extra170.cf_broken_executor_mro_len:
  description: "concurrent.futures.BrokenExecutor MRO length and entry name checks in cfbemro170 namespace — concurrent.futures.BrokenExecutor.__mro__.__len__()==5 (BrokenExecutor inherits from RuntimeError which inherits from Exception which inherits from BaseException which inherits from object; full Python exception hierarchy MRO: [concurrent.futures._base.BrokenExecutor, RuntimeError, Exception, BaseException, object]; 5 entries; BrokenExecutor is raised when an executor is in a broken state — e.g., when a worker process or thread is unexpectedly terminated); concurrent.futures.BrokenExecutor.__mro__[0].__name__=='BrokenExecutor' (entry 0: BrokenExecutor itself); concurrent.futures.BrokenExecutor.__mro__[1].__name__=='RuntimeError' (entry 1: immediate base; BrokenExecutor IS-A RuntimeError); concurrent.futures.BrokenExecutor.__mro__[2].__name__=='Exception' (entry 2); concurrent.futures.BrokenExecutor.__mro__[3].__name__=='BaseException' (entry 3); concurrent.futures.BrokenExecutor.__mro__[4].__name__=='object' (entry 4); KEY: BrokenExecutor.__mro__.__len__()==5 is the LONGEST MRO in this spec — the exception class hierarchy always has more entries than pure data classes; MRO ORDERING: Future(2) == Executor(2) < TPE(3) == PPE(3) < BrokenExecutor(5); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfbemro170

  columns: [id, function, args, expected, description]
  rows:
    - [be_mro_len,    concurrent.futures.BrokenExecutor.__mro__.__len__,             [],                  5,     "BrokenExecutor.__mro__.__len__() == 5 (exception hierarchy: BrokenExecutor > RuntimeError > Exception > BaseException > object); verified with Python 3.14.3"]
    - [be_mro0_name,  "concurrent.futures.BrokenExecutor.__mro__[0].__name__.__eq__",  ["BrokenExecutor"],  true,  "BrokenExecutor.__mro__[0].__name__ == 'BrokenExecutor' (the class itself; entry 0 of 5); verified with Python 3.14.3"]
    - [be_mro1_name,  "concurrent.futures.BrokenExecutor.__mro__[1].__name__.__eq__",  ["RuntimeError"],    true,  "BrokenExecutor.__mro__[1].__name__ == 'RuntimeError' (immediate base; BrokenExecutor IS-A RuntimeError); verified with Python 3.14.3"]
    - [be_mro2_name,  "concurrent.futures.BrokenExecutor.__mro__[2].__name__.__eq__",  ["Exception"],       true,  "BrokenExecutor.__mro__[2].__name__ == 'Exception' (entry 2 of 5 in exception chain); verified with Python 3.14.3"]
    - [be_mro3_name,  "concurrent.futures.BrokenExecutor.__mro__[3].__name__.__eq__",  ["BaseException"],   true,  "BrokenExecutor.__mro__[3].__name__ == 'BaseException' (entry 3 of 5; penultimate before object); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra170
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra170.cf_Future_mro_len:
  description: "concurrent.futures.Future.__mro__.__len__() returns 2 — concurrent.futures.Future.__mro__.__len__()==2; concurrent.futures.Future is a pure Python class in concurrent.futures._base; it inherits directly from object with no intermediate bases; MRO: [concurrent.futures._base.Future, object]; len=2 is the minimum MRO length for any non-object class; DESIGN NOTE: concurrent.futures.Future is completely separate from asyncio.Future (which is also len=2 from _asyncio C extension; established in asyncio_extra173); despite the same name and MRO length, cf.Future and asyncio.Future are incompatible types — they live in different frameworks; cf.Future is thread-safe (uses locking internally) while asyncio.Future is event-loop-safe (not thread-safe); the minimal 2-entry MRO of both Future types signals they are foundational root classes with no inherited behavior beyond object; NEW in extra170: first standalone concurrent.futures.Future.__mro__.__len__ invariant in cffutexecmro170 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__mro__.__len__
  args: []
  expected: 2

invariant concurrent_futures_extra170.cf_Executor_mro_len:
  description: "concurrent.futures.Executor.__mro__.__len__() returns 2 — concurrent.futures.Executor.__mro__.__len__()==2; Executor is the abstract base class for ThreadPoolExecutor and ProcessPoolExecutor; it inherits directly from object; MRO: [concurrent.futures._base.Executor, object]; COMPARISON: concurrent.futures.Future.__mro__.__len__()==2 (also 2; both root classes in the concurrent.futures hierarchy have minimal MRO chains); concurrent.futures.ThreadPoolExecutor.__mro__.__len__()==3 (Executor + 1; TPE's MRO extends Executor's by adding TPE itself at index 0); DESIGN: Executor is not registered with abc.ABCMeta — its abstractness is enforced by submit() raising NotImplementedError (from extra168) rather than by ABCMeta __abstractmethods__ machinery; the 2-entry MRO means Executor has no mixins or helper base classes — it is a standalone root; NEW in extra170: first standalone concurrent.futures.Executor.__mro__.__len__ invariant in cffutexecmro170 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.__mro__.__len__
  args: []
  expected: 2

invariant concurrent_futures_extra170.cf_TPE_mro_len:
  description: "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() returns 3 — concurrent.futures.ThreadPoolExecutor.__mro__.__len__()==3; MRO: [concurrent.futures.thread.ThreadPoolExecutor, concurrent.futures._base.Executor, object]; TPE inherits from Executor and adds thread-pool-specific implementation: a queue of work items, a set of worker threads, and thread lifecycle management; TPE.__mro__[0].__name__=='ThreadPoolExecutor' (len=18: 'Thread'=6+'Pool'=4+'Executor'=8=18); TPE.__mro__[1].__name__=='Executor' (the shared base with PPE); TPE.__mro__[2].__name__=='object'; COMPARISON: concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3 (same length; same MRO structure through Executor; TPE and PPE are sibling classes with identical MRO depth but different implementations); CONTRAST: asyncio.Task.__mro__.__len__()==3 (also 3; Task > Future > object — but these are C types; TPE and PPE are pure Python); NEW in extra170: first standalone TPE.__mro__.__len__ invariant in cftpemro170 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__mro__.__len__
  args: []
  expected: 3

invariant concurrent_futures_extra170.cf_PPE_mro_len:
  description: "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() returns 3 — concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3; MRO: [concurrent.futures.process.ProcessPoolExecutor, concurrent.futures._base.Executor, object]; PPE inherits from Executor and adds process-pool-specific implementation: a queue manager thread, worker processes via multiprocessing, and inter-process communication via pipes/queues; PPE.__mro__[0].__name__=='ProcessPoolExecutor' (len=19: 'Process'=7+'Pool'=4+'Executor'=8=19; 1 longer than ThreadPoolExecutor=18 because 'Process'=7 > 'Thread'=6 by 1); PPE.__mro__[1].__name__=='Executor' (the same base as TPE); STRUCTURAL INSIGHT: TPE and PPE have identical MRO structures (both 3-entry chains ending with Executor > object) but completely different implementations — threads share memory so TPE needs no serialization; processes are isolated so PPE must pickle all arguments (from extra168); both have __dict__ lengths confirming implementation differences: TPE=12, PPE=15 (from extra168); NEW in extra170: first standalone PPE.__mro__.__len__ invariant in cfppemro170 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__mro__.__len__
  args: []
  expected: 3

invariant concurrent_futures_extra170.cf_BrokenExecutor_mro_len:
  description: "concurrent.futures.BrokenExecutor.__mro__.__len__() returns 5 — concurrent.futures.BrokenExecutor.__mro__.__len__()==5; BrokenExecutor is an exception class that inherits from RuntimeError; the full Python exception hierarchy gives it 5 MRO entries: [BrokenExecutor, RuntimeError, Exception, BaseException, object]; BrokenExecutor is raised when an executor's internals fail in an unrecoverable way — e.g., a worker process dies unexpectedly; BrokenExecutor itself has two subclasses: BrokenThreadPool and BrokenProcessPool (raised by ThreadPoolExecutor and ProcessPoolExecutor respectively); COMPARISON: Future.__mro__.__len__()==2 vs Executor.__mro__.__len__()==2 vs TPE.__mro__.__len__()==3 vs PPE.__mro__.__len__()==3 vs BrokenExecutor.__mro__.__len__()==5; the exception class (5) has the longest MRO by far — the full exception hierarchy (RuntimeError > Exception > BaseException > object) adds 3 extra entries compared to the Executor base classes; MRO ORDERING: Future(2)==Executor(2) < TPE(3)==PPE(3) < BrokenExecutor(5); NEW in extra170: first standalone BrokenExecutor.__mro__.__len__ invariant in cfbemro170 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.BrokenExecutor.__mro__.__len__
  args: []
  expected: 5

invariant concurrent_futures_extra170.cf_BrokenExecutor_mro1_is_RuntimeError:
  description: "concurrent.futures.BrokenExecutor.__mro__[1].__name__.__eq__('RuntimeError') returns True — concurrent.futures.BrokenExecutor.__mro__[1].__name__=='RuntimeError'; BrokenExecutor's immediate base class is RuntimeError (the standard Python runtime error type); inheriting from RuntimeError means BrokenExecutor IS-A RuntimeError — it can be caught with 'except RuntimeError' as well as 'except concurrent.futures.BrokenExecutor'; this choice of base class signals that a broken executor is a runtime operational error (not a programming error like ValueError or TypeError, and not an I/O error like OSError); RuntimeError is in BrokenExecutor's MRO at index 1 (zero-indexed) — i.e., the entry immediately after BrokenExecutor itself; PATTERN: BrokenExecutor.__mro__[1:] == [RuntimeError, Exception, BaseException, object] which is the standard Python exception chain for RuntimeError; NEW in extra170: first standalone BrokenExecutor.__mro__[1].__name__ identity invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.BrokenExecutor.__mro__[1].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true

