    - [task_base_name_len,  "asyncio.Task.__bases__[0].__name__.__len__",  [],                  6,     "Task.__bases__[0].__name__.__len__() == 6 ('Future'=6; same as asyncio.Future name len=6); verified with Python 3.14.3"]
    - [handle_name_eq,      asyncio.Handle.__name__.__eq__,                ["Handle"],          true,  "asyncio.Handle.__name__ == 'Handle' (len=6: 'Handle'=6; same length as 'Future'=6); verified with Python 3.14.3"]
    - [handle_mod_eq,       asyncio.Handle.__module__.__eq__,              ["asyncio.events"],  true,  "asyncio.Handle.__module__ == 'asyncio.events' (len=14; pure Python; 6 longer than '_asyncio'=8); verified with Python 3.14.3"]

