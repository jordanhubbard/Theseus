spec: asyncio_extra166
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-future.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-future.html — Python asyncio Future documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio Task documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — Python asyncio Handle documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_asyncio.c"
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "This spec covers: asyncio.Future class name and module identity; asyncio.Task class name, module, and base class; asyncio.Handle class name and module identity. KEY FINDINGS: asyncio.Future.__module__=='_asyncio' (len=8: '_asyncio'=8; Future is implemented as a C extension type in CPython — Modules/_asyncio.c — NOT in asyncio.futures Python module; '_asyncio'=8 has leading underscore indicating a C-accelerator module); asyncio.Task.__module__=='_asyncio' (len=8; same C extension module as Future; Task is also implemented in C); asyncio.Task.__bases__[0].__name__=='Future' (Task inherits directly from Future; the MRO is Task -> Future -> object); asyncio.Handle.__module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14; Handle is implemented in Python in asyncio/events.py — not a C extension). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Future.__name__=='Future' (len=6: 'F'+'u'+'t'+'u'+'r'+'e'=6); asyncio.Future is the C-accelerated future class; asyncio.futures.Future is the same object (asyncio.futures.Future is asyncio.Future == True); asyncio.Future.__module__=='_asyncio' (len=8: '_'=1+'asyncio'=7=8; leading underscore indicates private C accelerator module); compare: asyncio.Handle.__module__=='asyncio.events' (len=14: 6 chars longer than '_asyncio'=8); 'asyncio.events'=14 has no leading underscore — Handle is pure Python; Future and Task are C-accelerated for performance; Handle is pure Python. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Task.__name__=='Task' (len=4: 'T'+'a'+'s'+'k'=4); asyncio.Task is a subclass of asyncio.Future that wraps a coroutine; asyncio.Task.__bases__[0].__name__=='Future' (len=6; Task's only base class is Future; single inheritance: Task -> Future); asyncio.Task.__module__=='_asyncio' (len=8; same C module as Future); Task name len(4) < Future name len(6) < Handle name len(6); Task(4) is the shortest class name in this spec; Future(6)==Handle(6) in name length — both 6-char class names; compare: asyncio.StreamReader.__name__.__len__()==12 (from extra164) — Task(4) is 8 chars shorter than StreamReader(12). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Handle.__name__=='Handle' (len=6: 'H'+'a'+'n'+'d'+'l'+'e'=6); asyncio.Handle wraps a callback scheduled via call_soon(), call_later(), or call_at(); Handle.__module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14; pure Python module; 'events'=6 is the same length as 'Handle'=6 — the module suffix equals the class name length); compare: asyncio.Handle.__module__.__len__()==14 == asyncio.StreamReader.__module__.__len__()==15-1 (asyncio.streams=15 is 1 longer than asyncio.events=14). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Future class identity — extra166
#
# asyncio.Future.__name__.__eq__('Future')   == True
# asyncio.Future.__name__.__len__()          == 6
# asyncio.Future.__module__.__eq__('_asyncio') == True
# asyncio.Future.__module__.__len__()        == 8
# ---------------------------------------------------------------------------

table asyncio_extra166.asyncio_future_identity:
  description: "asyncio.Future class name and module identity checks in asynciofut166 namespace — asyncio.Future.__name__.__eq__('Future')==True (asyncio.Future is the C-accelerated asyncio future class; Future.__name__=='Future' len=6: 'F'+'u'+'t'+'u'+'r'+'e'=6; asyncio.Future represents the result of an asynchronous operation — it can be in PENDING, CANCELLED, or FINISHED state; awaiting a Future blocks the coroutine until the future is resolved; asyncio.Future is produced by loop.create_future() and by internal asyncio machinery); asyncio.Future.__name__.__len__()==6 ('Future'=6; same length as asyncio.Handle.__name__.__len__()==6 — both are 6-char class names); asyncio.Future.__module__.__eq__('_asyncio')==True (KEY: Future is implemented as a C extension in Modules/_asyncio.c; its __module__ is '_asyncio' (len=8: '_'=1+'asyncio'=7=8) with a leading underscore indicating a private C accelerator module; the Python wrapper asyncio.futures.Future IS the same object as asyncio.Future — asyncio.futures.Future is asyncio.Future evaluates to True); asyncio.Future.__module__.__len__()==8 ('_asyncio'=8: '_'=1+'asyncio'=7=8; compare: asyncio.Handle.__module__=='asyncio.events' (len=14) is 6 chars longer because Handle is pure Python); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciofut166

  columns: [id, function, args, expected, description]
  rows:
    - [fut_name_eq,  asyncio.Future.__name__.__eq__,    ["Future"],    true,  "asyncio.Future.__name__ == 'Future' (len=6: 'Future'=6; C-accelerated future class); verified with Python 3.14.3"]
    - [fut_name_len, asyncio.Future.__name__.__len__,   [],            6,     "asyncio.Future.__name__.__len__() == 6 ('Future'=6; same as Handle name len=6); verified with Python 3.14.3"]
    - [fut_mod_eq,   asyncio.Future.__module__.__eq__,  ["_asyncio"],  true,  "asyncio.Future.__module__ == '_asyncio' (len=8; C extension module; leading underscore); verified with Python 3.14.3"]
    - [fut_mod_len,  asyncio.Future.__module__.__len__, [],            8,     "asyncio.Future.__module__.__len__() == 8 ('_asyncio'=8: '_'=1+'asyncio'=7=8); verified with Python 3.14.3"]

