table asyncio_extra166.asyncio_task_identity:
  description: "asyncio.Task class name, module, and base class checks in asynciotask166 namespace — asyncio.Task.__name__.__eq__('Task')==True (Task.__name__=='Task' len=4: 'T'+'a'+'s'+'k'=4; asyncio.Task is the primary coroutine wrapper in asyncio; Task schedules a coroutine for execution in the event loop and tracks its state; asyncio.create_task() and loop.create_task() both create Task instances); asyncio.Task.__name__.__len__()==4 ('Task'=4; the shortest class name in this spec; Task(4) < Future(6) == Handle(6)); asyncio.Task.__module__.__eq__('_asyncio')==True (Task is also implemented as a C extension in Modules/_asyncio.c; same module as Future: both '__module__=='_asyncio' (len=8); Task inherits from Future and the entire inheritance chain is in C); asyncio.Task.__bases__[0].__name__.__eq__('Future')==True (Task inherits directly from asyncio.Future; Task.__bases__ == (<class '_asyncio.Future'>,); Task.__bases__[0].__name__=='Future' (len=6); the MRO is Task -> Future -> object; Task wraps a coroutine and drives it to completion using Future's state machine); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotask166

  columns: [id, function, args, expected, description]
  rows:
    - [task_name_eq,   asyncio.Task.__name__.__eq__,    ["Task"],      true,  "asyncio.Task.__name__ == 'Task' (len=4: 'Task'=4; shortest class name in spec); verified with Python 3.14.3"]
    - [task_name_len,  asyncio.Task.__name__.__len__,   [],            4,     "asyncio.Task.__name__.__len__() == 4 ('Task'=4; shorter than Future=6 and Handle=6 by 2); verified with Python 3.14.3"]
    - [task_mod_eq,    asyncio.Task.__module__.__eq__,  ["_asyncio"],  true,  "asyncio.Task.__module__ == '_asyncio' (same C extension module as Future; both C-accelerated); verified with Python 3.14.3"]
    - [task_mod_len,   asyncio.Task.__module__.__len__, [],            8,     "asyncio.Task.__module__.__len__() == 8 ('_asyncio'=8; same length as Future module=8); verified with Python 3.14.3"]

