invariant asyncio_extra166.asyncio_Future_name_eq:
  description: "asyncio.Future.__name__.__eq__('Future') returns True — asyncio.Future is the C-accelerated asyncio future class; Future.__name__=='Future' (len=6: 'F'+'u'+'t'+'u'+'r'+'e'=6); asyncio.Future represents the eventual result of an asynchronous computation; it can be in one of three states: PENDING (initial state), CANCELLED (cancelled by Future.cancel()), or FINISHED (result or exception set); asyncio.Future is the base class for asyncio.Task (Task.__bases__[0] is asyncio.Future); asyncio.Future.__module__=='_asyncio' (len=8: '_asyncio' with leading underscore indicating the C accelerator module Modules/_asyncio.c); the Python-level asyncio.futures.Future is the same object: asyncio.futures.Future is asyncio.Future evaluates to True; compare: asyncio.Task.__name__=='Task' (len=4; Task is 2 chars shorter than Future); asyncio.Handle.__name__=='Handle' (len=6; same length as Future=6 — both 6-char names); NEW in extra166: first standalone asyncio.Future.__name__ identity invariant in asynciofut166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Future.__name__.__eq__
  args: ["Future"]
  expected: true

invariant asyncio_extra166.asyncio_Future_module_eq:
  description: "asyncio.Future.__module__.__eq__('_asyncio') returns True — asyncio.Future.__module__=='_asyncio' (len=8: '_'=1+'asyncio'=7=8); the leading underscore in '_asyncio' signals that this is the private C extension accelerator module (Modules/_asyncio.c in CPython); Future, Task, and related types are implemented in C for performance; the Python-level module asyncio.futures provides compatibility wrappers but asyncio.Future itself is the C type; compare: asyncio.Handle.__module__=='asyncio.events' (len=14; Handle is pure Python in asyncio/events.py — its module path is 6 chars longer than '_asyncio'=8 because it has the full 'asyncio.' prefix plus 'events'=6 rather than just '_asyncio'=8); the pattern: C-implemented asyncio types (_asyncio) vs Python-implemented asyncio types (asyncio.events, asyncio.locks, etc.); NEW in extra166: first standalone asyncio.Future.__module__ identity invariant in asynciofut166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Future.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra166.asyncio_Task_name_eq:
  description: "asyncio.Task.__name__.__eq__('Task') returns True — asyncio.Task is the primary coroutine-wrapping class in asyncio; Task.__name__=='Task' (len=4: 'T'+'a'+'s'+'k'=4); asyncio.Task is a concrete implementation of asyncio.Future that drives a coroutine to completion; when a coroutine is wrapped in a Task via asyncio.create_task() or loop.create_task(), the event loop schedules it for execution and Task monitors its progress; Task.__module__=='_asyncio' (len=8; same C extension as Future); Task.__bases__[0].__name__=='Future' (Task inherits directly from Future; Task IS a Future); compare: asyncio.Future.__name__=='Future' (len=6; Future is 2 chars longer than Task=4); asyncio.Handle.__name__=='Handle' (len=6; also 2 chars longer than Task=4); Task(4) has the shortest name in this spec; NEW in extra166: first standalone asyncio.Task.__name__ identity invariant in asynciotask166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.__name__.__eq__
  args: ["Task"]
  expected: true

invariant asyncio_extra166.asyncio_Task_base_is_Future:
  description: "asyncio.Task.__bases__[0].__name__.__eq__('Future') returns True — asyncio.Task.__bases__[0] is asyncio.Future; Task.__bases__[0].__name__=='Future' (len=6); Task inherits from Future via single-parent inheritance: Task.__bases__ == (<class '_asyncio.Future'>,) — exactly one base class; the MRO is: Task -> Future -> object; Task IS a Future — isinstance(asyncio_task, asyncio.Future) is True for any Task instance; Task extends Future by adding coroutine scheduling: Task holds a reference to its wrapped coroutine and calls coroutine.send(None) to step it forward, handling StopIteration (coroutine finished) and exceptions; the base class relationship (Task -> Future) means all Future state machine methods (add_done_callback, cancel, result, exception, set_result, set_exception) are available on Task; compare: asyncio.Task.__bases__[0].__name__.__len__()==6 ('Future'=6; same length as asyncio.Future.__name__.__len__()==6 — both verified in this spec); NEW in extra166: first standalone Task.__bases__[0].__name__ invariant in asynciotbh166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Task.__bases__[0].__name__.__eq__"
  args: ["Future"]
  expected: true

invariant asyncio_extra166.asyncio_Handle_name_eq:
  description: "asyncio.Handle.__name__.__eq__('Handle') returns True — asyncio.Handle is the opaque callback handle returned by loop scheduling methods; Handle.__name__=='Handle' (len=6: 'H'+'a'+'n'+'d'+'l'+'e'=6; same length as asyncio.Future.__name__=='Future' (len=6) — both are 6-char names); asyncio.Handle is returned by loop.call_soon(callback, *args), loop.call_soon_threadsafe(callback, *args); it represents a scheduled callback and can be cancelled by calling handle.cancel(); Handle.__module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14; Handle is pure Python in Lib/asyncio/events.py — unlike Future and Task which are C-accelerated in _asyncio); compare: asyncio.Handle and asyncio.Future both have 6-char names but different module origins — Handle is pure Python (asyncio.events) while Future is C-accelerated (_asyncio); NEW in extra166: first standalone asyncio.Handle.__name__ identity invariant in asynciotbh166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Handle.__name__.__eq__
  args: ["Handle"]
  expected: true

invariant asyncio_extra166.asyncio_Handle_module_eq:
  description: "asyncio.Handle.__module__.__eq__('asyncio.events') returns True — asyncio.Handle.__module__=='asyncio.events' (len=14: 'asyncio'=7+'.'=1+'events'=6=14); Handle is implemented in pure Python in Lib/asyncio/events.py; 'asyncio.events' len=14 contrasts with '_asyncio' len=8 (the module of Future and Task) — Handle's module path is 6 chars longer; 'events'=6 chars as the submodule name equals the class name 'Handle'=6 chars (a coincidence); asyncio.events is the module defining the abstract event loop interface and auxiliary types including Handle, TimerHandle, and AbstractEventLoop; compare: asyncio.StreamReader.__module__=='asyncio.streams' (len=15; 1 longer than asyncio.events=14 because 'streams'=7 > 'events'=6 by 1; established in extra164); asyncio.Queue.__module__=='asyncio.queues' (len=14; same length as asyncio.events=14 because 'queues'=6=='events'=6); NEW in extra166: first standalone asyncio.Handle.__module__ identity invariant in asynciotbh166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Handle.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra166.asyncio_Task_module_eq:
  description: "asyncio.Task.__module__.__eq__('_asyncio') returns True — asyncio.Task.__module__=='_asyncio' (len=8: '_'=1+'asyncio'=7=8; same C extension module as asyncio.Future); Task is implemented alongside Future in Modules/_asyncio.c in CPython; the C implementation of Task provides significant performance benefits for the core coroutine-driving loop (the step() method is called very frequently and benefits from C-level efficiency); asyncio.Task.__module__=='_asyncio' (len=8) == asyncio.Future.__module__=='_asyncio' (len=8) — both Future and Task share the same module because they are co-implemented in the same C extension; compare: asyncio.Handle.__module__=='asyncio.events' (len=14; Handle is pure Python); the _asyncio C module provides: asyncio.Future, asyncio.Task, asyncio.get_event_loop, asyncio.get_running_loop, asyncio.iscoroutine; NEW in extra166: first standalone asyncio.Task.__module__ identity invariant in asynciotask166 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.__module__.__eq__
  args: ["_asyncio"]
  expected: true

