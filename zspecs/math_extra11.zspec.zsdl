spec: math_extra11
version: ">=3.9"
backend: python_module(math)

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html — Python math documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mathmodule.c"
  notes:
    - "This spec extends math.zspec.zsdl and prior extras through math_extra10.zspec.zsdl."
    - "math_extra6 covers __qualname__ for floor/ceil/log/pow via table rows."
    - "math_extra8 covers __name__ as standalone invariants for atan/asin/acos/fsum."
    - "No prior spec covers floor.__name__, ceil.__name__, log.__name__, or pow.__name__ as standalone invariants."
    - "No prior spec covers floor(-3.7) == -4 (floor of a negative non-integer)."
    - "No prior spec covers ceil(-3.2) == -3 (ceil of a negative non-integer)."
    - "No prior spec covers math.pow(2, 10) == 1024.0 (integer power of two)."
    - "No prior spec covers math.pow(3, 3) == 27.0 (cube via math.pow)."
    - "math.floor.__name__ == 'floor' — floor is a module-level C builtin whose __name__ equals its string name."
    - "math.ceil.__name__ == 'ceil' — ceil is a module-level C builtin."
    - "math.log.__name__ == 'log' — log is a module-level C builtin."
    - "math.pow.__name__ == 'pow' — math.pow is distinct from the builtin pow; __name__ is 'pow'."
    - "math.floor(-3.7) == -4 — floor rounds toward negative infinity."
    - "math.ceil(-3.2) == -3 — ceil rounds toward positive infinity."
    - "math.pow(2, 10) == 1024.0 — 2^10 == 1024, result is always float."
    - "math.pow(3, 3) == 27.0 — 3^3 == 27, result is always float."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — floor / ceil / log / pow as standalone invariants
#
# math_extra6 covered __qualname__ for these four functions via table rows.
# math_extra8 covered __name__ for atan/asin/acos/fsum as standalone invariants.
# No prior spec covers floor/ceil/log/pow __name__ as standalone invariants.
# For module-level C builtins, __qualname__ == __name__, so both are the plain
# function name; the __name__ axis is a distinct, independently verifiable check.
# ---------------------------------------------------------------------------

invariant math_extra11.floor.function_name:
  description: "math.floor.__name__ == 'floor' — module-level builtin name attribute"
  category: function_names
  kind: python_call_eq
  function: floor.__name__.__eq__
  args: ["floor"]
  expected: true

invariant math_extra11.ceil.function_name:
  description: "math.ceil.__name__ == 'ceil' — module-level builtin name attribute"
  category: function_names
  kind: python_call_eq
  function: ceil.__name__.__eq__
  args: ["ceil"]
  expected: true

invariant math_extra11.log.function_name:
  description: "math.log.__name__ == 'log' — module-level builtin name attribute"
  category: function_names
  kind: python_call_eq
  function: log.__name__.__eq__
  args: ["log"]
  expected: true

invariant math_extra11.pow.function_name:
  description: "math.pow.__name__ == 'pow' — math.pow (C builtin) name attribute"
  category: function_names
  kind: python_call_eq
  function: pow.__name__.__eq__
  args: ["pow"]
  expected: true

# ---------------------------------------------------------------------------
# floor — negative non-integer value vectors
#
# math.zspec.zsdl and math_extra cover floor(3.7)==3 and floor(-3.0)==-3
# (integer-valued negative). No prior spec covers floor of a negative
# non-integer such as floor(-3.7) == -4 (rounds toward -infinity).
# ---------------------------------------------------------------------------

invariant math_extra11.floor.negative_noninteger:
  description: "math.floor(-3.7) == -4 — floor rounds toward negative infinity"
  category: rounding
  kind: python_call_eq
  function: floor
  args: [-3.7]
  expected: -4

invariant math_extra11.floor.negative_half:
  description: "math.floor(-0.5) == -1 — floor of negative half is -1, not 0"
  category: rounding
  kind: python_call_eq
  function: floor
  args: [-0.5]
  expected: -1

# ---------------------------------------------------------------------------
# ceil — negative non-integer value vectors
#
# No prior spec covers ceil of a negative non-integer. ceil(-3.2) == -3
# because ceil rounds toward positive infinity.
# ---------------------------------------------------------------------------

invariant math_extra11.ceil.negative_noninteger:
  description: "math.ceil(-3.2) == -3 — ceil rounds toward positive infinity"
  category: rounding
  kind: python_call_eq
  function: ceil
  args: [-3.2]
  expected: -3

invariant math_extra11.ceil.negative_half:
  description: "math.ceil(-0.5) == 0 — ceil of negative half rounds up to zero"
  category: rounding
  kind: python_call_eq
  function: ceil
  args: [-0.5]
  expected: 0

# ---------------------------------------------------------------------------
# math.pow — additional value vectors
#
# math.zspec.zsdl covers pow(2, 3)==8.0 and pow(9, 0.5)==3.0.
# No prior spec covers pow(2, 10) == 1024.0 or pow(3, 3) == 27.0.
# math.pow always returns a float, even for integer-valued results.
# ---------------------------------------------------------------------------

invariant math_extra11.pow.two_to_tenth:
  description: "math.pow(2, 10) == 1024.0 — 2^10 == 1024, returned as float"
  category: pow
  kind: python_call_eq
  function: pow
  args: [2, 10]
  expected: 1024.0

invariant math_extra11.pow.three_cubed:
  description: "math.pow(3, 3) == 27.0 — 3^3 == 27, returned as float"
  category: pow
  kind: python_call_eq
  function: pow
  args: [3, 3]
  expected: 27.0
