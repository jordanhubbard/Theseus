spec: dc3526
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 682 (dc3526): __set_name__, __init_subclass__, __class_getitem__ dict-presence checks for decimal types."
    - "All values false — decimal types do not implement class creation hooks or generic parameterization in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __set_name__ dict-presence — operator.contains(Cls.__dict__, '__set_name__')
# ---------------------------------------------------------------------------

table dc3526.set_name:
  description: "decimal types __set_name__ dict-presence checks; wave 682"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3526
  columns: [id, function, args, expected]
  rows:
    - ["dc3526001", operator.contains, [decimal.Decimal.__dict__,          "__set_name__"], false]
    - ["dc3526002", operator.contains, [decimal.Context.__dict__,          "__set_name__"], false]
