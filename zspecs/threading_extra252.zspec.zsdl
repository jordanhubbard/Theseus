spec: threading_extra252
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "This spec covers: threading.active_count, threading.enumerate, threading.main_thread, threading.get_ident, threading.settrace, threading.setprofile, and threading.stack_size function identity behavioral contracts."
    - "threading.active_count.__name__ == 'active_count' — active_count is a pure-Python function; __name__ is 'active_count'. Verified with Python 3.14.3."
    - "threading.active_count.__module__ == 'threading' — active_count is defined in the threading module; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.active_count.__class__.__name__ == 'function' — active_count is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "threading.enumerate.__name__ == 'enumerate' — threading.enumerate is a pure-Python function distinct from the built-in enumerate; __name__ is 'enumerate'. Verified with Python 3.14.3."
    - "threading.enumerate.__module__ == 'threading' — threading.enumerate is defined in the threading module; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.enumerate.__class__.__name__ == 'function' — threading.enumerate is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "threading.main_thread.__name__ == 'main_thread' — main_thread is a pure-Python function; __name__ is 'main_thread'. Verified with Python 3.14.3."
    - "threading.main_thread.__module__ == 'threading' — main_thread is defined in the threading module; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.get_ident.__name__ == 'get_ident' — get_ident is a C-level built-in from the _thread extension; __name__ is 'get_ident'. Verified with Python 3.14.3."
    - "threading.get_ident.__module__ == '_thread' — get_ident is implemented in the _thread C extension; __module__ is '_thread'. Verified with Python 3.14.3."
    - "threading.get_ident.__class__.__name__ == 'builtin_function_or_method' — get_ident is a C-level built-in; __class__.__name__ is 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "threading.settrace.__name__ == 'settrace' — settrace is a pure-Python function; __name__ is 'settrace'. Verified with Python 3.14.3."
    - "threading.settrace.__module__ == 'threading' — settrace is defined in the threading module; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.setprofile.__name__ == 'setprofile' — setprofile is a pure-Python function; __name__ is 'setprofile'. Verified with Python 3.14.3."
    - "threading.setprofile.__module__ == 'threading' — setprofile is defined in the threading module; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.stack_size.__name__ == 'stack_size' — stack_size is a C-level built-in from the _thread extension; __name__ is 'stack_size'. Verified with Python 3.14.3."
    - "threading.stack_size.__module__ == '_thread' — stack_size is implemented in the _thread C extension; __module__ is '_thread'. Verified with Python 3.14.3."
    - "threading.stack_size.__class__.__name__ == 'builtin_function_or_method' — stack_size is a C-level built-in. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.active_count and threading.enumerate function identity
#
# threading.active_count.__name__ == 'active_count'
# threading.active_count.__module__ == 'threading'
# threading.active_count.__class__.__name__ == 'function'
# threading.enumerate.__name__ == 'enumerate'
# threading.enumerate.__module__ == 'threading'
# threading.enumerate.__class__.__name__ == 'function'
#
# Both are pure-Python functions in the threading module. Note that
# threading.enumerate shadows the built-in enumerate within this module
# namespace but is a different function with __module__ == 'threading'.
# New to extra252.
# ---------------------------------------------------------------------------

table threading_extra252.active_count_enumerate_identity:
  description: "threading.active_count and threading.enumerate __name__, __module__, __class__.__name__ identity contracts; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: thdenumact252

  columns: [id, function, args, expected, description]
  rows:
    - [active_count_name_eq,
       active_count.__name__.__eq__,
       ["active_count"],
       true,
       "threading.active_count.__name__.__eq__('active_count') == True — active_count is a pure-Python function returning the number of Thread objects alive; __name__ is 'active_count'; new to extra252"]
    - [active_count_module_eq,
       active_count.__module__.__eq__,
       ["threading"],
       true,
       "threading.active_count.__module__.__eq__('threading') == True — active_count is defined in the threading module; __module__ is 'threading'; new to extra252"]
    - [active_count_class_name_eq,
       active_count.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.active_count.__class__.__name__.__eq__('function') == True — active_count is a plain Python function; __class__.__name__ is 'function'; new to extra252"]
    - [enumerate_name_eq,
       enumerate.__name__.__eq__,
       ["enumerate"],
       true,
       "threading.enumerate.__name__.__eq__('enumerate') == True — threading.enumerate is a pure-Python function listing all active Thread objects; __name__ is 'enumerate'; new to extra252"]
    - [enumerate_module_eq,
       enumerate.__module__.__eq__,
       ["threading"],
       true,
       "threading.enumerate.__module__.__eq__('threading') == True — threading.enumerate is defined in the threading module; __module__ is 'threading'; new to extra252"]

# ---------------------------------------------------------------------------
# Table 2: threading.main_thread and threading.get_ident function identity
#
# threading.main_thread.__name__ == 'main_thread'
# threading.main_thread.__module__ == 'threading'
# threading.main_thread.__class__.__name__ == 'function'
# threading.get_ident.__name__ == 'get_ident'
# threading.get_ident.__module__ == '_thread'
# threading.get_ident.__class__.__name__ == 'builtin_function_or_method'
#
# main_thread is pure-Python; get_ident is a C-level built-in from _thread.
# New to extra252.
# ---------------------------------------------------------------------------

table threading_extra252.main_thread_get_ident_identity:
  description: "threading.main_thread and threading.get_ident __name__, __module__, __class__.__name__ identity contracts; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: thdmainident252

  columns: [id, function, args, expected, description]
  rows:
    - [main_thread_name_eq,
       main_thread.__name__.__eq__,
       ["main_thread"],
       true,
       "threading.main_thread.__name__.__eq__('main_thread') == True — main_thread is a pure-Python function returning the main Thread object; __name__ is 'main_thread'; new to extra252"]
    - [main_thread_module_eq,
       main_thread.__module__.__eq__,
       ["threading"],
       true,
       "threading.main_thread.__module__.__eq__('threading') == True — main_thread is defined in the threading module; __module__ is 'threading'; new to extra252"]
    - [main_thread_class_name_eq,
       main_thread.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.main_thread.__class__.__name__.__eq__('function') == True — main_thread is a plain Python function; __class__.__name__ is 'function'; new to extra252"]
    - [get_ident_name_eq,
       get_ident.__name__.__eq__,
       ["get_ident"],
       true,
       "threading.get_ident.__name__.__eq__('get_ident') == True — get_ident is a C-level built-in returning the current thread identifier; __name__ is 'get_ident'; new to extra252"]
    - [get_ident_module_eq,
       get_ident.__module__.__eq__,
       ["_thread"],
       true,
       "threading.get_ident.__module__.__eq__('_thread') == True — get_ident is implemented in the _thread C extension; __module__ is '_thread'; new to extra252"]

# ---------------------------------------------------------------------------
# Table 3: threading.settrace, threading.setprofile, threading.stack_size
#
# threading.settrace.__name__ == 'settrace'
# threading.settrace.__module__ == 'threading'
# threading.setprofile.__name__ == 'setprofile'
# threading.setprofile.__module__ == 'threading'
# threading.stack_size.__name__ == 'stack_size'
# threading.stack_size.__module__ == '_thread'
# threading.stack_size.__class__.__name__ == 'builtin_function_or_method'
#
# settrace and setprofile are pure-Python; stack_size is a C-level built-in
# from the _thread extension, like get_ident. New to extra252.
# ---------------------------------------------------------------------------

table threading_extra252.settrace_setprofile_stack_size_identity:
  description: "threading.settrace, threading.setprofile, threading.stack_size __name__, __module__, __class__.__name__ identity contracts; new to extra252"
  kind: python_call_eq
  category: identity
  id_prefix: thdtrace252

  columns: [id, function, args, expected, description]
  rows:
    - [settrace_name_eq,
       settrace.__name__.__eq__,
       ["settrace"],
       true,
       "threading.settrace.__name__.__eq__('settrace') == True — settrace sets a trace function for all new threads; __name__ is 'settrace'; new to extra252"]
    - [settrace_module_eq,
       settrace.__module__.__eq__,
       ["threading"],
       true,
       "threading.settrace.__module__.__eq__('threading') == True — settrace is defined in the threading module; __module__ is 'threading'; new to extra252"]
    - [setprofile_name_eq,
       setprofile.__name__.__eq__,
       ["setprofile"],
       true,
       "threading.setprofile.__name__.__eq__('setprofile') == True — setprofile sets a profile function for all new threads; __name__ is 'setprofile'; new to extra252"]
    - [setprofile_module_eq,
       setprofile.__module__.__eq__,
       ["threading"],
       true,
       "threading.setprofile.__module__.__eq__('threading') == True — setprofile is defined in the threading module; __module__ is 'threading'; new to extra252"]
    - [stack_size_module_eq,
       stack_size.__module__.__eq__,
       ["_thread"],
       true,
       "threading.stack_size.__module__.__eq__('_thread') == True — stack_size is a C-level built-in from the _thread extension; __module__ is '_thread'; new to extra252"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra252
# ---------------------------------------------------------------------------

invariant threading_extra252.active_count.name_eq:
  description: "threading.active_count.__name__ == 'active_count' — pure-Python function counting alive Thread objects; new to extra252"
  category: identity
  kind: python_call_eq
  function: active_count.__name__.__eq__
  args: ["active_count"]
  expected: true

invariant threading_extra252.active_count.module_eq:
  description: "threading.active_count.__module__ == 'threading' — defined in the threading module; new to extra252"
  category: identity
  kind: python_call_eq
  function: active_count.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra252.active_count.class_is_function:
  description: "threading.active_count.__class__.__name__ == 'function' — active_count is a plain Python function; new to extra252"
  category: identity
  kind: python_call_eq
  function: active_count.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra252.active_count.name_len_12:
  description: "threading.active_count.__name__.__len__() == 12 — 'active_count' has 12 characters; new to extra252"
  category: identity
  kind: python_call_eq
  function: active_count.__name__.__len__
  args: []
  expected: 12

invariant threading_extra252.enumerate.name_eq:
  description: "threading.enumerate.__name__ == 'enumerate' — pure-Python function listing all active Thread objects; new to extra252"
  category: identity
  kind: python_call_eq
  function: enumerate.__name__.__eq__
  args: ["enumerate"]
  expected: true

invariant threading_extra252.enumerate.module_eq:
  description: "threading.enumerate.__module__ == 'threading' — defined in the threading module, distinct from the built-in enumerate; new to extra252"
  category: identity
  kind: python_call_eq
  function: enumerate.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra252.enumerate.class_is_function:
  description: "threading.enumerate.__class__.__name__ == 'function' — threading.enumerate is a plain Python function; new to extra252"
  category: identity
  kind: python_call_eq
  function: enumerate.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra252.main_thread.name_eq:
  description: "threading.main_thread.__name__ == 'main_thread' — pure-Python function returning the main Thread object; new to extra252"
  category: identity
  kind: python_call_eq
  function: main_thread.__name__.__eq__
  args: ["main_thread"]
  expected: true

invariant threading_extra252.main_thread.module_eq:
  description: "threading.main_thread.__module__ == 'threading' — defined in the threading module; new to extra252"
  category: identity
  kind: python_call_eq
  function: main_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra252.main_thread.name_len_11:
  description: "threading.main_thread.__name__.__len__() == 11 — 'main_thread' has 11 characters; new to extra252"
  category: identity
  kind: python_call_eq
  function: main_thread.__name__.__len__
  args: []
  expected: 11

invariant threading_extra252.get_ident.name_eq:
  description: "threading.get_ident.__name__ == 'get_ident' — C-level built-in returning the current thread identifier integer; new to extra252"
  category: identity
  kind: python_call_eq
  function: get_ident.__name__.__eq__
  args: ["get_ident"]
  expected: true

invariant threading_extra252.get_ident.module_eq:
  description: "threading.get_ident.__module__ == '_thread' — implemented in the _thread C extension; new to extra252"
  category: identity
  kind: python_call_eq
  function: get_ident.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra252.get_ident.class_is_builtin:
  description: "threading.get_ident.__class__.__name__ == 'builtin_function_or_method' — get_ident is a C-level built-in; new to extra252"
  category: identity
  kind: python_call_eq
  function: get_ident.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant threading_extra252.get_ident.name_len_9:
  description: "threading.get_ident.__name__.__len__() == 9 — 'get_ident' has 9 characters; new to extra252"
  category: identity
  kind: python_call_eq
  function: get_ident.__name__.__len__
  args: []
  expected: 9

invariant threading_extra252.settrace.name_eq:
  description: "threading.settrace.__name__ == 'settrace' — pure-Python function setting trace function for new threads; new to extra252"
  category: identity
  kind: python_call_eq
  function: settrace.__name__.__eq__
  args: ["settrace"]
  expected: true

invariant threading_extra252.settrace.module_eq:
  description: "threading.settrace.__module__ == 'threading' — defined in the threading module; new to extra252"
  category: identity
  kind: python_call_eq
  function: settrace.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra252.setprofile.name_eq:
  description: "threading.setprofile.__name__ == 'setprofile' — pure-Python function setting profile function for new threads; new to extra252"
  category: identity
  kind: python_call_eq
  function: setprofile.__name__.__eq__
  args: ["setprofile"]
  expected: true

invariant threading_extra252.setprofile.module_eq:
  description: "threading.setprofile.__module__ == 'threading' — defined in the threading module; new to extra252"
  category: identity
  kind: python_call_eq
  function: setprofile.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra252.stack_size.name_eq:
  description: "threading.stack_size.__name__ == 'stack_size' — C-level built-in for getting/setting thread stack size; new to extra252"
  category: identity
  kind: python_call_eq
  function: stack_size.__name__.__eq__
  args: ["stack_size"]
  expected: true

invariant threading_extra252.stack_size.module_eq:
  description: "threading.stack_size.__module__ == '_thread' — stack_size is implemented in the _thread C extension; new to extra252"
  category: identity
  kind: python_call_eq
  function: stack_size.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra252.stack_size.class_is_builtin:
  description: "threading.stack_size.__class__.__name__ == 'builtin_function_or_method' — stack_size is a C-level built-in; new to extra252"
  category: identity
  kind: python_call_eq
  function: stack_size.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant threading_extra252.stack_size.name_len_10:
  description: "threading.stack_size.__name__.__len__() == 10 — 'stack_size' has 10 characters; new to extra252"
  category: identity
  kind: python_call_eq
  function: stack_size.__name__.__len__
  args: []
  expected: 10
