spec: struct_extra616
version: ">=3.9"
backend: python_module(struct)
docs: "https://docs.python.org/3/library/struct.html"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers struct.Struct descriptor attributes and pack/unpack module-level function identity"
  created_at: "2026-04-12T00:00:00Z"

table struct_extra616.struct_descriptors:
  description: "Class name checks for struct.Struct descriptor attributes"
  kind: python_call_eq
  category: descriptor_identity
  id_prefix: st616pr
  columns: [id, function, args, expected]
  rows:
    - [st616pr001, struct.Struct.format.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [st616pr002, struct.Struct.size.__class__.__name__.__eq__, ["getset_descriptor"], true]

table struct_extra616.struct_qualnames:
  description: "Qualified name checks for struct.Struct attributes and methods"
  kind: python_call_eq
  category: function_identity
  id_prefix: st616fn
  columns: [id, function, args, expected]
  rows:
    - [st616fn001, struct.Struct.format.__qualname__.__eq__, ["Struct.format"], true]
    - [st616fn002, struct.Struct.size.__qualname__.__eq__, ["Struct.size"], true]
    - [st616fn003, struct.Struct.pack.__qualname__.__eq__, ["Struct.pack"], true]
    - [st616fn004, struct.Struct.unpack.__qualname__.__eq__, ["Struct.unpack"], true]
    - [st616fn005, struct.Struct.pack_into.__qualname__.__eq__, ["Struct.pack_into"], true]
    - [st616fn006, struct.Struct.unpack_from.__qualname__.__eq__, ["Struct.unpack_from"], true]
    - [st616fn007, struct.Struct.iter_unpack.__qualname__.__eq__, ["Struct.iter_unpack"], true]

table struct_extra616.struct_module_attrs:
  description: "Module-level pack/unpack identity and struct.error bases class check"
  kind: python_call_eq
  category: function_identity
  id_prefix: st616ma
  columns: [id, function, args, expected]
  rows:
    - [st616ma001, struct.error.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [st616ma002, struct.pack.__module__.__eq__, ["struct"], true]
    - [st616ma003, struct.unpack.__module__.__eq__, ["struct"], true]
