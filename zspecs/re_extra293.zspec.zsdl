spec: re_extra293
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module constants, flags, and function types"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py, Modules/_sre.c"
  notes:
    - "re module functions are Python functions wrapping the _sre C extension"
    - "re.NOFLAG == 0 (no flags set)"
    - "re.I == re.IGNORECASE == 2"
    - "re.L == re.LOCALE == 4"
    - "re.U == re.UNICODE == 32"
    - "re.A == re.ASCII == 256"
    - "All top-level re functions have __class__.__name__ == 'function'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table re_extra293.function_class_names:
  description: "re module top-level functions are Python functions"
  kind: python_call_eq
  category: identity
  id_prefix: re293a

  columns: [id, function, args, expected, description]
  rows:
    - [re293a001, re.compile.__class__.__name__.__eq__, ["function"], true, "re.compile is a Python function"]
    - [re293a002, re.match.__class__.__name__.__eq__, ["function"], true, "re.match is a Python function"]
    - [re293a003, re.search.__class__.__name__.__eq__, ["function"], true, "re.search is a Python function"]
    - [re293a004, re.sub.__class__.__name__.__eq__, ["function"], true, "re.sub is a Python function"]
    - [re293a005, re.subn.__class__.__name__.__eq__, ["function"], true, "re.subn is a Python function"]
    - [re293a006, re.split.__class__.__name__.__eq__, ["function"], true, "re.split is a Python function"]
    - [re293a007, re.findall.__class__.__name__.__eq__, ["function"], true, "re.findall is a Python function"]
    - [re293a008, re.finditer.__class__.__name__.__eq__, ["function"], true, "re.finditer is a Python function"]
    - [re293a009, re.escape.__class__.__name__.__eq__, ["function"], true, "re.escape is a Python function"]
    - [re293a010, re.purge.__class__.__name__.__eq__, ["function"], true, "re.purge is a Python function"]

table re_extra293.flag_values:
  description: "re flag integer values and class names"
  kind: python_call_eq
  category: identity
  id_prefix: re293b

  columns: [id, function, args, expected, description]
  rows:
    - [re293b001, re.NOFLAG.__eq__, [0], true, "re.NOFLAG == 0"]
    - [re293b002, re.NOFLAG.__class__.__name__.__eq__, ["RegexFlag"], true, "re.NOFLAG is a RegexFlag"]
    - [re293b003, re.L.__eq__, [4], true, "re.L (LOCALE) == 4"]
    - [re293b004, re.L.__class__.__name__.__eq__, ["RegexFlag"], true, "re.L is a RegexFlag"]
    - [re293b005, re.A.__eq__, [256], true, "re.A (ASCII) == 256"]
    - [re293b006, re.A.__class__.__name__.__eq__, ["RegexFlag"], true, "re.A is a RegexFlag"]
    - [re293b007, re.U.__eq__, [32], true, "re.U (UNICODE) == 32"]
    - [re293b008, re.U.__class__.__name__.__eq__, ["RegexFlag"], true, "re.U is a RegexFlag"]
    - [re293b009, re.I.__eq__, [2], true, "re.I (IGNORECASE) == 2"]
    - [re293b010, re.I.__class__.__name__.__eq__, ["RegexFlag"], true, "re.I is a RegexFlag"]

invariant re_extra293.noflag_is_zero:
  description: "re.NOFLAG equals integer 0"
  category: identity
  kind: python_call_eq
  function: re.NOFLAG.__eq__
  args: [0]
  expected: true

invariant re_extra293.locale_is_four:
  description: "re.L (LOCALE) equals integer 4"
  category: identity
  kind: python_call_eq
  function: re.L.__eq__
  args: [4]
  expected: true

invariant re_extra293.ascii_is_256:
  description: "re.A (ASCII) equals integer 256"
  category: identity
  kind: python_call_eq
  function: re.A.__eq__
  args: [256]
  expected: true
