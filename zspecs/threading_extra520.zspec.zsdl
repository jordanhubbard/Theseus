spec: threading_extra520
backend: python_module(threading)

---

table:
  id: condition_method_names
  columns: [id, function, args, expected]
  kind: python_call_eq
  rows:
    - [cond_acquire_name,    Condition.acquire.__name__.__eq__,    ["acquire"],    true]
    - [cond_release_name,    Condition.release.__name__.__eq__,    ["release"],    true]
    - [cond_wait_name,       Condition.wait.__name__.__eq__,       ["wait"],       true]
    - [cond_wait_for_name,   Condition.wait_for.__name__.__eq__,   ["wait_for"],   true]
    - [cond_notify_name,     Condition.notify.__name__.__eq__,     ["notify"],     true]
    - [cond_notify_all_name, Condition.notify_all.__name__.__eq__, ["notify_all"], true]
    - [cond_enter_name,      Condition.__enter__.__name__.__eq__,  ["__enter__"],  true]
    - [cond_exit_name,       Condition.__exit__.__name__.__eq__,   ["__exit__"],   true]

table:
  id: semaphore_method_names
  columns: [id, function, args, expected]
  kind: python_call_eq
  rows:
    - [sema_acquire_name, Semaphore.acquire.__name__.__eq__, ["acquire"], true]
    - [sema_release_name, Semaphore.release.__name__.__eq__, ["release"], true]

table:
  id: event_method_names
  columns: [id, function, args, expected]
  kind: python_call_eq
  rows:
    - [event_set_name,    Event.set.__name__.__eq__,    ["set"],    true]
    - [event_clear_name,  Event.clear.__name__.__eq__,  ["clear"],  true]
    - [event_wait_name,   Event.wait.__name__.__eq__,   ["wait"],   true]
    - [event_is_set_name, Event.is_set.__name__.__eq__, ["is_set"], true]
