spec: threading_extra520
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Checks __name__ identity for Condition, Semaphore, and Event methods"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra520.condition_method_names:
  description: "threading.Condition method __name__ identity"
  kind: python_call_eq
  category: method_names
  id_prefix: th520cn

  columns: [id, function, args, expected]
  rows:
    - [th520cn001, threading.Condition.acquire.__name__.__eq__,    ["acquire"],    true]
    - [th520cn002, threading.Condition.release.__name__.__eq__,    ["release"],    true]
    - [th520cn003, threading.Condition.wait.__name__.__eq__,       ["wait"],       true]
    - [th520cn004, threading.Condition.wait_for.__name__.__eq__,   ["wait_for"],   true]
    - [th520cn005, threading.Condition.notify.__name__.__eq__,     ["notify"],     true]
    - [th520cn006, threading.Condition.notify_all.__name__.__eq__, ["notify_all"], true]
    - [th520cn007, threading.Condition.__enter__.__name__.__eq__,  ["__enter__"],  true]
    - [th520cn008, threading.Condition.__exit__.__name__.__eq__,   ["__exit__"],   true]

table threading_extra520.semaphore_method_names:
  description: "threading.Semaphore method __name__ identity"
  kind: python_call_eq
  category: method_names
  id_prefix: th520sn

  columns: [id, function, args, expected]
  rows:
    - [th520sn001, threading.Semaphore.acquire.__name__.__eq__, ["acquire"], true]
    - [th520sn002, threading.Semaphore.release.__name__.__eq__, ["release"], true]

table threading_extra520.event_method_names:
  description: "threading.Event method __name__ identity"
  kind: python_call_eq
  category: method_names
  id_prefix: th520en

  columns: [id, function, args, expected]
  rows:
    - [th520en001, threading.Event.set.__name__.__eq__,    ["set"],    true]
    - [th520en002, threading.Event.clear.__name__.__eq__,  ["clear"],  true]
    - [th520en003, threading.Event.wait.__name__.__eq__,   ["wait"],   true]
    - [th520en004, threading.Event.is_set.__name__.__eq__, ["is_set"], true]
