spec: hashlib_extra50
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra49.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256 __class__.__name__.__eq__('builtin_function_or_method') and new __class__.__name__.__eq__('function'); blake2b/blake2s excluded (extra44 covers those)."
    - "hashlib_extra48.zspec.zsdl — covers blake2b/blake2s __name__.__eq__ string eq and __mro__ entry __name__.__eq__."
    - "hashlib_extra47.zspec.zsdl — covers sha3_512.__module__.__eq__('_hashlib') and sha3_512.__module__.__len__()==8."
    - "hashlib_extra44.zspec.zsdl — covers blake2b/blake2s __class__.__name__.__eq__('type')."
    - "hashlib_extra18.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/new __name__.__eq__ and __qualname__.__eq__ string values."
    - "hashlib_extra6.zspec.zsdl — covers blake2b/blake2s __module__.__eq__('_blake2')."
  notes:
    - "This spec extends hashlib through hashlib_extra49; it does NOT duplicate invariants present in those files."
    - "Coverage gap: No prior hashlib spec checks __class__.__qualname__.__eq__ for sha256, md5, sha1, pbkdf2_hmac, sha3_256, new, blake2b, or blake2s as module-level callables. The __class__.__qualname__ axis mirrors __class__.__name__ for non-nested types and provides additional regression coverage. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__class__.__qualname__ == 'builtin_function_or_method'. sha256 is a C-level constructor; its class's __qualname__ matches its __name__ (non-nested builtin type). No prior spec checks sha256.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.md5.__class__.__qualname__ == 'builtin_function_or_method'. Same C-level calling convention as sha256. No prior spec checks md5.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__class__.__qualname__ == 'builtin_function_or_method'. Same C-level calling convention as sha256 and md5. No prior spec checks sha1.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__class__.__qualname__ == 'builtin_function_or_method'. pbkdf2_hmac is a C builtin function in the _hashlib extension. No prior spec checks pbkdf2_hmac.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__class__.__qualname__ == 'builtin_function_or_method'. sha3_256 is exposed as a C-level builtin_function_or_method (openssl-backed). No prior spec checks sha3_256.__class__.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__qualname__ == 'function'. new is a Python-level wrapper function; its class (the built-in function type) has __qualname__ == 'function'. No prior spec checks new.__class__.__qualname__.__eq__('function'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__class__.__qualname__ == 'type'. blake2b is a C extension type; its metaclass is the built-in type whose __qualname__ is 'type'. No prior spec checks blake2b.__class__.__qualname__.__eq__('type'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__class__.__qualname__ == 'type'. Same as blake2b. No prior spec checks blake2s.__class__.__qualname__.__eq__('type'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__class__.__module__ == 'builtins'. The builtin_function_or_method type lives in the builtins module. No prior spec checks sha256.__class__.__module__.__eq__('builtins'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__module__ == 'builtins'. The built-in function type (to which Python functions belong) has __module__ == 'builtins'. No prior spec checks new.__class__.__module__.__eq__('builtins'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__class__.__module__ == 'builtins'. The metaclass of C extension types is the built-in type, whose __module__ is 'builtins'. No prior spec checks blake2b.__class__.__module__.__eq__('builtins'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib module-level callable __class__.__qualname__.__eq__ string values
#
# hashlib_extra49 covers __class__.__name__.__eq__ for sha256/md5/sha1/pbkdf2_hmac/
# sha3_256 ('builtin_function_or_method') and new ('function').
# hashlib_extra44 covers blake2b/blake2s __class__.__name__.__eq__('type').
# No prior spec checks __class__.__qualname__.__eq__ for any hashlib callable.
# This table adds blake2b and blake2s (excluded from extra49) because the
# __class__.__qualname__ axis is novel for all eight callables.
# ---------------------------------------------------------------------------

table hashlib_extra50.callable_class_qualnames:
  description: "hashlib sha256/md5/sha1/pbkdf2_hmac/sha3_256 __class__.__qualname__.__eq__('builtin_function_or_method'), new __class__.__qualname__.__eq__('function'), blake2b/blake2s __class__.__qualname__.__eq__('type') — novel __class__.__qualname__ axis; no prior hashlib spec checks __class__.__qualname__.__eq__ for any of these callables"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibclsqual50

  columns: [id, function, args, expected]
  rows:
    - [sha256_class_qualname_eq,      sha256.__class__.__qualname__.__eq__,      ["builtin_function_or_method"], true]
    - [md5_class_qualname_eq,         md5.__class__.__qualname__.__eq__,         ["builtin_function_or_method"], true]
    - [sha1_class_qualname_eq,        sha1.__class__.__qualname__.__eq__,        ["builtin_function_or_method"], true]
    - [pbkdf2_hmac_class_qualname_eq, pbkdf2_hmac.__class__.__qualname__.__eq__, ["builtin_function_or_method"], true]
    - [sha3_256_class_qualname_eq,    sha3_256.__class__.__qualname__.__eq__,    ["builtin_function_or_method"], true]
    - [new_class_qualname_eq,         new.__class__.__qualname__.__eq__,         ["function"],                   true]
    - [blake2b_class_qualname_eq,     blake2b.__class__.__qualname__.__eq__,     ["type"],                       true]
    - [blake2s_class_qualname_eq,     blake2s.__class__.__qualname__.__eq__,     ["type"],                       true]

# ---------------------------------------------------------------------------
# hashlib module-level callable __class__.__module__.__eq__ string values
#
# All hashlib module-level callables have their __class__ defined in builtins:
#   builtin_function_or_method.__module__ == 'builtins'
#   function.__module__ == 'builtins'
#   type.__module__ == 'builtins'
# No prior hashlib spec checks __class__.__module__.__eq__('builtins') for any
# of these objects. Three representative rows cover each distinct __class__ kind.
# ---------------------------------------------------------------------------

table hashlib_extra50.callable_class_modules:
  description: "hashlib sha256/new/blake2b __class__.__module__.__eq__('builtins') — all hashlib module-level callable metaclasses/types are defined in builtins; novel __class__.__module__ axis; no prior hashlib spec checks __class__.__module__.__eq__('builtins') for any hashlib callable"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibclsmod50

  columns: [id, function, args, expected]
  rows:
    - [sha256_class_module_eq,  sha256.__class__.__module__.__eq__,  ["builtins"], true]
    - [new_class_module_eq,     new.__class__.__module__.__eq__,     ["builtins"], true]
    - [blake2b_class_module_eq, blake2b.__class__.__module__.__eq__, ["builtins"], true]
