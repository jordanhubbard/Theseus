spec: decimal_extra976
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module Decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal.Decimal arithmetic operator method __qualname__ identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra976.decimal_arith_qualnames:
  description: "decimal.Decimal binary arithmetic operator method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: dc976a
  columns: [id, function, args, expected]
  rows:
    - [dc976a001, decimal.Decimal.__add__.__qualname__.__eq__,      ["Decimal.__add__"],      true]
    - [dc976a002, decimal.Decimal.__sub__.__qualname__.__eq__,      ["Decimal.__sub__"],      true]
    - [dc976a003, decimal.Decimal.__mul__.__qualname__.__eq__,      ["Decimal.__mul__"],      true]
    - [dc976a004, decimal.Decimal.__truediv__.__qualname__.__eq__,  ["Decimal.__truediv__"],  true]
    - [dc976a005, decimal.Decimal.__mod__.__qualname__.__eq__,      ["Decimal.__mod__"],      true]
    - [dc976a006, decimal.Decimal.__pow__.__qualname__.__eq__,      ["Decimal.__pow__"],      true]

table decimal_extra976.decimal_unary_qualnames:
  description: "decimal.Decimal unary operator method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: dc976u
  columns: [id, function, args, expected]
  rows:
    - [dc976u001, decimal.Decimal.__neg__.__qualname__.__eq__, ["Decimal.__neg__"], true]
    - [dc976u002, decimal.Decimal.__abs__.__qualname__.__eq__, ["Decimal.__abs__"], true]
    - [dc976u003, decimal.Decimal.__pos__.__qualname__.__eq__, ["Decimal.__pos__"], true]

table decimal_extra976.decimal_reflect_qualnames:
  description: "decimal.Decimal reflected arithmetic operator method __qualname__ identity"
  kind: python_call_eq
