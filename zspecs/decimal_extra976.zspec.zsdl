  columns: [id, function, args, expected]
  rows:
    - [dc976r001, decimal.Decimal.__radd__.__qualname__.__eq__,     ["Decimal.__radd__"],     true]
    - [dc976r002, decimal.Decimal.__rsub__.__qualname__.__eq__,     ["Decimal.__rsub__"],     true]
    - [dc976r003, decimal.Decimal.__rmul__.__qualname__.__eq__,     ["Decimal.__rmul__"],     true]
    - [dc976r004, decimal.Decimal.__rtruediv__.__qualname__.__eq__, ["Decimal.__rtruediv__"], true]
    - [dc976r005, decimal.Decimal.__rmod__.__qualname__.__eq__,     ["Decimal.__rmod__"],     true]
    - [dc976r006, decimal.Decimal.__rpow__.__qualname__.__eq__,     ["Decimal.__rpow__"],     true]

table decimal_extra976.decimal_module_identity:
  description: "decimal.Decimal class-level module and name identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: dc976m
  columns: [id, function, args, expected]
  rows:
    - [dc976m001, decimal.Decimal.__module__.__eq__,         ["decimal"], true]
    - [dc976m002, decimal.Decimal.__name__.__eq__,           ["Decimal"], true]
    - [dc976m003, decimal.Decimal.__class__.__name__.__eq__, ["type"],    true]
    - [dc976m004, decimal.Context.__module__.__eq__,         ["decimal"], true]
    - [dc976m005, decimal.Context.__name__.__eq__,           ["Context"], true]
