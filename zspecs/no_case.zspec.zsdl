spec: no_case
version: ">=3.0.0"
backend: node(no-case)

docs: https://www.npmjs.com/package/no-case

provenance:
  derived_from:
    - "no-case README — https://www.npmjs.com/package/no-case"
    - "Test vectors verified with no-case@3.0.4 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "no-case source"
  notes:
    - "no-case exports {noCase} named function."
    - "noCase converts string to lower case with spaces."
    - "Splits camelCase, PascalCase, snake_case, kebab-case inputs."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns lower case string with space separators."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table no_case.no_case:
  kind: node_module_call_eq
  function: noCase
  category: noCase
  id_prefix: ncase

  columns: [id, args, expected]
  rows:
    - [camel,   ["fooBar"],     "foo bar"]
    - [pascal,  ["FooBar"],     "foo bar"]
    - [snake,   ["foo_bar"],    "foo bar"]
    - [dash,    ["foo-bar"],    "foo bar"]
    - [multi,   ["fooBarBaz"],  "foo bar baz"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T21:47:33Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
