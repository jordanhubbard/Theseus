spec: struct_extra2761
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra276.zspec.zsdl — covers mixed-format calcsize, pack/unpack vectors for BB and !BH, and struct.error raising."
    - "struct_extra275.zspec.zsdl — covers little-endian pack/unpack vectors for H/I/Q formats and calcsize for '<HI'/'<HIQ'."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "struct.Struct.__dict__.__contains__('__matmul__') == False — struct.Struct is a binary format descriptor, not a numeric type; it defines no matrix multiplication operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__truediv__') == False — struct.Struct defines no true division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__iadd__') == False — struct.Struct defines no in-place addition operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__matmul__') == False — struct.error is an Exception subclass; exceptions never define matrix multiplication; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__truediv__') == False — struct.error defines no true division operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__iadd__') == False — struct.error defines no in-place addition operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct.__dict__ — __matmul__, __truediv__, __iadd__ absence
# struct.Struct is the compiled format object returned by struct.Struct(fmt).
# It exposes pack/unpack/pack_into/unpack_from/iter_unpack methods and the
# size/format attributes. None of the arithmetic or matrix operators apply.
# ---------------------------------------------------------------------------

table struct_extra2761.struct_dict_matmul_truediv_iadd:
  description: "struct.Struct.__dict__ does not contain __matmul__, __truediv__, or __iadd__ — Struct is a binary format descriptor, not a numeric type; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2761

  columns: [id, function, args, expected]
  rows:
    - ["st2761-struct-matmul",  struct.Struct.__dict__.__contains__,  ["__matmul__"],  false]
    - ["st2761-struct-truediv", struct.Struct.__dict__.__contains__,  ["__truediv__"], false]
    - ["st2761-struct-iadd",    struct.Struct.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Table 2: struct.error.__dict__ — __matmul__, __truediv__, __iadd__ absence
# struct.error is a subclass of Exception raised on pack/unpack failures.
# Exception types never define arithmetic operators in their own __dict__.
# ---------------------------------------------------------------------------

table struct_extra2761.error_dict_matmul_truediv_iadd:
  description: "struct.error.__dict__ does not contain __matmul__, __truediv__, or __iadd__ — struct.error is an Exception subclass; exception types define no arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2761

  columns: [id, function, args, expected]
  rows:
    - ["st2761-error-matmul",  struct.error.__dict__.__contains__,  ["__matmul__"],  false]
    - ["st2761-error-truediv", struct.error.__dict__.__contains__,  ["__truediv__"], false]
    - ["st2761-error-iadd",    struct.error.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct.__dict__ — per-dunder detail with descriptions
# ---------------------------------------------------------------------------

table struct_extra2761.struct_dict_detail:
  description: "struct.Struct.__dict__ operator absence detail — __matmul__, __truediv__, and __iadd__ are not defined because Struct is a packing/unpacking tool, not a numeric operand; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2761

  columns: [id, function, args, expected, description]
  rows:
    - ["st2761-d-matmul",  struct.Struct.__dict__.__contains__, ["__matmul__"],  false, "struct.Struct does not support @ — binary format descriptors are not matrix operands"]
    - ["st2761-d-truediv", struct.Struct.__dict__.__contains__, ["__truediv__"], false, "struct.Struct does not support / — division has no meaning for a format descriptor"]
    - ["st2761-d-iadd",    struct.Struct.__dict__.__contains__, ["__iadd__"],    false, "struct.Struct does not support += — no in-place accumulation semantics"]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — Struct and error both lack all three dunders
# ---------------------------------------------------------------------------

table struct_extra2761.all_types_all_dunders_absent:
  description: "struct.Struct and struct.error both lack __matmul__, __truediv__, and __iadd__ in __dict__ — neither struct type defines arithmetic or matrix operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2761

  columns: [id, function, args, expected]
  rows:
    - ["st2761-x-struct-matmul",  struct.Struct.__dict__.__contains__, ["__matmul__"],  false]
    - ["st2761-x-struct-truediv", struct.Struct.__dict__.__contains__, ["__truediv__"], false]
    - ["st2761-x-struct-iadd",    struct.Struct.__dict__.__contains__, ["__iadd__"],    false]
    - ["st2761-x-error-matmul",   struct.error.__dict__.__contains__,  ["__matmul__"],  false]
    - ["st2761-x-error-truediv",  struct.error.__dict__.__contains__,  ["__truediv__"], false]
    - ["st2761-x-error-iadd",     struct.error.__dict__.__contains__,  ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra2761.struct_no_matmul:
  description: "struct.Struct.__dict__.__contains__('__matmul__') == False — struct.Struct does not define the @ operator; it is a binary packing/unpacking tool, not a matrix-capable numeric type; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__matmul__"]
  expected: false

invariant struct_extra2761.struct_no_truediv:
  description: "struct.Struct.__dict__.__contains__('__truediv__') == False — struct.Struct does not define the / operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__truediv__"]
  expected: false

invariant struct_extra2761.struct_no_iadd:
  description: "struct.Struct.__dict__.__contains__('__iadd__') == False — struct.Struct does not define the += operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__iadd__"]
  expected: false

invariant struct_extra2761.error_no_matmul:
  description: "struct.error.__dict__.__contains__('__matmul__') == False — struct.error (Exception subclass) does not define the @ operator; exception types carry no arithmetic semantics; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__matmul__"]
  expected: false

invariant struct_extra2761.error_no_truediv:
  description: "struct.error.__dict__.__contains__('__truediv__') == False — struct.error does not define the / operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__truediv__"]
  expected: false

invariant struct_extra2761.error_no_iadd:
  description: "struct.error.__dict__.__contains__('__iadd__') == False — struct.error does not define the += operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__iadd__"]
  expected: false
