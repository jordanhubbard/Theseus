spec: functools_extra2686
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/functools.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 626 theme: __and__, __or__, and __xor__ dict-presence checks (bitwise AND, OR, XOR operators)."
    - "functools.partial is a callable wrapper; it does not implement bitwise operator protocols."
    - "functools.partialmethod is a descriptor; it similarly defines none of __and__, __or__, or __xor__."
    - "functools.cached_property is a data descriptor (defines __get__, __set__, __delete__) but not __and__, __or__, or __xor__."
    - "functools.singledispatchmethod is a descriptor wrapper; it does not define __and__, __or__, or __xor__."
    - "None of the functools public classes define __and__, __or__, or __xor__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __and__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2686.and_protocol:
  description: "__and__ is absent from all functools class __dict__s — none implement bitwise AND"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2686

  columns: [id, function, args, expected]
  rows:
    - ["ft2686001", "functools.partial.__dict__.__contains__",              ["__and__"], false]
    - ["ft2686002", "functools.partialmethod.__dict__.__contains__",        ["__and__"], false]
    - ["ft2686003", "functools.cached_property.__dict__.__contains__",      ["__and__"], false]
    - ["ft2686004", "functools.singledispatchmethod.__dict__.__contains__",  ["__and__"], false]

# ---------------------------------------------------------------------------
# __or__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2686.or_protocol:
  description: "__or__ is absent from all functools class __dict__s — none implement bitwise OR"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2686

  columns: [id, function, args, expected]
  rows:
    - ["ft2686005", "functools.partial.__dict__.__contains__",              ["__or__"], false]
    - ["ft2686006", "functools.partialmethod.__dict__.__contains__",        ["__or__"], false]
    - ["ft2686007", "functools.cached_property.__dict__.__contains__",      ["__or__"], false]
    - ["ft2686008", "functools.singledispatchmethod.__dict__.__contains__",  ["__or__"], false]

# ---------------------------------------------------------------------------
# __xor__ dict-presence — absent from all functools classes
# ---------------------------------------------------------------------------

table functools_extra2686.xor_protocol:
  description: "__xor__ is absent from all functools class __dict__s — none implement bitwise XOR"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2686

  columns: [id, function, args, expected]
  rows:
    - ["ft2686009", "functools.partial.__dict__.__contains__",              ["__xor__"], false]
    - ["ft2686010", "functools.partialmethod.__dict__.__contains__",        ["__xor__"], false]
    - ["ft2686011", "functools.cached_property.__dict__.__contains__",      ["__xor__"], false]
    - ["ft2686012", "functools.singledispatchmethod.__dict__.__contains__",  ["__xor__"], false]

# ---------------------------------------------------------------------------
# Combined view — partial and partialmethod vs. all three protocols
# ---------------------------------------------------------------------------

table functools_extra2686.partial_bitwise_combined:
  description: "functools.partial and functools.partialmethod define none of __and__, __or__, __xor__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2686

  columns: [id, function, args, expected]
  rows:
    - ["ft2686013", "functools.partial.__dict__.__contains__",       ["__and__"],  false]
    - ["ft2686014", "functools.partial.__dict__.__contains__",       ["__or__"],   false]
    - ["ft2686015", "functools.partial.__dict__.__contains__",       ["__xor__"],  false]
    - ["ft2686016", "functools.partialmethod.__dict__.__contains__", ["__and__"],  false]
    - ["ft2686017", "functools.partialmethod.__dict__.__contains__", ["__or__"],   false]
    - ["ft2686018", "functools.partialmethod.__dict__.__contains__", ["__xor__"],  false]
