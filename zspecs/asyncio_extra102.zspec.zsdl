invariant asyncio_extra102.asyncio_name_len_is_7:
  description: "asyncio.__name__.__len__() == 7 — asyncio.__name__ is 'asyncio' (7 characters: a-s-y-n-c-i-o); this contrasts with submodule names like asyncio.tasks (len=13), asyncio.events (len=14), asyncio.streams (len=15), asyncio.protocols (len=17); asyncio.__package__ is also 'asyncio' (len=7) — for top-level packages __package__ equals __name__; asyncio.__spec__.name is also 'asyncio' (len=7); all three (__name__, __package__, spec.name) share the same 7-character value; asyncio.__name__.__class__.__name__ is 'str'; NEW in extra102: first standalone asyncio module name length invariant in asynciomodident102 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: asyncio.__name__.__len__
  args: []
  expected: 7

invariant asyncio_extra102.asyncio_package_equals_name:
  description: "asyncio.__package__.__eq__('asyncio') returns True — asyncio.__package__ is 'asyncio', which equals asyncio.__name__; for top-level packages (packages not nested within another package), __package__ always equals __name__; this contrasts with submodules like asyncio.tasks where asyncio.tasks.__package__ would be 'asyncio' (the parent package name, not the submodule's own __name__); asyncio.__spec__.name is also 'asyncio' confirming the three-way equality (__name__ == __package__ == __spec__.name == 'asyncio'); asyncio is a directory-based package (not a namespace package) with __init__.py; NEW in extra102: first standalone asyncio.__package__ equality invariant in asynciomodident102 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: asyncio.__package__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra102.asyncio_spec_class_is_ModuleSpec:
  description: "asyncio.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — asyncio.__spec__ is an instance of importlib.machinery.ModuleSpec; ModuleSpec is the standard module spec class used by Python's import system for all regular packages and modules; asyncio.__spec__.name is 'asyncio'; asyncio.__spec__.has_location is True (asyncio/__init__.py exists on the filesystem); asyncio.__spec__.submodule_search_locations.__class__.__name__ is 'list' (the package directory search paths); asyncio is a regular package (not a frozen module like abc, not a C extension); NEW in extra102: first standalone asyncio __spec__ class name invariant in asynciomodident102 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: asyncio.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant asyncio_extra102.asyncio_submodule_search_locations_is_list:
  description: "asyncio.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') returns True — asyncio.__spec__.submodule_search_locations is a plain Python list containing the directory path(s) where asyncio submodules are searched; this is 'list' (not '_NamespacePath' which is used for namespace packages); asyncio is a regular directory package (Lib/asyncio/__init__.py in CPython) so its submodule_search_locations is a concrete list; this contrasts with single-file modules which have submodule_search_locations==None; the list contains one path: the asyncio package directory; NEW in extra102: first standalone asyncio submodule_search_locations class name invariant in asynciomodident102 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: asyncio.__spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant asyncio_extra102.asyncio_protocols_name_len_is_17:
  description: "asyncio.protocols.__name__.__len__() == 17 — asyncio.protocols.__name__ is 'asyncio.protocols' (17 chars: 'asyncio.'=8 + 'protocols'=9); this is the longest submodule __name__ among the commonly-used asyncio submodules covered in this spec: tasks=13, locks=13, queues=14, events=14, streams=15, runners=15, protocols=17; 'protocols' is a 9-character suffix, making the full dotted name 17 chars; asyncio.protocols defines the Protocol base classes for asyncio transports (Protocol, DatagramProtocol, SubprocessProtocol, BaseProtocol); asyncio.protocols.__name__.__class__.__name__ is 'str'; NEW in extra102: first standalone asyncio.protocols name length invariant in asynciomodident102 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: asyncio.protocols.__name__.__len__
  args: []
  expected: 17

