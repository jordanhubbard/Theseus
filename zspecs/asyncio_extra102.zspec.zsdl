#
# asyncio.__name__                                         == 'asyncio'    (len=7)
# asyncio.__package__                                      == 'asyncio'
# asyncio.__spec__.__class__.__name__                      == 'ModuleSpec'
# asyncio.__spec__.name                                    == 'asyncio'
# asyncio.__spec__.submodule_search_locations.__class__.__name__ == 'list'
# asyncio.__spec__.has_location                            == True
# asyncio.__file__.__class__.__name__                      == 'str'
# ---------------------------------------------------------------------------

table asyncio_extra102.asyncio_module_identity:
  description: "asyncio module __name__, __package__, and __spec__ identity checks in asynciomodident102 namespace — wave 254 theme: asyncio is a top-level package; asyncio.__name__.__eq__('asyncio')==True (len=7: a-s-y-n-c-i-o); asyncio.__name__.__len__()==7; asyncio.__package__.__eq__('asyncio')==True (for top-level packages, __package__ equals __name__); asyncio.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (spec is an importlib.machinery.ModuleSpec instance); asyncio.__spec__.name.__eq__('asyncio')==True (spec.name matches __name__); asyncio.__spec__.submodule_search_locations.__class__.__name__.__eq__('list')==True (asyncio is a directory package; submodule_search_locations is a list containing the asyncio package directory); asyncio.__spec__.has_location.__eq__(True)==True (asyncio has a file-system origin); asyncio.__file__.__class__.__name__.__eq__('str')==True (path to asyncio/__init__.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: asynciomodident102

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,       asyncio.__name__.__eq__,                                              ["asyncio"],   true, "asyncio.__name__ == 'asyncio'; verified with Python 3.14.3"]
    - [name_len,      asyncio.__name__.__len__,                                             [],            7,    "asyncio.__name__.__len__() == 7 (a-s-y-n-c-i-o); verified with Python 3.14.3"]
    - [pkg_eq,        asyncio.__package__.__eq__,                                           ["asyncio"],   true, "asyncio.__package__ == 'asyncio' (equals __name__ for top-level packages); verified with Python 3.14.3"]
    - [spec_cls,      asyncio.__spec__.__class__.__name__.__eq__,                           ["ModuleSpec"], true, "asyncio.__spec__.__class__.__name__ == 'ModuleSpec'; verified with Python 3.14.3"]
    - [spec_name,     asyncio.__spec__.name.__eq__,                                         ["asyncio"],   true, "asyncio.__spec__.name == 'asyncio'; verified with Python 3.14.3"]
    - [submod_locs,   asyncio.__spec__.submodule_search_locations.__class__.__name__.__eq__, ["list"],      true, "asyncio.__spec__.submodule_search_locations.__class__.__name__ == 'list' (directory package); verified with Python 3.14.3"]
    - [has_loc,       asyncio.__spec__.has_location.__eq__,                                 [true],        true, "asyncio.__spec__.has_location == True (file-system origin); verified with Python 3.14.3"]
    - [file_cls,      asyncio.__file__.__class__.__name__.__eq__,                           ["str"],       true, "asyncio.__file__.__class__.__name__ == 'str' (path to asyncio/__init__.py); verified with Python 3.14.3"]

