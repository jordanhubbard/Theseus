spec: pathlib_extra269
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
  notes:
    - "All PurePosixPath tests are platform-independent; no filesystem access is required."
    - "__truediv__ is chained with __str__ to compare the resulting path as a string."
    - "PurePosixPath('.').name returns an empty string — the current-directory path has no filename component."
    - "pathlib.Path('.') on macOS returns a PosixPath instance; type(Path('.')).__name__ == 'PosixPath'."
    - "str(Path('.')) == '.' — the dot path is preserved as-is."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PurePosixPath __truediv__ — joining with /
# ---------------------------------------------------------------------------

invariant pathlib_extra269.truediv.usr_local:
  description: "PurePosixPath('/usr') / 'local' as string == '/usr/local'"
  category: operators
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr"]
  method: __truediv__
  method_args: ["local"]
  method_chain: __str__
  expected: "/usr/local"

invariant pathlib_extra269.truediv.home_user_docs:
  description: "PurePosixPath('/home/user') / 'docs' as string == '/home/user/docs'"
  category: operators
  kind: python_call_eq
  function: PurePosixPath
  args: ["/home/user"]
  method: __truediv__
  method_args: ["docs"]
  method_chain: __str__
  expected: "/home/user/docs"

invariant pathlib_extra269.truediv.result_type:
  description: "type of PurePosixPath('/usr') / 'local' has __class__.__name__ == 'PurePosixPath'"
  category: operators
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr"]
  method: __truediv__
  method_args: ["local"]
  method_chain: __class__.__name__
  expected: "PurePosixPath"

# ---------------------------------------------------------------------------
# PurePosixPath __str__ — string representation
# ---------------------------------------------------------------------------

invariant pathlib_extra269.str.usr_local:
  description: "str(PurePosixPath('/usr/local')) == '/usr/local'"
  category: str_repr
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local"]
  method: __str__
  expected: "/usr/local"

invariant pathlib_extra269.str.dot:
  description: "str(PurePosixPath('.')) == '.'"
  category: str_repr
  kind: python_call_eq
  function: PurePosixPath
  args: ["."]
  method: __str__
  expected: "."

# ---------------------------------------------------------------------------
# PurePosixPath parent
# ---------------------------------------------------------------------------

invariant pathlib_extra269.parent.usr_local:
  description: "PurePosixPath('/usr/local').parent as string == '/usr'"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local"]
  method: parent
  method_chain: __str__
  expected: "/usr"

# ---------------------------------------------------------------------------
# PurePosixPath name
# ---------------------------------------------------------------------------

invariant pathlib_extra269.name.bin:
  description: "PurePosixPath('/usr/local/bin').name == 'bin'"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["/usr/local/bin"]
  method: name
  expected: "bin"

invariant pathlib_extra269.name.dot_is_empty:
  description: "PurePosixPath('.').name == '' — current-dir path has no name component"
  category: components
  kind: python_call_eq
  function: PurePosixPath
  args: ["."]
  method: name
  expected: ""

# ---------------------------------------------------------------------------
# pathlib.Path on macOS — concrete class is PosixPath
# ---------------------------------------------------------------------------

invariant pathlib_extra269.Path.dot_class_name:
  description: "Path('.').__class__.__name__ == 'PosixPath' on macOS/POSIX"
  category: identity
  kind: python_call_eq
  function: Path
  args: ["."]
  method: __class__.__name__.__eq__
  method_args: ["PosixPath"]
  expected: true

invariant pathlib_extra269.Path.dot_str:
  description: "str(Path('.')) == '.'"
  category: str_repr
  kind: python_call_eq
  function: Path
  args: ["."]
  method: __str__
  expected: "."
