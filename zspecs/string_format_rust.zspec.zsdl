spec: string_format_rust
version: ">=3.9"
backend: rust_module(string_format_rust)

docs: https://docs.python.org/3/library/string.html#format-string-syntax

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string documentation"
  not_derived_from:
    - "CPython source: Objects/stringlib/unicode_format.h"
  notes:
    - "string.Formatter().format() — not covered by string_extra_rust (which covers format_field)."
    - "Formatter().format(template, *args) formats a string using {0}, {1} positional placeholders."
    - "Formatter().format('{0}, {1}!', 'Hello', 'World') == 'Hello, World!'."
    - "Formatter().format('{0:.2f}', 3.14159) == '3.14' — float format spec."
    - "Formatter().format('{:>10}', 'hi') == '        hi' — right-align in 10 chars."
    - "Formatter().format('{0} + {1} = {2}', 1, 2, 3) == '1 + 2 = 3'."
    - "Formatter().format('{0!r}', 'hello') == \"'hello'\" — repr conversion."
    - "All test vectors verified against Python 3.14.3 string module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# Formatter().format — positional substitution
table string_format_rust.format.positional:
  kind: python_call_eq
  category: format
  id_prefix: sf_pos
  function: Formatter
  args: []
  method: format

  columns: [id, method_args, expected]
  rows:
    - [two_args,    ["{0}, {1}!", "Hello", "World"],  "Hello, World!"]
    - [three_args,  ["{0} + {1} = {2}", 1, 2, 3],    "1 + 2 = 3"]
    - [no_args,     ["no placeholders"],               "no placeholders"]
    - [repeated,    ["{0} {0} {0}", "go"],             "go go go"]

# Formatter().format — format specs
table string_format_rust.format.specs:
  kind: python_call_eq
  category: format
  id_prefix: sf_spec
  function: Formatter
  args: []
  method: format

  columns: [id, method_args, expected]
  rows:
    - [float_2dp,    ["{0:.2f}", 3.14159],   "3.14"]
    - [right_align,  ["{:>10}", "hi"],        "        hi"]
    - [left_align,   ["{:<10}", "hi"],        "hi        "]
    - [zero_pad,     ["{:05d}", 42],          "00042"]
    - [plus_sign,    ["{:+d}", 42],           "+42"]

