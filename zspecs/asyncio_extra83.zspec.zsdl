spec: asyncio_extra83
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra82.zspec.zsdl."
    - "This spec covers: wave 245 theme — asyncio Lock/Event/Semaphore __module__ and __dict__ membership. NEW in extra83: Lock.__module__=='asyncio.locks'; Event.__module__=='asyncio.locks'; Semaphore.__module__=='asyncio.locks'; BoundedSemaphore.__module__=='asyncio.locks'; Condition.__module__=='asyncio.locks'; Lock.__dict__.__contains__('acquire')==True; Lock.__dict__.__contains__('release')==True; Event.__dict__.__contains__('set')==True; Event.__dict__.__contains__('clear')==True; Event.__dict__.__contains__('wait')==True; Semaphore.__dict__.__contains__('acquire')==True; Semaphore.__dict__.__contains__('release')==True; Condition.__dict__.__contains__('notify')==True; Condition.__dict__.__contains__('wait')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__module__ == 'asyncio.locks'. Lock is defined in the asyncio.locks submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__module__ == 'asyncio.locks'. Event is defined in the asyncio.locks submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__module__ == 'asyncio.locks'. Semaphore is defined in the asyncio.locks submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks'. BoundedSemaphore is defined in the asyncio.locks submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__module__ == 'asyncio.locks'. Condition is defined in the asyncio.locks submodule. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__dict__.__contains__('acquire') == True. acquire is defined directly on Lock. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__dict__.__contains__('release') == True. release is defined directly on Lock. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__dict__.__contains__('set') == True. set is defined directly on Event. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__dict__.__contains__('clear') == True. clear is defined directly on Event. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__dict__.__contains__('wait') == True. wait is defined directly on Event. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__dict__.__contains__('acquire') == True. acquire is defined directly on Semaphore. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__dict__.__contains__('release') == True. release is defined directly on Semaphore. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__dict__.__contains__('notify') == True. notify is defined directly on Condition. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__dict__.__contains__('wait') == True. wait is defined directly on Condition. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Lock/Event/Semaphore __module__ checks — extra83
#
# Wave 245 theme: asyncio Lock/Event/Semaphore __module__ and __dict__ membership.
#
# Lock.__module__ == 'asyncio.locks'
# Event.__module__ == 'asyncio.locks'
# Semaphore.__module__ == 'asyncio.locks'
# BoundedSemaphore.__module__ == 'asyncio.locks'
# Condition.__module__ == 'asyncio.locks'
# ---------------------------------------------------------------------------

table asyncio_extra83.lock_event_semaphore_modules:
  description: "asyncio Lock/Event/Semaphore/BoundedSemaphore/Condition __module__ checks in asyncioextra83 namespace — wave 245 theme: asyncio Lock/Event/Semaphore __module__ and __dict__ membership; Lock.__module__=='asyncio.locks'; Event.__module__=='asyncio.locks'; Semaphore.__module__=='asyncio.locks'; BoundedSemaphore.__module__=='asyncio.locks'; Condition.__module__=='asyncio.locks'; all synchronization primitives are defined in the asyncio.locks submodule; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra83

  columns: [id, function, args, expected, description]
  rows:
    - [lock_module,             Lock.__module__.__eq__,              ["asyncio.locks"], true, "Lock.__module__ == 'asyncio.locks' — Lock is defined in asyncio.locks submodule; verified with Python 3.14.3"]
    - [event_module,            Event.__module__.__eq__,             ["asyncio.locks"], true, "Event.__module__ == 'asyncio.locks' — Event is defined in asyncio.locks submodule; verified with Python 3.14.3"]
    - [semaphore_module,        Semaphore.__module__.__eq__,         ["asyncio.locks"], true, "Semaphore.__module__ == 'asyncio.locks' — Semaphore is defined in asyncio.locks submodule; verified with Python 3.14.3"]
    - [bounded_sem_module,      BoundedSemaphore.__module__.__eq__,  ["asyncio.locks"], true, "BoundedSemaphore.__module__ == 'asyncio.locks' — BoundedSemaphore is defined in asyncio.locks submodule; verified with Python 3.14.3"]
    - [condition_module,        Condition.__module__.__eq__,         ["asyncio.locks"], true, "Condition.__module__ == 'asyncio.locks' — Condition is defined in asyncio.locks submodule; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Lock __dict__ membership checks — extra83
#
# Lock.__dict__.__contains__('acquire') == True
# Lock.__dict__.__contains__('release') == True
# ---------------------------------------------------------------------------

table asyncio_extra83.Lock_dict_membership:
  description: "asyncio Lock __dict__ membership checks in asyncioextra83 namespace — wave 245 theme: asyncio Lock/Event/Semaphore __dict__ membership; Lock.__dict__.__contains__('acquire')==True (acquire is defined directly on Lock); Lock.__dict__.__contains__('release')==True (release is defined directly on Lock); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra83a

  columns: [id, function, args, expected, description]
  rows:
    - [lock_has_acquire, "Lock.__dict__.__contains__", ["acquire"], true, "Lock.__dict__.__contains__('acquire') == True — acquire is defined directly on Lock; verified with Python 3.14.3"]
    - [lock_has_release, "Lock.__dict__.__contains__", ["release"], true, "Lock.__dict__.__contains__('release') == True — release is defined directly on Lock; verified with Python 3.14.3"]

