table asyncio_extra83.Semaphore_and_Condition_dict_membership:
  description: "asyncio Semaphore and Condition __dict__ membership checks in asyncioextra83 namespace — wave 245 theme: asyncio Semaphore/Condition __dict__ membership; Semaphore.__dict__.__contains__('acquire')==True; Semaphore.__dict__.__contains__('release')==True; Condition.__dict__.__contains__('notify')==True; Condition.__dict__.__contains__('wait')==True; Lock.__module__=='asyncio.locks' (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra83c

  columns: [id, function, args, expected, description]
  rows:
    - [sem_has_acquire,   "Semaphore.__dict__.__contains__",  ["acquire"], true, "Semaphore.__dict__.__contains__('acquire') == True — acquire is defined directly on Semaphore; verified with Python 3.14.3"]
    - [sem_has_release,   "Semaphore.__dict__.__contains__",  ["release"], true, "Semaphore.__dict__.__contains__('release') == True — release is defined directly on Semaphore; verified with Python 3.14.3"]
    - [cond_has_notify,   "Condition.__dict__.__contains__",  ["notify"],  true, "Condition.__dict__.__contains__('notify') == True — notify is defined directly on Condition; verified with Python 3.14.3"]
