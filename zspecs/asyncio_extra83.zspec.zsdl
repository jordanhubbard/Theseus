# ---------------------------------------------------------------------------
# Standalone invariants — extra83
# ---------------------------------------------------------------------------

invariant asyncio_extra83.Lock_module:
  description: "asyncio.Lock.__module__.__eq__('asyncio.locks') returns True — Lock is defined in the asyncio.locks submodule, not asyncio directly; NEW in extra83: first standalone __module__ invariant for Lock in asyncioextra83 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra83.Event_module:
  description: "asyncio.Event.__module__.__eq__('asyncio.locks') returns True — Event is defined in the asyncio.locks submodule alongside Lock; NEW in extra83: first standalone __module__ invariant for Event in asyncioextra83 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra83.Lock_has_acquire:
  description: "asyncio.Lock.__dict__.__contains__('acquire') returns True — acquire is defined directly on Lock, not inherited from a base class; NEW in extra83: first standalone __dict__.__contains__ invariant for Lock.acquire in asyncioextra83 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Lock.__dict__.__contains__
  args: ["acquire"]
  expected: true

invariant asyncio_extra83.Event_has_set:
  description: "asyncio.Event.__dict__.__contains__('set') returns True — set is defined directly on Event to signal all waiting coroutines; NEW in extra83: first standalone __dict__.__contains__ invariant for Event.set in asyncioextra83 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Event.__dict__.__contains__
  args: ["set"]
  expected: true

invariant asyncio_extra83.Condition_has_notify:
  description: "asyncio.Condition.__dict__.__contains__('notify') returns True — notify is defined directly on Condition to wake one waiting coroutine; NEW in extra83: first standalone __dict__.__contains__ invariant for Condition.notify in asyncioextra83 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Condition.__dict__.__contains__
  args: ["notify"]
  expected: true
