spec: hashlib_extra946
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib module identity, algorithm sets, and constructor name attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra946.module_identity:
  description: "hashlib module-level identity attributes"
  kind: python_call_eq
  category: module_identity
  id_prefix: hl946mi
  columns: [id, function, args, expected]
  rows:
    - [hl946mi001, hashlib.__name__.__eq__,         ["hashlib"], true]
    - [hl946mi002, hashlib.__package__.__eq__,      [""],        true]
    - [hl946mi003, hashlib.__spec__.name.__eq__,    ["hashlib"], true]
    - [hl946mi004, hashlib.__name__.__class__.__name__.__eq__, ["str"], true]
    - [hl946mi005, hashlib.__package__.__class__.__name__.__eq__, ["str"], true]

table hashlib_extra946.algorithm_sets:
  description: "hashlib algorithms_available and algorithms_guaranteed set identity"
  kind: python_call_eq
  category: algorithm_sets
  id_prefix: hl946as
  columns: [id, function, args, expected]
  rows:
    - [hl946as001, hashlib.algorithms_available.__class__.__name__.__eq__,  ["set"],      true]
    - [hl946as002, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["frozenset"], true]
    - [hl946as003, hashlib.algorithms_available.__class__.__name__.__eq__,  ["frozenset"], false]
    - [hl946as004, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["set"],       false]
    - [hl946as005, hashlib.algorithms_guaranteed.__class__.__module__.__eq__, ["builtins"], true]

table hashlib_extra946.constructor_names:
  description: "hashlib constructor __name__ attributes"
  kind: python_call_eq
  category: constructor_names
  id_prefix: hl946cn
  columns: [id, function, args, expected]
  rows:
    - [hl946cn001, hashlib.md5.__name__.__class__.__name__.__eq__,    ["str"],  true]
    - [hl946cn002, hashlib.sha256.__name__.__class__.__name__.__eq__, ["str"],  true]
    - [hl946cn003, hashlib.sha1.__name__.__class__.__name__.__eq__,   ["str"],  true]
    - [hl946cn004, hashlib.sha512.__name__.__class__.__name__.__eq__, ["str"],  true]
    - [hl946cn005, hashlib.md5.__module__.__class__.__name__.__eq__,  ["str"],  true]
