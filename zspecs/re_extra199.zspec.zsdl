spec: re_extra199
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape, and compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern/Match class names, error class, flag constants, match/search/sub/split/findall"
  notes:
    - "This spec covers re.Match object method qualnames not already in re.zspec.zsdl or re_extra.zspec.zsdl."
    - "re.Match.group.__qualname__ == 'Match.group' — method defined on the Match class."
    - "re.Match.groups.__qualname__ == 'Match.groups' — method defined on the Match class."
    - "re.Match.start.__qualname__ == 'Match.start' — method defined on the Match class."
    - "re.Match.end.__qualname__ == 'Match.end' — method defined on the Match class."
    - "re.Match.span.__qualname__ == 'Match.span' — method defined on the Match class."
    - "re.Match.groupdict.__qualname__ == 'Match.groupdict' — method defined on the Match class."
    - "re.Match.__repr__.__qualname__ == 'Match.__repr__' — dunder method defined on the Match class."
    - "re.Match.__getitem__.__qualname__ == 'Match.__getitem__' — dunder method defined on the Match class."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match core method qualnames — group, groups, start, end
# ---------------------------------------------------------------------------

table re_extra199.match_core_qualnames:
  description: "re.Match core method qualnames in remotematch199 namespace — group, groups, start, end qualnames all use 'Match.' prefix; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: remotematch199

  columns: [id, function, args, expected, description]
  rows:
    - [group_qn,  Match.group.__qualname__.__eq__,  ["Match.group"],  true, "re.Match.group.__qualname__ == 'Match.group' (len=11); verified with Python 3.14.3"]
    - [groups_qn, Match.groups.__qualname__.__eq__, ["Match.groups"], true, "re.Match.groups.__qualname__ == 'Match.groups' (len=12); verified with Python 3.14.3"]
    - [start_qn,  Match.start.__qualname__.__eq__,  ["Match.start"],  true, "re.Match.start.__qualname__ == 'Match.start' (len=11); verified with Python 3.14.3"]
    - [end_qn,    Match.end.__qualname__.__eq__,    ["Match.end"],    true, "re.Match.end.__qualname__ == 'Match.end' (len=9); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# re.Match span/groupdict method qualnames
# ---------------------------------------------------------------------------

table re_extra199.match_span_groupdict_qualnames:
  description: "re.Match span and groupdict method qualnames in remotematch199 namespace — span, groupdict qualnames use 'Match.' prefix; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: remotematch199b

  columns: [id, function, args, expected, description]
  rows:
    - [span_qn,      Match.span.__qualname__.__eq__,      ["Match.span"],      true, "re.Match.span.__qualname__ == 'Match.span' (len=10); verified with Python 3.14.3"]
    - [groupdict_qn, Match.groupdict.__qualname__.__eq__, ["Match.groupdict"], true, "re.Match.groupdict.__qualname__ == 'Match.groupdict' (len=15); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# re.Match dunder method qualnames — __repr__, __getitem__
# ---------------------------------------------------------------------------

table re_extra199.match_dunder_qualnames:
  description: "re.Match dunder method qualnames in remotematch199 namespace — __repr__ and __getitem__ qualnames use 'Match.' prefix; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: remotematch199c

  columns: [id, function, args, expected, description]
  rows:
    - [repr_qn,    "Match.__repr__.__qualname__.__eq__",    ["Match.__repr__"],    true, "re.Match.__repr__.__qualname__ == 'Match.__repr__' (len=14); verified with Python 3.14.3"]
    - [getitem_qn, "Match.__getitem__.__qualname__.__eq__", ["Match.__getitem__"], true, "re.Match.__getitem__.__qualname__ == 'Match.__getitem__' (len=17); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — remotematch199
# ---------------------------------------------------------------------------

invariant re_extra199.Match.group_qualname_eq:
  description: "re.Match.group.__qualname__.__eq__('Match.group') returns True — group(0) returns the entire match, group(N) returns the Nth capturing group; qualname 'Match.group' has len=11 ('Match.'=6+'group'=5=11); compare: start qualname='Match.start' also len=11; end qualname='Match.end' len=9 (shortest); groupdict qualname='Match.groupdict' len=15; NEW in re_extra199: first standalone Match.group qualname invariant in remotematch199 namespace; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true

invariant re_extra199.Match.groups_qualname_len:
  description: "re.Match.groups.__qualname__.__len__() == 12 — 'Match.groups' has 12 chars ('Match.'=6+'groups'=6=12); groups() returns a tuple of all capturing groups; compare: group qualname='Match.group' len=11; span qualname='Match.span' len=10; end qualname='Match.end' len=9 (shortest); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Match.groups.__qualname__.__len__
  args: []
  expected: 12

invariant re_extra199.Match.start_qualname_len:
  description: "re.Match.start.__qualname__.__len__() == 11 — 'Match.start' has 11 chars ('Match.'=6+'start'=5=11); start() returns the index of the start of the match (or the start of a group); compare: group qualname='Match.group' also len=11; end qualname='Match.end' len=9; span qualname='Match.span' len=10; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Match.start.__qualname__.__len__
  args: []
  expected: 11

invariant re_extra199.Match.end_qualname_len:
  description: "re.Match.end.__qualname__.__len__() == 9 — 'Match.end' has 9 chars ('Match.'=6+'end'=3=9) — shortest method qualname in this spec; end() returns the index past the end of the match (or the end of a group); compare: span qualname='Match.span' len=10; start/group len=11; __getitem__ qualname='Match.__getitem__' len=17 (longest); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Match.end.__qualname__.__len__
  args: []
  expected: 9

invariant re_extra199.Match.span_qualname_len:
  description: "re.Match.span.__qualname__.__len__() == 10 — 'Match.span' has 10 chars ('Match.'=6+'span'=4=10); span() returns a 2-tuple (m.start(group), m.end(group)); compare: end len=9; start/group len=11; groups len=12; groupdict len=15; __repr__ len=14; __getitem__ len=17; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Match.span.__qualname__.__len__
  args: []
  expected: 10

invariant re_extra199.Match.groupdict_qualname_eq:
  description: "re.Match.groupdict.__qualname__.__eq__('Match.groupdict') returns True — groupdict() returns a dict containing all named subgroups; qualname 'Match.groupdict' has len=15 ('Match.'=6+'groupdict'=9=15); compare: __repr__ qualname='Match.__repr__' len=14; __getitem__ qualname='Match.__getitem__' len=17 (longest); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Match.groupdict.__qualname__.__eq__
  args: ["Match.groupdict"]
  expected: true

invariant re_extra199.Match.repr_qualname_len:
  description: "re.Match.__repr__.__qualname__.__len__() == 14 — 'Match.__repr__' has 14 chars ('Match.'=6+'__repr__'=8=14); __repr__ returns a string representation of the match object; compare: groupdict qualname='Match.groupdict' len=15; __getitem__ qualname='Match.__getitem__' len=17 (longest); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "Match.__repr__.__qualname__.__len__"
  args: []
  expected: 14

invariant re_extra199.Match.getitem_qualname_len:
  description: "re.Match.__getitem__.__qualname__.__len__() == 17 — 'Match.__getitem__' has 17 chars ('Match.'=6+'__getitem__'=11=17) — longest method qualname in this spec; __getitem__ enables subscript access m[0] (equivalent to m.group(0)); compare: groupdict len=15, __repr__ len=14, groups len=12; end len=9 (shortest); compare all qualname lengths: end=9, span=10, group=11, start=11, groups=12, __repr__=14, groupdict=15, __getitem__=17; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "Match.__getitem__.__qualname__.__len__"
  args: []
  expected: 17

