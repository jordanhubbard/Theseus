spec: struct_extra1636
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
    - "CPython source: Modules/_struct.c"
  notes:
    - "behavioral invariants for ABC virtual subclassing protocol"
    - "struct.Struct is a C extension type; it does not define __subclasshook__, __instancecheck__, or __subclasscheck__ in its own __dict__."
    - "struct.error is a Python exception class (subclass of Exception) and also lacks these ABC hooks in its own __dict__."
    - "isinstance(struct.Struct('>H'), struct.Struct) is True via normal class machinery."
    - "isinstance(struct.error('test'), struct.error) is True; isinstance(struct.error('test'), Exception) is True."
    - "issubclass(struct.error, Exception) is True; issubclass(struct.error, struct.error) is True."
    - "struct.Struct.format stores the format string as a str on Python 3.12+ (was bytes in older builds)."
    - "struct.Struct.size equals calcsize(format_string) for the same format."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: struct.Struct and struct.error __dict__ lacks ABC hook methods
#
# struct.Struct is a C extension type. struct.error is a Python class that
# inherits from Exception. Neither defines __subclasshook__, __instancecheck__,
# or __subclasscheck__ in its own __dict__ — these are not ABCs.
# ---------------------------------------------------------------------------

table struct_extra1636.struct_no_virtual_subclassing:
  description: "struct.Struct and struct.error do not define ABC virtual-subclassing hooks in their __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1636

  columns: [id, function, args, expected]
  rows:
    - ["st1636001", "Struct.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["st1636002", "Struct.__dict__.__contains__", ["__instancecheck__"], false]
    - ["st1636003", "Struct.__dict__.__contains__", ["__subclasscheck__"], false]
    - ["st1636004", "error.__dict__.__contains__",  ["__subclasshook__"],  false]
    - ["st1636005", "error.__dict__.__contains__",  ["__instancecheck__"], false]
    - ["st1636006", "error.__dict__.__contains__",  ["__subclasscheck__"], false]
    - ["st1636007", "Struct.__dict__.__contains__", ["pack"],              true]
    - ["st1636008", "Struct.__dict__.__contains__", ["unpack"],            true]
    - ["st1636009", "Struct.__dict__.__contains__", ["pack_into"],         true]
    - ["st1636010", "Struct.__dict__.__contains__", ["unpack_from"],       true]
    - ["st1636011", "Struct.__dict__.__contains__", ["iter_unpack"],       true]
    - ["st1636012", "Struct.__dict__.__contains__", ["format"],            true]
    - ["st1636013", "Struct.__dict__.__contains__", ["size"],              true]
    - ["st1636014", "Struct.__name__.__eq__",        ["Struct"],           true]
    - ["st1636015", "error.__name__.__eq__",         ["error"],            true]
    - ["st1636016", "Struct.__bases__.__getitem__",  [0],                  "object"]
    - ["st1636017", "error.__bases__.__getitem__",   [0],                  "Exception"]
    - ["st1636018", "Struct.__bases__.__len__",      [],                   1]
    - ["st1636019", "error.__bases__.__len__",       [],                   1]
    - ["st1636020", "Struct.__module__.__eq__",      ["_struct"],          true]

# ---------------------------------------------------------------------------
# Table 2: isinstance / issubclass checks for struct.Struct and struct.error
#
# The normal Python class machinery provides isinstance/issubclass behaviour
# even for C extension types. struct.error is a subclass of Exception and of
# struct.error itself (every class is a subclass of itself).
# ---------------------------------------------------------------------------

table struct_extra1636.struct_isinstance_checks:
  description: "isinstance and issubclass work normally for struct.Struct and struct.error"
  kind: python_call_eq
  category: isinstance_issubclass
  id_prefix: st1636

  columns: [id, function, args, expected]
  rows:
    - ["st1636021", "Struct.__mro__.__len__",                              [],          2]
    - ["st1636022", "Struct.__mro__.__getitem__",                          [0],         "Struct"]
    - ["st1636023", "Struct.__mro__.__getitem__",                          [1],         "object"]
    - ["st1636024", "error.__mro__.__len__",                               [],          5]
    - ["st1636025", "error.__mro__.__getitem__",                           [0],         "error"]
    - ["st1636026", "error.__mro__.__getitem__",                           [1],         "Exception"]
    - ["st1636027", "error.__mro__.__getitem__",                           [2],         "BaseException"]
    - ["st1636028", "error.__mro__.__getitem__",                           [3],         "object"]
    - ["st1636029", "Struct.__class__.__name__.__eq__",                    ["type"],    true]
    - ["st1636030", "error.__class__.__name__.__eq__",                     ["type"],    true]
    - ["st1636031", "Struct.__dict__.__contains__",                        ["__doc__"], true]
    - ["st1636032", "error.__dict__.__contains__",                         ["__doc__"], false]
    - ["st1636033", "error.__module__.__eq__",                             ["struct"],  true]
    - ["st1636034", "Struct.__dict__.__contains__",                        ["__new__"], false]
    - ["st1636035", "error.__mro__.__contains__",                          ["error"],   false]
    - ["st1636036", "error.__bases__.__getitem__",                         [0],         "Exception"]
    - ["st1636037", "error.__dict__.__contains__",                         ["args"],    false]
    - ["st1636038", "Struct.__dict__.__contains__",                        ["__reduce_ex__"], false]
    - ["st1636039", "error.__dict__.__contains__",                         ["__reduce_ex__"], false]
    - ["st1636040", "Struct.__dict__.__contains__",                        ["__sizeof__"], true]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct format string and size attributes
#
# struct.Struct stores the format string given at construction and computes
# the byte size. All values are platform-independent for explicit byte-order
# prefixes (>, <, !).
# ---------------------------------------------------------------------------

table struct_extra1636.struct_format_size:
  description: "struct.Struct format and size attributes match the format string and calcsize result"
  kind: python_call_eq
  category: Struct_attributes
  id_prefix: st1636

  columns: [id, function, args, expected]
  rows:
    - ["st1636041", "Struct.__call__",     [">H"],      ">H"]
    - ["st1636042", "Struct",              [">H"],      ">H"]
    - ["st1636043", "Struct.__call__",     [">I"],      ">I"]
    - ["st1636044", "Struct.__call__",     ["!BBBB"],   "!BBBB"]
    - ["st1636045", "Struct.__call__",     [">Q"],      ">Q"]
    - ["st1636046", "Struct.__call__",     ["<H"],      "<H"]
    - ["st1636047", "Struct.__call__",     ["!HI"],     "!HI"]
    - ["st1636048", "Struct.__call__",     [">BHI"],    ">BHI"]
    - ["st1636049", "calcsize",            [">H"],      2]
    - ["st1636050", "calcsize",            [">I"],      4]
    - ["st1636051", "calcsize",            ["!BBBB"],   4]
    - ["st1636052", "calcsize",            [">Q"],      8]
    - ["st1636053", "calcsize",            ["<H"],      2]
    - ["st1636054", "calcsize",            ["!HI"],     6]
    - ["st1636055", "calcsize",            [">BHI"],    7]
    - ["st1636056", "calcsize",            [">q"],      8]
    - ["st1636057", "calcsize",            [">b"],      1]
    - ["st1636058", "calcsize",            [">B"],      1]
    - ["st1636059", "calcsize",            ["!BBBBBB"], 6]
    - ["st1636060", "calcsize",            [">hH"],     4]
