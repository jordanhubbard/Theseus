spec: hashlib_extra2
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified by running Python 3.12 hashlib on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "This spec extends hashlib.zspec.zsdl and hashlib_extra.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "hashlib.zspec.zsdl covers: sha256/sha1/md5/sha512/sha3_256/sha3_512/blake2b/blake2s known vectors; digest_size/block_size attrs; algorithms_guaranteed core set and sha3 membership; digest_consistency, copy_independence, api_equivalence."
    - "hashlib_extra.zspec.zsdl covers: blake2b default/custom digest_size and name; blake2s name; sha3_224/sha3_384 attrs; algorithms_guaranteed sha3_224/sha3_384 membership; algorithms_available type and sha256 membership; pbkdf2_hmac function name and return lengths."
    - "md5(b'').hexdigest() == 'd41d8cd98f00b204e9800998ecf8427e' — RFC 1321 Appendix A.5 reference vector."
    - "sha1(b'').hexdigest() == 'da39a3ee5e6b4b0d3255bfef95601890afd80709' — FIPS 180-4 reference vector."
    - "sha256(b'').hexdigest() == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855' — FIPS 180-4 reference vector."
    - "md5(b'hello').hexdigest() == '5d41402abc4b2a76b9719d911017c592' — widely cited reference vector for b'hello'."
    - "hashlib.new('md5', b'') returns a HASH object; its __class__.__name__ is implementation-defined (e.g. 'md5' or 'HASH') but is always a string."
    - "algorithms_available and algorithms_guaranteed are both plain Python sets."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "hashlib raises ValueError for unknown algorithm names passed to hashlib.new(). Hash constructor calls do not raise for valid algorithms."
  stderr: "null"
  stickiness: "N/A — hash objects are independent; module-level attributes are read-only sets."
  codes: {}

# ---------------------------------------------------------------------------
# hexdigest() known vectors — empty input
# These call the module-level constructor directly (md5, sha1, sha256 are
# exposed as top-level attributes of hashlib).
# ---------------------------------------------------------------------------

invariant hashlib_extra2.md5.empty_hexdigest:
  description: "hashlib.md5(b'').hexdigest() == 'd41d8cd98f00b204e9800998ecf8427e' (RFC 1321 A.5)"
  category: known_vector
  kind: python_call_eq
  function: md5
  args: [""]
  method: hexdigest
  method_args: []
  expected: "d41d8cd98f00b204e9800998ecf8427e"

invariant hashlib_extra2.sha1.empty_hexdigest:
  description: "hashlib.sha1(b'').hexdigest() == 'da39a3ee5e6b4b0d3255bfef95601890afd80709' (FIPS 180-4)"
  category: known_vector
  kind: python_call_eq
  function: sha1
  args: [""]
  method: hexdigest
  method_args: []
  expected: "da39a3ee5e6b4b0d3255bfef95601890afd80709"

invariant hashlib_extra2.sha256.empty_hexdigest:
  description: "hashlib.sha256(b'').hexdigest() == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855' (FIPS 180-4)"
  category: known_vector
  kind: python_call_eq
  function: sha256
  args: [""]
  method: hexdigest
  method_args: []
  expected: "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"

# ---------------------------------------------------------------------------
# hexdigest() known vector — md5(b'hello')
# ---------------------------------------------------------------------------

invariant hashlib_extra2.md5.hello_hexdigest:
  description: "hashlib.md5(b'hello').hexdigest() == '5d41402abc4b2a76b9719d911017c592'"
  category: known_vector
  kind: python_call_eq
  function: md5
  args: [!ascii "hello"]
  method: hexdigest
  method_args: []
  expected: "5d41402abc4b2a76b9719d911017c592"

# ---------------------------------------------------------------------------
# digest_size checks — sha256 and sha512
# (sha256 digest_size already covered in hashlib.zspec.zsdl but via hash_object_attr;
#  here we test via python_call_eq for orthogonal coverage of the same invariant)
# ---------------------------------------------------------------------------

invariant hashlib_extra2.sha256.digest_size_eq:
  description: "hashlib.sha256(b'hello').digest_size == 32 (256 bits = 32 bytes)"
  category: properties
  kind: python_call_eq
  function: sha256
  args: [!ascii "hello"]
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra2.sha512.digest_size_eq:
  description: "hashlib.sha512(b'hello').digest_size == 64 (512 bits = 64 bytes)"
  category: properties
  kind: python_call_eq
  function: sha512
  args: [!ascii "hello"]
  method: digest_size.__eq__
  method_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_available and algorithms_guaranteed — class name checks
# hashlib_extra.zspec.zsdl tests algorithms_available.__class__.__name__ == 'set';
# this spec tests algorithms_guaranteed.__class__.__name__ == 'set' (not yet covered).
# ---------------------------------------------------------------------------

invariant hashlib_extra2.algorithms_guaranteed.type_is_set:
  description: "type(hashlib.algorithms_guaranteed).__name__ == 'set'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new() — returns a hash object (class name is a non-empty string)
# The exact class name is implementation-defined ('md5', 'HASH', etc.) so we
# verify that __class__.__name__ is a str and that it is truthy (non-empty).
# ---------------------------------------------------------------------------

invariant hashlib_extra2.new.returns_hash_object:
  description: "type(hashlib.new('md5', b'')).__name__ is a non-empty string — new() returns a hash object"
  category: api
  kind: python_call_eq
  function: new
  args: ["md5", ""]
  method: __class__.__name__.__class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant hashlib_extra2.new.md5_empty_hexdigest:
  description: "hashlib.new('md5', b'').hexdigest() == 'd41d8cd98f00b204e9800998ecf8427e' — new() is equivalent to direct constructor"
  category: api
  kind: python_call_eq
  function: new
  args: ["md5", ""]
  method: hexdigest
  method_args: []
  expected: "d41d8cd98f00b204e9800998ecf8427e"
