spec: threading_extra1201
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading.Barrier.__bases__.__len__() == 1, threading.Thread.__bases__.__len__() == 1, threading.Condition.__bases__.__len__() == 1, threading.Event.__bases__.__len__() == 1, threading.Timer.__bases__.__len__() == 1, threading.Semaphore.__bases__.__len__() == 1, threading.BoundedSemaphore.__bases__.__len__() == 1, threading.local.__module__ == '_thread' — not covered in _extra1171/_extra1186"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1201.barrier_thread_condition_bases_len:
  description: "threading.Barrier, Thread, and Condition __bases__.__len__() == 1 identity"
  kind: python_call_eq
  category: barrier_thread_condition_bases_len
  id_prefix: th1201bt
  columns: [id, function, args, expected]
  rows:
    - [th1201bt001, threading.Barrier.__bases__.__len__,                      [],   1]
    - [th1201bt002, threading.Barrier.__bases__.__class__.__name__.__eq__,    ["tuple"], true]
    - [th1201bt003, threading.Thread.__bases__.__len__,                       [],   1]
    - [th1201bt004, threading.Thread.__bases__.__class__.__name__.__eq__,     ["tuple"], true]
    - [th1201bt005, threading.Condition.__bases__.__len__,                    [],   1]
    - [th1201bt006, threading.Condition.__bases__.__class__.__name__.__eq__,  ["tuple"], true]
    - [th1201bt007, threading.Barrier.__qualname__.__eq__,                    ["Barrier"],   true]
    - [th1201bt008, threading.Thread.__qualname__.__eq__,                     ["Thread"],    true]

table threading_extra1201.event_timer_semaphore_bases_len:
  description: "threading.Event, Timer, Semaphore, and BoundedSemaphore __bases__.__len__() == 1 identity"
  kind: python_call_eq
  category: event_timer_semaphore_bases_len
  id_prefix: th1201es
  columns: [id, function, args, expected]
  rows:
    - [th1201es001, threading.Event.__bases__.__len__,                        [],   1]
    - [th1201es002, threading.Event.__bases__.__class__.__name__.__eq__,      ["tuple"], true]
    - [th1201es003, threading.Timer.__bases__.__len__,                        [],   1]
    - [th1201es004, threading.Timer.__bases__.__class__.__name__.__eq__,      ["tuple"], true]
    - [th1201es005, threading.Semaphore.__bases__.__len__,                    [],   1]
    - [th1201es006, threading.Semaphore.__bases__.__class__.__name__.__eq__,  ["tuple"], true]
    - [th1201es007, threading.BoundedSemaphore.__bases__.__len__,             [],   1]
    - [th1201es008, threading.BoundedSemaphore.__bases__.__class__.__name__.__eq__, ["tuple"], true]

table threading_extra1201.local_module_and_class_qualnames:
  description: "threading.local __module__ and class qualname identity checks"
  kind: python_call_eq
  category: local_module_and_class_qualnames
  id_prefix: th1201lm
  columns: [id, function, args, expected]
  rows:
    - [th1201lm001, threading.local.__module__.__eq__,                    ["_thread"],         true]
    - [th1201lm002, threading.local.__qualname__.__eq__,                  ["local"],           true]
    - [th1201lm003, threading.local.__class__.__name__.__eq__,            ["type"],            true]
    - [th1201lm004, threading.Event.__qualname__.__eq__,                   ["Event"],          true]
    - [th1201lm005, threading.Semaphore.__qualname__.__eq__,               ["Semaphore"],      true]
    - [th1201lm006, threading.BoundedSemaphore.__qualname__.__eq__,        ["BoundedSemaphore"], true]
    - [th1201lm007, threading.Condition.__qualname__.__eq__,               ["Condition"],      true]
    - [th1201lm008, threading.Timer.__qualname__.__eq__,                   ["Timer"],          true]
