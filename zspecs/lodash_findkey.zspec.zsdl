spec: lodash_findkey
version: ">=4.0.0"
backend: node(lodash.findkey)

docs: https://lodash.com/docs/#findKey

provenance:
  derived_from:
    - "lodash.findkey README — https://www.npmjs.com/package/lodash.findkey"
    - "Test vectors verified with lodash.findkey@4.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.findkey exports the _.findKey function directly as module.exports."
    - "findKey(object, predicate) returns the key of the first element matching the predicate."
    - "Object predicate uses match shorthand. String predicate checks property truthiness."
    - "Returns undefined if not found (omitted from test vectors)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns string key or undefined."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_findkey.findkey:
  kind: node_module_call_eq
  function: ~
  category: findkey
  id_prefix: lfk

  columns: [id, args, expected]
  rows:
    - [by_match,  [{"a": {"n": 1}, "b": {"n": 2}}, {"n": 2}],  "b"]
    - [by_prop,   [{"x": {"active": true}, "y": {"active": false}}, "active"], "x"]
    - [first_key, [{"a": {"n": 1}, "b": {"n": 1}}, {"n": 1}],  "a"]

