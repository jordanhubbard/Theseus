spec: concurrent_futures_extra29
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra28.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values, class __module__/__name__/__len__() tables, ThreadPoolExecutor submit/shutdown qualname lens, ProcessPoolExecutor submit/shutdown qualname lens, Executor.map qualname len, Future method qualname lens for result/add_done_callback/cancel/done/exception/set_result/set_exception/running/set_running_or_notify_cancel, class __dict__.__class__.__name__.__len__() for Future/ThreadPoolExecutor/ProcessPoolExecutor/Executor/BrokenExecutor/CancelledError, as_completed/wait __module__.__len__(), __all__.__len__() == 14."
    - "NEW in this spec: ThreadPoolExecutor/__mro__.__len__() == 3; ProcessPoolExecutor/__mro__.__len__() == 3; Future/__mro__.__len__() == 2; Executor/__mro__.__len__() == 2; ThreadPoolExecutor/__bases__[0].__name__.__len__() == 8 (Executor); ProcessPoolExecutor/__bases__[0].__name__.__len__() == 8 (Executor); Future/__bases__[0].__name__.__len__() == 6 (object); Executor/__bases__[0].__name__.__len__() == 6 (object); Executor.submit/__qualname__.__len__() == 15; Executor.shutdown/__qualname__.__len__() == 17; Executor.map/__qualname__.__len__() == 12; Future/__qualname__.__len__() == 6; ThreadPoolExecutor/__qualname__.__len__() == 18; ProcessPoolExecutor/__qualname__.__len__() == 19; Executor/__qualname__.__len__() == 8."
    - "ThreadPoolExecutor and ProcessPoolExecutor both have MRO depth 3 — [Executor, object] above each."
    - "Future and Executor have MRO depth 2 — flat hierarchy, direct object subclasses."
    - "Both concrete executor subclasses share the same base: Executor (8 chars)."
    - "Executor context manager methods: __enter__.__qualname__.__len__() == 18, __exit__.__qualname__.__len__() == 17."
    - "ProcessPoolExecutor.__qualname__.__len__() == 19, one more than ThreadPoolExecutor (18)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __mro__.__len__() table — extra29 namespace
#
# MRO depths for the four main concurrent.futures classes:
#   ThreadPoolExecutor.__mro__.__len__() == 3 — [ThreadPoolExecutor, Executor, object]
#   ProcessPoolExecutor.__mro__.__len__() == 3 — [ProcessPoolExecutor, Executor, object]
#   Future.__mro__.__len__()             == 2 — [Future, object]
#   Executor.__mro__.__len__()           == 2 — [Executor, object]
# The two concrete executor classes share the same MRO depth of 3, while
# Future and the abstract Executor base are flat at depth 2.
# No prior spec has measured __mro__.__len__() for any concurrent.futures class.
# ---------------------------------------------------------------------------

table concurrent_futures_extra29.class_mro_lengths:
  description: "concurrent.futures class __mro__.__len__() for ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor in extra29 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: clsmrolen29

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__mro__,  [], !ascii "", __len__, [], "ThreadPoolExecutor MRO depth == 3"]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__mro__, [], !ascii "", __len__, [], "ProcessPoolExecutor MRO depth == 3"]
    - [Future,              Future.__mro__,              [], !ascii "", __len__, [], "Future MRO depth == 2"]
    - [Executor,            Executor.__mro__,            [], !ascii "", __len__, [], "Executor MRO depth == 2"]

# ---------------------------------------------------------------------------
# Class __bases__[0].__name__.__len__() table — extra29 namespace
#
# The four main concurrent.futures classes have direct base classes:
#   ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' (8 chars)
#   ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' (8 chars)
#   Future.__bases__[0].__name__             == 'object'   (6 chars)
#   Executor.__bases__[0].__name__           == 'object'   (6 chars)
# Both concrete executors inherit from Executor; Future and Executor directly
# subclass object. This table measures the length of those base class names.
# No prior spec has measured __bases__[0].__name__.__len__() for these classes.
# ---------------------------------------------------------------------------

table concurrent_futures_extra29.class_base_name_lengths:
  description: "concurrent.futures class __bases__[0].__name__.__len__() for ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor in extra29 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: clsbasenamelen29

  columns: [id, function, args, expected]
  rows:
    - [ThreadPoolExecutor,  "ThreadPoolExecutor.__bases__[0].__name__.__len__",  [], 8]
    - [ProcessPoolExecutor, "ProcessPoolExecutor.__bases__[0].__name__.__len__", [], 8]
    - [Future,              "Future.__bases__[0].__name__.__len__",              [], 6]
    - [Executor,            "Executor.__bases__[0].__name__.__len__",            [], 6]

# ---------------------------------------------------------------------------
# Executor method __qualname__ length table — extra29 namespace
#
# concurrent.futures.Executor defines three public methods (submit is abstract):
#   Executor.map.__qualname__      == 'Executor.map'      (12)
#   Executor.submit.__qualname__   == 'Executor.submit'   (15)
#   Executor.shutdown.__qualname__ == 'Executor.shutdown' (17)
# The __qualname__ carries the 'Executor.' prefix (9 chars) plus the method
# name. Prior spec extra28 measured Executor.map qualname len but NOT
# submit or shutdown as standalone values. This table groups all three.
# ---------------------------------------------------------------------------

table concurrent_futures_extra29.executor_method_qualname_lengths:
  description: "concurrent.futures.Executor method __qualname__ lengths for map/submit/shutdown in extra29 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: execmqualnamelen29

  columns: [id, function, args, expected]
  rows:
    - [map,      Executor.map.__qualname__.__len__,      [], 12]
    - [submit,   Executor.submit.__qualname__.__len__,   [], 15]
    - [shutdown, Executor.shutdown.__qualname__.__len__, [], 17]

# ---------------------------------------------------------------------------
# Class __qualname__.__len__() table — extra29 namespace
#
# All four main concurrent.futures classes are top-level definitions, so
# their __qualname__ equals their __name__:
#   Future.__qualname__.__len__()             == 6  ('Future')
#   ThreadPoolExecutor.__qualname__.__len__() == 18 ('ThreadPoolExecutor')
#   ProcessPoolExecutor.__qualname__.__len__() == 19 ('ProcessPoolExecutor')
#   Executor.__qualname__.__len__()           == 8  ('Executor')
# ProcessPoolExecutor has the longest class name (19 chars), one more than
# ThreadPoolExecutor (18 chars). No prior spec has measured __qualname__
# length for Executor or ProcessPoolExecutor.
# ---------------------------------------------------------------------------

table concurrent_futures_extra29.class_qualname_lengths:
  description: "concurrent.futures class __qualname__.__len__() for Future/ThreadPoolExecutor/ProcessPoolExecutor/Executor in extra29 namespace"
  kind: python_call_eq
  category: qualnames
  id_prefix: clsqualnamelen29

  columns: [id, function, args, expected]
  rows:
    - [Future,              Future.__qualname__.__len__,              [], 6]
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__qualname__.__len__,  [], 18]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__qualname__.__len__, [], 19]
    - [Executor,            Executor.__qualname__.__len__,            [], 8]

# ---------------------------------------------------------------------------
# Executor context manager method __qualname__ lengths — extra29 standalone
#
# Executor implements the context manager protocol via __enter__ and __exit__.
# Their __qualname__ values carry the 'Executor.' prefix:
#   Executor.__enter__.__qualname__ == 'Executor.__enter__' (18 chars)
#   Executor.__exit__.__qualname__  == 'Executor.__exit__'  (17 chars)
# No prior spec has measured context-manager method qualname lengths for Executor.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra29.Executor_enter_qualname_len:
  description: "concurrent.futures.Executor.__enter__.__qualname__.__len__() == 18 — 'Executor.__enter__' has eighteen characters"
  category: method_names
  kind: python_call_eq
  function: Executor.__enter__.__qualname__.__len__
  args: []
  expected: 18

invariant concurrent_futures_extra29.Executor_exit_qualname_len:
  description: "concurrent.futures.Executor.__exit__.__qualname__.__len__() == 17 — 'Executor.__exit__' has seventeen characters"
  category: method_names
  kind: python_call_eq
  function: Executor.__exit__.__qualname__.__len__
  args: []
  expected: 17

invariant concurrent_futures_extra29.ProcessPoolExecutor_qualname_len:
  description: "concurrent.futures.ProcessPoolExecutor.__qualname__.__len__() == 19 — 'ProcessPoolExecutor' has nineteen characters, one more than ThreadPoolExecutor"
  category: qualnames
  kind: python_call_eq
  function: ProcessPoolExecutor.__qualname__.__len__
  args: []
  expected: 19
