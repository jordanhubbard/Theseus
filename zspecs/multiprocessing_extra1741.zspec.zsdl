spec: multiprocessing_extra1741
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol dict-presence checks."
    - "Theme: which multiprocessing stdlib types define __get__, __set__, __delete__, __set_name__ in their own __dict__."
    - "All multiprocessing types are pure Python process/pool/sync classes with no descriptor protocol semantics."
    - "multiprocessing.Process: spawnable subprocess class; no descriptor methods in own __dict__ -> all False."
    - "multiprocessing.process.BaseProcess: abstract root of the process hierarchy; no descriptor methods in own __dict__ -> all False."
    - "multiprocessing.Pool: worker-process pool manager; no descriptor methods in own __dict__ -> all False."
    - "multiprocessing.Lock: cross-process synchronization primitive; no descriptor methods in own __dict__ -> all False."
    - "Rationale: multiprocessing types model OS-level subprocesses and inter-process synchronization, not attribute access protocols."
    - "Cross-check: __get__ is the hook that makes a class a non-data descriptor. None of the multiprocessing types sit in a class body to intercept attribute lookup."
    - "Cross-check: __set_name__ is called by type.__new__ when a class body attribute is assigned at class creation time. Multiprocessing objects are instantiated at runtime to spawn subprocesses, not at class-definition time."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: descriptor protocol dict-presence checks (__get__, __set__, __delete__)
#
# Wave 563 theme: do multiprocessing types define descriptor dunders in their
# own __dict__? multiprocessing.Process represents an OS subprocess whose
# lifecycle (start, join, terminate) is driven explicitly by the programmer.
# BaseProcess is the abstract root from which Process derives; it manages
# process state and signals but has no notion of attribute-access interception.
# Pool manages a set of worker processes for parallel task execution. None of
# these classes are designed to be stored as class body attributes and to
# intercept attribute access on instances of some other class. All checks
# return False.
# ---------------------------------------------------------------------------

table multiprocessing_extra1741.descriptor_protocol:
  description: "multiprocessing types: __get__, __set__, __delete__ dict-presence checks (all False — no descriptor protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1741

  columns: [id, function, args, expected]
  rows:
    - ["mp1741001", "multiprocessing.Process.__dict__.__contains__",             ["__get__"],    false]
    - ["mp1741002", "multiprocessing.Process.__dict__.__contains__",             ["__set__"],    false]
    - ["mp1741003", "multiprocessing.Process.__dict__.__contains__",             ["__delete__"], false]
    - ["mp1741004", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__get__"],    false]
    - ["mp1741005", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__set__"],    false]
    - ["mp1741006", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__delete__"], false]
    - ["mp1741007", "multiprocessing.Pool.__dict__.__contains__",                ["__get__"],    false]
    - ["mp1741008", "multiprocessing.Pool.__dict__.__contains__",                ["__set__"],    false]
    - ["mp1741009", "multiprocessing.Pool.__dict__.__contains__",                ["__delete__"], false]
    - ["mp1741010", "multiprocessing.Lock.__dict__.__contains__",                ["__get__"],    false]

# ---------------------------------------------------------------------------
# Table 2: __set_name__ dict-presence cross-checks
#
# Wave 563 cross-check: __set_name__ is invoked by type.__new__ when a class
# body attribute binding is detected at class creation time (PEP 487). Since
# none of the multiprocessing public types are descriptors, none implement
# __set_name__ in their own __dict__. This table extends coverage to Lock and
# also fills in remaining __set__ and __delete__ checks for Lock. Together the
# two tables give complete coverage of all four descriptor dunders (__get__,
# __set__, __delete__, __set_name__) across Process, BaseProcess, Pool, and Lock.
# ---------------------------------------------------------------------------

table multiprocessing_extra1741.set_name_protocol:
  description: "multiprocessing types: __set_name__ dict-presence cross-checks and Lock __set__/__delete__ extension (all False)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1741

  columns: [id, function, args, expected]
  rows:
    - ["mp1741011", "multiprocessing.Process.__dict__.__contains__",             ["__set_name__"], false]
    - ["mp1741012", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__set_name__"], false]
    - ["mp1741013", "multiprocessing.Pool.__dict__.__contains__",                ["__set_name__"], false]
    - ["mp1741014", "multiprocessing.Lock.__dict__.__contains__",                ["__set_name__"], false]
    - ["mp1741015", "multiprocessing.Lock.__dict__.__contains__",                ["__set__"],      false]
    - ["mp1741016", "multiprocessing.Lock.__dict__.__contains__",                ["__delete__"],   false]
    - ["mp1741017", "multiprocessing.Process.__dict__.__contains__",             ["__get__"],      false]
    - ["mp1741018", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__get__"],      false]
    - ["mp1741019", "multiprocessing.Pool.__dict__.__contains__",                ["__get__"],      false]
    - ["mp1741020", "multiprocessing.Lock.__dict__.__contains__",                ["__get__"],      false]
    - ["mp1741021", "multiprocessing.Process.__dict__.__contains__",             ["__set__"],      false]
    - ["mp1741022", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__set__"],      false]
    - ["mp1741023", "multiprocessing.Pool.__dict__.__contains__",                ["__set__"],      false]
    - ["mp1741024", "multiprocessing.Process.__dict__.__contains__",             ["__delete__"],   false]
    - ["mp1741025", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__delete__"],   false]
