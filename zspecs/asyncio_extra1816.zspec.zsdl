spec: asyncio_extra1816
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 568 (_extra1816): __format__ string formatting protocol; __reduce__/__copy__/__deepcopy__ copy/pickle protocol; task/future attribute dict-presence checks for asyncio types."
    - "asyncio.Future.__dict__ does not contain __format__ (inherits from object)."
    - "asyncio.Future.__dict__ contains __repr__ (defined in C extension or asyncio.futures)."
    - "asyncio.Task.__dict__ contains __repr__ (Task overrides it)."
    - "cancelling and uncancel were added in Python 3.11; since we target >=3.9 and test on Python 3.14 these are True."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra1816.format_protocol:
  description: "asyncio types __format__/__repr__/__str__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1816

  columns: [id, function, args, expected]
  rows:
    - ["as1816001", "asyncio.Future.__dict__.__contains__", ["__format__"], false]
    - ["as1816002", "asyncio.Future.__dict__.__contains__", ["__repr__"], true]
    - ["as1816003", "asyncio.Future.__dict__.__contains__", ["__str__"], false]
    - ["as1816004", "asyncio.Task.__dict__.__contains__", ["__repr__"], true]
    - ["as1816005", "asyncio.Task.__dict__.__contains__", ["__str__"], false]
    - ["as1816006", "asyncio.Queue.__dict__.__contains__", ["__repr__"], true]
    - ["as1816007", "asyncio.Lock.__dict__.__contains__", ["__repr__"], true]
    - ["as1816008", "asyncio.Event.__dict__.__contains__", ["__repr__"], true]

table asyncio_extra1816.copy_protocol:
  description: "asyncio types __reduce__/__copy__/__deepcopy__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1816

  columns: [id, function, args, expected]
  rows:
    - ["as1816101", "asyncio.Future.__dict__.__contains__", ["__reduce__"], false]
    - ["as1816102", "asyncio.Future.__dict__.__contains__", ["__copy__"], false]
    - ["as1816103", "asyncio.Future.__dict__.__contains__", ["__deepcopy__"], false]
    - ["as1816104", "asyncio.Task.__dict__.__contains__", ["__reduce__"], false]
    - ["as1816105", "asyncio.Queue.__dict__.__contains__", ["__reduce__"], false]
    - ["as1816106", "asyncio.Lock.__dict__.__contains__", ["__reduce__"], false]
    - ["as1816107", "asyncio.Semaphore.__dict__.__contains__", ["__reduce__"], false]
    - ["as1816108", "asyncio.Condition.__dict__.__contains__", ["__reduce__"], false]

table asyncio_extra1816.task_attrs:
  description: "Task and Future specific attribute dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1816

  columns: [id, function, args, expected]
  rows:
    - ["as1816201", "asyncio.Task.__dict__.__contains__", ["get_name"], true]
    - ["as1816202", "asyncio.Task.__dict__.__contains__", ["set_name"], true]
    - ["as1816203", "asyncio.Task.__dict__.__contains__", ["cancel"], true]
    - ["as1816204", "asyncio.Task.__dict__.__contains__", ["cancelling"], true]
    - ["as1816205", "asyncio.Task.__dict__.__contains__", ["uncancel"], true]
    - ["as1816206", "asyncio.Future.__dict__.__contains__", ["get_loop"], true]
    - ["as1816207", "asyncio.Future.__dict__.__contains__", ["cancel"], true]
    - ["as1816208", "asyncio.Future.__dict__.__contains__", ["done"], true]
    - ["as1816209", "asyncio.Future.__dict__.__contains__", ["result"], true]
    - ["as1816210", "asyncio.Future.__dict__.__contains__", ["exception"], true]
