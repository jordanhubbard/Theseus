spec: hashlib_extra2776
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra2761.zspec.zsdl — covers __matmul__, __truediv__, and __iadd__ absence for HASH, blake2b, blake2s."
    - "hashlib_extra2746.zspec.zsdl — covers __imatmul__, __ifloordiv__, __imod__ absence for HASH, blake2b, blake2s."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "hashlib.HASH.__dict__.__contains__('__isub__') == False — HASH (the OpenSSL-backed C type) does not define in-place subtraction; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.HASH.__dict__.__contains__('__imul__') == False — HASH does not define in-place multiplication; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.HASH.__dict__.__contains__('__itruediv__') == False — HASH does not define in-place true division; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__isub__') == False — blake2b does not define in-place subtraction; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__imul__') == False — blake2b does not define in-place multiplication; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2b.__dict__.__contains__('__itruediv__') == False — blake2b does not define in-place true division; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__isub__') == False — blake2s does not define in-place subtraction; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__imul__') == False — blake2s does not define in-place multiplication; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "hashlib.blake2s.__dict__.__contains__('__itruediv__') == False — blake2s does not define in-place true division; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib.HASH.__dict__ — __isub__, __imul__, __itruediv__ absence
# HASH is the C type for OpenSSL-backed hash objects (sha256, md5, sha1, etc.).
# Hash digest objects are cryptographic primitives; in-place arithmetic operators
# (-=, *=, /=) have no meaning for them and are not defined.
# ---------------------------------------------------------------------------

table hashlib_extra2776.hash_dict_isub_imul_itruediv:
  description: "hashlib.HASH.__dict__ does not contain __isub__, __imul__, or __itruediv__ — in-place arithmetic operators are not defined on hash digest objects; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2776

  columns: [id, function, args, expected]
  rows:
    - ["hl2776-hash-isub",     hashlib.HASH.__dict__.__contains__,  ["__isub__"],     false]
    - ["hl2776-hash-imul",     hashlib.HASH.__dict__.__contains__,  ["__imul__"],     false]
    - ["hl2776-hash-itruediv", hashlib.HASH.__dict__.__contains__,  ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Table 2: hashlib.blake2b.__dict__ — __isub__, __imul__, __itruediv__ absence
# blake2b is the C type for BLAKE2b hash objects.
# Like HASH, it defines no in-place arithmetic operators.
# ---------------------------------------------------------------------------

table hashlib_extra2776.blake2b_dict_isub_imul_itruediv:
  description: "hashlib.blake2b.__dict__ does not contain __isub__, __imul__, or __itruediv__ — the BLAKE2b hash type defines no in-place arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2776

  columns: [id, function, args, expected]
  rows:
    - ["hl2776-b2b-isub",     hashlib.blake2b.__dict__.__contains__,  ["__isub__"],     false]
    - ["hl2776-b2b-imul",     hashlib.blake2b.__dict__.__contains__,  ["__imul__"],     false]
    - ["hl2776-b2b-itruediv", hashlib.blake2b.__dict__.__contains__,  ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Table 3: hashlib.blake2s.__dict__ — __isub__, __imul__, __itruediv__ absence
# blake2s is the C type for BLAKE2s hash objects.
# Like HASH and blake2b, it defines no in-place arithmetic operators.
# ---------------------------------------------------------------------------

table hashlib_extra2776.blake2s_dict_isub_imul_itruediv:
  description: "hashlib.blake2s.__dict__ does not contain __isub__, __imul__, or __itruediv__ — the BLAKE2s hash type defines no in-place arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2776

  columns: [id, function, args, expected]
  rows:
    - ["hl2776-b2s-isub",     hashlib.blake2s.__dict__.__contains__,  ["__isub__"],     false]
    - ["hl2776-b2s-imul",     hashlib.blake2s.__dict__.__contains__,  ["__imul__"],     false]
    - ["hl2776-b2s-itruediv", hashlib.blake2s.__dict__.__contains__,  ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — all three hash types absent for all three dunders
# Consolidates one row per (type, dunder) pair for easy cross-type comparison.
# ---------------------------------------------------------------------------

table hashlib_extra2776.all_types_all_dunders_absent:
  description: "HASH, blake2b, and blake2s all lack __isub__, __imul__, and __itruediv__ in __dict__ — no hashlib hash type defines these in-place arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: hl2776

  columns: [id, function, args, expected]
  rows:
    - ["hl2776-x-hash-isub",     hashlib.HASH.__dict__.__contains__,    ["__isub__"],     false]
    - ["hl2776-x-hash-imul",     hashlib.HASH.__dict__.__contains__,    ["__imul__"],     false]
    - ["hl2776-x-hash-itruediv", hashlib.HASH.__dict__.__contains__,    ["__itruediv__"], false]
    - ["hl2776-x-b2b-isub",      hashlib.blake2b.__dict__.__contains__, ["__isub__"],     false]
    - ["hl2776-x-b2b-imul",      hashlib.blake2b.__dict__.__contains__, ["__imul__"],     false]
    - ["hl2776-x-b2b-itruediv",  hashlib.blake2b.__dict__.__contains__, ["__itruediv__"], false]
    - ["hl2776-x-b2s-isub",      hashlib.blake2s.__dict__.__contains__, ["__isub__"],     false]
    - ["hl2776-x-b2s-imul",      hashlib.blake2s.__dict__.__contains__, ["__imul__"],     false]
    - ["hl2776-x-b2s-itruediv",  hashlib.blake2s.__dict__.__contains__, ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra2776.hash_no_isub:
  description: "hashlib.HASH.__dict__.__contains__('__isub__') == False — HASH (OpenSSL-backed C type) does not define in-place subtraction; hash objects are cryptographic primitives, not numeric types; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__isub__"]
  expected: false

invariant hashlib_extra2776.hash_no_imul:
  description: "hashlib.HASH.__dict__.__contains__('__imul__') == False — HASH does not define in-place multiplication; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__imul__"]
  expected: false

invariant hashlib_extra2776.hash_no_itruediv:
  description: "hashlib.HASH.__dict__.__contains__('__itruediv__') == False — HASH does not define in-place true division; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: hashlib.HASH.__dict__.__contains__
  args: ["__itruediv__"]
  expected: false

