  expected: false

invariant hashlib_extra2776.blake2b_no_imul:
  description: "hashlib.blake2b.__dict__.__contains__('__imul__') == False — blake2b does not define in-place multiplication; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
