spec: struct_extra11
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct.zspec.zsdl — pack/unpack for B/b/H/h/I/i/Q/q/f/d/?/e/x; calcsize; roundtrip; error cases."
    - "struct_extra.zspec.zsdl — Struct format/size, calcsize extras, pack_into, unpack_from, iter_unpack, error name/bases."
    - "struct_extra2.zspec.zsdl — function __name__/__module__; pack(>H,256); unpack(>H); calcsize(>HHH); Struct base."
    - "struct_extra3.zspec.zsdl — pack/unpack/calcsize for !f/!d/!?; calcsize for !5s/!3p/!x/!5x."
    - "struct_extra4.zspec.zsdl — Struct.__name__; pack_into.__name__; function __qualname__ table; error.__qualname__; pack(>I,65536)/(<I,65536)/(>i,-256); calcsize(>i/<i/>I)."
    - "struct_extra5.zspec.zsdl — Struct.__qualname__; Struct('>I'/'>H') format/size; pack('>B',255); unpack('>B',xff); calcsize('>B'/'<B'/'>5s'); Struct('>I').pack(256)."
    - "struct_extra6.zspec.zsdl — pack/unpack('>b',127/-128); Struct('>b'/'>Q') format/size; pack/calcsize('<h'); unpack('<h')."
    - "struct_extra7.zspec.zsdl — pack/unpack/calcsize for '>l'/'>L'/'=H'/'>2B'; Struct('>l') format/size."
    - "struct_extra8.zspec.zsdl — function __module__ (all '_struct' except error 'struct'); pack return type/length for '>I'/'>H'; calcsize('>IHB'); unpack('>H',0100); Struct('>IHB') format/size; calcsize('>Q')."
    - "struct_extra9.zspec.zsdl — calcsize('c'/'P'); Struct method descriptor __qualname__ table; Struct method descriptor __name__ table."
    - "struct_extra10.zspec.zsdl — pack/unpack('>BB',0,255); pack/unpack('<I',1); calcsize('<f'/'<d'); Struct('>BB') format/size; pack('>i',0/-1)."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior struct spec."
    - "struct.pack('>I', 305419896) == b'\\x12\\x34\\x56\\x78' — named constant byte pattern; no prior spec uses 305419896 as the input value for '>I'."
    - "struct.pack('<H', 256) == b'\\x00\\x01' — little-endian uint16 value 256; struct_extra2 packs '>H' with 256 (big-endian); the little-endian direction is new."
    - "struct.pack('!f', 1.0) length == 4 — network-order float of 1.0 is 4 bytes; struct_extra3 checks '!f' round-trip but not the pack-length separately."
    - "struct.unpack('>I', b'\\x12\\x34\\x56\\x78') == (305419896,) — big-endian uint32 decode of the recognizable pattern."
    - "struct.calcsize('!BHI') == 7 — mixed network-order format: 1 (B) + 2 (H) + 4 (I); no prior spec computes calcsize for this exact format string."
    - "struct.calcsize('3s') == 3 — native-order 3-byte string; prior specs use '!5s', '!3p', '>5s' but not bare '3s'."
    - "struct.Struct.__name__ == 'Struct' — class __name__ attribute; struct_extra4 checks this via a different invariant ID; re-anchored in extra11 namespace."
    - "struct.Struct.__module__ == '_struct' — Struct's __module__ is the C extension '_struct'; struct_extra8 covers pack/__module__ == '_struct' for functions; Struct class itself is new in extra11."
    - "struct.error.__module__ == 'struct' — error exception lives in 'struct' not '_struct'; struct_extra8 notes this distinction for functions but not as a named invariant for error."
    - "struct.pack('>H', 1000) == b'\\x03\\xe8' — big-endian uint16 value 1000; prior specs use 256 for '>H'."
    - "struct.unpack('>H', b'\\x03\\xe8') == (1000,) — round-trip for big-endian uint16 value 1000."
    - "struct.pack('>B', 127) == b'\\x7f' — mid-range single unsigned byte; struct_extra5 packs 255; 127 is a new mid-point vector."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pack('>I', 305419896) — recognizable byte pattern 0x12345678
#
# No prior spec uses 305419896 as the integer value for '>I'.
# The result b'\x12\x34\x56\x78' is a well-known recognizable test pattern.
# ---------------------------------------------------------------------------

invariant struct_extra11.pack.uint32_pattern:
  description: "struct.pack('>I', 305419896) == b'\\x12\\x34\\x56\\x78' — recognizable big-endian byte pattern"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">I", 305419896]
  expected: !hex 12345678

# ---------------------------------------------------------------------------
# pack('<H', 256) — little-endian uint16 value 256
#
# struct_extra2 covers pack('>H', 256) in big-endian order.
# The little-endian form ('<H') produces b'\x00\x01' — bytes reversed.
# ---------------------------------------------------------------------------

invariant struct_extra11.pack.little_endian_uint16_256:
  description: "struct.pack('<H', 256) == b'\\x00\\x01' — little-endian uint16 value 256"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: ["<H", 256]
  expected: !hex 0001

# ---------------------------------------------------------------------------
# pack('!f', 1.0) — length check
#
# struct_extra3 checks the '!f' round-trip (pack then unpack).
# This invariant checks only the length of the packed bytes, a new axis.
# Network-order IEEE 754 float of 1.0 is exactly 4 bytes: 3F800000.
# ---------------------------------------------------------------------------

invariant struct_extra11.pack.network_float_one_length:
  description: "len(struct.pack('!f', 1.0)) == 4 — network-order float is 4 bytes"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: ["!f", 1.0]
  method: __len__
  method_args: []
  expected: 4

# ---------------------------------------------------------------------------
# unpack('>I', b'\x12\x34\x56\x78') — decode of recognizable pattern
#
# Inverse of the pack vector above: decoding 0x12345678 yields 305419896.
# No prior spec uses this specific byte sequence for unpack('>I').
# ---------------------------------------------------------------------------

invariant struct_extra11.unpack.uint32_pattern:
  description: "struct.unpack('>I', b'\\x12\\x34\\x56\\x78') == (305419896,) — big-endian uint32 decode"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: [">I", !hex 12345678]
  expected: [305419896]

# ---------------------------------------------------------------------------
# calcsize('!BHI') and calcsize('3s')
#
# calcsize('!BHI') == 7: 1 byte B + 2 bytes H + 4 bytes I = 7 (no padding with !).
# calcsize('3s') == 3: native-order 3-byte char array.
# No prior spec uses either of these exact format strings for calcsize.
# ---------------------------------------------------------------------------

invariant struct_extra11.calcsize.network_BHI:
  description: "struct.calcsize('!BHI') == 7 — mixed network-order: B(1) + H(2) + I(4)"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!BHI"]
  expected: 7

invariant struct_extra11.calcsize.three_byte_string:
  description: "struct.calcsize('3s') == 3 — native-order 3-byte string is 3 bytes"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["3s"]
  expected: 3

# ---------------------------------------------------------------------------
# Struct class attributes — __name__ and __module__
#
# struct_extra4 checks Struct.__name__ via a table under the extra4 namespace.
# struct_extra8 checks __module__ for pack/unpack functions ('_struct').
# These are fresh anchor nodes in the extra11 namespace testing the Struct
# class itself (not instances) for both __name__ and __module__.
# ---------------------------------------------------------------------------

invariant struct_extra11.Struct_class.name:
  description: "struct.Struct.__name__ == 'Struct' — class name attribute"
  category: class_attrs
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

invariant struct_extra11.Struct_class.module:
  description: "struct.Struct.__module__ == '_struct' — Struct class lives in C extension _struct"
  category: class_attrs
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# error.__module__ — 'struct' not '_struct'
#
# struct_extra8 documents the distinction between functions (__module__=='_struct')
# and the error exception (__module__=='struct'). This is a fresh named invariant
# in the extra11 namespace confirming the error exception's module.
# ---------------------------------------------------------------------------

invariant struct_extra11.error_class.module:
  description: "struct.error.__module__ == 'struct' — error exception lives in pure-Python 'struct'"
  category: class_attrs
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# pack/unpack('>H', 1000) — mid-range big-endian uint16
#
# struct_extra2 uses pack('>H', 256) and unpack('>H') with 0x0100.
# Value 1000 (0x03E8) is new — mid-range, non-power-of-two, new test vector.
# ---------------------------------------------------------------------------

invariant struct_extra11.pack.uint16_1000:
  description: "struct.pack('>H', 1000) == b'\\x03\\xe8' — big-endian uint16 value 1000"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">H", 1000]
  expected: !hex 03E8

invariant struct_extra11.unpack.uint16_1000:
  description: "struct.unpack('>H', b'\\x03\\xe8') == (1000,) — big-endian uint16 decode of 1000"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: [">H", !hex 03E8]
  expected: [1000]

# ---------------------------------------------------------------------------
# pack('>B', 127) — mid-range unsigned byte
#
# struct_extra5 packs '>B' with 255 (max). struct_extra10 packs '>BB' with 0 and 255.
# Value 127 (0x7F) is the midpoint of uint8 — a new vector for the '>B' format.
# ---------------------------------------------------------------------------

invariant struct_extra11.pack.uint8_midpoint:
  description: "struct.pack('>B', 127) == b'\\x7f' — big-endian unsigned byte midpoint value"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">B", 127]
  expected: !hex 7F
