spec: hashlib_extra1546
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "https://docs.python.org/3/library/_hashlib.html — CPython _hashlib C extension type docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha3/sha3module.c"
    - "hashlib_extra1531.zspec.zsdl — covers comparison operator absence on _hashlib.HASH (via md5/sha256) and hashlib.blake2b."
    - "hashlib_extra1516.zspec.zsdl — covers arithmetic operator absence on _hashlib.HASH; pack/unpack method presence."
    - "hashlib_extra1501.zspec.zsdl — covers bitwise operator absence on _hashlib.HASH and hashlib.blake2b (earlier wave)."
  notes:
    - "This spec is wave 550 / suffix _extra1546. Theme: bitwise operator dict-presence checks on _hashlib.HASH and hashlib.blake2b."
    - "_hashlib.HASH is the C-extension type returned by hashlib.md5(), hashlib.sha256(), etc. It is a hash state container holding cryptographic state, not a numeric value."
    - "Bitwise operators (__and__, __or__, __xor__, __invert__, __lshift__, __rshift__) are numeric/integer operations. A hash-state object represents accumulated message data, not an integer, so none of these operators are defined."
    - "Reflected variants (__rand__, __ror__, __rxor__) are also absent — _hashlib.HASH cannot act as the right-hand operand in a bitwise expression with any integer."
    - "Verified: __and__ in _hashlib.HASH.__dict__ == False."
    - "Verified: __or__ in _hashlib.HASH.__dict__ == False."
    - "Verified: __xor__ in _hashlib.HASH.__dict__ == False."
    - "Verified: __invert__ in _hashlib.HASH.__dict__ == False."
    - "Verified: __lshift__ in _hashlib.HASH.__dict__ == False."
    - "Verified: __rshift__ in _hashlib.HASH.__dict__ == False."
    - "Verified: __rand__ in _hashlib.HASH.__dict__ == False."
    - "Verified: __ror__ in _hashlib.HASH.__dict__ == False."
    - "Verified: __rxor__ in _hashlib.HASH.__dict__ == False."
    - "hashlib.blake2b is a distinct C-extension type; it equally defines no bitwise operators in its __dict__."
    - "True entries (update, digest, hexdigest, copy for HASH; digest_size, block_size for blake2b) confirm the dict-presence mechanism works."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _hashlib.HASH (via md5) — bitwise operator absence checks
#
# _hashlib.HASH is a cryptographic hash-state object. Bitwise operators
# (__and__, __or__, __xor__, __invert__, __lshift__, __rshift__) are defined
# for integer and integer-like types in Python. A HASH object holds message
# state, not an integer value — applying bitwise ops to it is meaningless.
# Consequently none of the bitwise dunders appear in _hashlib.HASH.__dict__.
# The reflected variants (__rand__, __ror__, __rxor__) are similarly absent.
# True entries (update, digest, hexdigest) confirm that the dict-presence
# lookup mechanism is functioning correctly.
# Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-12.
# ---------------------------------------------------------------------------

table hashlib_extra1546.hash_bitwise_absent_md5:
  description: "Bitwise operator dunders absent from _hashlib.HASH.__dict__ (via md5()) — not a numeric type"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl1546ha

  columns: [id, function, args, expected]
  rows:
    - ["hl1546ha001", "md5().__class__.__dict__.__contains__", ["__and__"],    false]
    - ["hl1546ha002", "md5().__class__.__dict__.__contains__", ["__or__"],     false]
    - ["hl1546ha003", "md5().__class__.__dict__.__contains__", ["__xor__"],    false]
    - ["hl1546ha004", "md5().__class__.__dict__.__contains__", ["__invert__"], false]
    - ["hl1546ha005", "md5().__class__.__dict__.__contains__", ["__lshift__"], false]
    - ["hl1546ha006", "md5().__class__.__dict__.__contains__", ["__rshift__"], false]
    - ["hl1546ha007", "md5().__class__.__dict__.__contains__", ["__rand__"],   false]
    - ["hl1546ha008", "md5().__class__.__dict__.__contains__", ["__ror__"],    false]
    - ["hl1546ha009", "md5().__class__.__dict__.__contains__", ["__rxor__"],   false]
    - ["hl1546ha010", "md5().__class__.__dict__.__contains__", ["update"],     true]
    - ["hl1546ha011", "md5().__class__.__dict__.__contains__", ["digest"],     true]
    - ["hl1546ha012", "md5().__class__.__dict__.__contains__", ["hexdigest"],  true]

# ---------------------------------------------------------------------------
# _hashlib.HASH (via sha256) — bitwise operator absence checks
#
# sha256() returns the same _hashlib.HASH C-extension type as md5(). The
# absence of bitwise dunders is therefore identical. This table provides
# independent confirmation through the sha256 constructor path and also
# verifies the copy method and the name, digest_size, block_size attributes.
# ---------------------------------------------------------------------------

table hashlib_extra1546.hash_bitwise_absent_sha256:
  description: "Bitwise operator dunders absent from _hashlib.HASH.__dict__ (via sha256()) — confirmed via second constructor"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl1546hb

  columns: [id, function, args, expected]
  rows:
    - ["hl1546hb001", "sha256().__class__.__dict__.__contains__", ["__and__"],      false]
    - ["hl1546hb002", "sha256().__class__.__dict__.__contains__", ["__or__"],       false]
    - ["hl1546hb003", "sha256().__class__.__dict__.__contains__", ["__xor__"],      false]
    - ["hl1546hb004", "sha256().__class__.__dict__.__contains__", ["__invert__"],   false]
    - ["hl1546hb005", "sha256().__class__.__dict__.__contains__", ["__lshift__"],   false]
    - ["hl1546hb006", "sha256().__class__.__dict__.__contains__", ["__rshift__"],   false]
    - ["hl1546hb007", "sha256().__class__.__dict__.__contains__", ["__rand__"],     false]
    - ["hl1546hb008", "sha256().__class__.__dict__.__contains__", ["__ror__"],      false]
    - ["hl1546hb009", "sha256().__class__.__dict__.__contains__", ["__rxor__"],     false]
    - ["hl1546hb010", "sha256().__class__.__dict__.__contains__", ["copy"],         true]
    - ["hl1546hb011", "sha256().__class__.__dict__.__contains__", ["name"],         true]
    - ["hl1546hb012", "sha256().__class__.__dict__.__contains__", ["digest_size"],  true]

# ---------------------------------------------------------------------------
# hashlib.blake2b — bitwise operator absence checks
#
# blake2b is a separate C-extension type accessible as hashlib.blake2b. Like
# _hashlib.HASH, it is a hash-state container with no integer semantics.
# None of the bitwise dunders (__and__, __or__, __xor__, __invert__,
# __lshift__, __rshift__, __rand__, __ror__, __rxor__) appear in
# hashlib.blake2b.__dict__. True entries (digest_size, block_size, name)
# confirm that dict-presence lookups on blake2b work correctly.
# ---------------------------------------------------------------------------

table hashlib_extra1546.blake2b_bitwise_absent:
  description: "Bitwise operator dunders absent from hashlib.blake2b.__dict__ — hash state, not a numeric type"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl1546bc

  columns: [id, function, args, expected]
  rows:
    - ["hl1546bc001", "blake2b.__dict__.__contains__", ["__and__"],    false]
    - ["hl1546bc002", "blake2b.__dict__.__contains__", ["__or__"],     false]
    - ["hl1546bc003", "blake2b.__dict__.__contains__", ["__xor__"],    false]
    - ["hl1546bc004", "blake2b.__dict__.__contains__", ["__invert__"], false]
    - ["hl1546bc005", "blake2b.__dict__.__contains__", ["__lshift__"], false]
    - ["hl1546bc006", "blake2b.__dict__.__contains__", ["__rshift__"], false]
    - ["hl1546bc007", "blake2b.__dict__.__contains__", ["__rand__"],   false]
    - ["hl1546bc008", "blake2b.__dict__.__contains__", ["__ror__"],    false]
    - ["hl1546bc009", "blake2b.__dict__.__contains__", ["__rxor__"],   false]
    - ["hl1546bc010", "blake2b.__dict__.__contains__", ["digest_size"],true]
    - ["hl1546bc011", "blake2b.__dict__.__contains__", ["block_size"], true]
    - ["hl1546bc012", "blake2b.__dict__.__contains__", ["name"],       true]
