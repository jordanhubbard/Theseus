spec: copy_extra7
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
  notes:
    - "This spec extends copy.zspec.zsdl and prior extras through copy_extra6.zspec.zsdl."
    - "Prior specs cover: copy/deepcopy of primitives (int, str, None, bool, float) and containers (list, dict, tuple); copy/deepcopy __name__/__module__/__qualname__/__class__.__name__; Error __name__/__module__/__qualname__/__class__.__name__/__bases__; copy returns equal value checks."
    - "NEW in this spec: copy.copy of negative int; copy.copy of a large int; copy.deepcopy of 'world' (distinct from 'hello'); deepcopy return type for str; copy.copy list length check; copy.copy dict length check; copy.deepcopy list of strings; copy.Error.__mro__ length; copy.Error.__mro__[1].__name__=='Exception'."
    - "copy.copy(-42) == -42 — negative int is an immutable singleton preserved by shallow copy."
    - "copy.copy(1000000) == 1000000 — large int shallow copy returns equal value."
    - "copy.deepcopy('world') == 'world' — deepcopy of a string returns equal value."
    - "copy.deepcopy('world').__class__.__name__ == 'str' — deepcopy of str returns a str."
    - "copy.copy([1,2,3]).__len__() == 3 — shallow-copied list preserves length."
    - "copy.copy({'a':1,'b':2}).__len__() == 2 — shallow-copied dict preserves key count."
    - "copy.deepcopy(['a','b','c']) == ['a','b','c'] — deepcopy of list of strings."
    - "copy.Error.__mro__.__len__() == 4 — MRO is [Error, Exception, BaseException, object]."
    - "copy.Error.__mro__[1].__name__ == 'Exception' — second entry in MRO is Exception."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# copy.copy — negative and large integers
#
# Prior copy specs test copy of 42 (positive int) and 0; no prior spec tests
# negative integers or larger positive integers. Integers are immutable, so
# copy.copy returns an equal value regardless of the actual memory address.
# ---------------------------------------------------------------------------

invariant copy_extra7.copy.negative_int:
  description: "copy.copy(-42) == -42 — shallow copy of a negative int returns the same value"
  category: copy_scalars
  kind: python_call_eq
  function: copy
  args: [-42]
  expected: -42

invariant copy_extra7.copy.large_int:
  description: "copy.copy(1000000) == 1000000 — shallow copy of a large int returns equal value"
  category: copy_scalars
  kind: python_call_eq
  function: copy
  args: [1000000]
  expected: 1000000

# ---------------------------------------------------------------------------
# copy.deepcopy — string 'world' (new value, distinct from 'hello')
#
# copy.zspec.zsdl tests deepcopy of 'hello'. This spec uses 'world' to confirm
# the behavior generalises to any string, and also verifies the return type.
# ---------------------------------------------------------------------------

invariant copy_extra7.deepcopy.world_value:
  description: "copy.deepcopy('world') == 'world' — deepcopy of a string returns an equal string"
  category: deepcopy_scalars
  kind: python_call_eq
  function: deepcopy
  args: ["world"]
  expected: "world"

invariant copy_extra7.deepcopy.world_class:
  description: "copy.deepcopy('world').__class__.__name__ == 'str' — deepcopy of str returns a str"
  category: deepcopy_type
  kind: python_call_eq
  function: deepcopy
  args: ["world"]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# copy.deepcopy of a negative int
#
# Confirms deepcopy also works correctly on negative integers, which are
# distinct from the positive integer vectors in prior specs.
# ---------------------------------------------------------------------------

invariant copy_extra7.deepcopy.negative_int:
  description: "copy.deepcopy(-5) == -5 — deepcopy of a negative int returns the same value"
  category: deepcopy_scalars
  kind: python_call_eq
  function: deepcopy
  args: [-5]
  expected: -5

# ---------------------------------------------------------------------------
# copy.copy — length checks on sequence containers
#
# Prior specs verify that copy returns an equal value but do not explicitly
# check the length of the returned container. This confirms the container
# preserves its element count.
# ---------------------------------------------------------------------------

invariant copy_extra7.copy.list_len:
  description: "copy.copy([1,2,3]).__len__() == 3 — shallow-copied list has the same length"
  category: copy_containers
  kind: python_call_eq
  function: copy
  args: [[1, 2, 3]]
  method: __len__
  method_args: []
  expected: 3

invariant copy_extra7.copy.dict_len:
  description: "copy.copy({'a': 1, 'b': 2}).__len__() == 2 — shallow-copied dict preserves key count"
  category: copy_containers
  kind: python_call_eq
  function: copy
  args: [{"a": 1, "b": 2}]
  method: __len__
  method_args: []
  expected: 2

# ---------------------------------------------------------------------------
# copy.deepcopy — list of strings
#
# Prior specs test deepcopy of lists of integers and nested lists. This adds
# a list of string elements to confirm that string elements are also preserved.
# ---------------------------------------------------------------------------

invariant copy_extra7.deepcopy.list_of_strings:
  description: "copy.deepcopy(['a','b','c']) == ['a','b','c'] — deepcopy of a list of strings"
  category: deepcopy_containers
  kind: python_call_eq
  function: deepcopy
  args: [["a", "b", "c"]]
  expected: ["a", "b", "c"]

# ---------------------------------------------------------------------------
# copy.Error — MRO (method resolution order)
#
# The MRO for copy.Error is [Error, Exception, BaseException, object].
# copy_extra6 checks the direct base; this spec checks the length of the full
# MRO and confirms the second entry is Exception (one level of indirection).
# ---------------------------------------------------------------------------

invariant copy_extra7.Error.mro_len:
  description: "copy.Error.__mro__.__len__() == 4 — MRO: Error, Exception, BaseException, object"
  category: error_hierarchy
  kind: python_call_eq
  function: Error.__mro__.__len__
  args: []
  expected: 4

invariant copy_extra7.Error.mro_1_is_Exception:
  description: "copy.Error.__mro__[1].__name__ == 'Exception' — second MRO entry is Exception"
  category: error_hierarchy
  kind: python_call_eq
  function: Error.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Exception"
