spec: wheel_rust
version: ">=3.9"
backend: rust_module(wheel_rust)

docs: https://wheel.readthedocs.io/

provenance:
  derived_from:
    - "https://wheel.readthedocs.io/ — wheel package format"
  notes:
    - "wheel provides the wheel package format."
    - "wheel.wheelfile.WheelFile is a class."
    - "wheel.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant wheel_rust.has_wheel_file:
  description: "wheel.wheelfile.WheelFile is a class"
  category: presence
  kind: python_call_eq
  function: wheel_has_wheel_file
  args: []
  expected: true

invariant wheel_rust.has_bdist_wheel:
  description: "wheel.bdist_wheel is importable"
  category: presence
  kind: python_call_eq
  function: wheel_has_bdist_wheel
  args: []
  expected: true

invariant wheel_rust.version_nonempty:
  description: "wheel.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: wheel_version_nonempty
  args: []
  expected: true

