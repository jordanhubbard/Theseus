spec: io_extra187
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "io.BytesIO.__name__ == 'BytesIO' (len=7); io.BytesIO.__module__ == '_io' (the C-level backing module, not 'io'); io.BytesIO.__qualname__ == 'BytesIO'; io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' (underscore-prefixed C-level base class)."
    - "io.StringIO.__name__ == 'StringIO' (len=8); io.StringIO.__module__ == '_io' (the C-level backing module, not 'io'); io.StringIO.__qualname__ == 'StringIO'; io.StringIO.__bases__[0].__name__ == '_TextIOBase' (underscore-prefixed C-level base class)."
    - "Both BytesIO and StringIO are implemented in the C extension _io, re-exported through the io module; __module__ reports '_io', not 'io'."
    - "len('BytesIO') == 7: B(1)y(2)t(3)e(4)s(5)I(6)O(7); len('StringIO') == 8: S(1)t(2)r(3)i(4)n(5)g(6)I(7)O(8); StringIO (8) > BytesIO (7)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.BytesIO class identity
# __name__=='BytesIO' (len=7); __module__=='_io'; __qualname__=='BytesIO'
# ---------------------------------------------------------------------------

table io_extra187.bytesio_class_identity:
  description: "io.BytesIO class identity: __name__=='BytesIO' (len=7); __module__=='_io' (C backing module); __qualname__=='BytesIO'; BytesIO (7) < StringIO (8): BytesIO class name is 1 character shorter than StringIO"
  kind: python_call_eq
  category: identity
  id_prefix: iobytesio187

  columns: [id, function, args, expected, description]
  rows:
    - [bytesio_name,      BytesIO.__name__.__eq__,        ["BytesIO"], true,  "io.BytesIO.__name__ == 'BytesIO' — the BytesIO class has the expected short name; len('BytesIO')==7: B(1)y(2)t(3)e(4)s(5)I(6)O(7); confirmed Python 3.14.3 macOS"]
    - [bytesio_name_len,  BytesIO.__name__.__len__,       [],          7,     "io.BytesIO.__name__.__len__() == 7 — 'BytesIO' has 7 characters; BytesIO (7) < StringIO (8): BytesIO is 1 char shorter; confirmed Python 3.14.3 macOS"]
    - [bytesio_module,    BytesIO.__module__.__eq__,      ["_io"],     true,  "io.BytesIO.__module__ == '_io' — BytesIO is implemented in the C extension _io, not in pure-Python io; __module__ reports '_io'; confirmed Python 3.14.3 macOS"]
    - [bytesio_qualname,  BytesIO.__qualname__.__eq__,    ["BytesIO"], true,  "io.BytesIO.__qualname__ == 'BytesIO' — BytesIO is a top-level class so __qualname__ matches __name__; confirmed Python 3.14.3 macOS"]
    - [bytesio_base_name, "BytesIO.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true, "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — the direct base class of BytesIO is the C-level _BufferedIOBase; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.StringIO class identity
# __name__=='StringIO' (len=8); __module__=='_io'; __qualname__=='StringIO'
# ---------------------------------------------------------------------------

table io_extra187.stringio_class_identity:
  description: "io.StringIO class identity: __name__=='StringIO' (len=8); __module__=='_io' (C backing module); __qualname__=='StringIO'; StringIO (8) > BytesIO (7): StringIO class name is 1 character longer than BytesIO"
  kind: python_call_eq
  category: identity
  id_prefix: iobytesio187

  columns: [id, function, args, expected, description]
  rows:
    - [stringio_name,      StringIO.__name__.__eq__,        ["StringIO"], true,  "io.StringIO.__name__ == 'StringIO' — the StringIO class has the expected short name; len('StringIO')==8: S(1)t(2)r(3)i(4)n(5)g(6)I(7)O(8); confirmed Python 3.14.3 macOS"]
    - [stringio_name_len,  StringIO.__name__.__len__,       [],           8,     "io.StringIO.__name__.__len__() == 8 — 'StringIO' has 8 characters; StringIO (8) > BytesIO (7): StringIO is 1 char longer; confirmed Python 3.14.3 macOS"]
    - [stringio_module,    StringIO.__module__.__eq__,      ["_io"],      true,  "io.StringIO.__module__ == '_io' — StringIO is implemented in the C extension _io, not in pure-Python io; __module__ reports '_io'; confirmed Python 3.14.3 macOS"]
    - [stringio_qualname,  StringIO.__qualname__.__eq__,    ["StringIO"], true,  "io.StringIO.__qualname__ == 'StringIO' — StringIO is a top-level class so __qualname__ matches __name__; confirmed Python 3.14.3 macOS"]
    - [stringio_base_name, "StringIO.__bases__[0].__name__.__eq__", ["_TextIOBase"], true, "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — the direct base class of StringIO is the C-level _TextIOBase; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: BytesIO vs StringIO name length comparison
# BytesIO (7) < StringIO (8); module for both is '_io'
# ---------------------------------------------------------------------------

table io_extra187.bytesio_stringio_comparison:
  description: "BytesIO vs StringIO name length comparison: BytesIO (7) < StringIO (8); both __module__ == '_io'; BytesIO.__name__ != StringIO.__name__; cross-checks that the two class names are distinct and correctly sized"
  kind: python_call_eq
  category: identity
  id_prefix: iobytesio187

  columns: [id, function, args, expected, description]
  rows:
    - [names_ne,          BytesIO.__name__.__eq__,        ["StringIO"], false, "io.BytesIO.__name__.__eq__('StringIO') == False — BytesIO and StringIO have distinct class names; 'BytesIO' != 'StringIO'; confirmed Python 3.14.3 macOS"]
    - [both_module_io,    BytesIO.__module__.__eq__,      ["_io"],      true,  "io.BytesIO.__module__ == '_io' — both BytesIO and StringIO share the _io C-extension module; cross-check for BytesIO side; confirmed Python 3.14.3 macOS"]
    - [str_module_io,     StringIO.__module__.__eq__,     ["_io"],      true,  "io.StringIO.__module__ == '_io' — both BytesIO and StringIO share the _io C-extension module; cross-check for StringIO side; confirmed Python 3.14.3 macOS"]
    - [bytesio_lt_str,    BytesIO.__name__.__len__,       [],           7,     "io.BytesIO.__name__.__len__() == 7 — BytesIO (7) < StringIO (8): BytesIO class name is 1 character shorter than StringIO; confirmed Python 3.14.3 macOS"]
    - [stringio_gt_bytes, StringIO.__name__.__len__,      [],           8,     "io.StringIO.__name__.__len__() == 8 — StringIO (8) > BytesIO (7): StringIO class name is 1 character longer than BytesIO; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra187.bytesio_name_is_bytesio:
  description: "io.BytesIO.__name__ == 'BytesIO' — BytesIO class has the expected name; len('BytesIO')==7: B(1)y(2)t(3)e(4)s(5)I(6)O(7); BytesIO (7) < StringIO (8); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BytesIO.__name__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra187.bytesio_name_len_is_7:
  description: "io.BytesIO.__name__.__len__() == 7 — 'BytesIO' has 7 characters; BytesIO (7) < StringIO (8): BytesIO is 1 char shorter; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BytesIO.__name__.__len__
  args: []
  expected: 7

invariant io_extra187.bytesio_module_is_underscore_io:
  description: "io.BytesIO.__module__ == '_io' — BytesIO is implemented in the C extension _io; __module__ is '_io', not 'io'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BytesIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra187.bytesio_qualname_is_bytesio:
  description: "io.BytesIO.__qualname__ == 'BytesIO' — top-level class so __qualname__ matches __name__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: BytesIO.__qualname__.__eq__
  args: ["BytesIO"]
  expected: true

invariant io_extra187.bytesio_base_is_bufferediobase:
  description: "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO inherits from the C-level _BufferedIOBase; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "BytesIO.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra187.stringio_name_is_stringio:
  description: "io.StringIO.__name__ == 'StringIO' — StringIO class has the expected name; len('StringIO')==8: S(1)t(2)r(3)i(4)n(5)g(6)I(7)O(8); StringIO (8) > BytesIO (7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: StringIO.__name__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra187.stringio_name_len_is_8:
  description: "io.StringIO.__name__.__len__() == 8 — 'StringIO' has 8 characters; StringIO (8) > BytesIO (7): StringIO is 1 char longer; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: StringIO.__name__.__len__
  args: []
  expected: 8

invariant io_extra187.stringio_module_is_underscore_io:
  description: "io.StringIO.__module__ == '_io' — StringIO is implemented in the C extension _io; __module__ is '_io', not 'io'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra187.stringio_qualname_is_stringio:
  description: "io.StringIO.__qualname__ == 'StringIO' — top-level class so __qualname__ matches __name__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: StringIO.__qualname__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra187.stringio_base_is_textiobase:
  description: "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO inherits from the C-level _TextIOBase; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "StringIO.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true
