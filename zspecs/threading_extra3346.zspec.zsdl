spec: th3346
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 670 (th3346): __neg__, __pos__, __abs__ dict-presence checks for threading types."
    - "Theme: __neg__/__pos__/__abs__ unary arithmetic dict-presence."
    - "Unary arithmetic operators (-x, +x, abs(x)) are defined by __neg__, __pos__, __abs__ respectively."
    - "All values False — callable/iterator/inspection/synchronization types have no unary arithmetic operators."
    - "None of the threading types define __neg__, __pos__, or __abs__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3346.neg:
  description: "threading types __neg__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3346
  columns: [id, function, args, expected]
  rows:
    - ["th3346001", operator.contains, [threading.Thread.__dict__,           "__neg__"], false]
    - ["th3346002", operator.contains, [threading.Event.__dict__,            "__neg__"], false]
    - ["th3346003", operator.contains, [threading.Condition.__dict__,        "__neg__"], false]
    - ["th3346004", operator.contains, [threading.Semaphore.__dict__,        "__neg__"], false]
    - ["th3346005", operator.contains, [threading.BoundedSemaphore.__dict__, "__neg__"], false]
    - ["th3346006", operator.contains, [threading.Timer.__dict__,            "__neg__"], false]
    - ["th3346007", operator.contains, [threading.Barrier.__dict__,          "__neg__"], false]
    - ["th3346008", operator.contains, [threading.local.__dict__,            "__neg__"], false]
    - ["th3346009", operator.contains, [type(threading.Lock()).__dict__,     "__neg__"], false]
    - ["th3346010", operator.contains, [type(threading.RLock()).__dict__,    "__neg__"], false]

