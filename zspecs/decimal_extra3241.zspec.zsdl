spec: dc3241
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed-point and floating-point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 663 (dc3241): __rtruediv__, __rfloordiv__, __rmod__ dict-presence checks for decimal types."
    - "Classes covered: decimal.Decimal, decimal.Context, decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow."
    - "Theme: __rtruediv__, __rfloordiv__, __rmod__ dict-presence (reflected division/modulo)."
    - "Key finding: decimal.Decimal defines all 3 reflected operators — consistent with wave 662 (__radd__/__rsub__/__rmul__ all true)."
    - "decimal.Decimal.__rtruediv__ = True: Decimal is a full numeric type implementing IEEE 754 decimal arithmetic; it defines __rtruediv__ so that expressions like (int / Decimal) work correctly by delegating to Decimal.__rtruediv__."
    - "decimal.Decimal.__rfloordiv__ = True: Decimal defines __rfloordiv__ to handle right-hand floor division, e.g. (int // Decimal) dispatches to Decimal.__rfloordiv__."
    - "decimal.Decimal.__rmod__ = True: Decimal defines __rmod__ to handle right-hand modulo, e.g. (int % Decimal) dispatches to Decimal.__rmod__."
    - "decimal.Context does NOT define __rtruediv__, __rfloordiv__, or __rmod__ in its own __dict__: Context is a precision/rounding configuration object, not a numeric operand."
    - "decimal.DecimalException, decimal.InvalidOperation, decimal.Overflow, decimal.Underflow are exception subclasses with no arithmetic protocol defined in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __rtruediv__ dict-presence — operator.contains(Cls.__dict__, '__rtruediv__')
#
# decimal.Decimal defines __rtruediv__ in its own __dict__: true.
# Decimal is a complete numeric type implementing IEEE 754; __rtruediv__ enables
# right-hand true division so that (int / Decimal) dispatches to Decimal.__rtruediv__.
# All other decimal classes: false.
# ---------------------------------------------------------------------------

table dc3241.rtruediv:
  description: "decimal types __rtruediv__ dict-presence checks; wave 663"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: dc3241

  columns: [id, function, args, expected]
  rows:
    - ["dc3241001", operator.contains, [decimal.Decimal.__dict__,          "__rtruediv__"], true]
    - ["dc3241002", operator.contains, [decimal.Context.__dict__,           "__rtruediv__"], false]
    - ["dc3241003", operator.contains, [decimal.DecimalException.__dict__,  "__rtruediv__"], false]
    - ["dc3241004", operator.contains, [decimal.InvalidOperation.__dict__,  "__rtruediv__"], false]
    - ["dc3241005", operator.contains, [decimal.Overflow.__dict__,          "__rtruediv__"], false]
    - ["dc3241006", operator.contains, [decimal.Underflow.__dict__,         "__rtruediv__"], false]

