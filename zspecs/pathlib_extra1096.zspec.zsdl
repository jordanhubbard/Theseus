spec: pathlib_extra1096
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module Path.exists/is_dir/is_file/is_absolute, PurePath.__hash__/__eq__/__lt__, and Path.__bytes__ method documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks Path.exists/is_dir/is_file/is_absolute __qualname__ (not covered in _extra1066/_extra1081 which covered stat/chmod/lstat/glob/cwd/home), PurePath.__hash__/__eq__/__lt__ qualnames, and Path.__bytes__ qualname"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1096.path_predicate_qualnames:
  description: "pathlib.Path existence and type predicate method __qualname__ checks"
  kind: python_call_eq
  category: path_predicate_qualnames
  id_prefix: pl1096pp
  columns: [id, function, args, expected]
  rows:
    - [pl1096pp001, pathlib.Path.exists.__qualname__.__eq__,       ["Path.exists"],       true]
    - [pl1096pp002, pathlib.Path.is_dir.__qualname__.__eq__,       ["Path.is_dir"],       true]
    - [pl1096pp003, pathlib.Path.is_file.__qualname__.__eq__,      ["Path.is_file"],      true]
    - [pl1096pp004, pathlib.Path.is_absolute.__qualname__.__eq__,  ["PurePath.is_absolute"], true]
    - [pl1096pp005, pathlib.Path.is_symlink.__qualname__.__eq__,   ["Path.is_symlink"],   true]
    - [pl1096pp006, pathlib.Path.is_mount.__qualname__.__eq__,     ["Path.is_mount"],     true]
    - [pl1096pp007, pathlib.Path.exists.__module__.__eq__,         ["pathlib"],           true]
    - [pl1096pp008, pathlib.Path.is_file.__module__.__eq__,        ["pathlib"],           true]

table pathlib_extra1096.purepath_dunder_qualnames:
  description: "pathlib.PurePath dunder method __qualname__ checks for __hash__, __eq__, and __lt__"
  kind: python_call_eq
  category: purepath_dunder_qualnames
  id_prefix: pl1096pd
  columns: [id, function, args, expected]
  rows:
    - [pl1096pd001, pathlib.PurePath.__hash__.__qualname__.__eq__,  ["PurePath.__hash__"],  true]
    - [pl1096pd002, pathlib.PurePath.__eq__.__qualname__.__eq__,    ["PurePath.__eq__"],    true]
    - [pl1096pd003, pathlib.PurePath.__lt__.__qualname__.__eq__,    ["PurePath.__lt__"],    true]
    - [pl1096pd004, pathlib.PurePath.__le__.__qualname__.__eq__,    ["PurePath.__le__"],    true]
    - [pl1096pd005, pathlib.PurePath.__gt__.__qualname__.__eq__,    ["PurePath.__gt__"],    true]
    - [pl1096pd006, pathlib.PurePath.__ge__.__qualname__.__eq__,    ["PurePath.__ge__"],    true]
    - [pl1096pd007, pathlib.PurePath.__hash__.__module__.__eq__,    ["pathlib"],            true]
    - [pl1096pd008, pathlib.PurePath.__eq__.__module__.__eq__,      ["pathlib"],            true]

table pathlib_extra1096.path_bytes_and_repr_qualnames:
  description: "pathlib.Path __bytes__ and __repr__ method __qualname__ checks, and PurePath module identity"
  kind: python_call_eq
  category: path_bytes_and_repr_qualnames
  id_prefix: pl1096br
  columns: [id, function, args, expected]
  rows:
    - [pl1096br001, pathlib.PurePath.__repr__.__qualname__.__eq__, ["PurePath.__repr__"], true]
    - [pl1096br002, pathlib.PurePath.__repr__.__module__.__eq__,   ["pathlib"],           true]
    - [pl1096br003, pathlib.PurePath.__module__.__eq__,            ["pathlib"],           true]
    - [pl1096br004, pathlib.PurePath.__qualname__.__eq__,          ["PurePath"],          true]
    - [pl1096br005, pathlib.Path.__module__.__eq__,                ["pathlib"],           true]
    - [pl1096br006, pathlib.Path.__qualname__.__eq__,              ["Path"],              true]
    - [pl1096br007, pathlib.Path.mkdir.__qualname__.__eq__,        ["Path.mkdir"],        true]
