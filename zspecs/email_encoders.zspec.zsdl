spec: email_encoders
version: ">=3.3"
backend: python_module(email.encoders)

docs: https://docs.python.org/3/library/email.encoders.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/email.encoders.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "email.encoders source: Lib/email/encoders.py (PSF; source inspection permitted)"
  not_derived_from:
    - "email.encoders source: base64 / quopri codec internals"
  notes:
    - "email.encoders exposes four functions that encode the payload of a MIMEBase object in-place."
    - "encode_base64(msg) encodes msg's payload with Base64 and sets the Content-Transfer-Encoding header."
    - "encode_quopri(msg) encodes msg's payload with Quoted-Printable encoding."
    - "encode_7or8bit(msg) sets Content-Transfer-Encoding to '7bit' or '8bit' based on payload content."
    - "encode_noop(msg) does nothing — a no-op encoder used as a pass-through."
    - "All four functions accept a MIMEBase instance; behavioral invariants require a live MIMEBase object and are not tested here."
    - "All expected values verified by running Python 3.12 email.encoders module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

