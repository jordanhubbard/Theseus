    - [encode_quopri,  encode_quopri.__module__.__eq__,  ["email.encoders"], true]
    - [encode_7or8bit, encode_7or8bit.__module__.__eq__, ["email.encoders"], true]
    - [encode_noop,    encode_noop.__module__.__eq__,    ["email.encoders"], true]

