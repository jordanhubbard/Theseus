    - [encode_quopri,  encode_quopri.__name__.__eq__,  ["encode_quopri"],  true]
    - [encode_7or8bit, encode_7or8bit.__name__.__eq__, ["encode_7or8bit"], true]
    - [encode_noop,    encode_noop.__name__.__eq__,    ["encode_noop"],    true]

