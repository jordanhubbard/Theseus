spec: inspect_extra174
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter class identity — __name__ 'Parameter' (len 9); __module__ 'inspect'; __mro__.__len__() 2 (Parameter > object); POSITIONAL_OR_KEYWORD.__class__.__name__ '_ParameterKind' (enum member); POSITIONAL_OR_KEYWORD value 1 (POSITIONAL_ONLY=0); VAR_POSITIONAL value 2; KEYWORD_ONLY value 3."
    - "inspect.Parameter.__name__ == 'Parameter' — the inspect.Parameter class has __name__ 'Parameter', 9 characters. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' — inspect.Parameter is defined in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.Parameter.__mro__.__len__() == 2 — inspect.Parameter inherits directly from object; its MRO is (Parameter, object). Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind' — it is an IntEnum member; the class name is '_ParameterKind' (with leading underscore) on Python 3.14.3. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY == 0, POSITIONAL_OR_KEYWORD == 1, VAR_POSITIONAL == 2, KEYWORD_ONLY == 3. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter class __name__ and __module__
#
# inspect.Parameter.__name__ == 'Parameter'
# inspect.Parameter.__name__.__len__() == 9
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.__module__.__len__() == 7
#
# inspect.Parameter is a Python class defined in Lib/inspect.py. It represents
# a parameter of a callable signature. Its __name__ is 'Parameter' (9 chars)
# and its __module__ is 'inspect' (7 chars). New to extra174.
# ---------------------------------------------------------------------------

table inspect_extra174.parameter_name_and_module:
  description: "inspect.Parameter.__name__ 'Parameter' len 9; __module__ 'inspect' len 7; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparam174

  columns: [id, function, args, expected, description]
  rows:
    - [param_name_parameter,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — the inspect.Parameter class has __name__ 'Parameter'; str.__eq__('Parameter') returns True; new to extra174"]
    - [param_name_len_9,
       "Parameter.__name__.__len__",
       [],
       9,
       "inspect.Parameter.__name__.__len__() == 9 — the string 'Parameter' has exactly 9 characters: P-a-r-a-m-e-t-e-r; str.__len__() returns 9; new to extra174"]
    - [param_module_inspect,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — inspect.Parameter is defined in Lib/inspect.py; its __module__ is the string 'inspect'; str.__eq__('inspect') returns True; new to extra174"]
    - [param_module_len_7,
       "Parameter.__module__.__len__",
       [],
       7,
       "inspect.Parameter.__module__.__len__() == 7 — the module name 'inspect' has exactly 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; new to extra174"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter.__mro__ length and entries
#
# inspect.Parameter.__mro__.__len__() == 2
# inspect.Parameter.__mro__[0].__name__ == 'Parameter'
# inspect.Parameter.__mro__[1].__name__ == 'object'
# inspect.Parameter.__mro__.__len__() != 3
#
# inspect.Parameter inherits directly from object with no intermediate base
# classes. Its MRO is (Parameter, object), a 2-tuple. Despite having many class
# attributes (POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL,
# KEYWORD_ONLY, VAR_KEYWORD, empty), its inheritance is flat. New to extra174.
# ---------------------------------------------------------------------------

table inspect_extra174.parameter_mro:
  description: "inspect.Parameter.__mro__: len 2, mro[0] 'Parameter', mro[1] 'object'; not len 3; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparam174

  columns: [id, function, args, expected, description]
  rows:
    - [param_mro_len_2,
       "Parameter.__mro__.__len__",
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — inspect.Parameter is a Python class defined in Lib/inspect.py representing a parameter of a callable; it inherits directly from object with no intermediate base classes; its __mro__ is (Parameter, object), a tuple of length 2; tuple.__len__() returns 2; new to extra174"]
    - ["param_mro_0_parameter",
       "Parameter.__mro__[0].__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__mro__[0].__name__.__eq__('Parameter') == True — the first entry in Parameter.__mro__ is the Parameter class itself; its __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra174"]
    - ["param_mro_1_object",
       "Parameter.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__mro__[1].__name__.__eq__('object') == True — the second entry in Parameter.__mro__ is the base class object; its __name__ is 'object'; this confirms Parameter inherits directly from object; str.__eq__('object') returns True; new to extra174"]
    - [param_mro_not_3,
       "Parameter.__mro__.__len__",
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 (not 3) — Parameter inherits only from object; there is no intermediate class; tuple.__len__() returns 2; new to extra174"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter.POSITIONAL_OR_KEYWORD enum kind identity
#
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True  (value is 1)
# inspect.Parameter.VAR_POSITIONAL.__eq__(2) == True
# inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True
#
# The Parameter kind constants are IntEnum members of the _ParameterKind enum
# (leading underscore, internal). POSITIONAL_OR_KEYWORD has integer value 1
# (not 0; POSITIONAL_ONLY=0). VAR_POSITIONAL=2, KEYWORD_ONLY=3. New to extra174.
# ---------------------------------------------------------------------------

table inspect_extra174.parameter_kind_values:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD class '_ParameterKind', value 1; VAR_POSITIONAL 2; KEYWORD_ONLY 3; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparam174

  columns: [id, function, args, expected, description]
  rows:
    - [pok_class_parameterkind,
       "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — POSITIONAL_OR_KEYWORD is an IntEnum member of the _ParameterKind enum (internal, with leading underscore); its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra174"]
    - [pok_value_1,
       "Parameter.POSITIONAL_OR_KEYWORD.__eq__",
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True — POSITIONAL_OR_KEYWORD has integer value 1 (not 0; POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1); it is an IntEnum so __eq__(1) returns True; new to extra174"]
    - [var_positional_value_2,
       "Parameter.VAR_POSITIONAL.__eq__",
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__eq__(2) == True — VAR_POSITIONAL has integer value 2; it represents *args parameters; as an IntEnum member, __eq__(2) returns True; new to extra174"]
    - [keyword_only_value_3,
       "Parameter.KEYWORD_ONLY.__eq__",
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True — KEYWORD_ONLY has integer value 3; it represents keyword-only parameters (those after * or *args in a signature); as an IntEnum member, __eq__(3) returns True; new to extra174"]

# ---------------------------------------------------------------------------
# Table 4: inspect.Parameter kind enum ordering cross-checks
#
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True
# inspect.Parameter.VAR_POSITIONAL.__eq__(2) == True
# inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind'
#
# Cross-checks confirming the integer ordering of the _ParameterKind enum
# values: POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1, VAR_POSITIONAL=2,
# KEYWORD_ONLY=3, VAR_KEYWORD=4. New to extra174.
# ---------------------------------------------------------------------------

table inspect_extra174.parameter_kind_ordering:
  description: "inspect.Parameter kinds ordering: POSITIONAL_OR_KEYWORD 1, VAR_POSITIONAL 2, KEYWORD_ONLY 3; class '_ParameterKind'; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: inspectparam174

  columns: [id, function, args, expected, description]
  rows:
    - [pok_is_1_not_0,
       "Parameter.POSITIONAL_OR_KEYWORD.__eq__",
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True — POSITIONAL_OR_KEYWORD is value 1 (not 0; POSITIONAL_ONLY is 0); the ordering is POSITIONAL_ONLY=0, POSITIONAL_OR_KEYWORD=1; __eq__(1) returns True; new to extra174"]
    - [var_positional_gt_pok,
       "Parameter.VAR_POSITIONAL.__eq__",
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__eq__(2) == True — VAR_POSITIONAL value 2 is greater than POSITIONAL_OR_KEYWORD value 1; it follows positional parameter kinds in the enum ordering; __eq__(2) returns True; new to extra174"]
    - [keyword_only_gt_var_pos,
       "Parameter.KEYWORD_ONLY.__eq__",
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True — KEYWORD_ONLY value 3 follows VAR_POSITIONAL (2); keyword-only parameters appear after *args in function signatures; __eq__(3) returns True; new to extra174"]
    - [pok_class_not_parameterkind_no_underscore,
       "Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — the enum class is named '_ParameterKind' (with a leading underscore indicating it is an internal/private name); str.__eq__('_ParameterKind') returns True; new to extra174"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra174
# ---------------------------------------------------------------------------

invariant inspect_extra174.parameter_name_parameter:
  description: "inspect.Parameter.__name__ == 'Parameter' — the class has __name__ 'Parameter'; new to extra174"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra174.parameter_name_len_9:
  description: "inspect.Parameter.__name__.__len__() == 9 — 'Parameter' is 9 characters long; new to extra174"
  kind: python_call_eq
  function: Parameter.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra174.parameter_module_inspect:
  description: "inspect.Parameter.__module__ == 'inspect' — Parameter is defined in Lib/inspect.py; new to extra174"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra174.parameter_mro_len_2:
  description: "inspect.Parameter.__mro__.__len__() == 2 — Parameter inherits directly from object; MRO is (Parameter, object); new to extra174"
  kind: python_call_eq
  function: Parameter.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra174.pok_class_parameterkind:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__ == '_ParameterKind' — it is an IntEnum member with internal class name; new to extra174"
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__
  args: ["_ParameterKind"]
  expected: true

invariant inspect_extra174.pok_value_1:
  description: "inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True — POSITIONAL_OR_KEYWORD has integer value 1 (POSITIONAL_ONLY=0); new to extra174"
  kind: python_call_eq
  function: Parameter.POSITIONAL_OR_KEYWORD.__eq__
  args: [1]
  expected: true

invariant inspect_extra174.var_positional_value_2:
  description: "inspect.Parameter.VAR_POSITIONAL.__eq__(2) == True — VAR_POSITIONAL has integer value 2; represents *args parameters; new to extra174"
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.__eq__
  args: [2]
  expected: true

invariant inspect_extra174.keyword_only_value_3:
  description: "inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True — KEYWORD_ONLY has integer value 3; represents keyword-only parameters; new to extra174"
  kind: python_call_eq
  function: Parameter.KEYWORD_ONLY.__eq__
  args: [3]
  expected: true

