spec: is_arrayish
version: ">=0.3.0"
backend: node(is-arrayish)

docs: https://github.com/qix-/node-is-arrayish#readme

provenance:
  derived_from:
    - "is-arrayish README — https://github.com/qix-/node-is-arrayish#readme"
    - "is-arrayish source — module.exports inspected for behavior."
    - "Test vectors verified with is-arrayish via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from: []
  notes:
    - "Predicate: 'is this Array-like enough to iterate?' — true for Arrays, false for plain objects, strings, primitives, null."
    - "Install: npm install is-arrayish"
    - "v0.3 CJS; module export IS the function. Note: only objects with .splice or own indexed properties match the array-like branch — plain {length: N} returns undefined (falsy)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant is_arrayish.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant is_arrayish.module_name:
  description: "Module function .name is 'isArrayish'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: name}
  expected: "isArrayish"

invariant is_arrayish.empty_array_true:
  description: "isArrayish([]) is true"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [[]]
  chain: []
  expected: true

invariant is_arrayish.populated_array_true:
  description: "isArrayish([1,2,3]) is true"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [[1, 2, 3]]
  chain: []
  expected: true

invariant is_arrayish.empty_object_false:
  description: "Plain {} is not arrayish"
  category: detect
  kind: node_chain_eq
  entry: module
  entry_args: [{}]
  chain: []
  expected: false

invariant is_arrayish.null_false:
  description: "null is not arrayish"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [null]
  chain: []
  expected: false

invariant is_arrayish.string_false:
  description: "Strings are not arrayish (early return)"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: ["abcdef"]
  chain: []
  expected: false

invariant is_arrayish.number_false:
  description: "Numbers are not arrayish"
  category: edge
  kind: node_chain_eq
  entry: module
  entry_args: [42]
  chain: []
  expected: false
