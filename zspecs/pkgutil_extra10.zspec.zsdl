spec: pkgutil_extra10
version: ">=3.9"
backend: python_module(pkgutil)

docs: https://docs.python.org/3/library/pkgutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pkgutil.html — Python pkgutil documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pkgutil.py"
    - "pkgutil_extra9.zspec.zsdl — covers __qualname__ for iter_modules/walk_packages/get_importer/resolve_name in a table."
  notes:
    - "This spec extends pkgutil.zspec.zsdl through pkgutil_extra9.zspec.zsdl."
    - "Focus: __qualname__ for remaining pkgutil functions not covered by extra9: get_data, extend_path, iter_importers, iter_importer_modules; and ModuleInfo.__qualname__."
    - "pkgutil.get_loader, pkgutil.find_loader, and pkgutil.ImpImporter do not exist in Python 3.12 (removed); this spec skips them."
    - "pkgutil.get_data.__qualname__ == 'get_data' — verified at runtime."
    - "pkgutil.extend_path.__qualname__ == 'extend_path' — verified at runtime."
    - "pkgutil.iter_importers.__qualname__ == 'iter_importers' — verified at runtime."
    - "pkgutil.iter_importer_modules.__qualname__ == 'iter_importer_modules' — verified at runtime."
    - "pkgutil.ModuleInfo.__qualname__ == 'ModuleInfo' — verified at runtime."
    - "pkgutil.__name__ == 'pkgutil' — verified at runtime."
    - "pkgutil.__package__ == '' — pkgutil is a top-level module with empty string package; verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Remaining function __qualname__ attributes — consolidated table
#
# pkgutil_extra9 covers __qualname__ for iter_modules/walk_packages/get_importer/
# resolve_name. This table covers the remaining public functions:
# get_data, extend_path, iter_importers, iter_importer_modules.
# ---------------------------------------------------------------------------

table pkgutil_extra10.function_qualnames:
  description: "__qualname__ for get_data, extend_path, iter_importers, iter_importer_modules"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [get_data,             get_data.__qualname__.__eq__,             ["get_data"],             true]
    - [extend_path,          extend_path.__qualname__.__eq__,          ["extend_path"],          true]
    - [iter_importers,       iter_importers.__qualname__.__eq__,       ["iter_importers"],       true]
    - [iter_importer_modules, iter_importer_modules.__qualname__.__eq__, ["iter_importer_modules"], true]

# ---------------------------------------------------------------------------
# pkgutil.ModuleInfo — __qualname__ standalone
#
# pkgutil_extra8 covers ModuleInfo.__name__ == 'ModuleInfo'. No prior pkgutil
# spec checks ModuleInfo.__qualname__. For a module-level class (even a
# namedtuple subclass) __qualname__ equals the simple class name.
# ---------------------------------------------------------------------------

invariant pkgutil_extra10.ModuleInfo.qualname:
  description: "pkgutil.ModuleInfo.__qualname__ == 'ModuleInfo'"
  category: class_attrs
  kind: python_call_eq
  function: ModuleInfo.__qualname__.__eq__
  args: ["ModuleInfo"]
  expected: true

# ---------------------------------------------------------------------------
# pkgutil.__name__ — standalone
#
# No prior pkgutil spec checks pkgutil.__name__ via __eq__ chain as a
# standalone invariant. This anchors it in the extra10 namespace.
# ---------------------------------------------------------------------------

invariant pkgutil_extra10.module.name:
  description: "pkgutil.__name__ == 'pkgutil'"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["pkgutil"]
  expected: true

# ---------------------------------------------------------------------------
# pkgutil.__package__ — standalone
#
# pkgutil is a top-level module; its __package__ is the empty string ''.
# No prior pkgutil spec checks __package__ at all.
# ---------------------------------------------------------------------------

invariant pkgutil_extra10.module.package:
  description: "pkgutil.__package__ == '' — top-level module has empty package string"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true
