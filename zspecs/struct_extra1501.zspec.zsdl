spec: struct_extra1501
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module Struct class and error class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 547 (_extra1501): async protocol method dict-presence checks for struct.Struct and struct.error."
    - "struct is a sync-only binary packing module; neither Struct nor error implements __await__, __aiter__, __anext__, __aenter__, or __aexit__."
    - "Positive anchor columns confirm that genuine Struct methods (pack, unpack, pack_into, unpack_from, iter_unpack) ARE present in struct.Struct.__dict__."
    - "struct.error.__dict__ contains only __doc__, __module__, and __weakref__; no operational methods beyond what is inherited."
    - "All results verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct — async protocol absent
# ---------------------------------------------------------------------------

table struct_extra1501.Struct.async_protocol_absent:
  description: "struct.Struct has no async protocol methods in its __dict__"
  kind: python_call_eq
  category: async_protocol
  id_prefix: st1501sa
  columns: [id, function, args, expected]
  rows:
    - [st1501sa001, struct.Struct.__dict__.__contains__, ["__await__"],  false]
    - [st1501sa002, struct.Struct.__dict__.__contains__, ["__aiter__"],  false]
    - [st1501sa003, struct.Struct.__dict__.__contains__, ["__anext__"],  false]
    - [st1501sa004, struct.Struct.__dict__.__contains__, ["__aenter__"], false]
    - [st1501sa005, struct.Struct.__dict__.__contains__, ["__aexit__"],  false]
    - [st1501sa006, struct.Struct.__dict__.__contains__, ["pack"],       true]

# ---------------------------------------------------------------------------
# struct.Struct — sync methods present (positive anchors)
# ---------------------------------------------------------------------------

table struct_extra1501.Struct.sync_methods_present:
  description: "struct.Struct sync operational methods are present in its __dict__"
  kind: python_call_eq
  category: async_protocol
  id_prefix: st1501ss
  columns: [id, function, args, expected]
  rows:
    - [st1501ss001, struct.Struct.__dict__.__contains__, ["pack"],         true]
    - [st1501ss002, struct.Struct.__dict__.__contains__, ["unpack"],       true]
    - [st1501ss003, struct.Struct.__dict__.__contains__, ["pack_into"],    true]
    - [st1501ss004, struct.Struct.__dict__.__contains__, ["unpack_from"],  true]
    - [st1501ss005, struct.Struct.__dict__.__contains__, ["iter_unpack"],  true]
    - [st1501ss006, struct.Struct.__dict__.__contains__, ["format"],       true]
    - [st1501ss007, struct.Struct.__dict__.__contains__, ["size"],         true]

# ---------------------------------------------------------------------------
# struct.error — async protocol absent, own __dict__ keys present
# ---------------------------------------------------------------------------

table struct_extra1501.error.async_protocol_absent:
  description: "struct.error has no async protocol methods in its __dict__; own keys (__doc__, __module__) ARE present"
  kind: python_call_eq
  category: async_protocol
  id_prefix: st1501ea
  columns: [id, function, args, expected]
  rows:
    - [st1501ea001, struct.error.__dict__.__contains__, ["__await__"],  false]
    - [st1501ea002, struct.error.__dict__.__contains__, ["__aiter__"],  false]
    - [st1501ea003, struct.error.__dict__.__contains__, ["__anext__"],  false]
    - [st1501ea004, struct.error.__dict__.__contains__, ["__aenter__"], false]
    - [st1501ea005, struct.error.__dict__.__contains__, ["__aexit__"],  false]
    - [st1501ea006, struct.error.__dict__.__contains__, ["__doc__"],    true]
    - [st1501ea007, struct.error.__dict__.__contains__, ["__module__"], true]
