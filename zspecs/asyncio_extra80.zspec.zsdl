spec: asyncio_extra80
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio_extra79.zspec.zsdl."
    - "This spec covers: wave 244 theme — asyncio Task/Future class identity (C types in Python 3.14). NEW in extra80: Task.__name__=='Task'; Task.__module__=='_asyncio' (C extension); Task.__bases__[0].__name__=='Future'; Task.__mro__.__len__()==3 (MRO: Task, Future, object); Future.__name__=='Future'; Future.__module__=='_asyncio' (C extension); Future.__bases__[0].__name__=='object'; Future.__mro__.__len__()==2 (MRO: Future, object); Task.__dict__.__class__.__name__=='mappingproxy'; Future.__dict__.__class__.__name__=='mappingproxy'; Task.__dict__.__contains__('cancel')==True; Task.__dict__.__contains__('result')==True; Future.__dict__.__contains__('result')==True; Future.__dict__.__contains__('cancel')==True; asyncio.Task.__qualname__=='Task'; asyncio.Future.__qualname__=='Future'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__name__ == 'Task'. Task is a C type defined in _asyncio extension module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__module__ == '_asyncio'. Task is implemented in the _asyncio C extension, not pure Python. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__bases__[0].__name__ == 'Future'. Task directly subclasses Future in the C extension. MRO is [Task, Future, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__mro__.__len__() == 3. MRO is [Task, Future, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__name__ == 'Future'. Future is a C type defined in _asyncio extension module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__module__ == '_asyncio'. Future is implemented in the _asyncio C extension. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__bases__[0].__name__ == 'object'. Future directly subclasses object; it is a root type in the asyncio hierarchy. MRO is [Future, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__mro__.__len__() == 2. MRO is [Future, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__class__.__name__ == 'mappingproxy'. Class __dict__ objects are always mappingproxy in CPython even for C extension types. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__dict__.__class__.__name__ == 'mappingproxy'. Class __dict__ objects are always mappingproxy in CPython. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__contains__('cancel') == True. Task defines cancel() in its C-level dict. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__dict__.__contains__('result') == True. Task defines result() in its C-level dict. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__dict__.__contains__('result') == True. Future defines result() in its C-level dict. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__dict__.__contains__('cancel') == True. Future defines cancel() in its C-level dict. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Task.__qualname__ == 'Task'. C extension types use their simple name as __qualname__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Future.__qualname__ == 'Future'. C extension types use their simple name as __qualname__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Task class identity — extra80
#
# Wave 244 theme: Task/Future class identity (C types in Python 3.14).
#
# Task.__name__ == 'Task'
# Task.__module__ == '_asyncio'
# Task.__bases__[0].__name__ == 'Future'
# Task.__mro__.__len__() == 3
# ---------------------------------------------------------------------------

table asyncio_extra80.Task_class_identity:
  description: "asyncio Task class identity checks in asyncioextra80 namespace — wave 244 theme: Task/Future class identity (C types in Python 3.14); Task.__name__=='Task'; Task.__module__=='_asyncio' (C extension, not pure Python); Task.__bases__[0].__name__=='Future' (Task directly subclasses Future); Task.__mro__.__len__()==3 (MRO: Task, Future, object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra80

  columns: [id, function, args, expected, description]
  rows:
    - [task_name,          Task.__name__.__eq__,             ["Task"],    true, "Task.__name__ == 'Task' — C extension type name; verified with Python 3.14.3"]
    - [task_module,        Task.__module__.__eq__,           ["_asyncio"], true, "Task.__module__ == '_asyncio' — Task is a C extension type, not pure Python; verified with Python 3.14.3"]
    - [task_bases_name,    "Task.__bases__[0].__name__.__eq__", ["Future"], true, "Task.__bases__[0].__name__ == 'Future' — Task directly subclasses Future; verified with Python 3.14.3"]
    - [task_mro_len,       Task.__mro__.__len__,             [],          3,    "Task.__mro__.__len__() == 3 — MRO is [Task, Future, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Future class identity — extra80
#
# Future.__name__ == 'Future'
# Future.__module__ == '_asyncio'
# Future.__bases__[0].__name__ == 'object'
# Future.__mro__.__len__() == 2
# ---------------------------------------------------------------------------

table asyncio_extra80.Future_class_identity:
  description: "asyncio Future class identity checks in asyncioextra80 namespace — wave 244 theme: Future class identity; Future.__name__=='Future'; Future.__module__=='_asyncio' (C extension); Future.__bases__[0].__name__=='object' (Future is a root type in asyncio hierarchy); Future.__mro__.__len__()==2 (MRO: Future, object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra80a

  columns: [id, function, args, expected, description]
  rows:
    - [future_name,        Future.__name__.__eq__,              ["Future"],   true, "Future.__name__ == 'Future' — C extension type name; verified with Python 3.14.3"]
    - [future_module,      Future.__module__.__eq__,            ["_asyncio"], true, "Future.__module__ == '_asyncio' — Future is a C extension type; verified with Python 3.14.3"]
    - [future_bases_name,  "Future.__bases__[0].__name__.__eq__", ["object"],  true, "Future.__bases__[0].__name__ == 'object' — Future directly subclasses object; verified with Python 3.14.3"]
    - [future_mro_len,     Future.__mro__.__len__,              [],           2,    "Future.__mro__.__len__() == 2 — MRO is [Future, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Task/Future __dict__ class names — extra80
#
# Task.__dict__.__class__.__name__ == 'mappingproxy'
# Future.__dict__.__class__.__name__ == 'mappingproxy'
# ---------------------------------------------------------------------------

table asyncio_extra80.Task_Future_dict_class_names:
  description: "asyncio Task and Future __dict__.__class__.__name__ checks in asyncioextra80 namespace — wave 244 theme: Task/Future dict class names; Task.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is always mappingproxy in CPython even for C extension types); Future.__dict__.__class__.__name__=='mappingproxy'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioextra80b

  columns: [id, function, args, expected, description]
  rows:
    - [task_dict_class_name,   Task.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true, "Task.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always mappingproxy in CPython; verified with Python 3.14.3"]
    - [future_dict_class_name, Future.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "Future.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always mappingproxy in CPython; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Task/Future __dict__ membership and qualname cross-check — extra80
#
# Task.__dict__.__contains__('cancel') == True
# Task.__dict__.__contains__('result') == True
# Future.__dict__.__contains__('result') == True
# Future.__dict__.__contains__('cancel') == True
# Task.__qualname__ == 'Task'
# Future.__qualname__ == 'Future'
# ---------------------------------------------------------------------------

table asyncio_extra80.Task_Future_dict_membership_and_qualname:
  description: "asyncio Task/Future __dict__ membership and qualname checks in asyncioextra80 namespace — wave 244 theme: Task/Future dict membership + qualname; Task.__dict__.__contains__('cancel')==True; Task.__dict__.__contains__('result')==True; Future.__dict__.__contains__('result')==True; Future.__dict__.__contains__('cancel')==True; Task.__qualname__=='Task'; Future.__qualname__=='Future'; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: asyncioextra80c

  columns: [id, function, args, expected, description]
  rows:
    - [task_dict_has_cancel,   Task.__dict__.__contains__,   ["cancel"],  true,    "Task.__dict__.__contains__('cancel') == True — Task defines cancel() in its C-level dict; verified with Python 3.14.3"]
    - [task_dict_has_result,   Task.__dict__.__contains__,   ["result"],  true,    "Task.__dict__.__contains__('result') == True — Task defines result() in its C-level dict; verified with Python 3.14.3"]
    - [future_dict_has_result, Future.__dict__.__contains__, ["result"],  true,    "Future.__dict__.__contains__('result') == True — Future defines result() in its C-level dict; verified with Python 3.14.3"]
    - [future_dict_has_cancel, Future.__dict__.__contains__, ["cancel"],  true,    "Future.__dict__.__contains__('cancel') == True — Future defines cancel() in its C-level dict; verified with Python 3.14.3"]
    - [task_qualname,          Task.__qualname__.__eq__,     ["Task"],    true,    "Task.__qualname__ == 'Task' — C extension types use simple name as __qualname__; verified with Python 3.14.3"]
    - [future_qualname,        Future.__qualname__.__eq__,   ["Future"],  true,    "Future.__qualname__ == 'Future' — C extension types use simple name as __qualname__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra80
# ---------------------------------------------------------------------------

invariant asyncio_extra80.Task_name:
  description: "asyncio.Task.__name__.__eq__('Task') returns True — Task is a C type in the _asyncio extension module; its __name__ is the simple class name 'Task'; NEW in extra80: first standalone __name__ invariant for Task in asyncioextra80 namespace; wave 244; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Task.__name__.__eq__
  args: ["Task"]
  expected: true

invariant asyncio_extra80.Task_module:
  description: "asyncio.Task.__module__.__eq__('_asyncio') returns True — Task is implemented in the _asyncio C extension module, not pure Python Lib/asyncio/; NEW in extra80: first standalone __module__ invariant for Task in asyncioextra80 namespace; wave 244; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Task.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra80.Future_module:
  description: "asyncio.Future.__module__.__eq__('_asyncio') returns True — Future is implemented in the _asyncio C extension module; NEW in extra80: first standalone __module__ invariant for Future in asyncioextra80 namespace; wave 244; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra80.Task_mro_len:
  description: "asyncio.Task.__mro__.__len__() == 3 — MRO is [Task, Future, object]; Task inherits from Future with no intermediary; NEW in extra80: first standalone __mro__.__len__ invariant for Task in asyncioextra80 namespace; wave 244; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Task.__mro__.__len__
  args: []
  expected: 3

invariant asyncio_extra80.Future_mro_len:
  description: "asyncio.Future.__mro__.__len__() == 2 — MRO is [Future, object]; Future is a root asyncio type with no intermediary; NEW in extra80: first standalone __mro__.__len__ invariant for Future in asyncioextra80 namespace; wave 244; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__mro__.__len__
  args: []
  expected: 2
