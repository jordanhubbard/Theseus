spec: concurrent_futures_extra101
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra99

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures_extra99.zspec.zsdl."
    - "This spec covers: wave 254 theme — concurrent.futures __doc__ class names and exception class __module__ values. NEW in extra101: concurrent.futures.Future.__doc__.__class__.__name__=='str'; concurrent.futures.CancelledError.__doc__.__class__.__name__=='str'; concurrent.futures.ThreadPoolExecutor.__doc__ is None (NoneType); concurrent.futures.CancelledError.__module__=='concurrent.futures._base'; concurrent.futures.BrokenExecutor.__module__=='concurrent.futures._base'; concurrent.futures.InvalidStateError.__module__=='concurrent.futures._base'; concurrent.futures.TimeoutError.__module__=='builtins' (TimeoutError is a builtin re-used); concurrent.futures.CancelledError.__qualname__=='CancelledError' (len=14); concurrent.futures.InvalidStateError.__qualname__=='InvalidStateError' (len=17, longest); concurrent.futures.BrokenExecutor.__qualname__=='BrokenExecutor' (len=14); concurrent.futures.ThreadPoolExecutor.__module__=='concurrent.futures.thread'; concurrent.futures.Future.__qualname__=='Future' (len=6). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.TimeoutError.__module__ == 'builtins'. TimeoutError in concurrent.futures is the built-in Python TimeoutError re-exported (a subclass of OSError); its __module__ is 'builtins', not 'concurrent.futures._base'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__doc__ is None. ThreadPoolExecutor has no docstring (doc is None/NoneType) while concurrent.futures.Future does have a docstring (str). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17. 'InvalidStateError' is 17 chars: 'Invalid'=7 + 'State'=5 + 'Error'=5 = 17. This is the longest exception qualname in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures __doc__ class names — extra101
#
# Wave 254 theme: concurrent.futures __doc__ class names and exception
#                 class __module__ values.
#
# concurrent.futures.Future.__doc__.__class__.__name__              == 'str'
# concurrent.futures.CancelledError.__doc__.__class__.__name__      == 'str'
# concurrent.futures.ThreadPoolExecutor.__doc__                     == None
# concurrent.futures.CancelledError.__module__                      == 'concurrent.futures._base'
# concurrent.futures.BrokenExecutor.__module__                      == 'concurrent.futures._base'
# concurrent.futures.InvalidStateError.__module__                   == 'concurrent.futures._base'
# concurrent.futures.TimeoutError.__module__                        == 'builtins'
# ---------------------------------------------------------------------------

table concurrent_futures_extra101.cf_doc_class_names:
  description: "concurrent.futures class __doc__ type checks in cfdocmod101 namespace — wave 254 theme: concurrent.futures.Future has a docstring (str); concurrent.futures.Future.__doc__.__class__.__name__.__eq__('str')==True (doc is 'Represents the result of an asynchronous computation.'); concurrent.futures.CancelledError.__doc__.__class__.__name__.__eq__('str')==True (doc is 'The Future was cancelled.'); concurrent.futures.ThreadPoolExecutor.__doc__ is None (no docstring; __class__.__name__ is 'NoneType'); concurrent.futures.ProcessPoolExecutor.__doc__.__class__.__name__.__eq__('NoneType')==True (also no docstring); concurrent.futures.Future.__doc__.__class__.__name__ == 'str' while ThreadPoolExecutor.__doc__ is None — this asymmetry reflects that Future has a module-level docstring in _base.py while the executor classes do not; verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: cfdocmod101

  columns: [id, function, args, expected, description]
  rows:
    - [future_doc_cls,   "concurrent.futures.Future.__doc__.__class__.__name__.__eq__",              ["str"],      true, "concurrent.futures.Future.__doc__.__class__.__name__ == 'str' (Future has a docstring); verified with Python 3.14.3"]
    - [cancerr_doc_cls,  "concurrent.futures.CancelledError.__doc__.__class__.__name__.__eq__",      ["str"],      true, "concurrent.futures.CancelledError.__doc__.__class__.__name__ == 'str' (CancelledError has a docstring); verified with Python 3.14.3"]
    - [tpe_module,       "concurrent.futures.ThreadPoolExecutor.__module__.__eq__",                  ["concurrent.futures.thread"], true, "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'; verified with Python 3.14.3"]
    - [future_module,    "concurrent.futures.Future.__module__.__eq__",                              ["concurrent.futures._base"],  true, "concurrent.futures.Future.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [cancerr_module,   "concurrent.futures.CancelledError.__module__.__eq__",                      ["concurrent.futures._base"],  true, "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [brokenex_module,  "concurrent.futures.BrokenExecutor.__module__.__eq__",                      ["concurrent.futures._base"],  true, "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [invstt_module,    "concurrent.futures.InvalidStateError.__module__.__eq__",                   ["concurrent.futures._base"],  true, "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [timeout_module,   "concurrent.futures.TimeoutError.__module__.__eq__",                        ["builtins"],                  true, "concurrent.futures.TimeoutError.__module__ == 'builtins' (TimeoutError is the built-in, re-exported); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures exception class __qualname__ values — extra101
#
# concurrent.futures.CancelledError.__qualname__   == 'CancelledError'   (len=14)
# concurrent.futures.TimeoutError.__qualname__     == 'TimeoutError'     (len=12)
# concurrent.futures.BrokenExecutor.__qualname__   == 'BrokenExecutor'   (len=14)
# concurrent.futures.InvalidStateError.__qualname__== 'InvalidStateError'(len=17, longest)
# concurrent.futures.Future.__qualname__           == 'Future'           (len=6)
# concurrent.futures.ThreadPoolExecutor.__qualname__== 'ThreadPoolExecutor'(len=18)
# ---------------------------------------------------------------------------

table concurrent_futures_extra101.cf_exception_qualnames:
  description: "concurrent.futures exception and class __qualname__ checks in cfdocmod101 namespace — wave 254 theme: concurrent.futures.CancelledError.__qualname__.__eq__('CancelledError')==True (len=14: 'Cancelled'=9 + 'Error'=5); concurrent.futures.CancelledError.__qualname__.__len__()==14; concurrent.futures.TimeoutError.__qualname__.__eq__('TimeoutError')==True (len=12: 'Timeout'=7 + 'Error'=5); concurrent.futures.TimeoutError.__qualname__.__len__()==12; concurrent.futures.BrokenExecutor.__qualname__.__eq__('BrokenExecutor')==True (len=14: 'Broken'=6 + 'Executor'=8; tied with CancelledError len=14); concurrent.futures.BrokenExecutor.__qualname__.__len__()==14; concurrent.futures.InvalidStateError.__qualname__.__eq__('InvalidStateError')==True (len=17: 'Invalid'=7+'State'=5+'Error'=5, the longest exception qualname in spec); concurrent.futures.InvalidStateError.__qualname__.__len__()==17; concurrent.futures.Future.__qualname__.__eq__('Future')==True (len=6); concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__('ThreadPoolExecutor')==True (len=18); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_names
  id_prefix: cfdocmod101a

  columns: [id, function, args, expected, description]
  rows:
    - [cancerr_qn_eq,   "concurrent.futures.CancelledError.__qualname__.__eq__",    ["CancelledError"],    true, "concurrent.futures.CancelledError.__qualname__ == 'CancelledError' (len=14); verified with Python 3.14.3"]
    - [cancerr_qn_len,  "concurrent.futures.CancelledError.__qualname__.__len__",   [],                    14,   "concurrent.futures.CancelledError.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [timeout_qn_eq,   "concurrent.futures.TimeoutError.__qualname__.__eq__",      ["TimeoutError"],      true, "concurrent.futures.TimeoutError.__qualname__ == 'TimeoutError' (len=12); verified with Python 3.14.3"]
    - [timeout_qn_len,  "concurrent.futures.TimeoutError.__qualname__.__len__",     [],                    12,   "concurrent.futures.TimeoutError.__qualname__.__len__() == 12; verified with Python 3.14.3"]
    - [brokenex_qn_eq,  "concurrent.futures.BrokenExecutor.__qualname__.__eq__",   ["BrokenExecutor"],    true, "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor' (len=14, tied with CancelledError); verified with Python 3.14.3"]
    - [brokenex_qn_len, "concurrent.futures.BrokenExecutor.__qualname__.__len__",  [],                    14,   "concurrent.futures.BrokenExecutor.__qualname__.__len__() == 14 (tied with CancelledError); verified with Python 3.14.3"]
    - [invstt_qn_eq,    "concurrent.futures.InvalidStateError.__qualname__.__eq__", ["InvalidStateError"], true, "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError' (len=17, longest exception qualname); verified with Python 3.14.3"]
    - [invstt_qn_len,   "concurrent.futures.InvalidStateError.__qualname__.__len__",[], 17, "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17 (longest; 'Invalid'=7+'State'=5+'Error'=5); verified with Python 3.14.3"]
    - [future_qn_eq,    "concurrent.futures.Future.__qualname__.__eq__",            ["Future"],            true, "concurrent.futures.Future.__qualname__ == 'Future' (len=6); verified with Python 3.14.3"]
    - [future_qn_len,   "concurrent.futures.Future.__qualname__.__len__",           [],                    6,    "concurrent.futures.Future.__qualname__.__len__() == 6; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra101
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra101.InvalidStateError_qualname_longest:
  description: "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17 — InvalidStateError.__qualname__ is 'InvalidStateError' (17 chars: 'Invalid'=7 + 'State'=5 + 'Error'=5); this is the longest exception qualname among concurrent.futures exception classes in this spec; compare exception qualname lengths: TimeoutError=12, CancelledError=14, BrokenExecutor=14, InvalidStateError=17; concurrent.futures.InvalidStateError.__module__ is 'concurrent.futures._base' (defined in Lib/concurrent/futures/_base.py); InvalidStateError.__bases__[0].__name__ is 'Error' (the private concurrent.futures._base.Error base class); NEW in extra101: first standalone InvalidStateError qualname length invariant in cfdocmod101 namespace; wave 254; verified with Python 3.14.3"
  category: class_names
  kind: python_call_eq
  function: "concurrent.futures.InvalidStateError.__qualname__.__len__"
  args: []
  expected: 17

invariant concurrent_futures_extra101.TimeoutError_module_is_builtins:
  description: "concurrent.futures.TimeoutError.__module__.__eq__('builtins') returns True — concurrent.futures.TimeoutError is the built-in Python TimeoutError (a subclass of OSError), re-exported by concurrent.futures for convenience; unlike CancelledError, BrokenExecutor, and InvalidStateError which are defined in concurrent.futures._base (module='concurrent.futures._base'), TimeoutError.__module__ is 'builtins'; concurrent.futures.TimeoutError.__bases__[0].__name__ is 'OSError' (unlike CancelledError whose base is 'Error'); TimeoutError.__mro__ is [TimeoutError, OSError, Exception, BaseException, object] (5 elements); NEW in extra101: first standalone TimeoutError module builtins invariant in cfdocmod101 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.TimeoutError.__module__.__eq__"
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra101.Future_doc_is_str:
  description: "concurrent.futures.Future.__doc__.__class__.__name__.__eq__('str') returns True — concurrent.futures.Future has a docstring: 'Represents the result of an asynchronous computation.' (type 'str'); this contrasts with concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor whose __doc__ is None; concurrent.futures.Future.__module__ is 'concurrent.futures._base'; Future.__qualname__ is 'Future' (len=6); Future.__mro__.__len__() == 2 ([Future, object]); the Future class is central to concurrent.futures — executors submit callables and return Future objects; NEW in extra101: first standalone Future __doc__ class name invariant in cfdocmod101 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.Future.__doc__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

invariant concurrent_futures_extra101.BrokenExecutor_module_is_cf_base:
  description: "concurrent.futures.BrokenExecutor.__module__.__eq__('concurrent.futures._base') returns True — BrokenExecutor is defined in Lib/concurrent/futures/_base.py (module='concurrent.futures._base'); BrokenExecutor.__bases__[0].__name__ is 'RuntimeError'; BrokenExecutor.__qualname__ is 'BrokenExecutor' (len=14, tied with CancelledError); BrokenExecutor.__mro__.__len__() == 5 ([BrokenExecutor, RuntimeError, Exception, BaseException, object]); BrokenExecutor is raised when a thread/process pool has been terminated or is in a broken state; compare modules: CancelledError='concurrent.futures._base', InvalidStateError='concurrent.futures._base', TimeoutError='builtins'; NEW in extra101: first standalone BrokenExecutor module invariant in cfdocmod101 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: "concurrent.futures.BrokenExecutor.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra101.CancelledError_qualname_len_14:
  description: "concurrent.futures.CancelledError.__qualname__.__len__() == 14 — CancelledError.__qualname__ is 'CancelledError' (14 chars: 'Cancelled'=9 + 'Error'=5); len=14 is tied with BrokenExecutor (14 chars: 'Broken'=6 + 'Executor'=8); concurrent.futures.CancelledError.__module__ is 'concurrent.futures._base'; CancelledError.__bases__[0].__name__ is 'Error' (private _base.Error intermediate class, not built-in Exception); CancelledError.__mro__.__len__() == 5 ([CancelledError, Error, Exception, BaseException, object]); concurrent.futures.CancelledError is distinct from the built-in asyncio.CancelledError; NEW in extra101: first standalone CancelledError qualname length invariant in cfdocmod101 namespace; wave 254; verified with Python 3.14.3"
  category: class_names
  kind: python_call_eq
  function: "concurrent.futures.CancelledError.__qualname__.__len__"
  args: []
  expected: 14
