# ---------------------------------------------------------------------------
# Cross-module summary — all 18 itertools types, __matmul__ only
#
# Confirms that the absence of __matmul__ is uniform across the full
# itertools namespace. The same result holds for __truediv__ and __iadd__
# (covered per-group in the tables above).
# ---------------------------------------------------------------------------

table itertools_extra2761.all_types_matmul_summary:
  description: "All 18 itertools types — '__matmul__' not in __dict__ for any of them; verified with Python 3.14.4"
