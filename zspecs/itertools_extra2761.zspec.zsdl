spec: itertools_extra2761
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "Wave 631 theme: __matmul__, __truediv__, and __iadd__ dict-presence checks."
    - "All 18 itertools C-level iterator types are checked: chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap, groupby, filterfalse, accumulate, zip_longest, pairwise, product, permutations, combinations, combinations_with_replacement."
    - "None of the itertools types define __matmul__, __truediv__, or __iadd__ in their __dict__."
    - "itertools types are C-level types (Modules/itertoolsmodule.c); they expose iteration protocol only."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools basic iterator types — __matmul__/__truediv__/__iadd__ dict-presence
#
# chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap
# are C-level types. None defines operator dunders for @, /, or +=.
# All nine checks per operator (27 total) return False.
# ---------------------------------------------------------------------------

table itertools_extra2761.basic_iterators_operator_dict:
  description: "itertools chain/count/repeat/cycle/islice/compress/dropwhile/takewhile/starmap — __matmul__, __truediv__, __iadd__ dict-presence all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: it2761bi

  columns: [id, function, args, expected]
  rows:
    - ["it2761bi_ch_mm",  chain.__dict__.__contains__,     ["__matmul__"],  false]
    - ["it2761bi_ch_td",  chain.__dict__.__contains__,     ["__truediv__"], false]
    - ["it2761bi_ch_ia",  chain.__dict__.__contains__,     ["__iadd__"],    false]
    - ["it2761bi_ct_mm",  count.__dict__.__contains__,     ["__matmul__"],  false]
    - ["it2761bi_ct_td",  count.__dict__.__contains__,     ["__truediv__"], false]
    - ["it2761bi_ct_ia",  count.__dict__.__contains__,     ["__iadd__"],    false]
