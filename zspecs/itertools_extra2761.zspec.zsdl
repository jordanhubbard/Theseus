  columns: [id, function, args, expected]
  rows:
    - ["it2761am_ch",  chain.__dict__.__contains__,                     ["__matmul__"], false]
    - ["it2761am_ct",  count.__dict__.__contains__,                     ["__matmul__"], false]
    - ["it2761am_rp",  repeat.__dict__.__contains__,                    ["__matmul__"], false]
    - ["it2761am_cy",  cycle.__dict__.__contains__,                     ["__matmul__"], false]
    - ["it2761am_is",  islice.__dict__.__contains__,                    ["__matmul__"], false]
    - ["it2761am_co",  compress.__dict__.__contains__,                  ["__matmul__"], false]
    - ["it2761am_dw",  dropwhile.__dict__.__contains__,                 ["__matmul__"], false]
    - ["it2761am_tw",  takewhile.__dict__.__contains__,                 ["__matmul__"], false]
    - ["it2761am_sm",  starmap.__dict__.__contains__,                   ["__matmul__"], false]
    - ["it2761am_gb",  groupby.__dict__.__contains__,                   ["__matmul__"], false]
    - ["it2761am_ff",  filterfalse.__dict__.__contains__,               ["__matmul__"], false]
    - ["it2761am_ac",  accumulate.__dict__.__contains__,                ["__matmul__"], false]
    - ["it2761am_zl",  zip_longest.__dict__.__contains__,               ["__matmul__"], false]
    - ["it2761am_pw",  pairwise.__dict__.__contains__,                  ["__matmul__"], false]
    - ["it2761am_pr",  product.__dict__.__contains__,                   ["__matmul__"], false]
    - ["it2761am_pe",  permutations.__dict__.__contains__,              ["__matmul__"], false]
    - ["it2761am_cm",  combinations.__dict__.__contains__,              ["__matmul__"], false]
    - ["it2761am_cr",  combinations_with_replacement.__dict__.__contains__, ["__matmul__"], false]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra2761
# ---------------------------------------------------------------------------

invariant itertools_extra2761.chain_no_matmul:
  description: "'__matmul__' not in itertools.chain.__dict__ — chain is an iterator type with no @ operator support"
  category: behavior
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__matmul__"]
  expected: false

invariant itertools_extra2761.chain_no_truediv:
  description: "'__truediv__' not in itertools.chain.__dict__ — chain does not implement the / operator"
  category: behavior
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__truediv__"]
  expected: false

invariant itertools_extra2761.chain_no_iadd:
  description: "'__iadd__' not in itertools.chain.__dict__ — chain does not implement the += operator"
  category: behavior
  kind: python_call_eq
  function: chain.__dict__.__contains__
  args: ["__iadd__"]
  expected: false

invariant itertools_extra2761.product_no_matmul:
  description: "'__matmul__' not in itertools.product.__dict__ — product is a combinatoric iterator with no @ operator support"
  category: behavior
  kind: python_call_eq
  function: product.__dict__.__contains__
  args: ["__matmul__"]
  expected: false

invariant itertools_extra2761.accumulate_no_iadd:
  description: "'__iadd__' not in itertools.accumulate.__dict__ — despite its name, accumulate does not implement the += operator"
  category: behavior
  kind: python_call_eq
  function: accumulate.__dict__.__contains__
  args: ["__iadd__"]
  expected: false

invariant itertools_extra2761.combinations_with_replacement_no_truediv:
  description: "'__truediv__' not in itertools.combinations_with_replacement.__dict__ — combinations_with_replacement does not implement the / operator"
  category: behavior
  kind: python_call_eq
  function: combinations_with_replacement.__dict__.__contains__
  args: ["__truediv__"]
  expected: false
