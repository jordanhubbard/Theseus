    - ["it2761bi_rp_td",  repeat.__dict__.__contains__,    ["__truediv__"], false]
    - ["it2761bi_rp_ia",  repeat.__dict__.__contains__,    ["__iadd__"],    false]
    - ["it2761bi_cy_mm",  cycle.__dict__.__contains__,     ["__matmul__"],  false]
    - ["it2761bi_cy_td",  cycle.__dict__.__contains__,     ["__truediv__"], false]
    - ["it2761bi_cy_ia",  cycle.__dict__.__contains__,     ["__iadd__"],    false]
    - ["it2761bi_is_mm",  islice.__dict__.__contains__,    ["__matmul__"],  false]
    - ["it2761bi_is_td",  islice.__dict__.__contains__,    ["__truediv__"], false]
    - ["it2761bi_is_ia",  islice.__dict__.__contains__,    ["__iadd__"],    false]
    - ["it2761bi_co_mm",  compress.__dict__.__contains__,  ["__matmul__"],  false]
    - ["it2761bi_co_td",  compress.__dict__.__contains__,  ["__truediv__"], false]
    - ["it2761bi_co_ia",  compress.__dict__.__contains__,  ["__iadd__"],    false]
    - ["it2761bi_dw_mm",  dropwhile.__dict__.__contains__, ["__matmul__"],  false]
    - ["it2761bi_dw_td",  dropwhile.__dict__.__contains__, ["__truediv__"], false]
    - ["it2761bi_dw_ia",  dropwhile.__dict__.__contains__, ["__iadd__"],    false]
