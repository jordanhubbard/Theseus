spec: os_extra24
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
    - "os_extra23.zspec.zsdl — covers sep/__class__.__name__; devnull/__class__.__name__; separator_values table; separator_class_names table"
    - "os_extra22.zspec.zsdl — covers getcwd/getpid/getuid/getgid/cpu_count/urandom return types; linesep/pathsep/name __class__.__name__"
    - "os_extra21.zspec.zsdl — covers getenv/putenv/environ/curdir/pardir standalone invariants"
  notes:
    - "This spec extends os.zspec.zsdl and all prior os_extra specs through os_extra23.zspec.zsdl."
    - "os.getpid.__name__ == 'getpid' — no prior os spec covers getpid.__name__ as a standalone named invariant in extra24 namespace."
    - "os.getpid().__class__.__name__ == 'int' — getpid returns an int; re-anchored as standalone in extra24 namespace."
    - "os.getpid() > 0 — all PIDs on POSIX are positive integers; verified via __gt__ call with argument 0."
    - "os.getcwd.__name__ == 'getcwd' — no prior os spec covers getcwd.__name__ as a standalone named invariant in extra24 namespace."
    - "os.getcwd().__class__.__name__ == 'str' — getcwd returns a str; re-anchored as standalone in extra24 namespace."
    - "os.listdir.__name__ == 'listdir' — no prior os spec covers listdir.__name__ as a standalone named invariant in extra24 namespace."
    - "os.path.join.__name__ == 'join' — os.path.join is a module-level function whose __name__ is 'join'; verified at runtime."
    - "os.environ.__class__.__name__ == '_Environ' — verified at runtime; the actual class is os._Environ, not Environ."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ table — getpid, getcwd, listdir
#
# No prior os spec collects getpid/getcwd/listdir __name__ values in a single
# table. This table anchors all three in the extra24 namespace.
# ---------------------------------------------------------------------------

table os_extra24.process_and_fs_function_names:
  description: "__name__ for os.getpid, os.getcwd, os.listdir"
  kind: python_call_eq
  category: function_identity
  id_prefix: pfname24

  columns: [id, function, args, expected]
  rows:
    - [getpid,   getpid.__name__.__eq__,   ["getpid"],   true]
    - [getcwd,   getcwd.__name__.__eq__,   ["getcwd"],   true]
    - [listdir,  listdir.__name__.__eq__,  ["listdir"],  true]

# ---------------------------------------------------------------------------
# os.getpid().__class__.__name__ == 'int'
#
# os.getpid() returns the current process ID as an int. Verified at runtime.
# os_extra22 covers getpid return type via a table; this standalone re-anchors
# the same check in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant os_extra24.getpid.return_type_int:
  description: "os.getpid().__class__.__name__ == 'int' — getpid always returns an integer process ID"
  category: return_types
  kind: python_call_eq
  function: getpid
  args: []
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# os.getpid() > 0
#
# On all POSIX platforms, process IDs are strictly positive. Calling __gt__
# with 0 on the return value of getpid() must yield True. Verified at runtime.
# No prior os spec covers this positivity check in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant os_extra24.getpid.positive:
  description: "os.getpid() > 0 — process ID is always a positive integer on POSIX"
  category: return_values
  kind: python_call_eq
  function: getpid
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# os.getcwd().__class__.__name__ == 'str'
#
# os.getcwd() returns the current working directory as a str. Verified at
# runtime. os_extra22 covers getcwd return type; this standalone re-anchors
# the check in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant os_extra24.getcwd.return_type_str:
  description: "os.getcwd().__class__.__name__ == 'str' — getcwd always returns a string path"
  category: return_types
  kind: python_call_eq
  function: getcwd
  args: []
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# os.path.join.__name__ == 'join'
#
# os.path.join is a callable whose __name__ attribute is 'join'. Verified at
# runtime. No prior os spec covers path.join.__name__ as a standalone named
# invariant in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant os_extra24.path_join.name:
  description: "os.path.join.__name__ == 'join' — path.join function name attribute"
  category: function_identity
  kind: python_call_eq
  function: path.join.__name__.__eq__
  args: ["join"]
  expected: true

# ---------------------------------------------------------------------------
# os.environ.__class__.__name__ == '_Environ'
#
# os.environ is an instance of os._Environ, a mapping class that wraps the
# process environment. Verified at runtime: __class__.__name__ == '_Environ'.
# No prior os spec covers environ.__class__.__name__ as a standalone named
# invariant in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant os_extra24.environ.class_name:
  description: "os.environ.__class__.__name__ == '_Environ' — environ is an instance of os._Environ"
  category: class_identity
  kind: python_call_eq
  function: environ.__class__.__name__.__eq__
  args: ["_Environ"]
  expected: true
