spec: threading_extra1591
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — descriptor protocol absence checks via __dict__.__contains__ for threading.Thread, threading.Lock, threading.RLock, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Behavioral invariants: all threading synchronization and concurrency classes are plain Python/C classes that do not implement the descriptor protocol. None define __get__, __set__, or __delete__ in their own __dict__. threading.local (from _thread) defines __getattribute__/__setattr__/__delattr__ for per-thread attribute access but no descriptor protocol methods."]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1591.thread_class_no_descriptor:
  description: "threading.Thread and threading.Timer define no descriptor protocol methods; Thread does define class-level API methods"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1591tc

  columns: [id, function, args, expected]
  rows:
    - [th1591tc001, threading.Thread.__dict__.__contains__, ["__get__"],      false]
    - [th1591tc002, threading.Thread.__dict__.__contains__, ["__set__"],      false]
    - [th1591tc003, threading.Thread.__dict__.__contains__, ["__delete__"],   false]
    - [th1591tc004, threading.Thread.__dict__.__contains__, ["__set_name__"], false]
    - [th1591tc005, threading.Thread.__dict__.__contains__, ["start"],        true]
    - [th1591tc006, threading.Thread.__dict__.__contains__, ["run"],          true]
    - [th1591tc007, threading.Thread.__dict__.__contains__, ["join"],         true]
    - [th1591tc008, threading.Thread.__dict__.__contains__, ["daemon"],       true]
    - [th1591tc009, threading.Thread.__dict__.__contains__, ["is_alive"],     true]
    - [th1591tc010, threading.Timer.__dict__.__contains__,  ["__get__"],     false]
    - [th1591tc011, threading.Timer.__dict__.__contains__,  ["__set__"],     false]
    - [th1591tc012, threading.Timer.__dict__.__contains__,  ["__delete__"],  false]
    - [th1591tc013, threading.Timer.__dict__.__contains__,  ["__set_name__"], false]
    - [th1591tc014, threading.Thread.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [th1591tc015, threading.Timer.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true]
    - [th1591tc016, threading.Thread.__module__.__eq__,  ["threading"], true]
    - [th1591tc017, threading.Timer.__module__.__eq__,   ["threading"], true]
    - [th1591tc018, threading.Thread.__name__.__eq__,    ["Thread"],    true]
    - [th1591tc019, threading.Timer.__name__.__eq__,     ["Timer"],     true]
    - [th1591tc020, threading.Thread.__class__.__name__.__eq__, ["type"], true]
    - [th1591tc021, threading.Timer.__class__.__name__.__eq__,  ["type"], true]
    - [th1591tc022, threading.Thread.__mro__.__class__.__name__.__eq__, ["tuple"], true]
    - [th1591tc023, threading.Thread.__bases__.__len__, [], 1]
    - [th1591tc024, threading.Thread.__dict__.__contains__, ["__iter__"],  false]
    - [th1591tc025, threading.Thread.__dict__.__contains__, ["__next__"],  false]

