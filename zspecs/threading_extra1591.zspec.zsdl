    - [th1591lo008, threading.local.__dict__.__contains__, ["__iter__"],          false]
    - [th1591lo009, threading.local.__dict__.__contains__, ["__next__"],          false]
    - [th1591lo010, threading.local.__dict__.__contains__, ["__enter__"],         false]
