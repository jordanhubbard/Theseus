spec: asyncio_extra1036
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio Queue, Future, and Task documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio.Queue, asyncio.Future, and asyncio.Task method qualnames and descriptor identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1036.queue_descriptors:
  description: "asyncio.Queue property descriptor class identity"
  kind: python_call_eq
  category: queue_descriptors
  id_prefix: as1036qd
  columns: [id, function, args, expected]
  rows:
    - [as1036qd001, asyncio.Queue.maxsize.__class__.__name__.__eq__, ["property"], true]
    - [as1036qd002, asyncio.Queue.qsize.__qualname__.__eq__,         ["Queue.qsize"], true]
    - [as1036qd003, asyncio.Queue.join.__qualname__.__eq__,          ["Queue.join"], true]
    - [as1036qd004, asyncio.Queue.empty.__qualname__.__eq__,         ["Queue.empty"], true]
    - [as1036qd005, asyncio.Queue.full.__qualname__.__eq__,          ["Queue.full"], true]
    - [as1036qd006, asyncio.Queue.put.__qualname__.__eq__,           ["Queue.put"], true]

table asyncio_extra1036.future_method_qualnames:
  description: "asyncio.Future special method __qualname__ identity"
  kind: python_call_eq
  category: future_method_qualnames
  id_prefix: as1036fm
  columns: [id, function, args, expected]
  rows:
    - [as1036fm001, asyncio.Future.__await__.__qualname__.__eq__, ["Future.__await__"], true]
    - [as1036fm002, asyncio.Future.__iter__.__qualname__.__eq__,  ["Future.__iter__"],  true]
    - [as1036fm003, asyncio.Future.cancel.__qualname__.__eq__,    ["Future.cancel"],    true]
    - [as1036fm004, asyncio.Future.result.__qualname__.__eq__,    ["Future.result"],    true]
    - [as1036fm005, asyncio.Future.done.__qualname__.__eq__,      ["Future.done"],      true]

table asyncio_extra1036.task_method_qualnames:
  description: "asyncio.Task method __qualname__ identity"
  kind: python_call_eq
  category: task_method_qualnames
  id_prefix: as1036tm
  columns: [id, function, args, expected]
  rows:
    - [as1036tm001, asyncio.Task.get_name.__qualname__.__eq__,    ["Task.get_name"],    true]
    - [as1036tm002, asyncio.Task.set_name.__qualname__.__eq__,    ["Task.set_name"],    true]
    - [as1036tm003, asyncio.Task.get_coro.__qualname__.__eq__,    ["Task.get_coro"],    true]
    - [as1036tm004, asyncio.Task.get_stack.__qualname__.__eq__,   ["Task.get_stack"],   true]
    - [as1036tm005, asyncio.Task.print_stack.__qualname__.__eq__, ["Task.print_stack"], true]
    - [as1036tm006, asyncio.Task.cancel.__qualname__.__eq__,      ["Task.cancel"],      true]
