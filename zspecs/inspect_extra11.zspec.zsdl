spec: inspect_extra11
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect.zspec.zsdl and prior extras through inspect_extra10.zspec.zsdl."
    - "inspect_extra10 covers CO_NESTED/CO_NOFREE/CO_COROUTINE flag values, isbuiltin/__module__, ismethod/__module__, getmembers/__module__, getdoc/__module__, isclass/isbuiltin/isfunction behavioral cases, predicate_modules table."
    - "inspect_extra9 covers isasyncgenfunction __qualname__/__module__, utility function qualnames/modules table, FullArgSpec __name__/__module__/__qualname__, isroutine false/true cases."
    - "inspect_extra8 covers Traceback/__qualname__, BlockFinder __qualname__, isroutine __name__/__module__/__qualname__, iscoroutinefunction/isgeneratorfunction __qualname__ table."
    - "NOT yet covered: inspect.getmembers.__module__.__eq__('inspect') as standalone invariant."
    - "NOT yet covered: inspect.getmodule.__module__.__eq__('inspect') as standalone invariant."
    - "NOT yet covered: inspect.getfile.__module__.__eq__('inspect') as standalone invariant."
    - "NOT yet covered: inspect.getsource.__module__.__eq__('inspect') as standalone invariant."
    - "NOT yet covered: inspect.getsourcelines.__module__.__eq__('inspect') as standalone invariant."
    - "NOT yet covered: inspect.getsourcefile.__module__.__eq__('inspect') as standalone invariant."
    - "NOT yet covered: inspect.getdoc.__module__.__eq__('inspect') as standalone invariant."
    - "NOT yet covered: inspect.ismodule.__module__.__eq__('inspect') as standalone invariant."
    - "NOT yet covered: inspect.isclass.__module__.__eq__('inspect') as standalone invariant."
    - "NOT yet covered: inspect.isfunction.__module__.__eq__('inspect') as standalone invariant."
    - "NOT yet covered: inspect.ismethod.__module__.__eq__('inspect') as standalone invariant."
    - "NOT yet covered: inspect.isbuiltin.__module__.__eq__('inspect') as standalone invariant."
    - "NOT yet covered: inspect.isgenerator.__module__.__eq__('inspect') as standalone invariant."
    - "All inspect module-level functions are pure-Python and have __module__ == 'inspect'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __module__ checks — utility/source functions via __eq__ chain
#
# inspect_extra9/extra10 cover several predicate functions' __module__ via
# tables. This spec adds standalone invariants for the source-retrieval and
# utility functions (getmembers, getmodule, getfile, getsource, getsourcelines,
# getsourcefile, getdoc) that have not been covered as boolean __eq__ contracts.
# ---------------------------------------------------------------------------

invariant inspect_extra11.getmembers.module:
  description: "inspect.getmembers.__module__.__eq__('inspect') == True"
  category: function_modules
  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra11.getmodule.module:
  description: "inspect.getmodule.__module__.__eq__('inspect') == True"
  category: function_modules
  kind: python_call_eq
  function: getmodule.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra11.getfile.module:
  description: "inspect.getfile.__module__.__eq__('inspect') == True"
  category: function_modules
  kind: python_call_eq
  function: getfile.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra11.getsource.module:
  description: "inspect.getsource.__module__.__eq__('inspect') == True"
  category: function_modules
  kind: python_call_eq
  function: getsource.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra11.getsourcelines.module:
  description: "inspect.getsourcelines.__module__.__eq__('inspect') == True"
  category: function_modules
  kind: python_call_eq
  function: getsourcelines.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra11.getsourcefile.module:
  description: "inspect.getsourcefile.__module__.__eq__('inspect') == True"
  category: function_modules
  kind: python_call_eq
  function: getsourcefile.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra11.getdoc.module:
  description: "inspect.getdoc.__module__.__eq__('inspect') == True"
  category: function_modules
  kind: python_call_eq
  function: getdoc.__module__.__eq__
  args: ["inspect"]
  expected: true

# ---------------------------------------------------------------------------
# Predicate function __module__ checks — is* functions via standalone invariants
#
# inspect_extra10 provides a predicate_modules table covering isfunction/
# ismodule/isclass. This spec adds standalone invariants for the remaining
# predicates: ismodule, isclass, isfunction (as individual invariants), and
# the newly targeted ismethod, isbuiltin, and isgenerator.
# ---------------------------------------------------------------------------

invariant inspect_extra11.ismodule.module:
  description: "inspect.ismodule.__module__.__eq__('inspect') == True"
  category: function_modules
  kind: python_call_eq
  function: ismodule.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra11.isclass.module:
  description: "inspect.isclass.__module__.__eq__('inspect') == True"
  category: function_modules
  kind: python_call_eq
  function: isclass.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra11.isfunction.module:
  description: "inspect.isfunction.__module__.__eq__('inspect') == True"
  category: function_modules
  kind: python_call_eq
  function: isfunction.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra11.ismethod.module:
  description: "inspect.ismethod.__module__.__eq__('inspect') == True"
  category: function_modules
  kind: python_call_eq
  function: ismethod.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra11.isbuiltin.module:
  description: "inspect.isbuiltin.__module__.__eq__('inspect') == True"
  category: function_modules
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra11.isgenerator.module:
  description: "inspect.isgenerator.__module__.__eq__('inspect') == True"
  category: function_modules
  kind: python_call_eq
