spec: th3316
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 668 (th3316): __ipow__, __ilshift__, __irshift__ dict-presence checks for threading types."
    - "Theme: __ipow__/__ilshift__/__irshift__ in-place power/shift dict-presence."
    - "In-place augmented assignment operators (**=, <<=, >>=) fall back to __pow__/__lshift__/__rshift__ if not defined."
    - "All values False — callable/iterator/inspection/synchronization types have no in-place power/shift operators."
    - "None of the threading types define __ipow__, __ilshift__, or __irshift__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3316.ipow:
  description: "threading types __ipow__ dict-presence checks; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3316
  columns: [id, function, args, expected]
  rows:
    - ["th3316001", operator.contains, [threading.Thread.__dict__,           "__ipow__"], false]
    - ["th3316002", operator.contains, [threading.Event.__dict__,            "__ipow__"], false]
    - ["th3316003", operator.contains, [threading.Condition.__dict__,        "__ipow__"], false]
    - ["th3316004", operator.contains, [threading.Semaphore.__dict__,        "__ipow__"], false]
    - ["th3316005", operator.contains, [threading.BoundedSemaphore.__dict__, "__ipow__"], false]
    - ["th3316006", operator.contains, [threading.Timer.__dict__,            "__ipow__"], false]
    - ["th3316007", operator.contains, [threading.Barrier.__dict__,          "__ipow__"], false]
    - ["th3316008", operator.contains, [threading.local.__dict__,            "__ipow__"], false]
    - ["th3316009", operator.contains, [type(threading.Lock()).__dict__,     "__ipow__"], false]
    - ["th3316010", operator.contains, [type(threading.RLock()).__dict__,    "__ipow__"], false]

