spec: left_pad
version: ">=1.3.0"
backend: node(left-pad)

docs: https://www.npmjs.com/package/left-pad

provenance:
  derived_from:
    - "left-pad README — https://www.npmjs.com/package/left-pad"
    - "Test vectors verified with left-pad via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "left-pad source"
  notes:
    - "left-pad is an npm package. Install: npm install left-pad"
    - "leftPad(str, len, ch) pads str on the left with ch (default space) to total length len."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the padded string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table left_pad.leftPad:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: lpad

  columns: [id, args, expected]
  rows:
    - [space_pad, ["hi", 5],          "   hi"]
    - [zero_pad,  ["42", 6, "0"],     "000042"]
    - [no_pad,    ["hello", 3],       "hello"]
