spec: concurrent_futures_extra6
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures.zspec.zsdl through concurrent_futures_extra5.zspec.zsdl."
    - "concurrent_futures_extra5 covers __name__ for ThreadPoolExecutor, ProcessPoolExecutor, Future, Executor, CancelledError, TimeoutError, BrokenExecutor, wait, as_completed; wait-constants __eq__; ThreadPoolExecutor.__module__=='concurrent.futures.thread'; Future.__module__ and Executor.__module__=='concurrent.futures._base'."
    - "This spec adds __qualname__ vectors for all major concurrent.futures classes and functions — not previously covered in any prior concurrent_futures spec."
    - "concurrent.futures.ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' — top-level executor class."
    - "concurrent.futures.ProcessPoolExecutor.__qualname__ == 'ProcessPoolExecutor' — top-level executor class."
    - "concurrent.futures.Future.__qualname__ == 'Future' — top-level class in _base."
    - "concurrent.futures.Executor.__qualname__ == 'Executor' — abstract base class."
    - "concurrent.futures.as_completed.__qualname__ == 'as_completed' — module-level generator function."
    - "concurrent.futures.wait.__qualname__ == 'wait' — module-level function."
    - "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str' — wait-return-when constant is a plain str."
    - "concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str' — wait-return-when constant is a plain str."
    - "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str' — wait-return-when constant is a plain str."
    - "concurrent.futures.CancelledError.__qualname__ == 'CancelledError' — exception class."
    - "concurrent.futures.TimeoutError.__qualname__ == 'TimeoutError' — exception class."
    - "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor' — exception class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ table for core concurrent.futures executor and future classes
#
# For top-level (non-nested) classes, __qualname__ == __name__.
# Prior specs verified __name__; this spec introduces __qualname__ vectors.
# ---------------------------------------------------------------------------

table concurrent_futures_extra6.class_qualnames:
  description: "Core concurrent.futures classes have correct __qualname__"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ThreadPoolExecutor,  ThreadPoolExecutor.__qualname__.__eq__,  ["ThreadPoolExecutor"],  true]
    - [ProcessPoolExecutor, ProcessPoolExecutor.__qualname__.__eq__, ["ProcessPoolExecutor"], true]
    - [Future,              Future.__qualname__.__eq__,              ["Future"],              true]
    - [Executor,            Executor.__qualname__.__eq__,            ["Executor"],            true]
    - [CancelledError,      CancelledError.__qualname__.__eq__,      ["CancelledError"],      true]
    - [TimeoutError,        TimeoutError.__qualname__.__eq__,        ["TimeoutError"],        true]
    - [BrokenExecutor,      BrokenExecutor.__qualname__.__eq__,      ["BrokenExecutor"],      true]

# ---------------------------------------------------------------------------
# __qualname__ for concurrent.futures module-level functions
# ---------------------------------------------------------------------------

table concurrent_futures_extra6.function_qualnames:
  description: "concurrent.futures module-level functions have correct __qualname__"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqualname

  columns: [id, function, args, expected]
  rows:
    - [as_completed, as_completed.__qualname__.__eq__, ["as_completed"], true]
    - [wait,         wait.__qualname__.__eq__,         ["wait"],         true]

# ---------------------------------------------------------------------------
# Wait-return-when constants — __class__.__name__ == 'str'
#
# FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are plain string constants.
# The prior spec verified their string values; this spec checks their type name.
# Using method chain in invariants (allowed) to navigate __class__.__name__.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra6.FIRST_COMPLETED.class_name:
  description: "concurrent.futures.FIRST_COMPLETED.__class__.__name__ == 'str'"
  category: constant_types
  kind: python_call_eq
  function: FIRST_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra6.FIRST_EXCEPTION.class_name:
  description: "concurrent.futures.FIRST_EXCEPTION.__class__.__name__ == 'str'"
  category: constant_types
  kind: python_call_eq
  function: FIRST_EXCEPTION.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra6.ALL_COMPLETED.class_name:
  description: "concurrent.futures.ALL_COMPLETED.__class__.__name__ == 'str'"
  category: constant_types
  kind: python_call_eq
  function: ALL_COMPLETED.__class__.__name__.__eq__
  args: ["str"]
  expected: true
