spec: ft3511
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 681 (ft3511): __get__, __set__, __delete__ dict-presence checks for functools types."
    - "functools.partial does NOT define __get__ in its own __dict__ (false): partial objects are not descriptors; use functools.partialmethod for descriptor behavior."
    - "functools.partialmethod defines __get__ (true): partialmethod is a descriptor designed to be used as a method in class bodies; __get__ returns a bound partial."
    - "functools.cached_property defines __get__ (true): cached_property is a non-data descriptor; __get__ computes and caches the value on first access."
    - "type(functools.lru_cache(lambda: None)) defines __get__ (true): the C-level _lru_cache_wrapper type implements tp_descr_get to allow @lru_cache on instance methods."
    - "None of the four functools types define __set__ or __delete__ in their own __dict__ (all false)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
# ---------------------------------------------------------------------------

table ft3511.get:
  description: "functools types __get__ dict-presence checks; wave 681"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3511
  columns: [id, function, args, expected]
  rows:
    - ["ft3511001", operator.contains, [functools.partial.__dict__,                       "__get__"], false]
    - ["ft3511002", operator.contains, [functools.partialmethod.__dict__,                 "__get__"], true]
    - ["ft3511003", operator.contains, [functools.cached_property.__dict__,               "__get__"], true]
    - ["ft3511004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__, "__get__"], true]

