spec: inspect_extra1381
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ and __isabstractmethod__ checks for inspect classes."
    - "inspect.Parameter, inspect.Signature, and inspect.BoundArguments are pure Python classes with no abstract methods defined."
    - "None of these classes have __abstractmethods__ or __isabstractmethod__ in their __dict__."
    - "All class __dict__ attributes are mappingproxy instances for both Python-defined and C extension classes."
    - "inspect.Parameter.__dict__ contains 'POSITIONAL_ONLY', 'POSITIONAL_OR_KEYWORD', 'VAR_POSITIONAL', 'KEYWORD_ONLY', 'VAR_KEYWORD' as class-level constants."
    - "inspect.Signature.__dict__ contains 'empty' (sentinel) and '_parameter_cls'."
    - "inspect.BoundArguments.__dict__ contains 'args' and 'kwargs' as property descriptors."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra1381.abstractmethods_not_in_dict_parameter_signature:
  description: "inspect.Parameter and Signature have no __abstractmethods__ or __isabstractmethod__ in their __dict__; pure Python classes with no abstract-method machinery"
  kind: python_call_eq
  category: abstractmethods_isabstractmethod_checks
  id_prefix: in1381ps
  columns: [id, function, args, expected]
  rows:
    - [in1381ps001, inspect.Parameter.__dict__.__contains__,  ["__abstractmethods__"],  false]
    - [in1381ps002, inspect.Parameter.__dict__.__contains__,  ["__isabstractmethod__"], false]
    - [in1381ps003, inspect.Signature.__dict__.__contains__,  ["__abstractmethods__"],  false]
    - [in1381ps004, inspect.Signature.__dict__.__contains__,  ["__isabstractmethod__"], false]
    - [in1381ps005, inspect.Parameter.__dict__.__class__.__name__.__eq__,  ["mappingproxy"],  true]
    - [in1381ps006, inspect.Signature.__dict__.__class__.__name__.__eq__,  ["mappingproxy"],  true]

table inspect_extra1381.abstractmethods_not_in_dict_boundarguments:
  description: "inspect.BoundArguments has no __abstractmethods__ or __isabstractmethod__ in its __dict__; also confirms mappingproxy type and presence of 'args' and 'kwargs' properties"
  kind: python_call_eq
  category: abstractmethods_isabstractmethod_checks
  id_prefix: in1381ba
  columns: [id, function, args, expected]
  rows:
    - [in1381ba001, inspect.BoundArguments.__dict__.__contains__, ["__abstractmethods__"],  false]
    - [in1381ba002, inspect.BoundArguments.__dict__.__contains__, ["__isabstractmethod__"], false]
    - [in1381ba003, inspect.BoundArguments.__dict__.__class__.__name__.__eq__, ["mappingproxy"],  true]
    - [in1381ba004, inspect.BoundArguments.__dict__.__contains__, ["args"],    true]
    - [in1381ba005, inspect.BoundArguments.__dict__.__contains__, ["kwargs"],  true]
    - [in1381ba006, inspect.Parameter.__dict__.__contains__,      ["POSITIONAL_ONLY"], true]

table inspect_extra1381.parameter_constants_and_signature_sentinel:
  description: "inspect.Parameter exposes kind-constant names in __dict__; inspect.Signature exposes 'empty' sentinel and '_parameter_cls'; none carry abstract-method entries"
  kind: python_call_eq
  category: abstractmethods_isabstractmethod_checks
  id_prefix: in1381pc
  columns: [id, function, args, expected]
  rows:
    - [in1381pc001, inspect.Parameter.__dict__.__contains__,  ["POSITIONAL_OR_KEYWORD"], true]
    - [in1381pc002, inspect.Parameter.__dict__.__contains__,  ["VAR_POSITIONAL"],         true]
    - [in1381pc003, inspect.Parameter.__dict__.__contains__,  ["KEYWORD_ONLY"],           true]
    - [in1381pc004, inspect.Parameter.__dict__.__contains__,  ["VAR_KEYWORD"],            true]
    - [in1381pc005, inspect.Signature.__dict__.__contains__,  ["empty"],                  true]
    - [in1381pc006, inspect.Signature.__dict__.__contains__,  ["_parameter_cls"],         true]
    - [in1381pc007, inspect.Parameter.__dict__.__contains__,  ["__abstractmethods__"],    false]
    - [in1381pc008, inspect.Signature.__dict__.__contains__,  ["__abstractmethods__"],    false]
