spec: multiprocessing_extra182
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/sharedctypes.py"
  notes:
    - "This spec covers multiprocessing.Value, Array, RawValue, RawArray factory function/method identity. At the top level, multiprocessing.Value and multiprocessing.Array are bound methods of the default context (type 'method'), while multiprocessing.RawValue and multiprocessing.RawArray are also bound methods. All four have __name__ attributes. multiprocessing.sharedctypes.Value and sharedctypes.Array are plain functions (type 'function') with __module__=='multiprocessing.sharedctypes'."
    - "multiprocessing.Value.__name__ == 'Value' (len=5). multiprocessing.Value is a bound method of the default multiprocessing context; it delegates to multiprocessing.sharedctypes.Value. __name__ attribute is 'Value'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.RawValue.__name__ == 'RawValue' (len=8). multiprocessing.RawValue is a bound method of the default context. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.sharedctypes.Value.__module__ == 'multiprocessing.sharedctypes' (len=28). The underlying function is defined in multiprocessing.sharedctypes. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.sharedctypes.RawValue.__module__ == 'multiprocessing.sharedctypes' (len=28). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Value and multiprocessing.Array __name__ identity
#
# multiprocessing.Value.__name__ == 'Value' (len=5)
# multiprocessing.Array.__name__ == 'Array' (len=5)
#
# These are bound methods on the default multiprocessing context.
# ---------------------------------------------------------------------------

table multiprocessing_extra182.value_array_name_identity:
  description: "multiprocessing.Value and Array __name__ identity: Value.__name__=='Value'(len=5), Array.__name__=='Array'(len=5); new to multiprocessing_extra182"
  kind: python_call_eq
  category: identity
  id_prefix: mpsharedctypes182

  columns: [id, function, args, expected, description]
  rows:
    - [val_name_eq,
       Value.__name__.__eq__,
       ["Value"],
       true,
       "multiprocessing.Value.__name__.__eq__('Value') == True — multiprocessing.Value is a bound method of the default context that creates a shared ctypes object with a lock; __name__ is 'Value' (5 chars); str.__eq__('Value') returns True; new to multiprocessing_extra182"]
    - [val_name_len_5,
       Value.__name__.__len__,
       [],
       5,
       "multiprocessing.Value.__name__.__len__() == 5 — 'Value' has 5 characters: V-a-l-u-e; NAME LENGTHS: Value=5 == Array=5 < RawValue=8 == RawArray=8; str.__len__() returns 5; new to multiprocessing_extra182"]
    - [arr_name_eq,
       Array.__name__.__eq__,
       ["Array"],
       true,
       "multiprocessing.Array.__name__.__eq__('Array') == True — multiprocessing.Array is a bound method of the default context that creates a shared ctypes array with a lock; __name__ is 'Array' (5 chars); str.__eq__('Array') returns True; new to multiprocessing_extra182"]
    - [arr_name_len_5,
       Array.__name__.__len__,
       [],
       5,
       "multiprocessing.Array.__name__.__len__() == 5 — 'Array' has 5 characters: A-r-r-a-y; same length as 'Value'; str.__len__() returns 5; new to multiprocessing_extra182"]
    - [val_name_eq_arr_len,
       Value.__name__.__len__,
       [],
       5,
       "multiprocessing.Value.__name__.__len__() == 5 — VALUE vs ARRAY name lengths are equal at 5; both shorter than RawValue(8) and RawArray(8); str.__len__() returns 5; new to multiprocessing_extra182"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.RawValue and multiprocessing.RawArray __name__ identity
#
# multiprocessing.RawValue.__name__ == 'RawValue' (len=8)
# multiprocessing.RawArray.__name__ == 'RawArray' (len=8)
#
# These are bound methods on the default multiprocessing context.
# ---------------------------------------------------------------------------

table multiprocessing_extra182.rawvalue_rawarray_name_identity:
  description: "multiprocessing.RawValue and RawArray __name__ identity: RawValue.__name__=='RawValue'(len=8), RawArray.__name__=='RawArray'(len=8); new to multiprocessing_extra182"
  kind: python_call_eq
  category: identity
  id_prefix: mpsharedctypes182

  columns: [id, function, args, expected, description]
  rows:
    - [rv_name_eq,
       RawValue.__name__.__eq__,
       ["RawValue"],
       true,
       "multiprocessing.RawValue.__name__.__eq__('RawValue') == True — multiprocessing.RawValue creates a shared ctypes object without a lock; __name__ is 'RawValue' (8 chars); str.__eq__('RawValue') returns True; new to multiprocessing_extra182"]
    - [rv_name_len_8,
       RawValue.__name__.__len__,
       [],
       8,
       "multiprocessing.RawValue.__name__.__len__() == 8 — 'RawValue' has 8 characters: R-a-w-V-a-l-u-e; NAME LENGTHS: Value=5 == Array=5 < RawValue=8 == RawArray=8; str.__len__() returns 8; new to multiprocessing_extra182"]
    - [ra_name_eq,
       RawArray.__name__.__eq__,
       ["RawArray"],
       true,
       "multiprocessing.RawArray.__name__.__eq__('RawArray') == True — multiprocessing.RawArray creates a shared ctypes array without a lock; __name__ is 'RawArray' (8 chars); str.__eq__('RawArray') returns True; new to multiprocessing_extra182"]
    - [ra_name_len_8,
       RawArray.__name__.__len__,
       [],
       8,
       "multiprocessing.RawArray.__name__.__len__() == 8 — 'RawArray' has 8 characters: R-a-w-A-r-r-a-y; same length as 'RawValue'; str.__len__() returns 8; new to multiprocessing_extra182"]
    - [rv_ra_name_len_eq,
       RawValue.__name__.__len__,
       [],
       8,
       "multiprocessing.RawValue.__name__.__len__() == 8 — RawValue(8) == RawArray(8) > Value(5) == Array(5); length ordering confirmed; str.__len__() returns 8; new to multiprocessing_extra182"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.sharedctypes function __module__ identity
#
# multiprocessing.sharedctypes.Value.__module__ == 'multiprocessing.sharedctypes' (len=28)
# multiprocessing.sharedctypes.Array.__module__ == 'multiprocessing.sharedctypes' (len=28)
# multiprocessing.sharedctypes.RawValue.__module__ == 'multiprocessing.sharedctypes' (len=28)
# multiprocessing.sharedctypes.RawArray.__module__ == 'multiprocessing.sharedctypes' (len=28)
# ---------------------------------------------------------------------------

table multiprocessing_extra182.sharedctypes_module_identity:
  description: "multiprocessing.sharedctypes functions __module__=='multiprocessing.sharedctypes'(len=28); new to multiprocessing_extra182"
  kind: python_call_eq
  category: identity
  id_prefix: mpsharedctypes182

  columns: [id, function, args, expected, description]
  rows:
    - [sc_val_module_eq,
       sharedctypes.Value.__module__.__eq__,
       ["multiprocessing.sharedctypes"],
       true,
       "multiprocessing.sharedctypes.Value.__module__.__eq__('multiprocessing.sharedctypes') == True — sharedctypes.Value is defined in multiprocessing.sharedctypes (len=28); str.__eq__('multiprocessing.sharedctypes') returns True; new to multiprocessing_extra182"]
    - [sc_arr_module_eq,
       sharedctypes.Array.__module__.__eq__,
       ["multiprocessing.sharedctypes"],
       true,
       "multiprocessing.sharedctypes.Array.__module__.__eq__('multiprocessing.sharedctypes') == True — sharedctypes.Array is defined in multiprocessing.sharedctypes (len=28); str.__eq__('multiprocessing.sharedctypes') returns True; new to multiprocessing_extra182"]
    - [sc_rv_module_eq,
       sharedctypes.RawValue.__module__.__eq__,
       ["multiprocessing.sharedctypes"],
       true,
       "multiprocessing.sharedctypes.RawValue.__module__.__eq__('multiprocessing.sharedctypes') == True — sharedctypes.RawValue is defined in multiprocessing.sharedctypes (len=28); str.__eq__('multiprocessing.sharedctypes') returns True; new to multiprocessing_extra182"]
    - [sc_ra_module_eq,
       sharedctypes.RawArray.__module__.__eq__,
       ["multiprocessing.sharedctypes"],
       true,
       "multiprocessing.sharedctypes.RawArray.__module__.__eq__('multiprocessing.sharedctypes') == True — sharedctypes.RawArray is defined in multiprocessing.sharedctypes (len=28); str.__eq__('multiprocessing.sharedctypes') returns True; new to multiprocessing_extra182"]
    - [sc_val_module_len_28,
       sharedctypes.Value.__module__.__len__,
       [],
       28,
       "multiprocessing.sharedctypes.Value.__module__.__len__() == 28 — 'multiprocessing.sharedctypes' has 28 characters; str.__len__() returns 28; new to multiprocessing_extra182"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra182
# ---------------------------------------------------------------------------

invariant multiprocessing_extra182.value_name_eq:
  description: "multiprocessing.Value.__name__ == 'Value' — factory for shared ctypes with lock; len=5; new to multiprocessing_extra182"
  category: identity
  kind: python_call_eq
  function: Value.__name__.__eq__
  args: ["Value"]
  expected: true

invariant multiprocessing_extra182.array_name_eq:
  description: "multiprocessing.Array.__name__ == 'Array' — factory for shared ctypes array with lock; len=5; new to multiprocessing_extra182"
  category: identity
  kind: python_call_eq
  function: Array.__name__.__eq__
  args: ["Array"]
  expected: true

invariant multiprocessing_extra182.rawvalue_name_eq:
  description: "multiprocessing.RawValue.__name__ == 'RawValue' — factory for shared ctypes without lock; len=8; new to multiprocessing_extra182"
  category: identity
  kind: python_call_eq
  function: RawValue.__name__.__eq__
  args: ["RawValue"]
  expected: true

invariant multiprocessing_extra182.rawarray_name_eq:
  description: "multiprocessing.RawArray.__name__ == 'RawArray' — factory for shared ctypes array without lock; len=8; new to multiprocessing_extra182"
  category: identity
  kind: python_call_eq
  function: RawArray.__name__.__eq__
  args: ["RawArray"]
  expected: true

invariant multiprocessing_extra182.sharedctypes_value_module_eq:
  description: "multiprocessing.sharedctypes.Value.__module__ == 'multiprocessing.sharedctypes' — underlying function defined in sharedctypes submodule; len=28; new to multiprocessing_extra182"
  category: identity
  kind: python_call_eq
  function: sharedctypes.Value.__module__.__eq__
  args: ["multiprocessing.sharedctypes"]
  expected: true

invariant multiprocessing_extra182.sharedctypes_array_module_eq:
  description: "multiprocessing.sharedctypes.Array.__module__ == 'multiprocessing.sharedctypes' — underlying function defined in sharedctypes submodule; len=28; new to multiprocessing_extra182"
  category: identity
  kind: python_call_eq
  function: sharedctypes.Array.__module__.__eq__
  args: ["multiprocessing.sharedctypes"]
  expected: true

invariant multiprocessing_extra182.sharedctypes_rawvalue_module_eq:
  description: "multiprocessing.sharedctypes.RawValue.__module__ == 'multiprocessing.sharedctypes' — defined in sharedctypes submodule; len=28; new to multiprocessing_extra182"
  category: identity
  kind: python_call_eq
  function: sharedctypes.RawValue.__module__.__eq__
  args: ["multiprocessing.sharedctypes"]
