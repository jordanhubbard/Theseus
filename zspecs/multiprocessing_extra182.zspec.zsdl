invariant multiprocessing_extra182.sharedctypes_rawarray_module_eq:
  description: "multiprocessing.sharedctypes.RawArray.__module__ == 'multiprocessing.sharedctypes' — defined in sharedctypes submodule; len=28; new to multiprocessing_extra182"
  category: identity
