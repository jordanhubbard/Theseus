invariant multiprocessing_extra124.Lock_is_method_not_class:
  description: "multiprocessing.Lock.__class__.__name__.__eq__('method') returns True — multiprocessing.Lock is NOT a class object; it is a bound method of the default multiprocessing context (an instance of DefaultContext, a subclass of BaseContext from Lib/multiprocessing/context.py); multiprocessing.Lock() creates and returns an actual synchronization lock object for the current start method (fork/spawn/forkserver); Lock.__qualname__ is 'BaseContext.Lock' (len=16: 'BaseContext.'=12+'Lock'=4); Lock.__module__ is 'multiprocessing.context'; this design allows multiprocessing to support multiple start methods via the same API — the bound method dispatches to the appropriate underlying lock class; compare with threading.Lock which IS a factory function (class='builtin_function_or_method') that directly returns a C-level lock; NEW in extra124: first standalone multiprocessing.Lock class name invariant in mpsyncident124 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Lock.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra124.Semaphore_qualname_len_21:
  description: "multiprocessing.Semaphore.__qualname__.__len__() == 21 — multiprocessing.Semaphore.__qualname__ is 'BaseContext.Semaphore' (21 chars: 'BaseContext.'=12+'Semaphore'=9=21); this is tied for the longest qualname among the 8 sync factory methods in this spec: Lock=16, RLock=Event=Value=17, Barrier=Manager=19, Semaphore=Condition=21; 'Semaphore' is 9 chars (a Greek-derived word for signaling); Semaphore.__class__.__name__ is 'method' (bound method of context); Semaphore.__module__ is 'multiprocessing.context'; Semaphore.__code__.co_name is 'Semaphore' (len=9, tied with Condition for longest co_name); NEW in extra124: first standalone Semaphore qualname length invariant in mpsyncident124 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Semaphore.__qualname__.__len__
  args: []
  expected: 21

invariant multiprocessing_extra124.Condition_qualname_len_21:
  description: "multiprocessing.Condition.__qualname__.__len__() == 21 — multiprocessing.Condition.__qualname__ is 'BaseContext.Condition' (21 chars: 'BaseContext.'=12+'Condition'=9=21); this is tied with Semaphore for the longest qualname in this spec; both 'Semaphore' and 'Condition' are 9-character names that push their qualnames to 21 chars (the maximum in the spec); Condition.__class__.__name__ is 'method' (bound method of context); Condition.__module__ is 'multiprocessing.context'; Condition.__code__.co_name is 'Condition' (len=9, tied with Semaphore for longest co_name); multiprocessing.Condition() creates a condition variable — a synchronization primitive that allows threads/processes to wait for some condition to become true; NEW in extra124: first standalone Condition qualname length invariant in mpsyncident124 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Condition.__qualname__.__len__
  args: []
  expected: 21

invariant multiprocessing_extra124.Lock_qualname_is_BaseContext_Lock:
  description: "multiprocessing.Lock.__qualname__.__eq__('BaseContext.Lock') returns True — multiprocessing.Lock.__qualname__ is 'BaseContext.Lock' (len=16: 'BaseContext.'=12+'Lock'=4); the qualname reflects that Lock is defined as a method on BaseContext (Lib/multiprocessing/context.py); 'BaseContext.Lock' is the shortest qualname among the 8 synchronization factory methods in this spec (Lock=16 < RLock=Event=Value=17 < Barrier=Manager=19 < Semaphore=Condition=21); multiprocessing.Lock.__class__.__name__ is 'method'; multiprocessing.Lock.__code__.co_name is 'Lock' (len=4, the shortest co_name in the spec); multiprocessing.Lock.__module__ is 'multiprocessing.context'; NEW in extra124: first standalone Lock qualname equality invariant in mpsyncident124 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
