table multiprocessing_extra124.mp_lock_semaphore_identity:
  description: "multiprocessing.Lock, Semaphore, RLock, Barrier class identity checks in mpsyncident124 namespace — wave 255 theme: multiprocessing.Lock, Semaphore, RLock, and Barrier are NOT class objects at the top-level multiprocessing namespace; they are bound methods of the default multiprocessing context (DefaultContext, a subclass of BaseContext in Lib/multiprocessing/context.py); multiprocessing.Lock.__class__.__name__.__eq__('method')==True (Lock is a bound method, not a class); multiprocessing.Semaphore.__class__.__name__.__eq__('method')==True (same pattern); multiprocessing.RLock.__class__.__name__.__eq__('method')==True; multiprocessing.Barrier.__class__.__name__.__eq__('method')==True; multiprocessing.Lock.__qualname__.__eq__('BaseContext.Lock')==True (len=16: 'BaseContext.'=12+'Lock'=4; qualname shows the defining class BaseContext); multiprocessing.Lock.__qualname__.__len__()==16; multiprocessing.Semaphore.__qualname__.__eq__('BaseContext.Semaphore')==True (len=21: 'BaseContext.'=12+'Semaphore'=9, longest in this table); multiprocessing.Semaphore.__qualname__.__len__()==21; multiprocessing.RLock.__qualname__.__eq__('BaseContext.RLock')==True (len=17: 'BaseContext.'=12+'RLock'=5); multiprocessing.RLock.__qualname__.__len__()==17; multiprocessing.Barrier.__qualname__.__eq__('BaseContext.Barrier')==True (len=19: 'BaseContext.'=12+'Barrier'=7); multiprocessing.Barrier.__qualname__.__len__()==19; all share __module__=='multiprocessing.context'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsyncident124

  columns: [id, function, args, expected, description]
  rows:
    - [lock_cls,     multiprocessing.Lock.__class__.__name__.__eq__,          ["method"],             true, "multiprocessing.Lock.__class__.__name__ == 'method' (bound method of default context, not a class); verified with Python 3.14.3"]
    - [sem_cls,      multiprocessing.Semaphore.__class__.__name__.__eq__,      ["method"],             true, "multiprocessing.Semaphore.__class__.__name__ == 'method' (bound method); verified with Python 3.14.3"]
    - [rl_cls,       multiprocessing.RLock.__class__.__name__.__eq__,          ["method"],             true, "multiprocessing.RLock.__class__.__name__ == 'method' (bound method); verified with Python 3.14.3"]
    - [bar_cls,      multiprocessing.Barrier.__class__.__name__.__eq__,        ["method"],             true, "multiprocessing.Barrier.__class__.__name__ == 'method' (bound method); verified with Python 3.14.3"]
    - [lock_qn_eq,   multiprocessing.Lock.__qualname__.__eq__,                 ["BaseContext.Lock"],   true, "multiprocessing.Lock.__qualname__ == 'BaseContext.Lock' (len=16; defines in BaseContext); verified with Python 3.14.3"]
    - [lock_qn_len,  multiprocessing.Lock.__qualname__.__len__,                [],                     16,   "multiprocessing.Lock.__qualname__.__len__() == 16 ('BaseContext.'=12+'Lock'=4=16); verified with Python 3.14.3"]
    - [sem_qn_eq,    multiprocessing.Semaphore.__qualname__.__eq__,            ["BaseContext.Semaphore"], true, "multiprocessing.Semaphore.__qualname__ == 'BaseContext.Semaphore' (len=21, longest in table); verified with Python 3.14.3"]
    - [sem_qn_len,   multiprocessing.Semaphore.__qualname__.__len__,           [],                     21,   "multiprocessing.Semaphore.__qualname__.__len__() == 21 ('BaseContext.'=12+'Semaphore'=9=21); verified with Python 3.14.3"]
    - [rl_qn_eq,     multiprocessing.RLock.__qualname__.__eq__,                ["BaseContext.RLock"],  true, "multiprocessing.RLock.__qualname__ == 'BaseContext.RLock' (len=17); verified with Python 3.14.3"]
