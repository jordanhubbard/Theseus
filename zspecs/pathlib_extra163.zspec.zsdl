spec: pathlib_extra163
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers: pathlib.Path method __qualname__ values for read_text, read_bytes, write_bytes, open, expanduser, resolve, absolute."
    - "pathlib.POSIX_FLAVOUR does not exist in Python 3.14.3 (hasattr(pathlib, 'POSIX_FLAVOUR') == False); it was removed as part of the pathlib refactoring in Python 3.12."
    - "All pathlib.Path method qualnames follow the 'Path.<method>' pattern with the public class name 'Path' (no underscore prefix). This contrasts with io.IOBase methods which use the private C name '_IOBase.' in their qualnames."
    - "pathlib.Path.read_text.__qualname__ == 'Path.read_text' (len=14); read_bytes == 'Path.read_bytes' (len=15); write_bytes == 'Path.write_bytes' (len=16); open == 'Path.open' (len=9); expanduser == 'Path.expanduser' (len=15); resolve == 'Path.resolve' (len=12); absolute == 'Path.absolute' (len=13)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path I/O method __qualname__ values
# read_text, read_bytes, write_bytes, open — filesystem I/O methods on Path.
# All use 'Path.' prefix (public class name, no underscore prefix).
# This contrasts with io.IOBase methods which use '_IOBase.' (private C name).
# ---------------------------------------------------------------------------

table pathlib_extra163.Path_io_method_qualnames:
  description: "pathlib.Path I/O method __qualname__ values: read_text='Path.read_text', read_bytes='Path.read_bytes', write_bytes='Path.write_bytes', open='Path.open'; all use public 'Path.' prefix"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibmq163

  columns: [id, function, args, expected, description]
  rows:
    - [read_text_qeq,   Path.read_text.__qualname__.__eq__,   ["Path.read_text"],   true, "pathlib.Path.read_text.__qualname__ == 'Path.read_text' (read_text() opens the file in text mode and returns the contents as a string; accepts optional encoding and errors parameters; 'Path.read_text' has 14 characters: 'Path.' (5) + 'read_text' (9) = 14; Path method qualnames use the public class name 'Path' — no underscore prefix — unlike io.IOBase methods which use '_IOBase.' in qualnames)"]
    - [read_bytes_qeq,  Path.read_bytes.__qualname__.__eq__,  ["Path.read_bytes"],  true, "pathlib.Path.read_bytes.__qualname__ == 'Path.read_bytes' (read_bytes() opens the file in binary mode and returns the contents as a bytes object; it is the binary analog of read_text(); 'Path.read_bytes' has 15 characters: 'Path.' (5) + 'read_bytes' (10) = 15; one character longer than 'Path.read_text' (14) because 'read_bytes' (10) is one character longer than 'read_text' (9))"]
    - [write_bytes_qeq, Path.write_bytes.__qualname__.__eq__, ["Path.write_bytes"], true, "pathlib.Path.write_bytes.__qualname__ == 'Path.write_bytes' (write_bytes() opens the file in binary mode and writes data as bytes; it is the complement of read_bytes(); 'Path.write_bytes' has 16 characters: 'Path.' (5) + 'write_bytes' (11) = 16; the 'write_' prefix adds one character over 'read_bytes' making write_bytes the longest I/O method qualname in this table at 16)"]
    - [open_qeq,        Path.open.__qualname__.__eq__,        ["Path.open"],        true, "pathlib.Path.open.__qualname__ == 'Path.open' (Path.open() opens the file and returns a file object, analogous to the built-in open() but using the Path object; accepts mode, buffering, encoding, errors, newline arguments; 'Path.open' has 9 characters: 'Path.' (5) + 'open' (4) = 9; the shortest Path I/O method qualname covered here — 'open' (4 chars) is the shortest method name)"]

# ---------------------------------------------------------------------------
# pathlib.Path path-manipulation method __qualname__ values
# expanduser, resolve, absolute — path transformation methods.
# expanduser: 'Path.expanduser' (len=15)
# resolve: 'Path.resolve' (len=12)
# absolute: 'Path.absolute' (len=13)
# ---------------------------------------------------------------------------

table pathlib_extra163.Path_transform_method_qualnames:
  description: "pathlib.Path path-transformation method __qualname__ values: expanduser='Path.expanduser', resolve='Path.resolve', absolute='Path.absolute'; lengths 15, 12, 13 respectively"
  kind: python_call_eq
  category: qualname
  id_prefix: pathlibmq163

  columns: [id, function, args, expected, description]
  rows:
    - [expanduser_qeq, Path.expanduser.__qualname__.__eq__, ["Path.expanduser"], true, "pathlib.Path.expanduser.__qualname__ == 'Path.expanduser' (expanduser() expands a leading ~ or ~user in the path to the user's home directory; returns a new Path with ~ expanded; 'Path.expanduser' has 15 characters: 'Path.' (5) + 'expanduser' (10) = 15; expanduser() was added to pathlib in Python 3.5 and makes pathlib more convenient for working with user-relative paths like '~/Documents')"]
    - [resolve_qeq,    Path.resolve.__qualname__.__eq__,    ["Path.resolve"],    true, "pathlib.Path.resolve.__qualname__ == 'Path.resolve' (resolve() makes the path absolute, resolving any symlinks; returns a new absolute Path; 'Path.resolve' has 12 characters: 'Path.' (5) + 'resolve' (7) = 12; resolve() is the recommended way to normalize paths in pathlib as it also resolves symlinks, unlike Path.absolute() which only makes the path absolute without resolving symlinks)"]
    - [absolute_qeq,   Path.absolute.__qualname__.__eq__,   ["Path.absolute"],   true, "pathlib.Path.absolute.__qualname__ == 'Path.absolute' (absolute() makes the path absolute without resolving symlinks; returns a new absolute Path; 'Path.absolute' has 13 characters: 'Path.' (5) + 'absolute' (8) = 13; one character longer than 'Path.resolve' (12); unlike resolve(), absolute() does not follow symlinks or resolve '..' components — it simply prepends the current directory if the path is relative)"]
    - [read_text_qlen, Path.read_text.__qualname__.__len__,  [], 14, "pathlib.Path.read_text.__qualname__.__len__() == 14 ('Path.read_text' has 14 characters; 'Path.' (5) + 'read_text' (9) = 14; among Path I/O methods, read_text (14) < read_bytes (15) < write_bytes (16); the length progression from read_text to write_bytes reflects the increasing length of the method names: 'read_text' (9), 'read_bytes' (10), 'write_bytes' (11))"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra163.Path_read_text_qualname_uses_public_prefix:
  description: "pathlib.Path.read_text.__qualname__ == 'Path.read_text' — Path.read_text() uses the public class name 'Path' in its qualname (not a private underscore-prefixed name); this is the key contrast with io.IOBase methods whose qualnames use '_IOBase.' (private C name); pathlib is implemented in pure Python (Lib/pathlib/_local.py), so its method qualnames naturally reflect the public class names; 'Path.read_text' has 14 characters; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Path.read_text.__qualname__.__eq__
  args: ["Path.read_text"]
  expected: true

invariant pathlib_extra163.Path_resolve_qualname_len_12:
  description: "pathlib.Path.resolve.__qualname__.__len__() == 12 — 'Path.resolve' has 12 characters: 'Path.' (5) + 'resolve' (7) = 12; resolve() is the recommended pathlib method for obtaining a fully normalized absolute path with symlinks expanded; it differs from absolute() (len=13) which does not follow symlinks; 'Path.resolve' (12) is shorter than 'Path.absolute' (13) and 'Path.expanduser' (15); confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Path.resolve.__qualname__.__len__
  args: []
  expected: 12

invariant pathlib_extra163.Path_write_bytes_qualname_len_16:
  description: "pathlib.Path.write_bytes.__qualname__.__len__() == 16 — 'Path.write_bytes' has 16 characters: 'Path.' (5) + 'write_bytes' (11) = 16; write_bytes() is the longest-named of the four Path I/O methods covered in this spec (open=9, read_text=14, read_bytes=15, write_bytes=16); write_bytes() atomically writes bytes to the file, overwriting any existing contents; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Path.write_bytes.__qualname__.__len__
  args: []
  expected: 16

invariant pathlib_extra163.POSIX_FLAVOUR_does_not_exist:
  description: "hasattr(pathlib, 'POSIX_FLAVOUR') == False — pathlib.POSIX_FLAVOUR does not exist in Python 3.14.3; it was an internal implementation detail removed during the pathlib refactoring in Python 3.12+ (PEP 428 / pathlib internals cleanup); the new pathlib architecture in Lib/pathlib/_local.py and Lib/pathlib/_abc.py replaced the old 'flavour' objects; code that relied on pathlib._POSIX_FLAVOUR or pathlib.POSIX_FLAVOUR should be updated; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.__dict__.__contains__
  args: ["POSIX_FLAVOUR"]
  expected: false
