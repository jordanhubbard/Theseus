spec: uuid_extra18
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Extends uuid.zspec.zsdl through uuid_extra17.zspec.zsdl."
    - "uuid_extra5 covers: UUID.__qualname__.__eq__ and uuid1/3/4/5 __qualname__.__eq__ in a table."
    - "uuid_extra15 covers: NAMESPACE_DNS/URL/OID.__class__.__qualname__.__eq__('UUID'); uuid3/uuid5 __qualname__ standalone."
    - "uuid_extra16 covers: UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__ method __qualname__.__eq__ and __qualname__.__len__()."
    - "uuid_extra17 covers: UUID comparison method __qualname__ values (__lt__/__gt__/__le__/__ge__); NAMESPACE_X500.__class__.__qualname__; NAMESPACE_DNS.version and .variant types."
    - "This spec adds: uuid.UUID.__module__ and uuid.UUID.__bases__[0].__name__; uuid1/uuid3/uuid4/uuid5 __module__; uuid.UUID property fget __qualname__ values for hex/bytes/urn/version/bytes_le/fields/variant. uuid_extra5 checks uuid1-5 __qualname__.__eq__ in a table but no prior spec checks their __module__. No prior spec checks UUID.__module__ or UUID.__bases__[0].__name__. No prior spec checks property fget __qualname__ for hex/bytes/urn/version/bytes_le/fields/variant."
    - "uuid.UUID.__module__ == 'uuid' — the UUID class is defined in the top-level uuid module."
    - "uuid.UUID.__bases__[0].__name__ == 'object' — UUID inherits directly from object; no prior uuid spec checks this."
    - "uuid.uuid1/3/4/5 __module__ == 'uuid' — all factory functions are defined in the top-level uuid module. uuid_extra5 checks their __qualname__ but no spec checks __module__."
    - "uuid.UUID.hex.fget.__qualname__ == 'UUID.hex' (length 8) — hex is a property; fget is the getter function. No prior uuid spec checks property fget qualnames."
    - "uuid.UUID.bytes.fget.__qualname__ == 'UUID.bytes' (length 10) — bytes is a property."
    - "uuid.UUID.urn.fget.__qualname__ == 'UUID.urn' (length 8) — urn is a property."
    - "uuid.UUID.version.fget.__qualname__ == 'UUID.version' (length 12) — version is a property."
    - "uuid.UUID.bytes_le.fget.__qualname__ == 'UUID.bytes_le' (length 13) — bytes_le is a property."
    - "uuid.UUID.fields.fget.__qualname__ == 'UUID.fields' (length 11) — fields is a property."
    - "uuid.UUID.variant.fget.__qualname__ == 'UUID.variant' (length 12) — variant is a property."
    - "Note: uuid.UUID.int is a member_descriptor (slot), not a property, so it has no fget attribute. It is not covered here."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__module__ and __bases__[0].__name__
#
# No prior uuid spec checks UUID.__module__ or UUID.__bases__[0].__name__.
# UUID is defined in the top-level 'uuid' module and inherits from object.
# ---------------------------------------------------------------------------

invariant uuid_extra18.UUID.module:
  description: "uuid.UUID.__module__ == 'uuid' — UUID class is defined in the top-level uuid module; no prior spec checks this"
  category: class_identity
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra18.UUID.bases_name:
  description: "uuid.UUID.__bases__[0].__name__ == 'object' — UUID inherits directly from object; no prior spec checks this"
  category: class_identity
  kind: python_call_eq
  function: "UUID.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# uuid factory function __module__ values
#
# uuid_extra5 checks uuid1/3/4/5 __qualname__.__eq__ in a table. No prior
# uuid spec checks __module__ for any factory function. All four are defined
# in the top-level 'uuid' module.
# ---------------------------------------------------------------------------

table uuid_extra18.factory_modules:
  description: "uuid1/uuid3/uuid4/uuid5 __module__ == 'uuid' — no prior uuid spec checks factory function __module__"
  kind: python_call_eq
  category: function_modules
  id_prefix: factmod18

  columns: [id, function, args, expected]
  rows:
    - [uuid1, uuid1.__module__.__eq__, ["uuid"], true]
    - [uuid3, uuid3.__module__.__eq__, ["uuid"], true]
    - [uuid4, uuid4.__module__.__eq__, ["uuid"], true]
    - [uuid5, uuid5.__module__.__eq__, ["uuid"], true]

# ---------------------------------------------------------------------------
# UUID property fget __qualname__ values
#
# uuid.UUID exposes several attributes as Python properties. Each property
# has a fget getter function whose __qualname__ follows the 'UUID.<name>'
# pattern. No prior uuid spec checks property fget __qualname__ values.
# uuid.UUID.int is a slot (member_descriptor) and has no fget; it is excluded.
# ---------------------------------------------------------------------------

table uuid_extra18.UUID_property_fget_qualnames:
  description: "UUID property fget __qualname__ values — no prior uuid spec checks property fget qualnames"
  kind: python_call_eq
  category: property_qualnames
  id_prefix: propfqn18

  columns: [id, function, args, expected]
  rows:
    - [hex,      "UUID.hex.fget.__qualname__.__eq__",      ["UUID.hex"],      true]
    - [bytes,    "UUID.bytes.fget.__qualname__.__eq__",    ["UUID.bytes"],    true]
    - [urn,      "UUID.urn.fget.__qualname__.__eq__",      ["UUID.urn"],      true]
    - [version,  "UUID.version.fget.__qualname__.__eq__",  ["UUID.version"],  true]
    - [bytes_le, "UUID.bytes_le.fget.__qualname__.__eq__", ["UUID.bytes_le"], true]
    - [fields,   "UUID.fields.fget.__qualname__.__eq__",   ["UUID.fields"],   true]
    - [variant,  "UUID.variant.fget.__qualname__.__eq__",  ["UUID.variant"],  true]

# ---------------------------------------------------------------------------
# UUID property fget __qualname__ string lengths
#
# No prior uuid spec checks string lengths for property fget qualnames.
# UUID.hex and UUID.urn are both 8 chars; UUID.bytes is 10; UUID.version
# and UUID.variant are both 12; UUID.fields is 11; UUID.bytes_le is 13.
# ---------------------------------------------------------------------------

table uuid_extra18.UUID_property_fget_qualname_lengths:
  description: "UUID property fget __qualname__ string lengths — no prior uuid spec checks these lengths"
  kind: python_call_eq
  category: property_qualnames
  id_prefix: propfql18

  columns: [id, function, args, expected]
  rows:
    - [hex,      UUID.hex.fget.__qualname__.__len__,      [], 8]
    - [bytes,    UUID.bytes.fget.__qualname__.__len__,    [], 10]
    - [urn,      UUID.urn.fget.__qualname__.__len__,      [], 8]
    - [version,  UUID.version.fget.__qualname__.__len__,  [], 12]
    - [bytes_le, UUID.bytes_le.fget.__qualname__.__len__, [], 13]
    - [fields,   UUID.fields.fget.__qualname__.__len__,   [], 11]
    - [variant,  UUID.variant.fget.__qualname__.__len__,  [], 12]
