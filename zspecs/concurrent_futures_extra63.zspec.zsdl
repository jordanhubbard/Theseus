spec: concurrent_futures_extra63
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object co_consts, co_nlocals, and co_stacksize documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures_extra62.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, CancelledError/TimeoutError/BrokenExecutor/InvalidStateError identity and bases, as_completed/wait __name__/__qualname__, FIRST_COMPLETED/FIRST_EXCEPTION/ALL_COMPLETED values and __len__(), class __module__/__name__/__len__() tables, submit/shutdown qualname lens, Future method qualname lens, class __dict__.__class__.__name__/__qualname__ tables, wait/__name__=='wait', as_completed/__name__=='as_completed', wait/__qualname__.__len__()==4, as_completed/__qualname__.__len__()==12 (extra51), class __class__.__name__/__qualname__ equality (extra44/extra45), wait/__class__.__module__=='builtins' and ThreadPoolExecutor/__class__.__module__=='builtins' (extra45), class __doc__/__class__/__module__=='builtins' tables (extra47/extra49), ProcessPoolExecutor/Future/Executor __class__.__module__.__eq__('builtins') (extra52), as_completed/__class__.__module__.__eq__('builtins') (extra52), ThreadPoolExecutor/ProcessPoolExecutor/Future __init__.__class__.__name__.__eq__('function') (extra52), class __repr__.__class__.__name__ tables (extra53), class __weakref__.__class__.__name__ tables (extra53), exception __repr__.__class__.__name__ tables (extra53), cf.__all__.__class__.__name__.__eq__('list') (extra54), cf.__all__.__len__()==14 (extra54), __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra54), cf.__all__.__contains__ membership checks (extra55), cf.__package__.__eq__('concurrent.futures') (extra55), Future/Executor __doc__.__class__.__name__.__eq__('str') (extra55), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra56), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra57), Future/__init__ and ThreadPoolExecutor/__init__ and Future.result/done/cancel/exception and ThreadPoolExecutor.submit/shutdown __qualname__.__eq__ (extra58), wait/as_completed __annotations__.__class__.__name__.__eq__('dict'), wait __globals__.__class__.__name__.__eq__('dict'), wait __globals__.__contains__('wait'), Future.__doc__.__contains__('Represents'), ThreadPoolExecutor.__doc__.__class__.__name__.__eq__('NoneType') (extra59), wait/__defaults__/__code__/__class__.__name__ checks, as_completed/__defaults__/__code__/__class__.__name__ checks, Future.__init__/__defaults__/__class__.__name__ checks (extra60), wait/as_completed/Future.__init__ __code__.co_name equality and co_argcount values (extra61), wait/as_completed/Future.__init__ co_varnames/co_filename/co_flags attribute chains (extra62)."
    - "This spec covers (cfcode4_63 namespace): wave 232 theme — __code__.co_consts, co_nlocals, co_stacksize attribute chains, plus class __doc__ content checks. NEW in extra63: wait.__code__.co_consts.__class__.__name__=='tuple' — co_consts is always a tuple; as_completed.__code__.co_consts.__class__.__name__=='tuple'; Future.__init__.__code__.co_consts.__class__.__name__=='tuple'; wait/as_completed/Future.__init__ co_nlocals.__class__.__name__=='int'; wait/as_completed/Future.__init__ co_stacksize.__class__.__name__=='int'; Future.__doc__.__class__.__name__=='str'; Future.__doc__.__contains__('Future')==True; Executor.__doc__.__contains__('Executor')==True."
    - "concurrent.futures.wait.__code__.co_consts.__class__.__name__ == 'tuple'. co_consts is a tuple of constants (literals, nested code objects, None, etc.) used by the code object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__code__.co_nlocals.__class__.__name__ == 'int'. co_nlocals is the number of local variables (including parameters) used by the function, stored as a plain Python int. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.wait.__code__.co_stacksize.__class__.__name__ == 'int'. co_stacksize is the required stack size (the maximum number of stack entries needed during execution), stored as a plain Python int. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__doc__.__contains__('Future') == True. Future.__doc__ is a non-empty string that mentions 'Future' in its text. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__doc__.__contains__('Executor') == True. Executor.__doc__ is a non-empty string that mentions 'Executor' in its text. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures __code__.co_consts.__class__.__name__ checks — extra63
#
# Wave 232 theme: co_consts type identity.
#
# co_consts is always a tuple of constants (literals, nested code objects,
# None, etc.) used by the code object.
# tuple.__class__.__name__ == 'tuple'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra63.co_consts_class_name:
  description: "concurrent.futures __code__.co_consts.__class__.__name__.__eq__('tuple') checks in cfcode4_63 namespace — wave 232 theme: co_consts type identity; co_consts is always a tuple on all code objects; wait/as_completed/Future.__init__ all have co_consts.__class__.__name__=='tuple'; NEW in extra63: no prior cf spec has checked __code__.co_consts.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfcode4_63

  columns: [id, function, args, expected, description]
  rows:
    - [wait_co_consts_class,         wait.__code__.co_consts.__class__.__name__.__eq__,             ["tuple"], true, "wait.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is a tuple of constants (literals, nested code objects, None, etc.) used by the code object; wait.__code__.co_consts is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra63: first co_consts.__class__.__name__ check for wait in any cf spec; verified with Python 3.14.3"]
    - [as_completed_co_consts_class, as_completed.__code__.co_consts.__class__.__name__.__eq__,     ["tuple"], true, "as_completed.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple; as_completed.__code__.co_consts is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra63: first co_consts.__class__.__name__ check for as_completed in any cf spec; verified with Python 3.14.3"]
    - [future_init_co_consts_class,  Future.__init__.__code__.co_consts.__class__.__name__.__eq__,  ["tuple"], true, "Future.__init__.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is always a tuple; Future.__init__.__code__.co_consts is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra63: first co_consts.__class__.__name__ check for Future.__init__ in any cf spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures __code__.co_nlocals.__class__.__name__ checks — extra63
#
# Wave 232 theme: co_nlocals type identity.
#
# co_nlocals is the count of local variables (including parameters) used by
# the function. It is always a plain Python int.
# int.__class__.__name__ == 'int'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra63.co_nlocals_class_name:
  description: "concurrent.futures __code__.co_nlocals.__class__.__name__.__eq__('int') checks in cfcode4_63 namespace — wave 232 theme: co_nlocals type identity; co_nlocals is the count of local variables (including parameters); wait/as_completed/Future.__init__ all have co_nlocals.__class__.__name__=='int'; NEW in extra63: no prior cf spec has checked __code__.co_nlocals.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfcode4_63a

  columns: [id, function, args, expected, description]
  rows:
    - [wait_co_nlocals_class,         wait.__code__.co_nlocals.__class__.__name__.__eq__,             ["int"], true, "wait.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is the number of local variables (including parameters) used by the function, stored as a plain Python int; wait.__code__.co_nlocals is an int; int.__class__.__name__ is 'int'; NEW in extra63: first co_nlocals.__class__.__name__ check for wait in any cf spec; verified with Python 3.14.3"]
    - [as_completed_co_nlocals_class, as_completed.__code__.co_nlocals.__class__.__name__.__eq__,     ["int"], true, "as_completed.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is always an int; as_completed.__code__.co_nlocals is an int; int.__class__.__name__ is 'int'; NEW in extra63: first co_nlocals.__class__.__name__ check for as_completed in any cf spec; verified with Python 3.14.3"]
    - [future_init_co_nlocals_class,  Future.__init__.__code__.co_nlocals.__class__.__name__.__eq__,  ["int"], true, "Future.__init__.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is always an int; Future.__init__.__code__.co_nlocals is an int; int.__class__.__name__ is 'int'; NEW in extra63: first co_nlocals.__class__.__name__ check for Future.__init__ in any cf spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures __code__.co_stacksize.__class__.__name__ checks — extra63
#
# Wave 232 theme: co_stacksize type identity.
#
# co_stacksize is the required stack size (the maximum number of stack
# entries needed during execution). It is always a plain Python int.
# int.__class__.__name__ == 'int'.
# ---------------------------------------------------------------------------

table concurrent_futures_extra63.co_stacksize_class_name:
  description: "concurrent.futures __code__.co_stacksize.__class__.__name__.__eq__('int') checks in cfcode4_63 namespace — wave 232 theme: co_stacksize type identity; co_stacksize is the required stack size for code execution; wait/as_completed/Future.__init__ all have co_stacksize.__class__.__name__=='int'; NEW in extra63: no prior cf spec has checked __code__.co_stacksize.__class__.__name__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfcode4_63b

  columns: [id, function, args, expected, description]
  rows:
    - [wait_co_stacksize_class,         wait.__code__.co_stacksize.__class__.__name__.__eq__,             ["int"], true, "wait.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the required stack size (maximum number of stack entries needed during execution), stored as a plain Python int; wait.__code__.co_stacksize is an int; int.__class__.__name__ is 'int'; NEW in extra63: first co_stacksize.__class__.__name__ check for wait in any cf spec; verified with Python 3.14.3"]
    - [as_completed_co_stacksize_class, as_completed.__code__.co_stacksize.__class__.__name__.__eq__,     ["int"], true, "as_completed.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is always an int; as_completed.__code__.co_stacksize is an int; int.__class__.__name__ is 'int'; NEW in extra63: first co_stacksize.__class__.__name__ check for as_completed in any cf spec; verified with Python 3.14.3"]
    - [future_init_co_stacksize_class,  Future.__init__.__code__.co_stacksize.__class__.__name__.__eq__,  ["int"], true, "Future.__init__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is always an int; Future.__init__.__code__.co_stacksize is an int; int.__class__.__name__ is 'int'; NEW in extra63: first co_stacksize.__class__.__name__ check for Future.__init__ in any cf spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures class __doc__ content checks — extra63
#
# Wave 232 theme: class docstring type and content.
#
# Future and Executor both have non-empty docstrings. The docstring text
# mentions the class name in each case.
# Note: ThreadPoolExecutor.__doc__ is None in CPython — skipped.
# ---------------------------------------------------------------------------

table concurrent_futures_extra63.class_doc_contains:
  description: "concurrent.futures class __doc__.__class__.__name__ and __doc__.__contains__ checks in cfcode4_63 namespace — wave 232 theme: class docstring type and content; Future.__doc__ is a str containing 'Future'; Executor.__doc__ contains 'Executor'; ThreadPoolExecutor.__doc__ is None (skipped); NEW in extra63: these specific __doc__.__contains__ checks have not appeared in prior cf code-attribute specs; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfcode4_63c

  columns: [id, function, args, expected, description]
  rows:
    - [future_doc_class,    Future.__doc__.__class__.__name__.__eq__,   ["str"],      true, "Future.__doc__.__class__.__name__ == 'str' — Future has a docstring; the docstring is a plain Python str; str.__class__.__name__ is 'str'; NEW in extra63: first __doc__.__class__.__name__ check for Future in cfcode4_63 namespace; verified with Python 3.14.3"]
    - [future_doc_contains, Future.__doc__.__contains__,                ["Future"],   true, "Future.__doc__.__contains__('Future') == True — Future.__doc__ is a non-empty string describing the concurrent.futures Future class; the docstring mentions 'Future' by name; __contains__('Future') returns True; NEW in extra63: first __doc__.__contains__ check for Future in cfcode4_63 namespace; verified with Python 3.14.3"]
    - [executor_doc_contains, Executor.__doc__.__contains__,            ["Executor"], true, "Executor.__doc__.__contains__('Executor') == True — Executor.__doc__ is a non-empty string (the base class has a docstring); the docstring mentions 'Executor' by name; __contains__('Executor') returns True; NEW in extra63: first __doc__.__contains__ check for Executor in cfcode4_63 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra63
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra63.wait_co_consts_tuple:
  description: "concurrent.futures.wait.__code__.co_consts.__class__.__name__.__eq__('tuple') returns True — co_consts is a tuple of constants (literals, nested code objects, None, etc.) used by the code object; wait.__code__.co_consts is a tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra63: no prior cf spec has checked wait.__code__.co_consts.__class__.__name__ via __eq__; wave 232 first co_consts type identity invariant for wait; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: wait.__code__.co_consts.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant concurrent_futures_extra63.wait_co_nlocals_int:
  description: "concurrent.futures.wait.__code__.co_nlocals.__class__.__name__.__eq__('int') returns True — co_nlocals is the number of local variables (including parameters) used by the function, stored as a plain Python int; wait.__code__.co_nlocals is an int; int.__class__.__name__ is 'int'; NEW in extra63: no prior cf spec has checked wait.__code__.co_nlocals.__class__.__name__ via __eq__; wave 232 first co_nlocals type identity invariant for wait; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: wait.__code__.co_nlocals.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant concurrent_futures_extra63.wait_co_stacksize_int:
  description: "concurrent.futures.wait.__code__.co_stacksize.__class__.__name__.__eq__('int') returns True — co_stacksize is the required stack size (maximum number of stack entries needed during execution), stored as a plain Python int; wait.__code__.co_stacksize is an int; int.__class__.__name__ is 'int'; NEW in extra63: no prior cf spec has checked wait.__code__.co_stacksize.__class__.__name__ via __eq__; wave 232 first co_stacksize type identity invariant for wait; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: wait.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant concurrent_futures_extra63.Future_doc_Future:
  description: "concurrent.futures.Future.__doc__.__contains__('Future') returns True — Future.__doc__ is a non-empty string describing the concurrent.futures Future class; the docstring text mentions 'Future' by name; __contains__('Future') returns True; NEW in extra63: no prior cf spec has checked Future.__doc__.__contains__('Future') as a standalone invariant in the cfcode4_63 namespace; wave 232 first __doc__ content invariant for Future; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Future.__doc__.__contains__
  args: ["Future"]
  expected: true
