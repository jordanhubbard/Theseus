spec: itertools_extra63
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra62.zspec.zsdl."
    - "Wave 229 theme: __defaults__ and __kwdefaults__ checks for function parameters + __code__ attribute identity + __closure__ checks."
    - "All itertools types (groupby, chain, count, accumulate) are C extension types defined in Modules/itertoolsmodule.c. They have no __defaults__, __kwdefaults__, __code__, or __closure__ attributes. These attributes are only defined on Python function objects (PyFunctionObject), not on C extension types."
    - "Because C extension types lack these attributes, this spec focuses instead on __doc__ content checks that have not yet been covered by extra62: the module-level __doc__ contains 'Functional' (confirmed True) and 'iterators' (confirmed True); groupby.__doc__ contains 'key' (confirmed True); accumulate.__doc__ contains 'accumulate' (confirmed True) and 'function' (confirmed True) but NOT 'iterable' (confirmed False — accumulate.__doc__ is 'Return series of accumulated sums (or other binary function results).'); count.__doc__ contains 'consecutive' was covered in extra62, here we check new substrings."
    - "itertools.__doc__ contains 'Functional' (True) — the opening line is 'Functional tools for creating and using iterators.'. This was not checked in extra62."
    - "itertools.__doc__ contains 'iterators' (True) — appears in the opening line. Not checked in extra62."
    - "accumulate.__doc__ contains 'function' (True) — docstring reads 'Return series of accumulated sums (or other binary function results).'; 'function' appears in 'binary function results'. Not checked in any prior itertools spec."
    - "accumulate.__doc__ contains 'iterable' (False) — the short docstring 'Return series of accumulated sums (or other binary function results).' does NOT mention 'iterable'. Not checked in any prior itertools spec."
    - "groupby.__doc__ contains 'key' (True) — groupby's docstring has a 'key' section describing the key function parameter. Not checked in extra62."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "No prior itertools spec checks the module __doc__ for 'Functional' or 'iterators', accumulate.__doc__ content, or groupby.__doc__.__contains__('key'). All checks in this spec are new to extra63."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools module __doc__ content — extra63
#
# Wave 229 theme: __doc__ string content checks (new substrings not in extra62).
#
# itertools.__doc__ is:
#   'Functional tools for creating and using iterators.\n\nInfinite iterators:\n...'
#
# extra62 checked: __doc__.__class__.__name__ == 'str', __contains__('count'),
#   __contains__('itertools') == False.
#
# New to extra63:
#   __doc__.__contains__('Functional') == True  (opening word of opening sentence)
#   __doc__.__contains__('iterators') == True   (closing word of opening sentence)
#   __doc__.__contains__('tools') == True        (middle of opening sentence)
#
# No prior itertools spec checks these substrings in the module __doc__.
# ---------------------------------------------------------------------------

table itertools_extra63.module_doc_new_content:
  description: "itertools.__doc__.__contains__ — new substrings: 'Functional', 'iterators', 'tools'; wave 229 __doc__ content; new to extra63"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc2_63

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_contains_Functional,
       __doc__.__contains__,
       ["Functional"],
       true,
       "itertools.__doc__.__contains__('Functional') == True — itertools is a C extension module (Modules/itertoolsmodule.c); its module-level __doc__ opens with 'Functional tools for creating and using iterators.'; the word 'Functional' (capital F) is the very first word of the docstring; __contains__ on a str returns True when the substring is present; prior itertools spec extra62 checked __doc__.__contains__('count') and __doc__.__contains__('itertools') but NOT 'Functional'; new to extra63"]
    - [module_doc_contains_iterators,
       __doc__.__contains__,
       ["iterators"],
       true,
       "itertools.__doc__.__contains__('iterators') == True — itertools.__doc__ opens with 'Functional tools for creating and using iterators.'; the word 'iterators' appears at the end of the opening sentence and again in the section header 'Infinite iterators:'; __contains__ returns True; prior itertools spec extra62 did not check __doc__.__contains__('iterators'); new to extra63"]
    - [module_doc_contains_tools,
       __doc__.__contains__,
       ["tools"],
       true,
       "itertools.__doc__.__contains__('tools') == True — itertools.__doc__ opens with 'Functional tools for creating and using iterators.'; the word 'tools' appears in this opening phrase; __contains__ returns True; prior itertools spec extra62 did not check __doc__.__contains__('tools'); new to extra63"]

# ---------------------------------------------------------------------------
# groupby.__doc__.__contains__('key') — extra63
#
# Wave 229 theme: __doc__ string content checks.
#
# itertools.groupby is a C extension type. Its docstring:
#   'make an iterator that returns consecutive keys and groups from the iterable
#    \n\n  iterable\n    Elements to divide into groups according to the key
#    function.\n  key\n    A function for computing the group category...'
#
# groupby.__doc__.__contains__('key') == True
#   The word 'key' appears multiple times: 'consecutive keys', 'key function',
#   and as a parameter label in the docstring parameter section.
#
# extra62 checked groupby.__doc__.__contains__('iterable'), ('groupby'), ('iterator').
# 'key' was NOT checked in extra62. New to extra63.
# ---------------------------------------------------------------------------

table itertools_extra63.groupby_doc_key_content:
  description: "groupby.__doc__.__contains__('key') == True — groupby docstring describes the key function parameter; wave 229 __doc__ content; new to extra63"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc2_63

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_doc_contains_key,
       groupby.__doc__.__contains__,
       ["key"],
       true,
       "itertools.groupby.__doc__.__contains__('key') == True — groupby is a C extension type (Modules/itertoolsmodule.c) that groups consecutive elements by a key function; its docstring contains the word 'key' multiple times: 'consecutive keys and groups', 'key function', and as a parameter label 'key\\n    A function for computing the group category for each element.'; __contains__ on a str returns True when the substring appears anywhere; prior itertools spec extra62 checked groupby.__doc__.__contains__('iterable'), ('groupby'), and ('iterator') but NOT 'key'; new to extra63"]
    - [groupby_doc_contains_consecutive,
       groupby.__doc__.__contains__,
       ["consecutive"],
       true,
       "itertools.groupby.__doc__.__contains__('consecutive') == True — groupby.__doc__ begins 'make an iterator that returns consecutive keys and groups from the iterable'; 'consecutive' appears in this opening description; __contains__ returns True; prior itertools spec extra62 checked 'consecutive' for count.__doc__ but NOT for groupby.__doc__; new to extra63"]

# ---------------------------------------------------------------------------
# chain.__doc__.__contains__ — extra63 new substrings
#
# Wave 229 theme: __doc__ string content checks.
#
# itertools.chain is a C extension type. Its docstring:
#   'Return a chain object whose .__next__() method returns elements from the
#    first iterable until it is exhausted, then elements from the next
#    iterable, until all of the iterables are exhausted.'
#
# extra62 checked: chain.__doc__.__contains__('chain'), ('iterable').
# New substrings for extra63:
#   __contains__('exhausted') == True  (appears twice in the docstring)
#   __contains__('elements') == True   ('returns elements from the first iterable')
#
# No prior itertools spec checks 'exhausted' or 'elements' in chain.__doc__.
# ---------------------------------------------------------------------------

table itertools_extra63.chain_doc_new_content:
  description: "chain.__doc__.__contains__ — new substrings: 'exhausted', 'elements'; wave 229 __doc__ content; new to extra63"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc2_63

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_contains_exhausted,
       chain.__doc__.__contains__,
       ["exhausted"],
       true,
       "itertools.chain.__doc__.__contains__('exhausted') == True — chain is a C extension type (Modules/itertoolsmodule.c); its docstring reads 'Return a chain object whose .__next__() method returns elements from the\\nfirst iterable until it is exhausted, then elements from the next\\niterable, until all of the iterables are exhausted.'; the word 'exhausted' appears twice in the docstring; __contains__ returns True at the first occurrence; prior itertools spec extra62 checked chain.__doc__.__contains__('chain') and ('iterable') but NOT 'exhausted'; new to extra63"]
    - [chain_doc_contains_elements,
       chain.__doc__.__contains__,
       ["elements"],
       true,
       "itertools.chain.__doc__.__contains__('elements') == True — chain.__doc__ reads 'Return a chain object whose .__next__() method returns elements from the\\nfirst iterable until it is exhausted, then elements from the next\\niterable...'; 'elements' appears twice in the docstring; __contains__ returns True; prior itertools spec extra62 did not check chain.__doc__.__contains__('elements'); new to extra63"]

# ---------------------------------------------------------------------------
# accumulate.__doc__.__contains__ — extra63
#
# Wave 229 theme: __doc__ string content checks.
#
# itertools.accumulate is a C extension type. Its docstring:
#   'Return series of accumulated sums (or other binary function results).'
#
# This is a short single-sentence docstring. Key findings:
#   accumulate.__doc__.__contains__('accumulate') == True  (the type name appears)
#   accumulate.__doc__.__contains__('function') == True    ('binary function results')
#   accumulate.__doc__.__contains__('iterable') == False   (not mentioned in short doc)
#   accumulate.__doc__.__contains__('Return') == True      (opening word)
#
# No prior itertools spec checks accumulate.__doc__.__contains__. New to extra63.
# ---------------------------------------------------------------------------

table itertools_extra63.accumulate_doc_contains:
  description: "accumulate.__doc__.__contains__ checks — short docstring contains 'accumulate', 'function', 'Return' but NOT 'iterable'; wave 229 __doc__ content; new to extra63"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc2_63

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_doc_contains_accumulate,
       accumulate.__doc__.__contains__,
       ["accumulate"],
       true,
       "itertools.accumulate.__doc__.__contains__('accumulate') == True — accumulate is a C extension type (Modules/itertoolsmodule.c) that returns a running accumulation of values; its docstring is 'Return series of accumulated sums (or other binary function results).'; the word 'accumulated' contains the substring 'accumulate' so __contains__ returns True; the type name is self-referenced implicitly via 'accumulated'; no prior itertools spec checks accumulate.__doc__.__contains__; new to extra63"]
    - [accumulate_doc_contains_function,
       accumulate.__doc__.__contains__,
       ["function"],
       true,
       "itertools.accumulate.__doc__.__contains__('function') == True — accumulate.__doc__ reads 'Return series of accumulated sums (or other binary function results).'; the word 'function' appears in the phrase 'binary function results' describing the optional func parameter's role; __contains__ returns True; no prior itertools spec checks accumulate.__doc__.__contains__('function'); new to extra63"]
    - [accumulate_doc_not_contains_iterable,
       accumulate.__doc__.__contains__,
       ["iterable"],
       false,
       "itertools.accumulate.__doc__.__contains__('iterable') == False — accumulate.__doc__ is the short one-sentence string 'Return series of accumulated sums (or other binary function results).'; this concise docstring does not mention the word 'iterable' even though accumulate does accept an iterable as its first positional argument; the omission reflects a compact C docstring style; __contains__ returns False; this False result distinguishes accumulate from groupby and chain whose docstrings do mention 'iterable'; no prior itertools spec checks accumulate.__doc__.__contains__('iterable'); new to extra63"]
    - [accumulate_doc_contains_Return,
       accumulate.__doc__.__contains__,
       ["Return"],
       true,
       "itertools.accumulate.__doc__.__contains__('Return') == True — accumulate.__doc__ opens with the word 'Return' (capital R) as in 'Return series of accumulated sums...'; __contains__ is case-sensitive and 'Return' with capital R appears as the very first word; no prior itertools spec checks accumulate.__doc__.__contains__('Return'); new to extra63"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra63
# ---------------------------------------------------------------------------

invariant itertools_extra63.module_doc_contains_Functional:
  description: "itertools.__doc__.__contains__('Functional') == True — module docstring opens with 'Functional tools for creating and using iterators.'; wave 229 __doc__ content; new to extra63"
  kind: python_call_eq
  function: __doc__.__contains__
  args: ["Functional"]
  expected: true

invariant itertools_extra63.groupby_doc_contains_key:
  description: "itertools.groupby.__doc__.__contains__('key') == True — groupby docstring describes the key function parameter and uses the word 'key' multiple times; wave 229 __doc__ content; new to extra63"
  kind: python_call_eq
  function: groupby.__doc__.__contains__
  args: ["key"]
  expected: true

invariant itertools_extra63.accumulate_doc_not_contains_iterable:
  description: "itertools.accumulate.__doc__.__contains__('iterable') == False — accumulate's short C docstring does not mention 'iterable'; contrasts with groupby and chain; wave 229 __doc__ content; new to extra63"
  kind: python_call_eq
  function: accumulate.__doc__.__contains__
  args: ["iterable"]
  expected: false
