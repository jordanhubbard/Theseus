# socket module __dict__ membership checks — exception classes
#
# socket.__dict__.__contains__('gaierror') == True
# socket.__dict__.__contains__('herror')   == True
# socket.__dict__.__contains__('timeout')  == True
# ---------------------------------------------------------------------------

table socket_extra225.dict_membership_exceptions:
  description: "socket module __dict__ membership checks for exception classes in socket225c namespace — wave 225 theme: gaierror, herror, timeout are the socket exception classes; gaierror is raised by getaddrinfo/getnameinfo; herror is raised by gethostbyname/gethostbyaddr; timeout is raised when a socket operation times out; all confirmed present in socket.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: socket225c

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_gaierror, socket.__dict__.__contains__, ["gaierror"], true, "socket.__dict__.__contains__('gaierror') == True — gaierror is raised when getaddrinfo/getnameinfo fails; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]
    - [dict_has_herror,   socket.__dict__.__contains__, ["herror"],   true, "socket.__dict__.__contains__('herror') == True — herror is raised when gethostbyname/gethostbyaddr fails; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]
    - [dict_has_timeout,  socket.__dict__.__contains__, ["timeout"],  true, "socket.__dict__.__contains__('timeout') == True — timeout is raised when a socket operation times out; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants for socket __dict__ membership checks
# ---------------------------------------------------------------------------

invariant socket_extra225.dict_contains_socket:
  description: "socket.__dict__.__contains__('socket') == True — socket is the main socket class exported by the socket module; 'socket' appears as a key in socket.__dict__; socket.socket(family, type) creates a new socket object; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["socket"]
  expected: true

invariant socket_extra225.dict_contains_AF_INET:
  description: "socket.__dict__.__contains__('AF_INET') == True — AF_INET is the IPv4 address family constant used when creating IPv4 sockets; 'AF_INET' appears as a key in socket.__dict__; AF_INET is the most commonly used address family for TCP/IP networking; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["AF_INET"]
  expected: true

invariant socket_extra225.dict_contains_gaierror:
  description: "socket.__dict__.__contains__('gaierror') == True — gaierror is the exception raised when getaddrinfo() or getnameinfo() fails; 'gaierror' appears as a key in socket.__dict__; it is a subclass of OSError; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["gaierror"]
  expected: true
