table socket_extra225.dict_membership_utility_functions:
  description: "socket module __dict__ membership checks for utility functions in socket225b namespace — wave 225 theme: gethostname, gethostbyname, getaddrinfo, setdefaulttimeout, getdefaulttimeout are top-level names exported by socket; these are core networking utility functions; confirmed present in socket.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: socket225b

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_gethostname,       socket.__dict__.__contains__, ["gethostname"],       true, "socket.__dict__.__contains__('gethostname') == True — gethostname returns the current host name; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]
    - [dict_has_gethostbyname,     socket.__dict__.__contains__, ["gethostbyname"],     true, "socket.__dict__.__contains__('gethostbyname') == True — gethostbyname resolves a hostname to an IPv4 address; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]
    - [dict_has_getaddrinfo,       socket.__dict__.__contains__, ["getaddrinfo"],       true, "socket.__dict__.__contains__('getaddrinfo') == True — getaddrinfo translates host/port to socket address; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]
    - [dict_has_setdefaulttimeout, socket.__dict__.__contains__, ["setdefaulttimeout"], true, "socket.__dict__.__contains__('setdefaulttimeout') == True — setdefaulttimeout sets the default socket timeout; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]
    - [dict_has_getdefaulttimeout, socket.__dict__.__contains__, ["getdefaulttimeout"], true, "socket.__dict__.__contains__('getdefaulttimeout') == True — getdefaulttimeout returns the default socket timeout; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]

