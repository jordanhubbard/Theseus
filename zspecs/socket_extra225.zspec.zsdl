spec: socket_extra225
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 793 — Transmission Control Protocol"
  - "RFC 768 — User Datagram Protocol"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.__dict__.__contains__('socket') == True — socket class is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('AF_INET') == True — AF_INET is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('AF_INET6') == True — AF_INET6 is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('AF_UNIX') == True — AF_UNIX is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('SOCK_STREAM') == True — SOCK_STREAM is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('SOCK_DGRAM') == True — SOCK_DGRAM is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('SOCK_RAW') == True — SOCK_RAW is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('gethostname') == True — gethostname is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('gethostbyname') == True — gethostbyname is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('getaddrinfo') == True — getaddrinfo is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('setdefaulttimeout') == True — setdefaulttimeout is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('getdefaulttimeout') == True — getdefaulttimeout is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('gaierror') == True — gaierror is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('herror') == True — herror is a top-level name in socket.__dict__."
    - "socket.__dict__.__contains__('timeout') == True — timeout is a top-level name in socket.__dict__."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket module __dict__ membership checks — socket class and address families
#
# socket.__dict__.__contains__('socket')   == True
# socket.__dict__.__contains__('AF_INET')  == True
# socket.__dict__.__contains__('AF_INET6') == True
# socket.__dict__.__contains__('AF_UNIX')  == True
# ---------------------------------------------------------------------------

table socket_extra225.dict_membership_class_and_af:
  description: "socket module __dict__ membership checks for socket class and address family constants in socket225 namespace — wave 225 theme: socket, AF_INET, AF_INET6, AF_UNIX are all top-level names exported by socket; socket is the main socket class; AF_INET/AF_INET6/AF_UNIX are the primary address family constants; confirmed present in socket.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: socket225

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_socket,  socket.__dict__.__contains__, ["socket"],  true, "socket.__dict__.__contains__('socket') == True — socket is the main socket class exported as top-level name in socket.__dict__; verified with Python 3.14.3"]
    - [dict_has_AF_INET, socket.__dict__.__contains__, ["AF_INET"], true, "socket.__dict__.__contains__('AF_INET') == True — AF_INET is the IPv4 address family constant; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]
    - [dict_has_AF_INET6, socket.__dict__.__contains__, ["AF_INET6"], true, "socket.__dict__.__contains__('AF_INET6') == True — AF_INET6 is the IPv6 address family constant; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]
    - [dict_has_AF_UNIX, socket.__dict__.__contains__, ["AF_UNIX"], true, "socket.__dict__.__contains__('AF_UNIX') == True — AF_UNIX is the Unix domain socket address family constant; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket module __dict__ membership checks — socket type constants
#
# socket.__dict__.__contains__('SOCK_STREAM') == True
# socket.__dict__.__contains__('SOCK_DGRAM')  == True
# socket.__dict__.__contains__('SOCK_RAW')    == True
# ---------------------------------------------------------------------------

table socket_extra225.dict_membership_sock_types:
  description: "socket module __dict__ membership checks for socket type constants in socket225a namespace — wave 225 theme: SOCK_STREAM, SOCK_DGRAM, SOCK_RAW are the core socket type constants; SOCK_STREAM is for TCP-style reliable byte streams; SOCK_DGRAM is for UDP-style datagrams; SOCK_RAW is for raw socket access; all confirmed present in socket.__dict__; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: socket225a

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_SOCK_STREAM, socket.__dict__.__contains__, ["SOCK_STREAM"], true, "socket.__dict__.__contains__('SOCK_STREAM') == True — SOCK_STREAM is the TCP stream socket type constant; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]
    - [dict_has_SOCK_DGRAM,  socket.__dict__.__contains__, ["SOCK_DGRAM"],  true, "socket.__dict__.__contains__('SOCK_DGRAM') == True — SOCK_DGRAM is the UDP datagram socket type constant; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]
    - [dict_has_SOCK_RAW,    socket.__dict__.__contains__, ["SOCK_RAW"],    true, "socket.__dict__.__contains__('SOCK_RAW') == True — SOCK_RAW is the raw socket type constant; exported as top-level name in socket.__dict__; verified with Python 3.14.3"]

