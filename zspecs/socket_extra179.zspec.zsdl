spec: socket_extra179
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "This spec covers: socket.AddressFamily enum class identity — socket.AddressFamily.__name__=='AddressFamily' (len=13); socket.AddressFamily.__module__=='socket'; socket.AddressFamily.__bases__[0].__name__=='IntEnum' (AddressFamily is an IntEnum); socket.SocketKind.__name__=='SocketKind' (len=10); socket.SocketKind.__bases__[0].__name__=='IntEnum'; socket.AF_INET.__class__.__name__=='AddressFamily'; socket.SOCK_STREAM.__class__.__name__=='SocketKind'; socket.SOCK_DGRAM.__class__.__name__=='SocketKind'."
    - "socket.AddressFamily is an IntEnum (subclass of both int and enum.Enum) introduced in Python 3.4 to give address-family constants symbolic names. AF_INET, AF_INET6, AF_UNIX etc. are members."
    - "socket.SocketKind is an IntEnum for socket-type constants. SOCK_STREAM, SOCK_DGRAM, SOCK_RAW etc. are members."
    - "AddressFamily.__name__ == 'AddressFamily' has 13 characters: A-d-d-r-e-s-s-F-a-m-i-l-y."
    - "SocketKind.__name__ == 'SocketKind' has 10 characters: S-o-c-k-e-t-K-i-n-d."
    - "Both AddressFamily and SocketKind directly subclass IntEnum; __bases__[0].__name__ == 'IntEnum'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.AddressFamily class name and module identity
#
# socket.AddressFamily.__name__ == 'AddressFamily' (len 13)
# socket.AddressFamily.__module__ == 'socket'
# socket.AddressFamily.__name__.__eq__('AddressFamily') == True
# socket.AddressFamily.__module__.__eq__('socket') == True
#
# AddressFamily is an IntEnum class defined in Lib/socket.py that provides
# symbolic names for address-family integer constants.  Its __module__ is
# 'socket' (the Python wrapper module, not the C extension).
# New to extra179.
# ---------------------------------------------------------------------------

table socket_extra179.address_family_name_and_module:
  description: "AddressFamily.__name__=='AddressFamily' (len=13); __module__=='socket'; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: socketenums179

  columns: [id, function, args, expected, description]
  rows:
    - [af_name_eq,
       "AddressFamily.__name__.__eq__",
       ["AddressFamily"],
       true,
       "socket.AddressFamily.__name__.__eq__('AddressFamily') == True — AddressFamily is the IntEnum class for address-family constants defined in Lib/socket.py; its __name__ is 'AddressFamily'; str.__eq__('AddressFamily') returns True; new to extra179"]
    - [af_name_len_13,
       "AddressFamily.__name__.__len__",
       [],
       13,
       "socket.AddressFamily.__name__.__len__() == 13 — 'AddressFamily' has 13 characters (A-d-d-r-e-s-s-F-a-m-i-l-y); str.__len__() returns 13; new to extra179"]
    - [af_module_eq_socket,
       "AddressFamily.__module__.__eq__",
       ["socket"],
       true,
       "socket.AddressFamily.__module__.__eq__('socket') == True — AddressFamily is defined in Lib/socket.py; its __module__ attribute is 'socket'; str.__eq__('socket') returns True; new to extra179"]
    - [af_module_not_builtins,
       "AddressFamily.__module__.__eq__",
       ["builtins"],
       false,
       "socket.AddressFamily.__module__.__eq__('builtins') == False — AddressFamily is defined in Lib/socket.py, not in builtins; its __module__ is 'socket'; str.__eq__('builtins') returns False; new to extra179"]

# ---------------------------------------------------------------------------
# Table 2: socket.AddressFamily and socket.SocketKind base class identity
#
# socket.AddressFamily.__bases__[0].__name__ == 'IntEnum'
# socket.SocketKind.__bases__[0].__name__ == 'IntEnum'
# socket.SocketKind.__name__ == 'SocketKind' (len 10)
# socket.SocketKind.__module__ == 'socket'
#
# Both AddressFamily and SocketKind directly subclass enum.IntEnum.
# IntEnum itself subclasses both int and enum.Enum, so members of these
# classes are simultaneously ints and enum members.  New to extra179.
# ---------------------------------------------------------------------------

table socket_extra179.enum_bases_intenum:
  description: "AddressFamily.__bases__[0].__name__=='IntEnum'; SocketKind.__bases__[0].__name__=='IntEnum'; SocketKind name len=10; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: socketenums179

  columns: [id, function, args, expected, description]
  rows:
    - [af_bases0_intenum,
       "AddressFamily.__bases__[0].__name__.__eq__",
       ["IntEnum"],
       true,
       "socket.AddressFamily.__bases__[0].__name__.__eq__('IntEnum') == True — AddressFamily is defined as 'class AddressFamily(IntEnum)' in Lib/socket.py; its first direct base class is IntEnum; __bases__[0].__name__ is 'IntEnum'; str.__eq__('IntEnum') returns True; new to extra179"]
    - [sk_bases0_intenum,
       "SocketKind.__bases__[0].__name__.__eq__",
       ["IntEnum"],
       true,
       "socket.SocketKind.__bases__[0].__name__.__eq__('IntEnum') == True — SocketKind is defined as 'class SocketKind(IntEnum)' in Lib/socket.py; its first direct base class is IntEnum; __bases__[0].__name__ is 'IntEnum'; str.__eq__('IntEnum') returns True; new to extra179"]
    - [sk_name_eq,
       "SocketKind.__name__.__eq__",
       ["SocketKind"],
       true,
       "socket.SocketKind.__name__.__eq__('SocketKind') == True — SocketKind is the IntEnum class for socket-type constants defined in Lib/socket.py; its __name__ is 'SocketKind'; str.__eq__('SocketKind') returns True; new to extra179"]
    - [sk_name_len_10,
       "SocketKind.__name__.__len__",
       [],
       10,
       "socket.SocketKind.__name__.__len__() == 10 — 'SocketKind' has 10 characters (S-o-c-k-e-t-K-i-n-d); str.__len__() returns 10; new to extra179"]
    - [sk_module_eq_socket,
       "SocketKind.__module__.__eq__",
       ["socket"],
       true,
       "socket.SocketKind.__module__.__eq__('socket') == True — SocketKind is defined in Lib/socket.py; its __module__ attribute is 'socket'; str.__eq__('socket') returns True; new to extra179"]

# ---------------------------------------------------------------------------
# Table 3: AF_INET, SOCK_STREAM, SOCK_DGRAM enum member class identity
#
# socket.AF_INET.__class__.__name__ == 'AddressFamily'
# socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'
# socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind'
# socket.AF_INET.__class__.__name__ != 'int'
#
# AF_INET, SOCK_STREAM, and SOCK_DGRAM are members of their respective IntEnum
# classes.  Their __class__ is the IntEnum subclass (AddressFamily or SocketKind),
# not 'int', even though IntEnum members compare equal to ints.
# New to extra179.
# ---------------------------------------------------------------------------

table socket_extra179.enum_member_class_identity:
  description: "AF_INET.__class__.__name__=='AddressFamily'; SOCK_STREAM and SOCK_DGRAM __class__.__name__=='SocketKind'; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: socketenums179

  columns: [id, function, args, expected, description]
  rows:
    - [af_inet_class_address_family,
       "AF_INET.__class__.__name__.__eq__",
       ["AddressFamily"],
       true,
       "socket.AF_INET.__class__.__name__.__eq__('AddressFamily') == True — AF_INET is a member of the AddressFamily IntEnum; its __class__.__name__ is 'AddressFamily', not 'int'; str.__eq__('AddressFamily') returns True; new to extra179"]
    - [sock_stream_class_socketkind,
       "SOCK_STREAM.__class__.__name__.__eq__",
       ["SocketKind"],
       true,
       "socket.SOCK_STREAM.__class__.__name__.__eq__('SocketKind') == True — SOCK_STREAM is a member of the SocketKind IntEnum; its __class__.__name__ is 'SocketKind', not 'int'; str.__eq__('SocketKind') returns True; new to extra179"]
    - [sock_dgram_class_socketkind,
       "SOCK_DGRAM.__class__.__name__.__eq__",
       ["SocketKind"],
       true,
       "socket.SOCK_DGRAM.__class__.__name__.__eq__('SocketKind') == True — SOCK_DGRAM is a member of the SocketKind IntEnum; its __class__.__name__ is 'SocketKind', not 'int'; str.__eq__('SocketKind') returns True; new to extra179"]
    - [af_inet_class_not_int,
       "AF_INET.__class__.__name__.__eq__",
       ["int"],
       false,
       "socket.AF_INET.__class__.__name__.__eq__('int') == False — AF_INET is an AddressFamily member, not a plain int; although IntEnum members compare equal to ints, their __class__ is AddressFamily, not int; str.__eq__('int') returns False; new to extra179"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra179
# ---------------------------------------------------------------------------

invariant socket_extra179.af_name_eq_address_family:
  description: "socket.AddressFamily.__name__ == 'AddressFamily' — the IntEnum class for address-family constants; new to extra179"
  kind: python_call_eq
  function: AddressFamily.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra179.af_name_len_13:
  description: "socket.AddressFamily.__name__.__len__() == 13 — 'AddressFamily' is a 13-character string; new to extra179"
  kind: python_call_eq
  function: AddressFamily.__name__.__len__
  args: []
  expected: 13

invariant socket_extra179.af_module_socket:
  description: "socket.AddressFamily.__module__ == 'socket' — AddressFamily is defined in Lib/socket.py; new to extra179"
  kind: python_call_eq
  function: AddressFamily.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra179.af_bases0_intenum:
  description: "socket.AddressFamily.__bases__[0].__name__ == 'IntEnum' — AddressFamily directly subclasses IntEnum; new to extra179"
  kind: python_call_eq
  function: "AddressFamily.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true

invariant socket_extra179.sk_name_len_10:
  description: "socket.SocketKind.__name__.__len__() == 10 — 'SocketKind' is a 10-character string; new to extra179"
  kind: python_call_eq
  function: SocketKind.__name__.__len__
  args: []
  expected: 10

invariant socket_extra179.sk_bases0_intenum:
  description: "socket.SocketKind.__bases__[0].__name__ == 'IntEnum' — SocketKind directly subclasses IntEnum; new to extra179"
  kind: python_call_eq
  function: "SocketKind.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true

invariant socket_extra179.af_inet_class_address_family:
  description: "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an AddressFamily member, not a plain int; new to extra179"
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra179.sock_stream_class_socketkind:
  description: "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is a SocketKind member, not a plain int; new to extra179"
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true

invariant socket_extra179.sock_dgram_class_socketkind:
  description: "socket.SOCK_DGRAM.__class__.__name__ == 'SocketKind' — SOCK_DGRAM is a SocketKind member, not a plain int; new to extra179"
  kind: python_call_eq
  function: SOCK_DGRAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true
