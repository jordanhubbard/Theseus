spec: abc_extra120
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: wave 256 theme — abc module public symbol __name__, __qualname__, __module__, and __mro__ identity. NEW in extra120: abc.ABC.__name__=='ABC' (len=3); abc.ABC.__class__.__name__=='ABCMeta' (not 'type'; ABC is an instance of ABCMeta); abc.ABC.__mro__.__len__()==2 ([ABC, object]); abc.ABC.__bases__[0].__name__=='object'; abc.ABCMeta.__name__=='ABCMeta' (len=7); abc.ABCMeta.__class__.__name__=='type'; abc.ABCMeta.__mro__.__len__()==3 ([ABCMeta, type, object]); abc.ABCMeta.__bases__[0].__name__=='type'; abc.abstractmethod.__name__=='abstractmethod' (len=14); abc.abstractmethod.__class__.__name__=='function'; abc.abstractproperty.__name__=='abstractproperty' (len=16); abc.abstractproperty.__mro__.__len__()==3 ([abstractproperty, property, object]); abc.abstractproperty.__bases__[0].__name__=='property'; abc.get_cache_token.__name__=='get_cache_token' (len=15); abc.get_cache_token.__class__.__name__=='builtin_function_or_method'; abc.update_abstractmethods.__name__=='update_abstractmethods' (len=22, longest); abc.update_abstractmethods.__code__.co_argcount==1; abc.update_abstractmethods.__code__.co_varnames.__len__()==5. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__class__.__name__ == 'ABCMeta'. ABC is an instance of ABCMeta (not of type directly); its metaclass is ABCMeta rather than the default 'type' because ABC is defined with 'class ABC(metaclass=ABCMeta): pass'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__mro__.__len__() == 3. ABCMeta's MRO is [ABCMeta, type, object]: ABCMeta inherits from type (since ABCMeta is a metaclass extending type). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractproperty.__bases__[0].__name__ == 'property'. abstractproperty inherits from the built-in property descriptor, making it a subclass of property. abstractproperty is deprecated since Python 3.3 in favor of using abstractmethod with property. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method'. get_cache_token is implemented as a C-level function in Modules/_abc.c (not in Lib/abc.py), hence its class is 'builtin_function_or_method'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.update_abstractmethods.__name__.__len__() == 22. 'update_abstractmethods' is 22 chars: 'update'=6+'_'=1+'abstract'=8+'methods'=7=22, the longest symbol name in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC and abc.ABCMeta class identity — extra120
#
# Wave 256 theme: abc module public symbol __name__, __qualname__, __module__,
#                 and __mro__ identity.
#
# abc.ABC.__name__              == 'ABC'     (len=3)
# abc.ABC.__class__.__name__    == 'ABCMeta' (metaclass is ABCMeta, not type)
# abc.ABC.__mro__.__len__()     == 2         ([ABC, object])
# abc.ABC.__bases__[0].__name__ == 'object'
# abc.ABCMeta.__name__          == 'ABCMeta' (len=7)
# abc.ABCMeta.__class__.__name__== 'type'
# abc.ABCMeta.__mro__.__len__() == 3         ([ABCMeta, type, object])
# abc.ABCMeta.__bases__[0].__name__ == 'type'
# ---------------------------------------------------------------------------

table abc_extra120.abc_ABC_ABCMeta_identity:
  description: "abc.ABC and abc.ABCMeta class identity checks in abcpubsym120 namespace — wave 256 theme: abc.ABC.__name__.__eq__('ABC')==True (len=3: 'ABC'=3, the shortest symbol name in this spec); abc.ABC.__name__.__len__()==3; abc.ABC.__class__.__name__.__eq__('ABCMeta')==True (ABC is an instance of ABCMeta, not of type — its metaclass is ABCMeta because ABC is defined as 'class ABC(metaclass=ABCMeta): pass'; this contrasts with ordinary classes whose metaclass is 'type'); abc.ABC.__module__.__eq__('abc')==True; abc.ABC.__mro__.__len__()==2 ([ABC, object]: minimal 2-element MRO, ABC directly extends object); abc.ABC.__bases__[0].__name__.__eq__('object')==True (direct subclass of object); abc.ABCMeta.__name__.__eq__('ABCMeta')==True (len=7: 'ABCMeta'=7); abc.ABCMeta.__name__.__len__()==7; abc.ABCMeta.__class__.__name__.__eq__('type')==True (ABCMeta is a class with metaclass 'type'; ABCMeta is itself a metaclass but its own class is 'type'); abc.ABCMeta.__module__.__eq__('abc')==True; abc.ABCMeta.__mro__.__len__()==3 ([ABCMeta, type, object]: ABCMeta inherits from type, which adds type between ABCMeta and object); abc.ABCMeta.__bases__[0].__name__.__eq__('type')==True (direct subclass of type, making ABCMeta a metaclass that extends type's functionality); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcpubsym120

  columns: [id, function, args, expected, description]
  rows:
    - [abc_nm_eq,     abc.ABC.__name__.__eq__,                         ["ABC"],     true, "abc.ABC.__name__ == 'ABC' (len=3, shortest symbol name in spec); verified with Python 3.14.3"]
    - [abc_nm_len,    abc.ABC.__name__.__len__,                        [],          3,    "abc.ABC.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [abc_meta_eq,   abc.ABC.__class__.__name__.__eq__,               ["ABCMeta"], true, "abc.ABC.__class__.__name__ == 'ABCMeta' (metaclass is ABCMeta, not type); verified with Python 3.14.3"]
    - [abc_mod_eq,    abc.ABC.__module__.__eq__,                       ["abc"],     true, "abc.ABC.__module__ == 'abc'; verified with Python 3.14.3"]
    - [abc_mro_len,   abc.ABC.__mro__.__len__,                         [],          2,    "abc.ABC.__mro__.__len__() == 2 ([ABC, object]); verified with Python 3.14.3"]
    - [abc_base0,     "abc.ABC.__bases__[0].__name__.__eq__",           ["object"],  true, "abc.ABC.__bases__[0].__name__ == 'object' (direct subclass of object); verified with Python 3.14.3"]
    - [meta_nm_eq,    abc.ABCMeta.__name__.__eq__,                     ["ABCMeta"], true, "abc.ABCMeta.__name__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [meta_nm_len,   abc.ABCMeta.__name__.__len__,                    [],          7,    "abc.ABCMeta.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [meta_cls_eq,   abc.ABCMeta.__class__.__name__.__eq__,           ["type"],    true, "abc.ABCMeta.__class__.__name__ == 'type' (ABCMeta itself has metaclass type); verified with Python 3.14.3"]
    - [meta_mro_len,  abc.ABCMeta.__mro__.__len__,                     [],          3,    "abc.ABCMeta.__mro__.__len__() == 3 ([ABCMeta, type, object]); verified with Python 3.14.3"]
    - [meta_base0,    "abc.ABCMeta.__bases__[0].__name__.__eq__",       ["type"],    true, "abc.ABCMeta.__bases__[0].__name__ == 'type' (ABCMeta extends type, making it a metaclass); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod and abc.abstractproperty identity — extra120
#
# abstractmethod.__name__              == 'abstractmethod'   (len=14)
# abstractmethod.__qualname__          == 'abstractmethod'   (len=14)
# abstractmethod.__class__.__name__    == 'function'
# abstractmethod.__module__            == 'abc'
# abstractproperty.__name__            == 'abstractproperty' (len=16)
# abstractproperty.__class__.__name__  == 'type'
# abstractproperty.__mro__.__len__()   == 3
# abstractproperty.__bases__[0].__name__== 'property'
# ---------------------------------------------------------------------------

table abc_extra120.abc_abstractmethod_abstractproperty_identity:
  description: "abc.abstractmethod and abc.abstractproperty identity checks in abcpubsym120 namespace — wave 256 theme: abstractmethod.__name__.__eq__('abstractmethod')==True (len=14: 'abstract'=8+'method'=6=14); abstractmethod.__name__.__len__()==14; abstractmethod.__qualname__.__eq__('abstractmethod')==True (len=14, same as name; qualname equals name for module-level functions); abstractmethod.__class__.__name__.__eq__('function')==True (abstractmethod is a Python function defined in Lib/abc.py); abstractmethod.__module__.__eq__('abc')==True; abstractmethod.__code__.co_name.__eq__('abstractmethod')==True (co_name matches function name); abstractmethod.__code__.co_argcount.__eq__(1)==True (single parameter: funcobj); abstractproperty.__name__.__eq__('abstractproperty')==True (len=16: 'abstract'=8+'property'=8=16, two chars longer than abstractmethod); abstractproperty.__name__.__len__()==16; abstractproperty.__class__.__name__.__eq__('type')==True (abstractproperty is a class, not a function — it inherits from property); abstractproperty.__module__.__eq__('abc')==True; abstractproperty.__mro__.__len__()==3 ([abstractproperty, property, object]: inherits from built-in property descriptor); abstractproperty.__bases__[0].__name__.__eq__('property')==True (direct subclass of property; deprecated since Python 3.3); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcpubsym120a

  columns: [id, function, args, expected, description]
  rows:
    - [am_nm_eq,    abc.abstractmethod.__name__.__eq__,                    ["abstractmethod"],   true, "abc.abstractmethod.__name__ == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [am_nm_len,   abc.abstractmethod.__name__.__len__,                   [],                  14,   "abc.abstractmethod.__name__.__len__() == 14 ('abstract'=8+'method'=6=14); verified with Python 3.14.3"]
    - [am_qn_eq,    abc.abstractmethod.__qualname__.__eq__,                ["abstractmethod"],   true, "abc.abstractmethod.__qualname__ == 'abstractmethod' (len=14, qualname equals name); verified with Python 3.14.3"]
    - [am_cls_eq,   abc.abstractmethod.__class__.__name__.__eq__,          ["function"],         true, "abc.abstractmethod.__class__.__name__ == 'function' (Python decorator defined in abc.py); verified with Python 3.14.3"]
    - [am_mod_eq,   abc.abstractmethod.__module__.__eq__,                  ["abc"],              true, "abc.abstractmethod.__module__ == 'abc'; verified with Python 3.14.3"]
    - [am_argc,     abc.abstractmethod.__code__.co_argcount.__eq__,        [1],                  true, "abc.abstractmethod.__code__.co_argcount == 1 (single parameter: funcobj); verified with Python 3.14.3"]
    - [ap_nm_eq,    abc.abstractproperty.__name__.__eq__,                  ["abstractproperty"],  true, "abc.abstractproperty.__name__ == 'abstractproperty' (len=16); verified with Python 3.14.3"]
    - [ap_nm_len,   abc.abstractproperty.__name__.__len__,                 [],                   16,   "abc.abstractproperty.__name__.__len__() == 16 ('abstract'=8+'property'=8=16); verified with Python 3.14.3"]
    - [ap_cls_eq,   abc.abstractproperty.__class__.__name__.__eq__,        ["type"],              true, "abc.abstractproperty.__class__.__name__ == 'type' (a class, not a function, inherits from property); verified with Python 3.14.3"]
    - [ap_mro_len,  abc.abstractproperty.__mro__.__len__,                  [],                   3,    "abc.abstractproperty.__mro__.__len__() == 3 ([abstractproperty, property, object]); verified with Python 3.14.3"]
    - [ap_base0,    "abc.abstractproperty.__bases__[0].__name__.__eq__",    ["property"],          true, "abc.abstractproperty.__bases__[0].__name__ == 'property' (direct subclass of built-in property); verified with Python 3.14.3"]

