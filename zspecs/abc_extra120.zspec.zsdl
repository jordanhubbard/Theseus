# get_cache_token.__class__.__name__         == 'builtin_function_or_method'
# update_abstractmethods.__name__            == 'update_abstractmethods' (len=22, longest)
# update_abstractmethods.__class__.__name__  == 'function'
# update_abstractmethods.__code__.co_argcount == 1
# update_abstractmethods.__code__.co_varnames[0] == 'cls'
# update_abstractmethods.__code__.co_varnames.__len__() == 5
# ---------------------------------------------------------------------------

table abc_extra120.abc_get_cache_token_update_abstractmethods_identity:
  description: "abc.get_cache_token and abc.update_abstractmethods identity checks in abcpubsym120 namespace — wave 256 theme: get_cache_token.__name__.__eq__('get_cache_token')==True (len=15: 'get'=3+'_cache_'=7+'token'=5=15); get_cache_token.__name__.__len__()==15; get_cache_token.__qualname__.__eq__('get_cache_token')==True (len=15, qualname equals name); get_cache_token.__class__.__name__.__eq__('builtin_function_or_method')==True (get_cache_token is implemented in C in Modules/_abc.c, unlike abstractmethod which is Python-defined); this is the only 'builtin_function_or_method' among the non-class public abc symbols (abstractmethod and update_abstractmethods are 'function'); update_abstractmethods.__name__.__eq__('update_abstractmethods')==True (len=22: 'update'=6+'_'=1+'abstract'=8+'methods'=7=22, the longest symbol name in this spec); update_abstractmethods.__name__.__len__()==22; update_abstractmethods.__qualname__.__eq__('update_abstractmethods')==True (len=22); update_abstractmethods.__class__.__name__.__eq__('function')==True (Python-defined in Lib/abc.py, added in Python 3.10); update_abstractmethods.__module__.__eq__('abc')==True; update_abstractmethods.__code__.co_argcount.__eq__(1)==True (one positional param: cls); update_abstractmethods.__code__.co_varnames.__getitem__(0).__eq__('cls')==True; update_abstractmethods.__code__.co_varnames.__len__()==5 (5 varnames: cls, abstracts, scls, name, value; 1 param + 4 locals); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcpubsym120b

  columns: [id, function, args, expected, description]
  rows:
    - [gct_nm_eq,    abc.get_cache_token.__name__.__eq__,                                ["get_cache_token"],        true, "abc.get_cache_token.__name__ == 'get_cache_token' (len=15); verified with Python 3.14.3"]
    - [gct_nm_len,   abc.get_cache_token.__name__.__len__,                               [],                        15,   "abc.get_cache_token.__name__.__len__() == 15 ('get_cache_token'=15); verified with Python 3.14.3"]
    - [gct_qn_eq,    abc.get_cache_token.__qualname__.__eq__,                            ["get_cache_token"],        true, "abc.get_cache_token.__qualname__ == 'get_cache_token' (len=15, qualname equals name); verified with Python 3.14.3"]
    - [gct_cls_eq,   abc.get_cache_token.__class__.__name__.__eq__,                     ["builtin_function_or_method"], true, "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' (C-level, from _abc.c); verified with Python 3.14.3"]
    - [uam_nm_eq,    abc.update_abstractmethods.__name__.__eq__,                         ["update_abstractmethods"], true, "abc.update_abstractmethods.__name__ == 'update_abstractmethods' (len=22, longest in spec); verified with Python 3.14.3"]
    - [uam_nm_len,   abc.update_abstractmethods.__name__.__len__,                        [],                        22,   "abc.update_abstractmethods.__name__.__len__() == 22 ('update_abstractmethods'=22, longest); verified with Python 3.14.3"]
    - [uam_cls_eq,   abc.update_abstractmethods.__class__.__name__.__eq__,               ["function"],               true, "abc.update_abstractmethods.__class__.__name__ == 'function' (Python-defined in abc.py); verified with Python 3.14.3"]
    - [uam_mod_eq,   abc.update_abstractmethods.__module__.__eq__,                       ["abc"],                    true, "abc.update_abstractmethods.__module__ == 'abc'; verified with Python 3.14.3"]
    - [uam_argc,     abc.update_abstractmethods.__code__.co_argcount.__eq__,             [1],                        true, "abc.update_abstractmethods.__code__.co_argcount == 1 (one positional param: cls); verified with Python 3.14.3"]
    - [uam_var0,     abc.update_abstractmethods.__code__.co_varnames.__getitem__,        [0],                        "cls", "abc.update_abstractmethods.__code__.co_varnames[0] == 'cls'; verified with Python 3.14.3"]
    - [uam_varlen,   abc.update_abstractmethods.__code__.co_varnames.__len__,            [],                        5,    "abc.update_abstractmethods.__code__.co_varnames.__len__() == 5 (1 param + 4 locals); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra120
# ---------------------------------------------------------------------------

invariant abc_extra120.ABC_class_is_ABCMeta:
  description: "abc.ABC.__class__.__name__.__eq__('ABCMeta') returns True — abc.ABC is an instance of ABCMeta (its metaclass is ABCMeta, not the default 'type'); this is because ABC is defined as 'class ABC(metaclass=ABCMeta): pass' in Lib/abc.py; abc.ABC.__class__.__name__ is 'ABCMeta' while abc.ABCMeta.__class__.__name__ is 'type' (ABCMeta itself has the default metaclass 'type'); abc.ABC.__name__ is 'ABC' (len=3, the shortest name in this spec); abc.ABC.__mro__.__len__() is 2 ([ABC, object]); abc.ABC.__bases__[0].__name__ is 'object'; abc.ABC.__module__ is 'abc'; NEW in extra120: first standalone ABC metaclass identity invariant in abcpubsym120 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__class__.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra120.ABCMeta_mro_len_3:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — ABCMeta.__mro__ is [ABCMeta, type, object] (3 elements); ABCMeta inherits from type (making it a metaclass that extends type's class-creation protocol); compare with abc.ABC.__mro__.__len__()==2 ([ABC, object]) — ABC has the minimal MRO while ABCMeta has one more level; compare with abc.abstractproperty.__mro__.__len__()==3 ([abstractproperty, property, object]) — both ABCMeta and abstractproperty have 3-element MROs but for different reasons (ABCMeta extends type; abstractproperty extends property); ABCMeta.__bases__[0].__name__ is 'type'; ABCMeta.__class__.__name__ is 'type'; ABCMeta.__name__ is 'ABCMeta' (len=7); NEW in extra120: first standalone ABCMeta MRO length invariant in abcpubsym120 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra120.get_cache_token_is_builtin:
  description: "abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') returns True — abc.get_cache_token is implemented as a C-level function in Modules/_abc.c (not in Lib/abc.py); its class is 'builtin_function_or_method', unlike abc.abstractmethod and abc.update_abstractmethods which are Python 'function' class; get_cache_token.__name__ is 'get_cache_token' (len=15); get_cache_token.__qualname__ is 'get_cache_token' (len=15); get_cache_token() returns an opaque token representing the current version of the ABC cache — each call to register() invalidates the cache and increments the token; NEW in extra120: first standalone get_cache_token builtin class invariant in abcpubsym120 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra120.update_abstractmethods_name_len_22:
  description: "abc.update_abstractmethods.__name__.__len__() == 22 — update_abstractmethods.__name__ is 'update_abstractmethods' (22 chars: 'update'=6+'_abstract_methods'=16=22); this is the longest symbol name in this spec; compare name lengths: ABC=3, ABCMeta=7, abstractmethod=14, get_cache_token=15, abstractproperty=16, update_abstractmethods=22; update_abstractmethods was added in Python 3.10 to recalculate the set of abstract methods after modification of a class; it is Python-defined (class='function') with one parameter (cls) and 5 co_varnames total (cls plus 4 local variables); abc.update_abstractmethods.__qualname__.__len__() is also 22; NEW in extra120: first standalone update_abstractmethods name length invariant in abcpubsym120 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__name__.__len__
  args: []
  expected: 22

invariant abc_extra120.abstractproperty_base_is_property:
  description: "abc.abstractproperty.__bases__[0].__name__.__eq__('property') returns True — abc.abstractproperty is a class that inherits from the built-in 'property' descriptor; abstractproperty.__mro__ is [abstractproperty, property, object] (length=3); abstractproperty is deprecated since Python 3.3 in favor of combining @property and @abstractmethod decorators; abstractproperty.__class__.__name__ is 'type' (it is a class, unlike abstractmethod which is a function); abstractproperty.__name__ is 'abstractproperty' (len=16); abstractproperty.__module__ is 'abc'; compare: abc.ABC extends object (bases[0]='object'), abc.ABCMeta extends type (bases[0]='type'), abc.abstractproperty extends property (bases[0]='property'); NEW in extra120: first standalone abstractproperty base class invariant in abcpubsym120 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "abc.abstractproperty.__bases__[0].__name__.__eq__"
  args: ["property"]
  expected: true

