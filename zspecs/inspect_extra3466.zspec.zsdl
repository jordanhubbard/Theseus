spec: in3466
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 678 (in3466): __iter__, __next__, __len__ dict-presence checks for inspect types."
    - "All values False — inspect introspection types have no custom iter/next/len in their own __dict__."
    - "None of the inspect types define __iter__, __next__, or __len__ in their own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "None of these types implement iterator or sizing protocols directly in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3466.iter:
  description: "inspect types __iter__ dict-presence checks; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3466
  columns: [id, function, args, expected]
  rows:
    - ["in3466001", operator.contains, [inspect.Parameter.__dict__,           "__iter__"], false]
    - ["in3466002", operator.contains, [inspect.Signature.__dict__,           "__iter__"], false]
    - ["in3466003", operator.contains, [inspect.BoundArguments.__dict__,      "__iter__"], false]
    - ["in3466004", operator.contains, [inspect.FrameInfo.__dict__,           "__iter__"], false]
    - ["in3466005", operator.contains, [inspect.ArgInfo.__dict__,             "__iter__"], false]
    - ["in3466006", operator.contains, [inspect.FullArgSpec.__dict__,         "__iter__"], false]
    - ["in3466007", operator.contains, [inspect.Attribute.__dict__,           "__iter__"], false]
    - ["in3466008", operator.contains, [inspect.ClassFoundException.__dict__, "__iter__"], false]
    - ["in3466009", operator.contains, [inspect.EndOfBlock.__dict__,          "__iter__"], false]

