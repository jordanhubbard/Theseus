spec: inspect_extra1321
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 535 (_extra1321): focuses on __repr__ and __str__ output class checks for inspect pure-Python classes."
    - "inspect.Parameter defines both __repr__ and __str__ as Python functions; both have class name 'function'."
    - "inspect.Parameter.__repr__.__qualname__ == 'Parameter.__repr__' — defined in the class body."
    - "inspect.Parameter.__str__.__qualname__ == 'Parameter.__str__' — defined in the class body."
    - "inspect.Signature defines both __repr__ and __str__ as Python functions."
    - "inspect.Signature.__repr__.__qualname__ == 'Signature.__repr__' — defined in the class body."
    - "inspect.Signature.__str__.__qualname__ == 'Signature.__str__' — defined in the class body."
    - "inspect.BoundArguments defines __repr__ as a Python function but inherits __str__ from object."
    - "inspect.BoundArguments.__repr__.__qualname__ == 'BoundArguments.__repr__' — defined in the class body."
    - "inspect.BoundArguments.__str__.__qualname__ == 'object.__str__' — inherited from object, not overridden."
    - "repr(inspect.Parameter).__class__.__name__ == 'str' — repr of any class object is always a str."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra1321.parameter_repr_str_checks:
  description: "inspect.Parameter __repr__ and __str__ class name and qualname; Parameter defines both as Python functions"
  kind: python_call_eq
  category: repr_str_class_checks
  id_prefix: in1321pa
  columns: [id, function, args, expected]
  rows:
    - [in1321pa001, inspect.Parameter.__repr__.__class__.__name__.__eq__,  ["function"],           true]
    - [in1321pa002, inspect.Parameter.__repr__.__qualname__.__eq__,        ["Parameter.__repr__"], true]
    - [in1321pa003, inspect.Parameter.__str__.__class__.__name__.__eq__,   ["function"],           true]
    - [in1321pa004, inspect.Parameter.__str__.__qualname__.__eq__,         ["Parameter.__str__"],  true]
    - [in1321pa005, repr(inspect.Parameter).__class__.__name__.__eq__,     ["str"],                true]
    - [in1321pa006, repr(inspect.Signature).__class__.__name__.__eq__,     ["str"],                true]

table inspect_extra1321.signature_repr_str_checks:
  description: "inspect.Signature __repr__ and __str__ class name and qualname; Signature defines both as Python functions"
  kind: python_call_eq
  category: repr_str_class_checks
  id_prefix: in1321si
  columns: [id, function, args, expected]
  rows:
    - [in1321si001, inspect.Signature.__repr__.__class__.__name__.__eq__,  ["function"],           true]
    - [in1321si002, inspect.Signature.__repr__.__qualname__.__eq__,        ["Signature.__repr__"], true]
    - [in1321si003, inspect.Signature.__str__.__class__.__name__.__eq__,   ["function"],           true]
    - [in1321si004, inspect.Signature.__str__.__qualname__.__eq__,         ["Signature.__str__"],  true]
    - [in1321si005, repr(inspect.BoundArguments).__class__.__name__.__eq__, ["str"],               true]
    - [in1321si006, inspect.Signature.__repr__.__class__.__name__.__eq__,  ["function"],           true]

table inspect_extra1321.boundarguments_repr_str_checks:
  description: "inspect.BoundArguments __repr__ and __str__ class name and qualname; defines __repr__ but inherits __str__ from object"
  kind: python_call_eq
  category: repr_str_class_checks
  id_prefix: in1321ba
  columns: [id, function, args, expected]
  rows:
    - [in1321ba001, inspect.BoundArguments.__repr__.__class__.__name__.__eq__,  ["function"],                true]
    - [in1321ba002, inspect.BoundArguments.__repr__.__qualname__.__eq__,        ["BoundArguments.__repr__"], true]
    - [in1321ba003, inspect.BoundArguments.__str__.__class__.__name__.__eq__,   ["wrapper_descriptor"],      true]
    - [in1321ba004, inspect.BoundArguments.__str__.__qualname__.__eq__,         ["object.__str__"],          true]
    - [in1321ba005, repr(inspect.Parameter).__class__.__name__.__eq__,          ["str"],                     true]
    - [in1321ba006, repr(inspect.BoundArguments).__class__.__name__.__eq__,     ["str"],                     true]
