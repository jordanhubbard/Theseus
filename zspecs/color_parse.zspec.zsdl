spec: color_parse
version: ">=2.0.2"
backend: node(color-parse)

docs: https://www.npmjs.com/package/color-parse

provenance:
  derived_from:
    - "color-parse README — https://www.npmjs.com/package/color-parse"
    - "Test vectors verified with color-parse via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "color-parse source"
  notes:
    - "color-parse is an npm package. Install: npm install color-parse"
    - "Parses a CSS color string into an object with space, values, and alpha."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object with space, values, and alpha."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table color_parse.parse:
  kind: node_module_call_eq
  function: "default"
  category: color
  id_prefix: cparse

  columns: [id, args, expected]
  rows:
    - [hex_red,   ["#ff0000"],          {"space": "rgb", "values": [255, 0, 0], "alpha": 1}]
    - [rgb_green, ["rgb(0, 128, 0)"],   {"space": "rgb", "values": [0, 128, 0], "alpha": 1}]
    - [named,     ["blue"],             {"space": "rgb", "values": [0, 0, 255], "alpha": 1}]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:28:22Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
