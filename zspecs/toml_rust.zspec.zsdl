spec: toml_rust
version: ">=3.9"
backend: rust_module(toml_rust)

docs: https://github.com/hukkin/tomli

provenance:
  derived_from:
    - "https://github.com/hukkin/tomli — tomli documentation"
  not_derived_from:
    - "tomllib source: Lib/tomllib/__init__.py"
  notes:
    - "tomllib (Python 3.11+) / tomli provide TOML parsing."
    - "tomllib.loads('[section]\\nkey = \"value\"')['section']['key'] == 'value'."
    - "tomllib.loads('x = 42')['x'] == 42."
    - "tomllib.loads('arr = [1, 2, 3]')['arr'] == [1, 2, 3]."
    - "Expose toml_loads_str(toml, key) -> str: tomllib.loads(toml)[key]."
    - "Expose toml_loads_int(toml, key) -> int: tomllib.loads(toml)[key]."
    - "Expose toml_loads_list(toml, key) -> list: tomllib.loads(toml)[key]."
    - "Use import tomllib (Python 3.11+) or import tomli as tomllib."
    - "All test vectors verified against tomllib (Python 3.12)."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# toml_loads_str — string value from TOML
table toml_rust.parse.loads_str:
  kind: python_call_eq
  category: loads_str
  id_prefix: toml_s
  function: toml_loads_str

  columns: [id, args, expected]
  rows:
    - [simple, ["key = \"value\"", "key"],        "value"]
    - [name,   ["name = \"Alice\"", "name"],       "Alice"]

# toml_loads_int — integer value from TOML
table toml_rust.parse.loads_int:
  kind: python_call_eq
  category: loads_int
  id_prefix: toml_i
  function: toml_loads_int

  columns: [id, args, expected]
  rows:
    - [forty2, ["x = 42", "x"], 42]
    - [zero,   ["n = 0",  "n"],  0]

# toml_loads_list — list value from TOML
invariant toml_rust.parse.loads_list:
  description: "arr = [1,2,3] parses to [1,2,3]"
  category: loads_list
  kind: python_call_eq
  function: toml_loads_list
  args: ["arr = [1, 2, 3]", "arr"]
  expected: [1, 2, 3]

