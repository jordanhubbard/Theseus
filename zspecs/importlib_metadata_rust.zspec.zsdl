spec: importlib_metadata_rust
version: ">=3.9"
backend: rust_module(importlib_metadata_rust)

docs: https://importlib-metadata.readthedocs.io/

provenance:
  derived_from:
    - "https://importlib-metadata.readthedocs.io/ — importlib-metadata"
  notes:
    - "importlib_metadata provides metadata for installed packages."
    - "importlib_metadata.version('pip') is non-empty."
    - "importlib_metadata.packages_distributions() returns a dict."
    - "importlib_metadata.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant importlib_metadata_rust.pip_version_nonempty:
  description: "importlib_metadata.version('pip') is non-empty"
  category: version
  kind: python_call_eq
  function: importlib_metadata_pip_version_nonempty
  args: []
  expected: true

invariant importlib_metadata_rust.has_packages_distributions:
  description: "importlib_metadata.packages_distributions is callable"
  category: presence
  kind: python_call_eq
  function: importlib_metadata_has_packages_distributions
  args: []
  expected: true

invariant importlib_metadata_rust.version_nonempty:
  description: "importlib_metadata.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: importlib_metadata_version_nonempty
  args: []
  expected: true

