spec: difflib_extra23
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib_extra22.zspec.zsdl."
    - "Prior specs covered: SequenceMatcher/Differ/HtmlDiff __module__.__len__() (extra22), __name__.__len__() (extra22); unified_diff/context_diff/ndiff/get_close_matches __module__.__len__() (extra22), unified_diff/__name__.__len__() (extra22), context_diff/__name__.__len__() (extra22)."
    - "This spec covers: ndiff.__name__.__len__() (NOVEL — extra22 covers ndiff.__module__.__len__ but not __name__.__len__); get_close_matches.__name__.__len__() (NOVEL); diff_bytes.__module__.__len__() (NOVEL); diff_bytes.__name__.__len__() (NOVEL); restore.__module__.__len__() (NOVEL); restore.__name__.__len__() (NOVEL); SequenceMatcher.__qualname__.__len__() (NOVEL); Differ.__qualname__.__len__() (NOVEL); HtmlDiff.__qualname__.__len__() (NOVEL); ndiff.__qualname__.__len__() (NOVEL); get_close_matches.__qualname__.__len__() (NOVEL); diff_bytes.__qualname__.__len__() (NOVEL)."
    - "difflib.ndiff.__name__ == 'ndiff' — len 5. Verified at runtime."
    - "difflib.get_close_matches.__name__ == 'get_close_matches' — len 17. Verified at runtime."
    - "difflib.diff_bytes.__module__ == 'difflib' — len 7. Verified at runtime."
    - "difflib.diff_bytes.__name__ == 'diff_bytes' — len 10. Verified at runtime."
    - "difflib.restore.__module__ == 'difflib' — len 7. Verified at runtime."
    - "difflib.restore.__name__ == 'restore' — len 7. Verified at runtime."
    - "difflib.SequenceMatcher.__qualname__ == 'SequenceMatcher' — len 15. Verified at runtime."
    - "difflib.Differ.__qualname__ == 'Differ' — len 6. Verified at runtime."
    - "difflib.HtmlDiff.__qualname__ == 'HtmlDiff' — len 8. Verified at runtime."
    - "difflib.ndiff.__qualname__ == 'ndiff' — len 5. Verified at runtime."
    - "difflib.get_close_matches.__qualname__ == 'get_close_matches' — len 17. Verified at runtime."
    - "difflib.diff_bytes.__qualname__ == 'diff_bytes' — len 10. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# difflib.ndiff.__name__.__len__()
#
# extra22 covers ndiff.__module__.__len__() == 7 (extra22 namespace).
# No prior spec verifies ndiff.__name__.__len__() as a standalone invariant.
# ndiff.__name__ == 'ndiff', len('ndiff') == 5.
# ---------------------------------------------------------------------------

invariant difflib_extra23.ndiff.name_len:
  description: "len(difflib.ndiff.__name__) == 5 — 'ndiff' has 5 characters"
  category: function_identity
  kind: python_call_eq
  function: ndiff.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# difflib.get_close_matches.__name__.__len__()
#
# extra22 covers get_close_matches.__module__.__len__() == 7.
# No prior spec verifies get_close_matches.__name__.__len__().
# get_close_matches.__name__ == 'get_close_matches', len == 17.
# ---------------------------------------------------------------------------

invariant difflib_extra23.get_close_matches.name_len:
  description: "len(difflib.get_close_matches.__name__) == 17 — 'get_close_matches' has 17 characters"
  category: function_identity
  kind: python_call_eq
  function: get_close_matches.__name__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# difflib.diff_bytes.__module__.__len__()
#
# No prior spec covers diff_bytes.__module__ or its length.
# diff_bytes.__module__ == 'difflib', len('difflib') == 7. Novel.
# ---------------------------------------------------------------------------

invariant difflib_extra23.diff_bytes.module_len:
  description: "len(difflib.diff_bytes.__module__) == 7 — 'difflib' has 7 characters"
  category: function_identity
  kind: python_call_eq
  function: diff_bytes.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# difflib.diff_bytes.__name__.__len__()
#
# No prior spec covers diff_bytes.__name__ or its length.
# diff_bytes.__name__ == 'diff_bytes', len('diff_bytes') == 10. Novel.
# ---------------------------------------------------------------------------

invariant difflib_extra23.diff_bytes.name_len:
  description: "len(difflib.diff_bytes.__name__) == 10 — 'diff_bytes' has 10 characters"
  category: function_identity
  kind: python_call_eq
  function: diff_bytes.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# difflib.restore.__module__.__len__()
#
# No prior spec covers restore.__module__ or its length.
# restore.__module__ == 'difflib', len('difflib') == 7. Novel.
# ---------------------------------------------------------------------------

invariant difflib_extra23.restore.module_len:
  description: "len(difflib.restore.__module__) == 7 — 'difflib' has 7 characters"
  category: function_identity
  kind: python_call_eq
  function: restore.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# difflib.restore.__name__.__len__()
#
# No prior spec covers restore.__name__ or its length.
# restore.__name__ == 'restore', len('restore') == 7. Novel.
# ---------------------------------------------------------------------------

invariant difflib_extra23.restore.name_len:
  description: "len(difflib.restore.__name__) == 7 — 'restore' has 7 characters"
  category: function_identity
  kind: python_call_eq
  function: restore.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# SequenceMatcher, Differ, HtmlDiff __qualname__.__len__()
#
# No prior spec checks __qualname__.__len__() for any difflib class in a
# standalone invariant. SequenceMatcher.__qualname__ == 'SequenceMatcher' (15),
# Differ.__qualname__ == 'Differ' (6), HtmlDiff.__qualname__ == 'HtmlDiff' (8).
# ---------------------------------------------------------------------------

invariant difflib_extra23.SequenceMatcher.qualname_len:
  description: "len(difflib.SequenceMatcher.__qualname__) == 15 — 'SequenceMatcher' has 15 characters"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__qualname__.__len__
  args: []
  expected: 15

invariant difflib_extra23.Differ.qualname_len:
  description: "len(difflib.Differ.__qualname__) == 6 — 'Differ' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: Differ.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Table: diff_bytes and restore __module__.__len__() and __name__.__len__()
#
# No prior spec groups diff_bytes and restore __module__/__name__ length checks.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table difflib_extra23.utility_function_len_attrs:
  description: "difflib.diff_bytes and restore __module__ and __name__ lengths — novel invariants"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [diff_bytes_module_len,
       diff_bytes.__module__.__len__,
       [],
       7,
       "len(diff_bytes.__module__) == 7"]
    - [diff_bytes_name_len,
       diff_bytes.__name__.__len__,
       [],
       10,
       "len(diff_bytes.__name__) == 10"]
    - [restore_module_len,
       restore.__module__.__len__,
       [],
       7,
       "len(restore.__module__) == 7"]
    - [restore_name_len,
       restore.__name__.__len__,
       [],
       7,
       "len(restore.__name__) == 7"]
    - [ndiff_name_len,
       ndiff.__name__.__len__,
       [],
       5,
       "len(ndiff.__name__) == 5"]
    - [get_close_matches_name_len,
       get_close_matches.__name__.__len__,
       [],
       17,
       "len(get_close_matches.__name__) == 17"]

# ---------------------------------------------------------------------------
# Table: class __qualname__.__len__() for SequenceMatcher, Differ, HtmlDiff
#
# No prior spec tables __qualname__.__len__() for any difflib class.
# SequenceMatcher=15, Differ=6, HtmlDiff=8. All values verified at runtime.
# ---------------------------------------------------------------------------

table difflib_extra23.class_qualname_lengths:
  description: "difflib class __qualname__ lengths — SequenceMatcher (15), Differ (6), HtmlDiff (8)"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [SequenceMatcher_qualname_len,
       SequenceMatcher.__qualname__.__len__,
       [],
       15,
       "len(SequenceMatcher.__qualname__) == 15"]
    - [Differ_qualname_len,
       Differ.__qualname__.__len__,
       [],
       6,
       "len(Differ.__qualname__) == 6"]
    - [HtmlDiff_qualname_len,
       HtmlDiff.__qualname__.__len__,
       [],
       8,
       "len(HtmlDiff.__qualname__) == 8"]
    - [ndiff_qualname_len,
       ndiff.__qualname__.__len__,
       [],
       5,
       "len(ndiff.__qualname__) == 5"]
    - [get_close_matches_qualname_len,
       get_close_matches.__qualname__.__len__,
       [],
       17,
       "len(get_close_matches.__qualname__) == 17"]
    - [diff_bytes_qualname_len,
       diff_bytes.__qualname__.__len__,
       [],
       10,
       "len(diff_bytes.__qualname__) == 10"]
