# concurrent.futures._base.__name__             == 'concurrent.futures._base'
# concurrent.futures._base.__spec__.name        == 'concurrent.futures._base'
# concurrent.futures._base.__name__.__len__()   == 24
# ---------------------------------------------------------------------------

table concurrent_futures_extra278.cfbase_module_identity:
  description: "concurrent.futures._base module identity checks in cfbase278 namespace — concurrent.futures._base is defined in Lib/concurrent/futures/_base.py; its __name__ is 'concurrent.futures._base' (len=24: 'concurrent.futures.'=19+'_base'=5); __spec__.name is also 'concurrent.futures._base'; __name__.__len__()==24; _base is the core internal module defining Error, CancelledError, TimeoutError (re-export), BrokenExecutor, Future, Executor, and thread-pool internals; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfbase278

  columns: [id, function, args, expected, description]
  rows:
    - [mod_name_eq,   "concurrent.futures._base.__name__.__eq__",        ["concurrent.futures._base"],  true, "concurrent.futures._base.__name__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [mod_spec_eq,   "concurrent.futures._base.__spec__.name.__eq__",   ["concurrent.futures._base"],  true, "concurrent.futures._base.__spec__.name == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [mod_name_len,  "concurrent.futures._base.__name__.__len__",       [],                            24,   "concurrent.futures._base.__name__.__len__() == 24 ('concurrent.futures._base'=24); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
