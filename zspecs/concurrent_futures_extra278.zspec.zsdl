#
# Error.__name__                       == 'Error'
# Error.__module__                     == 'concurrent.futures._base'
# Error.__qualname__                   == 'Error'
# Error.__bases__[0].__name__          == 'Exception'
# Error.__mro__.__len__()              == 4
# BrokenExecutor.__name__              == 'BrokenExecutor'
# BrokenExecutor.__module__            == 'concurrent.futures._base'
# BrokenExecutor.__qualname__          == 'BrokenExecutor'
# BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'
# BrokenExecutor.__mro__.__len__()     == 5
# CancelledError.__name__              == 'CancelledError'
# CancelledError.__module__            == 'concurrent.futures._base'
# CancelledError.__bases__[0].__name__ == 'Error'
# CancelledError.__mro__.__len__()     == 5
# BrokenExecutor.__init__.__qualname__ == 'BaseException.__init__'
# ---------------------------------------------------------------------------

table concurrent_futures_extra278.cfbase_exception_class_identity:
  description: "concurrent.futures._base exception class identity checks in cfbase278a namespace — Error, BrokenExecutor, and CancelledError are defined in Lib/concurrent/futures/_base.py; Error inherits from Exception (MRO len=4: [Error, Exception, BaseException, object]); BrokenExecutor inherits from RuntimeError (MRO len=5: [BrokenExecutor, RuntimeError, Exception, BaseException, object]); CancelledError inherits from Error (MRO len=5: [CancelledError, Error, Exception, BaseException, object]); BrokenExecutor does NOT inherit from Error — it inherits from RuntimeError directly; Error.__name__.__eq__('Error')==True (len=5, shortest class name in spec); BrokenExecutor.__name__.__len__()==14; CancelledError.__name__.__len__()==14 (same length as BrokenExecutor); all share __module__ 'concurrent.futures._base' (len=24); BrokenExecutor.__init__.__qualname__.__eq__('BaseException.__init__')==True (inherited, no own __init__); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfbase278a

  columns: [id, function, args, expected, description]
  rows:
    - [err_name_eq,    "concurrent.futures._base.Error.__name__.__eq__",                         ["Error"],                         true, "concurrent.futures._base.Error.__name__ == 'Error'; verified with Python 3.14.3"]
    - [err_mod_eq,     "concurrent.futures._base.Error.__module__.__eq__",                       ["concurrent.futures._base"],      true, "concurrent.futures._base.Error.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [err_qn_eq,      "concurrent.futures._base.Error.__qualname__.__eq__",                     ["Error"],                         true, "concurrent.futures._base.Error.__qualname__ == 'Error'; verified with Python 3.14.3"]
    - [err_base0_eq,   "concurrent.futures._base.Error.__bases__[0].__name__.__eq__",            ["Exception"],                     true, "concurrent.futures._base.Error.__bases__[0].__name__ == 'Exception'; verified with Python 3.14.3"]
    - [err_mro_len,    "concurrent.futures._base.Error.__mro__.__len__",                         [],                                4,    "concurrent.futures._base.Error.__mro__.__len__() == 4 — [Error, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [be_name_eq,     "concurrent.futures._base.BrokenExecutor.__name__.__eq__",                ["BrokenExecutor"],                true, "concurrent.futures._base.BrokenExecutor.__name__ == 'BrokenExecutor'; verified with Python 3.14.3"]
    - [be_mod_eq,      "concurrent.futures._base.BrokenExecutor.__module__.__eq__",              ["concurrent.futures._base"],      true, "concurrent.futures._base.BrokenExecutor.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [be_qn_eq,       "concurrent.futures._base.BrokenExecutor.__qualname__.__eq__",            ["BrokenExecutor"],                true, "concurrent.futures._base.BrokenExecutor.__qualname__ == 'BrokenExecutor'; verified with Python 3.14.3"]
    - [be_base0_eq,    "concurrent.futures._base.BrokenExecutor.__bases__[0].__name__.__eq__",   ["RuntimeError"],                  true, "concurrent.futures._base.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' (not Error); verified with Python 3.14.3"]
    - [be_mro_len,     "concurrent.futures._base.BrokenExecutor.__mro__.__len__",                [],                                5,    "concurrent.futures._base.BrokenExecutor.__mro__.__len__() == 5 — [BrokenExecutor, RuntimeError, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [ce_name_eq,     "concurrent.futures._base.CancelledError.__name__.__eq__",                ["CancelledError"],                true, "concurrent.futures._base.CancelledError.__name__ == 'CancelledError'; verified with Python 3.14.3"]
    - [ce_mod_eq,      "concurrent.futures._base.CancelledError.__module__.__eq__",              ["concurrent.futures._base"],      true, "concurrent.futures._base.CancelledError.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [ce_base0_eq,    "concurrent.futures._base.CancelledError.__bases__[0].__name__.__eq__",   ["Error"],                         true, "concurrent.futures._base.CancelledError.__bases__[0].__name__ == 'Error' (inherits from futures Error, not BaseException); verified with Python 3.14.3"]
    - [ce_mro_len,     "concurrent.futures._base.CancelledError.__mro__.__len__",                [],                                5,    "concurrent.futures._base.CancelledError.__mro__.__len__() == 5 — [CancelledError, Error, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [be_init_qn_eq,  "concurrent.futures._base.BrokenExecutor.__init__.__qualname__.__eq__",   ["BaseException.__init__"],        true, "concurrent.futures._base.BrokenExecutor.__init__.__qualname__ == 'BaseException.__init__' (inherited, no own __init__); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra278
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra278.cfbase_name_len_is_24:
  description: "concurrent.futures._base.__name__.__len__() == 24 — concurrent.futures._base.__name__ is 'concurrent.futures._base' (24 characters: 'concurrent.futures.'=19+'_base'=5=24); concurrent.futures._base.__spec__.name is also 'concurrent.futures._base' (len=24); compare submodule name lengths: _base=24, thread=25, process=26; _base has the shortest __name__ among the three concurrent.futures submodules; _base defines the core classes (Error, Future, Executor) that thread and process extend; NEW in extra278: first standalone concurrent.futures._base module name length invariant in cfbase278 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures._base.__name__.__len__"
  args: []
  expected: 24

invariant concurrent_futures_extra278.Error_module_is_cfbase:
  description: "concurrent.futures._base.Error.__module__.__eq__('concurrent.futures._base') returns True — Error is defined in Lib/concurrent/futures/_base.py; its __module__ is 'concurrent.futures._base' (len=24); Error is the root exception class for all concurrent.futures exceptions (the parallel to OSError for I/O); Error.__bases__[0].__name__ is 'Exception' (standard exception hierarchy); Error.__mro__.__len__() is 4 ([Error, Exception, BaseException, object]); Error.__name__.__len__() is 5 ('Error'=5, shortest class name in spec); Error.__qualname__ is 'Error' (module-level class); NEW in extra278: first standalone Error.__module__ invariant in cfbase278a namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures._base.Error.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra278.BrokenExecutor_base_is_RuntimeError:
  description: "concurrent.futures._base.BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError') returns True — BrokenExecutor inherits from RuntimeError, NOT from Error; this is a deliberate design: BrokenExecutor signals that the executor itself is in an unrecoverable state (e.g., a worker process crashed), which is a runtime-level problem rather than a futures-domain error; BrokenExecutor.__mro__ is [BrokenExecutor, RuntimeError, Exception, BaseException, object] (len=5); compare: Error.__bases__[0].__name__ is 'Exception' (MRO len=4); CancelledError.__bases__[0].__name__ is 'Error' (MRO len=5, same depth as BrokenExecutor); BrokenExecutor.__module__ is 'concurrent.futures._base'; NEW in extra278: first standalone BrokenExecutor base-is-RuntimeError invariant in cfbase278a namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures._base.BrokenExecutor.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true

invariant concurrent_futures_extra278.BrokenExecutor_mro_len_is_5:
  description: "concurrent.futures._base.BrokenExecutor.__mro__.__len__() == 5 — BrokenExecutor's MRO is [BrokenExecutor, RuntimeError, Exception, BaseException, object] (length=5); this is the deepest MRO in this spec (tied with CancelledError at len=5); BrokenExecutor is raised when a thread or process in a pool terminates abnormally; compare MRO depths: Error=4, BrokenExecutor=5, CancelledError=5; BrokenExecutor.__module__ is 'concurrent.futures._base'; BrokenExecutor.__name__.__len__() is 14 ('BrokenExecutor'=14); NEW in extra278: first standalone BrokenExecutor MRO length invariant in cfbase278a namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures._base.BrokenExecutor.__mro__.__len__"
  args: []
  expected: 5

invariant concurrent_futures_extra278.CancelledError_base_is_Error:
  description: "concurrent.futures._base.CancelledError.__bases__[0].__name__.__eq__('Error') returns True — concurrent.futures._base.CancelledError inherits from concurrent.futures._base.Error (the futures-domain root exception), NOT from BaseException or builtins.CancelledError; CancelledError's MRO is [CancelledError, Error, Exception, BaseException, object] (len=5); this is distinct from asyncio.exceptions.CancelledError which inherits from BaseException (MRO len=3); CancelledError.__module__ is 'concurrent.futures._base'; CancelledError.__name__.__len__() is 14 ('CancelledError'=14, same length as BrokenExecutor); NEW in extra278: first standalone CancelledError base-is-Error invariant in cfbase278a namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures._base.CancelledError.__bases__[0].__name__.__eq__"
  args: ["Error"]
  expected: true

invariant concurrent_futures_extra278.BrokenExecutor_init_qualname_is_BaseException_init:
  description: "concurrent.futures._base.BrokenExecutor.__init__.__qualname__.__eq__('BaseException.__init__') returns True — BrokenExecutor does not define its own __init__ method; the __init__.__qualname__ attribute therefore reflects the inherited method from BaseException (not RuntimeError, which also inherits BaseException.__init__); BrokenExecutor.__init__.__qualname__ is 'BaseException.__init__' because Python reports the qualname of the defining class in the MRO, which is BaseException; similarly BrokenExecutor.__str__.__qualname__ is 'BaseException.__str__' and BrokenExecutor.__repr__.__qualname__ is 'BaseException.__repr__'; NEW in extra278: first standalone BrokenExecutor.__init__ qualname invariant in cfbase278a namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures._base.BrokenExecutor.__init__.__qualname__.__eq__"
  args: ["BaseException.__init__"]
  expected: true
