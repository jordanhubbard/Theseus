spec: threading_extra189
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Thread.name, daemon, ident, and native_id are properties; their fget function __name__ matches the property name; verified with Python 3.14.3."
    - "threading.Thread.name.fget.__name__ == 'name' (len=4); threading.Thread.daemon.fget.__name__ == 'daemon' (len=6); threading.Thread.ident.fget.__name__ == 'ident' (len=5); threading.Thread.native_id.fget.__name__ == 'native_id' (len=9); all verified with Python 3.14.3."
    - "threading.Thread.name.fget.__module__ == 'threading'; threading.Thread.daemon.fget.__module__ == 'threading'; both verified with Python 3.14.3."
    - "threading.Thread.name.fget.__qualname__ == 'Thread.name' (len=11); threading.Thread.daemon.fget.__qualname__ == 'Thread.daemon' (len=13); the __qualname__ of a method includes the class name as prefix; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread property fget __name__ identity
#
# threading.Thread.name.fget.__name__      == 'name'      (len=4)
# threading.Thread.daemon.fget.__name__    == 'daemon'    (len=6)
# threading.Thread.ident.fget.__name__     == 'ident'     (len=5)
# threading.Thread.native_id.fget.__name__ == 'native_id' (len=9)
#
# Each property's getter function has a __name__ matching the property name.
# New to extra189.
# ---------------------------------------------------------------------------

table threading_extra189.property_fget_names:
  description: "threading.Thread property fget __name__: name.fget.__name__=='name' (len=4); daemon.fget.__name__=='daemon' (len=6); ident.fget.__name__=='ident' (len=5); native_id.fget.__name__=='native_id' (len=9); new to extra189"
  kind: python_call_eq
  category: identity
  id_prefix: threadingprops189

  columns: [id, function, args, expected, description]
  rows:
    - [name_fget_name_eq,
       Thread.name.fget.__name__.__eq__,
       ["name"],
       true,
       "threading.Thread.name.fget.__name__.__eq__('name') == True — the name property getter __name__ is 'name' (len=4); str.__eq__('name') returns True; verified with Python 3.14.3; new to extra189"]
    - [daemon_fget_name_eq,
       Thread.daemon.fget.__name__.__eq__,
       ["daemon"],
       true,
       "threading.Thread.daemon.fget.__name__.__eq__('daemon') == True — the daemon property getter __name__ is 'daemon' (len=6); str.__eq__('daemon') returns True; verified with Python 3.14.3; new to extra189"]
    - [ident_fget_name_eq,
       Thread.ident.fget.__name__.__eq__,
       ["ident"],
       true,
       "threading.Thread.ident.fget.__name__.__eq__('ident') == True — the ident property getter __name__ is 'ident' (len=5); str.__eq__('ident') returns True; verified with Python 3.14.3; new to extra189"]
    - [native_id_fget_name_eq,
       Thread.native_id.fget.__name__.__eq__,
       ["native_id"],
       true,
       "threading.Thread.native_id.fget.__name__.__eq__('native_id') == True — the native_id property getter __name__ is 'native_id' (len=9); str.__eq__('native_id') returns True; verified with Python 3.14.3; new to extra189"]

