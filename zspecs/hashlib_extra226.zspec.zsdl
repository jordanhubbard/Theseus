spec: hashlib_extra226
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "hashlib.sha3_256(b'').hexdigest() == 'a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a' — SHA3-256 of empty string."
    - "hashlib.sha3_256(b'hello').hexdigest() == '3338be694f50c5f338814986cdf0686453a888b84f424d792af4b9202398f392' — SHA3-256 of 'hello'."
    - "hashlib.sha3_512(b'').hexdigest().__len__() == 128 — SHA3-512 hex digest is 128 characters."
    - "hashlib.sha3_224(b'').hexdigest().__len__() == 56 — SHA3-224 hex digest is 56 characters."
    - "hashlib.sha3_384(b'').hexdigest().__len__() == 96 — SHA3-384 hex digest is 96 characters."
    - "hashlib.sha3_256(b'').digest().__len__() == 32 — SHA3-256 raw digest is 32 bytes."
    - "hashlib.sha3_256.__class__.__name__ == 'builtin_function_or_method' — sha3_256 is a C-level builtin."
    - "hashlib.sha3_256().__class__.__name__ == 'HASH' — sha3_256() returns a HASH instance."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib SHA3 known digest values and output size contracts
#
# hashlib.sha3_256(b'').hexdigest()         == 'a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a'
# hashlib.sha3_256(b'hello').hexdigest()    == '3338be694f50c5f338814986cdf0686453a888b84f424d792af4b9202398f392'
# hashlib.sha3_512(b'').hexdigest().__len__() == 128
# hashlib.sha3_224(b'').hexdigest().__len__() == 56
# hashlib.sha3_384(b'').hexdigest().__len__() == 96
# hashlib.sha3_256(b'').digest().__len__()    == 32
# ---------------------------------------------------------------------------

table hashlib_extra226.sha3_digest_values:
  description: "hashlib SHA3 known digest values and output size contracts in hashlib226 namespace — wave 226 theme: SHA3-256 known hex digests for empty string and 'hello'; SHA3-512 hex is 128 chars; SHA3-224 hex is 56 chars; SHA3-384 hex is 96 chars; SHA3-256 raw digest is 32 bytes; sha3_256 is builtin_function_or_method; sha3_256() returns HASH instance; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: digest_values
  id_prefix: hashlib226

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_empty_hexdigest,  hashlib.sha3_256(b'').hexdigest.__eq__,                   ["a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a"], true,  "hashlib.sha3_256(b'').hexdigest() == 'a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a' — SHA3-256 of empty string"]
    - [sha3_256_hello_hexdigest,  hashlib.sha3_256(b'hello').hexdigest.__eq__,               ["3338be694f50c5f338814986cdf0686453a888b84f424d792af4b9202398f392"],  true,  "hashlib.sha3_256(b'hello').hexdigest() == '3338be694f50c5f338814986cdf0686453a888b84f424d792af4b9202398f392' — SHA3-256 of 'hello'"]
    - [sha3_512_empty_hexlen,     hashlib.sha3_512(b'').hexdigest().__len__,                  [],                                                                        128,   "hashlib.sha3_512(b'').hexdigest().__len__() == 128 — SHA3-512 hex output is 128 characters"]
    - [sha3_224_empty_hexlen,     hashlib.sha3_224(b'').hexdigest().__len__,                  [],                                                                        56,    "hashlib.sha3_224(b'').hexdigest().__len__() == 56 — SHA3-224 hex output is 56 characters"]
    - [sha3_384_empty_hexlen,     hashlib.sha3_384(b'').hexdigest().__len__,                  [],                                                                        96,    "hashlib.sha3_384(b'').hexdigest().__len__() == 96 — SHA3-384 hex output is 96 characters"]
    - [sha3_256_empty_digestlen,  hashlib.sha3_256(b'').digest().__len__,                     [],                                                                        32,    "hashlib.sha3_256(b'').digest().__len__() == 32 — SHA3-256 raw digest is 32 bytes"]
    - [sha3_256_class_name,       hashlib.sha3_256.__class__.__name__.__eq__,                 ["builtin_function_or_method"],                                            true,  "hashlib.sha3_256.__class__.__name__ == 'builtin_function_or_method' — sha3_256 is a C-level builtin"]
    - [sha3_256_inst_class_name,  hashlib.sha3_256().__class__.__name__.__eq__,               ["HASH"],                                                                   true,  "hashlib.sha3_256().__class__.__name__ == 'HASH' — sha3_256() returns a HASH instance"]

# ---------------------------------------------------------------------------
# Standalone invariants for SHA3-256 known digest values
# ---------------------------------------------------------------------------

invariant hashlib_extra226.sha3_256_empty_hexdigest_eq:
  description: "hashlib.sha3_256(b'').hexdigest.__eq__('a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a') == True — SHA3-256 of empty string is a well-known FIPS 202 test vector; verified with Python 3.14.3"
  category: digest_values
  kind: python_call_eq
  function: hashlib.sha3_256(b'').hexdigest.__eq__
  args: ["a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a"]
  expected: true

invariant hashlib_extra226.sha3_256_hello_hexdigest_eq:
  description: "hashlib.sha3_256(b'hello').hexdigest.__eq__('3338be694f50c5f338814986cdf0686453a888b84f424d792af4b9202398f392') == True — SHA3-256 of b'hello' is a known test vector; verified with Python 3.14.3"
  category: digest_values
  kind: python_call_eq
  function: hashlib.sha3_256(b'hello').hexdigest.__eq__
  args: ["3338be694f50c5f338814986cdf0686453a888b84f424d792af4b9202398f392"]
  expected: true
