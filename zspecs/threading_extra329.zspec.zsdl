spec: threading_extra329
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.local — identity (implemented as _thread._local)
# ---------------------------------------------------------------------------

invariant threading_extra329.local.__name__:
  description: "threading.local.__name__ == '_local' — backed by _thread._local"
  category: identity
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra329.local.__module__:
  description: "threading.local.__module__ == '_thread'"
  category: identity
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

# ---------------------------------------------------------------------------
# threading.local() — instance identity
# ---------------------------------------------------------------------------

invariant threading_extra329.local_instance.__class__.__name__:
  description: "threading.local().__class__.__name__ == '_local'"
  category: identity
  kind: python_call_eq
  function: local().__class__.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra329.local_instance.__class__.__module__:
  description: "threading.local().__class__.__module__ == '_thread'"
  category: identity
  kind: python_call_eq
  function: local().__class__.__module__.__eq__
  args: ["_thread"]
  expected: true

# ---------------------------------------------------------------------------
# threading.local() — instance dict
# ---------------------------------------------------------------------------

invariant threading_extra329.local_instance.__dict__.__class__.__name__:
  description: "threading.local().__dict__.__class__.__name__ == 'dict'"
  category: identity
  kind: python_call_eq
  function: local().__dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant threading_extra329.local_instance.__dict__.__len__:
  description: "threading.local().__dict__.__len__() == 0 — new local has empty instance dict"
  category: behavioral
  kind: python_call_eq
  function: local().__dict__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# threading.RLock — identity
# ---------------------------------------------------------------------------

invariant threading_extra329.RLock_instance.__class__.__name__:
  description: "threading.RLock().__class__.__name__ == 'RLock'"
  category: identity
  kind: python_call_eq
  function: RLock().__class__.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra329.RLock_instance.__class__.__module__:
  description: "threading.RLock().__class__.__module__ == '_thread'"
  category: identity
  kind: python_call_eq
  function: RLock().__class__.__module__.__eq__
  args: ["_thread"]
  expected: true

# ---------------------------------------------------------------------------
# Table: class __name__ and __module__ for local and RLock types
# ---------------------------------------------------------------------------

table threading_extra329.type_identity:
  kind: python_call_eq
  category: identity
  id_prefix: tid

  columns: [id, function, args, expected]
  rows:
    - [local_name,    local.__name__.__eq__,              ["_local"],  true]
    - [local_module,  local.__module__.__eq__,            ["_thread"], true]
    - [rlock_inst_name,   RLock().__class__.__name__.__eq__,   ["RLock"],   true]
    - [rlock_inst_module, RLock().__class__.__module__.__eq__, ["_thread"], true]
