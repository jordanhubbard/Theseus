spec: uuid_extra856
python: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/uuid.py"
  not_derived_from:
    - "any third-party UUID library"
  notes:
    - "Covers UUID class and uuid function type identity checks via __class__.__name__"
    - "Also covers __module__ and __qualname__ attributes and doc string class identity"
    - "NAMESPACE_DNS and NAMESPACE_URL are module-level UUID sentinel instances"
  created_at: "2026-04-12"

table uuid_extra856.type_identity:
  description: "Verify type identity of uuid.UUID class, uuid functions, and namespace constants"
  kind: python_call_eq
  category: introspection
  id_prefix: uu856xx
  columns: [id, function, args, expected]
  rows:
    - [uu856xx001, "uuid.UUID.__class__.__name__.__eq__", ["type"], true]
    - [uu856xx002, "uuid.UUID.__module__.__eq__", ["uuid"], true]
    - [uu856xx003, "uuid.UUID.__qualname__.__eq__", ["UUID"], true]
    - [uu856xx004, "uuid.UUID.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [uu856xx005, "uuid.uuid1.__class__.__name__.__eq__", ["function"], true]
    - [uu856xx006, "uuid.uuid3.__class__.__name__.__eq__", ["function"], true]
    - [uu856xx007, "uuid.uuid4.__class__.__name__.__eq__", ["function"], true]
    - [uu856xx008, "uuid.uuid5.__class__.__name__.__eq__", ["function"], true]
    - [uu856xx009, "uuid.uuid1.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [uu856xx010, "uuid.uuid4.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [uu856xx011, "uuid.NAMESPACE_DNS.__class__.__name__.__eq__", ["UUID"], true]
    - [uu856xx012, "uuid.NAMESPACE_URL.__class__.__name__.__eq__", ["UUID"], true]
