spec: theseus_logging_config_cr
version: ">=3.0"
backend: python_cleanroom(theseus_logging_config_cr)
blocks: logging.config

docs: https://docs.python.org/3/library/logging.config.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/logging.config.html"
  not_derived_from:
    - "CPython source: Lib/logging/config.py"
  notes:
    - "Clean-room logging.config module. Do NOT import logging.config."

error_model: python_exceptions

invariant theseus_logging_config_cr.logcfg2_dictconfig:
  description: "dictConfig() configures logging from a dict"
  category: behavior
  kind: python_call_eq
  function: logcfg2_dictconfig
  args: []
  expected: true

invariant theseus_logging_config_cr.logcfg2_fileconfig:
  description: "fileConfig() function exists and is callable"
  category: behavior
  kind: python_call_eq
  function: logcfg2_fileconfig
  args: []
  expected: true

invariant theseus_logging_config_cr.logcfg2_listen:
  description: "listen() and stopListening() functions exist"
  category: behavior
  kind: python_call_eq
  function: logcfg2_listen
  args: []
  expected: true
