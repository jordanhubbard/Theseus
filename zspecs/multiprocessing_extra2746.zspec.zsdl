spec: multiprocessing_extra2746
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 630 (_extra2746): __round__, __divmod__, __pow__ dict-presence checks."
    - "multiprocessing.Process, multiprocessing.pool.Pool, and multiprocessing.pool.AsyncResult are process/IPC primitives, not numeric types."
    - "None of these types define rounding, divmod, or power protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __round__ dict-presence checks
#
# Wave 630 theme: multiprocessing process and pool types do not implement
# the round operator. __round__ does not appear in any of these
# classes' own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2746.round_protocol:
  description: "multiprocessing.Process, Pool, AsyncResult __round__ dict-presence checks — none define rounding in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2746

  columns: [id, function, args, expected]
  rows:
    - ["mp2746001", "multiprocessing.Process.__dict__.__contains__",          ["__round__"], false]
    - ["mp2746002", "multiprocessing.pool.Pool.__dict__.__contains__",        ["__round__"], false]
    - ["mp2746003", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__round__"], false]

