    - ["mp2746008", "multiprocessing.pool.Pool.__dict__.__contains__",        ["__pow__"], false]
    - ["mp2746009", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__pow__"], false]

# ---------------------------------------------------------------------------
# Table 4: synchronize types __round__/__divmod__/__pow__ checks
#
# Wave 630 theme: multiprocessing.synchronize Lock, RLock, Semaphore, and
# Event are IPC synchronization primitives. None define any rounding, divmod,
# or power operator protocol in their own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2746.synchronize_arithmetic:
  description: "multiprocessing.synchronize types __round__/__divmod__/__pow__ dict-presence checks — IPC sync primitives define none"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2746

  columns: [id, function, args, expected]
  rows:
    - ["mp2746010", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__round__"],  false]
    - ["mp2746011", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__divmod__"], false]
    - ["mp2746012", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__pow__"],    false]
    - ["mp2746013", "multiprocessing.synchronize.RLock.__dict__.__contains__",     ["__round__"],  false]
    - ["mp2746014", "multiprocessing.synchronize.RLock.__dict__.__contains__",     ["__divmod__"], false]
    - ["mp2746015", "multiprocessing.synchronize.RLock.__dict__.__contains__",     ["__pow__"],    false]
    - ["mp2746016", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__round__"],  false]
    - ["mp2746017", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__divmod__"], false]
    - ["mp2746018", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__pow__"],    false]
    - ["mp2746019", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__round__"],  false]
    - ["mp2746020", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__divmod__"], false]
    - ["mp2746021", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__pow__"],    false]
