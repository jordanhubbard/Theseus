spec: socket_extra217
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 791 — Internet Protocol"
  - "RFC 1700 — Assigned Numbers (network byte order)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 791 — Internet Protocol, DARPA, September 1981"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "verified with Python 3.14.3."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'; SOCK_DGRAM and SOCK_RAW also SocketKind."
    - "socket.SocketKind.SOCK_STREAM.value == 1; SOCK_DGRAM.value == 2; SOCK_RAW.value == 3."
    - "socket.AddressFamily.__name__ == 'AddressFamily'; socket.AddressFamily.__module__ == 'socket'."
    - "socket.SocketKind.__name__ == 'SocketKind'; socket.SocketKind.__module__ == 'socket'."
    - "socket.socket.__name__ == 'socket'; socket.socket.__module__ == 'socket'."
    - "socket.socket.__bases__[0].__name__ == 'socket'; socket.socket.__bases__[0].__module__ == '_socket'."
    - "socket.AF_INET.value.__class__.__name__ == 'int'; socket.SOCK_STREAM.value.__class__.__name__ == 'int'."
    - "socket.socket.fileno.__name__ == 'fileno'; socket.socket.close.__name__ == 'close'; socket.socket.setblocking.__name__ == 'setblocking'."
    - "AF_INET6.value == 30 on macOS/Darwin (platform-dependent; 10 on Linux); not checked here."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

