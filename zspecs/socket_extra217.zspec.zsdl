invariant socket_extra217.socket_class_name:
  description: "socket.socket.__name__ == 'socket' — the socket.socket class simple name is 'socket'; this is the Python-level class that wraps _socket.socket and adds higher-level methods; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "socket.socket.__name__.__eq__"
  args: ["socket"]
  expected: true

invariant socket_extra217.socket_class_module:
  description: "socket.socket.__module__ == 'socket' — the socket.socket class is defined in the Python-level 'socket' module (Lib/socket.py), not the _socket C extension; the Python class inherits from _socket.socket and adds convenience methods; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "socket.socket.__module__.__eq__"
  args: ["socket"]
  expected: true

invariant socket_extra217.socket_base_class_name:
  description: "socket.socket.__bases__[0].__name__ == 'socket' — the first (and only) base class of socket.socket is _socket.socket, whose __name__ is 'socket'; this confirms the single-inheritance chain from the C-level socket type; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "socket.socket.__bases__[0].__name__.__eq__"
  args: ["socket"]
  expected: true

invariant socket_extra217.socket_fileno_name:
  description: "socket.socket.fileno.__name__ == 'fileno' — the fileno method returns the underlying file descriptor integer; its __name__ confirms method identity; fileno is a standard POSIX file descriptor accessor; verified with Python 3.14.3"
  category: method_identity
  kind: python_call_eq
  function: "socket.socket.fileno.__name__.__eq__"
  args: ["fileno"]
  expected: true

invariant socket_extra217.sock_stream_value_type:
  description: "socket.SOCK_STREAM.value.__class__.__name__ == 'int' — the .value attribute of a SocketKind enum member is a plain Python int; SocketKind is an IntEnum subclass so enum values are integers; verified with Python 3.14.3"
  category: enum_values
  kind: python_call_eq
  function: "socket.SOCK_STREAM.value.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

