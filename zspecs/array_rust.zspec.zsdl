spec: array_rust
version: ">=3.9"
backend: rust_module(array_rust)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array documentation"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
  notes:
    - "Clean-room Rust reimplementation of Python array module, exposed via PyO3."
    - "array(typecode, initializer) creates a typed array; typecodes: b B u h H i I l L q Q f d."
    - "tolist() converts array elements to a Python list."
    - "typecodes is a module-level string constant containing all valid typecodes."
    - "array('i', [1,2,3]).tolist() == [1, 2, 3] — int array roundtrip."
    - "array('d', [1.0, 2.0]).tolist() == [1.0, 2.0] — double array roundtrip."
    - "len(array('b', [0, 1, -1])) == 3 — length of byte array."
    - "array('i', [10, 20, 30])[1] == 20 — indexing."
    - "All test vectors verified against Python 3.14.3 array module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# array tolist — roundtrip through list initializer
table array_rust.array.tolist:
  kind: python_call_eq
  category: array
  id_prefix: tolist
  function: array
  method: tolist
  method_args: []

  columns: [id, args, expected]
  rows:
    - [int_list,    ["i", [1, 2, 3]],      [1, 2, 3]]
    - [double_list, ["d", [1.0, 2.0]],     [1.0, 2.0]]
    - [byte_list,   ["b", [0, 1, -1]],     [0, 1, -1]]
    - [empty_int,   ["i", []],             []]
    - [single_int,  ["i", [42]],           [42]]

# array __len__ — length of typed arrays
table array_rust.array.len:
  kind: python_call_eq
  category: array
  id_prefix: array_len
  function: array
  method: __len__
  method_args: []

  columns: [id, args, expected]
  rows:
    - [three_ints,   ["i", [1, 2, 3]],  3]
    - [two_doubles,  ["d", [1.0, 2.0]], 2]
    - [empty,        ["i", []],         0]

# array __getitem__ — indexing
table array_rust.array.getitem:
  kind: python_call_eq
  category: array
  id_prefix: array_idx
  function: array
  method: __getitem__

  columns: [id, args, method_args, expected]
  rows:
    - [first,  ["i", [10, 20, 30]], [0],  10]
    - [middle, ["i", [10, 20, 30]], [1],  20]
    - [last,   ["i", [10, 20, 30]], [2],  30]
    - [neg,    ["i", [10, 20, 30]], [-1], 30]

# typecodes — module-level string constant
invariant array_rust.typecodes.has_i:
  description: "typecodes.__contains__('i') == True"
  category: typecodes
  kind: python_call_eq
  function: typecodes.__contains__
  args: ["i"]
  expected: true

invariant array_rust.typecodes.has_d:
  description: "typecodes.__contains__('d') == True"
  category: typecodes
  kind: python_call_eq
  function: typecodes.__contains__
  args: ["d"]
  expected: true

invariant array_rust.typecodes.has_b:
  description: "typecodes.__contains__('b') == True"
  category: typecodes
  kind: python_call_eq
  function: typecodes.__contains__
  args: ["b"]
  expected: true

