spec: dataclasses_extra31
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses_extra30.zspec.zsdl."
    - "Prior specs covered: dataclass/fields/asdict/astuple/make_dataclass/replace/is_dataclass __name__, Field/__name__/__module__/__qualname__, FrozenInstanceError/__name__/__module__/__bases__[0].__name__, MISSING/__class__.__name__, KW_ONLY, dataclasses.__all__ type/length, __module__.__eq__ for all seven functions, __module__.__len__() for dataclass/Field (both 11), __qualname__ for dataclass/fields/asdict."
    - "This spec covers: __name__.__len__() for dataclass/field/fields/asdict/astuple/make_dataclass/replace/is_dataclass/Field/FrozenInstanceError; __qualname__.__len__() for dataclass/field/fields/asdict/astuple/make_dataclass/replace/is_dataclass."
    - "dataclasses.dataclass.__name__.__len__() == 9 — 'dataclass' has length 9."
    - "dataclasses.field.__name__.__len__() == 5 — 'field' has length 5."
    - "dataclasses.make_dataclass.__name__.__len__() == 14 — 'make_dataclass' has length 14, longest among module-level functions."
    - "dataclasses.FrozenInstanceError.__name__.__len__() == 19 — longest __name__ in the dataclasses public API."
    - "All __qualname__.__len__() values match __name__.__len__() for these module-level symbols."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() table — all module-level functions plus Field and
# FrozenInstanceError (extra31 namespace)
#
# Prior specs record __name__ strings but not their lengths. This table
# assembles the complete name-length picture for the dataclasses public API:
#   dataclass -> 9, field -> 5, fields -> 6, asdict -> 6, astuple -> 7,
#   make_dataclass -> 14, replace -> 7, is_dataclass -> 12,
#   Field -> 5, FrozenInstanceError -> 19.
# FrozenInstanceError (19) is the longest name in the module; make_dataclass
# (14) is the longest among module-level functions.
# ---------------------------------------------------------------------------

table dataclasses_extra31.name_str_lengths:
  description: "__name__.__len__() for dataclasses module-level functions, Field, and FrozenInstanceError"
  kind: python_call_eq
  category: string_properties
  id_prefix: name_len

  columns: [id, function, args, expected]
  rows:
    - [dataclass,          dataclass.__name__.__len__,          [], 9]
    - [field,              field.__name__.__len__,              [], 5]
    - [fields,             fields.__name__.__len__,             [], 6]
    - [asdict,             asdict.__name__.__len__,             [], 6]
    - [astuple,            astuple.__name__.__len__,            [], 7]
    - [make_dataclass,     make_dataclass.__name__.__len__,     [], 14]
    - [replace,            replace.__name__.__len__,            [], 7]
    - [is_dataclass,       is_dataclass.__name__.__len__,       [], 12]
    - [Field,              Field.__name__.__len__,              [], 5]
    - [FrozenInstanceError, FrozenInstanceError.__name__.__len__, [], 19]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — module-level functions (extra31 namespace)
#
# All module-level dataclasses functions are defined at module scope, so
# __qualname__ == __name__ for each. Consequently __qualname__.__len__() is
# identical to __name__.__len__(). This table verifies that equality via the
# __len__ call path for the seven primary module-level functions. No prior
# dataclasses spec records these qualname lengths in the extra31 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra31.qualname_str_lengths:
  description: "__qualname__.__len__() for dataclasses module-level functions — matches __name__.__len__()"
  kind: python_call_eq
  category: string_properties
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__qualname__.__len__,      [], 9]
    - [field,          field.__qualname__.__len__,          [], 5]
    - [fields,         fields.__qualname__.__len__,         [], 6]
    - [asdict,         asdict.__qualname__.__len__,         [], 6]
    - [astuple,        astuple.__qualname__.__len__,        [], 7]
    - [make_dataclass, make_dataclass.__qualname__.__len__, [], 14]
    - [replace,        replace.__qualname__.__len__,        [], 7]
    - [is_dataclass,   is_dataclass.__qualname__.__len__,   [], 12]

# ---------------------------------------------------------------------------
# dataclasses.FrozenInstanceError.__name__.__len__() == 19 — standalone
# (extra31 namespace)
#
# 'FrozenInstanceError' is the longest __name__ in the dataclasses public API
# at 19 characters. It is a subclass of AttributeError raised when a frozen
# dataclass has a field assignment attempted after construction. No prior
# dataclasses spec records this standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra31.FrozenInstanceError.name.len:
  description: "dataclasses.FrozenInstanceError.__name__.__len__() == 19 — longest name in dataclasses public API"
  category: name_attrs
  kind: python_call_eq
  function: FrozenInstanceError.__name__.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# dataclasses.make_dataclass.__name__.__len__() == 14 — standalone
# (extra31 namespace)
#
# 'make_dataclass' has 14 characters, making it the longest name among the
# seven module-level functions. It dynamically creates a new dataclass type
# from a list of field specifications. No prior dataclasses spec records this
# standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra31.make_dataclass.name.len:
  description: "dataclasses.make_dataclass.__name__.__len__() == 14 — longest name among module-level functions"
  category: name_attrs
  kind: python_call_eq
  function: make_dataclass.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# dataclasses.is_dataclass.__qualname__.__len__() == 12 — standalone
# (extra31 namespace)
#
# 'is_dataclass' has 12 characters. As a module-level function its __qualname__
# equals its __name__, both length 12. This confirms the top-level scope of
# is_dataclass and distinguishes it from nested helpers. No prior dataclasses
# spec records this standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra31.is_dataclass.qualname.len:
  description: "dataclasses.is_dataclass.__qualname__.__len__() == 12 — top-level function so qualname equals name"
  category: qualname_attrs
  kind: python_call_eq
  function: is_dataclass.__qualname__.__len__
  args: []
  expected: 12
