    - [re1141er002, re.error.__qualname__.__eq__, ["error"], true]
    - [re1141er003, re.error.__name__.__eq__,     ["error"], true]
    - [re1141er004, re.error.__module__.__eq__,   ["_sre"],  false]
    - [re1141er005, re.error.__module__.__eq__,   ["builtins"], false]
    - [re1141er006, re.error.__name__.__class__.__name__.__eq__,     ["str"],  true]
    - [re1141er007, re.error.__module__.__class__.__name__.__eq__,   ["str"],  true]
    - [re1141er008, re.error.__qualname__.__class__.__name__.__eq__, ["str"],  true]

