  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1141.regexflag_doc_and_module:
  description: "re.RegexFlag __doc__.__class__.__name__ and __module__ checks"
  kind: python_call_eq
  category: regexflag_doc_and_module
  id_prefix: re1141rf
  columns: [id, function, args, expected]
  rows:
    - [re1141rf001, re.RegexFlag.__doc__.__class__.__name__.__eq__,  ["str"],      true]
    - [re1141rf002, re.RegexFlag.__module__.__eq__,                  ["re"],       true]
    - [re1141rf003, re.RegexFlag.__doc__.__class__.__name__.__eq__,  ["bytes"],    false]
    - [re1141rf004, re.RegexFlag.__module__.__eq__,                  ["_sre"],     false]
    - [re1141rf005, re.RegexFlag.__module__.__class__.__name__.__eq__, ["str"],    true]
    - [re1141rf006, re.RegexFlag.__qualname__.__eq__,                ["RegexFlag"], true]
    - [re1141rf007, re.RegexFlag.__name__.__eq__,                    ["RegexFlag"], true]

table re_extra1141.error_class_identity:
