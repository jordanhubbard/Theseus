spec: re_extra300
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.Pattern and re.Match are the public generic aliases for compiled pattern and match objects."
    - "re.Pattern.__name__ == 'Pattern'; re.Match.__name__ == 'Match' — both report clean public names."
    - "re.Pattern.__module__ == 're'; re.Match.__module__ == 're'."
    - "type(re.Pattern).__name__ == 'type' — Pattern is a genuine type (class), not a generic alias."
    - "Compiled pattern .flags is a plain int (value 32 for default re.UNICODE flag); not a RegexFlag enum."
    - "Default compile flags: 32 (re.UNICODE only). With re.IGNORECASE added: 34 (32 | 2)."
    - "re.IGNORECASE integer value: 2."
    - "compile(r'(\w+)').groups == 1 — groups is an int count of capturing groups."
    - "compile(r'\d+').pattern == r'\d+' — pattern attribute stores the original pattern string."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern and re.Match class identity — __name__ and __module__
# ---------------------------------------------------------------------------

table re_extra300.class_names:
  description: "__name__ for re.Pattern and re.Match — public generic alias names"
  kind: python_call_eq
  category: class_names

  columns: [id, function, args, expected]
  rows:
    - [Pattern, Pattern.__name__.__eq__, ["Pattern"], true]
    - [Match,   Match.__name__.__eq__,   ["Match"],   true]

table re_extra300.class_modules:
  description: "__module__ for re.Pattern and re.Match — both report 're'"
  kind: python_call_eq
  category: class_modules

  columns: [id, function, args, expected]
  rows:
    - [Pattern, Pattern.__module__.__eq__, ["re"], true]
    - [Match,   Match.__module__.__eq__,   ["re"], true]

# ---------------------------------------------------------------------------
# type(re.Pattern).__name__ — Pattern is a genuine type
# ---------------------------------------------------------------------------

invariant re_extra300.Pattern.metatype:
  description: "type(re.Pattern).__name__ == 'type' — re.Pattern is a genuine Python type (class)"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Compiled pattern .pattern attribute — stores original pattern string
# ---------------------------------------------------------------------------

invariant re_extra300.compile.pattern_attr:
  description: "re.compile(r'\d+').pattern == r'\d+' — compiled pattern stores the original pattern string"
  category: compiled_pattern
  kind: python_call_eq
  function: compile
  args: ["\\d+"]
  method: pattern.__eq__
  method_args: ["\\d+"]
  expected: true

# ---------------------------------------------------------------------------
# Compiled pattern .flags attribute — plain int, value 32 for default (UNICODE)
# ---------------------------------------------------------------------------

invariant re_extra300.compile.default_flags:
  description: "re.compile(r'\d+').flags == 32 — default compile flags are re.UNICODE (32) only"
  category: compiled_pattern
  kind: python_call_eq
  function: compile
  args: ["\\d+"]
  method: flags.__eq__
  method_args: [32]
  expected: true

# ---------------------------------------------------------------------------
# Compiled pattern .groups attribute — count of capturing groups
# ---------------------------------------------------------------------------

invariant re_extra300.compile.groups_zero:
  description: "re.compile(r'\d+').groups == 0 — no capturing groups in this pattern"
  category: compiled_pattern
  kind: python_call_eq
  function: compile
  args: ["\\d+"]
  method: groups.__eq__
  method_args: [0]
  expected: true

invariant re_extra300.compile.groups_one:
  description: "re.compile(r'(\w+)').groups == 1 — one capturing group"
  category: compiled_pattern
  kind: python_call_eq
  function: compile
  args: ["(\\w+)"]
  method: groups.__eq__
  method_args: [1]
  expected: true
