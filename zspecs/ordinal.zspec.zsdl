spec: ordinal
version: ">=1.0.0"
backend: node(ordinal)

docs: https://www.npmjs.com/package/ordinal

provenance:
  derived_from:
    - "ordinal README — https://www.npmjs.com/package/ordinal"
    - "Test vectors verified with ordinal via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "ordinal source"
  notes:
    - "ordinal is an npm package. Install: npm install ordinal"
    - "ordinal(n) returns the ordinal string for integer n (e.g., 1 → '1st', 2 → '2nd')."
    - "Handles teen exceptions: 11 → '11th', 12 → '12th', 13 → '13th'."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns ordinal string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ordinal.ordinal:
  kind: node_module_call_eq
  function: ~
  category: ordinal
  id_prefix: ord

  columns: [id, args, expected]
  rows:
    - [one,        [1],   "1st"]
    - [two,        [2],   "2nd"]
    - [three,      [3],   "3rd"]
    - [eleven,     [11],  "11th"]
    - [twenty_one, [21],  "21st"]
    - [hundred,    [100], "100th"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:18:25Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
