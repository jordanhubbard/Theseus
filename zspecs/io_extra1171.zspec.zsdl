spec: io_extra1171
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io.__all__ membership checks for IOBase/RawIOBase/FileIO/BytesIO/StringIO/TextIOWrapper/DEFAULT_BUFFER_SIZE/open, io.__all__.__len__, and io.DEFAULT_BUFFER_SIZE.__eq__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io.__all__.__contains__ for IOBase, RawIOBase, FileIO, BytesIO, StringIO, TextIOWrapper, DEFAULT_BUFFER_SIZE, open; io.__all__.__len__() value; io.DEFAULT_BUFFER_SIZE.__eq__(8192); none of these __all__ membership or DEFAULT_BUFFER_SIZE value checks were covered in _extra1141 or _extra1156"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1171.all_contains_abstract_and_concrete:
  description: "io.__all__.__contains__ membership checks for abstract base classes and concrete classes"
  kind: python_call_eq
  category: all_contains_abstract_and_concrete
  id_prefix: io1171ab
  columns: [id, function, args, expected]
  rows:
    - [io1171ab001, io.__all__.__contains__, ["IOBase"],        true]
    - [io1171ab002, io.__all__.__contains__, ["RawIOBase"],     true]
    - [io1171ab003, io.__all__.__contains__, ["BufferedIOBase"], true]
    - [io1171ab004, io.__all__.__contains__, ["TextIOBase"],    true]
    - [io1171ab005, io.__all__.__contains__, ["FileIO"],        true]
    - [io1171ab006, io.__all__.__contains__, ["BytesIO"],       true]
    - [io1171ab007, io.__all__.__contains__, ["StringIO"],      true]
    - [io1171ab008, io.__all__.__contains__, ["TextIOWrapper"], true]
    - [io1171ab009, io.__all__.__contains__, ["_IOBase"],       false]
    - [io1171ab010, io.__all__.__contains__, ["iobase"],        false]

table io_extra1171.all_contains_builtins_and_constants:
  description: "io.__all__.__contains__ checks for DEFAULT_BUFFER_SIZE, open, BufferedReader, BufferedWriter, and non-members"
  kind: python_call_eq
  category: all_contains_builtins_and_constants
  id_prefix: io1171bc
  columns: [id, function, args, expected]
  rows:
    - [io1171bc001, io.__all__.__contains__, ["DEFAULT_BUFFER_SIZE"], true]
    - [io1171bc002, io.__all__.__contains__, ["open"],                true]
    - [io1171bc003, io.__all__.__contains__, ["BufferedReader"],      true]
    - [io1171bc004, io.__all__.__contains__, ["BufferedWriter"],      true]
    - [io1171bc005, io.__all__.__contains__, ["DEFAULT_BUFFER"],      false]
    - [io1171bc006, io.__all__.__contains__, ["BUFFER_SIZE"],         false]
    - [io1171bc007, io.__all__.__contains__, ["open_code"],           false]
    - [io1171bc008, io.__all__.__contains__, ["_open"],               false]

table io_extra1171.default_buffer_size_and_all_len:
  description: "io.DEFAULT_BUFFER_SIZE value equality and io.__all__.__len__ sanity checks"
  kind: python_call_eq
  category: default_buffer_size_and_all_len
  id_prefix: io1171ds
  columns: [id, function, args, expected]
  rows:
    - [io1171ds001, io.DEFAULT_BUFFER_SIZE.__eq__,                   ["8192"], false]
    - [io1171ds002, io.DEFAULT_BUFFER_SIZE.__eq__,                   [8192],   true]
    - [io1171ds003, io.DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"],  true]
    - [io1171ds004, io.DEFAULT_BUFFER_SIZE.__eq__,                   [4096],   false]
    - [io1171ds005, io.DEFAULT_BUFFER_SIZE.__eq__,                   [16384],  false]
    - [io1171ds006, io.__all__.__len__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [io1171ds007, io.DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["str"],  false]
    - [io1171ds008, io.DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["float"], false]
