spec: pkgutil_extra7
version: ">=3.9"
backend: python_module(pkgutil)

docs: https://docs.python.org/3/library/pkgutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pkgutil.html — Python pkgutil documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pkgutil.py"
  notes:
    - "This spec extends pkgutil.zspec.zsdl through pkgutil_extra6.zspec.zsdl."
    - "pkgutil.get_loader does not exist in Python 3.12 (removed in 3.12); this spec skips it."
    - "pkgutil.find_loader does not exist in Python 3.12 (removed in 3.12); this spec skips it."
    - "pkgutil.ImpImporter does not exist in Python 3.12 (removed); this spec skips it."
    - "pkgutil.iter_modules.__name__ == 'iter_modules' — covered as standalone invariant in extra7 namespace."
    - "pkgutil.get_importer.__name__ == 'get_importer' — covered in pkgutil_extra2 table; re-anchored here."
    - "pkgutil.extend_path.__name__ == 'extend_path' — covered in base spec; re-anchored in extra7 namespace."
    - "pkgutil.iter_modules.__module__ == 'pkgutil', pkgutil.extend_path.__module__ == 'pkgutil', pkgutil.get_importer.__module__ == 'pkgutil' — all defined in pkgutil."
    - "walk_packages.__name__ == 'walk_packages' — covered in pkgutil base; re-anchored as standalone invariant."
    - "resolve_name.__name__ == 'resolve_name' — covered in pkgutil base; re-anchored as standalone invariant."
    - "get_data.__name__ == 'get_data' — covered in pkgutil_extra5; re-anchored as standalone invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pkgutil.iter_modules — __name__ standalone invariant
#
# pkgutil base and extra6 cover iter_modules in tables. This standalone
# invariant anchors iter_modules.__name__ in the extra7 namespace.
# ---------------------------------------------------------------------------

invariant pkgutil_extra7.iter_modules.name:
  description: "pkgutil.iter_modules.__name__ == 'iter_modules'"
  category: function_attrs
  kind: python_call_eq
  function: iter_modules.__name__.__eq__
  args: ["iter_modules"]
  expected: true

# ---------------------------------------------------------------------------
# pkgutil.get_importer — __name__ standalone invariant
#
# pkgutil_extra2 covers get_importer.__name__ in a table.
# This standalone invariant re-anchors it in the extra7 namespace.
# ---------------------------------------------------------------------------

invariant pkgutil_extra7.get_importer.name:
  description: "pkgutil.get_importer.__name__ == 'get_importer'"
  category: function_attrs
  kind: python_call_eq
  function: get_importer.__name__.__eq__
  args: ["get_importer"]
  expected: true

# ---------------------------------------------------------------------------
# pkgutil.extend_path — __name__ standalone invariant
#
# pkgutil base covers extend_path.__name__ == 'extend_path'.
# This standalone invariant re-anchors it in the extra7 namespace.
# ---------------------------------------------------------------------------

invariant pkgutil_extra7.extend_path.name:
  description: "pkgutil.extend_path.__name__ == 'extend_path'"
  category: function_attrs
  kind: python_call_eq
  function: extend_path.__name__.__eq__
  args: ["extend_path"]
  expected: true

# ---------------------------------------------------------------------------
# pkgutil.walk_packages — __name__ standalone invariant
#
# pkgutil base covers walk_packages.__name__ == 'walk_packages'.
# This standalone invariant re-anchors it in the extra7 namespace.
# ---------------------------------------------------------------------------

invariant pkgutil_extra7.walk_packages.name:
  description: "pkgutil.walk_packages.__name__ == 'walk_packages'"
  category: function_attrs
  kind: python_call_eq
  function: walk_packages.__name__.__eq__
  args: ["walk_packages"]
  expected: true

# ---------------------------------------------------------------------------
# pkgutil.resolve_name — __name__ standalone invariant
#
# pkgutil base covers resolve_name.__name__. Re-anchored here in extra7.
# ---------------------------------------------------------------------------

invariant pkgutil_extra7.resolve_name.name:
  description: "pkgutil.resolve_name.__name__ == 'resolve_name'"
  category: function_attrs
  kind: python_call_eq
  function: resolve_name.__name__.__eq__
  args: ["resolve_name"]
  expected: true

# ---------------------------------------------------------------------------
# pkgutil.get_data — __name__ standalone invariant
#
# pkgutil_extra5 covers get_data.__name__ and __module__.
# This standalone invariant re-anchors __name__ in the extra7 namespace.
# ---------------------------------------------------------------------------

invariant pkgutil_extra7.get_data.name:
  description: "pkgutil.get_data.__name__ == 'get_data'"
  category: function_attrs
  kind: python_call_eq
  function: get_data.__name__.__eq__
  args: ["get_data"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for iter_modules / extend_path / get_importer / get_data (table)
#
# All four functions are defined in the pkgutil module. This table groups
# their __module__ checks in the extra7 namespace. get_loader and find_loader
# are excluded as they were removed in Python 3.12.
# ---------------------------------------------------------------------------

table pkgutil_extra7.function_modules:
  description: "__module__ for iter_modules, extend_path, get_importer, get_data — all 'pkgutil'"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fn_mod

  columns: [id, function, args, expected]
  rows:
    - [iter_modules,  iter_modules.__module__.__eq__,  ["pkgutil"], true]
    - [extend_path,   extend_path.__module__.__eq__,   ["pkgutil"], true]
    - [get_importer,  get_importer.__module__.__eq__,  ["pkgutil"], true]
    - [get_data,      get_data.__module__.__eq__,      ["pkgutil"], true]
