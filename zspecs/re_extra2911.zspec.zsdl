    - ["re2911009", "type(re.match('', '')).__dict__.__contains__",          ["__irshift__"], false]
    - ["re2911010", "re.RegexFlag.__dict__.__contains__",                    ["__rshift__"],  false]
    - ["re2911011", "type(re.compile('')).__dict__.__contains__",            ["__rshift__"],  false]
