# ---------------------------------------------------------------------------
# Table: combined — all three in-place shift/power ops absent from all re types
# Contrasts with wave 638 where RegexFlag uniquely owned reflected bitwise ops (__ror__, __rand__, __rxor__)
# ---------------------------------------------------------------------------

table re2911.combined:
  description: "re.RegexFlag (IntFlag), Pattern, and Match all lack in-place shift/power ops — IntFlag's in-place support is bitwise OR/AND/XOR only, not shifts or powers"
  kind: python_call_eq
