spec: re2911
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/re_extra2896.zspec.zsdl — wave 640 predecessor (covered __itruediv__, __ifloordiv__, __imod__)"
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "Wave 641 theme: __ilshift__, __irshift__, __ipow__ dict-presence checks (in-place left-shift, right-shift, power operators)."
    - "re.RegexFlag is an IntFlag subclass — IntFlag provides bitwise OR/AND/XOR in-place ops via EnumType, but does NOT define __ilshift__, __irshift__, or __ipow__."
    - "re.RegexFlag also lacks the non-inplace __lshift__, __rshift__, and __pow__ — IntFlag's integer-like behavior does not extend to shifts or powers."
    - "re.Pattern (type(re.compile(''))) does NOT define any of these operators — compiled pattern objects are not numeric operands."
    - "re.Match (type(re.match('',''))) does NOT define any of these operators — match objects carry match state, not arithmetic values."
    - "In wave 638, RegexFlag's reflected bitwise ops (__ror__, __rand__, __rxor__) were confirmed True. Shifts and powers are a different matter."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __ilshift__ dict-presence
# RegexFlag: False; Pattern and Match: False — no bitwise left-shift semantics on re types
# ---------------------------------------------------------------------------

table re2911.ilshift:
  description: "__ilshift__ is absent from re.RegexFlag (IntFlag has no in-place left-shift), Pattern, and Match"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2911

  columns: [id, function, args, expected]
  rows:
    - ["re2911001", "re.RegexFlag.__dict__.__contains__",                    ["__ilshift__"], false]
    - ["re2911002", "type(re.compile('')).__dict__.__contains__",            ["__ilshift__"], false]
    - ["re2911003", "type(re.match('', '')).__dict__.__contains__",          ["__ilshift__"], false]
    - ["re2911004", "re.RegexFlag.__dict__.__contains__",                    ["__lshift__"],  false]
    - ["re2911005", "type(re.compile('')).__dict__.__contains__",            ["__lshift__"],  false]
    - ["re2911006", "type(re.match('', '')).__dict__.__contains__",          ["__lshift__"],  false]

