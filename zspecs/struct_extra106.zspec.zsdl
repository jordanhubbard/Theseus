spec: struct_extra106
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra105.zspec.zsdl — covers struct.__spec__ attributes (name, __class__.__name__) / struct.__name__ and __package__ equality and lengths / struct.error method qualnames (__init__=BaseException.__init__, __str__=BaseException.__str__) and init type (wrapper_descriptor) (table + invariants)."
    - "struct_extra104.zspec.zsdl — covers Struct.size/format getset_descriptor qualnames and __objclass__ / module-level function qualname equality for all six functions / iter_unpack qualname and function module equality (table + invariants)."
    - "struct_extra103.zspec.zsdl — covers calcsize for compound format strings / repeat-count formats / fixed-size string formats / struct module attribute checks (table + invariants)."
    - "struct_extra102.zspec.zsdl — covers calcsize for single-char format codes and two-element composites (table + invariants)."
    - "struct_extra101.zspec.zsdl — covers struct.error class identity (__name__/__module__/__bases__[0].__name__/__mro__.__len__()==4/__class__.__name__=='type') / Struct class attribute equality / Struct method types and instance size (table + invariants)."
    - "struct_extra100.zspec.zsdl — covers Struct instance method qualname lengths / module-level function qualname lengths / Struct class-level method_descriptor type names (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers module-level function __doc__ lengths / Struct.size/__format__ __doc__ equality and lengths (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra105; it does NOT duplicate invariants present in those files."
    - "Wave 271 theme: struct.Struct class-level method qualnames — pack, unpack, pack_into, unpack_from, iter_unpack — use 'Struct.method' prefix; all are method_descriptor type; Struct.__init__ is wrapper_descriptor with qualname 'Struct.__init__'."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('Struct.pack') == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('Struct.unpack') == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('Struct.pack_into') == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('Struct.unpack_from') == 18. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('Struct.iter_unpack') == 18. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(struct.Struct.pack).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(struct.Struct.unpack).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__qualname__ == 'Struct.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(struct.Struct.__init__).__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len('Struct.__init__') == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct class-level methods (pack, unpack, pack_into, unpack_from, iter_unpack) are method_descriptor objects (C-level, from _struct.c). Their qualnames use the 'Struct.' prefix (the class name is 'Struct' with capital S). struct_extra104 anchors module-level function qualname equality; this spec anchors the Struct class-level method qualnames as equality checks for the first time."
    - "Note: struct.Struct.__init__ is a wrapper_descriptor (not a method_descriptor) because Struct uses the standard C type init mechanism. Its qualname is 'Struct.__init__' (15 chars). The other five methods (pack, unpack, pack_into, unpack_from, iter_unpack) are method_descriptor type."
    - "Note: struct_extra100 anchors Struct class-level method_descriptor type names and Struct instance method qualname lengths. struct_extra95 anchors Struct.__qualname__.__len__()==6. This spec anchors the Struct class-level method qualname string equality for pack/unpack/pack_into/unpack_from/iter_unpack for the first time."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack')
# struct.Struct.unpack.__qualname__.__eq__('Struct.unpack')
# struct.Struct.pack.__qualname__.__len__()==11
# struct.Struct.unpack.__qualname__.__len__()==13
# type(struct.Struct.pack).__name__.__eq__('method_descriptor')
#
# Wave 271 theme: Struct.pack and Struct.unpack qualname string equality.
#
# struct.Struct.pack and struct.Struct.unpack are method_descriptor objects
# at the class level. Their qualnames are 'Struct.pack' (11 chars: 'Struct.'=7
# + 'pack'=4) and 'Struct.unpack' (13 chars: 'Struct.'=7 + 'unpack'=6).
# The 'Struct.' prefix (capital S) reflects that the class name is 'Struct'.
# struct_extra100 anchors Struct class-level method_descriptor type names and
# Struct instance method qualname lengths; this spec anchors the class-level
# qualname string equality for pack and unpack as a new grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra106.Struct_pack_and_unpack_qualname_equality:
  description: "Struct.pack.__qualname__.__eq__('Struct.pack')==True / Struct.unpack.__qualname__.__eq__('Struct.unpack')==True / Struct.pack.__qualname__.__len__()==11 / Struct.unpack.__qualname__.__len__()==13 / type(Struct.pack).__name__.__eq__('method_descriptor')==True — pack and unpack are C-level method_descriptors; qualnames use 'Struct.' prefix (capital S class name); pack=11 chars ('Struct.'=7+'pack'=4); unpack=13 chars ('Struct.'=7+'unpack'=6); extra100 anchors type names; first structqual106 anchor"
  kind: python_call_eq
  category: method_identity
  id_prefix: structqual106

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qualname_eq,     "Struct.pack.__qualname__.__eq__",              ["Struct.pack"],   true, "Struct.pack.__qualname__ is 'Struct.pack' (11 chars; 'Struct.'=7 + 'pack'=4; C-level method_descriptor in _struct)"]
    - [unpack_qualname_eq,   "Struct.unpack.__qualname__.__eq__",            ["Struct.unpack"], true, "Struct.unpack.__qualname__ is 'Struct.unpack' (13 chars; 'Struct.'=7 + 'unpack'=6; C-level method_descriptor)"]
    - [pack_qualname_len,    "Struct.pack.__qualname__.__len__",             [],                11,   "Struct.pack.__qualname__.__len__() is 11 ('Struct.pack': 'Struct.'=7 + 'pack'=4)"]
    - [unpack_qualname_len,  "Struct.unpack.__qualname__.__len__",           [],                13,   "Struct.unpack.__qualname__.__len__() is 13 ('Struct.unpack': 'Struct.'=7 + 'unpack'=6)"]
    - [pack_type_eq,         "Struct.pack.__class__.__name__.__eq__",        ["method_descriptor"], true, "type(Struct.pack) is 'method_descriptor' (C-level method on Struct class from _struct.c; not a Python function)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into')
# struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from')
# struct.Struct.pack_into.__qualname__.__len__()==16
# struct.Struct.unpack_from.__qualname__.__len__()==18
# struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into')
#
# Wave 271 theme: Struct.pack_into and Struct.unpack_from qualname string equality.
#
# struct.Struct.pack_into.__qualname__ is 'Struct.pack_into' (16 chars: 'Struct.'=7 +
# 'pack_into'=9). struct.Struct.unpack_from.__qualname__ is 'Struct.unpack_from'
# (18 chars: 'Struct.'=7 + 'unpack_from'=11). unpack_from (18 chars) has the same
# length as iter_unpack (also 18 chars). pack_into (16 chars) is the second-longest
# after unpack_from/iter_unpack. No prior struct spec anchors Struct.pack_into or
# Struct.unpack_from qualname equality as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra106.Struct_pack_into_and_unpack_from_qualname_equality:
  description: "Struct.pack_into.__qualname__.__eq__('Struct.pack_into')==True / Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from')==True / Struct.pack_into.__qualname__.__len__()==16 / Struct.unpack_from.__qualname__.__len__()==18 / type(Struct.unpack_from).__name__.__eq__('method_descriptor')==True — pack_into is 16 chars ('Struct.'=7+'pack_into'=9); unpack_from is 18 chars ('Struct.'=7+'unpack_from'=11; same length as iter_unpack); both are method_descriptor; no prior spec anchors these qualname equalities; first structqual106 anchor"
  kind: python_call_eq
  category: method_identity
  id_prefix: structqual106

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_qualname_eq,    "Struct.pack_into.__qualname__.__eq__",           ["Struct.pack_into"],   true, "Struct.pack_into.__qualname__ is 'Struct.pack_into' (16 chars; 'Struct.'=7 + 'pack_into'=9; writes packed data into buffer)"]
    - [unpack_from_qualname_eq,  "Struct.unpack_from.__qualname__.__eq__",         ["Struct.unpack_from"], true, "Struct.unpack_from.__qualname__ is 'Struct.unpack_from' (18 chars; 'Struct.'=7 + 'unpack_from'=11; reads from buffer at offset)"]
    - [pack_into_qualname_len,   "Struct.pack_into.__qualname__.__len__",          [],                     16,   "Struct.pack_into.__qualname__.__len__() is 16 ('Struct.pack_into': 'Struct.'=7 + 'pack_into'=9)"]
    - [unpack_from_qualname_len, "Struct.unpack_from.__qualname__.__len__",        [],                     18,   "Struct.unpack_from.__qualname__.__len__() is 18 ('Struct.unpack_from': 'Struct.'=7 + 'unpack_from'=11)"]
    - [unpack_from_type_eq,      "Struct.unpack_from.__class__.__name__.__eq__",   ["method_descriptor"],  true, "type(Struct.unpack_from) is 'method_descriptor' (C-level method from _struct.c; reads from buffer at given offset)"]

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack')
# struct.Struct.iter_unpack.__qualname__.__len__()==18
# struct.Struct.__init__.__qualname__.__eq__('Struct.__init__')
# type(struct.Struct.__init__).__name__.__eq__('wrapper_descriptor')
# struct.Struct.__init__.__qualname__.__len__()==15
#
# Wave 271 theme: Struct.iter_unpack qualname and Struct.__init__ qualname/type.
#
# struct.Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack' (18 chars:
# 'Struct.'=7 + 'iter_unpack'=11). This has the same length as 'Struct.unpack_from'
# (also 18 chars). struct.Struct.__init__ has type wrapper_descriptor (not
# method_descriptor) and qualname 'Struct.__init__' (15 chars). The wrapper_descriptor
# type distinguishes __init__ from the other Struct methods which are method_descriptor.
# No prior struct spec anchors Struct.iter_unpack or Struct.__init__ qualname
# equality in a grouped table. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra106.Struct_iter_unpack_and_init_qualname_type:
  description: "Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack')==True / Struct.iter_unpack.__qualname__.__len__()==18 / Struct.__init__.__qualname__.__eq__('Struct.__init__')==True / type(Struct.__init__).__name__.__eq__('wrapper_descriptor')==True / Struct.__init__.__qualname__.__len__()==15 — iter_unpack is 18 chars (same length as unpack_from); __init__ is wrapper_descriptor (not method_descriptor); __init__ qualname is 15 chars ('Struct.'=7+'__init__'=8); no prior spec anchors these; first structqual106 anchor"
  kind: python_call_eq
  category: method_identity
  id_prefix: structqual106

  columns: [id, function, args, expected, description]
  rows:
    - [iter_unpack_qualname_eq,  "Struct.iter_unpack.__qualname__.__eq__",        ["Struct.iter_unpack"], true, "Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack' (18 chars; 'Struct.'=7 + 'iter_unpack'=11; returns iterator)"]
    - [iter_unpack_qualname_len, "Struct.iter_unpack.__qualname__.__len__",       [],                     18,   "Struct.iter_unpack.__qualname__.__len__() is 18 ('Struct.iter_unpack': same length as 'Struct.unpack_from')"]
    - [init_qualname_eq,         "Struct.__init__.__qualname__.__eq__",           ["Struct.__init__"],    true, "Struct.__init__.__qualname__ is 'Struct.__init__' (15 chars; 'Struct.'=7 + '__init__'=8)"]
    - [init_type_wrapper,        "Struct.__init__.__class__.__name__.__eq__",     ["wrapper_descriptor"], true, "type(Struct.__init__) is 'wrapper_descriptor' (not method_descriptor; distinguishes __init__ from pack/unpack/etc.)"]
    - [init_qualname_len,        "Struct.__init__.__qualname__.__len__",          [],                     15,   "Struct.__init__.__qualname__.__len__() is 15 ('Struct.__init__': 'Struct.'=7 + '__init__'=8)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack') — standalone
#
# struct.Struct.pack.__qualname__ is 'Struct.pack' (11 chars). The Struct.pack
# method is the class-level method_descriptor for packing values into bytes
# according to the Struct's format string. Its qualname uses the 'Struct.' prefix
# (capital S), reflecting that the class name is 'Struct'. This contrasts with
# the module-level struct.pack function whose qualname is 'pack' (without prefix).
# struct_extra104 anchors module-level pack qualname equality; struct_extra100
# anchors Struct.pack method_descriptor type name; this spec anchors the
# Struct.pack qualname equality as a standalone under structqual106.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra106.Struct_pack_qualname_eq:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — qualname is 'Struct.pack' (11 chars; 'Struct.'=7 + 'pack'=4); class-level method_descriptor; contrasts with module-level struct.pack whose qualname is 'pack' (no prefix); extra104 anchors module-level pack qualname; extra100 anchors Struct.pack type name; first standalone under structqual106"
  category: method_identity
  kind: python_call_eq
  function: "Struct.pack.__qualname__.__eq__"
  args: ["Struct.pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.unpack.__qualname__.__eq__('Struct.unpack') — standalone
#
# struct.Struct.unpack.__qualname__ is 'Struct.unpack' (13 chars: 'Struct.'=7 +
# 'unpack'=6). Struct.unpack reads and interprets packed bytes according to the
# Struct format string, returning a tuple. Its qualname length (13) is 2 more
# than pack (11) because 'unpack' has 6 chars vs 'pack' with 4 chars. The module-
# level struct.unpack has qualname 'unpack' (6 chars, no prefix). No prior struct
# spec anchors Struct.unpack qualname equality as a standalone under structqual106.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra106.Struct_unpack_qualname_eq:
  description: "struct.Struct.unpack.__qualname__.__eq__('Struct.unpack') == True — qualname is 'Struct.unpack' (13 chars; 'Struct.'=7 + 'unpack'=6); 2 chars longer than Struct.pack qualname (11); class-level method_descriptor; module-level struct.unpack has qualname 'unpack' (no prefix); first standalone under structqual106"
  category: method_identity
  kind: python_call_eq
  function: "Struct.unpack.__qualname__.__eq__"
  args: ["Struct.unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into') — standalone
#
# struct.Struct.pack_into.__qualname__ is 'Struct.pack_into' (16 chars: 'Struct.'=7 +
# 'pack_into'=9). Struct.pack_into writes packed bytes directly into a writable
# buffer (e.g., bytearray or memoryview) at a given offset — avoiding a new
# bytes allocation. This is useful for efficiency when writing into pre-allocated
# buffers. Its qualname (16 chars) is 5 chars longer than Struct.pack (11 chars)
# due to the '_into' suffix (5 chars). struct_extra95 anchors pack_into qualname
# length; this spec anchors the string equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra106.Struct_pack_into_qualname_eq:
  description: "struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into') == True — qualname is 'Struct.pack_into' (16 chars; 'Struct.'=7 + 'pack_into'=9); pack_into writes directly into buffer (no new bytes allocation); 5 chars longer than Struct.pack (11) due to '_into' suffix; extra95 anchors qualname length; first standalone under structqual106"
  category: method_identity
  kind: python_call_eq
  function: "Struct.pack_into.__qualname__.__eq__"
  args: ["Struct.pack_into"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') — standalone
#
# struct.Struct.unpack_from.__qualname__ is 'Struct.unpack_from' (18 chars:
# 'Struct.'=7 + 'unpack_from'=11). Struct.unpack_from reads from a buffer at a
# given byte offset without requiring the buffer to be sliced. This is efficient
# for reading from large binary buffers at arbitrary positions. Its qualname length
# (18) ties with Struct.iter_unpack (also 18 chars) as the longest Struct class-
# level method qualnames. The '_from' suffix (5 chars) makes unpack_from 5 chars
# longer than unpack (13 chars). struct_extra95 anchors unpack_from qualname
# length; this spec anchors the equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra106.Struct_unpack_from_qualname_eq:
  description: "struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') == True — qualname is 'Struct.unpack_from' (18 chars; 'Struct.'=7 + 'unpack_from'=11); reads from buffer at offset (no slicing needed); tied with iter_unpack as longest Struct class-level method qualname; 5 chars longer than Struct.unpack (13) due to '_from' suffix; extra95 anchors qualname length; first standalone under structqual106"
  category: method_identity
  kind: python_call_eq
  function: "Struct.unpack_from.__qualname__.__eq__"
  args: ["Struct.unpack_from"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') — standalone
#
# struct.Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack' (18 chars:
# 'Struct.'=7 + 'iter_unpack'=11). Struct.iter_unpack returns an iterator that
# reads successive packed items from a buffer. The buffer must be a multiple of
# the struct size. This is useful for reading arrays of uniform binary records.
# Its qualname length (18) ties with Struct.unpack_from as the longest Struct
# class-level method qualnames. struct_extra95 anchors iter_unpack qualname length;
# struct_extra104 anchors module-level iter_unpack qualname equality; this spec
# anchors Struct.iter_unpack class-level qualname equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra106.Struct_iter_unpack_qualname_eq:
  description: "struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') == True — qualname is 'Struct.iter_unpack' (18 chars; 'Struct.'=7 + 'iter_unpack'=11); returns iterator over successive packed items in buffer; tied with Struct.unpack_from as longest Struct method qualname (both 18 chars); extra95 anchors qualname length; extra104 anchors module-level iter_unpack equality; first standalone for class-level under structqual106"
  category: method_identity
  kind: python_call_eq
  function: "Struct.iter_unpack.__qualname__.__eq__"
  args: ["Struct.iter_unpack"]
  expected: true
