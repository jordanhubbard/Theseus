spec: compute_max
version: ">=1.0.1"
backend: node(compute-max)

docs: https://www.npmjs.com/package/compute-max

provenance:
  derived_from:
    - "compute-max README — https://www.npmjs.com/package/compute-max"
    - "Test vectors verified with compute-max via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "compute-max source"
  notes:
    - "compute-max is an npm package. Install: npm install compute-max"
    - "Returns the maximum value of an array of numbers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table compute_max.max:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: cmax

  columns: [id, args, expected]
  rows:
    - [five,  [[3, 1, 4, 1, 5]],  5]
    - [one,   [[7]],              7]
    - [neg,   [[-3, -1, -2]],     -1]
