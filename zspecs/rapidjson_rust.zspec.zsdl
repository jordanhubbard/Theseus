spec: rapidjson_rust
version: ">=3.9"
backend: rust_module(rapidjson_rust)

docs: https://python-rapidjson.readthedocs.io/

provenance:
  derived_from:
    - "https://python-rapidjson.readthedocs.io/ — python-rapidjson"
  notes:
    - "python-rapidjson is a fast JSON encoder/decoder."
    - "rapidjson.dumps({'a': 1}) produces valid JSON."
    - "rapidjson.loads('{\"a\": 1}') == {'a': 1}."
    - "rapidjson.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant rapidjson_rust.roundtrip:
  description: "loads(dumps({'a':1})) == {'a':1}"
  category: roundtrip
  kind: python_call_eq
  function: rapidjson_roundtrip
  args: []
  expected: true

invariant rapidjson_rust.has_dumps:
  description: "rapidjson has dumps function"
  category: presence
  kind: python_call_eq
  function: rapidjson_has_dumps
  args: []
  expected: true

invariant rapidjson_rust.version_nonempty:
  description: "rapidjson.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: rapidjson_version_nonempty
  args: []
  expected: true

