spec: asyncio_extra1426
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio queue documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio tasks documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py, Lib/asyncio/queues.py, Lib/asyncio/tasks.py, Lib/asyncio/taskgroups.py"
  notes:
    - "Wave 542 (_extra1426): focuses on __format__ and __dir__ method type and dict-presence checks for asyncio classes."
    - "All asyncio sync primitive classes (Queue, Task, Future, Lock, Event, Semaphore, Barrier, TaskGroup) have __format__ with type 'method_descriptor'."
    - "All asyncio sync primitive classes have __dir__ with type 'method_descriptor'."
    - "None of these classes define __format__ or __dir__ in their own __dict__ — both are inherited from object."
    - "asyncio.Queue.__format__.__class__.__name__ == 'method_descriptor'; '__format__' not in asyncio.Queue.__dict__."
    - "asyncio.Task.__format__.__class__.__name__ == 'method_descriptor'; '__format__' not in asyncio.Task.__dict__."
    - "asyncio.Future.__format__.__class__.__name__ == 'method_descriptor'; '__format__' not in asyncio.Future.__dict__."
    - "asyncio.Lock.__dir__.__class__.__name__ == 'method_descriptor'; '__dir__' not in asyncio.Lock.__dict__."
    - "asyncio.Event.__dir__.__class__.__name__ == 'method_descriptor'; '__dir__' not in asyncio.Event.__dict__."
    - "asyncio.Semaphore.__dir__.__class__.__name__ == 'method_descriptor'; '__dir__' not in asyncio.Semaphore.__dict__."
    - "asyncio.Barrier.__format__.__class__.__name__ == 'method_descriptor'; asyncio.TaskGroup.__format__.__class__.__name__ == 'method_descriptor'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra1426.format_class_name:
  description: "asyncio class __format__.__class__.__name__ identity checks — all asyncio sync primitive classes inherit __format__ from object hierarchy; type is 'method_descriptor' for all pure-Python class types; none define __format__ in their own __dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: format_class_name
  id_prefix: as1426fm
  columns: [id, function, args, expected]
  rows:
    - [as1426fm001, asyncio.Queue.__format__.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [as1426fm002, asyncio.Task.__format__.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [as1426fm003, asyncio.Future.__format__.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [as1426fm004, asyncio.Lock.__format__.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [as1426fm005, asyncio.Event.__format__.__class__.__name__.__eq__,     ["method_descriptor"], true]
    - [as1426fm006, asyncio.Semaphore.__format__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [as1426fm007, asyncio.Barrier.__format__.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [as1426fm008, asyncio.TaskGroup.__format__.__class__.__name__.__eq__, ["method_descriptor"], true]

table asyncio_extra1426.format_not_in_dict:
