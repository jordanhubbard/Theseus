spec: typing_extra19
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 484 — Type Hints"
    - "PEP 544 — Protocols: Structural subtyping (static duck typing)"
    - "PEP 589 — TypedDict: Type Hints for Dictionaries with a Fixed Set of Keys"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing.zspec.zsdl through typing_extra18.zspec.zsdl."
    - "typing_extra18 covers: __qualname__.__len__() for no_type_check/no_type_check_decorator/final/assert_never/assert_type/is_typeddict/get_overloads/overload/cast/runtime_checkable; standalone __qualname__.__eq__ for no_type_check_decorator/get_overloads/is_typeddict."
    - "typing_extra17 covers: TypeVar/ParamSpec/TypeVarTuple/Protocol __name__.__len__; TypeVarTuple MRO/bases; ParamSpec MRO; Protocol.__bases__[0]; get_type_hints/__qualname__.__len__."
    - "typing_extra15 covers: TypeVar bases; Protocol __name__/__module__/__qualname__; NamedTuple/__name__; TypedDict/__name__; get_args/__qualname__; get_origin/__qualname__; cast/__qualname__."
    - "typing_extra7 covers: TypeVarTuple/__qualname__; Generic/__qualname__; Protocol/__qualname__; TypedDict/__qualname__; NamedTuple/__qualname__; get_type_hints/__qualname__; cast/__qualname__; overload/__qualname__."
    - "Focus of this spec: __name__.__len__() for Generic, NamedTuple, TypedDict, cast, get_type_hints — no prior spec covers these lengths; __qualname__.__len__() for Generic, NamedTuple, TypedDict — no prior spec covers these."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for Generic, NamedTuple, TypedDict
#
# typing_extra17 covers TypeVar/ParamSpec/TypeVarTuple/Protocol name lengths.
# typing_extra15 covers NamedTuple/__name__.__eq__ and TypedDict/__name__.__eq__.
# typing_extra2 and typing_extra cover Generic.__name__.__eq__.
# No prior spec checks __name__.__len__() for Generic, NamedTuple, or TypedDict.
# Lengths: Generic='Generic'=7, NamedTuple='NamedTuple'=10, TypedDict='TypedDict'=9.
# ---------------------------------------------------------------------------

table typing_extra19.class_name_lengths:
  kind: python_call_eq
  category: class_names
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [Generic,    Generic.__name__.__len__,    [], 7]
    - [NamedTuple, NamedTuple.__name__.__len__, [], 10]
    - [TypedDict,  TypedDict.__name__.__len__,  [], 9]

# ---------------------------------------------------------------------------
# __name__.__len__() for cast and get_type_hints
#
# typing_extra17 covers get_type_hints.__qualname__.__len__() == 14.
# typing_extra12 covers cast.__name__ == 'cast' (extra12 covers cast.__name__).
# No prior spec checks cast.__name__.__len__() or get_type_hints.__name__.__len__().
# Lengths: cast='cast'=4, get_type_hints='get_type_hints'=14.
# For top-level functions __name__ == __qualname__ so lengths match.
# ---------------------------------------------------------------------------

invariant typing_extra19.cast.name_len:
  description: "typing.cast.__name__.__len__() == 4 — 'cast' is 4 characters"
  category: function_names
  kind: python_call_eq
  function: cast.__name__.__len__
  args: []
  expected: 4

invariant typing_extra19.get_type_hints.name_len:
  description: "typing.get_type_hints.__name__.__len__() == 14 — 'get_type_hints' is 14 characters"
  category: function_names
  kind: python_call_eq
  function: get_type_hints.__name__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# __qualname__.__len__() for Generic, NamedTuple, TypedDict
#
# typing_extra7 covers Generic/__qualname__.__eq__, NamedTuple/__qualname__.__eq__,
# TypedDict/__qualname__.__eq__ in a table. No prior spec checks the
# __qualname__.__len__() for any of these three. For top-level classes and
# factory functions, __qualname__ == __name__ so lengths match the name lengths.
# Lengths: Generic=7, NamedTuple=10, TypedDict=9.
# ---------------------------------------------------------------------------

table typing_extra19.class_qualname_lengths:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualnamelen

  columns: [id, function, args, expected]
  rows:
    - [Generic,    Generic.__qualname__.__len__,    [], 7]
    - [NamedTuple, NamedTuple.__qualname__.__len__, [], 10]
    - [TypedDict,  TypedDict.__qualname__.__len__,  [], 9]

# ---------------------------------------------------------------------------
# Generic.__name__.__len__() standalone
#
# The table above checks Generic.__name__.__len__(). This standalone invariant
# re-verifies it outside the table for isolated machine-readable indexing.
# Note: typing_extra and typing_extra2 cover Generic.__name__.__eq__ as standalone
# invariants; no prior spec checks Generic.__name__.__len__() as standalone.
# 'Generic' is 7 characters.
# ---------------------------------------------------------------------------

invariant typing_extra19.Generic.name_len_standalone:
  description: "typing.Generic.__name__.__len__() == 7 — 'Generic' is 7 characters (standalone)"
  category: class_names
  kind: python_call_eq
  function: Generic.__name__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# NamedTuple.__qualname__.__eq__ standalone
#
# typing_extra7 covers NamedTuple.__qualname__.__eq__ in a table alongside
# other classes. No prior spec has it as a standalone invariant.
# For a top-level factory function __qualname__ == __name__ == 'NamedTuple'.
# ---------------------------------------------------------------------------

invariant typing_extra19.NamedTuple.qualname_eq:
  description: "typing.NamedTuple.__qualname__ == 'NamedTuple' — factory function qualname equals name (standalone)"
  category: qualnames
  kind: python_call_eq
  function: NamedTuple.__qualname__.__eq__
  args: ["NamedTuple"]
  expected: true

# ---------------------------------------------------------------------------
# TypedDict.__qualname__.__eq__ standalone
#
# typing_extra7 covers TypedDict.__qualname__.__eq__ in a table. No prior spec
# has it as a standalone invariant. TypedDict is defined as a function or class
# at the module level; its __qualname__ equals 'TypedDict'.
# ---------------------------------------------------------------------------

invariant typing_extra19.TypedDict.qualname_eq:
  description: "typing.TypedDict.__qualname__ == 'TypedDict' — top-level qualname equals name (standalone)"
  category: qualnames
  kind: python_call_eq
  function: TypedDict.__qualname__.__eq__
  args: ["TypedDict"]
  expected: true

# ---------------------------------------------------------------------------
# get_type_hints.__qualname__.__eq__ standalone
#
# typing_extra7 covers get_type_hints.__qualname__.__eq__ in a combined table.
# typing_extra17 covers get_type_hints.__qualname__.__len__() == 14.
# No prior spec has get_type_hints.__qualname__.__eq__ as an individual
# standalone invariant (not in a table). For a top-level function,
# __qualname__ == __name__ == 'get_type_hints'.
# ---------------------------------------------------------------------------

invariant typing_extra19.get_type_hints.qualname_eq:
  description: "typing.get_type_hints.__qualname__ == 'get_type_hints' — standalone boolean invariant"
  category: function_names
  kind: python_call_eq
  function: get_type_hints.__qualname__.__eq__
  args: ["get_type_hints"]
  expected: true
