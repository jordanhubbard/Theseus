spec: copy_extra14
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
    - "copy_extra13.zspec.zsdl — covers copy/__name__/module standalone; deepcopy/__name__/module standalone; error/__name__/base_name; copy/deepcopy of dict {'a':1}"
    - "copy_extra12.zspec.zsdl — covers copy/deepcopy __name__ table; copy/deepcopy __module__ standalone; error.__qualname__; error.__bases__.__getitem__(0).__name__; copy/deepcopy of [1,2,3]"
    - "copy_extra11.zspec.zsdl — covers copy/__name__/__module__; deepcopy/__name__/__module__; Error/__name__/__module__/__bases__; copy/deepcopy of 42/'hello'/True/[]"
    - "copy_extra6.zspec.zsdl — covers copy/__qualname__/deepcopy/__qualname__/Error/__qualname__; Error.__bases__[0].__name__; Error.__class__.__name__"
  notes:
    - "This spec extends copy.zspec.zsdl through copy_extra13.zspec.zsdl."
    - "NEW: table of __class__.__name__ for copy, deepcopy, Error — verifying function vs. type identity."
    - "NEW: copy.copy.__qualname__ standalone (extra14 namespace); copy.deepcopy.__qualname__ standalone (extra14 namespace)."
    - "NEW: copy/deepcopy of tuple (1,2,3) behavioral invariants."
    - "copy.copy.__class__.__name__ == 'function' — copy.copy is a regular Python function, not a builtin."
    - "copy.deepcopy.__class__.__name__ == 'function' — copy.deepcopy is a regular Python function."
    - "copy.Error.__class__.__name__ == 'type' — copy.Error is a class (type object)."
    - "copy.copy((1,2,3)) == (1,2,3) — shallow copy of a tuple equals the original by value."
    - "copy.deepcopy((1,2,3)) == (1,2,3) — deep copy of a tuple equals the original by value."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# copy and deepcopy — __qualname__ (extra14 namespace)
#
# copy_extra6 covers __qualname__ for copy, deepcopy, Error. These re-anchor
# copy and deepcopy __qualname__ under the extra14 namespace for independent
# coverage.
# ---------------------------------------------------------------------------

invariant copy_extra14.copy.qualname:
  description: "copy.copy.__qualname__ == 'copy' — function qualname attribute"
  category: function_attrs
  kind: python_call_eq
  function: copy.__qualname__.__eq__
  args: ["copy"]
  expected: true

invariant copy_extra14.deepcopy.qualname:
  description: "copy.deepcopy.__qualname__ == 'deepcopy' — function qualname attribute"
  category: function_attrs
  kind: python_call_eq
  function: deepcopy.__qualname__.__eq__
  args: ["deepcopy"]
  expected: true

# ---------------------------------------------------------------------------
# __class__.__name__ table — copy, deepcopy, Error
#
# No prior copy spec collects __class__.__name__ for copy, deepcopy, and
# Error together in a single table. copy and deepcopy are regular Python
# functions ('function'); Error is a class ('type'). This table verifies
# each object's runtime kind under the extra14 namespace.
# ---------------------------------------------------------------------------

table copy_extra14.object_class_names:
  description: "__class__.__name__ for copy, deepcopy, Error — function vs. type identity"
  kind: python_call_eq
  category: class_attrs

  columns: [id, function, args, expected]
  rows:
    - [copy,     copy.__class__.__name__.__eq__,     ["function"], true]
    - [deepcopy, deepcopy.__class__.__name__.__eq__, ["function"], true]
    - [Error,    Error.__class__.__name__.__eq__,    ["type"],     true]

# ---------------------------------------------------------------------------
# Behavioral: copy and deepcopy of tuple (1, 2, 3)
#
# copy_extra11 and copy_extra12 cover copy/deepcopy of [1,2,3] (lists).
# copy_extra13 covers copy/deepcopy of {'a':1} (dicts).
# No prior copy spec covers copy/deepcopy of a tuple as a behavioral invariant.
# ---------------------------------------------------------------------------

invariant copy_extra14.copy.tuple_equals:
  description: "copy.copy((1,2,3)) == (1,2,3) — shallow copy of tuple equals original by value"
  category: behavioral
  kind: python_call_eq
  function: copy
  args: [[1, 2, 3]]
  method: __eq__
  method_args: [[1, 2, 3]]
  expected: true

invariant copy_extra14.deepcopy.tuple_equals:
  description: "copy.deepcopy((1,2,3)) == (1,2,3) — deep copy of tuple equals original by value"
  category: behavioral
  kind: python_call_eq
  function: deepcopy
  args: [[1, 2, 3]]
  method: __eq__
  method_args: [[1, 2, 3]]
  expected: true

# ---------------------------------------------------------------------------
# Error.__bases__[0].__name__ standalone (extra14 namespace)
#
# copy_extra13 covers error.__bases__.__getitem__(0).__name__ (via the alias).
# copy_extra6 covers Error.__bases__[0].__name__ in the extra6 namespace.
# This re-anchors Error.__bases__[0].__name__ under the extra14 namespace.
# ---------------------------------------------------------------------------

invariant copy_extra14.Error.base_name:
  description: "copy.Error.__bases__[0].__name__ == 'Exception' — Error directly inherits from Exception"
  category: error_hierarchy
  kind: python_call_eq
  function: "Error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true
