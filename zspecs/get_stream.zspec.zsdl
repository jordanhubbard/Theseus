spec: get_stream
version: ">=9.0.0"
backend: node(get-stream)
esm: true

docs: https://github.com/sindresorhus/get-stream#readme

provenance:
  derived_from:
    - "get-stream README — https://github.com/sindresorhus/get-stream#readme"
    - "Test vectors verified with get-stream via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "get-stream source"
  notes:
    - "Collect a Readable stream into a string / Buffer / array / ArrayBuffer."
    - "Install: npm install get-stream"
    - "v9 ESM only; default export getStream() returns string; named getStreamAsBuffer / getStreamAsArray / getStreamAsArrayBuffer."
    - "MaxBufferError is thrown when the maxBuffer option is exceeded."
    - "Spec covers shape only — passing a real stream via JSON entry_args is not supported."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Returned promise rejects with MaxBufferError when maxBuffer is exceeded; underlying stream errors propagate."
  stderr: "null"
  stickiness: "Each call drains the stream once."
  codes:
    MaxBufferError: "Stream exceeded the configured maxBuffer"

invariant get_stream.default_is_function:
  description: "Default export getStream() is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "AsyncFunction"

invariant get_stream.has_getStreamAsBuffer:
  description: "Named export getStreamAsBuffer exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "getStreamAsBuffer.constructor.name"}
  expected: "AsyncFunction"

invariant get_stream.has_getStreamAsArray:
  description: "Named export getStreamAsArray exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "getStreamAsArray.constructor.name"}
  expected: "AsyncFunction"

invariant get_stream.has_getStreamAsArrayBuffer:
  description: "Named export getStreamAsArrayBuffer exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "getStreamAsArrayBuffer.constructor.name"}
  expected: "AsyncFunction"

invariant get_stream.has_MaxBufferError:
  description: "MaxBufferError class exposed"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "MaxBufferError.constructor.name"}
  expected: "Function"

invariant get_stream.MaxBufferError_name:
  description: "MaxBufferError.name is 'MaxBufferError'"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "MaxBufferError.name"}
  expected: "MaxBufferError"

invariant get_stream.default_arity:
  description: "getStream() takes 2 args (stream, options)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 2

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:37:25Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
