spec: inspect_extra185
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.classify_class_attrs, inspect.getmembers, inspect.getattr_static, and inspect.getmro function identity — inspect.getmembers.__name__=='getmembers' (len=10); inspect.getmembers.__module__=='inspect'; inspect.getmembers.__qualname__=='getmembers'; inspect.classify_class_attrs.__name__=='classify_class_attrs' (len=20); inspect.classify_class_attrs.__module__=='inspect'; inspect.getattr_static.__name__=='getattr_static' (len=14); inspect.getmro.__name__=='getmro' (len=6); inspect.getmro.__module__=='inspect'."
    - "inspect.getmembers.__name__ == 'getmembers' — getmembers is a pure-Python function in Lib/inspect.py that returns all members of an object as (name, value) pairs; its __name__ is 'getmembers' (10 chars). Verified with Python 3.14.3."
    - "inspect.getmembers.__module__ == 'inspect' — getmembers is defined in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getmembers.__qualname__ == 'getmembers' — module-level function has __qualname__ == __name__ == 'getmembers'. Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__name__ == 'classify_class_attrs' — classify_class_attrs is a pure-Python function that classifies the attributes of a class into groups; its __name__ is 'classify_class_attrs' (20 chars). Verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__module__ == 'inspect' — classify_class_attrs is defined in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getattr_static.__name__ == 'getattr_static' — getattr_static retrieves attributes without triggering dynamic lookup (descriptors, __getattr__); its __name__ is 'getattr_static' (14 chars). Verified with Python 3.14.3."
    - "inspect.getmro.__name__ == 'getmro' — getmro returns the method resolution order tuple for a class; its __name__ is 'getmro' (6 chars). Verified with Python 3.14.3."
    - "inspect.getmro.__module__ == 'inspect' — getmro is defined in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmembers __name__, __module__, __qualname__
#
# inspect.getmembers.__name__ == 'getmembers'
# inspect.getmembers.__name__.__len__() == 10
# inspect.getmembers.__module__ == 'inspect'
# inspect.getmembers.__qualname__ == 'getmembers'
#
# inspect.getmembers is a pure-Python function in Lib/inspect.py that returns
# all members of an object as sorted (name, value) pairs, optionally filtered
# by a predicate. Its __name__ is 'getmembers' (10 chars). New to extra185.
# ---------------------------------------------------------------------------

table inspect_extra185.getmembers_identity:
  description: "inspect.getmembers.__name__=='getmembers' len 10; __module__=='inspect'; __qualname__=='getmembers'; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: inspectmembers185

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_name_eq,
       getmembers.__name__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__name__.__eq__('getmembers') == True — getmembers returns all members of an object as sorted (name, value) pairs, optionally filtered by predicate; its __name__ is 'getmembers' (10 chars); str.__eq__('getmembers') returns True; new to extra185"]
    - [getmembers_name_len_10,
       getmembers.__name__.__len__,
       [],
       10,
       "inspect.getmembers.__name__.__len__() == 10 — the name 'getmembers' has exactly 10 characters: g-e-t-m-e-m-b-e-r-s; str.__len__() returns 10; new to extra185"]
    - [getmembers_module_eq,
       getmembers.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — getmembers is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra185"]
    - [getmembers_qualname_eq,
       getmembers.__qualname__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__qualname__.__eq__('getmembers') == True — as a module-level function, __qualname__ equals __name__ 'getmembers' (10 chars); str.__eq__('getmembers') returns True; new to extra185"]

# ---------------------------------------------------------------------------
# Table 2: inspect.classify_class_attrs __name__ and __module__,
#          inspect.getattr_static __name__
#
# inspect.classify_class_attrs.__name__ == 'classify_class_attrs'
# inspect.classify_class_attrs.__name__.__len__() == 20
# inspect.classify_class_attrs.__module__ == 'inspect'
# inspect.getattr_static.__name__ == 'getattr_static'
#
# classify_class_attrs classifies attributes of a class into groups (method,
# class method, static method, data attribute, etc.). Its __name__ is
# 'classify_class_attrs' (20 chars). getattr_static retrieves attributes
# without triggering dynamic lookup; its __name__ is 'getattr_static' (14
# chars). New to extra185.
# ---------------------------------------------------------------------------

table inspect_extra185.classify_attrs_and_getattr_static_identity:
  description: "inspect.classify_class_attrs.__name__=='classify_class_attrs' len 20; __module__=='inspect'; inspect.getattr_static.__name__=='getattr_static' len 14; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: inspectmembers185

  columns: [id, function, args, expected, description]
  rows:
    - [classify_name_eq,
       classify_class_attrs.__name__.__eq__,
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__name__.__eq__('classify_class_attrs') == True — classify_class_attrs classifies attributes of a class into groups (method, class method, static method, data); its __name__ is 'classify_class_attrs' (20 chars); str.__eq__('classify_class_attrs') returns True; new to extra185"]
    - [classify_name_len_20,
       classify_class_attrs.__name__.__len__,
       [],
       20,
       "inspect.classify_class_attrs.__name__.__len__() == 20 — the name 'classify_class_attrs' has exactly 20 characters; str.__len__() returns 20; new to extra185"]
    - [classify_module_eq,
       classify_class_attrs.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.classify_class_attrs.__module__.__eq__('inspect') == True — classify_class_attrs is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra185"]
    - [getattr_static_name_eq,
       getattr_static.__name__.__eq__,
       ["getattr_static"],
       true,
       "inspect.getattr_static.__name__.__eq__('getattr_static') == True — getattr_static retrieves attributes without triggering dynamic lookup via descriptors or __getattr__; its __name__ is 'getattr_static' (14 chars); str.__eq__('getattr_static') returns True; new to extra185"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getattr_static __name__ length and inspect.getmro identity
#
# inspect.getattr_static.__name__.__len__() == 14
# inspect.getmro.__name__ == 'getmro'
# inspect.getmro.__name__.__len__() == 6
# inspect.getmro.__module__ == 'inspect'
#
# getattr_static name is 14 chars: g-e-t-a-t-t-r-_-s-t-a-t-i-c.
# getmro returns the MRO tuple for a class (same as __mro__ attribute); its
# __name__ is 'getmro' (6 chars) and __module__ is 'inspect'. New to extra185.
# ---------------------------------------------------------------------------

table inspect_extra185.getattr_static_len_and_getmro_identity:
  description: "inspect.getattr_static.__name__.__len__()==14; inspect.getmro.__name__=='getmro' len 6; __module__=='inspect'; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: inspectmembers185

  columns: [id, function, args, expected, description]
  rows:
    - [getattr_static_name_len_14,
       getattr_static.__name__.__len__,
       [],
       14,
       "inspect.getattr_static.__name__.__len__() == 14 — the name 'getattr_static' has exactly 14 characters: g-e-t-a-t-t-r-_-s-t-a-t-i-c; str.__len__() returns 14; new to extra185"]
    - [getmro_name_eq,
       getmro.__name__.__eq__,
       ["getmro"],
       true,
       "inspect.getmro.__name__.__eq__('getmro') == True — getmro returns the method resolution order tuple for a class (equivalent to cls.__mro__); its __name__ is 'getmro' (6 chars); str.__eq__('getmro') returns True; new to extra185"]
    - [getmro_name_len_6,
       getmro.__name__.__len__,
       [],
       6,
       "inspect.getmro.__name__.__len__() == 6 — the name 'getmro' has exactly 6 characters: g-e-t-m-r-o; str.__len__() returns 6; new to extra185"]
    - [getmro_module_eq,
       getmro.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getmro.__module__.__eq__('inspect') == True — getmro is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra185"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra185
# ---------------------------------------------------------------------------

invariant inspect_extra185.getmembers_name_is_getmembers:
  description: "inspect.getmembers.__name__ == 'getmembers' — returns all members of an object as sorted (name, value) pairs, optionally filtered by predicate; __name__ is 'getmembers' (10 chars); new to extra185"
  category: identity
  kind: python_call_eq
  function: getmembers.__name__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra185.getmembers_module_is_inspect:
  description: "inspect.getmembers.__module__ == 'inspect' — getmembers is defined in Lib/inspect.py; its __module__ is 'inspect'; new to extra185"
  category: identity
  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra185.getmembers_qualname_equals_name:
  description: "inspect.getmembers.__qualname__ == 'getmembers' — module-level function has __qualname__ == __name__ == 'getmembers' (10 chars); new to extra185"
  category: identity
  kind: python_call_eq
  function: getmembers.__qualname__.__eq__
  args: ["getmembers"]
  expected: true

invariant inspect_extra185.classify_class_attrs_name_is_expected:
  description: "inspect.classify_class_attrs.__name__ == 'classify_class_attrs' — classifies attributes of a class into groups (method, class method, static method, data attribute); __name__ is 'classify_class_attrs' (20 chars); new to extra185"
  category: identity
  kind: python_call_eq
  function: classify_class_attrs.__name__.__eq__
  args: ["classify_class_attrs"]
  expected: true

invariant inspect_extra185.classify_class_attrs_module_is_inspect:
  description: "inspect.classify_class_attrs.__module__ == 'inspect' — classify_class_attrs is defined in Lib/inspect.py; its __module__ is 'inspect'; new to extra185"
  category: identity
  kind: python_call_eq
  function: classify_class_attrs.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra185.getattr_static_name_is_getattr_static:
  description: "inspect.getattr_static.__name__ == 'getattr_static' — retrieves attributes without triggering dynamic lookup via descriptors or __getattr__; __name__ is 'getattr_static' (14 chars); new to extra185"
  category: identity
  kind: python_call_eq
  function: getattr_static.__name__.__eq__
  args: ["getattr_static"]
  expected: true

invariant inspect_extra185.getmro_name_is_getmro:
  description: "inspect.getmro.__name__ == 'getmro' — returns the method resolution order tuple for a class, equivalent to cls.__mro__; __name__ is 'getmro' (6 chars); new to extra185"
  category: identity
  kind: python_call_eq
  function: getmro.__name__.__eq__
  args: ["getmro"]
  expected: true

invariant inspect_extra185.getmro_module_is_inspect:
  description: "inspect.getmro.__module__ == 'inspect' — getmro is defined in Lib/inspect.py; its __module__ is 'inspect'; new to extra185"
  category: identity
  kind: python_call_eq
  function: getmro.__module__.__eq__
  args: ["inspect"]
  expected: true
