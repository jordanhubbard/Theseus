spec: demjson3_rust
version: ">=3.9"
backend: rust_module(demjson3_rust)

docs: https://github.com/dmeranda/demjson

provenance:
  derived_from:
    - "https://github.com/dmeranda/demjson — demjson3"
  notes:
    - "demjson3 provides lenient JSON encoding/decoding."
    - "demjson3.encode({'a': 1}) produces a valid JSON string."
    - "demjson3.decode('{\"a\": 1}') == {'a': 1}."
    - "demjson3.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant demjson3_rust.has_encode:
  description: "demjson3 has encode function"
  category: presence
  kind: python_call_eq
  function: demjson3_has_encode
  args: []
  expected: true

invariant demjson3_rust.has_decode:
  description: "demjson3 has decode function"
  category: presence
  kind: python_call_eq
  function: demjson3_has_decode
  args: []
  expected: true

invariant demjson3_rust.version_nonempty:
  description: "demjson3.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: demjson3_version_nonempty
  args: []
  expected: true

