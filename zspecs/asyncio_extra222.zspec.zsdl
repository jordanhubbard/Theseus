spec: asyncio_extra222
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
  notes:
    - "asyncio.Queue.__qualname__ == 'Queue' — verified with Python 3.14.3."
    - "asyncio.LifoQueue.__qualname__ == 'LifoQueue' — verified with Python 3.14.3."
    - "asyncio.PriorityQueue.__qualname__ == 'PriorityQueue' — verified with Python 3.14.3."
    - "asyncio.Lock.__qualname__ == 'Lock' — verified with Python 3.14.3."
    - "asyncio.Event.__qualname__ == 'Event' — verified with Python 3.14.3."
    - "asyncio.Condition.__qualname__ == 'Condition' — verified with Python 3.14.3."
    - "asyncio.Semaphore.__qualname__ == 'Semaphore' — verified with Python 3.14.3."
    - "asyncio.BoundedSemaphore.__qualname__ == 'BoundedSemaphore' — verified with Python 3.14.3."
    - "asyncio.Task.__qualname__ == 'Task' — verified with Python 3.14.3."
    - "asyncio.Future.__qualname__ == 'Future' — verified with Python 3.14.3."
    - "asyncio.Queue.put.__qualname__ == 'Queue.put' — verified with Python 3.14.3."
    - "asyncio.Queue.get.__qualname__ == 'Queue.get' — verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio queue class __qualname__ contracts — extra222 namespace
#
# Captures asyncio.Queue, asyncio.LifoQueue, asyncio.PriorityQueue __qualname__
# equality. Each class's __qualname__ matches its simple class name.
# ---------------------------------------------------------------------------

table asyncio_extra222.queue_qualnames:
  description: "asyncio queue class __qualname__.__eq__() checks in extra222 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio222queuequalname

  columns: [id, function, args, expected, description]
  rows:
    - [queue_qualname_eq,         Queue.__qualname__.__eq__,         ["Queue"],         true, "asyncio.Queue.__qualname__ == 'Queue'; verified with Python 3.14.3"]
    - [lifoqueue_qualname_eq,     LifoQueue.__qualname__.__eq__,     ["LifoQueue"],     true, "asyncio.LifoQueue.__qualname__ == 'LifoQueue'; verified with Python 3.14.3"]
    - [priorityqueue_qualname_eq, PriorityQueue.__qualname__.__eq__, ["PriorityQueue"], true, "asyncio.PriorityQueue.__qualname__ == 'PriorityQueue'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio synchronization primitive class __qualname__ contracts — extra222
# ---------------------------------------------------------------------------

table asyncio_extra222.sync_primitive_qualnames:
  description: "asyncio synchronization primitive class __qualname__.__eq__() checks in extra222 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio222syncqualname

  columns: [id, function, args, expected, description]
  rows:
    - [lock_qualname_eq,             Lock.__qualname__.__eq__,             ["Lock"],             true, "asyncio.Lock.__qualname__ == 'Lock'; verified with Python 3.14.3"]
    - [event_qualname_eq,            Event.__qualname__.__eq__,            ["Event"],            true, "asyncio.Event.__qualname__ == 'Event'; verified with Python 3.14.3"]
    - [condition_qualname_eq,        Condition.__qualname__.__eq__,        ["Condition"],        true, "asyncio.Condition.__qualname__ == 'Condition'; verified with Python 3.14.3"]
    - [semaphore_qualname_eq,        Semaphore.__qualname__.__eq__,        ["Semaphore"],        true, "asyncio.Semaphore.__qualname__ == 'Semaphore'; verified with Python 3.14.3"]
    - [boundedsemaphore_qualname_eq, BoundedSemaphore.__qualname__.__eq__, ["BoundedSemaphore"], true, "asyncio.BoundedSemaphore.__qualname__ == 'BoundedSemaphore'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Task and Future class __qualname__ contracts — extra222 namespace
# ---------------------------------------------------------------------------

table asyncio_extra222.task_future_qualnames:
  description: "asyncio Task and Future class __qualname__.__eq__() checks in extra222 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio222taskfutqualname

  columns: [id, function, args, expected, description]
  rows:
    - [task_qualname_eq,   Task.__qualname__.__eq__,   ["Task"],   true, "asyncio.Task.__qualname__ == 'Task'; verified with Python 3.14.3"]
    - [future_qualname_eq, Future.__qualname__.__eq__, ["Future"], true, "asyncio.Future.__qualname__ == 'Future'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Queue method __qualname__ contracts — extra222 namespace
#
# Queue.put.__qualname__ == 'Queue.put' and Queue.get.__qualname__ == 'Queue.get'.
# ---------------------------------------------------------------------------

invariant asyncio_extra222.queue_put_qualname:
  description: "asyncio.Queue.put.__qualname__ == 'Queue.put'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Queue.put.__qualname__.__eq__
  args: ["Queue.put"]
  expected: true

invariant asyncio_extra222.queue_get_qualname:
  description: "asyncio.Queue.get.__qualname__ == 'Queue.get'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Queue.get.__qualname__.__eq__
  args: ["Queue.get"]
  expected: true
