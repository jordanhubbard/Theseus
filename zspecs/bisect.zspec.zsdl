spec: bisect
version: ">=3.2"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "Python bisect documentation — https://docs.python.org/3/library/bisect.html"
    - "Test vectors verified by running Python 3.14.3 bisect module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "bisect_left(a, x) returns the leftmost index i such that a[i-1] < x <= a[i]."
    - "bisect_right(a, x) returns the rightmost index i such that a[i-1] <= x < a[i]."
    - "bisect(a, x) is an alias for bisect_right."
    - "When x is not in a, bisect_left and bisect_right return the same index."
    - "When x appears multiple times, bisect_left returns the index of the first occurrence and bisect_right returns one past the last."
    - "lo and hi optional args restrict the search to the subrange a[lo:hi]; returned index is in terms of the full list."
    - "insort modifies the list in-place and cannot be tested with a single stateless invariant; its presence is verified via __name__."
    - "All expected values verified by running Python 3.14.3 bisect module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# bisect_left — sorted list [1, 3, 5, 7, 9]
# ---------------------------------------------------------------------------

table bisect.bisect_left.basic:
  kind: python_call_eq
  function: bisect_left
  id_prefix: bisect_left

  columns: [id, description, category, args, expected]
  rows:
    - [present,      "bisect_left([1,3,5,7,9], 5) == 2 — element present",      basic,    [[1, 3, 5, 7, 9], 5],  2]
    - [before_all,   "bisect_left([1,3,5,7,9], 0) == 0 — before everything",    edge,     [[1, 3, 5, 7, 9], 0],  0]
    - [after_all,    "bisect_left([1,3,5,7,9], 10) == 5 — after everything",    edge,     [[1, 3, 5, 7, 9], 10], 5]
    - [first_elem,   "bisect_left([1,3,5,7,9], 1) == 0 — leftmost element",     basic,    [[1, 3, 5, 7, 9], 1],  0]
    - [last_elem,    "bisect_left([1,3,5,7,9], 9) == 4 — rightmost element",    basic,    [[1, 3, 5, 7, 9], 9],  4]
    - [mid_gap,      "bisect_left([1,3,5,7,9], 3) == 1 — in-list element",      basic,    [[1, 3, 5, 7, 9], 3],  1]
    - [empty,        "bisect_left([], 5) == 0 — empty list",                    edge,     [[], 5],               0]
    - [single_eq,    "bisect_left([5], 5) == 0 — single element equal",         edge,     [[5], 5],              0]
    - [single_lt,    "bisect_left([5], 3) == 0 — single element greater",       edge,     [[5], 3],              0]
    - [single_gt,    "bisect_left([5], 7) == 1 — single element smaller",       edge,     [[5], 7],              1]

# ---------------------------------------------------------------------------
# bisect_right — sorted list [1, 3, 5, 7, 9]
# ---------------------------------------------------------------------------

table bisect.bisect_right.basic:
  kind: python_call_eq
  function: bisect_right
  id_prefix: bisect_right

  columns: [id, description, category, args, expected]
  rows:
    - [present,      "bisect_right([1,3,5,7,9], 5) == 3 — after element",       basic,    [[1, 3, 5, 7, 9], 5],  3]
    - [before_all,   "bisect_right([1,3,5,7,9], 0) == 0 — before everything",   edge,     [[1, 3, 5, 7, 9], 0],  0]
    - [after_all,    "bisect_right([1,3,5,7,9], 10) == 5 — after everything",   edge,     [[1, 3, 5, 7, 9], 10], 5]
    - [first_elem,   "bisect_right([1,3,5,7,9], 1) == 1 — after leftmost",      basic,    [[1, 3, 5, 7, 9], 1],  1]
    - [last_elem,    "bisect_right([1,3,5,7,9], 9) == 5 — after rightmost",     basic,    [[1, 3, 5, 7, 9], 9],  5]
    - [mid_gap,      "bisect_right([1,3,5,7,9], 3) == 2 — after in-list elem",  basic,    [[1, 3, 5, 7, 9], 3],  2]
    - [empty,        "bisect_right([], 5) == 0 — empty list",                   edge,     [[], 5],               0]
    - [single_eq,    "bisect_right([5], 5) == 1 — single element equal",        edge,     [[5], 5],              1]
    - [single_lt,    "bisect_right([5], 3) == 0 — single element greater",      edge,     [[5], 3],              0]
    - [single_gt,    "bisect_right([5], 7) == 1 — single element smaller",      edge,     [[5], 7],              1]

# ---------------------------------------------------------------------------
# Duplicates — left vs right differ when x appears multiple times
# List: [1, 3, 5, 5, 5, 7]
# ---------------------------------------------------------------------------

invariant bisect.bisect_left.duplicates_first:
  description: "bisect_left([1,3,5,5,5,7], 5) == 2 — index of first 5"
  category: duplicates
  kind: python_call_eq
  function: bisect_left
  args: [[1, 3, 5, 5, 5, 7], 5]
  expected: 2

invariant bisect.bisect_right.duplicates_last:
  description: "bisect_right([1,3,5,5,5,7], 5) == 5 — one past the last 5"
  category: duplicates
  kind: python_call_eq
  function: bisect_right
  args: [[1, 3, 5, 5, 5, 7], 5]
  expected: 5

# ---------------------------------------------------------------------------
# bisect — alias for bisect_right
# ---------------------------------------------------------------------------

invariant bisect.bisect.alias_eq_bisect_right:
  description: "bisect([1,3,5,7,9], 5) == 3 — same result as bisect_right"
  category: alias
  kind: python_call_eq
  function: bisect
  args: [[1, 3, 5, 7, 9], 5]
  expected: 3

invariant bisect.bisect.alias_before_all:
  description: "bisect([1,3,5,7,9], 0) == 0 — same as bisect_right for value before all"
  category: alias
  kind: python_call_eq
  function: bisect
  args: [[1, 3, 5, 7, 9], 0]
  expected: 0

invariant bisect.bisect.alias_after_all:
  description: "bisect([1,3,5,7,9], 10) == 5 — same as bisect_right for value after all"
  category: alias
  kind: python_call_eq
  function: bisect
  args: [[1, 3, 5, 7, 9], 10]
  expected: 5

# ---------------------------------------------------------------------------
# lo/hi subrange arguments (Python 3.2+)
# bisect_left([1,3,5,7,9], 5, 2, 4) searches a[2:4]=[5,7] for 5 → returns 2
# bisect_right([1,3,5,7,9], 5, 2, 4) searches a[2:4]=[5,7] for 5 → returns 3
# ---------------------------------------------------------------------------

invariant bisect.bisect_left.lo_hi_present:
  description: "bisect_left([1,3,5,7,9], 5, 2, 4) == 2 — subrange [5,7], 5 at index 2"
  category: lo_hi
  kind: python_call_eq
  function: bisect_left
  args: [[1, 3, 5, 7, 9], 5, 2, 4]
  expected: 2

invariant bisect.bisect_right.lo_hi_present:
  description: "bisect_right([1,3,5,7,9], 5, 2, 4) == 3 — subrange [5,7], 5 inserts after index 2"
  category: lo_hi
  kind: python_call_eq
  function: bisect_right
  args: [[1, 3, 5, 7, 9], 5, 2, 4]
  expected: 3

invariant bisect.bisect_left.lo_hi_absent:
  description: "bisect_left([1,3,5,7,9], 7, 2, 4) == 3 — subrange [5,7], 7 at index 3"
  category: lo_hi
  kind: python_call_eq
  function: bisect_left
  args: [[1, 3, 5, 7, 9], 7, 2, 4]
  expected: 3

# ---------------------------------------------------------------------------
# Function name identity — verifies module exports expected callables
# insort modifies a list in-place; verified by __name__ only.
# ---------------------------------------------------------------------------

invariant bisect.bisect_left.name:
  description: "bisect_left.__name__ == 'bisect_left'"
  category: identity
  kind: python_call_eq
  function: bisect_left.__name__.__eq__
  args: ["bisect_left"]
  expected: true

invariant bisect.bisect_right.name:
  description: "bisect_right.__name__ == 'bisect_right'"
  category: identity
  kind: python_call_eq
  function: bisect_right.__name__.__eq__
  args: ["bisect_right"]
  expected: true

invariant bisect.insort.name:
  description: "insort.__name__ == 'insort_right' — Python exposes insort as insort_right internally"
  category: identity
  kind: python_call_eq
  function: insort.__name__.__eq__
  args: ["insort_right"]
  expected: true
