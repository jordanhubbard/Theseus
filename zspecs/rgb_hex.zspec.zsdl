spec: rgb_hex
version: ">=4.1.0"
backend: node(rgb-hex)

docs: https://www.npmjs.com/package/rgb-hex

provenance:
  derived_from:
    - "rgb-hex README — https://www.npmjs.com/package/rgb-hex"
    - "Test vectors verified with rgb-hex via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "rgb-hex source"
  notes:
    - "rgb-hex is an npm package. Install: npm install rgb-hex"
    - "Converts R, G, B integer values to a 6-character hex string (no leading #). ESM; use function: default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a lowercase hex color string without #."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table rgb_hex.rgbHex:
  kind: node_module_call_eq
  function: "default"
  category: convert
  id_prefix: rgbhex

  columns: [id, args, expected]
  rows:
    - [red,   [255, 0, 0],   "ff0000"]
    - [green, [0, 255, 0],   "00ff00"]
    - [blue,  [0, 0, 255],   "0000ff"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:22:41Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
