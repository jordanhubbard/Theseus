spec: pymongo_rust
version: ">=3.9"
backend: rust_module(pymongo_rust)

docs: https://pymongo.readthedocs.io/en/stable/api/

provenance:
  derived_from:
    - "https://pymongo.readthedocs.io/en/stable/api/ — PyMongo API"
  not_derived_from:
    - "pymongo source: pymongo/__init__.py"
  notes:
    - "PyMongo is the Python driver for MongoDB."
    - "pymongo.version is a non-empty string."
    - "pymongo.MongoClient is available."
    - "pymongo.MongoClient.__name__ == 'MongoClient'."
    - "bson.ObjectId is available."
    - "bson.objectid.ObjectId() generates a 24-hex-char string id."
    - "Expose pymongo_has_client() -> bool: hasattr(pymongo, 'MongoClient')."
    - "Expose pymongo_client_name() -> str: pymongo.MongoClient.__name__."
    - "Expose pymongo_version_nonempty() -> bool: len(pymongo.version) > 0."
    - "All test vectors verified against pymongo 4.11.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# pymongo_has_client — MongoClient present
invariant pymongo_rust.module.has_client:
  description: "pymongo.MongoClient is available"
  category: module
  kind: python_call_eq
  function: pymongo_has_client
  args: []
  expected: true

# pymongo_client_name — client class name
invariant pymongo_rust.client.class_name:
  description: "pymongo.MongoClient.__name__ == 'MongoClient'"
  category: client
  kind: python_call_eq
  function: pymongo_client_name
  args: []
  expected: "MongoClient"

# pymongo_version_nonempty — version non-empty
invariant pymongo_rust.version.nonempty:
  description: "pymongo.version is non-empty"
  category: version
  kind: python_call_eq
  function: pymongo_version_nonempty
  args: []
  expected: true

