spec: socket_extra264
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra263.zspec.zsdl — covers socket module identity (__name__, __package__, __spec__, __loader__); socket.socket.__doc__ string checks; IPPROTO_ICMP/TCP/UDP/IP/IPV6 integer values."
    - "socket_extra262.zspec.zsdl — covers socketpair/fromfd function identity; ntohs/htons/ntohl/htonl byte-order function identity."
    - "socket.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX; SOCK_STREAM/SOCK_DGRAM/SOCK_RAW; IPPROTO_IP/TCP/UDP; SOL_SOCKET; socket/herror/gaierror class names."
  notes:
    - "socket.socket.setblocking.__name__ == 'setblocking' (instance-level: builtin_function_or_method; class-level: method_descriptor). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.makefile.__name__ == 'makefile' (instance-level: method; class-level: function). The makefile() method is defined in the Python-level socket.socket wrapper (Lib/socket.py), not in the C extension. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.settimeout.__name__ == 'settimeout' (class-level: method_descriptor). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.gettimeout.__name__ == 'gettimeout' (class-level: method_descriptor). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.fileno.__name__ == 'fileno' (class-level: method_descriptor). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.CMSG_SPACE is available on macOS; socket.CMSG_SPACE.__name__ == 'CMSG_SPACE' and __class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.CMSG_LEN is available on macOS; socket.CMSG_LEN.__name__ == 'CMSG_LEN' and __class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.CMSG_SPACE(0) == 12 on macOS/Darwin 25.4.0 — minimal CMSG header overhead with 0 data bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.CMSG_LEN(0) == 12 on macOS/Darwin 25.4.0 — CMSG_LEN(0) equals CMSG_SPACE(0) when data length is 0. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.makefile.__class__.__name__ == 'function' at the class level — makefile is a pure-Python method defined in Lib/socket.py, not a C method_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket.setblocking.__class__.__name__ == 'method_descriptor' at the class level — setblocking is defined in the C extension (_socket). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method identity — setblocking, makefile, settimeout, gettimeout, fileno
# Checked at the class level (unbound methods) where the class types are stable:
# C-backed methods are method_descriptor; Python-defined methods are function.
# ---------------------------------------------------------------------------

table socket_extra264.socket_method_identity:
  description: "socket.socket method identity: setblocking/makefile/settimeout/gettimeout/fileno __name__ and __class__.__name__; C methods are method_descriptor, Python methods are function; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockmethod264

  columns: [id, function, args, expected, description]
  rows:
    - [setblocking_name,   socket.setblocking.__name__.__eq__,              ["setblocking"],     true, "socket.socket.setblocking.__name__ == 'setblocking'"]
    - [setblocking_class,  socket.setblocking.__class__.__name__.__eq__,     ["method_descriptor"], true, "socket.socket.setblocking.__class__.__name__ == 'method_descriptor' — defined in C extension"]
    - [makefile_name,      socket.makefile.__name__.__eq__,                 ["makefile"],        true, "socket.socket.makefile.__name__ == 'makefile'"]
    - [makefile_class,     socket.makefile.__class__.__name__.__eq__,        ["function"],        true, "socket.socket.makefile.__class__.__name__ == 'function' — defined in Python (Lib/socket.py)"]
    - [settimeout_name,    socket.settimeout.__name__.__eq__,               ["settimeout"],      true, "socket.socket.settimeout.__name__ == 'settimeout'"]

# ---------------------------------------------------------------------------
# socket.socket additional method identity — gettimeout, fileno
# ---------------------------------------------------------------------------

table socket_extra264.socket_method_identity2:
  description: "socket.socket gettimeout and fileno method identity; both are method_descriptor (C-backed); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sockmethod264b

  columns: [id, function, args, expected, description]
  rows:
    - [gettimeout_name,    socket.gettimeout.__name__.__eq__,               ["gettimeout"],      true, "socket.socket.gettimeout.__name__ == 'gettimeout'"]
    - [gettimeout_class,   socket.gettimeout.__class__.__name__.__eq__,      ["method_descriptor"], true, "socket.socket.gettimeout.__class__.__name__ == 'method_descriptor' — defined in C extension"]
    - [fileno_name,        socket.fileno.__name__.__eq__,                   ["fileno"],          true, "socket.socket.fileno.__name__ == 'fileno'"]
    - [fileno_class,       socket.fileno.__class__.__name__.__eq__,          ["method_descriptor"], true, "socket.socket.fileno.__class__.__name__ == 'method_descriptor' — defined in C extension"]
    - [settimeout_class,   socket.settimeout.__class__.__name__.__eq__,      ["method_descriptor"], true, "socket.socket.settimeout.__class__.__name__ == 'method_descriptor' — defined in C extension"]

# ---------------------------------------------------------------------------
# socket.CMSG_SPACE and socket.CMSG_LEN function identity
# Both are available on macOS (Darwin). They are C-level builtins.
# CMSG_SPACE(0) == 12 on macOS/Darwin 25.4.0 (minimal CMSG overhead).
# CMSG_LEN(0) == 12 on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra264.CMSG_function_identity:
  description: "socket.CMSG_SPACE and CMSG_LEN function identity: __name__ and __class__.__name__; both are C-level builtins available on macOS; verified with Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: identity
  id_prefix: sockcmsg264

  columns: [id, function, args, expected, description]
  rows:
    - [cmsg_space_name,   CMSG_SPACE.__name__.__eq__,              ["CMSG_SPACE"],               true, "socket.CMSG_SPACE.__name__ == 'CMSG_SPACE'"]
    - [cmsg_space_class,  CMSG_SPACE.__class__.__name__.__eq__,     ["builtin_function_or_method"], true, "socket.CMSG_SPACE.__class__.__name__ == 'builtin_function_or_method' — C-level function"]
    - [cmsg_len_name,     CMSG_LEN.__name__.__eq__,                ["CMSG_LEN"],                 true, "socket.CMSG_LEN.__name__ == 'CMSG_LEN'"]
    - [cmsg_len_class,    CMSG_LEN.__class__.__name__.__eq__,       ["builtin_function_or_method"], true, "socket.CMSG_LEN.__class__.__name__ == 'builtin_function_or_method' — C-level function"]
    - [cmsg_space_qualname, CMSG_SPACE.__qualname__.__eq__,          ["CMSG_SPACE"],               true, "socket.CMSG_SPACE.__qualname__ == 'CMSG_SPACE' — qualname matches __name__ for a C builtin"]

# ---------------------------------------------------------------------------
# CMSG_SPACE(0) and CMSG_LEN(0) values on macOS/Darwin 25.4.0
# Both return 12 — minimal CMSG header with 0 data bytes.
# These values are platform-specific (macOS); they differ on Linux.
# ---------------------------------------------------------------------------

invariant socket_extra264.CMSG_SPACE_0_value:
  description: "socket.CMSG_SPACE(0) == 12 on macOS/Darwin 25.4.0 — minimal CMSG ancillary data header overhead with 0 data bytes; value is platform-specific (macOS); verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: cmsg_values
  kind: python_call_eq
  function: "CMSG_SPACE(0).__eq__"
  args: [12]
  expected: true

invariant socket_extra264.CMSG_LEN_0_value:
  description: "socket.CMSG_LEN(0) == 12 on macOS/Darwin 25.4.0 — CMSG_LEN(0) equals CMSG_SPACE(0) when data length is 0; value is platform-specific (macOS); verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: cmsg_values
  kind: python_call_eq
  function: "CMSG_LEN(0).__eq__"
  args: [12]
  expected: true

# ---------------------------------------------------------------------------
# Standalone identity invariants
# ---------------------------------------------------------------------------

invariant socket_extra264.setblocking_name_eq:
  description: "socket.socket.setblocking.__name__ == 'setblocking' — socket method name"
  category: identity
  kind: python_call_eq
  function: socket.setblocking.__name__.__eq__
  args: ["setblocking"]
  expected: true

invariant socket_extra264.setblocking_class_eq:
  description: "socket.socket.setblocking.__class__.__name__ == 'method_descriptor' — defined in C extension"
  category: identity
  kind: python_call_eq
  function: socket.setblocking.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant socket_extra264.makefile_name_eq:
  description: "socket.socket.makefile.__name__ == 'makefile' — socket method name"
  category: identity
  kind: python_call_eq
  function: socket.makefile.__name__.__eq__
  args: ["makefile"]
  expected: true

invariant socket_extra264.makefile_class_eq:
  description: "socket.socket.makefile.__class__.__name__ == 'function' — makefile is a pure-Python method defined in Lib/socket.py"
  category: identity
  kind: python_call_eq
  function: socket.makefile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant socket_extra264.CMSG_SPACE_name_eq:
  description: "socket.CMSG_SPACE.__name__ == 'CMSG_SPACE' — CMSG_SPACE function name"
  category: identity
  kind: python_call_eq
  function: CMSG_SPACE.__name__.__eq__
  args: ["CMSG_SPACE"]
  expected: true

invariant socket_extra264.CMSG_LEN_name_eq:
  description: "socket.CMSG_LEN.__name__ == 'CMSG_LEN' — CMSG_LEN function name"
  category: identity
  kind: python_call_eq
  function: CMSG_LEN.__name__.__eq__
  args: ["CMSG_LEN"]
  expected: true
