spec: multiprocessing_extra100
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra99

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing_extra99.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing module __name__, __package__, and submodule names. NEW in extra100: multiprocessing.__name__=='multiprocessing' (len=15); multiprocessing.__package__=='multiprocessing'; multiprocessing.__spec__.__class__.__name__=='ModuleSpec'; multiprocessing.__spec__.name=='multiprocessing'; multiprocessing.__spec__.submodule_search_locations.__class__.__name__=='list'; multiprocessing.__spec__.has_location==True; multiprocessing.pool.__name__=='multiprocessing.pool' (len=20); multiprocessing.process.__name__=='multiprocessing.process' (len=23); multiprocessing.context.__name__=='multiprocessing.context' (len=23, tied with process); multiprocessing.managers.__name__=='multiprocessing.managers' (len=24); multiprocessing.queues.__name__=='multiprocessing.queues' (len=22); multiprocessing.synchronize.__name__=='multiprocessing.synchronize' (len=27, longest). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__name__.__len__() == 15. 'multiprocessing' is 15 characters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.synchronize.__name__.__len__() == 27. 'multiprocessing.synchronize' is 27 chars: 'multiprocessing.'=16 + 'synchronize'=11 = 27. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.process.__name__.__len__() == 23 (not 22). 'multiprocessing.process' is 23 chars: 'multiprocessing.'=16 + 'process'=7 = 23. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing module identity — extra100
#
# Wave 254 theme: multiprocessing module __name__, __package__, __spec__.
#
# multiprocessing.__name__                                              == 'multiprocessing'  (len=15)
# multiprocessing.__package__                                           == 'multiprocessing'
# multiprocessing.__spec__.__class__.__name__                           == 'ModuleSpec'
# multiprocessing.__spec__.name                                         == 'multiprocessing'
# multiprocessing.__spec__.submodule_search_locations.__class__.__name__ == 'list'
# multiprocessing.__spec__.has_location                                  == True
# ---------------------------------------------------------------------------

table multiprocessing_extra100.mp_module_identity:
  description: "multiprocessing module __name__, __package__, and __spec__ identity checks in mpmodident100 namespace — wave 254 theme: multiprocessing is a top-level package; multiprocessing.__name__.__eq__('multiprocessing')==True (len=15: 'multiprocessing' is 15 chars); multiprocessing.__name__.__len__()==15; multiprocessing.__package__.__eq__('multiprocessing')==True (for top-level packages, __package__ equals __name__); multiprocessing.__spec__.__class__.__name__.__eq__('ModuleSpec')==True (standard module spec instance); multiprocessing.__spec__.name.__eq__('multiprocessing')==True (spec.name matches __name__); multiprocessing.__spec__.submodule_search_locations.__class__.__name__.__eq__('list')==True (multiprocessing is a directory package); multiprocessing.__spec__.has_location.__eq__(True)==True (filesystem origin); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: mpmodident100

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,     multiprocessing.__name__.__eq__,                                              ["multiprocessing"], true, "multiprocessing.__name__ == 'multiprocessing' (len=15); verified with Python 3.14.3"]
    - [name_len,    multiprocessing.__name__.__len__,                                             [],                 15,   "multiprocessing.__name__.__len__() == 15; verified with Python 3.14.3"]
    - [pkg_eq,      multiprocessing.__package__.__eq__,                                           ["multiprocessing"], true, "multiprocessing.__package__ == 'multiprocessing' (equals __name__); verified with Python 3.14.3"]
    - [spec_cls,    multiprocessing.__spec__.__class__.__name__.__eq__,                           ["ModuleSpec"],      true, "multiprocessing.__spec__.__class__.__name__ == 'ModuleSpec'; verified with Python 3.14.3"]
    - [spec_name,   multiprocessing.__spec__.name.__eq__,                                         ["multiprocessing"], true, "multiprocessing.__spec__.name == 'multiprocessing'; verified with Python 3.14.3"]
    - [submod_locs, multiprocessing.__spec__.submodule_search_locations.__class__.__name__.__eq__, ["list"],            true, "multiprocessing.__spec__.submodule_search_locations.__class__.__name__ == 'list'; verified with Python 3.14.3"]
    - [has_loc,     multiprocessing.__spec__.has_location.__eq__,                                 [true],              true, "multiprocessing.__spec__.has_location == True (filesystem origin); verified with Python 3.14.3"]
    - [name_cls,    multiprocessing.__name__.__class__.__name__.__eq__,                           ["str"],             true, "multiprocessing.__name__.__class__.__name__ == 'str'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing submodule __name__ attributes — extra100
#
# multiprocessing.pool.__name__         == 'multiprocessing.pool'         (len=20)
# multiprocessing.process.__name__      == 'multiprocessing.process'      (len=23)
# multiprocessing.context.__name__      == 'multiprocessing.context'      (len=23, tied)
# multiprocessing.queues.__name__       == 'multiprocessing.queues'       (len=22)
# multiprocessing.managers.__name__     == 'multiprocessing.managers'     (len=24)
# multiprocessing.synchronize.__name__  == 'multiprocessing.synchronize'  (len=27, longest)
# ---------------------------------------------------------------------------

table multiprocessing_extra100.mp_submodule_names:
  description: "multiprocessing submodule __name__ checks in mpmodident100 namespace — wave 254 theme: multiprocessing submodule __name__ attributes; multiprocessing.pool.__name__.__eq__('multiprocessing.pool')==True (len=20: 'multiprocessing.'=16 + 'pool'=4); multiprocessing.pool.__name__.__len__()==20; multiprocessing.queues.__name__.__eq__('multiprocessing.queues')==True (len=22: 'multiprocessing.'=16 + 'queues'=6); multiprocessing.process.__name__.__eq__('multiprocessing.process')==True (len=23: 'multiprocessing.'=16 + 'process'=7); multiprocessing.context.__name__.__eq__('multiprocessing.context')==True (len=23: tied with process; 'multiprocessing.'=16 + 'context'=7); multiprocessing.managers.__name__.__eq__('multiprocessing.managers')==True (len=24: 'multiprocessing.'=16 + 'managers'=8); multiprocessing.synchronize.__name__.__eq__('multiprocessing.synchronize')==True (len=27: 'multiprocessing.'=16 + 'synchronize'=11, the longest); all __name__ values share the 'multiprocessing.' prefix (16 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: mpmodident100a

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name_eq,   multiprocessing.pool.__name__.__eq__,         ["multiprocessing.pool"],        true, "multiprocessing.pool.__name__ == 'multiprocessing.pool' (len=20); verified with Python 3.14.3"]
    - [pool_name_len,  multiprocessing.pool.__name__.__len__,        [],                              20,   "multiprocessing.pool.__name__.__len__() == 20; verified with Python 3.14.3"]
    - [queues_name_eq, multiprocessing.queues.__name__.__eq__,       ["multiprocessing.queues"],      true, "multiprocessing.queues.__name__ == 'multiprocessing.queues' (len=22); verified with Python 3.14.3"]
    - [proc_name_eq,   multiprocessing.process.__name__.__eq__,      ["multiprocessing.process"],     true, "multiprocessing.process.__name__ == 'multiprocessing.process' (len=23); verified with Python 3.14.3"]
    - [proc_name_len,  multiprocessing.process.__name__.__len__,     [],                              23,   "multiprocessing.process.__name__.__len__() == 23; verified with Python 3.14.3"]
    - [ctx_name_eq,    multiprocessing.context.__name__.__eq__,      ["multiprocessing.context"],     true, "multiprocessing.context.__name__ == 'multiprocessing.context' (len=23, tied with process); verified with Python 3.14.3"]
    - [ctx_name_len,   multiprocessing.context.__name__.__len__,     [],                              23,   "multiprocessing.context.__name__.__len__() == 23 (tied with process); verified with Python 3.14.3"]
    - [mgr_name_eq,    multiprocessing.managers.__name__.__eq__,     ["multiprocessing.managers"],    true, "multiprocessing.managers.__name__ == 'multiprocessing.managers' (len=24); verified with Python 3.14.3"]
    - [mgr_name_len,   multiprocessing.managers.__name__.__len__,    [],                              24,   "multiprocessing.managers.__name__.__len__() == 24; verified with Python 3.14.3"]
    - [sync_name_eq,   multiprocessing.synchronize.__name__.__eq__,  ["multiprocessing.synchronize"], true, "multiprocessing.synchronize.__name__ == 'multiprocessing.synchronize' (len=27, longest); verified with Python 3.14.3"]
    - [sync_name_len,  multiprocessing.synchronize.__name__.__len__, [],                              27,   "multiprocessing.synchronize.__name__.__len__() == 27 (longest submodule name in this set); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra100
# ---------------------------------------------------------------------------

invariant multiprocessing_extra100.mp_name_len_is_15:
  description: "multiprocessing.__name__.__len__() == 15 — multiprocessing.__name__ is 'multiprocessing' (15 characters); this is the longest standalone module __name__ in this spec series — compare with concurrent.futures (18 chars as a dotted name, but as a single token 'multiprocessing' has 15 chars vs 'concurrent'=10); multiprocessing.__package__ is also 'multiprocessing' (len=15) and multiprocessing.__spec__.name is also 'multiprocessing' (len=15); all three attributes share the same 15-character value; NEW in extra100: first standalone multiprocessing module name length invariant in mpmodident100 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: multiprocessing.__name__.__len__
  args: []
  expected: 15

invariant multiprocessing_extra100.mp_package_equals_name:
  description: "multiprocessing.__package__.__eq__('multiprocessing') returns True — multiprocessing.__package__ is 'multiprocessing', which equals multiprocessing.__name__; for top-level packages, __package__ always equals __name__; this contrasts with submodules like multiprocessing.pool where __package__ would be 'multiprocessing' (the parent package name, not the submodule's own __name__); multiprocessing.__spec__.name is also 'multiprocessing' confirming the three-way equality (__name__ == __package__ == __spec__.name == 'multiprocessing'); multiprocessing is a directory-based package (Lib/multiprocessing/__init__.py); NEW in extra100: first standalone multiprocessing.__package__ equality invariant in mpmodident100 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: multiprocessing.__package__.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra100.mp_spec_class_is_ModuleSpec:
  description: "multiprocessing.__spec__.__class__.__name__.__eq__('ModuleSpec') returns True — multiprocessing.__spec__ is an instance of importlib.machinery.ModuleSpec; multiprocessing.__spec__.name is 'multiprocessing'; multiprocessing.__spec__.has_location is True (filesystem origin); multiprocessing.__spec__.submodule_search_locations.__class__.__name__ is 'list' (directory-based package); multiprocessing is a regular package (not a frozen module like abc — which has origin='frozen' and has_location=False; not a namespace package); NEW in extra100: first standalone multiprocessing __spec__ class name invariant in mpmodident100 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: multiprocessing.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant multiprocessing_extra100.mp_synchronize_name_len_is_27:
  description: "multiprocessing.synchronize.__name__.__len__() == 27 — multiprocessing.synchronize.__name__ is 'multiprocessing.synchronize' (27 chars: 'multiprocessing.'=16 + 'synchronize'=11); this is the longest submodule __name__ in multiprocessing: pool=20, queues=22, process=23, context=23, managers=24, synchronize=27; 'synchronize' is an 11-character suffix — the longest single-word suffix in this submodule set; multiprocessing.synchronize defines synchronization primitives (Lock, RLock, Semaphore, BoundedSemaphore, Event, Condition, Barrier) for use across processes; multiprocessing.synchronize.__package__ is 'multiprocessing' (the parent package); NEW in extra100: first standalone multiprocessing.synchronize name length invariant in mpmodident100 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: multiprocessing.synchronize.__name__.__len__
  args: []
  expected: 27

invariant multiprocessing_extra100.mp_process_context_same_len:
  description: "multiprocessing.process.__name__.__len__() == 23 — multiprocessing.process.__name__ is 'multiprocessing.process' (23 chars: 'multiprocessing.'=16 + 'process'=7); multiprocessing.context.__name__.__len__() is also 23 ('multiprocessing.context': 'multiprocessing.'=16 + 'context'=7); both 'process' and 'context' are 7-character suffix names producing the same submodule __name__ length of 23; multiprocessing.process defines the BaseProcess class (the superclass of all multiprocessing Process implementations); multiprocessing.context defines the spawning contexts (spawn, fork, forkserver); multiprocessing.Process.__module__ is 'multiprocessing.context' (not 'multiprocessing.process') because Process is created via the context system; NEW in extra100: first standalone multiprocessing.process name length invariant in mpmodident100 namespace; wave 254; verified with Python 3.14.3"
  category: module_identity
  kind: python_call_eq
  function: multiprocessing.process.__name__.__len__
  args: []
  expected: 23
