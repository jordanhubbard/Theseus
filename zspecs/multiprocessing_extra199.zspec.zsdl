       [],
       12,
       "mp.BufferTooShort.__bases__[0].__name__.__len__() == 12 — 'ProcessError' has 12 characters; new to multiprocessing_extra199"]
    - [timeout_error_base_name_eq_process_error,
       "TimeoutError.__bases__.__getitem__(0).__name__.__eq__",
       ["ProcessError"],
       true,
       "mp.TimeoutError.__bases__[0].__name__.__eq__('ProcessError') == True — TimeoutError inherits from ProcessError; new to multiprocessing_extra199"]
    - [timeout_error_base_name_len_eq_12,
       "TimeoutError.__bases__.__getitem__(0).__name__.__len__",
       [],
       12,
       "mp.TimeoutError.__bases__[0].__name__.__len__() == 12 — 'ProcessError' has 12 characters; new to multiprocessing_extra199"]

# ---------------------------------------------------------------------------
# Table 3: AuthenticationError hierarchy and module values
#
# multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'
# multiprocessing.BufferTooShort.__module__ == 'multiprocessing.context'
