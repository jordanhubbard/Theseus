spec: multiprocessing_extra199
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers exception class hierarchy depths for four multiprocessing exception classes: ProcessError, BufferTooShort, TimeoutError, AuthenticationError."
    - "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception' — ProcessError inherits directly from Exception. Verified with Python 3.14.3."
    - "multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError' — BufferTooShort inherits from ProcessError. Verified with Python 3.14.3."
    - "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError' — TimeoutError inherits from ProcessError. Verified with Python 3.14.3."
    - "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError' — AuthenticationError inherits from ProcessError. Verified with Python 3.14.3."
    - "multiprocessing.ProcessError.__module__ == 'multiprocessing.context' — all four exception classes are defined in multiprocessing.context. Verified with Python 3.14.3."
    - "multiprocessing.BufferTooShort.__module__ == 'multiprocessing.context' — defined in multiprocessing.context submodule. Verified with Python 3.14.3."
    - "multiprocessing.TimeoutError.__module__ == 'multiprocessing.context' — defined in multiprocessing.context submodule. Verified with Python 3.14.3."
    - "multiprocessing.AuthenticationError.__module__ == 'multiprocessing.context' — defined in multiprocessing.context submodule. Verified with Python 3.14.3."
    - "The module string 'multiprocessing.context' has length 23."
    - "The base class name 'ProcessError' has length 12; the base class name 'Exception' has length 9."
    - "Prior multiprocessing specs cover __doc__.__class__.__name__ identity. No prior spec covers exception class hierarchy depths or __module__ values."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing ProcessError hierarchy depth and module
#
# multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'
# multiprocessing.ProcessError.__module__ == 'multiprocessing.context'
#
# ProcessError is the root exception for the multiprocessing exception
# hierarchy. It inherits directly from Exception.
# New to multiprocessing_extra199.
# ---------------------------------------------------------------------------

table multiprocessing_extra199.process_error_hierarchy:
  description: "mp.ProcessError base class is Exception and module is multiprocessing.context; root of the multiprocessing exception hierarchy; new to multiprocessing_extra199"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: mpexchierarchy199

  columns: [id, function, args, expected, description]
  rows:
    - [process_error_base_name_eq_exception,
       "ProcessError.__bases__.__getitem__(0).__name__.__eq__",
       ["Exception"],
       true,
       "mp.ProcessError.__bases__[0].__name__.__eq__('Exception') == True — ProcessError inherits directly from Exception; new to multiprocessing_extra199"]
    - [process_error_base_name_len_eq_9,
       "ProcessError.__bases__.__getitem__(0).__name__.__len__",
       [],
       9,
       "mp.ProcessError.__bases__[0].__name__.__len__() == 9 — 'Exception' has 9 characters; new to multiprocessing_extra199"]
    - [process_error_module_eq_context,
       "ProcessError.__module__.__eq__",
       ["multiprocessing.context"],
       true,
       "mp.ProcessError.__module__.__eq__('multiprocessing.context') == True — ProcessError is defined in multiprocessing.context; new to multiprocessing_extra199"]
    - [process_error_module_len_eq_23,
       "ProcessError.__module__.__len__",
       [],
       23,
       "mp.ProcessError.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters; new to multiprocessing_extra199"]

# ---------------------------------------------------------------------------
# Table 2: BufferTooShort and TimeoutError base class names
#
# multiprocessing.BufferTooShort.__bases__[0].__name__ == 'ProcessError'
# multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError'
#
# Both BufferTooShort and TimeoutError inherit directly from ProcessError,
# forming the second tier of the multiprocessing exception hierarchy.
# New to multiprocessing_extra199.
# ---------------------------------------------------------------------------

