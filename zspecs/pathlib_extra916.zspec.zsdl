spec: pathlib_extra916
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks pathlib module class __qualname__ identity for PurePath and Path hierarchies"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra916.pure_path_qualnames:
  description: "pathlib PurePath hierarchy __qualname__ identity"
  kind: python_call_eq
  category: pure_path_qualnames
  id_prefix: pl916pp
  columns: [id, function, args, expected]
  rows:
    - [pl916pp001, pathlib.PurePath.__qualname__.__eq__,            ["PurePath"],            true]
    - [pl916pp002, pathlib.PurePosixPath.__qualname__.__eq__,       ["PurePosixPath"],       true]
    - [pl916pp003, pathlib.PureWindowsPath.__qualname__.__eq__,     ["PureWindowsPath"],     true]
    - [pl916pp004, pathlib.PurePath.__module__.__eq__,              ["pathlib"],             true]
    - [pl916pp005, pathlib.PurePosixPath.__module__.__eq__,         ["pathlib"],             true]
    - [pl916pp006, pathlib.PureWindowsPath.__module__.__eq__,       ["pathlib"],             true]
    - [pl916pp007, pathlib.PurePath.__name__.__eq__,                ["PurePath"],            true]
    - [pl916pp008, pathlib.PurePosixPath.__name__.__eq__,           ["PurePosixPath"],       true]

table pathlib_extra916.concrete_path_qualnames:
  description: "pathlib Path hierarchy __qualname__ identity"
  kind: python_call_eq
  category: concrete_path_qualnames
  id_prefix: pl916cp
  columns: [id, function, args, expected]
  rows:
    - [pl916cp001, pathlib.Path.__qualname__.__eq__,          ["Path"],          true]
    - [pl916cp002, pathlib.PosixPath.__qualname__.__eq__,     ["PosixPath"],     true]
    - [pl916cp003, pathlib.WindowsPath.__qualname__.__eq__,   ["WindowsPath"],   true]
    - [pl916cp004, pathlib.Path.__module__.__eq__,            ["pathlib"],       true]
    - [pl916cp005, pathlib.PosixPath.__module__.__eq__,       ["pathlib"],       true]
    - [pl916cp006, pathlib.WindowsPath.__module__.__eq__,     ["pathlib"],       true]
    - [pl916cp007, pathlib.Path.__name__.__eq__,              ["Path"],          true]
    - [pl916cp008, pathlib.PosixPath.__name__.__eq__,         ["PosixPath"],     true]

table pathlib_extra916.class_name_identity:
  description: "pathlib class __name__ identity for all six classes"
  kind: python_call_eq
  category: class_name_identity
  id_prefix: pl916cn
  columns: [id, function, args, expected]
  rows:
    - [pl916cn001, pathlib.PurePath.__name__.__eq__,        ["PurePath"],        true]
    - [pl916cn002, pathlib.PurePosixPath.__name__.__eq__,   ["PurePosixPath"],   true]
    - [pl916cn003, pathlib.PureWindowsPath.__name__.__eq__, ["PureWindowsPath"], true]
    - [pl916cn004, pathlib.Path.__name__.__eq__,            ["Path"],            true]
    - [pl916cn005, pathlib.PosixPath.__name__.__eq__,       ["PosixPath"],       true]
    - [pl916cn006, pathlib.WindowsPath.__name__.__eq__,     ["WindowsPath"],     true]
    - [pl916cn007, pathlib.WindowsPath.__name__.__eq__,     ["WindowsPath"],     true]
