spec: asyncio_extra228
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-queue.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-queue.html — Python asyncio queues documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "asyncio.Queue().__class__.__name__ == 'Queue' — verified with Python 3.14.3."
    - "asyncio.Queue().maxsize == 0 — maxsize of 0 means unlimited capacity; verified with Python 3.14.3."
    - "asyncio.Queue(maxsize=5).maxsize == 5 — maxsize is stored as provided; verified with Python 3.14.3."
    - "asyncio.Queue().empty() == True — a newly created queue is always empty; verified with Python 3.14.3."
    - "asyncio.Queue(maxsize=5).full() == False — a newly created bounded queue is not full; verified with Python 3.14.3."
    - "asyncio.Queue.__module__ == 'asyncio.queues' — Queue is defined in asyncio.queues submodule; verified with Python 3.14.3."
    - "asyncio.LifoQueue().__class__.__name__ == 'LifoQueue' — startswith('Lifo') is True; len is 9; verified with Python 3.14.3."
    - "asyncio.PriorityQueue().__class__.__name__ == 'PriorityQueue' — startswith('Priority') is True; len is 13; verified with Python 3.14.3."
    - "asyncio.Queue.__name__.__len__() == 5 — 'Queue' has 5 characters; verified with Python 3.14.3."
    - "asyncio.LifoQueue.__name__.__len__() == 9 — 'LifoQueue' has 9 characters; verified with Python 3.14.3."
    - "asyncio.PriorityQueue.__name__.__len__() == 13 — 'PriorityQueue' has 13 characters; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue size/empty/full behavioral contracts — extra228 namespace
#
# Queue maxsize=0 means unlimited; newly created queues are always empty.
# ---------------------------------------------------------------------------

table asyncio_extra228.queue_init_state:
  description: "asyncio Queue initial state behavioral contracts in aio228qs namespace"
  kind: python_call_eq
  category: behavioral
  id_prefix: aio228qs

  columns: [id, function, args, expected, description]
  rows:
    - [Queue_maxsize_default,    Queue().maxsize.__eq__,          [0], true, "asyncio.Queue().maxsize == 0 — default maxsize is 0 meaning unlimited capacity; verified with Python 3.14.3"]
    - [Queue_maxsize_five,       Queue(maxsize=5).maxsize.__eq__, [5], true, "asyncio.Queue(maxsize=5).maxsize == 5 — maxsize is stored as provided; verified with Python 3.14.3"]
    - [Queue_empty_on_create,    Queue().empty.__eq__,            [True], true, "asyncio.Queue().empty() == True — newly created queue is always empty; verified with Python 3.14.3"]
    - [Queue5_not_full_on_create, Queue(maxsize=5).full.__eq__,   [False], true, "asyncio.Queue(maxsize=5).full() == False — newly created bounded queue is not full; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Queue subclass __name__ identity contracts — extra228 namespace
#
# Queue, LifoQueue, PriorityQueue all have __module__ == 'asyncio.queues'.
# ---------------------------------------------------------------------------

table asyncio_extra228.queue_class_names:
  description: "asyncio Queue subclass __class__.__name__ and __name__ contracts in aio228qn namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio228qn

  columns: [id, function, args, expected, description]
  rows:
    - [Queue_class_name,          Queue.__name__.__eq__,          ["Queue"],         true, "asyncio.Queue.__name__ == 'Queue'; verified with Python 3.14.3"]
    - [LifoQueue_class_name,      LifoQueue.__name__.__eq__,      ["LifoQueue"],     true, "asyncio.LifoQueue.__name__ == 'LifoQueue'; verified with Python 3.14.3"]
    - [PriorityQueue_class_name,  PriorityQueue.__name__.__eq__,  ["PriorityQueue"], true, "asyncio.PriorityQueue.__name__ == 'PriorityQueue'; verified with Python 3.14.3"]
    - [LifoQueue_sw_Lifo,         LifoQueue.__name__.__startswith__, ["Lifo"],        true, "asyncio.LifoQueue.__name__.__startswith__('Lifo') == True; verified with Python 3.14.3"]
    - [PriorityQueue_sw_Priority, PriorityQueue.__name__.__startswith__, ["Priority"], true, "asyncio.PriorityQueue.__name__.__startswith__('Priority') == True; verified with Python 3.14.3"]
    - [Queue_ew_Queue,            Queue.__name__.__endswith__,    ["Queue"],         true, "asyncio.Queue.__name__.__endswith__('Queue') == True; verified with Python 3.14.3"]
    - [LifoQueue_ew_Queue,        LifoQueue.__name__.__endswith__, ["Queue"],        true, "asyncio.LifoQueue.__name__.__endswith__('Queue') == True; verified with Python 3.14.3"]
    - [PriorityQueue_ew_Queue,    PriorityQueue.__name__.__endswith__, ["Queue"],    true, "asyncio.PriorityQueue.__name__.__endswith__('Queue') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Queue subclass __name__ length contracts — extra228 namespace
#
# Queue=5, LifoQueue=9, PriorityQueue=13 chars; verified Python 3.14.3.
# ---------------------------------------------------------------------------

table asyncio_extra228.queue_name_lengths:
  description: "asyncio Queue subclass __name__.__len__() contracts in aio228nl namespace"
  kind: python_call_eq
  category: string_length
  id_prefix: aio228nl

  columns: [id, function, args, expected, description]
  rows:
    - [Queue_name_len_5,          Queue.__name__.__len__,         [], 5,  "asyncio.Queue.__name__.__len__() == 5 — 'Queue' has 5 characters; verified with Python 3.14.3"]
    - [LifoQueue_name_len_9,      LifoQueue.__name__.__len__,     [], 9,  "asyncio.LifoQueue.__name__.__len__() == 9 — 'LifoQueue' has 9 characters; verified with Python 3.14.3"]
    - [PriorityQueue_name_len_13, PriorityQueue.__name__.__len__, [], 13, "asyncio.PriorityQueue.__name__.__len__() == 13 — 'PriorityQueue' has 13 characters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Queue subclass __module__ contracts — extra228 namespace
#
# All queue classes live in asyncio.queues submodule; verified Python 3.14.3.
# ---------------------------------------------------------------------------

table asyncio_extra228.queue_module_checks:
  description: "asyncio Queue subclass __module__ contracts in aio228mod namespace"
  kind: python_call_eq
  category: module_identity
  id_prefix: aio228mod

  columns: [id, function, args, expected, description]
  rows:
    - [Queue_module_eq,          Queue.__module__.__eq__,         ["asyncio.queues"], true, "asyncio.Queue.__module__ == 'asyncio.queues'; verified with Python 3.14.3"]
    - [LifoQueue_module_eq,      LifoQueue.__module__.__eq__,     ["asyncio.queues"], true, "asyncio.LifoQueue.__module__ == 'asyncio.queues'; verified with Python 3.14.3"]
    - [PriorityQueue_module_eq,  PriorityQueue.__module__.__eq__, ["asyncio.queues"], true, "asyncio.PriorityQueue.__module__ == 'asyncio.queues'; verified with Python 3.14.3"]
    - [Queue_module_sw_asyncio,  Queue.__module__.__startswith__, ["asyncio"],        true, "asyncio.Queue.__module__.__startswith__('asyncio') == True; verified with Python 3.14.3"]
