spec: decimal_extra214
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic Specification, Version 1.72"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec covers: getcontext() rounding, Emax, Emin attributes; Decimal arithmetic __str__ results; ROUND_* constant string equality; Decimal class __name__ and __module__."
    - "getcontext().rounding == 'ROUND_HALF_EVEN' — the default rounding mode."
    - "getcontext().Emax == 999999 on CPython 3.14.3 (not 999999999 as stated in some docs — the C implementation uses a smaller default)."
    - "getcontext().Emin == -999999 — symmetric with Emax."
    - "Decimal('0.1') + Decimal('0.2') == Decimal('0.3') — exact decimal arithmetic avoids binary float rounding errors."
    - "Decimal('1.5') * Decimal('2') == Decimal('3.0') — trailing zero in product is preserved."
    - "Decimal('7') // Decimal('2') == Decimal('3') — floor division."
    - "Decimal('7') % Decimal('2') == Decimal('1') — modulo."
    - "Decimal('3.14159').quantize(Decimal('0.01')) == Decimal('3.14') — round to 2 decimal places using ROUND_HALF_EVEN."
    - "decimal.ROUND_HALF_EVEN, ROUND_UP, ROUND_DOWN, ROUND_CEILING, ROUND_FLOOR are str objects whose string value equals their name."
    - "Decimal.__name__ == 'Decimal'; Decimal.__module__ == 'decimal'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Context attributes: rounding, Emax, Emin
# getcontext() returns the current thread-local Context. Its rounding attribute
# is a str constant string like 'ROUND_HALF_EVEN'. Emax and Emin are ints.
# ---------------------------------------------------------------------------

invariant decimal_extra214.context.rounding_default:
  description: "getcontext().rounding == 'ROUND_HALF_EVEN' — the default rounding mode for decimal arithmetic"
  category: context
  kind: python_call_eq
  function: getcontext
  args: []
  method: rounding
  expected: "ROUND_HALF_EVEN"

invariant decimal_extra214.context.Emax:
  description: "getcontext().Emax == 999999 — maximum exponent for a normal Decimal value in CPython 3.14"
  category: context
  kind: python_call_eq
  function: getcontext
  args: []
  method: Emax
  expected: 999999

invariant decimal_extra214.context.Emin:
  description: "getcontext().Emin == -999999 — minimum exponent for a normal Decimal value in CPython 3.14"
  category: context
  kind: python_call_eq
  function: getcontext
  args: []
  method: Emin
  expected: -999999

# ---------------------------------------------------------------------------
# Decimal arithmetic __str__ results
# Exact decimal arithmetic avoids binary floating-point rounding errors.
# All results are tested via method: __str__ on the Decimal instance produced
# by the arithmetic operation.
# ---------------------------------------------------------------------------

table decimal_extra214.unary_method_str_repr:
  description: "Decimal unary methods: copy_abs and to_integral_value via __str__"
  kind: python_call_eq
  category: arithmetic
  id_prefix: decarith214
  function: Decimal

  columns: [id, args, method, method_chain, expected]
  rows:
    - [abs_negative,       ["-42"   ], copy_abs,         __str__, "42"  ]
    - [abs_positive,       ["42"    ], copy_abs,         __str__, "42"  ]
    - [negate_positive,    ["5"     ], copy_negate,      __str__, "-5"  ]
    - [integral_round_up,  ["3.7"   ], to_integral_value, __str__, "4"  ]
    - [integral_round_down,["3.2"   ], to_integral_value, __str__, "3"  ]

# ---------------------------------------------------------------------------
# Decimal.quantize() string results
# quantize() rounds a Decimal to the precision of the argument.
# ROUND_HALF_EVEN: 3.14159 -> 3.14 (digits: 4, 1 -> 4 rounds down, but 5 rounds up)
# Actually: 3.14159 quantized to 0.01 = 3.14 (because 1 < 5, rounds down).
# ---------------------------------------------------------------------------

invariant decimal_extra214.quantize.two_decimal_places:
  description: "Decimal('3.14159').quantize(Decimal('0.01')).__str__() == '3.14' — rounds to 2 decimal places using ROUND_HALF_EVEN"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["3.14159"]
  method: quantize
  method_args: ["0.01"]
  method_chain: __str__
  expected: "3.14"

# ---------------------------------------------------------------------------
# ROUND_* constants are str objects
# decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN', etc.
# ---------------------------------------------------------------------------

table decimal_extra214.round_constants:
  description: "ROUND_* module-level constants equal their own string names"
  kind: python_call_eq
  category: constants
  id_prefix: decrnd214

  columns: [id, function, args, expected]
  rows:
    - [half_even, ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_EVEN"], true]
    - [round_up,  ROUND_UP.__eq__,        ["ROUND_UP"],        true]
    - [round_down, ROUND_DOWN.__eq__,     ["ROUND_DOWN"],      true]
    - [ceiling,   ROUND_CEILING.__eq__,   ["ROUND_CEILING"],   true]
    - [floor,     ROUND_FLOOR.__eq__,     ["ROUND_FLOOR"],     true]

# ---------------------------------------------------------------------------
# Decimal class metadata: __name__ and __module__
# ---------------------------------------------------------------------------

invariant decimal_extra214.Decimal.class_name:
  description: "decimal.Decimal.__name__ == 'Decimal'"
  category: class_metadata
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra214.Decimal.module:
  description: "decimal.Decimal.__module__ == 'decimal'"
  category: class_metadata
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra214.ROUND_HALF_EVEN.value:
  description: "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' — the constant is a str equal to its own name"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra214.context.prec_is_28:
  description: "getcontext().prec == 28 — default arithmetic precision is 28 significant digits"
  category: context
  kind: python_call_eq
  function: getcontext
  args: []
  method: prec
  expected: 28

