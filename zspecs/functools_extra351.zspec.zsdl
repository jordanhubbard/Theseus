spec: functools_extra351
version: ">=3.14"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.Placeholder is a Python 3.14 new feature — a singleton sentinel for use with functools.partial."
    - "functools.Placeholder.__class__.__name__ == '_PlaceholderType' — the internal singleton class name."
    - "functools.Placeholder.__class__.__module__ == 'functools' — defined in the functools module."
    - "functools.Placeholder.__class__.__qualname__ == '_PlaceholderType' — top-level class, qualname equals name."
    - "repr(functools.Placeholder) == 'Placeholder' — the repr of the singleton is 'Placeholder' (not '...')."
    - "str(functools.Placeholder) == 'Placeholder' — the str of the singleton is 'Placeholder' (not '...')."
    - "functools._PlaceholderType is accessible on Python 3.14 and its __name__ == '_PlaceholderType'."
    - "functools.partial.__doc__.__len__() == 83 — partial docstring length verified on Python 3.14 macOS."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.Placeholder — class name, module, qualname (Python 3.14+)
# ---------------------------------------------------------------------------

invariant functools_extra351.Placeholder.class_name:
  description: "functools.Placeholder.__class__.__name__ == '_PlaceholderType'"
  category: Placeholder
  kind: python_call_eq
  function: Placeholder.__class__.__name__.__eq__
  args: ["_PlaceholderType"]
  expected: true

invariant functools_extra351.Placeholder.class_module:
  description: "functools.Placeholder.__class__.__module__ == 'functools'"
  category: Placeholder
  kind: python_call_eq
  function: Placeholder.__class__.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra351.Placeholder.class_qualname:
  description: "functools.Placeholder.__class__.__qualname__ == '_PlaceholderType'"
  category: Placeholder
  kind: python_call_eq
  function: Placeholder.__class__.__qualname__.__eq__
  args: ["_PlaceholderType"]
  expected: true

# ---------------------------------------------------------------------------
# functools.Placeholder — repr and str
#
# Both repr() and str() return 'Placeholder' on Python 3.14.
# ---------------------------------------------------------------------------

invariant functools_extra351.Placeholder.repr:
  description: "repr(functools.Placeholder) == 'Placeholder'"
  category: Placeholder
  kind: python_call_eq
  function: Placeholder.__repr__
  args: []
  expected: "Placeholder"

invariant functools_extra351.Placeholder.str:
  description: "str(functools.Placeholder) == 'Placeholder'"
  category: Placeholder
  kind: python_call_eq
  function: Placeholder.__str__
  args: []
  expected: "Placeholder"

# ---------------------------------------------------------------------------
# functools.Placeholder — singleton identity via class name eq
# ---------------------------------------------------------------------------

invariant functools_extra351.Placeholder.class_name_eq:
  description: "functools.Placeholder.__class__.__name__.__eq__('_PlaceholderType') — singleton class check"
  category: Placeholder
  kind: python_call_eq
  function: Placeholder.__class__.__name__.__eq__
  args: ["_PlaceholderType"]
  expected: true

# ---------------------------------------------------------------------------
# functools._PlaceholderType — accessible and named correctly
# ---------------------------------------------------------------------------

invariant functools_extra351.PlaceholderType.name:
  description: "functools._PlaceholderType.__name__ == '_PlaceholderType'"
  category: PlaceholderType
  kind: python_call_eq
  function: _PlaceholderType.__name__.__eq__
  args: ["_PlaceholderType"]
  expected: true

# ---------------------------------------------------------------------------
# functools.partial — __doc__ length
# ---------------------------------------------------------------------------

invariant functools_extra351.partial.doc_length:
  description: "functools.partial.__doc__.__len__() == 83"
  category: partial
  kind: python_call_eq
  function: partial.__doc__.__len__
  args: []
  expected: 83
