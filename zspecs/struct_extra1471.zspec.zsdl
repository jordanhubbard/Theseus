spec: struct_extra1471
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra1456.zspec.zsdl — covers __contains__ and __iter__ for Struct and struct.error"
    - "_struct.zspec.zsdl — covers Struct pack/unpack/calcsize and format string attributes"
  notes:
    - "Wave 545 theme: __len__ and __getitem__ method presence and type checks."
    - "struct.Struct is a C-level type (_struct.Struct) for compiled format strings; it is not a sequence."
    - "struct.error is the exception class raised on packing/unpacking failures."
    - "struct.Struct.__dict__ does not contain '__len__' — Struct objects are not sized sequences."
    - "struct.Struct.__dict__ does not contain '__getitem__' — Struct objects do not support subscript access."
    - "struct.Struct.size is a read-only integer attribute for the byte size of the packed format — it is not __len__."
    - "struct.error.__dict__ does not contain '__len__' or '__getitem__' — exceptions are not sequences."
    - "struct.Struct.__mro__ is (_struct.Struct, object) — single-level C-extension inheritance, no sequence mixin."
    - "list.__len__.__class__.__name__ == 'wrapper_descriptor' — reference descriptor type for sized sequences."
    - "list.__getitem__.__class__.__name__ == 'method_descriptor' — reference descriptor type for indexed access."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct — __len__ and __getitem__ absence checks
#
# struct.Struct is a compiled struct format object. It exposes pack(), unpack(),
# pack_into(), unpack_from(), iter_unpack(), size, and format — but it is not
# itself a sequence. Notably, struct.Struct.size gives the byte width of the
# packed format, but that is a named integer attribute, NOT a __len__
# implementation. The Struct type has no __len__ or __getitem__ in __dict__.
# ---------------------------------------------------------------------------

table struct_extra1471.Struct_len_getitem:
  description: "struct.Struct has no __len__ or __getitem__ — Struct is a compiled format object, not a sequence; neither method appears in Struct.__dict__; wave 545 __len__/__getitem__ absence theme; st1471lg anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st1471lg

  columns: [id, function, args, expected, description]
  rows:
    - [st1471lg001, "struct.Struct.__dict__.__contains__", ["__len__"],      false, "struct.Struct.__dict__ does not contain '__len__' — Struct is not a sized sequence"]
    - [st1471lg002, "struct.Struct.__dict__.__contains__", ["__getitem__"],  false, "struct.Struct.__dict__ does not contain '__getitem__' — Struct does not support subscript indexing"]
    - [st1471lg003, "struct.Struct.__dict__.__contains__", ["pack"],         true,  "struct.Struct.__dict__ contains 'pack' — confirms __dict__ lookup works correctly on Struct"]
    - [st1471lg004, "struct.Struct.__dict__.__contains__", ["unpack"],       true,  "struct.Struct.__dict__ contains 'unpack' — confirms __dict__ lookup works correctly on Struct"]
    - [st1471lg005, "struct.Struct.__dict__.__contains__", ["size"],         true,  "struct.Struct.__dict__ contains 'size' — Struct exposes byte size as a named attribute, not as __len__"]
    - [st1471lg006, "struct.Struct.__dict__.__contains__", ["iter_unpack"],  true,  "struct.Struct.__dict__ contains 'iter_unpack' — iter_unpack returns an iterator over a buffer, but Struct itself is not a sequence"]

# ---------------------------------------------------------------------------
# struct.error — __len__ and __getitem__ absence checks
#
# struct.error is the exception class for struct packing/unpacking failures.
# As an Exception subclass, it has no sequence protocol. Neither __len__ nor
# __getitem__ appears anywhere in its MRO (Exception > BaseException > object).
# This confirms that struct.error is purely an exception, not a sequence type.
# ---------------------------------------------------------------------------

table struct_extra1471.error_len_getitem:
  description: "struct.error has no __len__ or __getitem__ — struct.error is an Exception subclass, not a sequence; neither method in error.__dict__; wave 545 theme; st1471er anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st1471er

  columns: [id, function, args, expected, description]
  rows:
    - [st1471er001, "struct.error.__dict__.__contains__", ["__len__"],     false, "struct.error.__dict__ does not contain '__len__' — struct.error is an exception, not a sized sequence"]
    - [st1471er002, "struct.error.__dict__.__contains__", ["__getitem__"], false, "struct.error.__dict__ does not contain '__getitem__' — struct.error does not support subscript access"]
    - [st1471er003, "struct.error.__name__.__eq__",       ["error"],       true,  "struct.error.__name__ == 'error' — confirms the exception class name"]
    - [st1471er004, "struct.error.__module__.__eq__",     ["struct"],      true,  "struct.error.__module__ == 'struct' — error is defined in the struct module"]
    - [st1471er005, "struct.error.__dict__.__contains__", ["__doc__"],     true,  "struct.error.__dict__ contains '__doc__' — confirms __dict__ lookup works correctly on struct.error"]
    - [st1471er006, "struct.error.__dict__.__contains__", ["__module__"],  true,  "struct.error.__dict__ contains '__module__' — confirms __dict__ lookup works on struct.error class"]

# ---------------------------------------------------------------------------
# struct.Struct vs list symmetry — Struct lacks sequence protocol that list has
#
# list defines __len__ (wrapper_descriptor) and __getitem__ (method_descriptor).
# struct.Struct has neither. This table anchors the contrast: the struct.Struct.size
# attribute is distinct from __len__, and there is no __getitem__ at all.
# ---------------------------------------------------------------------------

table struct_extra1471.Struct_vs_list_protocol:
  description: "struct.Struct lacks __len__/__getitem__ that list provides — list.__len__ is 'wrapper_descriptor', list.__getitem__ is 'method_descriptor'; Struct has neither; contrast confirms Struct is not a sequence; wave 545 st1471vs anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: st1471vs

  columns: [id, function, args, expected, description]
  rows:
    - [st1471vs001, "struct.Struct.__dict__.__contains__",       ["__len__"],            false, "struct.Struct.__dict__ does not contain '__len__' — contrast with list which defines __len__"]
    - [st1471vs002, "struct.Struct.__dict__.__contains__",       ["__getitem__"],        false, "struct.Struct.__dict__ does not contain '__getitem__' — contrast with list which defines __getitem__"]
    - [st1471vs003, "list.__len__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true,  "list.__len__.__class__.__name__ == 'wrapper_descriptor' — reference value that Struct does NOT have"]
    - [st1471vs004, "list.__getitem__.__class__.__name__.__eq__", ["method_descriptor"], true,  "list.__getitem__.__class__.__name__ == 'method_descriptor' — reference value that Struct does NOT have"]
    - [st1471vs005, "struct.Struct.__name__.__eq__",             ["Struct"],             true,  "struct.Struct.__name__ == 'Struct' — confirms we are testing the correct C-level type"]
    - [st1471vs006, "struct.Struct.__dict__.__contains__",       ["format"],             true,  "struct.Struct.__dict__ contains 'format' — Struct exposes its format string, not sequence methods"]
