spec: theseus_re_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_re_cr2)
blocks: re

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html"
  notes:
    - "Clean-room extended regex utilities. Do NOT import re."
    - "compile(pattern, flags=0): compile pattern to reusable regex object."
    - "Pattern.sub(repl, string): replace matches with repl."
    - "Pattern.findall(string): return list of all matches."
    - "Pattern.split(string): split string at pattern matches."
    - "re_cr2_sub(): re.sub('a', 'b', 'banana') == 'bbnbnb'."
    - "re_cr2_findall(): re.findall('[0-9]+', 'a1b22c333') == ['1','22','333']."
    - "re_cr2_split(): re.split('[,;]', 'a,b;c') == ['a','b','c']."
    - "Export: compile, sub, findall, split (extending theseus_re)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_re_cr2.sub:
  description: "sub('a', 'b', 'banana') == 'bbnbnb'"
  category: sub
  kind: python_call_eq
  function: re_cr2_sub
  args: []
  expected: "bbnbnb"

invariant theseus_re_cr2.findall:
  description: "findall('[0-9]+', 'a1b22c333') == ['1','22','333']"
  category: findall
  kind: python_call_eq
  function: re_cr2_findall
  args: []
  expected: ["1", "22", "333"]

invariant theseus_re_cr2.split:
  description: "split('[,;]', 'a,b;c') == ['a','b','c']"
  category: split
  kind: python_call_eq
  function: re_cr2_split
  args: []
  expected: ["a", "b", "c"]
