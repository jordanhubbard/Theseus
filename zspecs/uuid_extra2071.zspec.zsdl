spec: uuid_extra2071
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "uuid.UUID is not a numeric type, so __pos__/__neg__ are absent from its own __dict__. uuid.UUID does not define __reduce__, __reduce_ex__, __copy__, or __deepcopy__ in its own __dict__; pickle support comes from the default object protocol. __getattribute__ is not overridden."
    - "uuid.SafeUUID is an IntEnum subclass; __pos__/__neg__ are inherited from int/IntEnum and not present in its own __dict__. None of the pickle/copy dunders appear in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra2071.unary_sign_protocol:
  description: "uuid types __pos__/__neg__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2071

  columns: [id, function, args, expected]
  rows:
    - ["uu2071001", "uuid.UUID.__dict__.__contains__",     ["__pos__"], false]
    - ["uu2071002", "uuid.UUID.__dict__.__contains__",     ["__neg__"], false]
    - ["uu2071003", "uuid.SafeUUID.__dict__.__contains__", ["__pos__"], false]
    - ["uu2071004", "uuid.SafeUUID.__dict__.__contains__", ["__neg__"], false]

