spec: decimal_extra18
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic specification"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal.zspec.zsdl and prior extras (decimal_extra through decimal_extra17)."
    - "decimal_extra5 covers Inexact/__qualname__ and Rounded/__qualname__; decimal_extra7 covers Inexact/__module__ and Rounded/__module__."
    - "No prior spec covers Clamped/__name__, Inexact/__name__, Rounded/__name__, Subnormal/__name__, or FloatOperation/__name__ via __name__.__eq__ call form."
    - "No prior spec covers Clamped/__qualname__, Subnormal/__qualname__, or FloatOperation/__qualname__."
    - "No prior spec covers Clamped/__module__, Subnormal/__module__, or FloatOperation/__module__."
    - "decimal.Clamped.__name__ == 'Clamped' — signal for exponent clamping to fit in valid range."
    - "decimal.Inexact.__name__ == 'Inexact' — signal for inexact rounding."
    - "decimal.Rounded.__name__ == 'Rounded' — signal for rounding that discards digits."
    - "decimal.Subnormal.__name__ == 'Subnormal' — signal for results below normal range."
    - "decimal.FloatOperation.__name__ == 'FloatOperation' — signal for mixing Decimal and float."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception subclass __name__ attributes — Clamped, Inexact, Rounded,
# Subnormal, FloatOperation
#
# decimal_extra5 covers Inexact/__qualname__ and Rounded/__qualname__ in a
# table. decimal_extra7 covers Inexact/__module__ and Rounded/__module__.
# No prior spec records any of these five classes via __name__.__eq__ call.
# ---------------------------------------------------------------------------

table decimal_extra18.exception_names:
  kind: python_call_eq
  category: class_identity
  id_prefix: exc_name

  columns: [id, function, args, expected]
  rows:
    - [clamped,         Clamped.__name__.__eq__,         ["Clamped"],         true]
    - [inexact,         Inexact.__name__.__eq__,         ["Inexact"],         true]
    - [rounded,         Rounded.__name__.__eq__,         ["Rounded"],         true]
    - [subnormal,       Subnormal.__name__.__eq__,       ["Subnormal"],       true]
    - [float_operation, FloatOperation.__name__.__eq__,  ["FloatOperation"],  true]

# ---------------------------------------------------------------------------
# Clamped, Subnormal, FloatOperation — __qualname__ and __module__
#
# decimal_extra5 covers Inexact/__qualname__ and Rounded/__qualname__ and
# decimal_extra7 covers their __module__. No prior spec covers __qualname__
# or __module__ for Clamped, Subnormal, or FloatOperation.
# All three are top-level classes defined in the decimal module.
# ---------------------------------------------------------------------------

invariant decimal_extra18.Clamped.qualname:
  description: "decimal.Clamped.__qualname__ == 'Clamped' — top-level exception class qualname"
  category: class_identity
  kind: python_call_eq
  function: Clamped.__qualname__.__eq__
  args: ["Clamped"]
  expected: true

invariant decimal_extra18.Subnormal.qualname:
  description: "decimal.Subnormal.__qualname__ == 'Subnormal' — top-level exception class qualname"
  category: class_identity
  kind: python_call_eq
  function: Subnormal.__qualname__.__eq__
  args: ["Subnormal"]
  expected: true

invariant decimal_extra18.FloatOperation.qualname:
  description: "decimal.FloatOperation.__qualname__ == 'FloatOperation' — top-level exception class qualname"
  category: class_identity
  kind: python_call_eq
  function: FloatOperation.__qualname__.__eq__
  args: ["FloatOperation"]
  expected: true

invariant decimal_extra18.Clamped.module:
  description: "decimal.Clamped.__module__ == 'decimal' — Clamped is defined in the decimal module"
  category: class_identity
  kind: python_call_eq
  function: Clamped.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra18.Subnormal.module:
  description: "decimal.Subnormal.__module__ == 'decimal' — Subnormal is defined in the decimal module"
  category: class_identity
  kind: python_call_eq
  function: Subnormal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra18.FloatOperation.module:
  description: "decimal.FloatOperation.__module__ == 'decimal' — FloatOperation is defined in the decimal module"
  category: class_identity
  kind: python_call_eq
  function: FloatOperation.__module__.__eq__
  args: ["decimal"]
  expected: true
