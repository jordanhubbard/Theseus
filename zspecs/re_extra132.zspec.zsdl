spec: re_extra132
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.__all__ additional membership for names not covered in re_extra98 — Pattern, Match, fullmatch, findall, finditer, split, subn, purge, escape, RegexFlag, MULTILINE, DOTALL, VERBOSE, UNICODE, LOCALE, NOFLAG, PatternError, and the single-letter flag aliases A, I, L, M, S, X, U."
    - "re.__all__ is a list of length 31 (first verified in re_extra98)."
    - "re.__all__.__contains__('Pattern') == True — the compiled regex type."
    - "re.__all__.__contains__('Match') == True — the match result type."
    - "re.__all__.__contains__('fullmatch') == True — fullmatch() requires the entire string to match."
    - "re.__all__.__contains__('findall') == True — findall() returns all non-overlapping matches."
    - "re.__all__.__contains__('finditer') == True — finditer() returns an iterator over matches."
    - "re.__all__.__contains__('split') == True — split() splits a string by occurrences of a pattern."
    - "re.__all__.__contains__('subn') == True — subn() returns a (new_string, count) tuple."
    - "re.__all__.__contains__('purge') == True — purge() clears the regex cache."
    - "re.__all__.__contains__('escape') == True — escape() escapes special regex characters."
    - "re.__all__.__contains__('RegexFlag') == True — the IntFlag enum for all regex flags."
    - "re.__all__.__contains__('MULTILINE') == True (value 8); re.__all__.__contains__('DOTALL') == True (value 16)."
    - "re.__all__.__contains__('VERBOSE') == True (value 64); re.__all__.__contains__('UNICODE') == True (value 32)."
    - "re.__all__.__contains__('LOCALE') == True (value 4); re.__all__.__contains__('NOFLAG') == True (value 0)."
    - "re.__all__.__contains__('PatternError') == True — the canonical exception name in Python 3.14+."
    - "Single-letter aliases in __all__: 'A' (ASCII), 'I' (IGNORECASE), 'L' (LOCALE), 'M' (MULTILINE), 'S' (DOTALL), 'X' (VERBOSE), 'U' (UNICODE)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.__all__ membership: function names not in re_extra98
# re_extra98 covered: compile, match, search, sub, IGNORECASE, error.
# This spec covers: fullmatch, findall, finditer, split, subn, purge, escape.
# ---------------------------------------------------------------------------

table re_extra132.all_function_membership:
  description: "re.__all__ contains function names: fullmatch, findall, finditer, split, subn, purge, escape"
  kind: python_call_eq
  category: module_all
  id_prefix: reall132

  columns: [id, function, args, expected]
  rows:
    - [has_fullmatch,   __all__.__contains__, ["fullmatch"],  true]
    - [has_findall,     __all__.__contains__, ["findall"],    true]
    - [has_finditer,    __all__.__contains__, ["finditer"],   true]
    - [has_split,       __all__.__contains__, ["split"],      true]
    - [has_subn,        __all__.__contains__, ["subn"],       true]
    - [has_purge,       __all__.__contains__, ["purge"],      true]
    - [has_escape,      __all__.__contains__, ["escape"],     true]
    - [not_sre,         __all__.__contains__, ["sre_parse"],  false]

# ---------------------------------------------------------------------------
# re.__all__ membership: type names and exception name
# Pattern, Match are C extension types exposed in __all__.
# RegexFlag is the IntFlag enum class.
# PatternError is the canonical exception name in Python 3.14+ (re.error alias).
# ---------------------------------------------------------------------------

table re_extra132.all_type_and_exception_membership:
  description: "re.__all__ contains type names Pattern, Match, RegexFlag, and exception name PatternError"
  kind: python_call_eq
  category: module_all
  id_prefix: reall132

  columns: [id, function, args, expected]
  rows:
    - [has_pattern,      __all__.__contains__, ["Pattern"],      true]
    - [has_match,        __all__.__contains__, ["Match"],        true]
    - [has_regexflag,    __all__.__contains__, ["RegexFlag"],    true]
    - [has_patternerror, __all__.__contains__, ["PatternError"], true]
    - [not_sre_pattern,  __all__.__contains__, ["SRE_Pattern"],  false]
    - [all_len_31_xchk,  __all__.__len__,      [],               31]

# ---------------------------------------------------------------------------
# re.__all__ membership: long-form flag names not in re_extra98
# re_extra98 covered: IGNORECASE, ASCII (via re_extra98.all_has_ic and re_extra98.RegexFlag tables).
# This spec covers: MULTILINE, DOTALL, VERBOSE, UNICODE, LOCALE, NOFLAG.
# Single-letter aliases: A, I, L, M, S, X, U.
# ---------------------------------------------------------------------------

table re_extra132.all_flag_membership:
  description: "re.__all__ contains flag names: MULTILINE, DOTALL, VERBOSE, UNICODE, LOCALE, NOFLAG, and aliases A, I, L, M, S, X, U"
  kind: python_call_eq
  category: module_all
  id_prefix: reall132

  columns: [id, function, args, expected]
  rows:
    - [has_multiline,  __all__.__contains__, ["MULTILINE"], true]
    - [has_dotall,     __all__.__contains__, ["DOTALL"],    true]
    - [has_verbose,    __all__.__contains__, ["VERBOSE"],   true]
    - [has_unicode,    __all__.__contains__, ["UNICODE"],   true]
    - [has_locale,     __all__.__contains__, ["LOCALE"],    true]
    - [has_noflag,     __all__.__contains__, ["NOFLAG"],    true]
    - [has_alias_a,    __all__.__contains__, ["A"],         true]
    - [has_alias_l,    __all__.__contains__, ["L"],         true]
    - [has_alias_m,    __all__.__contains__, ["M"],         true]
    - [has_alias_s,    __all__.__contains__, ["S"],         true]
    - [has_alias_x,    __all__.__contains__, ["X"],         true]
    - [has_alias_u,    __all__.__contains__, ["U"],         true]
    - [not_fullname_d, __all__.__contains__, ["DEBUG_FLAG"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra132.all.has_Pattern:
  description: "re.__all__.__contains__('Pattern') == True (re.Pattern is the compiled regular expression type; it is a C extension type from _sre and is exported in re.__all__)"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Pattern"]
  expected: true

invariant re_extra132.all.has_Match:
  description: "re.__all__.__contains__('Match') == True (re.Match is the match result type; it is a C extension type returned by match(), search(), and finditer())"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Match"]
  expected: true

invariant re_extra132.all.has_PatternError:
  description: "re.__all__.__contains__('PatternError') == True (re.PatternError is the canonical exception name added in Python 3.14; re.error remains as a backward-compatible alias)"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["PatternError"]
  expected: true

invariant re_extra132.all.has_MULTILINE:
  description: "re.__all__.__contains__('MULTILINE') == True (MULTILINE is the flag that makes ^ and $ match at line boundaries; its integer value is 8)"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["MULTILINE"]
  expected: true

invariant re_extra132.all.has_RegexFlag:
  description: "re.__all__.__contains__('RegexFlag') == True (RegexFlag is the IntFlag enum class that contains all flag values; individual flags like IGNORECASE are members of this enum)"
  category: module_all
  kind: python_call_eq
  function: __all__.__contains__
  args: ["RegexFlag"]
  expected: true
