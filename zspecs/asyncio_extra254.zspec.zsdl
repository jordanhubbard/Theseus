spec: asyncio_extra254
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-stream.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-stream.html — asyncio streams documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/streams.py (StreamReader, StreamWriter implementation)"
  notes:
    - "asyncio.StreamReader.__name__ == 'StreamReader' (len=12); __module__ == 'asyncio.streams' (len=15); __bases__[0].__name__ == 'object' (len=6) — StreamReader inherits directly from object."
    - "asyncio.StreamWriter.__name__ == 'StreamWriter' (len=12); __module__ == 'asyncio.streams' (len=15); __bases__[0].__name__ == 'object' (len=6) — StreamWriter also inherits directly from object."
    - "asyncio.open_connection.__name__ == 'open_connection' (len=15); __module__ == 'asyncio.streams' (len=15) — both the function name and module string share the same length of 15."
    - "asyncio.start_server.__name__ == 'start_server' (len=12); __module__ == 'asyncio.streams' (len=15)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.StreamReader class identity
#
# StreamReader.__name__ == 'StreamReader' (len=12)
# StreamReader.__module__ == 'asyncio.streams' (len=15)
# StreamReader.__bases__[0].__name__ == 'object' (len=6)
# ---------------------------------------------------------------------------

table asyncio_extra254.stream_reader_class_identity:
  description: "asyncio StreamReader class identity — StreamReader(len=12) inherits directly from object(len=6); __module__=='asyncio.streams'(len=15); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: async254sr

  columns: [id, function, args, expected, description]
  rows:
    - [sr_name_eq,   StreamReader.__name__.__eq__,                    ["StreamReader"],   true, "asyncio.StreamReader.__name__ == 'StreamReader'; verified with Python 3.14.3"]
    - [sr_name_len,  StreamReader.__name__.__len__,                   [],                 12,   "asyncio.StreamReader.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [sr_mod_eq,    StreamReader.__module__.__eq__,                  ["asyncio.streams"], true, "asyncio.StreamReader.__module__ == 'asyncio.streams'; verified with Python 3.14.3"]
    - [sr_mod_len,   StreamReader.__module__.__len__,                 [],                 15,   "asyncio.StreamReader.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [sr_base_eq,   "StreamReader.__bases__[0].__name__.__eq__",     ["object"],         true, "asyncio.StreamReader.__bases__[0].__name__ == 'object' — StreamReader inherits directly from object; verified with Python 3.14.3"]
    - [sr_base_len,  "StreamReader.__bases__[0].__name__.__len__",    [],                 6,    "asyncio.StreamReader.__bases__[0].__name__.__len__() == 6; verified with Python 3.14.3"]

