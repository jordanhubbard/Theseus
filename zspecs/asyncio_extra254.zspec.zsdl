table asyncio_extra254.stream_function_identity:
  description: "asyncio stream function identity — open_connection(len=15) and start_server(len=12) are both coroutine functions defined in asyncio.streams(len=15); notably open_connection.__name__ length (15) equals __module__ length (15); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: async254fn

  columns: [id, function, args, expected, description]
  rows:
    - [oc_name_eq,   open_connection.__name__.__eq__,   ["open_connection"],  true, "asyncio.open_connection.__name__ == 'open_connection'; verified with Python 3.14.3"]
    - [oc_name_len,  open_connection.__name__.__len__,  [],                   15,   "asyncio.open_connection.__name__.__len__() == 15; verified with Python 3.14.3"]
    - [oc_mod_eq,    open_connection.__module__.__eq__, ["asyncio.streams"],  true, "asyncio.open_connection.__module__ == 'asyncio.streams'; verified with Python 3.14.3"]
    - [oc_mod_len,   open_connection.__module__.__len__, [],                  15,   "asyncio.open_connection.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [ss_name_eq,   start_server.__name__.__eq__,      ["start_server"],     true, "asyncio.start_server.__name__ == 'start_server'; verified with Python 3.14.3"]
    - [ss_name_len,  start_server.__name__.__len__,     [],                   12,   "asyncio.start_server.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [ss_mod_eq,    start_server.__module__.__eq__,    ["asyncio.streams"],  true, "asyncio.start_server.__module__ == 'asyncio.streams'; verified with Python 3.14.3"]
    - [ss_mod_len,   start_server.__module__.__len__,   [],                   15,   "asyncio.start_server.__module__.__len__() == 15; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra254
# ---------------------------------------------------------------------------

invariant asyncio_extra254.stream_reader_module:
  description: "asyncio.StreamReader.__module__.__eq__('asyncio.streams') returns True — StreamReader is defined in asyncio.streams(len=15), not in the top-level asyncio package; this module string length (15) is identical to the function name open_connection(len=15); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: StreamReader.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true

invariant asyncio_extra254.stream_writer_base_is_object:
  description: "asyncio.StreamWriter.__bases__[0].__name__.__eq__('object') returns True — StreamWriter inherits directly from object(len=6) with no intermediate abstract base class; this mirrors StreamReader which also has object as its sole base; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "StreamWriter.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
