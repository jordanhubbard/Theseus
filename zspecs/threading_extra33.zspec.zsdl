spec: threading_extra33
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra32.zspec.zsdl."
    - "Prior specs covered: Thread.__name__/__module__/__qualname__, Lock/RLock/Event/Condition/Semaphore/BoundedSemaphore/Timer/Barrier class names/modules, current_thread/main_thread/active_count/__name__, TIMEOUT_MAX, local().__class__.__name__, threading.excepthook/__name__, class __module__/__name__/__qualname__ length tables, Lock.__module__.__len__()==7 (C extension), Thread/Event/Semaphore/Condition method qualname lens, class __bases__[0].__name__ for Thread/Event/Semaphore/BoundedSemaphore/Timer, Thread/__mro__.__len__()==2, BoundedSemaphore/__mro__.__len__()==3, class __dict__.__class__.__name__.__len__() for Thread/Event/Timer/Barrier/Condition/Semaphore, class __mro__.__len__() for Event/Timer/Condition/Barrier, Barrier/__bases__[0].__name__ == 'object', Condition/__bases__[0].__name__ == 'object', TIMEOUT_MAX.__class__.__name__.__len__() == 5, threading.__all__.__len__() == 28."
    - "NEW in this spec: Semaphore/__mro__.__len__() == 2; BoundedSemaphore/__bases__[0].__name__.__len__() == 9 (Semaphore); class __dict__.__class__.__name__.__len__() for Semaphore/BoundedSemaphore/local (all 12, though local is C extension); threading.local/__qualname__.__len__() == 6 (note: __qualname__ == '_local', not 'local'); threading.local/__mro__.__len__() == 2; threading.local/__bases__[0].__name__.__len__() == 6; RLock is a factory function not a class — threading.RLock.__dict__ is a dict (4 chars); Barrier method __qualname__.__len__() for wait/abort/reset."
    - "SURPRISE: threading.RLock is a factory function (type 'function'), not a class — threading.RLock.__dict__.__class__.__name__ == 'dict' (4 chars), not 'mappingproxy'."
    - "SURPRISE: threading.local.__qualname__ == '_local' (6 chars), not 'local' (5 chars) — the actual C type is _thread._local."
    - "threading.Semaphore.__mro__.__len__() == 2 — flat hierarchy, direct object subclass."
    - "BoundedSemaphore.__bases__[0].__name__.__len__() == 9 — 'Semaphore' has nine characters."
    - "threading.local.__mro__: [_thread._local, object] — C extension type with flat hierarchy."
    - "Barrier.wait.__qualname__.__len__() == 12; Barrier.abort.__qualname__.__len__() == 13; Barrier.reset.__qualname__.__len__() == 13."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__() table — extra33 namespace
#
# Additional threading classes not measured in extra32:
#   Semaphore.__dict__.__class__.__name__.__len__()       == 12 (mappingproxy)
#   BoundedSemaphore.__dict__.__class__.__name__.__len__() == 12 (mappingproxy)
#   threading.local.__dict__.__class__.__name__.__len__()  == 12 (mappingproxy for class)
#   threading.RLock.__dict__.__class__.__name__.__len__()  == 4  (dict — RLock is a function)
# NOTE: threading.RLock is a factory function, not a class. Its __dict__ is a
# plain dict (4 chars), not a mappingproxy. This is a notable exception to the
# uniform 12 seen in other threading objects.
# ---------------------------------------------------------------------------

table threading_extra33.class_dict_class_name_lengths:
  description: "threading class __dict__.__class__.__name__.__len__() for Semaphore/BoundedSemaphore/local/RLock in extra33 namespace"
  kind: python_call_eq
  category: class_structure
  id_prefix: classdictnamelen33

  columns: [id, function, args, expected]
  rows:
    - [Semaphore,       Semaphore.__dict__.__class__.__name__.__len__,          [], 12]
    - [BoundedSemaphore, BoundedSemaphore.__dict__.__class__.__name__.__len__,  [], 12]
    - [local,           threading.local.__dict__.__class__.__name__.__len__,    [], 12]
    - [RLock,           threading.RLock.__dict__.__class__.__name__.__len__,    [], 4]

# ---------------------------------------------------------------------------
# Semaphore MRO and BoundedSemaphore base name — extra33 namespace
#
# threading.Semaphore has MRO depth 2 — a flat hierarchy inheriting from
# object directly (not yet measured in prior specs; extra31 and extra32
# covered Thread==2, BoundedSemaphore==3, Event==2, Timer==3, Condition==2,
# Barrier==2).
# BoundedSemaphore.__bases__[0].__name__.__len__() == 9 — 'Semaphore' is
# 9 characters. extra31 confirmed the name == 'Semaphore' via equality;
# no prior spec measured its length.
# ---------------------------------------------------------------------------

table threading_extra33.semaphore_hierarchy:
  description: "threading.Semaphore MRO length and BoundedSemaphore base name length in extra33 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: sema33

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [Semaphore_mro_len, Semaphore.__mro__, [], !ascii "", __len__, [], "Semaphore MRO depth == 2"]

# ---------------------------------------------------------------------------
# threading.local class metadata — extra33 namespace
#
# threading.local is actually _thread._local, a C extension type. Its
# __qualname__ is '_local' (6 chars), not 'local' — a surprising discrepancy
# from its public name. Its MRO is flat: [_thread._local, object], giving
# __mro__.__len__() == 2.
# ---------------------------------------------------------------------------

table threading_extra33.local_metadata:
  description: "threading.local class metadata: __qualname__.__len__(), __mro__.__len__(), __bases__[0].__name__.__len__() in extra33 namespace"
  kind: python_call_eq
  category: class_structure
  id_prefix: localmetadata33

  columns: [id, function, args, expected]
  rows:
    - [qualname_len,  threading.local.__qualname__.__len__,              [], 6]
    - [mro_len,       threading.local.__mro__.__len__,                    [], 2]
    - [base_name_len, "threading.local.__bases__[0].__name__.__len__",     [], 6]

# ---------------------------------------------------------------------------
# Barrier method __qualname__ length table — extra33 namespace
#
# threading.Barrier exposes three public methods:
#   Barrier.wait.__qualname__  == 'Barrier.wait'  (12)
#   Barrier.abort.__qualname__ == 'Barrier.abort' (13)
#   Barrier.reset.__qualname__ == 'Barrier.reset' (13)
# abort and reset share length 13; wait is one shorter at 12.
# No prior spec has measured __qualname__.__len__() for Barrier methods.
# ---------------------------------------------------------------------------

table threading_extra33.barrier_method_qualname_lengths:
  description: "threading.Barrier method __qualname__ lengths for wait/abort/reset in extra33 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: barriermqualnamelen33

  columns: [id, function, args, expected]
  rows:
    - [wait,  Barrier.wait.__qualname__.__len__,  [], 12]
    - [abort, Barrier.abort.__qualname__.__len__, [], 13]
    - [reset, Barrier.reset.__qualname__.__len__, [], 13]

# ---------------------------------------------------------------------------
# BoundedSemaphore.__bases__[0].__name__.__len__() == 9 — extra33 standalone
#
# threading_extra31 confirmed BoundedSemaphore.__bases__[0].__name__ ==
# 'Semaphore' via equality check. No prior spec has measured the length of
# that base class name string. 'Semaphore' is 9 characters.
# ---------------------------------------------------------------------------

invariant threading_extra33.BoundedSemaphore_base_name_len:
  description: "threading.BoundedSemaphore.__bases__[0].__name__.__len__() == 9 — 'Semaphore' has nine characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__len__"
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# Semaphore.__mro__.__len__() == 2 — extra33 standalone invariant
#
# threading.Semaphore is a flat class inheriting directly from object.
# Prior specs measured Thread (2), Event (2), Condition (2), Barrier (2),
# BoundedSemaphore (3), Timer (3). Semaphore itself was not measured.
# ---------------------------------------------------------------------------

invariant threading_extra33.Semaphore_mro_len:
  description: "threading.Semaphore.__mro__.__len__() == 2 — Semaphore inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Semaphore.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# threading.RLock dict type name length — extra33 standalone invariant
#
# threading.RLock is a factory function, not a class. Its __dict__ is a
# plain dict (type name 'dict', 4 chars), unlike the mappingproxy (12 chars)
# found on all pure-Python threading class objects. This contrast with
# Thread, Event, Semaphore, etc. highlights the special nature of RLock.
# ---------------------------------------------------------------------------

invariant threading_extra33.RLock_dict_class_name_len:
  description: "threading.RLock.__dict__.__class__.__name__.__len__() == 4 — RLock is a factory function with a plain dict, not a mappingproxy"
  category: class_structure
  kind: python_call_eq
  function: threading.RLock.__dict__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# threading.local __qualname__ length — extra33 standalone invariant
#
# threading.local.__qualname__ == '_local' (6 chars), not 'local' (5 chars).
# The underlying C type is _thread._local, whose __qualname__ exposes the
# private name '_local'. No prior spec has confirmed this qualname length.
# ---------------------------------------------------------------------------

invariant threading_extra33.local_qualname_len:
  description: "threading.local.__qualname__.__len__() == 6 — qualname is '_local', not 'local'"
  category: class_structure
  kind: python_call_eq
  function: threading.local.__qualname__.__len__
  args: []
  expected: 6
