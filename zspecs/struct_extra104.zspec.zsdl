spec: struct_extra104
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra103.zspec.zsdl — covers struct.calcsize for three-element compound format strings ('!BHI','!BHQ','!bhi') / two-element float compound ('!fd') / repeat-count formats ('!2I','!3H') / fixed-size string formats ('!16s','!32s','!64s') / struct module attribute checks (__name__,__package__,__spec__,pack.__qualname__) (table + invariants)."
    - "struct_extra102.zspec.zsdl — covers struct.calcsize for single-char format codes ('!B','!H','!I','!Q','!b','!h','!i','!q','!f','!d') and two-element composites ('!BH','!IQ') and special codes ('!4s','c','x') (table + invariants)."
    - "struct_extra101.zspec.zsdl — covers struct.error class identity (__name__/__module__/__bases__[0].__name__/__mro__.__len__()==4/__class__.__name__=='type') / Struct class attribute equality / Struct method types (wrapper_descriptor/method_descriptor) and instance size (table + invariants)."
    - "struct_extra100.zspec.zsdl — covers Struct instance method qualname lengths / module-level function qualname lengths / Struct class-level method_descriptor type names (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers module-level function __doc__ lengths / Struct.size/__format__ __doc__ equality and lengths / struct module __doc__ length (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / descriptor qualname/name lengths and __objclass__.__name__ / Struct.__doc__ length (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra103; it does NOT duplicate invariants present in those files."
    - "Wave 270 theme: Struct.size and Struct.format getset_descriptor qualnames and __objclass__ / module-level function qualname equality for pack/unpack/calcsize/pack_into/unpack_from/iter_unpack / function module equality for all 6 module-level functions."
    - "struct.Struct.size.__qualname__ == 'Struct.size'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__qualname__ == 'Struct.format'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__qualname__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__ == 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__qualname__ == 'pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__ == 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct_extra98 anchors Struct.size/__format__ getset_descriptor class names and qualnames at table level; this spec anchors qualname equality (not just length) and __objclass__.__name__ equality as grouped tables under structdesc104."
    - "Note: struct_extra95 anchors pack_into/unpack_from/iter_unpack qualname lengths; struct_extra103 anchors pack.__qualname__=='pack' equality; this spec anchors all 6 module-level function qualname equalities and their __module__ values as grouped tables."
    - "Note: All 6 module-level functions have __module__ == '_struct' (from the _struct C extension). Their qualnames are plain function names (no class prefix) because they are module-level, not class-bound."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.size.__qualname__.__eq__('Struct.size')
# struct.Struct.format.__qualname__.__eq__('Struct.format')
# struct.Struct.size.__objclass__.__name__.__eq__('Struct')
# struct.Struct.format.__objclass__.__name__.__eq__('Struct')
# struct.Struct.size.__class__.__name__.__eq__('getset_descriptor')
#
# Wave 270 theme: Struct.size and Struct.format getset_descriptor qualnames and objclass.
#
# Struct.size and Struct.format are getset_descriptor objects (C-level attribute
# descriptors). Their qualnames are 'Struct.size' and 'Struct.format'. Their
# __objclass__ is the Struct class. struct_extra98 anchors these qualnames and
# class names; this spec anchors them via __eq__ calls in a grouped table under
# structdesc104. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra104.Struct_size_format_descriptor_qualnames_and_objclass:
  description: "Struct.size.__qualname__.__eq__('Struct.size')==True / Struct.format.__qualname__.__eq__('Struct.format')==True / Struct.size.__objclass__.__name__.__eq__('Struct')==True / Struct.format.__objclass__.__name__.__eq__('Struct')==True / Struct.size.__class__.__name__.__eq__('getset_descriptor')==True — both are getset_descriptors bound to the Struct class; extra98 anchors qualnames and class names; this spec anchors via __eq__ calls; first structdesc104 anchor"
  kind: python_call_eq
  category: descriptor_attributes
  id_prefix: structdesc104

  columns: [id, function, args, expected, description]
  rows:
    - [size_qualname_eq,      "Struct.size.__qualname__.__eq__",             ["Struct.size"],       true, "Struct.size.__qualname__ is 'Struct.size' (getset_descriptor; C-level read-only attribute)"]
    - [format_qualname_eq,    "Struct.format.__qualname__.__eq__",           ["Struct.format"],     true, "Struct.format.__qualname__ is 'Struct.format' (getset_descriptor; C-level read-only attribute)"]
    - [size_objclass_eq,      "Struct.size.__objclass__.__name__.__eq__",    ["Struct"],            true, "Struct.size.__objclass__.__name__ is 'Struct' (getset_descriptor is bound to the Struct C type)"]
    - [format_objclass_eq,    "Struct.format.__objclass__.__name__.__eq__",  ["Struct"],            true, "Struct.format.__objclass__.__name__ is 'Struct' (getset_descriptor is bound to the Struct C type)"]
    - [size_class_name,       "Struct.size.__class__.__name__.__eq__",       ["getset_descriptor"], true, "type(Struct.size) is 'getset_descriptor' (C-level get/set descriptor, not property or member_descriptor)"]

# ---------------------------------------------------------------------------
# struct.pack.__qualname__.__eq__('pack')
# struct.unpack.__qualname__.__eq__('unpack')
# struct.calcsize.__qualname__.__eq__('calcsize')
# struct.pack_into.__qualname__.__eq__('pack_into')
# struct.unpack_from.__qualname__.__eq__('unpack_from')
#
# Wave 270 theme: Module-level function qualname equality for pack/unpack/calcsize/pack_into/unpack_from.
#
# Module-level struct functions have unqualified qualnames (no 'ClassName.'
# prefix). pack.__qualname__=='pack', unpack.__qualname__=='unpack',
# calcsize.__qualname__=='calcsize', pack_into.__qualname__=='pack_into',
# unpack_from.__qualname__=='unpack_from'. struct_extra103 anchors
# pack.__qualname__=='pack' equality; struct_extra95 anchors qualname lengths;
# this spec anchors all five as a grouped equality table under structdesc104.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra104.module_function_qualname_equality:
  description: "pack.__qualname__.__eq__('pack')==True / unpack.__qualname__.__eq__('unpack')==True / calcsize.__qualname__.__eq__('calcsize')==True / pack_into.__qualname__.__eq__('pack_into')==True / unpack_from.__qualname__.__eq__('unpack_from')==True — all are module-level C functions with unqualified qualnames (no 'ClassName.' prefix); extra103 anchors pack equality; extra95 anchors lengths; this spec anchors 5-function equality group; first structdesc104 anchor"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: structdesc104

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qualname_eq,      "pack.__qualname__.__eq__",       ["pack"],        true, "pack.__qualname__ is 'pack' (4 chars; unqualified module-level C function from _struct)"]
    - [unpack_qualname_eq,    "unpack.__qualname__.__eq__",     ["unpack"],      true, "unpack.__qualname__ is 'unpack' (6 chars; unqualified module-level C function from _struct)"]
    - [calcsize_qualname_eq,  "calcsize.__qualname__.__eq__",   ["calcsize"],    true, "calcsize.__qualname__ is 'calcsize' (8 chars; unqualified module-level C function from _struct)"]
    - [pack_into_qualname,    "pack_into.__qualname__.__eq__",  ["pack_into"],   true, "pack_into.__qualname__ is 'pack_into' (9 chars; unqualified module-level C function from _struct)"]
    - [unpack_from_qualname,  "unpack_from.__qualname__.__eq__", ["unpack_from"], true, "unpack_from.__qualname__ is 'unpack_from' (11 chars; unqualified module-level C function from _struct)"]

# ---------------------------------------------------------------------------
# struct.iter_unpack.__qualname__.__eq__('iter_unpack')
# struct.pack.__module__.__eq__('_struct')
# struct.unpack.__module__.__eq__('_struct')
# struct.calcsize.__module__.__eq__('_struct')
# struct.pack_into.__module__.__eq__('_struct')
#
# Wave 270 theme: iter_unpack qualname equality and all module-level function modules.
#
# iter_unpack.__qualname__ is 'iter_unpack' (11 chars; same length as
# unpack_from). All 6 module-level struct functions have __module__=='_struct'
# (from the _struct C extension). struct_extra95 anchors __module__=='_struct'
# for module-level functions; this spec anchors the same via __eq__ calls in
# a new grouped table, adding iter_unpack qualname equality not anchored in
# extra103. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra104.iter_unpack_qualname_and_function_modules:
  description: "iter_unpack.__qualname__.__eq__('iter_unpack')==True / pack.__module__.__eq__('_struct')==True / unpack.__module__.__eq__('_struct')==True / calcsize.__module__.__eq__('_struct')==True / pack_into.__module__.__eq__('_struct')==True — iter_unpack qualname is 'iter_unpack' (11 chars; same length as unpack_from); all module-level functions come from _struct C extension; extra95 anchors __module__ equality; this spec adds iter_unpack qualname and groups modules; first structdesc104 anchor"
  kind: python_call_eq
  category: function_identity
  id_prefix: structdesc104

  columns: [id, function, args, expected, description]
  rows:
    - [iter_unpack_qualname,  "iter_unpack.__qualname__.__eq__",   ["iter_unpack"],  true, "iter_unpack.__qualname__ is 'iter_unpack' (11 chars; same length as unpack_from; returns iterator)"]
    - [pack_module_eq,        "pack.__module__.__eq__",            ["_struct"],      true, "pack.__module__ is '_struct' (C extension module; all struct module-level functions come from _struct)"]
    - [unpack_module_eq,      "unpack.__module__.__eq__",          ["_struct"],      true, "unpack.__module__ is '_struct' (C extension module)"]
    - [calcsize_module_eq,    "calcsize.__module__.__eq__",        ["_struct"],      true, "calcsize.__module__ is '_struct' (C extension module; calcsize is a pure C function)"]
    - [pack_into_module_eq,   "pack_into.__module__.__eq__",       ["_struct"],      true, "pack_into.__module__ is '_struct' (C extension module; pack_into writes into a buffer in-place)"]

# ---------------------------------------------------------------------------
# struct.Struct.size.__qualname__.__eq__('Struct.size') — standalone
#
# struct.Struct.size.__qualname__ is 'Struct.size'. The size attribute of the
# Struct class is a getset_descriptor that returns the number of bytes needed
# to represent the struct in memory (equivalent to calcsize(fmt) for that
# format string). Its qualname 'Struct.size' (11 chars: 'Struct.'=7 + 'size'=4)
# follows the 'ClassName.attrname' format. struct_extra98 anchors the qualname
# at table level; this spec anchors it as a standalone under structdesc104.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra104.Struct_size_qualname_eq:
  description: "struct.Struct.size.__qualname__.__eq__('Struct.size') == True — qualname is 'Struct.size' (11 chars = 'Struct.'7 + 'size'4); getset_descriptor returning byte size of packed struct; equivalent to calcsize(fmt) for the format; extra98 anchors at table level; first standalone under structdesc104"
  category: descriptor_attributes
  kind: python_call_eq
  function: "Struct.size.__qualname__.__eq__"
  args: ["Struct.size"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.format.__qualname__.__eq__('Struct.format') — standalone
#
# struct.Struct.format.__qualname__ is 'Struct.format'. The format attribute
# is a getset_descriptor that returns the format string that was used to
# create the Struct instance (e.g., '!IH' for a Struct('!IH') instance).
# Its qualname 'Struct.format' (13 chars: 'Struct.'=7 + 'format'=6) is
# longer than Struct.size (11 chars). struct_extra98 anchors this at table
# level; this spec anchors it as a standalone under structdesc104.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra104.Struct_format_qualname_eq:
  description: "struct.Struct.format.__qualname__.__eq__('Struct.format') == True — qualname is 'Struct.format' (13 chars = 'Struct.'7 + 'format'6); getset_descriptor returning the format string used to create the Struct; extra98 anchors at table level; first standalone under structdesc104"
  category: descriptor_attributes
  kind: python_call_eq
  function: "Struct.format.__qualname__.__eq__"
  args: ["Struct.format"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack.__qualname__.__eq__('unpack') — standalone
#
# struct.unpack.__qualname__ is 'unpack' (6 chars). Like all module-level
# struct functions, unpack has an unqualified qualname — it is a C-level
# function from _struct without any class prefix. struct.unpack(fmt, buffer)
# returns a tuple of values unpacked from buffer according to the format string
# fmt. The tuple always contains exactly calcsize(fmt) bytes' worth of data.
# struct_extra95 anchors unpack qualname length (6); struct_extra103 anchors
# only pack.__qualname__=='pack'; no prior spec anchors unpack qualname
# equality as a standalone under structdesc104.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra104.unpack_qualname_eq:
  description: "struct.unpack.__qualname__.__eq__('unpack') == True — qualname is 'unpack' (6 chars; unqualified C function from _struct); unpack(fmt, buffer) returns tuple of values from buffer; extra95 anchors length(6); extra103 only anchors pack equality; first standalone under structdesc104"
  category: function_qualnames
  kind: python_call_eq
  function: "unpack.__qualname__.__eq__"
  args: ["unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.iter_unpack.__qualname__.__eq__('iter_unpack') — standalone
#
# struct.iter_unpack.__qualname__ is 'iter_unpack' (11 chars). iter_unpack
# is the streaming variant of unpack — it returns an iterator that unpacks
# successive struct-sized chunks from a buffer. Its qualname length (11) equals
# that of unpack_from (also 11 chars). struct_extra95 anchors the iter_unpack
# qualname length; no prior spec anchors iter_unpack qualname equality as a
# standalone under structdesc104. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra104.iter_unpack_qualname_eq:
  description: "struct.iter_unpack.__qualname__.__eq__('iter_unpack') == True — qualname is 'iter_unpack' (11 chars; same length as unpack_from; returns iterator for successive struct-sized chunks); extra95 anchors length but not equality; first standalone under structdesc104"
  category: function_qualnames
  kind: python_call_eq
  function: "iter_unpack.__qualname__.__eq__"
  args: ["iter_unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.size.__objclass__.__name__.__eq__('Struct') — standalone
#
# struct.Struct.size.__objclass__.__name__ is 'Struct'. The __objclass__
# attribute of a descriptor indicates the class that defines (owns) the
# descriptor. For Struct.size, the owning class is Struct. This confirms that
# the size getset_descriptor is bound specifically to the Struct C type, not
# inherited from a base type. struct_extra98 anchors the descriptor's
# __objclass__.__name__ as part of a table on qualname/name lengths; this spec
# anchors it via an __eq__ call as a standalone under structdesc104.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra104.Struct_size_objclass_is_Struct:
  description: "struct.Struct.size.__objclass__.__name__.__eq__('Struct') == True — Struct.size.__objclass__ is the Struct C type (descriptor is bound to Struct, not a base type); __objclass__ is the defining class for the getset_descriptor; extra98 anchors objclass in table on qualname lengths; first standalone for __objclass__ equality under structdesc104"
  category: descriptor_attributes
  kind: python_call_eq
  function: "Struct.size.__objclass__.__name__.__eq__"
  args: ["Struct"]
  expected: true
