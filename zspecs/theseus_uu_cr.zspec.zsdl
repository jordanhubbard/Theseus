spec: theseus_uu_cr
version: ">=3.8"
backend: python_cleanroom(theseus_uu_cr)
blocks: uu

docs: https://docs.python.org/3/library/uu.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/uu.html"
  not_derived_from:
    - "CPython source: Lib/uu.py (internal implementation)"
  notes:
    - "Clean-room uu module. Do NOT import uu."
    - "encode(in_file, out_file, name): uuencode data."
    - "decode(in_file, out_file): uudecode data."

error_model: python_exceptions

invariant theseus_uu_cr.uu2_encode_decode:
  description: "uuencode then decode round-trips data correctly"
  category: encode
  kind: python_call_eq
  function: uu2_encode_decode
  args: []
  expected: true

invariant theseus_uu_cr.uu2_header:
  description: "encoded data starts with 'begin' header"
  category: encode
  kind: python_call_eq
  function: uu2_header
  args: []
  expected: true

invariant theseus_uu_cr.uu2_footer:
  description: "encoded data ends with 'end' footer"
  category: encode
  kind: python_call_eq
  function: uu2_footer
  args: []
  expected: true
