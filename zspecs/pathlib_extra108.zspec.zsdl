spec: pathlib_extra108
version: ">=3.9"
backend: python_module(pathlib)
extends: pathlib_extra107

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/_abc.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends pathlib_extra107.zspec.zsdl."
    - "This spec covers: pathlib module __name__, __package__, __spec__ attrs and class __module__ / __qualname__ lengths."
    - "pathlib.__package__ == 'pathlib' (pathlib is a package; __package__ equals the package name, not empty string)."
    - "pathlib.__spec__.__class__.__name__ == 'ModuleSpec' (length 10)."
    - "pathlib.__loader__.__class__.__name__ == 'SourceFileLoader' (pathlib is a regular Python file, not frozen)."
    - "pathlib.__spec__.has_location == True (pathlib is a source file module)."
    - "pathlib.PurePath.__module__ == 'pathlib' (length 7)."
    - "pathlib.Path.__module__ == 'pathlib' (length 7)."
    - "pathlib.PurePosixPath.__module__ == 'pathlib' (length 7)."
    - "pathlib.PureWindowsPath.__module__ == 'pathlib' (length 7)."
    - "pathlib.Path.__qualname__ == 'Path' (length 4)."
    - "pathlib.PurePosixPath.__qualname__ == 'PurePosixPath' (length 13)."
    - "pathlib.PureWindowsPath.__qualname__ == 'PureWindowsPath' (length 15)."
    - "pathlib.PosixPath.__qualname__ == 'PosixPath' (length 9)."
    - "pathlib.WindowsPath.__qualname__ == 'WindowsPath' (length 11)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib module identity: __name__, __package__, __spec__ attributes
# pathlib is a source file module, so has_location is True.
# __package__ == 'pathlib' (the package name, not empty string).
# __loader__.__class__.__name__ == 'SourceFileLoader'.
# ---------------------------------------------------------------------------

table pathlib_extra108.module_identity:
  description: "pathlib module identity: __name__ ('pathlib', len 7), __package__ ('pathlib'), __spec__.__class__.__name__ ('ModuleSpec'), __spec__.name ('pathlib')"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibmodid108

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,        __name__.__eq__,                    ["pathlib"],       true,  "pathlib.__name__ == 'pathlib'"]
    - [name_len,       __name__.__len__,                   [],                7,     "pathlib.__name__.__len__() == 7 ('pathlib' has 7 characters)"]
    - [pkg_eq,         __package__.__eq__,                 ["pathlib"],       true,  "pathlib.__package__ == 'pathlib' (pathlib is a package; __package__ == package name)"]
    - [pkg_not_empty,  __package__.__eq__,                 [""],              false, "pathlib.__package__ != '' (pathlib is a package, so __package__ is 'pathlib', not empty string)"]
    - [spec_cls_name,  __spec__.__class__.__name__.__eq__, ["ModuleSpec"],    true,  "pathlib.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [spec_name_eq,   __spec__.name.__eq__,               ["pathlib"],       true,  "pathlib.__spec__.name == 'pathlib'"]
    - [spec_name_len,  __spec__.name.__len__,              [],                7,     "pathlib.__spec__.name.__len__() == 7 ('pathlib' has 7 characters)"]
    - [loader_cls,     __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "pathlib.__loader__.__class__.__name__ == 'SourceFileLoader' (pathlib is a regular Python source file)"]

# ---------------------------------------------------------------------------
# pathlib module __spec__ source-file attributes
# has_location is True (pathlib has an on-disk .py file).
# __spec__.__class__.__name__.__len__() == 10 ('ModuleSpec').
# ---------------------------------------------------------------------------

table pathlib_extra108.spec_source_attrs:
  description: "pathlib.__spec__ source-module attributes: has_location (True), __spec__.__class__.__name__.__len__() (10)"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibmodid108

  columns: [id, function, args, expected, description]
  rows:
    - [has_loc_true,    __spec__.has_location.__eq__,            [true],  true,  "pathlib.__spec__.has_location == True (pathlib has an on-disk source file)"]
    - [spec_cls_len,    __spec__.__class__.__name__.__len__,     [],      10,    "pathlib.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec' has 10 characters)"]
    - [name_not_path,   __name__.__eq__,                         ["path"], false, "pathlib.__name__ != 'path' (the module name is the full 'pathlib', not 'path')"]

# ---------------------------------------------------------------------------
# pathlib class __module__ lengths
# PurePath, Path, PurePosixPath, PureWindowsPath, PosixPath, WindowsPath
# all have __module__ == 'pathlib' (length 7).
# ---------------------------------------------------------------------------

table pathlib_extra108.class_module_lengths:
  description: "pathlib class __module__ == 'pathlib' (length 7) for PurePath, Path, PurePosixPath, PureWindowsPath, PosixPath, WindowsPath"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibmodid108

  columns: [id, function, args, expected, description]
  rows:
    - [pp_mod_len,    PurePath.__module__.__len__,         [], 7, "pathlib.PurePath.__module__.__len__() == 7 ('pathlib' has 7 characters)"]
    - [path_mod_len,  Path.__module__.__len__,             [], 7, "pathlib.Path.__module__.__len__() == 7 ('pathlib' has 7 characters)"]
    - [ppp_mod_len,   PurePosixPath.__module__.__len__,    [], 7, "pathlib.PurePosixPath.__module__.__len__() == 7 ('pathlib' has 7 characters)"]
    - [pwp_mod_len,   PureWindowsPath.__module__.__len__,  [], 7, "pathlib.PureWindowsPath.__module__.__len__() == 7 ('pathlib' has 7 characters)"]
    - [posp_mod_len,  PosixPath.__module__.__len__,        [], 7, "pathlib.PosixPath.__module__.__len__() == 7 ('pathlib' has 7 characters)"]
    - [winp_mod_len,  WindowsPath.__module__.__len__,      [], 7, "pathlib.WindowsPath.__module__.__len__() == 7 ('pathlib' has 7 characters)"]

# ---------------------------------------------------------------------------
# pathlib class __qualname__ lengths
# Path=4, PurePosixPath=13, PureWindowsPath=15, PosixPath=9, WindowsPath=11.
# Note: PurePath.__qualname__ == 'PurePath' (8 characters).
# ---------------------------------------------------------------------------

table pathlib_extra108.class_qualname_lengths:
  description: "pathlib class __qualname__ lengths: PurePath (8), Path (4), PurePosixPath (13), PureWindowsPath (15), PosixPath (9), WindowsPath (11)"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibmodid108

  columns: [id, function, args, expected, description]
  rows:
    - [pp_qn_len,    PurePath.__qualname__.__len__,        [], 8,  "pathlib.PurePath.__qualname__.__len__() == 8 ('PurePath' has 8 characters)"]
    - [path_qn_len,  Path.__qualname__.__len__,            [], 4,  "pathlib.Path.__qualname__.__len__() == 4 ('Path' has 4 characters; shortest class qualname in this spec)"]
    - [ppp_qn_len,   PurePosixPath.__qualname__.__len__,   [], 13, "pathlib.PurePosixPath.__qualname__.__len__() == 13 ('PurePosixPath' has 13 characters)"]
    - [pwp_qn_len,   PureWindowsPath.__qualname__.__len__, [], 15, "pathlib.PureWindowsPath.__qualname__.__len__() == 15 ('PureWindowsPath' has 15 characters; longest in this spec)"]
    - [posp_qn_len,  PosixPath.__qualname__.__len__,       [], 9,  "pathlib.PosixPath.__qualname__.__len__() == 9 ('PosixPath' has 9 characters)"]
    - [winp_qn_len,  WindowsPath.__qualname__.__len__,     [], 11, "pathlib.WindowsPath.__qualname__.__len__() == 11 ('WindowsPath' has 11 characters)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra108.module_name_is_pathlib:
  description: "pathlib.__name__ == 'pathlib' (the public module name is 'pathlib', length 7)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra108.package_is_pathlib:
  description: "pathlib.__package__ == 'pathlib' (pathlib is organized as a package; its __package__ attribute equals its own name, not empty string)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra108.spec_has_location_true:
  description: "pathlib.__spec__.has_location == True (pathlib is a regular Python source module with an on-disk .py file)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

invariant pathlib_extra108.Path_module_len_7:
  description: "pathlib.Path.__module__.__len__() == 7 ('pathlib' has 7 characters; all pathlib public classes share this __module__ value)"
  category: class_identity
  kind: python_call_eq
  function: Path.__module__.__len__
  args: []
  expected: 7

invariant pathlib_extra108.PureWindowsPath_qualname_len_15:
  description: "pathlib.PureWindowsPath.__qualname__.__len__() == 15 ('PureWindowsPath' is the longest class qualname in this spec at 15 characters)"
  category: class_identity
  kind: python_call_eq
  function: PureWindowsPath.__qualname__.__len__
  args: []
  expected: 15
