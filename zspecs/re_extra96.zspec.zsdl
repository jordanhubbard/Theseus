spec: re_extra96
version: ">=3.9"
backend: python_module(re)
extends: re_extra95

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra95.zspec.zsdl."
    - "This spec covers: re module identity (__name__, __package__, __loader__, __spec__) + re.error class identity + re.RegexFlag enum identity + flag values."
    - "re.__name__ = 're' — the module's __name__ attribute equals its dotted name."
    - "re.__package__ = 're' — re is a package (its __package__ equals its own name)."
    - "re.__loader__.__class__.__name__ = 'SourceFileLoader' — re is a pure Python module."
    - "re.__spec__.__class__.__name__ = 'ModuleSpec' — module spec is a ModuleSpec instance."
    - "re.error.__name__ = 'PatternError' — in Python 3.14, re.error was renamed to PatternError (re.error is still an alias)."
    - "re.error.__module__ = 're' — PatternError/error is defined in the re module."
    - "re.error.__bases__[0].__name__ = 'Exception' — re.error directly extends Exception."
    - "re.error.__mro__.__len__() = 4 — MRO: [PatternError, Exception, BaseException, object]."
    - "re.RegexFlag.__name__ = 'RegexFlag' — the enum class name."
    - "re.RegexFlag.__bases__[0].__name__ = 'IntFlag' — RegexFlag extends IntFlag."
    - "re.RegexFlag.__mro__.__len__() = 7 — MRO: [RegexFlag, IntFlag, int, ReprEnum, Enum, int, object] (approximate)."
    - "re.IGNORECASE.value = 2, re.MULTILINE.value = 8, re.DOTALL.value = 16, re.VERBOSE.value = 64."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module identity: __name__, __package__, __loader__ class, __spec__ class
# re is a pure Python package loaded by SourceFileLoader.
# __spec__ is a ModuleSpec instance.
# ---------------------------------------------------------------------------

table re_extra96.module_identity:
  description: "re module identity: __name__, __package__, __loader__.__class__.__name__, __spec__.__class__.__name__"
  kind: python_call_eq
  category: module_identity
  id_prefix: remoduleid96

  columns: [id, function, args, expected]
  rows:
    - [re_name_eq,         __name__.__eq__,                       ["re"],               true]
    - [re_name_not_regex,  __name__.__eq__,                       ["regex"],            false]
    - [re_pkg_eq,          __package__.__eq__,                    ["re"],               true]
    - [re_loader_cls_eq,   __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true]
    - [re_spec_cls_eq,     __spec__.__class__.__name__.__eq__,    ["ModuleSpec"],       true]
    - [re_doc_cls_eq,      __doc__.__class__.__name__.__eq__,     ["str"],              true]

# ---------------------------------------------------------------------------
# re.error class identity
# In Python 3.14, re.error.__name__ == 'PatternError' (renamed from 'error').
# re.error is still available as an alias. __module__ == 're'.
# __bases__[0].__name__ == 'Exception'. __mro__.__len__() == 4.
# ---------------------------------------------------------------------------

table re_extra96.error_class_identity:
  description: "re.error class identity: __name__, __module__, __qualname__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: remoduleid96

  columns: [id, function, args, expected]
  rows:
    - [error_name_eq,       error.__name__.__eq__,                         ["PatternError"], true]
    - [error_module_eq,     error.__module__.__eq__,                       ["re"],           true]
    - [error_qualname_eq,   error.__qualname__.__eq__,                     ["PatternError"], true]
    - [error_base_eq,       "error.__bases__[0].__name__.__eq__",           ["Exception"],    true]
    - [error_base_not_exc,  "error.__bases__[0].__name__.__eq__",           ["ValueError"],   false]
    - [error_mro_len,       error.__mro__.__len__,                         [],               4]

# ---------------------------------------------------------------------------
# re.RegexFlag enum identity
# RegexFlag.__name__ == 'RegexFlag', __module__ == 're'.
# __bases__[0].__name__ == 'IntFlag' (extends IntFlag).
# __mro__.__len__() == 7.
# ---------------------------------------------------------------------------

table re_extra96.RegexFlag_identity:
  description: "re.RegexFlag enum identity: __name__, __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: remoduleid96

  columns: [id, function, args, expected]
  rows:
    - [regflag_name_eq,    RegexFlag.__name__.__eq__,                    ["RegexFlag"], true]
    - [regflag_module_eq,  RegexFlag.__module__.__eq__,                  ["re"],        true]
    - [regflag_base_eq,    "RegexFlag.__bases__[0].__name__.__eq__",      ["IntFlag"],   true]
    - [regflag_base_not,   "RegexFlag.__bases__[0].__name__.__eq__",      ["Flag"],      false]
    - [regflag_mro_len,    RegexFlag.__mro__.__len__,                    [],            7]

# ---------------------------------------------------------------------------
# re flag constant values
# IGNORECASE=2, MULTILINE=8, DOTALL=16, VERBOSE=64
# ---------------------------------------------------------------------------

table re_extra96.flag_values:
  description: "re flag constant values: IGNORECASE=2, MULTILINE=8, DOTALL=16, VERBOSE=64"
  kind: python_call_eq
  category: enum_values
  id_prefix: remoduleid96

  columns: [id, function, args, expected]
  rows:
    - [ignorecase_val,     IGNORECASE.value.__eq__,  [2],   true]
    - [multiline_val,      MULTILINE.value.__eq__,   [8],   true]
    - [dotall_val,         DOTALL.value.__eq__,      [16],  true]
    - [verbose_val,        VERBOSE.value.__eq__,     [64],  true]
    - [ignorecase_not_1,   IGNORECASE.value.__eq__,  [1],   false]
    - [multiline_not_2,    MULTILINE.value.__eq__,   [2],   false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra96.module.name_eq_re:
  description: "re.__name__ == 're' (the module's __name__ attribute equals its dotted module name)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["re"]
  expected: true

invariant re_extra96.error.name_is_PatternError:
  description: "re.error.__name__ == 'PatternError' (in Python 3.14, re.error was renamed to PatternError; re.error remains as an alias)"
  category: class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true

invariant re_extra96.error.mro_len_4:
  description: "re.error.__mro__.__len__() == 4 (MRO is [PatternError, Exception, BaseException, object])"
  category: class_identity
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

invariant re_extra96.RegexFlag.base_is_IntFlag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag extends IntFlag to provide integer-compatible flag values)"
  category: class_identity
  kind: python_call_eq
  function: "RegexFlag.__bases__[0].__name__.__eq__"
  args: ["IntFlag"]
  expected: true

invariant re_extra96.DOTALL.value_eq_16:
  description: "re.DOTALL.value == 16 (DOTALL flag has integer value 16)"
  category: enum_values
  kind: python_call_eq
  function: DOTALL.value.__eq__
  args: [16]
  expected: true
