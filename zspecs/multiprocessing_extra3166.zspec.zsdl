    - ["mp3166023", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__mul__"], false]
    - ["mp3166024", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__mul__"], false]

# ---------------------------------------------------------------------------
# combined — __add__, __sub__, __mul__ across all 8 mp subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __add__: true for BaseListProxy only; false for all others.
# __sub__: true for _BaseSetProxy only; false for all others.
# __mul__: true for BaseListProxy only; false for all others.
#
# The manager proxy classes again expose the arithmetic profile of their
# underlying Python collection type:
#   BaseListProxy  (proxies list): __add__=true, __sub__=false, __mul__=true
#   _BaseDictProxy (proxies dict): __add__=false, __sub__=false, __mul__=false
#   _BaseSetProxy  (proxies set):  __add__=false, __sub__=true,  __mul__=false
#
# This precisely mirrors Python's built-in type arithmetic:
#   list:  [1]+[2]=[1,2] (add), [1]*3=[1,1,1] (mul), no sub.
#   dict:  no +, no -, no * in dict's own __dict__ (dict | is __or__, not __add__).
#   set:   {1}-{2}={1} (sub via difference), no + (uses | for union), no *.
#
# BaseListProxy shows the characteristic list pattern: the same two operators
# that make lists useful as sequences (__add__ for concatenation, __mul__ for
# repetition) are faithfully proxied across the process boundary.
#
# _BaseSetProxy shows the set asymmetry: __sub__ for set difference is defined,
# but __add__ (not defined on set) and __mul__ (not defined on set) are absent.
# Sets use __or__/__and__/__xor__ for the other set-algebraic operators.
#
# Cross-wave pattern for manager proxies:
#   Wave 656 (mp3136): __len__ — all 3 proxies true; __getitem__ — list+dict true.
#   Wave 657 (mp3151): __setitem__/__delitem__ — list+dict true; __contains__ — all 3 true.
#   Wave 658 (mp3166): __add__/__mul__ — list only; __sub__ — set only.
#
# Cross-wave summary for all mp subjects:
#   Wave 652 (mp3076): __get__/__set__/__delete__ — all false for all 8.
#   Wave 653 (mp3091): __hash__/__eq__/__bool__ — all false for all 8.
#   Wave 654 (mp3106): __lt__/__le__/__gt__ — _BaseSetProxy true; others false.
#   Wave 655 (mp3121): __ge__ — _BaseSetProxy true; __repr__ — Pool true; __str__ all false.
#   Wave 656 (mp3136): __call__ all false; __len__ — 3 proxies true; __getitem__ — list+dict true.
#   Wave 657 (mp3151): __setitem__/__delitem__ — list+dict proxies true; __contains__ — all 3 proxies true.
#   Wave 658 (mp3166): __add__/__mul__ — BaseListProxy true; __sub__ — _BaseSetProxy true.
# ---------------------------------------------------------------------------

