    - ["mp3166010", operator.contains, [multiprocessing.pool.Pool.__dict__,                "__sub__"], false]
    - ["mp3166011", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,         "__sub__"], false]
    - ["mp3166012", operator.contains, [multiprocessing.pool.MapResult.__dict__,           "__sub__"], false]
    - ["mp3166013", operator.contains, [multiprocessing.managers.SyncManager.__dict__,     "__sub__"], false]
    - ["mp3166014", operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,   "__sub__"], false]
    - ["mp3166015", operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__,  "__sub__"], false]
    - ["mp3166016", operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,   "__sub__"], true]

# ---------------------------------------------------------------------------
# __mul__ dict-presence — operator.contains(Cls.__dict__, '__mul__')
#
# multiprocessing.managers.BaseListProxy: TRUE — proxies list * n (repetition)
#   to the managed list in the server process.
#   Python's built-in list defines __mul__ for repetition; the proxy mirrors it.
# multiprocessing.managers._BaseDictProxy: FALSE — dict does not define __mul__.
#   There is no dict * n operation in Python.
# multiprocessing.managers._BaseSetProxy: FALSE — set does not define __mul__.
#   There is no set * n operation in Python; sets are unordered and unique.
# All other 5 classes: false — Process, Pool, AsyncResult, MapResult,
#   and SyncManager have no repetition or multiplication semantics.
# ---------------------------------------------------------------------------

