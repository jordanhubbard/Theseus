# ---------------------------------------------------------------------------
# Module identity — readline.__name__ is 'readline'
# ---------------------------------------------------------------------------

invariant readline_extra.module.name:
  description: "readline.__name__ == 'readline' — the module's own __name__ attribute"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["readline"]
  expected: true
