spec: readline_extra
version: ">=3.9"
backend: python_module(readline)

docs: https://docs.python.org/3/library/readline.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/readline.html — Python readline module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/readline.c"
  notes:
    - "Extends readline.zspec.zsdl with __name__ and __module__ invariants for individual readline functions."
    - "readline is a POSIX-only C extension module; its functions are C builtins whose __module__ == 'readline'."
    - "read_history_file and write_history_file default to ~/.history when called with no filename argument."
    - "set_completer(None) clears the completer; get_completer() returns None when no completer is set."
    - "parse_and_bind() executes a readline init-file command string (e.g. 'tab: complete')."
    - "add_history() appends a string to the in-memory history list without writing to disk."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# read_history_file — function name and module affiliation
# ---------------------------------------------------------------------------

invariant readline_extra.read_history_file.name:
  description: "readline.read_history_file.__name__ == 'read_history_file'"
  category: functions
  kind: python_call_eq
  function: read_history_file.__name__.__eq__
  args: ["read_history_file"]
  expected: true

invariant readline_extra.read_history_file.module:
  description: "readline.read_history_file.__module__ == 'readline'"
  category: functions
  kind: python_call_eq
  function: read_history_file.__module__.__eq__
  args: ["readline"]
  expected: true

