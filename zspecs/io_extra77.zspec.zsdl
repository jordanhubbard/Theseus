spec: io_extra77
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra76."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor __class__.__name__ and __qualname__ checks."
    - "io_extra76 covers IOBase.close/flush/readable/writable/seekable/tell __class__.__name__ == 'method_descriptor' and __qualname__ values."
    - "This spec covers: RawIOBase/BufferedIOBase/TextIOBase method descriptor identity via __class__.__name__ for read, readinto (RawIOBase), write (BufferedIOBase/TextIOBase); IOBase.__dict__.__class__.__name__; IOBase.__dict__ membership for __module__, __doc__, __abstractmethods__, _abc_impl."
    - "io.RawIOBase.read.__class__.__name__ == 'method_descriptor' — C slot on RawIOBase."
    - "io.RawIOBase.readinto.__class__.__name__ == 'method_descriptor' — C slot on RawIOBase."
    - "io.BufferedIOBase.read.__class__.__name__ == 'method_descriptor' — C slot on BufferedIOBase."
    - "io.BufferedIOBase.write.__class__.__name__ == 'method_descriptor' — C slot on BufferedIOBase."
    - "io.TextIOBase.read.__class__.__name__ == 'method_descriptor' — C slot on TextIOBase."
    - "io.TextIOBase.write.__class__.__name__ == 'method_descriptor' — C slot on TextIOBase."
    - "io.IOBase.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy."
    - "io.IOBase.__dict__ contains '__module__' == True — Python 3.14 IOBase is a pure Python ABC."
    - "io.IOBase.__dict__ contains '__doc__' == True."
    - "io.IOBase.__dict__ contains '__abstractmethods__' == True."
    - "io.IOBase.__dict__ contains '_abc_impl' == True."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# RawIOBase method descriptor class checks — read and readinto
# io_extra76 checks IOBase methods; no prior spec checks RawIOBase.read or
# RawIOBase.readinto __class__.__name__.
# ---------------------------------------------------------------------------

table io_extra77.RawIOBase_method_classes:
  description: "RawIOBase C methods read and readinto have __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_descriptors
  id_prefix: iomore77

  columns: [id, function, args, expected]
  rows:
    - [read,    RawIOBase.read.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [readinto, RawIOBase.readinto.__class__.__name__.__eq__, ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# BufferedIOBase and TextIOBase method descriptor class checks
# BufferedIOBase.read, BufferedIOBase.write, TextIOBase.read, TextIOBase.write
# are all C method_descriptors. Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra77.BufferedTextIOBase_method_classes:
  description: "BufferedIOBase and TextIOBase C methods have __class__.__name__ == 'method_descriptor'"
  kind: python_call_eq
  category: method_descriptors
  id_prefix: iomore77

  columns: [id, function, args, expected]
  rows:
    - [buffered_read,  BufferedIOBase.read.__class__.__name__.__eq__,  ["method_descriptor"], true]
    - [buffered_write, BufferedIOBase.write.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [text_read,      TextIOBase.read.__class__.__name__.__eq__,      ["method_descriptor"], true]
    - [text_write,     TextIOBase.write.__class__.__name__.__eq__,     ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# IOBase.__dict__ class and membership checks
# Python 3.14 IOBase is a pure Python ABC. Its __dict__ is a mappingproxy
# containing __module__, __doc__, __abstractmethods__, _abc_impl.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra77.IOBase_dict_class:
  description: "IOBase.__dict__ is a mappingproxy"
  kind: python_call_eq
  category: class_dict
  id_prefix: iomore77

  columns: [id, function, args, expected]
  rows:
    - [mappingproxy, IOBase.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# IOBase.__dict__ membership checks
# __module__, __doc__, __abstractmethods__, _abc_impl are present in the dict.
# Not covered in any prior io spec.
# ---------------------------------------------------------------------------

table io_extra77.IOBase_dict_contains:
  description: "IOBase.__dict__ contains expected ABC infrastructure keys"
  kind: python_call_eq
  category: class_dict
  id_prefix: iomore77

  columns: [id, function, args, expected]
  rows:
    - [has_module,           "IOBase.__dict__.__contains__", ["__module__"],           true]
    - [has_doc,              "IOBase.__dict__.__contains__", ["__doc__"],              true]
    - [has_abstractmethods,  "IOBase.__dict__.__contains__", ["__abstractmethods__"],  true]
    - [has_abc_impl,         "IOBase.__dict__.__contains__", ["_abc_impl"],            true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra77.RawIOBase_read.method_descriptor:
  description: "io.RawIOBase.read.__class__.__name__ == 'method_descriptor'"
  category: method_descriptors
  kind: python_call_eq
  function: RawIOBase.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra77.RawIOBase_readinto.method_descriptor:
  description: "io.RawIOBase.readinto.__class__.__name__ == 'method_descriptor'"
  category: method_descriptors
  kind: python_call_eq
  function: RawIOBase.readinto.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra77.BufferedIOBase_write.method_descriptor:
  description: "io.BufferedIOBase.write.__class__.__name__ == 'method_descriptor'"
  category: method_descriptors
  kind: python_call_eq
  function: BufferedIOBase.write.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra77.TextIOBase_read.method_descriptor:
  description: "io.TextIOBase.read.__class__.__name__ == 'method_descriptor'"
  category: method_descriptors
  kind: python_call_eq
  function: TextIOBase.read.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra77.IOBase_dict.mappingproxy:
  description: "io.IOBase.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: IOBase.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
