# ---------------------------------------------------------------------------
# Table 3: __invert__ dict-presence checks
#
# Wave 627 theme: abc module types do not implement the bitwise NOT (unary ~)
# operator. __invert__ does not appear in any of these classes' own __dict__.
# ---------------------------------------------------------------------------

table abc_extra2701.invert_protocol:
  description: "abc.ABCMeta, abc.ABC, abc.abstractmethod, abc.abstractproperty __invert__ dict-presence checks — none define bitwise NOT in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2701

  columns: [id, function, args, expected]
  rows:
    - ["ab2701017", "abc.ABCMeta.__dict__.__contains__",          ["__invert__"], false]
    - ["ab2701018", "abc.ABC.__dict__.__contains__",              ["__invert__"], false]
    - ["ab2701019", "abc.abstractmethod.__dict__.__contains__",   ["__invert__"], false]
    - ["ab2701020", "abc.abstractproperty.__dict__.__contains__", ["__invert__"], false]

# ---------------------------------------------------------------------------
# Table 4: combined ilshift/irshift checks for ABCMeta and abstractproperty
#
# Wave 627 theme: in-place variants (__ilshift__, __irshift__) are equally
# absent from abc types. ABCMeta and abstractproperty do not define any
# in-place left-shift or right-shift operator in their own __dict__.
# ---------------------------------------------------------------------------

table abc_extra2701.inplace_shift_protocol:
  description: "abc.ABCMeta and abc.abstractproperty __ilshift__/__irshift__ dict-presence checks — in-place shift variants also absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2701

  columns: [id, function, args, expected]
  rows:
    - ["ab2701021", "abc.ABCMeta.__dict__.__contains__",          ["__ilshift__"], false]
    - ["ab2701022", "abc.ABCMeta.__dict__.__contains__",          ["__irshift__"], false]
    - ["ab2701023", "abc.ABC.__dict__.__contains__",              ["__ilshift__"], false]
    - ["ab2701024", "abc.ABC.__dict__.__contains__",              ["__irshift__"], false]
    - ["ab2701025", "abc.abstractmethod.__dict__.__contains__",   ["__ilshift__"], false]
    - ["ab2701026", "abc.abstractmethod.__dict__.__contains__",   ["__irshift__"], false]
    - ["ab2701027", "abc.abstractproperty.__dict__.__contains__", ["__ilshift__"], false]
    - ["ab2701028", "abc.abstractproperty.__dict__.__contains__", ["__irshift__"], false]
