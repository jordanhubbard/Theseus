spec: abc_extra2701
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 627 (_extra2701): __lshift__, __rshift__, __invert__ dict-presence checks."
    - "abc.ABCMeta is a metaclass; abc.ABC is a helper base class; abc.abstractmethod and abc.abstractproperty are decorators."
    - "None of these abc constructs define left-shift, right-shift, or bitwise NOT protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __lshift__ dict-presence checks
#
# Wave 627 theme: abc module types do not implement the left-shift operator.
# Neither __lshift__ nor its reflected variant __rlshift__ appear in any of
# these classes' own __dict__.
# ---------------------------------------------------------------------------

table abc_extra2701.lshift_protocol:
  description: "abc.ABCMeta, abc.ABC, abc.abstractmethod, abc.abstractproperty __lshift__/__rlshift__ dict-presence checks — none define left-shift in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2701

  columns: [id, function, args, expected]
  rows:
    - ["ab2701001", "abc.ABCMeta.__dict__.__contains__",        ["__lshift__"],  false]
    - ["ab2701002", "abc.ABCMeta.__dict__.__contains__",        ["__rlshift__"], false]
    - ["ab2701003", "abc.ABC.__dict__.__contains__",            ["__lshift__"],  false]
    - ["ab2701004", "abc.ABC.__dict__.__contains__",            ["__rlshift__"], false]
    - ["ab2701005", "abc.abstractmethod.__dict__.__contains__", ["__lshift__"],  false]
    - ["ab2701006", "abc.abstractmethod.__dict__.__contains__", ["__rlshift__"], false]
    - ["ab2701007", "abc.abstractproperty.__dict__.__contains__", ["__lshift__"],  false]
    - ["ab2701008", "abc.abstractproperty.__dict__.__contains__", ["__rlshift__"], false]

