spec: pp3286
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 666 (pp3286): __iadd__, __isub__, __imul__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __iadd__, __isub__, __imul__ dict-presence (in-place augmented assignment)."
    - "No pathlib class defines __iadd__ in its own __dict__: path objects represent filesystem paths, not numeric types, and do not implement in-place addition."
    - "No pathlib class defines __isub__ in its own __dict__: path objects do not implement in-place subtraction; arithmetic is not part of the path protocol."
    - "No pathlib class defines __imul__ in its own __dict__: path objects do not implement in-place multiplication; augmented assignment operators have no meaning for filesystem paths."
    - "pathlib defines __truediv__ (wave 659) for path joining but defines no in-place augmented assignment operators on any class."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iadd__ dict-presence — operator.contains(Cls.__dict__, '__iadd__')
#
# No pathlib class defines __iadd__ in its own __dict__; all false.
# pathlib types represent immutable filesystem paths, not numeric operands.
# pathlib defines __truediv__ (wave 659) but no in-place arithmetic operators.
# ---------------------------------------------------------------------------

table pp3286.iadd:
  description: "pathlib types __iadd__ dict-presence checks; wave 666"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3286

  columns: [id, function, args, expected]
  rows:
    - ["pp3286001", operator.contains, [pathlib.PurePath.__dict__,         "__iadd__"], false]
    - ["pp3286002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__iadd__"], false]
    - ["pp3286003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__iadd__"], false]
    - ["pp3286004", operator.contains, [pathlib.Path.__dict__,             "__iadd__"], false]
    - ["pp3286005", operator.contains, [pathlib.PosixPath.__dict__,        "__iadd__"], false]

