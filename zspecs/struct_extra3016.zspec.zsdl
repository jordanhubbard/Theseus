spec: st3016
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct: Interpret bytes as packed binary data"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 648 (st3016): __iter__, __next__, __reversed__ dict-presence checks for struct types."
    - "struct.Struct is a C extension type for packing/unpacking binary data — not a sequence or iterator; it does not define __iter__, __next__, or __reversed__ in its own __dict__."
    - "struct.error is an exception subclass — not a sequence or iterator type."
    - "None of the struct types define __iter__, __next__, or __reversed__ in their own __dict__."
    - "Verified types: struct.Struct, struct.error."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table st3016.iter:
  description: "struct types __iter__ dict-presence checks; wave 648"
