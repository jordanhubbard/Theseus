    - ["as3391010", operator.contains, [asyncio.LifoQueue.__dict__,        "__int__"], false]

# ---------------------------------------------------------------------------
# __float__ dict-presence — operator.contains(Cls.__dict__, '__float__')
#
# All 10 asyncio classes return false for __float__.
# float() delegates to __float__ (numbers.Real protocol) when defined.
# asyncio types define no numeric protocol — no real-valued magnitude is
#   associated with any asyncio concurrency primitive.
# asyncio.Event/Lock/Condition: boolean-state guards; float(event) is not
#   a meaningful Python expression for synchronization objects.
# asyncio.Semaphore/BoundedSemaphore: the permit counter is encapsulated and
#   not exposed through __float__ or any numeric data model method.
# asyncio.Task/Future: coroutine result handles; float(task) and
#   float(future) are not valid Python expressions.
# asyncio.Queue/PriorityQueue/LifoQueue: item stores; float(queue) is not
#   defined. Queue length is accessed via qsize(), not float().
# ---------------------------------------------------------------------------

