    - ["io2851041", "io.RawIOBase.__dict__.__contains__",      ["__rrshift__"], false]
    - ["io2851042", "io.RawIOBase.__dict__.__contains__",      ["__rpow__"],    false]
    - ["io2851043", "io.BufferedIOBase.__dict__.__contains__", ["__rlshift__"], false]
    - ["io2851044", "io.BufferedIOBase.__dict__.__contains__", ["__rrshift__"], false]
    - ["io2851045", "io.BufferedIOBase.__dict__.__contains__", ["__rpow__"],    false]
