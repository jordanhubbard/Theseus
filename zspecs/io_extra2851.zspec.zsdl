spec: io2851
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/io_extra2836.zspec.zsdl — wave 636 predecessor (covered __rtruediv__, __rfloordiv__, __rmod__)"
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "Wave 637 theme: __rlshift__, __rrshift__, and __rpow__ dict-presence checks (reflected left-shift, right-shift, and power operators)."
    - "io classes are I/O stream objects, not numeric types — none define reflected bitwise shift or power operators."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase do NOT define __rlshift__, __rrshift__, or __rpow__."
    - "io.BytesIO, io.StringIO, io.FileIO do NOT define any of these reflected operators."
    - "io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper, io.IncrementalNewlineDecoder also absent for all three."
    - "Absence is consistent across all 11 io classes tested — io streams have no arithmetic or bitwise semantics."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __rlshift__ dict-presence — absent from all io ABC and concrete classes
# ---------------------------------------------------------------------------

table io2851.rlshift_protocol:
  description: "__rlshift__ is absent from all io class __dict__s — io streams are not bitwise-shift operands"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2851

  columns: [id, function, args, expected]
  rows:
    - ["io2851001", "io.IOBase.__dict__.__contains__",              ["__rlshift__"], false]
    - ["io2851002", "io.RawIOBase.__dict__.__contains__",           ["__rlshift__"], false]
    - ["io2851003", "io.BufferedIOBase.__dict__.__contains__",      ["__rlshift__"], false]
    - ["io2851004", "io.TextIOBase.__dict__.__contains__",          ["__rlshift__"], false]
    - ["io2851005", "io.BytesIO.__dict__.__contains__",             ["__rlshift__"], false]
    - ["io2851006", "io.StringIO.__dict__.__contains__",            ["__rlshift__"], false]
    - ["io2851007", "io.FileIO.__dict__.__contains__",              ["__rlshift__"], false]
    - ["io2851008", "io.BufferedReader.__dict__.__contains__",      ["__rlshift__"], false]
    - ["io2851009", "io.BufferedWriter.__dict__.__contains__",      ["__rlshift__"], false]
    - ["io2851010", "io.BufferedRandom.__dict__.__contains__",      ["__rlshift__"], false]
    - ["io2851011", "io.TextIOWrapper.__dict__.__contains__",       ["__rlshift__"], false]
    - ["io2851012", "io.IncrementalNewlineDecoder.__dict__.__contains__", ["__rlshift__"], false]

