table abc_extra87.builtin_methods_class_name:
  description: "abc builtin method __class__.__name__ checks in abcmetacode87 namespace — wave 252 theme: abc ABCMeta.__new__ and ABCMeta.register __code__ attributes (co_name, co_argcount); ABCMeta.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')==True (no __code__ — implemented in C via _abc module); ABC.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method')==True; get_cache_token.__class__.__name__.__eq__('builtin_function_or_method')==True; ABCMeta.register.__code__.co_argcount==2 (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
