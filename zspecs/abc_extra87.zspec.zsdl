    - [instancecheck_co_argcount, ABCMeta.__instancecheck__.__code__.co_argcount,         [],                     2,    "ABCMeta.__instancecheck__.__code__.co_argcount == 2 — takes cls and instance; verified with Python 3.14.3"]
    - [subclasscheck_co_name,     ABCMeta.__subclasscheck__.__code__.co_name.__eq__,     ["__subclasscheck__"],  true, "ABCMeta.__subclasscheck__.__code__.co_name == '__subclasscheck__' — Python function in abc.py; verified with Python 3.14.3"]
    - [subclasscheck_co_argcount, ABCMeta.__subclasscheck__.__code__.co_argcount,         [],                     2,    "ABCMeta.__subclasscheck__.__code__.co_argcount == 2 — takes cls and subclass; verified with Python 3.14.3"]

