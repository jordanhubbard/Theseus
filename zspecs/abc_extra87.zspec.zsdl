    - [abc_subclasshook_cls,     "ABC.__subclasshook__.__class__.__name__.__eq__",     ["builtin_function_or_method"], true, "ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — no __code__; verified with Python 3.14.3"]
    - [get_cache_token_cls,      "get_cache_token.__class__.__name__.__eq__",          ["builtin_function_or_method"], true, "get_cache_token.__class__.__name__ == 'builtin_function_or_method' — no __code__; implemented in C via _abc module; verified with Python 3.14.3"]
    - [reg_co_argcount_cross,    ABCMeta.register.__code__.co_argcount,                [],                            2,    "ABCMeta.register.__code__.co_argcount == 2 — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABC class attribute checks — extra87
#
# ABC.__class__.__name__ == 'ABCMeta'
# ABC.__module__ == 'abc'
# ABC.__qualname__ == 'ABC'
# ---------------------------------------------------------------------------

table abc_extra87.ABC_class_attrs:
  description: "abc ABC class attribute checks in abcmetacode87 namespace — wave 252 theme: abc ABCMeta.__new__ and ABCMeta.register __code__ attributes (co_name, co_argcount); ABC.__class__.__name__.__eq__('ABCMeta')==True (ABC is an instance of ABCMeta, i.e. a class whose metaclass is ABCMeta); ABC.__module__.__eq__('abc')==True (ABC is defined in the abc module); ABC.__qualname__.__eq__('ABC')==True; ABCMeta.__new__.__code__.co_argcount==4 (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetacode87c

  columns: [id, function, args, expected, description]
  rows:
    - [abc_class_name,     "ABC.__class__.__name__.__eq__",  ["ABCMeta"], true, "ABC.__class__.__name__ == 'ABCMeta' — ABC is a class whose metaclass is ABCMeta; verified with Python 3.14.3"]
    - [abc_module_eq,      ABC.__module__.__eq__,            ["abc"],     true, "ABC.__module__ == 'abc' — ABC is defined in the abc module; verified with Python 3.14.3"]
    - [abc_qualname_eq,    ABC.__qualname__.__eq__,          ["ABC"],     true, "ABC.__qualname__ == 'ABC' — verified with Python 3.14.3"]
    - [new_co_argcount_cross, ABCMeta.__new__.__code__.co_argcount, [],   4,    "ABCMeta.__new__.__code__.co_argcount == 4 — cross-check; takes cls, name, bases, namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra87
# ---------------------------------------------------------------------------

invariant abc_extra87.ABCMeta_register_co_name:
  description: "abc.ABCMeta.register.__code__.co_name.__eq__('register') returns True — the code object's co_name attribute equals 'register', confirming the internal function name matches the method name; NEW in extra87: first standalone co_name invariant for ABCMeta.register in abcmetacode87 namespace; wave 252; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.register.__code__.co_name.__eq__
  args: ["register"]
  expected: true

invariant abc_extra87.ABCMeta_instancecheck_co_argcount:
  description: "abc.ABCMeta.__instancecheck__.__code__.co_argcount == 2 — ABCMeta.__instancecheck__ takes cls and instance as its two positional arguments; it is a Python function defined in abc.py that dispatches to the C-level _abc module; NEW in extra87: first standalone co_argcount invariant for ABCMeta.__instancecheck__ in abcmetacode87 namespace; wave 252; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__code__.co_argcount
  args: []
  expected: 2

invariant abc_extra87.ABCMeta_subclasshook_is_builtin:
  description: "abc.ABCMeta.__subclasshook__.__class__.__name__.__eq__('builtin_function_or_method') returns True — ABCMeta.__subclasshook__ is implemented in C via the _abc module, so it has no __code__ attribute; this contrasts with ABCMeta.register and ABCMeta.__new__ which are Python functions with __code__; NEW in extra87: first standalone builtin class name invariant for ABCMeta.__subclasshook__ in abcmetacode87 namespace; wave 252; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABCMeta.__subclasshook__.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra87.get_cache_token_is_builtin:
  description: "abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') returns True — get_cache_token is a C-level function from the _abc module; it returns an opaque object used to invalidate ABCMeta caches; NEW in extra87: first standalone builtin class name invariant for get_cache_token in abcmetacode87 namespace; wave 252; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "get_cache_token.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra87.ABC_class_is_ABCMeta:
  description: "abc.ABC.__class__.__name__.__eq__('ABCMeta') returns True — ABC is a class object whose metaclass is ABCMeta; in Python, a class is an instance of its metaclass, so ABC.__class__ is ABCMeta; this is the fundamental relationship between ABC and ABCMeta; NEW in extra87: first standalone ABC metaclass identity invariant in abcmetacode87 namespace; wave 252; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ABC.__class__.__name__.__eq__"
  args: ["ABCMeta"]
  expected: true
