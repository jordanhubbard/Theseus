spec: abc_extra87
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra86

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra86.zspec.zsdl."
    - "This spec covers: wave 252 theme — abc ABCMeta.__new__ and ABCMeta.register __code__ attributes (co_name, co_argcount), and class identity checks for builtin methods. NEW in extra87: ABCMeta.register.__code__.co_name.__eq__('register')==True; ABCMeta.register.__code__.co_argcount==2; ABCMeta.__new__.__code__.co_name.__eq__('__new__')==True; ABCMeta.__new__.__code__.co_argcount==4; ABCMeta.__instancecheck__.__code__.co_name.__eq__('__instancecheck__')==True; ABCMeta.__instancecheck__.__code__.co_argcount==2; ABCMeta.__subclasscheck__.__code__.co_name.__eq__('__subclasscheck__')==True; ABCMeta.__subclasscheck__.__code__.co_argcount==2; ABCMeta.__subclasshook__.__class__.__name__=='builtin_function_or_method' (no __code__); ABC.__subclasshook__.__class__.__name__=='builtin_function_or_method' (no __code__); get_cache_token.__class__.__name__=='builtin_function_or_method' (no __code__); ABC.__class__.__name__=='ABCMeta'; ABC.__module__.__eq__('abc')==True; ABC.__qualname__.__eq__('ABC')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_name == 'register'. The code object co_name confirms the function name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__code__.co_argcount == 2. Takes cls and subclass. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__code__.co_name == '__new__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__new__.__code__.co_argcount == 4. Takes cls, name, bases, namespace. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__code__.co_name == '__instancecheck__'. Defined as Python function in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__code__.co_argcount == 2. Takes cls and instance. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__code__.co_name == '__subclasscheck__'. Defined as Python function in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__code__.co_argcount == 2. Takes cls and subclass. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. No __code__ attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. No __code__ attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method'. No __code__ attribute. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__class__.__name__ == 'ABCMeta'. ABC is an instance of ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__module__ == 'abc'. ABC is defined in the abc module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__qualname__ == 'ABC'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc ABCMeta.register __code__ attributes — extra87
#
# Wave 252 theme: abc ABCMeta.__new__ and ABCMeta.register __code__ attributes.
#
# ABCMeta.register.__code__.co_name == 'register'
# ABCMeta.register.__code__.co_argcount == 2
# ABCMeta.__new__.__code__.co_name == '__new__'
# ABCMeta.__new__.__code__.co_argcount == 4
# ---------------------------------------------------------------------------

table abc_extra87.ABCMeta_register_and_new_code_attrs:
  description: "abc ABCMeta.register and __new__ __code__ attribute checks in abcmetacode87 namespace — wave 252 theme: abc ABCMeta.__new__ and ABCMeta.register __code__ attributes (co_name, co_argcount); ABCMeta.register.__code__.co_name.__eq__('register')==True; ABCMeta.register.__code__.co_argcount==2 (takes cls and subclass); ABCMeta.__new__.__code__.co_name.__eq__('__new__')==True; ABCMeta.__new__.__code__.co_argcount==4 (takes cls, name, bases, namespace); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetacode87

  columns: [id, function, args, expected, description]
  rows:
    - [reg_co_name,      ABCMeta.register.__code__.co_name.__eq__,     ["register"], true, "ABCMeta.register.__code__.co_name == 'register' — confirmed by code object co_name; verified with Python 3.14.3"]
    - [reg_co_argcount,  ABCMeta.register.__code__.co_argcount,        [],           2,    "ABCMeta.register.__code__.co_argcount == 2 — takes cls and subclass; verified with Python 3.14.3"]
    - [new_co_name,      ABCMeta.__new__.__code__.co_name.__eq__,      ["__new__"],  true, "ABCMeta.__new__.__code__.co_name == '__new__' — confirmed by code object co_name; verified with Python 3.14.3"]
    - [new_co_argcount,  ABCMeta.__new__.__code__.co_argcount,         [],           4,    "ABCMeta.__new__.__code__.co_argcount == 4 — takes cls, name, bases, namespace; verified with Python 3.14.3"]

