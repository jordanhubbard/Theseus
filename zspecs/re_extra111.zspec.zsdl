spec: re_extra111
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra110.zspec.zsdl."
    - "This spec covers: re.Pattern bound method types on instances ('builtin_method'), re.Pattern class-level descriptor types ('method_descriptor'), and Pattern method __qualname__ values and lengths."
    - "Bound methods on a compiled re.Pattern instance (p.match, p.search, etc.) have type 'builtin_method' — they are bound to a C extension object."
    - "On the class (re.Pattern.match, re.Pattern.search, etc.) the type is 'method_descriptor' — the unbound C slot descriptor."
    - "p.split and p.findall have type 'builtin_function_or_method' (distinct from match/search/etc. which are 'builtin_method')."
    - "re.Pattern.match.__qualname__ == 'Pattern.match' (13 chars); search='Pattern.search'(14); findall='Pattern.findall'(15)."
    - "re.Pattern.sub.__qualname__ == 'Pattern.sub' (11 chars); subn='Pattern.subn'(12); split='Pattern.split'(13)."
    - "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' (17 chars); finditer='Pattern.finditer'(16)."
    - "re.compile.__qualname__ == 'compile' (7 chars; top-level function, qualname equals function name)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern class-level method descriptor types
# On the class (re.Pattern.match, re.Pattern.search, etc.) the type is
# 'method_descriptor' — the unbound C extension method descriptor.
# This contrasts with bound methods on instances which are 'builtin_method'.
# ---------------------------------------------------------------------------

table re_extra111.Pattern_class_method_types:
  description: "re.Pattern class-level method types: match/search/findall/sub/fullmatch/split/finditer/subn are all 'method_descriptor' when accessed on the class"
  kind: python_call_eq
  category: class_names
  id_prefix: repm111a

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_match_type,    "Pattern.match.__class__.__name__.__eq__",    ["method_descriptor"], true,  "type(re.Pattern.match).__name__ == 'method_descriptor' (C extension unbound descriptor on the class)"]
    - [pattern_search_type,   "Pattern.search.__class__.__name__.__eq__",   ["method_descriptor"], true,  "type(re.Pattern.search).__name__ == 'method_descriptor'"]
    - [pattern_findall_type,  "Pattern.findall.__class__.__name__.__eq__",  ["method_descriptor"], true,  "type(re.Pattern.findall).__name__ == 'method_descriptor'"]
    - [pattern_sub_type,      "Pattern.sub.__class__.__name__.__eq__",      ["method_descriptor"], true,  "type(re.Pattern.sub).__name__ == 'method_descriptor'"]
    - [pattern_fullmatch_type,"Pattern.fullmatch.__class__.__name__.__eq__",["method_descriptor"], true,  "type(re.Pattern.fullmatch).__name__ == 'method_descriptor'"]
    - [pattern_split_type,    "Pattern.split.__class__.__name__.__eq__",    ["method_descriptor"], true,  "type(re.Pattern.split).__name__ == 'method_descriptor'"]
    - [pattern_finditer_type, "Pattern.finditer.__class__.__name__.__eq__", ["method_descriptor"], true,  "type(re.Pattern.finditer).__name__ == 'method_descriptor'"]
    - [pattern_subn_type,     "Pattern.subn.__class__.__name__.__eq__",     ["method_descriptor"], true,  "type(re.Pattern.subn).__name__ == 'method_descriptor'"]
    - [pattern_not_func,      "Pattern.match.__class__.__name__.__eq__",    ["function"],          false, "type(re.Pattern.match).__name__ != 'function' (Pattern.match is a C extension method_descriptor, not a Python function)"]

# ---------------------------------------------------------------------------
# re.Pattern method __qualname__ values and lengths
# match: 'Pattern.match' (13); search: 'Pattern.search' (14); findall: 'Pattern.findall' (15).
# sub: 'Pattern.sub' (11); subn: 'Pattern.subn' (12); split: 'Pattern.split' (13).
# fullmatch: 'Pattern.fullmatch' (17); finditer: 'Pattern.finditer' (16).
# ---------------------------------------------------------------------------

table re_extra111.Pattern_method_qualnames:
  description: "re.Pattern method __qualname__: match='Pattern.match'(13), search='Pattern.search'(14), findall='Pattern.findall'(15), sub='Pattern.sub'(11), subn='Pattern.subn'(12), split='Pattern.split'(13)"
  kind: python_call_eq
  category: qualnames
  id_prefix: repm111b

  columns: [id, function, args, expected, description]
  rows:
    - [match_qn_eq,     "Pattern.match.__qualname__.__eq__",    ["Pattern.match"],    true,  "re.Pattern.match.__qualname__ == 'Pattern.match'"]
    - [match_qn_len,    "Pattern.match.__qualname__.__len__",   [],                   13,    "re.Pattern.match.__qualname__.__len__() == 13 ('Pattern.match' has 13 chars)"]
    - [search_qn_eq,    "Pattern.search.__qualname__.__eq__",   ["Pattern.search"],   true,  "re.Pattern.search.__qualname__ == 'Pattern.search'"]
    - [search_qn_len,   "Pattern.search.__qualname__.__len__",  [],                   14,    "re.Pattern.search.__qualname__.__len__() == 14 ('Pattern.search' has 14 chars)"]
    - [findall_qn_eq,   "Pattern.findall.__qualname__.__eq__",  ["Pattern.findall"],  true,  "re.Pattern.findall.__qualname__ == 'Pattern.findall'"]
    - [findall_qn_len,  "Pattern.findall.__qualname__.__len__", [],                   15,    "re.Pattern.findall.__qualname__.__len__() == 15 ('Pattern.findall' has 15 chars)"]
    - [sub_qn_eq,       "Pattern.sub.__qualname__.__eq__",      ["Pattern.sub"],      true,  "re.Pattern.sub.__qualname__ == 'Pattern.sub' (shortest Pattern method qualname)"]
    - [sub_qn_len,      "Pattern.sub.__qualname__.__len__",     [],                   11,    "re.Pattern.sub.__qualname__.__len__() == 11 ('Pattern.sub' has 11 chars; shortest Pattern method qualname)"]
    - [subn_qn_eq,      "Pattern.subn.__qualname__.__eq__",     ["Pattern.subn"],     true,  "re.Pattern.subn.__qualname__ == 'Pattern.subn'"]
    - [subn_qn_len,     "Pattern.subn.__qualname__.__len__",    [],                   12,    "re.Pattern.subn.__qualname__.__len__() == 12 ('Pattern.subn' has 12 chars)"]
    - [split_qn_eq,     "Pattern.split.__qualname__.__eq__",    ["Pattern.split"],    true,  "re.Pattern.split.__qualname__ == 'Pattern.split'"]
    - [split_qn_len,    "Pattern.split.__qualname__.__len__",   [],                   13,    "re.Pattern.split.__qualname__.__len__() == 13 ('Pattern.split' has 13 chars; same length as Pattern.match)"]

# ---------------------------------------------------------------------------
# re.Pattern fullmatch/finditer qualnames and re.compile qualname
# fullmatch: 'Pattern.fullmatch' (17 chars); finditer: 'Pattern.finditer' (16 chars).
# re.compile.__qualname__ == 'compile' (7 chars; top-level function, qualname == name).
# re.compile.__module__ == 're'.
# ---------------------------------------------------------------------------

table re_extra111.Pattern_fullmatch_finditer_compile_qualnames:
  description: "re.Pattern.fullmatch='Pattern.fullmatch'(17), finditer='Pattern.finditer'(16); re.compile.__qualname__='compile'(7); compile is a pure Python function in the re module"
  kind: python_call_eq
  category: qualnames
  id_prefix: repm111c

  columns: [id, function, args, expected, description]
  rows:
    - [fullmatch_qn_eq,   "Pattern.fullmatch.__qualname__.__eq__",  ["Pattern.fullmatch"],  true,  "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' (longest Pattern method qualname at 17 chars)"]
    - [fullmatch_qn_len,  "Pattern.fullmatch.__qualname__.__len__", [],                     17,    "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' has 17 chars; longest among Pattern methods)"]
    - [finditer_qn_eq,    "Pattern.finditer.__qualname__.__eq__",   ["Pattern.finditer"],   true,  "re.Pattern.finditer.__qualname__ == 'Pattern.finditer'"]
    - [finditer_qn_len,   "Pattern.finditer.__qualname__.__len__",  [],                     16,    "re.Pattern.finditer.__qualname__.__len__() == 16 ('Pattern.finditer' has 16 chars)"]
    - [compile_qn_eq,     "compile.__qualname__.__eq__",            ["compile"],            true,  "re.compile.__qualname__ == 'compile' (top-level function; qualname equals simple name with no class prefix)"]
    - [compile_qn_len,    "compile.__qualname__.__len__",           [],                     7,     "re.compile.__qualname__.__len__() == 7 ('compile' has 7 chars)"]
    - [compile_module_eq, "compile.__module__.__eq__",              ["re"],                 true,  "re.compile.__module__ == 're' (pure Python function in the re module)"]
    - [fullmatch_gt_finditer, "Pattern.fullmatch.__qualname__.__len__.__gt__", [16],        true,  "len('Pattern.fullmatch') > len('Pattern.finditer') (17 > 16; fullmatch is longer by one char)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra111.Pattern.match_type_method_descriptor:
  description: "type(re.Pattern.match).__name__ == 'method_descriptor' (when accessed on the class, Pattern.match is a C extension method_descriptor; when accessed on an instance p.match it becomes a 'builtin_method' — a bound C extension method; this is the same type distinction seen for all C extension class methods)"
  category: class_names
  kind: python_call_eq
  function: "Pattern.match.__class__.__name__.__eq__"
  args: ["method_descriptor"]
  expected: true

invariant re_extra111.Pattern.match_qualname:
  description: "re.Pattern.match.__qualname__ == 'Pattern.match' (length 13; the Pattern. prefix (8 chars including dot) plus 'match' (5 chars) gives 13; contrast with Pattern.search at 14 chars and Pattern.sub at 11 chars which is the shortest)"
  category: qualnames
  kind: python_call_eq
  function: "Pattern.match.__qualname__.__eq__"
  args: ["Pattern.match"]
  expected: true

invariant re_extra111.Pattern.fullmatch_qualname_len:
  description: "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' has 17 characters; it is the longest qualname among all Pattern methods; the 'Pattern.' prefix is 8 chars and 'fullmatch' adds 9 chars)"
  category: qualnames
  kind: python_call_eq
  function: "Pattern.fullmatch.__qualname__.__len__"
  args: []
  expected: 17

invariant re_extra111.Pattern.sub_qualname_len:
  description: "re.Pattern.sub.__qualname__.__len__() == 11 ('Pattern.sub' has 11 characters; it is the shortest qualname among all Pattern methods; the 'Pattern.' prefix is 8 chars and 'sub' adds only 3 chars)"
  category: qualnames
  kind: python_call_eq
  function: "Pattern.sub.__qualname__.__len__"
  args: []
  expected: 11

invariant re_extra111.compile.qualname_len_7:
  description: "re.compile.__qualname__.__len__() == 7 ('compile' has 7 characters; as a top-level function its __qualname__ equals its simple name with no class prefix; contrast with Pattern methods whose qualnames use the 'Pattern.' prefix)"
  category: qualnames
  kind: python_call_eq
  function: "compile.__qualname__.__len__"
  args: []
  expected: 7
