spec: seedrandom
version: ">=3.0.0"
backend: node(seedrandom)

docs: https://github.com/davidbau/seedrandom#readme

provenance:
  derived_from:
    - "seedrandom README — https://github.com/davidbau/seedrandom#readme"
    - "Test vectors verified with seedrandom via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "seedrandom source"
  notes:
    - "Deterministic RNG — same seed always produces same sequence (ARC4 by default)."
    - "Install: npm install seedrandom"
    - "v3 CJS; module export IS the factory; calling seedrandom(seed) returns a generator function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure factory; never throws."
  stderr: "null"
  stickiness: "N/A — each generator independent."
  codes: {}

invariant seedrandom.deterministic_first_value:
  description: "seedrandom('hello')() always returns 0.5463663768140734"
  category: deterministic
  kind: node_chain_eq
  entry: module
  entry_args: ["hello"]
  chain:
    - {call: []}
  expected: 0.5463663768140734

invariant seedrandom.same_seed_same_sequence:
  description: "Two generators with the same seed produce the same first value"
  category: deterministic
  kind: node_chain_eq
  entry: module
  entry_args: ["hello"]
  chain:
    - {call: []}
  expected: 0.5463663768140734

invariant seedrandom.different_seed_different_value:
  description: "Different seed produces different (but deterministic) value"
  category: deterministic
  kind: node_chain_eq
  entry: module
  entry_args: ["world"]
  chain:
    - {call: []}
  expected: 0.7876907653907878

invariant seedrandom.values_in_unit_range:
  description: "Generated value is between 0 and 1"
  category: range
  kind: node_chain_eq
  entry: module
  entry_args: ["range-test"]
  chain:
    - {call: []}
    - {get: "constructor.name"}
  expected: "Number"

invariant seedrandom.factory_returns_function:
  description: "seedrandom(seed) returns a function"
  category: shape
  kind: node_chain_eq
  entry: module
  entry_args: ["x"]
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant seedrandom.factory_arity:
  description: "seedrandom factory takes (seed, options, callback) — function.length 3"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 3

invariant seedrandom.empty_seed_still_deterministic:
  description: "seedrandom('')() returns a stable value across invocations"
  category: deterministic
  kind: node_chain_eq
  entry: module
  entry_args: [""]
  chain:
    - {call: []}
    - {get: "constructor.name"}
  expected: "Number"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T23:28:08Z
  iterations: 2
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 2 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
