spec: threading_extra249
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Thread start, run, join method identity — __name__, __qualname__, __module__, __class__.__name__."
    - "threading.Thread.start.__name__ == 'start' — start is the method that starts the thread's activity. Verified with Python 3.14.3."
    - "threading.Thread.start.__qualname__ == 'Thread.start' — start is defined directly on Thread. Verified with Python 3.14.3."
    - "threading.Thread.run.__name__ == 'run' — run is the method that defines the thread's activity; can be overridden. Verified with Python 3.14.3."
    - "threading.Thread.run.__qualname__ == 'Thread.run' — run is defined directly on Thread. Verified with Python 3.14.3."
    - "threading.Thread.join.__name__ == 'join' — join blocks until the thread terminates. Verified with Python 3.14.3."
    - "threading.Thread.join.__qualname__ == 'Thread.join' — join is defined directly on Thread. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__name__ == 'is_alive'; __qualname__ == 'Thread.is_alive'; verified with Python 3.14.3."
    - "threading.Thread.__init__.__name__ == '__init__'; __qualname__ == 'Thread.__init__'; verified with Python 3.14.3."
    - "All methods (start, run, join, is_alive, __init__) have __class__.__name__ == 'function' — plain Python functions. Verified with Python 3.14.3."
    - "All methods have __module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('start') == True, ('run') == True, ('join') == True, ('is_alive') == True. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread start/run/join __name__ checks
#
# threading.Thread.start.__name__ == 'start'
# threading.Thread.run.__name__ == 'run'
# threading.Thread.join.__name__ == 'join'
# threading.Thread.is_alive.__name__ == 'is_alive'
# threading.Thread.__init__.__name__ == '__init__'
#
# These are the core lifecycle methods of threading.Thread. Their __name__
# is the unqualified method name. New to extra249.
# ---------------------------------------------------------------------------

table threading_extra249.thread_method_names:
  description: "threading.Thread start/run/join/is_alive/__init__ __name__ checks; new to extra249"
  kind: python_call_eq
  category: method_identity
  id_prefix: thr249meth

  columns: [id, function, args, expected, description]
  rows:
    - [start_name_eq,
       Thread.start.__name__.__eq__,
       ["start"],
       true,
       "threading.Thread.start.__name__.__eq__('start') == True — start is the method that begins thread activity by invoking run() in a new OS thread; its __name__ is 'start'; str.__eq__('start') returns True; new to extra249"]
    - [run_name_eq,
       Thread.run.__name__.__eq__,
       ["run"],
       true,
       "threading.Thread.run.__name__.__eq__('run') == True — run is the method invoked by start() in the new thread; subclasses override run() to define thread activity; its __name__ is 'run'; str.__eq__('run') returns True; new to extra249"]
    - [join_name_eq,
       Thread.join.__name__.__eq__,
       ["join"],
       true,
       "threading.Thread.join.__name__.__eq__('join') == True — join blocks the calling thread until the thread whose join() is called terminates; its __name__ is 'join'; str.__eq__('join') returns True; new to extra249"]
    - [is_alive_name_eq,
       Thread.is_alive.__name__.__eq__,
       ["is_alive"],
       true,
       "threading.Thread.is_alive.__name__.__eq__('is_alive') == True — is_alive returns True if the thread is alive (between start() and termination); its __name__ is 'is_alive'; str.__eq__('is_alive') returns True; new to extra249"]
    - [init_name_eq,
       Thread.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "threading.Thread.__init__.__name__.__eq__('__init__') == True — __init__ is the Thread constructor; its __name__ is '__init__'; str.__eq__('__init__') returns True; new to extra249"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread start/run/join __qualname__ checks
#
# threading.Thread.start.__qualname__ == 'Thread.start'
# threading.Thread.run.__qualname__ == 'Thread.run'
# threading.Thread.join.__qualname__ == 'Thread.join'
# threading.Thread.is_alive.__qualname__ == 'Thread.is_alive'
# threading.Thread.__init__.__qualname__ == 'Thread.__init__'
#
# All lifecycle methods are defined directly on the Thread class so their
# __qualname__ is 'Thread.<method>'. New to extra249.
# ---------------------------------------------------------------------------

table threading_extra249.thread_method_qualnames:
  description: "threading.Thread start/run/join/is_alive/__init__ __qualname__ checks; new to extra249"
  kind: python_call_eq
  category: method_identity
  id_prefix: thr249meth

  columns: [id, function, args, expected, description]
  rows:
    - [start_qualname_eq,
       Thread.start.__qualname__.__eq__,
       ["Thread.start"],
       true,
       "threading.Thread.start.__qualname__.__eq__('Thread.start') == True — start is defined directly on the Thread class so its __qualname__ is 'Thread.start'; str.__eq__('Thread.start') returns True; new to extra249"]
    - [run_qualname_eq,
       Thread.run.__qualname__.__eq__,
       ["Thread.run"],
       true,
       "threading.Thread.run.__qualname__.__eq__('Thread.run') == True — run is defined directly on the Thread class so its __qualname__ is 'Thread.run'; str.__eq__('Thread.run') returns True; new to extra249"]
    - [join_qualname_eq,
       Thread.join.__qualname__.__eq__,
       ["Thread.join"],
       true,
       "threading.Thread.join.__qualname__.__eq__('Thread.join') == True — join is defined directly on the Thread class so its __qualname__ is 'Thread.join'; str.__eq__('Thread.join') returns True; new to extra249"]
    - [is_alive_qualname_eq,
       Thread.is_alive.__qualname__.__eq__,
       ["Thread.is_alive"],
       true,
       "threading.Thread.is_alive.__qualname__.__eq__('Thread.is_alive') == True — is_alive is defined directly on Thread so its __qualname__ is 'Thread.is_alive'; str.__eq__('Thread.is_alive') returns True; new to extra249"]
    - [init_qualname_eq,
       Thread.__init__.__qualname__.__eq__,
       ["Thread.__init__"],
       true,
       "threading.Thread.__init__.__qualname__.__eq__('Thread.__init__') == True — __init__ is defined directly on Thread so its __qualname__ is 'Thread.__init__'; str.__eq__('Thread.__init__') returns True; new to extra249"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread method __class__.__name__ and __module__
#
# threading.Thread.start/__class__.__name__ == 'function'
# threading.Thread.run.__class__.__name__ == 'function'
# threading.Thread.join.__class__.__name__ == 'function'
# threading.Thread.start.__module__ == 'threading'
# threading.Thread.run.__module__ == 'threading'
# threading.Thread.join.__module__ == 'threading'
#
# All Thread lifecycle methods are plain Python functions defined in
# Lib/threading.py. New to extra249.
# ---------------------------------------------------------------------------

table threading_extra249.thread_method_class_and_module:
  description: "threading.Thread start/run/join __class__.__name__ == 'function'; __module__ == 'threading'; new to extra249"
  kind: python_call_eq
  category: method_identity
  id_prefix: thr249meth

  columns: [id, function, args, expected, description]
  rows:
    - [start_class_function,
       Thread.start.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Thread.start.__class__.__name__.__eq__('function') == True — Thread.start is a plain Python function defined in Lib/threading.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra249"]
    - [run_class_function,
       Thread.run.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Thread.run.__class__.__name__.__eq__('function') == True — Thread.run is a plain Python function defined in Lib/threading.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra249"]
    - [join_class_function,
       Thread.join.__class__.__name__.__eq__,
       ["function"],
       true,
       "threading.Thread.join.__class__.__name__.__eq__('function') == True — Thread.join is a plain Python function defined in Lib/threading.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra249"]
    - [start_module_threading,
       Thread.start.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.start.__module__.__eq__('threading') == True — Thread.start is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra249"]
    - [run_module_threading,
       Thread.run.__module__.__eq__,
       ["threading"],
       true,
       "threading.Thread.run.__module__.__eq__('threading') == True — Thread.run is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra249"]

# ---------------------------------------------------------------------------
# Table 4: threading.Thread.__dict__ contains start/run/join and negatives
#
# threading.Thread.__dict__.__contains__('start') == True
# threading.Thread.__dict__.__contains__('run') == True
# threading.Thread.__dict__.__contains__('join') == True
# threading.Thread.__dict__.__contains__('is_alive') == True
# threading.Thread.__dict__.__contains__('acquire') == False
# threading.Thread.__dict__.__contains__('nonexistent') == False
#
# Thread.__dict__ is Thread's own class namespace. start, run, join, and
# is_alive are defined directly on Thread. 'acquire' is a Lock method.
# New to extra249.
# ---------------------------------------------------------------------------

table threading_extra249.thread_dict_method_membership:
  description: "threading.Thread.__dict__ contains start/run/join/is_alive; not acquire/nonexistent; new to extra249"
  kind: python_call_eq
  category: dict_membership
  id_prefix: thr249meth

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_start,
       Thread.__dict__.__contains__,
       ["start"],
       true,
       "threading.Thread.__dict__.__contains__('start') == True — Thread defines 'start' directly in its class body in Lib/threading.py; __contains__('start') returns True; new to extra249"]
    - [dict_has_run,
       Thread.__dict__.__contains__,
       ["run"],
       true,
       "threading.Thread.__dict__.__contains__('run') == True — Thread defines 'run' directly in its class body; __contains__('run') returns True; new to extra249"]
    - [dict_has_join,
       Thread.__dict__.__contains__,
       ["join"],
       true,
       "threading.Thread.__dict__.__contains__('join') == True — Thread defines 'join' directly in its class body; __contains__('join') returns True; new to extra249"]
    - [dict_has_is_alive,
       Thread.__dict__.__contains__,
       ["is_alive"],
       true,
       "threading.Thread.__dict__.__contains__('is_alive') == True — Thread defines 'is_alive' directly in its class body; __contains__('is_alive') returns True; new to extra249"]
    - [dict_no_acquire,
       Thread.__dict__.__contains__,
       ["acquire"],
       false,
       "threading.Thread.__dict__.__contains__('acquire') == False — 'acquire' is a Lock method unrelated to Thread; Thread.__dict__ does not contain 'acquire'; __contains__('acquire') returns False; new to extra249"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra249
# ---------------------------------------------------------------------------

invariant threading_extra249.Thread.start_name_eq:
  description: "threading.Thread.start.__name__ == 'start' — start is the thread activation method; new to extra249"
  category: method_identity
  kind: python_call_eq
  function: Thread.start.__name__.__eq__
  args: ["start"]
  expected: true

invariant threading_extra249.Thread.start_qualname_eq:
  description: "threading.Thread.start.__qualname__ == 'Thread.start' — start is defined on Thread; new to extra249"
  category: method_identity
  kind: python_call_eq
  function: Thread.start.__qualname__.__eq__
  args: ["Thread.start"]
  expected: true

invariant threading_extra249.Thread.run_name_eq:
  description: "threading.Thread.run.__name__ == 'run' — run defines the thread's activity; new to extra249"
  category: method_identity
  kind: python_call_eq
  function: Thread.run.__name__.__eq__
  args: ["run"]
  expected: true

invariant threading_extra249.Thread.run_qualname_eq:
  description: "threading.Thread.run.__qualname__ == 'Thread.run' — run is defined on Thread; new to extra249"
  category: method_identity
  kind: python_call_eq
  function: Thread.run.__qualname__.__eq__
  args: ["Thread.run"]
  expected: true

invariant threading_extra249.Thread.join_name_eq:
  description: "threading.Thread.join.__name__ == 'join' — join blocks until thread termination; new to extra249"
  category: method_identity
  kind: python_call_eq
  function: Thread.join.__name__.__eq__
  args: ["join"]
  expected: true

invariant threading_extra249.Thread.join_qualname_eq:
  description: "threading.Thread.join.__qualname__ == 'Thread.join' — join is defined on Thread; new to extra249"
  category: method_identity
  kind: python_call_eq
  function: Thread.join.__qualname__.__eq__
  args: ["Thread.join"]
  expected: true

invariant threading_extra249.Thread.join_module_threading:
  description: "threading.Thread.join.__module__ == 'threading' — join is defined in Lib/threading.py; new to extra249"
  category: method_identity
  kind: python_call_eq
  function: Thread.join.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra249.Thread.join_class_function:
  description: "threading.Thread.join.__class__.__name__ == 'function' — join is a plain Python function; new to extra249"
  category: method_identity
  kind: python_call_eq
  function: Thread.join.__class__.__name__.__eq__
  args: ["function"]
  expected: true
