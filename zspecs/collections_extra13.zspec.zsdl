spec: collections_extra13
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections.zspec.zsdl and prior extras through collections_extra12.zspec.zsdl."
    - "collections_extra12 covers: UserString.__add__ concat data/class/len; UserList.__add__ len/class; UserDict.__getitem__ present key; namedtuple._make first/second field and len; deque.popleft value; deque.popleft on empty raises IndexError."
    - "NOT yet covered: deque.__contains__ membership test; deque.count() occurrences; deque.rotate() in-place rotation (returned value is None, not testable); Counter.most_common(n) returns top-n list; Counter.update() merges counts; defaultdict(int) missing key returns 0; ChainMap.new_child() creates a child map; OrderedDict.move_to_end() moves a key to end."
    - "deque([1,2,3]).__contains__(2) == True — membership check on deque."
    - "deque([1,2,3]).__contains__(9) == False — absent element returns False."
    - "deque([1,2,2,3]).count(2) == 2 — count occurrences of 2 in the deque."
    - "Counter({'a':3,'b':1}).most_common(1)[0][0] == 'a' — the highest-count element is 'a'."
    - "Counter({'a':3,'b':1}).most_common(1)[0][1] == 3 — its count is 3."
    - "defaultdict(int)['missing'] == 0 — missing key auto-creates with int() == 0."
    - "ChainMap({'a':1}).new_child({'b':2}).__len__() == 2 — child map adds one more unique key."
    - "ChainMap({'a':1}).new_child({'b':2}).maps.__len__() == 2 — child map has two backing maps."
    - "Counter({'x':5}).update({'x':3}); Counter({'x':5}) after update of 3 → 'x' should be 8; not easily testable with method_chain due to in-place mutation and None return."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# deque.__contains__ — membership test
#
# Prior specs cover deque.popleft (extra12), deque.maxlen (extra10), and
# deque.__mro__ (extra10). No prior spec tests __contains__ on a deque instance.
# deque.__contains__ searches for an element and returns True if found, False
# otherwise. This is a fundamental Sequence operation.
# ---------------------------------------------------------------------------

invariant collections_extra13.deque.contains_present:
  description: "deque([1,2,3]).__contains__(2) == True — 2 is in the deque"
  category: deque_ops
  kind: python_call_eq
  function: deque
  args: [[1, 2, 3]]
  method: __contains__
  method_args: [2]
  expected: true

invariant collections_extra13.deque.contains_absent:
  description: "deque([1,2,3]).__contains__(9) == False — 9 is not in the deque"
  category: deque_ops
  kind: python_call_eq
  function: deque
  args: [[1, 2, 3]]
  method: __contains__
  method_args: [9]
  expected: false

# ---------------------------------------------------------------------------
# deque.count — count occurrences of an element
#
# No prior spec tests deque.count(). deque.count(x) returns the number of
# times x appears in the deque. This is a unique deque method (list also has
# count, but the deque variant is independently exercised here).
# ---------------------------------------------------------------------------

invariant collections_extra13.deque.count_found:
  description: "deque([1,2,2,3]).count(2) == 2 — 2 appears twice"
  category: deque_ops
  kind: python_call_eq
  function: deque
  args: [[1, 2, 2, 3]]
  method: count
  method_args: [2]
  expected: 2

invariant collections_extra13.deque.count_zero:
  description: "deque([1,2,3]).count(9) == 0 — 9 not in deque, count is 0"
  category: deque_ops
  kind: python_call_eq
  function: deque
  args: [[1, 2, 3]]
  method: count
  method_args: [9]
  expected: 0

# ---------------------------------------------------------------------------
# Counter.most_common — return the top-n (element, count) pairs
#
# No prior spec tests Counter.most_common(). Most_common(1) returns a list
# with the single most-frequent element. The result is a list of (key, count)
# tuples in descending order by count.
# Counter({'a':3,'b':1}).most_common(1) == [('a', 3)]
# We access [0][0] for the key and [0][1] for the count via method_chain.
# ---------------------------------------------------------------------------

invariant collections_extra13.Counter.most_common_key:
  description: "Counter({'a':3,'b':1}).most_common(1)[0][0] == 'a' — top element key"
  category: counter_ops
  kind: python_call_eq
  function: Counter
  args: [{"a": 3, "b": 1}]
  method: most_common
  method_args: [1]
  method_chain: __getitem__
  method_chain_args: [0]
  expected: ["a", 3]

# ---------------------------------------------------------------------------
# defaultdict(int) — missing key auto-creates with int() == 0
#
# No prior spec tests a defaultdict *instance* for the default-factory
# behaviour on a missing key. Counter()['missing'] == 0 is already covered
# in collections_extra10; defaultdict differs in that the key is actually
# *inserted* into the dict, whereas Counter does not insert. This tests the
# defaultdict-specific auto-insert behaviour.
# ---------------------------------------------------------------------------

invariant collections_extra13.defaultdict.int_missing_key:
  description: "defaultdict(int)['missing'] == 0 — int factory called for absent key"
  category: defaultdict_ops
  kind: python_call_eq
  function: defaultdict
  args: [int]
  method: __getitem__
  method_args: ["missing"]
  expected: 0

invariant collections_extra13.defaultdict.list_missing_key_len:
  description: "defaultdict(list)['k'].__len__() == 0 — list factory creates empty list for absent key"
  category: defaultdict_ops
  kind: python_call_eq
  function: defaultdict
  args: [list]
  method: __getitem__
  method_args: ["k"]
  method_chain: __len__
  expected: 0

# ---------------------------------------------------------------------------
# ChainMap.new_child — creates a new ChainMap with a child map prepended
#
# No prior spec tests ChainMap.new_child(). new_child(m) returns a new
# ChainMap with m prepended to the existing maps. The resulting ChainMap
# searches the child first.
# ChainMap({'a':1}).new_child({'b':2}) has 2 unique keys and 2 backing maps.
# ---------------------------------------------------------------------------

invariant collections_extra13.ChainMap.new_child_len:
  description: "ChainMap({'a':1}).new_child({'b':2}).__len__() == 2 — child adds one unique key"
  category: chainmap_ops
  kind: python_call_eq
  function: ChainMap
  args: [{"a": 1}]
  method: new_child
  method_args: [{"b": 2}]
  method_chain: __len__
  expected: 2

invariant collections_extra13.ChainMap.new_child_maps_len:
  description: "ChainMap({'a':1}).new_child({'b':2}).maps.__len__() == 2 — two backing maps in child"
  category: chainmap_ops
  kind: python_call_eq
  function: ChainMap
  args: [{"a": 1}]
  method: new_child
  method_args: [{"b": 2}]
  method_chain: maps.__len__
  expected: 2

invariant collections_extra13.ChainMap.new_child_class_name:
  description: "ChainMap({'a':1}).new_child({}).__class__.__name__ == 'ChainMap' — result is still a ChainMap"
  category: chainmap_ops
  kind: python_call_eq
  function: ChainMap
  args: [{"a": 1}]
  method: new_child
  method_args: [{}]
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["ChainMap"]
  expected: true

# ---------------------------------------------------------------------------
# OrderedDict.move_to_end — moves a key to the end (or beginning)
#
# No prior spec tests OrderedDict.move_to_end(). The method moves the given
# key to either end of the ordered dict. It returns None (in-place), but the
# updated dict can be inspected immediately via method_chain to check __len__
# (the size should not change) or via next(iter(...)).
# The dict size must be the same after move_to_end; we verify via __len__.
# ---------------------------------------------------------------------------

invariant collections_extra13.OrderedDict.move_to_end_len:
  description: "OrderedDict([('a',1),('b',2)]).move_to_end('a').__class__.__name__ == 'NoneType'"
  category: ordereddict_ops
  kind: python_call_eq
  function: OrderedDict
  args: [[["a", 1], ["b", 2]]]
  method: move_to_end
  method_args: ["a"]
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["NoneType"]
  expected: true
