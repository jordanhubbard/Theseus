spec: asyncio_extra386
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio-protocol.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-protocol.html — asyncio protocol documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "asyncio.BaseProtocol lives in module asyncio.protocols and derives from object"
    - "asyncio.Protocol lives in module asyncio.protocols and derives from BaseProtocol"
    - "asyncio.DatagramProtocol lives in module asyncio.protocols and derives from BaseProtocol"
    - "asyncio.SubprocessProtocol lives in module asyncio.protocols and derives from BaseProtocol"
    - "asyncio.BufferedProtocol lives in module asyncio.protocols and derives from BaseProtocol"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra386.class_names:
  description: "Verify __name__ attribute of asyncio protocol classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio386n

  columns: [id, function, args, expected]
  rows:
    - [aio386n001, asyncio.Protocol.__name__.__eq__, ["Protocol"], true]
    - [aio386n002, asyncio.BaseProtocol.__name__.__eq__, ["BaseProtocol"], true]
    - [aio386n003, asyncio.DatagramProtocol.__name__.__eq__, ["DatagramProtocol"], true]
    - [aio386n004, asyncio.SubprocessProtocol.__name__.__eq__, ["SubprocessProtocol"], true]
    - [aio386n005, asyncio.BufferedProtocol.__name__.__eq__, ["BufferedProtocol"], true]

table asyncio_extra386.class_modules:
  description: "Verify __module__ attribute of asyncio protocol classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio386m

  columns: [id, function, args, expected]
  rows:
    - [aio386m001, asyncio.Protocol.__module__.__eq__, ["asyncio.protocols"], true]
    - [aio386m002, asyncio.BaseProtocol.__module__.__eq__, ["asyncio.protocols"], true]
    - [aio386m003, asyncio.DatagramProtocol.__module__.__eq__, ["asyncio.protocols"], true]
    - [aio386m004, asyncio.SubprocessProtocol.__module__.__eq__, ["asyncio.protocols"], true]
    - [aio386m005, asyncio.BufferedProtocol.__module__.__eq__, ["asyncio.protocols"], true]

table asyncio_extra386.class_bases:
  description: "Verify __bases__[0].__name__ (first immediate base class name) of asyncio protocol classes"
  kind: python_call_eq
  category: identity
  id_prefix: aio386b

  columns: [id, function, args, expected]
  rows:
    - ["aio386b001", "asyncio.Protocol.__bases__[0].__name__.__eq__", ["BaseProtocol"], true]
    - ["aio386b002", "asyncio.BaseProtocol.__bases__[0].__name__.__eq__", ["object"], true]
    - ["aio386b003", "asyncio.DatagramProtocol.__bases__[0].__name__.__eq__", ["BaseProtocol"], true]
    - ["aio386b004", "asyncio.SubprocessProtocol.__bases__[0].__name__.__eq__", ["BaseProtocol"], true]
    - ["aio386b005", "asyncio.BufferedProtocol.__bases__[0].__name__.__eq__", ["BaseProtocol"], true]
