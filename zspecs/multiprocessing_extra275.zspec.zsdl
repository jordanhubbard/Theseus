spec: multiprocessing_extra275
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — shared memory types and manager classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/sharedctypes.py, Lib/multiprocessing/managers.py"
  notes:
    - "multiprocessing.sharedctypes.Value and Array are functions, not classes, but have __name__ attributes"
    - "multiprocessing.managers.BaseProxy.__bases__[0].__name__ == 'object'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra275.sharedctypes_names:
  description: "sharedctypes function and class name identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: mp275s

  columns: [id, function, args, expected, description]
  rows:
    - [mp275s001, multiprocessing.sharedctypes.Value.__name__.__eq__, ["Value"], true, "sharedctypes.Value __name__ is 'Value'"]
    - [mp275s002, multiprocessing.sharedctypes.Array.__name__.__eq__, ["Array"], true, "sharedctypes.Array __name__ is 'Array'"]
    - [mp275s003, multiprocessing.sharedctypes.RawValue.__name__.__eq__, ["RawValue"], true, "sharedctypes.RawValue __name__ is 'RawValue'"]
    - [mp275s004, multiprocessing.sharedctypes.RawArray.__name__.__eq__, ["RawArray"], true, "sharedctypes.RawArray __name__ is 'RawArray'"]
    - [mp275s005, multiprocessing.sharedctypes.SynchronizedBase.__name__.__eq__, ["SynchronizedBase"], true, "sharedctypes.SynchronizedBase __name__ is 'SynchronizedBase'"]

table multiprocessing_extra275.managers_names:
  description: "managers class name identity checks for BaseProxy and AutoProxy"
  kind: python_call_eq
  category: identity
  id_prefix: mp275m

  columns: [id, function, args, expected, description]
  rows:
    - [mp275m001, multiprocessing.managers.BaseProxy.__name__.__eq__, ["BaseProxy"], true, "managers.BaseProxy __name__ is 'BaseProxy'"]
    - [mp275m002, multiprocessing.managers.BaseProxy.__module__.__eq__, ["multiprocessing.managers"], true, "managers.BaseProxy module is 'multiprocessing.managers'"]
    - [mp275m003, multiprocessing.managers.AutoProxy.__name__.__eq__, ["AutoProxy"], true, "managers.AutoProxy __name__ is 'AutoProxy'"]
    - [mp275m004, multiprocessing.managers.SyncManager.__name__.__eq__, ["SyncManager"], true, "managers.SyncManager __name__ is 'SyncManager'"]
    - [mp275m005, multiprocessing.managers.SyncManager.__module__.__eq__, ["multiprocessing.managers"], true, "managers.SyncManager module is 'multiprocessing.managers'"]

invariant multiprocessing_extra275.baseproxy_base_is_object:
  description: "multiprocessing.managers.BaseProxy.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.BaseProxy.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra275.synchronizedbase_module:
  description: "multiprocessing.sharedctypes.SynchronizedBase.__module__ == 'multiprocessing.sharedctypes'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.sharedctypes.SynchronizedBase.__module__.__eq__
  args: ["multiprocessing.sharedctypes"]
  expected: true

invariant multiprocessing_extra275.sharedctypes_module_name:
  description: "multiprocessing.sharedctypes.__name__ == 'multiprocessing.sharedctypes'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.sharedctypes.__name__.__eq__
  args: ["multiprocessing.sharedctypes"]
  expected: true

invariant multiprocessing_extra275.sharedctypes_value_module:
  description: "multiprocessing.sharedctypes.Value.__module__ == 'multiprocessing.sharedctypes'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.sharedctypes.Value.__module__.__eq__
  args: ["multiprocessing.sharedctypes"]
  expected: true
