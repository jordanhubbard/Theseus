spec: io_extra2011
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2011 (_extra2011): __add__/__radd__/__iadd__, __mul__/__rmul__/__imul__, __sub__/__rsub__/__isub__ dict-presence checks."
    - "io.IOBase, io.BytesIO, io.StringIO, io.FileIO, io.RawIOBase are stream/buffer types — none define arithmetic operators."
    - "These classes use read/write/seek semantics, not numeric addition/subtraction/multiplication."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table io_extra2011.add_protocol:
  description: "io stream classes __add__/__radd__/__iadd__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2011

  columns: [id, function, args, expected]
  rows:
    - ["io2011001", "io.IOBase.__dict__.__contains__",   ["__add__"],  false]
    - ["io2011002", "io.IOBase.__dict__.__contains__",   ["__radd__"], false]
    - ["io2011003", "io.IOBase.__dict__.__contains__",   ["__iadd__"], false]
    - ["io2011004", "io.BytesIO.__dict__.__contains__",  ["__add__"],  false]
    - ["io2011005", "io.BytesIO.__dict__.__contains__",  ["__radd__"], false]
    - ["io2011006", "io.BytesIO.__dict__.__contains__",  ["__iadd__"], false]
    - ["io2011007", "io.StringIO.__dict__.__contains__", ["__add__"],  false]
    - ["io2011008", "io.StringIO.__dict__.__contains__", ["__radd__"], false]
    - ["io2011009", "io.StringIO.__dict__.__contains__", ["__iadd__"], false]
    - ["io2011010", "io.FileIO.__dict__.__contains__",   ["__add__"],  false]
    - ["io2011011", "io.FileIO.__dict__.__contains__",   ["__radd__"], false]
    - ["io2011012", "io.FileIO.__dict__.__contains__",   ["__iadd__"], false]
    - ["io2011013", "io.RawIOBase.__dict__.__contains__", ["__add__"],  false]
    - ["io2011014", "io.RawIOBase.__dict__.__contains__", ["__radd__"], false]
    - ["io2011015", "io.RawIOBase.__dict__.__contains__", ["__iadd__"], false]

