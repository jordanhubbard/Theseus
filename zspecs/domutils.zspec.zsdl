spec: domutils
version: ">=3.0.0"
backend: node(domutils)

docs: https://github.com/fb55/domutils#readme

provenance:
  derived_from:
    - "domutils README — https://github.com/fb55/domutils#readme"
    - "Test vectors verified with domutils via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "domutils source"
  notes:
    - "DOM traversal and manipulation helpers; companion to htmlparser2/domhandler."
    - "Install: npm install domutils"
    - "Most functions accept node objects of the shape produced by domhandler. We test pure-data helpers that take plain object inputs."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on shape-correct inputs."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# textContent — concatenates text nodes
invariant domutils.textContent_of_text_node:
  description: "textContent of a text node returns its data"
  category: textContent
  kind: node_module_call_eq
  function: textContent
  args: [{type: "text", data: "hello"}]
  expected: "hello"

invariant domutils.textContent_of_array:
  description: "textContent of an array concatenates the text nodes"
  category: textContent
  kind: node_module_call_eq
  function: textContent
  args: [[{type: "text", data: "foo"}, {type: "text", data: "bar"}]]
  expected: "foobar"

# getAttributeValue
invariant domutils.getAttributeValue_present:
  description: "getAttributeValue returns the matching attribute"
  category: attributes
  kind: node_module_call_eq
  function: getAttributeValue
  args: [{type: "tag", name: "p", attribs: {class: "hello"}}, "class"]
  expected: "hello"

invariant domutils.getAttributeValue_missing:
  description: "getAttributeValue returns undefined for missing attribute"
  category: attributes
  kind: node_module_call_eq
  function: getAttributeValue
  args: [{type: "tag", name: "p", attribs: {}}, "missing"]
  expected: ~

invariant domutils.getAttributeValue_text_node_undefined:
  description: "getAttributeValue on a text node returns undefined"
  category: attributes
  kind: node_module_call_eq
  function: getAttributeValue
  args: [{type: "text", data: "hi"}, "anything"]
  expected: ~

# hasAttrib
invariant domutils.hasAttrib_present:
  description: "hasAttrib true when attribute is present"
  category: attributes
  kind: node_module_call_eq
  function: hasAttrib
  args: [{type: "tag", name: "p", attribs: {class: "x"}}, "class"]
  expected: true

invariant domutils.hasAttrib_absent:
  description: "hasAttrib false when attribute is absent"
  category: attributes
  kind: node_module_call_eq
  function: hasAttrib
  args: [{type: "tag", name: "p", attribs: {}}, "class"]
  expected: false

# getName
invariant domutils.getName_returns_tag:
  description: "getName(tagNode) returns the tag name"
  category: name
  kind: node_module_call_eq
  function: getName
  args: [{type: "tag", name: "p"}]
  expected: "p"



# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:28:27Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
