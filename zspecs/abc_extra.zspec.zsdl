spec: abc_extra
version: ">=3.3"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers abc behaviors not in abc.zspec.zsdl or abc_meta.zspec.zsdl."
    - "ABC.__subclasshook__ returns NotImplemented by default — this is the documented sentinel for ABCMeta to fall through to normal subclass checking."
    - "abstractmethod.__isabstractmethod__ is True at the class level, not just on decorated instances."
    - "abstractmethod.__name__ == 'abstractmethod' (it is a plain function/class)."
    - "ABC.__module__ == 'abc' — the helper class is defined directly in the abc module."
    - "get_cache_token() returns an int; its type can be confirmed via __class__.__name__."
    - "ABC.__abstractmethods__ is an empty frozenset on the ABC class itself."
    - "abstractclassmethod, abstractstaticmethod, and abstractproperty were deprecated in Python 3.3 and removed in Python 3.13."
    - "ABCMeta.__instancecheck__ is a function attribute on the metaclass, enabling isinstance() delegation."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abstractmethod — name and isabstractmethod flag
#
# abstractmethod is exported as a plain function (or class). Its __name__
# attribute is 'abstractmethod' and __isabstractmethod__ is True.
# ---------------------------------------------------------------------------

invariant abc_extra.abstractmethod.name:
  description: "abc.abstractmethod.__name__ == 'abstractmethod'"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra.abstractmethod.isabstractmethod_true:
  description: "abc.abstractmethod.__isabstractmethod__ == True — the decorator marks itself abstract"
  category: abstractmethod
  kind: python_call_eq
  function: abstractmethod.__isabstractmethod__.__eq__
  args: [true]
  expected: true

# ---------------------------------------------------------------------------
# ABC.__module__ — the ABC helper class lives in the abc module
# ---------------------------------------------------------------------------

invariant abc_extra.ABC.module:
  description: "abc.ABC.__module__ == 'abc'"
  category: abc_class
  kind: python_call_eq
  function: ABC.__module__.__eq__
  args: ["abc"]
  expected: true

# ---------------------------------------------------------------------------
# ABC.__subclasshook__ — returns NotImplemented by default
#
# The default __subclasshook__ classmethod on ABC (and any ABCMeta-derived
# class that does not override it) returns NotImplemented, signalling that
# the normal subclass-check machinery should be used instead.
# ---------------------------------------------------------------------------

invariant abc_extra.ABC.subclasshook_returns_notimplemented:
  description: "ABC.__subclasshook__(object) is NotImplemented — default hook defers to normal check"
  category: abc_class
  kind: python_call_eq
  function: ABC.__subclasshook__
  args: ["object"]
  method: __class__.__name__.__eq__
  method_args: ["NotImplementedType"]
  expected: true

# ---------------------------------------------------------------------------
# ABC.__abstractmethods__ — empty frozenset on the ABC helper class
#
# ABC itself has no abstract methods; its __abstractmethods__ is an empty
# frozenset. This is tested independently of abc_meta.zspec.zsdl to confirm
# the type and emptiness via distinct method chains.
# ---------------------------------------------------------------------------

invariant abc_extra.ABC.abstractmethods_is_frozenset:
  description: "type(abc.ABC.__abstractmethods__).__name__ == 'frozenset'"
  category: abc_abstractmethods
  kind: python_call_eq
  function: ABC.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant abc_extra.ABC.abstractmethods_len_zero:
  description: "len(abc.ABC.__abstractmethods__) == 0 — ABC has no abstract methods"
  category: abc_abstractmethods
  kind: python_call_eq
  function: ABC.__abstractmethods__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# ABCMeta.__instancecheck__ — isinstance() delegation hook
#
# ABCMeta overrides __instancecheck__ so that isinstance(x, SomeABC) consults
# the ABC's virtual-subclass registry. We confirm the method is present and
# callable with the right __name__.
# ---------------------------------------------------------------------------

invariant abc_extra.ABCMeta.instancecheck_name:
  description: "abc.ABCMeta.__instancecheck__.__name__ == '__instancecheck__'"
  category: abcmeta_instancecheck
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__name__.__eq__
  args: ["__instancecheck__"]
  expected: true

invariant abc_extra.ABCMeta.instancecheck_is_function:
  description: "type(abc.ABCMeta.__instancecheck__).__name__ == 'function'"
  category: abcmeta_instancecheck
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# get_cache_token() — return type is int
#
# get_cache_token() returns an opaque non-negative integer that increments
# each time the ABC inheritance cache is invalidated. We confirm the type.
# ---------------------------------------------------------------------------

invariant abc_extra.get_cache_token.return_type_is_int:
  description: "type(abc.get_cache_token()).__name__ == 'int'"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Deprecated abstracts — abstractclassmethod, abstractstaticmethod,
# abstractproperty (present in >=3.3, removed in 3.13)
#
# These were deprecated in Python 3.3 in favour of stacking @classmethod /
# @staticmethod / @property with @abstractmethod. They remain importable from
# abc on Python versions before 3.13.
# ---------------------------------------------------------------------------

invariant abc_extra.abstractproperty.name:
  description: "abc.abstractproperty.__name__ == 'abstractproperty' (deprecated, present <3.13)"
  category: deprecated
  version: ">=3.3,<3.13"
  kind: python_call_eq
  function: abstractproperty.__name__.__eq__
  args: ["abstractproperty"]
  expected: true

invariant abc_extra.abstractclassmethod.name:
  description: "abc.abstractclassmethod.__name__ == 'abstractclassmethod' (deprecated, present <3.13)"
  category: deprecated
  version: ">=3.3,<3.13"
  kind: python_call_eq
  function: abstractclassmethod.__name__.__eq__
  args: ["abstractclassmethod"]
  expected: true

invariant abc_extra.abstractstaticmethod.name:
  description: "abc.abstractstaticmethod.__name__ == 'abstractstaticmethod' (deprecated, present <3.13)"
  category: deprecated
  version: ">=3.3,<3.13"
  kind: python_call_eq
  function: abstractstaticmethod.__name__.__eq__
  args: ["abstractstaticmethod"]
  expected: true
