spec: socket_extra40
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra39.zspec.zsdl — covers socket.socket connect/bind/accept/listen/send/recv __name__.__eq__ string values."
    - "socket_extra38.zspec.zsdl — covers socket.AF_INET==2, SOCK_STREAM==1, SOCK_DGRAM==2; getfqdn/__name__=='getfqdn'; getfqdn/__module__=='socket'."
    - "socket_extra37.zspec.zsdl — covers socket.socket recvfrom/sendto/makefile/connect_ex/recv_into/recvfrom_into __name__.__len__(); dup/get_inheritable/set_inheritable __name__.__len__(); gaierror/herror/timeout __module__.__len__()."
    - "socket_extra34.zspec.zsdl — covers socket.socket close/setblocking/getsockname/fileno/detach/shutdown/sendall __name__.__len__() (length checks only, NOT string eq values)."
    - "socket_extra29.zspec.zsdl — covers socket.socket/__mro__.__len__()==3; setsockopt/getsockopt/__name__.__len__()==10; settimeout/getpeername __name__/__qualname__.__len__()."
    - "socket_extra28.zspec.zsdl — covers socket.socket bind/connect/listen/accept/send/recv __name__/__qualname__/__len__(); setdefaulttimeout/__qualname__/__module__ lengths."
    - "socket_extra25.zspec.zsdl — covers herror/gaierror __module__.__eq__('socket'); timeout.__module__.__eq__('builtins')."
    - "socket_extra20.zspec.zsdl — covers setdefaulttimeout.__qualname__.__eq__('setdefaulttimeout') and __qualname__.__len__()==17."
    - "socket_extra19.zspec.zsdl — covers gaierror/__name__.__eq__('gaierror'); herror/__name__.__eq__('herror')."
    - "socket_extra11.zspec.zsdl — covers setdefaulttimeout/__module__.__eq__('_socket'); getdefaulttimeout/__module__.__eq__('_socket')."
    - "socket_extra8.zspec.zsdl — covers setdefaulttimeout/__qualname__.__eq__ as a standalone invariant."
    - "socket_extra7.zspec.zsdl — covers setdefaulttimeout/__name__.__eq__('setdefaulttimeout'); getdefaulttimeout/__name__.__eq__('getdefaulttimeout')."
    - "socket.zspec.zsdl — covers getdefaulttimeout/__name__.__eq__('getdefaulttimeout')."
  notes:
    - "This spec extends socket through socket_extra39; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: socket_extra8 and socket_extra20 cover setdefaulttimeout.__qualname__.__eq__('setdefaulttimeout'). But NO prior spec checks getdefaulttimeout.__qualname__.__eq__('getdefaulttimeout') as a string eq value. socket_extra7 and socket.zspec cover getdefaulttimeout.__name__.__eq__; socket_extra32 covers getdefaulttimeout.__name__.__len__()==17. The __qualname__.__eq__ axis is independent and not covered for getdefaulttimeout. For C-level built-in functions __qualname__ == __name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.getdefaulttimeout.__qualname__ == 'getdefaulttimeout'. Identical to __name__ for C-level functions. socket_extra7 covers __name__.__eq__; socket_extra20 covers setdefaulttimeout.__qualname__.__eq__ but NOT getdefaulttimeout.__qualname__.__eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: socket_extra34 covers socket.socket.close/__name__.__len__()==5 and fileno/__name__.__len__()==6 (length checks). socket_extra39 covers connect/bind/accept/listen/send/recv __name__.__eq__ (string eq values). But NO prior spec checks socket.socket.fileno/__name__.__eq__('fileno'), close/__name__.__eq__('close'), setsockopt/__name__.__eq__('setsockopt'), or getsockopt/__name__.__eq__('getsockopt') as string eq values. The __name__.__eq__ axis is distinct from __name__.__len__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.fileno.__name__ == 'fileno'. extra34 covers __name__.__len__()==6 (length only). No prior spec checks __name__.__eq__('fileno'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.close.__name__ == 'close'. extra34 covers __name__.__len__()==5 (length only). No prior spec checks __name__.__eq__('close'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__name__ == 'setsockopt'. extra29 covers __name__.__len__()==10 (length only). No prior spec checks __name__.__eq__('setsockopt'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__name__ == 'getsockopt'. extra29 covers __name__.__len__()==10 (length only). No prior spec checks __name__.__eq__('getsockopt'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.getdefaulttimeout.__qualname__ string eq check
#
# socket.zspec and socket_extra7 cover getdefaulttimeout.__name__.__eq__('getdefaulttimeout').
# socket_extra20 covers setdefaulttimeout.__qualname__.__eq__('setdefaulttimeout').
# No prior spec checks getdefaulttimeout.__qualname__.__eq__('getdefaulttimeout').
# For C-level built-in functions in _socket, __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant socket_extra40.getdefaulttimeout.qualname_eq:
  description: "socket.getdefaulttimeout.__qualname__ == 'getdefaulttimeout' — C builtin; novel: extra7/socket.zspec cover __name__.__eq__; extra20 covers setdefaulttimeout.__qualname__.__eq__ but NOT getdefaulttimeout.__qualname__.__eq__"
  category: function_names
  kind: python_call_eq
  function: getdefaulttimeout.__qualname__.__eq__
  args: ["getdefaulttimeout"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket method __name__ string eq values: fileno, close, setsockopt, getsockopt
#
# socket_extra39 covers connect/bind/accept/listen/send/recv __name__.__eq__.
# socket_extra34 covers close/__name__.__len__()==5 and fileno/__name__.__len__()==6 (length only).
# socket_extra29 covers setsockopt/__name__.__len__()==10 and getsockopt/__name__.__len__()==10 (length only).
# No prior spec checks __name__.__eq__ for any of these four methods.
# ---------------------------------------------------------------------------

table socket_extra40.socket_method_name_eqs:
  description: "socket.socket fileno/close/setsockopt/getsockopt __name__.__eq__ string values — novel: extra34 covers fileno/close __name__.__len__(); extra29 covers setsockopt/getsockopt __name__.__len__(); no prior spec checks __name__.__eq__ for any of these methods"
  kind: python_call_eq
  category: function_names
  id_prefix: ssmne40

  columns: [id, function, args, expected]
  rows:
    - [fileno_name_eq,    "socket.fileno.__name__.__eq__",    ["fileno"],    true]
    - [close_name_eq,     "socket.close.__name__.__eq__",     ["close"],     true]
    - [setsockopt_name_eq,"socket.setsockopt.__name__.__eq__",["setsockopt"],true]
    - [getsockopt_name_eq,"socket.getsockopt.__name__.__eq__",["getsockopt"],true]
