spec: warnings_extra15
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Modules/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl through warnings_extra14.zspec.zsdl."
    - "warnings_extra14 covers: simplefilter/__name__/__module__, filterwarnings/__name__/__module__, _filters_mutated/__module__/__qualname__."
    - "warnings_extra13 covers: filterwarnings/__class__.__name__, simplefilter/__class__.__name__, resetwarnings/__class__.__name__, showwarning/__class__.__name__ == 'function'."
    - "warnings_extra12 covers: WarningMessage/__class__.__name__ == 'type', catch_warnings/__class__.__name__ == 'type'."
    - "warnings_extra11 covers: WarningMessage/__name__/__module__/__bases__[0].__name__, warn/__qualname__, defaultaction value."
    - "NOT yet covered in any prior spec: catch_warnings/__name__/__module__/__qualname__."
    - "NOT yet covered in any prior spec: resetwarnings/__name__/__module__/__qualname__."
    - "NOT yet covered in any prior spec: showwarning/__name__/__module__/__qualname__."
    - "NOT yet covered in any prior spec: warn_explicit/__name__/__module__/__class__.__name__."
    - "catch_warnings.__module__ == '_py_warnings' — defined in pure-Python warnings fallback layer."
    - "resetwarnings.__module__ == '_py_warnings' — same layer as filterwarnings and simplefilter."
    - "showwarning.__module__ == '_py_warnings' — same layer."
    - "warn_explicit.__module__ == '_warnings' — C-level implementation (like warn itself)."
    - "warn_explicit.__class__.__name__ == 'builtin_function_or_method' — C builtin, unlike the pure-Python functions."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# catch_warnings — __name__, __module__, __qualname__
#
# warnings_extra12 records catch_warnings.__class__.__name__ == 'type'.
# No prior spec records __name__, __module__, or __qualname__ for catch_warnings.
# catch_warnings is a pure-Python class in _py_warnings; its __qualname__
# equals its __name__ (top-level class, no enclosing scope).
# ---------------------------------------------------------------------------

invariant warnings_extra15.catch_warnings.name:
  description: "warnings.catch_warnings.__name__ == 'catch_warnings'"
  category: class_identity
  kind: python_call_eq
  function: catch_warnings.__name__.__eq__
  args: ["catch_warnings"]
  expected: true

invariant warnings_extra15.catch_warnings.module:
  description: "warnings.catch_warnings.__module__ == '_py_warnings'"
  category: class_identity
  kind: python_call_eq
  function: catch_warnings.__module__.__eq__
  args: ["_py_warnings"]
  expected: true

invariant warnings_extra15.catch_warnings.qualname:
  description: "warnings.catch_warnings.__qualname__ == 'catch_warnings'"
  category: class_identity
  kind: python_call_eq
  function: catch_warnings.__qualname__.__eq__
  args: ["catch_warnings"]
  expected: true

# ---------------------------------------------------------------------------
# warn_explicit — __name__, __module__, __class__.__name__
#
# No prior spec records any identity attribute for warn_explicit.
# warn_explicit is the C-level implementation (like warn); its __module__ is
# '_warnings' (not '_py_warnings') and its __class__.__name__ is
# 'builtin_function_or_method' — distinguishing it from the pure-Python
# functions in this module.
# ---------------------------------------------------------------------------

invariant warnings_extra15.warn_explicit.name:
  description: "warnings.warn_explicit.__name__ == 'warn_explicit'"
  category: function_identity
  kind: python_call_eq
  function: warn_explicit.__name__.__eq__
  args: ["warn_explicit"]
  expected: true

invariant warnings_extra15.warn_explicit.module:
  description: "warnings.warn_explicit.__module__ == '_warnings' — C-level implementation"
  category: function_identity
  kind: python_call_eq
  function: warn_explicit.__module__.__eq__
  args: ["_warnings"]
  expected: true

invariant warnings_extra15.warn_explicit.class_name:
  description: "warnings.warn_explicit.__class__.__name__ == 'builtin_function_or_method'"
  category: function_identity
  kind: python_call_eq
  function: warn_explicit.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# Pure-Python function __name__ and __module__ table
#
# warnings_extra13 records __class__.__name__ == 'function' for resetwarnings
# and showwarning. warnings_extra14 records __name__ and __module__ for
# simplefilter and filterwarnings. No prior spec records __name__ or __module__
# for resetwarnings or showwarning.
# All four are pure-Python functions defined in _py_warnings.
# ---------------------------------------------------------------------------

table warnings_extra15.py_function_identity:
  description: "__name__ and __module__ for resetwarnings and showwarning"
  kind: python_call_eq
  category: function_identity

  columns: [id, function, args, expected]
  rows:
    - [resetwarnings_name,   resetwarnings.__name__.__eq__,   ["resetwarnings"], true]
    - [resetwarnings_module, resetwarnings.__module__.__eq__, ["_py_warnings"],  true]
    - [showwarning_name,     showwarning.__name__.__eq__,     ["showwarning"],   true]
    - [showwarning_module,   showwarning.__module__.__eq__,   ["_py_warnings"],  true]
