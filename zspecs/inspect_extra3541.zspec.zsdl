spec: in3541
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 683 (in3541): __format__, __sizeof__, __dir__ dict-presence checks for inspect types."
    - "All values false — inspect introspection types do not define __format__, __sizeof__, or __dir__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __format__ dict-presence — operator.contains(Cls.__dict__, '__format__')
# ---------------------------------------------------------------------------

table in3541.format:
  description: "inspect types __format__ dict-presence checks; wave 683"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3541
  columns: [id, function, args, expected]
  rows:
    - ["in3541001", operator.contains, [inspect.Parameter.__dict__,           "__format__"], false]
    - ["in3541002", operator.contains, [inspect.Signature.__dict__,           "__format__"], false]
    - ["in3541003", operator.contains, [inspect.BoundArguments.__dict__,      "__format__"], false]
    - ["in3541004", operator.contains, [inspect.FrameInfo.__dict__,           "__format__"], false]
    - ["in3541005", operator.contains, [inspect.ArgInfo.__dict__,             "__format__"], false]
    - ["in3541006", operator.contains, [inspect.FullArgSpec.__dict__,         "__format__"], false]
    - ["in3541007", operator.contains, [inspect.Attribute.__dict__,           "__format__"], false]
    - ["in3541008", operator.contains, [inspect.ClassFoundException.__dict__, "__format__"], false]
    - ["in3541009", operator.contains, [inspect.EndOfBlock.__dict__,          "__format__"], false]

