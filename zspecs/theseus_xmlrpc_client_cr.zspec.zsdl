spec: theseus_xmlrpc_client_cr
version: ">=3.8"
backend: python_cleanroom(theseus_xmlrpc_client_cr)
blocks: xmlrpc.client

docs: https://docs.python.org/3/library/xmlrpc.client.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/xmlrpc.client.html"
  not_derived_from:
    - "CPython source: Lib/xmlrpc/client.py"
  notes:
    - "Clean-room xmlrpc.client module. Do NOT import xmlrpc.client."
    - "Marshals and unmarshals Python types to/from XML-RPC."

error_model: python_exceptions

invariant theseus_xmlrpc_client_cr.xmlrpc2_boolean:
  description: "Boolean values marshal to <boolean>1</boolean> or <boolean>0</boolean>"
  category: marshaling
  kind: python_call_eq
  function: xmlrpc2_boolean
  args: []
  expected: true

invariant theseus_xmlrpc_client_cr.xmlrpc2_fault:
  description: "Fault class stores faultCode and faultString"
  category: exceptions
  kind: python_call_eq
  function: xmlrpc2_fault
  args: []
  expected: true

invariant theseus_xmlrpc_client_cr.xmlrpc2_dumps:
  description: "dumps produces valid XML-RPC method call XML"
  category: serialization
  kind: python_call_eq
  function: xmlrpc2_dumps
  args: []
  expected: true
