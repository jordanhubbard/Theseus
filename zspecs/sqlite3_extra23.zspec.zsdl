spec: sqlite3_extra23
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra22.zspec.zsdl."
    - "Prior specs covered: sqlite3.__name__/__package__; Connection/__name__/__module__/__qualname__; Cursor/__name__/__module__/__qualname__; Row/__name__/__module__/__qualname__; Error/__name__/__module__; DatabaseError/__name__; OperationalError/__name__; IntegrityError/__name__; sqlite3.connect/__name__/__module__; sqlite3.sqlite_version/__class__/__name__; Connection/__bases__[0].__name__; Cursor/__bases__[0].__name__; Error/__bases__[0].__name__; DatabaseError/__bases__[0].__name__; OperationalError/__bases__[0].__name__; complete_statement/__name__; various __qualname__ checks; Warning/InterfaceError/NotSupportedError qualnames and bases."
    - "This spec covers: sqlite3.Connection.__init__.__name__; sqlite3.Cursor.__init__.__name__; sqlite3.InterfaceError/__name__/__bases__[0].__name__; sqlite3.DataError/__name__/__bases__[0].__name__; sqlite3.NotSupportedError/__name__/__bases__[0].__name__; sqlite3.ProgrammingError/__name__/__bases__[0].__name__; sqlite3.InternalError/__name__/__bases__[0].__name__; sqlite3.Warning/__name__."
    - "sqlite3.Connection.__init__.__name__ == '__init__' — Connection is a C-extension type that defines its own __init__. Verified at runtime."
    - "sqlite3.Cursor.__init__.__name__ == '__init__' — Cursor is a C-extension type that defines its own __init__. Verified at runtime."
    - "sqlite3.InterfaceError.__name__ == 'InterfaceError' — direct subclass of Error. Verified at runtime."
    - "sqlite3.InterfaceError.__bases__[0].__name__ == 'Error' — InterfaceError inherits from Error, not DatabaseError. Verified at runtime."
    - "sqlite3.DataError.__name__ == 'DataError' — direct subclass of DatabaseError. Verified at runtime."
    - "sqlite3.DataError.__bases__[0].__name__ == 'DatabaseError' — DataError inherits from DatabaseError. Verified at runtime."
    - "sqlite3.NotSupportedError.__name__ == 'NotSupportedError' — direct subclass of DatabaseError. Verified at runtime."
    - "sqlite3.NotSupportedError.__bases__[0].__name__ == 'DatabaseError' — NotSupportedError inherits from DatabaseError. Verified at runtime."
    - "sqlite3.ProgrammingError.__name__ == 'ProgrammingError' — direct subclass of DatabaseError. Verified at runtime."
    - "sqlite3.ProgrammingError.__bases__[0].__name__ == 'DatabaseError' — ProgrammingError inherits from DatabaseError. Verified at runtime."
    - "sqlite3.InternalError.__name__ == 'InternalError' — direct subclass of DatabaseError. Verified at runtime."
    - "sqlite3.InternalError.__bases__[0].__name__ == 'DatabaseError' — InternalError inherits from DatabaseError. Verified at runtime."
    - "sqlite3.Warning.__name__ == 'Warning' — sqlite3.Warning is a distinct exception type that inherits from Exception, not from Error. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sqlite3.Connection.__init__ — __name__
#
# No prior spec verifies Connection.__init__.__name__ as a standalone invariant.
# Connection is a C-extension type that defines its own __init__;
# __name__ == '__init__'. Verified at runtime: '__init__'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra23.Connection.init_name:
  description: "sqlite3.Connection.__init__.__name__ == '__init__' — Connection (C-extension) defines its own __init__"
  category: function_identity
  kind: python_call_eq
  function: Connection.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Cursor.__init__ — __name__
#
# No prior spec verifies Cursor.__init__.__name__ as a standalone invariant.
# Cursor is a C-extension type that defines its own __init__;
# __name__ == '__init__'. Verified at runtime: '__init__'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra23.Cursor.init_name:
  description: "sqlite3.Cursor.__init__.__name__ == '__init__' — Cursor (C-extension) defines its own __init__"
  category: function_identity
  kind: python_call_eq
  function: Cursor.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.InterfaceError — __name__
#
# sqlite3_extra21 covers InterfaceError.__qualname__ as a table entry. No prior
# spec verifies InterfaceError.__name__ as a standalone invariant in this spec.
# InterfaceError is the exception raised for errors related to the database
# interface rather than the database itself. __name__ == 'InterfaceError'.
# Verified at runtime: 'InterfaceError'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra23.InterfaceError.name:
  description: "sqlite3.InterfaceError.__name__ == 'InterfaceError' — exception for database interface errors"
  category: class_identity
  kind: python_call_eq
  function: InterfaceError.__name__.__eq__
  args: ["InterfaceError"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.InterfaceError — __bases__[0].__name__
#
# sqlite3_extra21 covers InterfaceError.__bases__[0].__name__ in a table entry.
# No prior spec verifies it as a standalone invariant in this spec.
# InterfaceError is a direct subclass of Error (not DatabaseError), placing it
# at the Error level of the exception hierarchy.
# Verified at runtime: 'Error'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra23.InterfaceError.base_name:
  description: "sqlite3.InterfaceError.__bases__[0].__name__ == 'Error' — InterfaceError is a direct subclass of Error"
  category: class_identity
  kind: python_call_eq
  function: "InterfaceError.__bases__[0].__name__.__eq__"
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.DataError — __name__
#
# No prior spec verifies DataError.__name__ as a standalone invariant.
# DataError is raised for errors due to problems with the processed data.
# __name__ == 'DataError'. Verified at runtime: 'DataError'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra23.DataError.name:
  description: "sqlite3.DataError.__name__ == 'DataError' — exception for data processing errors"
  category: class_identity
  kind: python_call_eq
  function: DataError.__name__.__eq__
  args: ["DataError"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.DataError — __bases__[0].__name__
#
# No prior spec verifies DataError.__bases__[0].__name__ as a standalone
# invariant. DataError is a direct subclass of DatabaseError.
# Verified at runtime: 'DatabaseError'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra23.DataError.base_name:
  description: "sqlite3.DataError.__bases__[0].__name__ == 'DatabaseError' — DataError is a direct subclass of DatabaseError"
  category: class_identity
  kind: python_call_eq
  function: "DataError.__bases__[0].__name__.__eq__"
  args: ["DatabaseError"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.NotSupportedError — __name__
#
# sqlite3_extra21 covers NotSupportedError.__qualname__ as a table entry. No
# prior spec verifies NotSupportedError.__name__ as a standalone invariant in
# this spec. NotSupportedError is raised when a method or database API is not
# supported. __name__ == 'NotSupportedError'.
# Verified at runtime: 'NotSupportedError'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra23.NotSupportedError.name:
  description: "sqlite3.NotSupportedError.__name__ == 'NotSupportedError' — exception for unsupported methods or features"
  category: class_identity
  kind: python_call_eq
  function: NotSupportedError.__name__.__eq__
  args: ["NotSupportedError"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.NotSupportedError — __bases__[0].__name__
#
# sqlite3_extra21 covers NotSupportedError.__bases__[0].__name__ in a table
# entry. No prior spec verifies it as a standalone invariant in this spec.
# NotSupportedError is a direct subclass of DatabaseError.
# Verified at runtime: 'DatabaseError'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra23.NotSupportedError.base_name:
  description: "sqlite3.NotSupportedError.__bases__[0].__name__ == 'DatabaseError' — NotSupportedError is a direct subclass of DatabaseError"
  category: class_identity
  kind: python_call_eq
  function: "NotSupportedError.__bases__[0].__name__.__eq__"
  args: ["DatabaseError"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.ProgrammingError — __name__
#
# No prior spec verifies ProgrammingError.__name__ as a standalone invariant.
# ProgrammingError is raised for programming errors such as table not found,
# syntax errors, wrong number of parameters, etc.
# __name__ == 'ProgrammingError'. Verified at runtime: 'ProgrammingError'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra23.ProgrammingError.name:
  description: "sqlite3.ProgrammingError.__name__ == 'ProgrammingError' — exception for programming errors such as syntax errors or wrong parameter counts"
  category: class_identity
  kind: python_call_eq
  function: ProgrammingError.__name__.__eq__
  args: ["ProgrammingError"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.ProgrammingError — __bases__[0].__name__
#
# No prior spec verifies ProgrammingError.__bases__[0].__name__ as a standalone
# invariant. ProgrammingError is a direct subclass of DatabaseError.
# Verified at runtime: 'DatabaseError'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra23.ProgrammingError.base_name:
  description: "sqlite3.ProgrammingError.__bases__[0].__name__ == 'DatabaseError' — ProgrammingError is a direct subclass of DatabaseError"
  category: class_identity
  kind: python_call_eq
  function: "ProgrammingError.__bases__[0].__name__.__eq__"
  args: ["DatabaseError"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.InternalError — __name__
#
# No prior spec verifies InternalError.__name__ as a standalone invariant.
# InternalError is raised when the database encounters an internal error,
# such as a cursor not being valid any more.
# __name__ == 'InternalError'. Verified at runtime: 'InternalError'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra23.InternalError.name:
  description: "sqlite3.InternalError.__name__ == 'InternalError' — exception for internal database errors"
  category: class_identity
  kind: python_call_eq
  function: InternalError.__name__.__eq__
  args: ["InternalError"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Warning — __name__
#
# No prior spec verifies Warning.__name__ as a standalone invariant in this
# spec. sqlite3.Warning is raised for important warnings, and unlike the
# DatabaseError subclasses it directly inherits from Exception.
# __name__ == 'Warning'. Verified at runtime: 'Warning'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra23.Warning.name:
  description: "sqlite3.Warning.__name__ == 'Warning' — exception for important warnings; inherits from Exception, not from Error"
  category: class_identity
  kind: python_call_eq
  function: Warning.__name__.__eq__
  args: ["Warning"]
  expected: true

# ---------------------------------------------------------------------------
# Table: Connection and Cursor __init__.__name__ values
#
# No prior spec groups Connection and Cursor __init__.__name__ checks into a
# single table. Both are C-extension types that define their own __init__.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table sqlite3_extra23.init_names:
  description: "sqlite3 class __init__.__name__ values — Connection and Cursor each define their own __init__"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [Connection_init,
       Connection.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "Connection.__init__.__name__ == '__init__'"]
    - [Cursor_init,
       Cursor.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "Cursor.__init__.__name__ == '__init__'"]

# ---------------------------------------------------------------------------
# Table: sqlite3 exception class names and base class names
#
# No prior spec groups InterfaceError, DataError, NotSupportedError,
# ProgrammingError, InternalError, and Warning __name__ and __bases__[0].__name__
# values into a single table. All values verified at runtime.
# ---------------------------------------------------------------------------

table sqlite3_extra23.exception_class_hierarchy:
  description: "sqlite3 exception class __name__ and __bases__[0].__name__ values — InterfaceError, DataError, NotSupportedError, ProgrammingError, InternalError, Warning"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [InterfaceError_name,
       InterfaceError.__name__.__eq__,
       ["InterfaceError"],
       true,
       "InterfaceError.__name__ == 'InterfaceError'"]
    - [InterfaceError_base,
       "InterfaceError.__bases__[0].__name__.__eq__",
       ["Error"],
       true,
       "InterfaceError.__bases__[0].__name__ == 'Error'"]
    - [DataError_name,
       DataError.__name__.__eq__,
       ["DataError"],
       true,
       "DataError.__name__ == 'DataError'"]
    - [DataError_base,
       "DataError.__bases__[0].__name__.__eq__",
       ["DatabaseError"],
       true,
       "DataError.__bases__[0].__name__ == 'DatabaseError'"]
    - [NotSupportedError_name,
       NotSupportedError.__name__.__eq__,
       ["NotSupportedError"],
       true,
       "NotSupportedError.__name__ == 'NotSupportedError'"]
    - [NotSupportedError_base,
       "NotSupportedError.__bases__[0].__name__.__eq__",
       ["DatabaseError"],
       true,
       "NotSupportedError.__bases__[0].__name__ == 'DatabaseError'"]
    - [ProgrammingError_name,
       ProgrammingError.__name__.__eq__,
       ["ProgrammingError"],
       true,
       "ProgrammingError.__name__ == 'ProgrammingError'"]
    - [ProgrammingError_base,
       "ProgrammingError.__bases__[0].__name__.__eq__",
       ["DatabaseError"],
       true,
       "ProgrammingError.__bases__[0].__name__ == 'DatabaseError'"]
    - [InternalError_name,
       InternalError.__name__.__eq__,
       ["InternalError"],
       true,
       "InternalError.__name__ == 'InternalError'"]
    - [Warning_name,
       Warning.__name__.__eq__,
       ["Warning"],
       true,
       "Warning.__name__ == 'Warning'"]
