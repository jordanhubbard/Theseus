spec: itertools_extra268
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "All itertools types in this spec have __doc__ strings of type 'str' — none are None."
    - "itertools.chain.__doc__ length is 190; itertools.count.__doc__ length is 205 (longest in first table)."
    - "itertools.accumulate.__doc__ length is 69 — shortest docstring among the types covered here."
    - "itertools.product.__doc__ length is 681 — longest overall docstring in spec."
    - "All itertools C-level types have __doc__ attributes of Python type str."
    - "chain.__doc__ contains 'chain'; count.__doc__ contains 'count'; repeat.__doc__ contains 'repeat'."
    - "itertools.islice.__name__ == 'islice' (len=6); islice.__doc__ type is 'str'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools types doc class names: chain, count, repeat, cycle, product, combinations
#
# All have __doc__ of Python type str.
# count.__doc__ (205) is longest in this table.
# cycle.__doc__ (95) is shortest in this table.
# ---------------------------------------------------------------------------

table itertools_extra268.doc_class_first_six:
  description: "itertools chain, count, repeat, cycle, product, combinations __doc__ class names — all are 'str'; count.__doc__(205) longest in table; cycle.__doc__(95) shortest in table; all docs are non-empty; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex268da

  columns: [id, function, args, expected, description]
  rows:
    - [ch_doc_cls,         chain.__doc__.__class__.__name__.__eq__,     ["str"],                        true, "itertools.chain.__doc__.__class__.__name__ == 'str' — chain has a docstring; verified with Python 3.14.3"]
    - [ch_doc_len,         chain.__doc__.__len__,                       [],                             190,  "itertools.chain.__doc__.__len__() == 190; verified with Python 3.14.3"]
    - [co_doc_cls,         count.__doc__.__class__.__name__.__eq__,     ["str"],                        true, "itertools.count.__doc__.__class__.__name__ == 'str' — count has a docstring; verified with Python 3.14.3"]
    - [co_doc_len,         count.__doc__.__len__,                       [],                             205,  "itertools.count.__doc__.__len__() == 205 — longest doc in table; verified with Python 3.14.3"]
    - [rp_doc_cls,         repeat.__doc__.__class__.__name__.__eq__,    ["str"],                        true, "itertools.repeat.__doc__.__class__.__name__ == 'str' — repeat has a docstring; verified with Python 3.14.3"]
    - [rp_doc_len,         repeat.__doc__.__len__,                      [],                             154,  "itertools.repeat.__doc__.__len__() == 154; verified with Python 3.14.3"]
    - [cy_doc_cls,         cycle.__doc__.__class__.__name__.__eq__,     ["str"],                        true, "itertools.cycle.__doc__.__class__.__name__ == 'str' — cycle has a docstring; verified with Python 3.14.3"]
    - [cy_doc_len,         cycle.__doc__.__len__,                       [],                             95,   "itertools.cycle.__doc__.__len__() == 95 — shortest doc in table; verified with Python 3.14.3"]
    - [pr_doc_cls,         product.__doc__.__class__.__name__.__eq__,   ["str"],                        true, "itertools.product.__doc__.__class__.__name__ == 'str' — product has a docstring; verified with Python 3.14.3"]
    - [pr_doc_len,         product.__doc__.__len__,                     [],                             681,  "itertools.product.__doc__.__len__() == 681 — longest overall doc in spec; verified with Python 3.14.3"]
    - [cb_doc_cls,         combinations.__doc__.__class__.__name__.__eq__, ["str"],                     true, "itertools.combinations.__doc__.__class__.__name__ == 'str' — combinations has a docstring; verified with Python 3.14.3"]
    - [cb_doc_len,         combinations.__doc__.__len__,                [],                             134,  "itertools.combinations.__doc__.__len__() == 134; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# itertools types doc class names: permutations, accumulate, islice, starmap, dropwhile, takewhile
#
# All have __doc__ of Python type str.
# accumulate.__doc__ (69) is shortest in spec.
# islice.__doc__ (453) is longest in this table.
# ---------------------------------------------------------------------------

table itertools_extra268.doc_class_next_six:
  description: "itertools permutations, accumulate, islice, starmap, dropwhile, takewhile __doc__ class names — all are 'str'; islice.__doc__(453) longest in table; accumulate.__doc__(69) shortest in spec; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex268db

  columns: [id, function, args, expected, description]
  rows:
    - [pm_doc_cls,         permutations.__doc__.__class__.__name__.__eq__, ["str"],                     true, "itertools.permutations.__doc__.__class__.__name__ == 'str' — permutations has a docstring; verified with Python 3.14.3"]
    - [pm_doc_len,         permutations.__doc__.__len__,                [],                             140,  "itertools.permutations.__doc__.__len__() == 140; verified with Python 3.14.3"]
    - [ac_doc_cls,         accumulate.__doc__.__class__.__name__.__eq__, ["str"],                       true, "itertools.accumulate.__doc__.__class__.__name__ == 'str' — accumulate has a docstring; verified with Python 3.14.3"]
    - [ac_doc_len,         accumulate.__doc__.__len__,                  [],                             69,   "itertools.accumulate.__doc__.__len__() == 69 — shortest docstring in spec; verified with Python 3.14.3"]
    - [is_doc_cls,         islice.__doc__.__class__.__name__.__eq__,    ["str"],                        true, "itertools.islice.__doc__.__class__.__name__ == 'str' — islice has a docstring; verified with Python 3.14.3"]
    - [is_doc_len,         islice.__doc__.__len__,                      [],                             453,  "itertools.islice.__doc__.__len__() == 453 — longest doc in this table; verified with Python 3.14.3"]
    - [sm_doc_cls,         starmap.__doc__.__class__.__name__.__eq__,   ["str"],                        true, "itertools.starmap.__doc__.__class__.__name__ == 'str' — starmap has a docstring; verified with Python 3.14.3"]
    - [sm_doc_len,         starmap.__doc__.__len__,                     [],                             126,  "itertools.starmap.__doc__.__len__() == 126 — tied with dropwhile; verified with Python 3.14.3"]
    - [dw_doc_cls,         dropwhile.__doc__.__class__.__name__.__eq__, ["str"],                        true, "itertools.dropwhile.__doc__.__class__.__name__ == 'str' — dropwhile has a docstring; verified with Python 3.14.3"]
    - [dw_doc_len,         dropwhile.__doc__.__len__,                   [],                             126,  "itertools.dropwhile.__doc__.__len__() == 126 — tied with starmap; verified with Python 3.14.3"]
    - [tw_doc_cls,         takewhile.__doc__.__class__.__name__.__eq__, ["str"],                        true, "itertools.takewhile.__doc__.__class__.__name__ == 'str' — takewhile has a docstring; verified with Python 3.14.3"]
    - [tw_doc_len,         takewhile.__doc__.__len__,                   [],                             101,  "itertools.takewhile.__doc__.__len__() == 101; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra268
# ---------------------------------------------------------------------------

invariant itertools_extra268.chain_doc_is_str:
  description: "itertools.chain.__doc__.__class__.__name__ == 'str' — all itertools types in this spec have docstrings of Python type str; none have None docs"
  category: identity
  kind: python_call_eq
  function: chain.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra268.accumulate_doc_is_shortest:
  description: "itertools.accumulate.__doc__.__len__() == 69 — shortest docstring in spec; much shorter than product(681) or islice(453)"
  category: identity
  kind: python_call_eq
  function: accumulate.__doc__.__len__
  args: []
  expected: 69

invariant itertools_extra268.product_doc_is_longest:
  description: "itertools.product.__doc__.__len__() == 681 — longest docstring in spec; far longer than count(205) or chain(190)"
  category: identity
  kind: python_call_eq
  function: product.__doc__.__len__
  args: []
  expected: 681

invariant itertools_extra268.starmap_doc_len_equals_dropwhile:
  description: "itertools.starmap.__doc__.__len__() == 126 == itertools.dropwhile.__doc__.__len__() — starmap and dropwhile docstrings are both length 126"
  category: identity
  kind: python_call_eq
  function: starmap.__doc__.__len__
  args: []
  expected: 126

invariant itertools_extra268.islice_name_is_islice:
  description: "itertools.islice.__name__ == 'islice' (len=6) — islice is a C-level type with __module__ == 'itertools'; also has the longest docstring in its table at 453 chars"
  category: identity
  kind: python_call_eq
  function: islice.__name__.__eq__
  args: ["islice"]
  expected: true
