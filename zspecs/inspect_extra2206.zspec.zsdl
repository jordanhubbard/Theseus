spec: inspect_extra2206
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2206: rich comparison operator protocol dict-presence — __lt__, __le__, __gt__, __ge__, __eq__, __ne__."
    - "inspect.Parameter defines __eq__ and __hash__ in its own __dict__, but NOT __lt__, __le__, __gt__, __ge__, or __ne__."
    - "inspect.Signature defines __eq__ and __hash__ in its own __dict__, but NOT __lt__, __le__, __gt__, __ge__, or __ne__."
    - "inspect.BoundArguments defines __eq__ and __hash__ in its own __dict__, but NOT __lt__, __le__, __gt__, __ge__, or __ne__."
    - "All three classes define custom __eq__ for value-based equality comparison, with matching __hash__ for correctness."
    - "The absence of __lt__/__le__/__gt__/__ge__ in Parameter, Signature, and BoundArguments confirms they are equality-only comparable — no ordering."
    - "inspect.FullArgSpec is a namedtuple subclass; it does NOT define comparison operators in its own __dict__ (inherits from tuple)."
    - "inspect.Parameter also defines __repr__, __str__, __init__, __slots__, __reduce__, __replace__ in its own __dict__."
    - "inspect.Signature also defines __repr__, __str__, __init__, __slots__, __reduce__, __replace__ in its own __dict__."
    - "inspect.BoundArguments also defines __repr__, __init__, __slots__, __weakref__ in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra2206.parameter_comparison_protocol:
  description: "inspect.Parameter dict-presence — defines __eq__ and __hash__ only; no ordering operators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2206

  columns: [id, function, args, expected]
  rows:
    - ["in2206001", "inspect.Parameter.__dict__.__contains__", ["__lt__"], false]
    - ["in2206002", "inspect.Parameter.__dict__.__contains__", ["__le__"], false]
    - ["in2206003", "inspect.Parameter.__dict__.__contains__", ["__gt__"], false]
    - ["in2206004", "inspect.Parameter.__dict__.__contains__", ["__ge__"], false]
    - ["in2206005", "inspect.Parameter.__dict__.__contains__", ["__eq__"], true]
    - ["in2206006", "inspect.Parameter.__dict__.__contains__", ["__ne__"], false]
    - ["in2206007", "inspect.Parameter.__dict__.__contains__", ["__hash__"], true]
    - ["in2206008", "inspect.Parameter.__dict__.__contains__", ["__repr__"], true]
    - ["in2206009", "inspect.Parameter.__dict__.__contains__", ["__init__"], true]
    - ["in2206010", "inspect.Parameter.__dict__.__contains__", ["__slots__"], true]

