spec: uuid_extra8
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra.zspec.zsdl — covers UUID.__name__/__module__, uuid1/3/4/5 __name__ (table), uuid4 return type/version, NAMESPACE_* class names (table), UUID int/hex attribute types"
    - "uuid_extra2.zspec.zsdl — covers uuid1/3/4/5 __name__ standalone, NAMESPACE_* class names standalone, RESERVED_*/RFC_4122 values and type table"
    - "uuid_extra3.zspec.zsdl — covers uuid1/3/4/5 __module__, UUID.__bases__[0].__name__, uuid4 version/class standalone, UUID(int=0).version is None, NAMESPACE_* class names standalone"
    - "uuid_extra4.zspec.zsdl — covers NAMESPACE_* class names (table), uuid4 version, uuid4 class name, uuid4 hex len, uuid5/__name__, uuid3/__name__, UUID str format, UUID int type, NAMESPACE_DNS str repr"
    - "uuid_extra5.zspec.zsdl — covers __qualname__ for UUID and uuid1/3/4/5 (table), UUID instance class name via fixed literal"
    - "uuid_extra6.zspec.zsdl — covers RESERVED_*/RFC_4122 __class__.__name__ (table), UUID.bytes/__class__/__name__, UUID.bytes_le/__class__/__name__, UUID.fields/__class__/__name__, UUID.fields.__len__() == 6"
    - "uuid_extra7.zspec.zsdl — covers SafeUUID class metadata, NAMESPACE_* .version attribute (table), uuid1()/uuid4() return class name and version standalone"
  notes:
    - "This spec extends the uuid chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: UUID.__bases__.__len__() == 1 (length of the bases tuple not previously checked); NAMESPACE_DNS and NAMESPACE_URL .int and .bytes attribute type checks as namespace-specific vectors (extra6 covers a generic fixed UUID, not the predefined namespace constants); __doc__ class name checks for UUID, uuid1, uuid4 (no prior spec checks docstring presence/type)."
    - "uuid.UUID.__bases__.__len__() == 1 — UUID has exactly one direct base (object); extra3 checks __bases__[0].__name__ but not the tuple length."
    - "uuid.NAMESPACE_DNS.int.__class__.__name__ == 'int' — the integer representation of NAMESPACE_DNS is a plain Python int; extra6 verifies .int for a generic fixed UUID, not for the predefined namespace constant."
    - "uuid.NAMESPACE_DNS.bytes.__class__.__name__ == 'bytes' — similarly, NAMESPACE_DNS.bytes is a 16-byte bytes object; this is the first check targeting a named namespace constant rather than a generic UUID."
    - "uuid.NAMESPACE_URL.int.__class__.__name__ == 'int' — same vector applied to NAMESPACE_URL for independent coverage."
    - "uuid.UUID.__doc__.__class__.__name__ == 'str' — UUID has a docstring; its type is str. No prior spec checks any __doc__ attribute in the uuid chain."
    - "uuid.uuid1.__doc__.__class__.__name__ == 'str' — uuid1 has a docstring; __doc__ is a str."
    - "uuid.uuid4.__doc__.__class__.__name__ == 'str' — uuid4 has a docstring; __doc__ is a str."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__bases__.__len__() == 1 — single-inheritance confirmation.
# uuid_extra3 verifies UUID.__bases__[0].__name__ == 'object' but does not
# check the length of the __bases__ tuple.
# ---------------------------------------------------------------------------

invariant uuid_extra8.UUID.bases_len:
  description: "uuid.UUID.__bases__.__len__() == 1 — UUID has exactly one direct base class (object)"
  category: class_metadata
  kind: python_call_eq
  function: UUID.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# NAMESPACE_DNS and NAMESPACE_URL instance attribute type checks.
# uuid_extra6 covers .bytes, .bytes_le, .fields for a generic fixed UUID string.
# No prior spec checks these attributes on the predefined namespace constants.
# ---------------------------------------------------------------------------

table uuid_extra8.namespace_int_class:
  kind: python_call_eq
  category: namespace_attributes
  id_prefix: nsint8

  columns: [id, function, args, expected]
  rows:
    - [NAMESPACE_DNS, NAMESPACE_DNS.int.__class__.__name__.__eq__, ["int"], true]
    - [NAMESPACE_URL, NAMESPACE_URL.int.__class__.__name__.__eq__, ["int"], true]

invariant uuid_extra8.NAMESPACE_DNS.bytes_class:
  description: "uuid.NAMESPACE_DNS.bytes.__class__.__name__ == 'bytes' — NAMESPACE_DNS.bytes is a 16-byte bytes object"
  category: namespace_attributes
  kind: python_call_eq
  function: NAMESPACE_DNS.bytes.__class__.__name__.__eq__
  args: ["bytes"]
  expected: true

# ---------------------------------------------------------------------------
# __doc__ attribute type checks for UUID class and uuid generator functions.
# No prior spec in the uuid chain checks any __doc__ attribute.
# UUID, uuid1, and uuid4 all have non-None docstrings; their type is str.
# ---------------------------------------------------------------------------

table uuid_extra8.doc_class_names:
  kind: python_call_eq
  category: docstrings
  id_prefix: doc8

  columns: [id, function, args, expected]
  rows:
    - [UUID,  UUID.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [uuid1, uuid1.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uuid4, uuid4.__doc__.__class__.__name__.__eq__, ["str"], true]
