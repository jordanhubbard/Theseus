spec: decimal_extra272
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "decimal.localcontext, setcontext, and getcontext are C-level builtins; __module__ == '_decimal'."
    - "decimal.getcontext() returns a Context instance; __class__.__name__ == 'Context'."
    - "decimal.BasicContext, DefaultContext, and ExtendedContext are pre-built Context instances, not classes."
    - "decimal.BasicContext.__class__.__name__ == 'Context' — it is an instance, not a type."
    - "decimal.Context.__module__ == 'decimal' (public module), but its functions are in '_decimal' (C extension)."
    - "decimal.Context.__bases__[0].__name__ == 'object' — Context is a direct subclass of object."
    - "decimal.BasicContext.prec == 9 and .rounding == 'ROUND_HALF_UP' (IBM GDAS basic profile)."
    - "decimal.DefaultContext.prec == 28 and .rounding == 'ROUND_HALF_EVEN' (CPython default)."
    - "decimal.ExtendedContext.prec == 9 and .rounding == 'ROUND_HALF_EVEN' (IBM GDAS extended profile)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Context function identity — localcontext, setcontext, getcontext are C builtins
# ---------------------------------------------------------------------------

table decimal_extra272.context_function_identity:
  description: "decimal.localcontext, setcontext, getcontext __module__ and __class__.__name__"
  kind: python_call_eq
  category: identity
  id_prefix: cfi

  columns: [id, function, args, expected, description]
  rows:
    - [localcontext_module,  localcontext.__module__.__eq__,              ["_decimal"], true, "decimal.localcontext.__module__ == '_decimal' (C extension)"]
    - [localcontext_type,    localcontext.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "decimal.localcontext is a C-level builtin"]
    - [setcontext_module,    setcontext.__module__.__eq__,                ["_decimal"], true, "decimal.setcontext.__module__ == '_decimal' (C extension)"]
    - [setcontext_type,      setcontext.__class__.__name__.__eq__,        ["builtin_function_or_method"], true, "decimal.setcontext is a C-level builtin"]
    - [getcontext_module,    getcontext.__module__.__eq__,                ["_decimal"], true, "decimal.getcontext.__module__ == '_decimal' (C extension)"]
    - [getcontext_type,      getcontext.__class__.__name__.__eq__,        ["builtin_function_or_method"], true, "decimal.getcontext is a C-level builtin"]

# ---------------------------------------------------------------------------
# Context class identity — __name__, __module__, __bases__[0].__name__
# ---------------------------------------------------------------------------

table decimal_extra272.context_class_identity:
  description: "decimal.Context __name__, __module__, __bases__[0].__name__, and __class__.__name__"
  kind: python_call_eq
  category: identity
  id_prefix: cci

  columns: [id, function, args, expected, description]
  rows:
    - [context_name,   Context.__name__.__eq__,                  ["Context"],  true, "decimal.Context.__name__ == 'Context'"]
    - [context_module, Context.__module__.__eq__,                ["decimal"],  true, "decimal.Context.__module__ == 'decimal' (public name, not '_decimal')"]
    - [context_base,   "Context.__bases__[0].__name__.__eq__",   ["object"],   true, "decimal.Context.__bases__[0].__name__ == 'object' — Context is a direct subclass of object"]
    - [context_meta,   Context.__class__.__name__.__eq__,        ["type"],     true, "decimal.Context.__class__.__name__ == 'type' — Context is a plain class"]

# ---------------------------------------------------------------------------
# getcontext() return value — class and default attributes
# ---------------------------------------------------------------------------

invariant decimal_extra272.getcontext.result_class_name:
  description: "decimal.getcontext().__class__.__name__ == 'Context'"
  category: context_instance
  kind: python_call_eq
  function: getcontext
  args: []
  method: __class__.__name__
  expected: "Context"

invariant decimal_extra272.getcontext.default_prec:
  description: "decimal.getcontext().prec == 28 — CPython default arithmetic precision"
  category: context_instance
  kind: python_call_eq
  function: getcontext
  args: []
  method: prec
  expected: 28

invariant decimal_extra272.getcontext.default_rounding:
  description: "decimal.getcontext().rounding == 'ROUND_HALF_EVEN' — CPython default rounding mode"
  category: context_instance
  kind: python_call_eq
  function: getcontext
  args: []
  method: rounding
  expected: "ROUND_HALF_EVEN"

# ---------------------------------------------------------------------------
# Pre-built Context instances — BasicContext and DefaultContext
# ---------------------------------------------------------------------------

invariant decimal_extra272.BasicContext.class_name:
  description: "decimal.BasicContext.__class__.__name__ == 'Context' — BasicContext is an instance, not a class"
  category: context_instance
  kind: python_call_eq
  function: BasicContext.__class__.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra272.BasicContext.prec:
  description: "decimal.BasicContext.prec == 9 — IBM GDAS basic profile precision"
  category: context_instance
  kind: python_call_eq
  function: BasicContext.prec.__eq__
  args: [9]
  expected: true

invariant decimal_extra272.BasicContext.rounding:
  description: "decimal.BasicContext.rounding == 'ROUND_HALF_UP' — IBM GDAS basic profile rounding"
  category: context_instance
  kind: python_call_eq
  function: BasicContext.rounding.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true

invariant decimal_extra272.DefaultContext.class_name:
  description: "decimal.DefaultContext.__class__.__name__ == 'Context' — DefaultContext is an instance"
  category: context_instance
  kind: python_call_eq
  function: DefaultContext.__class__.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra272.DefaultContext.prec:
  description: "decimal.DefaultContext.prec == 28 — CPython default precision matches getcontext().prec"
  category: context_instance
  kind: python_call_eq
  function: DefaultContext.prec.__eq__
  args: [28]
  expected: true
