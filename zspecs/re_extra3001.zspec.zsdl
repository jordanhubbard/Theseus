spec: re3001
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module compiled pattern and match objects"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 647 (re3001): __getitem__, __setitem__, __delitem__ dict-presence checks for re types."
    - "re.Match defines __getitem__ in its own __dict__ (true): m[0] returns the full match, m['name'] accesses named groups."
    - "re.Match does NOT define __setitem__ or __delitem__ — match objects are read-only via subscript."
    - "re.Pattern does not define any item access slots; patterns are not subscriptable."
    - "re.RegexFlag is an IntFlag enum subclass; it does not define item access slots in its own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __getitem__ dict-presence — operator.contains(Cls.__dict__, '__getitem__')
#
# re.Match defines __getitem__ (true) for group access via m[n] / m['name'].
# re.Pattern and re.RegexFlag do not define __getitem__; both false.
# ---------------------------------------------------------------------------

table re3001.getitem:
  description: "re types __getitem__ dict-presence checks; wave 647"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re3001
  columns: [id, function, args, expected]
  rows:
    - ["re3001001", operator.contains, [re.Match.__dict__,     "__getitem__"], true]
    - ["re3001002", operator.contains, [re.Pattern.__dict__,   "__getitem__"], false]
    - ["re3001003", operator.contains, [re.RegexFlag.__dict__, "__getitem__"], false]
    - ["re3001004", operator.contains, [re.Match.__dict__,     "__getitem__"], true]
    - ["re3001005", operator.contains, [re.Pattern.__dict__,   "__getitem__"], false]
    - ["re3001006", operator.contains, [re.RegexFlag.__dict__, "__getitem__"], false]

# ---------------------------------------------------------------------------
# __setitem__ dict-presence — operator.contains(Cls.__dict__, '__setitem__')
#
# Match objects are read-only via subscript; no re type defines __setitem__; all false.
# ---------------------------------------------------------------------------

table re3001.setitem:
  description: "re types __setitem__ dict-presence checks; wave 647"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re3001
