  rows:
    - ["re3001007", operator.contains, [re.Match.__dict__,     "__setitem__"], false]
    - ["re3001008", operator.contains, [re.Pattern.__dict__,   "__setitem__"], false]
    - ["re3001009", operator.contains, [re.RegexFlag.__dict__, "__setitem__"], false]
    - ["re3001010", operator.contains, [re.Match.__dict__,     "__setitem__"], false]
    - ["re3001011", operator.contains, [re.Pattern.__dict__,   "__setitem__"], false]
    - ["re3001012", operator.contains, [re.RegexFlag.__dict__, "__setitem__"], false]

# ---------------------------------------------------------------------------
# __delitem__ dict-presence — operator.contains(Cls.__dict__, '__delitem__')
#
# No re type supports subscript deletion; none define __delitem__; all false.
# ---------------------------------------------------------------------------

table re3001.delitem:
  description: "re types __delitem__ dict-presence checks; wave 647"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re3001
  columns: [id, function, args, expected]
  rows:
    - ["re3001013", operator.contains, [re.Match.__dict__,     "__delitem__"], false]
    - ["re3001014", operator.contains, [re.Pattern.__dict__,   "__delitem__"], false]
    - ["re3001015", operator.contains, [re.RegexFlag.__dict__, "__delitem__"], false]
    - ["re3001016", operator.contains, [re.Match.__dict__,     "__delitem__"], false]
    - ["re3001017", operator.contains, [re.Pattern.__dict__,   "__delitem__"], false]
    - ["re3001018", operator.contains, [re.RegexFlag.__dict__, "__delitem__"], false]

# ---------------------------------------------------------------------------
