spec: posixpath_extra
version: ">=3.0"
backend: python_module(posixpath)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/os.path.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py internals"
  notes:
    - "This spec covers posixpath behaviors not present in posixpath.zspec.zsdl."
    - "posixpath.join.__module__ == 'posixpath' confirms the function is defined in posixpath."
    - "join('/a', 'b', 'c') tests three-component joining with a leading absolute path."
    - "basename('/a/b/c.txt') returns 'c.txt' — the final path component including extension."
    - "dirname('/a/b/c.txt') returns '/a/b' — all components before the final separator."
    - "normpath('/a//b/../c') collapses double slashes and resolves the '..' up-reference to yield '/a/c'."
    - "isabs('/a/b') is True because the path begins with '/'."
    - "isabs('a/b') is False because the path does not begin with '/'."
    - "All expected values verified by running Python 3.14.3 posixpath module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module identity
# ---------------------------------------------------------------------------

invariant posixpath_extra.module.join_module:
  description: "posixpath.join.__module__ == 'posixpath'"
  category: module
  kind: python_call_eq
  function: join.__module__.__eq__
  args: ["posixpath"]
  expected: true

# ---------------------------------------------------------------------------
# Function name checks not in posixpath.zspec.zsdl
# ---------------------------------------------------------------------------

table posixpath_extra.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [join,        join.__name__.__eq__,        ["join"],        true]
    - [split,       split.__name__.__eq__,        ["split"],       true]
    - [basename,    basename.__name__.__eq__,     ["basename"],    true]
    - [dirname,     dirname.__name__.__eq__,      ["dirname"],     true]
    - [normpath,    normpath.__name__.__eq__,     ["normpath"],    true]
    - [abspath,     abspath.__name__.__eq__,      ["abspath"],     true]
    - [expanduser,  expanduser.__name__.__eq__,   ["expanduser"],  true]

# ---------------------------------------------------------------------------
# join — three-component POSIX path joining
# ---------------------------------------------------------------------------

invariant posixpath_extra.join.three_components:
  description: "posixpath.join('/a', 'b', 'c') == '/a/b/c'"
  category: join
  kind: python_call_eq
  function: join
  args: ["/a", "b", "c"]
  expected: "/a/b/c"

# ---------------------------------------------------------------------------
# basename — last component including extension
# ---------------------------------------------------------------------------

invariant posixpath_extra.basename.with_extension:
  description: "posixpath.basename('/a/b/c.txt') == 'c.txt'"
  category: basename
  kind: python_call_eq
  function: basename
  args: ["/a/b/c.txt"]
  expected: "c.txt"

# ---------------------------------------------------------------------------
# dirname — parent directory
# ---------------------------------------------------------------------------

invariant posixpath_extra.dirname.with_extension:
  description: "posixpath.dirname('/a/b/c.txt') == '/a/b'"
  category: dirname
  kind: python_call_eq
  function: dirname
  args: ["/a/b/c.txt"]
  expected: "/a/b"

# ---------------------------------------------------------------------------
# normpath — collapse double slashes and dot-dot
# ---------------------------------------------------------------------------

invariant posixpath_extra.normpath.double_slash_and_dotdot:
  description: "posixpath.normpath('/a//b/../c') == '/a/c'"
  category: normpath
  kind: python_call_eq
  function: normpath
  args: ["/a//b/../c"]
  expected: "/a/c"

# ---------------------------------------------------------------------------
# isabs — absolute vs relative detection
# ---------------------------------------------------------------------------

invariant posixpath_extra.isabs.absolute:
  description: "posixpath.isabs('/a/b') == True — path beginning with '/' is absolute"
  category: isabs
  kind: python_call_eq
  function: isabs
  args: ["/a/b"]
  expected: true

invariant posixpath_extra.isabs.relative:
  description: "posixpath.isabs('a/b') == False — path without leading '/' is relative"
  category: isabs
  kind: python_call_eq
  function: isabs
  args: ["a/b"]
  expected: false
