  id_prefix: cf2476

  columns: [id, function, args, expected]
  rows:
    - ["cf2476012", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__, ["__init__"],      true]
    - ["cf2476013", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__, ["submit"],        true]
    - ["cf2476014", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__, ["BROKEN"],        true]
    - ["cf2476015", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__, ["__contains__"],  false]
    - ["cf2476016", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__, ["__getitem__"],   false]

table concurrent_futures_extra2476.process_pool_dict_contains:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__ checks — defines submit, __init__, shutdown but NOT __contains__ or __getitem__; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: cf2476

  columns: [id, function, args, expected]
  rows:
    - ["cf2476017", concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__init__"],      true]
    - ["cf2476018", concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["submit"],        true]
    - ["cf2476019", concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["shutdown"],      true]
    - ["cf2476020", concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__contains__"],  false]
    - ["cf2476021", concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__getitem__"],   false]

# ---------------------------------------------------------------------------
# __getitem__ on class __dict__ raises KeyError for missing keys
# ---------------------------------------------------------------------------

table concurrent_futures_extra2476.dict_getitem_raises:
  description: "concurrent.futures class __dict__.__getitem__ raises KeyError for absent __contains__ and __getitem__ keys; verified Python 3.14.4"
  kind: python_call_raises
  category: dict_presence
  id_prefix: cf2476

  columns: [id, function, args, raises]
  rows:
    - ["cf2476022", concurrent.futures.Future.__dict__.__getitem__,              ["__contains__"],  KeyError]
    - ["cf2476023", concurrent.futures.Future.__dict__.__getitem__,              ["__getitem__"],   KeyError]
    - ["cf2476024", concurrent.futures.Executor.__dict__.__getitem__,            ["__contains__"],  KeyError]
    - ["cf2476025", concurrent.futures.Executor.__dict__.__getitem__,            ["__getitem__"],   KeyError]
    - ["cf2476026", concurrent.futures.ThreadPoolExecutor.__dict__.__getitem__,  ["__nonexistent__"], KeyError]
    - ["cf2476027", concurrent.futures.ProcessPoolExecutor.__dict__.__getitem__, ["__contains__"],  KeyError]
