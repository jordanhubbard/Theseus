spec: concurrent_futures_extra2476
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Theme: __contains__ and __getitem__ dict-presence — checking whether concurrent.futures classes define membership test and item access protocol in their class __dict__."
    - "concurrent.futures.Future.__dict__.__contains__('__contains__') == False — Future does not define __contains__; verified Python 3.14.4."
    - "concurrent.futures.Future.__dict__.__contains__('__getitem__') == False — Future does not define __getitem__; verified Python 3.14.4."
    - "concurrent.futures.Executor.__dict__.__contains__('__contains__') == False — Executor does not define __contains__; verified Python 3.14.4."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__contains__') == False — ThreadPoolExecutor does not define __contains__; verified Python 3.14.4."
    - "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__contains__') == False — ProcessPoolExecutor does not define __contains__; verified Python 3.14.4."
    - "Accessing a missing key via __dict__.__getitem__ raises KeyError for all concurrent.futures classes; verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures class __dict__ __contains__ checks
#
# None of Future, Executor, ThreadPoolExecutor, or ProcessPoolExecutor define
# __contains__ or __getitem__ in their class __dict__. They define standard
# lifecycle methods: cancel, result, done, submit, shutdown, map.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2476.future_dict_contains:
  description: "concurrent.futures.Future.__dict__.__contains__ checks — Future defines __init__, __repr__, cancel, result, done but NOT __contains__ or __getitem__; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: cf2476

  columns: [id, function, args, expected]
  rows:
    - ["cf2476001", concurrent.futures.Future.__dict__.__contains__, ["__init__"],      true]
    - ["cf2476002", concurrent.futures.Future.__dict__.__contains__, ["__repr__"],      true]
    - ["cf2476003", concurrent.futures.Future.__dict__.__contains__, ["cancel"],        true]
    - ["cf2476004", concurrent.futures.Future.__dict__.__contains__, ["result"],        true]
    - ["cf2476005", concurrent.futures.Future.__dict__.__contains__, ["__contains__"],  false]
    - ["cf2476006", concurrent.futures.Future.__dict__.__contains__, ["__getitem__"],   false]

table concurrent_futures_extra2476.executor_dict_contains:
  description: "concurrent.futures.Executor.__dict__.__contains__ checks — Executor defines submit, map, shutdown but NOT __contains__ or __getitem__; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: cf2476

  columns: [id, function, args, expected]
  rows:
    - ["cf2476007", concurrent.futures.Executor.__dict__.__contains__, ["submit"],       true]
    - ["cf2476008", concurrent.futures.Executor.__dict__.__contains__, ["map"],          true]
    - ["cf2476009", concurrent.futures.Executor.__dict__.__contains__, ["shutdown"],     true]
    - ["cf2476010", concurrent.futures.Executor.__dict__.__contains__, ["__contains__"], false]
    - ["cf2476011", concurrent.futures.Executor.__dict__.__contains__, ["__getitem__"],  false]

table concurrent_futures_extra2476.thread_pool_dict_contains:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__ checks — defines submit, __init__, BROKEN but NOT __contains__ or __getitem__; verified Python 3.14.4"
  kind: python_call_eq
