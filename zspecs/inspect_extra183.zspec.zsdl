spec: inspect_extra183
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.FrameInfo and inspect.getframeinfo function identity — inspect.getframeinfo.__name__=='getframeinfo' (len=12); inspect.getframeinfo.__module__=='inspect'; inspect.getframeinfo.__qualname__=='getframeinfo'; inspect.getouterframes.__name__=='getouterframes' (len=14); inspect.getinnerframes.__name__=='getinnerframes' (len=14); inspect.currentframe.__name__=='currentframe' (len=12); inspect.stack.__name__=='stack' (len=5); inspect.trace.__name__=='trace' (len=5)."
    - "inspect.getframeinfo.__name__ == 'getframeinfo' — getframeinfo is a Python function in Lib/inspect.py that retrieves information about a frame or traceback object, returning a named tuple with filename, lineno, function, code_context, and index; its __name__ is 'getframeinfo', 12 characters. Verified with Python 3.14.3."
    - "inspect.getframeinfo.__module__ == 'inspect' — getframeinfo is defined in the pure-Python inspect module (Lib/inspect.py); its __module__ attribute is 'inspect'. Verified with Python 3.14.3."
    - "inspect.getframeinfo.__qualname__ == 'getframeinfo' — getframeinfo is a module-level Python function (not nested), so its __qualname__ equals its __name__ 'getframeinfo' (12 chars). Verified with Python 3.14.3."
    - "inspect.getouterframes.__name__ == 'getouterframes' — getouterframes is a Python function in Lib/inspect.py that returns a list of FrameInfo named tuples for the frame and all outer frames; its __name__ is 'getouterframes', 14 characters. Verified with Python 3.14.3."
    - "inspect.getinnerframes.__name__ == 'getinnerframes' — getinnerframes is a Python function in Lib/inspect.py that returns a list of FrameInfo named tuples for the traceback and all inner frames; its __name__ is 'getinnerframes', 14 characters. Verified with Python 3.14.3."
    - "inspect.currentframe.__name__ == 'currentframe' — currentframe is a built-in function that returns the frame object for the caller's current stack frame; its __name__ is 'currentframe', 12 characters. Verified with Python 3.14.3."
    - "inspect.stack.__name__ == 'stack' — stack is a Python function in Lib/inspect.py that returns a list of FrameInfo named tuples for the caller's stack (calls getouterframes on the current frame); its __name__ is 'stack', 5 characters. Verified with Python 3.14.3."
    - "inspect.trace.__name__ == 'trace' — trace is a Python function in Lib/inspect.py that returns a list of FrameInfo named tuples for the traceback (calls getinnerframes on the current exception's traceback); its __name__ is 'trace', 5 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getframeinfo __name__, __module__, __qualname__
#
# inspect.getframeinfo.__name__ == 'getframeinfo'
# inspect.getframeinfo.__name__.__len__() == 12
# inspect.getframeinfo.__module__ == 'inspect'
# inspect.getframeinfo.__qualname__ == 'getframeinfo'
#
# inspect.getframeinfo is a Python function in Lib/inspect.py that retrieves
# information about a frame or traceback, returning a Traceback named tuple
# (FrameInfo-compatible) with filename, lineno, function, code_context, index.
# Its __name__ is 'getframeinfo' (12 chars). New to extra183.
# ---------------------------------------------------------------------------

table inspect_extra183.getframeinfo_identity:
  description: "inspect.getframeinfo.__name__ 'getframeinfo' len 12; __module__ 'inspect'; __qualname__ 'getframeinfo' equals __name__; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: inspectframes183

  columns: [id, function, args, expected, description]
  rows:
    - [gfi_name_eq,
       getframeinfo.__name__.__eq__,
       ["getframeinfo"],
       true,
       "inspect.getframeinfo.__name__.__eq__('getframeinfo') == True — getframeinfo is a Python function in Lib/inspect.py that retrieves frame or traceback information, returning a Traceback named tuple with filename, lineno, function, code_context, and index; its __name__ is 'getframeinfo'; str.__eq__('getframeinfo') returns True; new to extra183"]
    - [gfi_name_len_12,
       getframeinfo.__name__.__len__,
       [],
       12,
       "inspect.getframeinfo.__name__.__len__() == 12 — the name 'getframeinfo' has exactly 12 characters: g-e-t-f-r-a-m-e-i-n-f-o; str.__len__() returns 12; new to extra183"]
    - [gfi_module_eq,
       getframeinfo.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getframeinfo.__module__.__eq__('inspect') == True — getframeinfo is defined in the pure-Python inspect module (Lib/inspect.py); its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra183"]
    - [gfi_qualname_eq,
       getframeinfo.__qualname__.__eq__,
       ["getframeinfo"],
       true,
       "inspect.getframeinfo.__qualname__.__eq__('getframeinfo') == True — getframeinfo is a module-level Python function (not nested or a method), so its __qualname__ equals its __name__ 'getframeinfo' (12 chars); str.__eq__('getframeinfo') returns True; new to extra183"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getouterframes and inspect.getinnerframes __name__
#
# inspect.getouterframes.__name__ == 'getouterframes'
# inspect.getouterframes.__name__.__len__() == 14
# inspect.getinnerframes.__name__ == 'getinnerframes'
# inspect.getinnerframes.__name__.__len__() == 14
#
# getouterframes returns FrameInfo tuples for a frame and all its outer frames.
# getinnerframes returns FrameInfo tuples for a traceback and all inner frames.
# Both have __name__ of 14 characters. New to extra183.
# ---------------------------------------------------------------------------

table inspect_extra183.outer_and_inner_frames_identity:
  description: "inspect.getouterframes.__name__ 'getouterframes' len 14; inspect.getinnerframes.__name__ 'getinnerframes' len 14; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: inspectframes183

  columns: [id, function, args, expected, description]
  rows:
    - [gouter_name_eq,
       getouterframes.__name__.__eq__,
       ["getouterframes"],
       true,
       "inspect.getouterframes.__name__.__eq__('getouterframes') == True — getouterframes is a Python function in Lib/inspect.py that returns a list of FrameInfo named tuples for a frame and all outer (caller) frames in the call stack; its __name__ is 'getouterframes'; str.__eq__('getouterframes') returns True; new to extra183"]
    - [gouter_name_len_14,
       getouterframes.__name__.__len__,
       [],
       14,
       "inspect.getouterframes.__name__.__len__() == 14 — the name 'getouterframes' has exactly 14 characters: g-e-t-o-u-t-e-r-f-r-a-m-e-s; str.__len__() returns 14; new to extra183"]
    - [ginner_name_eq,
       getinnerframes.__name__.__eq__,
       ["getinnerframes"],
       true,
       "inspect.getinnerframes.__name__.__eq__('getinnerframes') == True — getinnerframes is a Python function in Lib/inspect.py that returns a list of FrameInfo named tuples for a traceback and all inner frames; its __name__ is 'getinnerframes'; str.__eq__('getinnerframes') returns True; new to extra183"]
    - [ginner_name_len_14,
       getinnerframes.__name__.__len__,
       [],
       14,
       "inspect.getinnerframes.__name__.__len__() == 14 — the name 'getinnerframes' has exactly 14 characters: g-e-t-i-n-n-e-r-f-r-a-m-e-s; str.__len__() returns 14; same length as 'getouterframes'; new to extra183"]

# ---------------------------------------------------------------------------
# Table 3: inspect.currentframe, inspect.stack, and inspect.trace __name__
#
# inspect.currentframe.__name__ == 'currentframe'
# inspect.currentframe.__name__.__len__() == 12
# inspect.stack.__name__ == 'stack'
# inspect.stack.__name__.__len__() == 5
# inspect.trace.__name__ == 'trace'
# inspect.trace.__name__.__len__() == 5
#
# currentframe is a builtin function returning the caller's frame object.
# stack and trace are Python functions in Lib/inspect.py that wrap
# getouterframes and getinnerframes respectively. New to extra183.
# ---------------------------------------------------------------------------

table inspect_extra183.currentframe_stack_trace_identity:
  description: "inspect.currentframe.__name__ 'currentframe' len 12; inspect.stack.__name__ 'stack' len 5; inspect.trace.__name__ 'trace' len 5; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: inspectframes183

  columns: [id, function, args, expected, description]
  rows:
    - [curframe_name_eq,
       currentframe.__name__.__eq__,
       ["currentframe"],
       true,
       "inspect.currentframe.__name__.__eq__('currentframe') == True — currentframe is a built-in function (from sys module, re-exported by inspect) that returns the frame object for the caller's current execution frame; its __name__ is 'currentframe'; str.__eq__('currentframe') returns True; new to extra183"]
    - [curframe_name_len_12,
       currentframe.__name__.__len__,
       [],
       12,
       "inspect.currentframe.__name__.__len__() == 12 — the name 'currentframe' has exactly 12 characters: c-u-r-r-e-n-t-f-r-a-m-e; str.__len__() returns 12; same length as 'getframeinfo'; new to extra183"]
    - [stack_name_eq,
       stack.__name__.__eq__,
       ["stack"],
       true,
       "inspect.stack.__name__.__eq__('stack') == True — stack is a Python function in Lib/inspect.py that returns a list of FrameInfo named tuples for the caller's call stack by calling getouterframes(currentframe()); its __name__ is 'stack'; str.__eq__('stack') returns True; new to extra183"]
    - [stack_name_len_5,
       stack.__name__.__len__,
       [],
       5,
       "inspect.stack.__name__.__len__() == 5 — the name 'stack' has exactly 5 characters: s-t-a-c-k; str.__len__() returns 5; same length as inspect.trace.__name__; new to extra183"]
    - [trace_name_eq,
       trace.__name__.__eq__,
       ["trace"],
       true,
       "inspect.trace.__name__.__eq__('trace') == True — trace is a Python function in Lib/inspect.py that returns a list of FrameInfo named tuples for the current exception's traceback by calling getinnerframes(sys.exc_info()[2]); its __name__ is 'trace'; str.__eq__('trace') returns True; new to extra183"]
    - [trace_name_len_5,
       trace.__name__.__len__,
       [],
       5,
       "inspect.trace.__name__.__len__() == 5 — the name 'trace' has exactly 5 characters: t-r-a-c-e; str.__len__() returns 5; same length as inspect.stack.__name__; new to extra183"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra183
# ---------------------------------------------------------------------------

invariant inspect_extra183.getframeinfo_name_is_getframeinfo:
  description: "inspect.getframeinfo.__name__ == 'getframeinfo' — Python function in Lib/inspect.py retrieving frame or traceback info; __name__ is 'getframeinfo' (12 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: getframeinfo.__name__.__eq__
  args: ["getframeinfo"]
  expected: true

invariant inspect_extra183.getframeinfo_module_is_inspect:
  description: "inspect.getframeinfo.__module__ == 'inspect' — getframeinfo is defined in the pure-Python inspect module Lib/inspect.py; its __module__ is 'inspect'; new to extra183"
  category: identity
  kind: python_call_eq
  function: getframeinfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra183.getframeinfo_qualname_equals_name:
  description: "inspect.getframeinfo.__qualname__ == 'getframeinfo' — module-level Python function has __qualname__ == __name__ == 'getframeinfo' (12 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: getframeinfo.__qualname__.__eq__
  args: ["getframeinfo"]
  expected: true

invariant inspect_extra183.getouterframes_name_is_getouterframes:
  description: "inspect.getouterframes.__name__ == 'getouterframes' — Python function returning FrameInfo tuples for a frame and all outer caller frames; __name__ is 'getouterframes' (14 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: getouterframes.__name__.__eq__
  args: ["getouterframes"]
  expected: true

invariant inspect_extra183.getinnerframes_name_is_getinnerframes:
  description: "inspect.getinnerframes.__name__ == 'getinnerframes' — Python function returning FrameInfo tuples for a traceback and all inner frames; __name__ is 'getinnerframes' (14 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: getinnerframes.__name__.__eq__
  args: ["getinnerframes"]
  expected: true

invariant inspect_extra183.currentframe_name_is_currentframe:
  description: "inspect.currentframe.__name__ == 'currentframe' — built-in function returning the caller's current stack frame object; __name__ is 'currentframe' (12 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: currentframe.__name__.__eq__
  args: ["currentframe"]
  expected: true

invariant inspect_extra183.stack_name_is_stack:
  description: "inspect.stack.__name__ == 'stack' — Python function in Lib/inspect.py wrapping getouterframes(currentframe()); __name__ is 'stack' (5 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: stack.__name__.__eq__
  args: ["stack"]
  expected: true

invariant inspect_extra183.trace_name_is_trace:
  description: "inspect.trace.__name__ == 'trace' — Python function in Lib/inspect.py wrapping getinnerframes on the current exception traceback; __name__ is 'trace' (5 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: trace.__name__.__eq__
  args: ["trace"]
  expected: true
