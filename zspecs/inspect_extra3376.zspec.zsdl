spec: in3376
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 672 (in3376): __trunc__, __round__, __index__ dict-presence checks for inspect types."
    - "Theme: __trunc__/__round__/__index__ dict-presence (math.trunc(x), round(x), operator.index(x))."
    - "All values False — inspect introspection types have no numeric protocol support."
    - "No inspect type defines __trunc__, __round__, or __index__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "None of these types implement truncation, rounding, or integer-index conversion protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3376.trunc:
  description: "inspect types __trunc__ dict-presence checks; wave 672"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3376
  columns: [id, function, args, expected]
  rows:
    - ["in3376001", operator.contains, [inspect.Parameter.__dict__,           "__trunc__"], false]
    - ["in3376002", operator.contains, [inspect.Signature.__dict__,           "__trunc__"], false]
    - ["in3376003", operator.contains, [inspect.BoundArguments.__dict__,      "__trunc__"], false]
    - ["in3376004", operator.contains, [inspect.FrameInfo.__dict__,           "__trunc__"], false]
    - ["in3376005", operator.contains, [inspect.ArgInfo.__dict__,             "__trunc__"], false]
    - ["in3376006", operator.contains, [inspect.FullArgSpec.__dict__,         "__trunc__"], false]
    - ["in3376007", operator.contains, [inspect.Attribute.__dict__,           "__trunc__"], false]
    - ["in3376008", operator.contains, [inspect.ClassFoundException.__dict__, "__trunc__"], false]
    - ["in3376009", operator.contains, [inspect.EndOfBlock.__dict__,          "__trunc__"], false]

