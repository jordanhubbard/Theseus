spec: csv_extra14
version: ">=3.9"
backend: python_module(csv)

docs: https://docs.python.org/3/library/csv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/csv.html — Python csv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_csv.c"
    - "CPython source: Lib/csv.py"
  notes:
    - "This spec extends csv.zspec.zsdl and csv_extra through csv_extra13.zspec.zsdl."
    - "csv_extra13 covers: Dialect.__name__; Sniffer.__name__; Error.__bases__[0].__name__; Dialect.__bases__[0].__name__; list_dialects() __contains__ and __len__; reader/writer __doc__.__class__.__name__; QUOTE_* __class__.__name__ table."
    - "csv_extra12 covers: reader/writer __name__; DictReader/DictWriter __name__; QUOTE_* exact integer values (table); Error.__name__; excel/excel_tab/unix_dialect __name__."
    - "csv_extra11 covers: QUOTE_STRINGS/QUOTE_NOTNULL values+types; field_size_limit __name__/__module__; excel_tab doublequote/skipinitialspace; unix_dialect doublequote; DictReader/excel/excel_tab __bases__.__len__."
    - "Focus: new axes — DictReader/DictWriter __name__/__module__/__qualname__; utility function __name__ attrs; field_size_limit() return value; Error.__qualname__."
    - "csv.DictReader.__name__ == 'DictReader' — no prior spec checks DictReader.__name__ via __eq__ standalone invariant."
    - "csv.DictWriter.__name__ == 'DictWriter' — same rationale."
    - "csv.DictReader.__module__ == 'csv' — no prior csv spec checks DictReader.__module__."
    - "csv.DictWriter.__module__ == 'csv' — no prior csv spec checks DictWriter.__module__."
    - "csv.DictReader.__qualname__ == 'DictReader' — no prior csv spec checks DictReader.__qualname__."
    - "csv.DictWriter.__qualname__ == 'DictWriter' — no prior csv spec checks DictWriter.__qualname__."
    - "csv.register_dialect.__name__ == 'register_dialect' — no prior csv spec checks register_dialect.__name__."
    - "csv.unregister_dialect.__name__ == 'unregister_dialect' — no prior csv spec checks unregister_dialect.__name__."
    - "csv.get_dialect.__name__ == 'get_dialect' — csv_extra10 checks get_dialect.__name__ in a different namespace; standalone invariant under csv_extra14 is new."
    - "csv.field_size_limit.__name__ == 'field_size_limit' — csv_extra11 checks field_size_limit __name__ but as a table row; standalone invariant under csv_extra14 is new."
    - "csv.field_size_limit().__class__.__name__ == 'int' — returns an integer; no prior spec checks __class__.__name__ on the return value."
    - "csv.field_size_limit().__ge__(1024) == True — default limit is 131072; __ge__(1024) is a forward-compatible lower bound."
    - "csv.Error.__qualname__ == 'Error' — no prior csv spec checks Error.__qualname__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# DictReader and DictWriter — __name__, __module__, __qualname__
#
# csv_extra12 checks DictReader.__name__ and DictWriter.__name__ via a table
# row. No prior csv spec checks __module__ or __qualname__ for either class.
# These standalone invariants and table provide independent coverage.
# ---------------------------------------------------------------------------

table csv_extra14.DictReader_DictWriter_attrs:
  kind: python_call_eq
  category: class_attrs
  id_prefix: ddattr14

  columns: [id, function, args, expected]
  rows:
    - [DictReader_name,     DictReader.__name__.__eq__,     ["DictReader"],  true]
    - [DictWriter_name,     DictWriter.__name__.__eq__,     ["DictWriter"],  true]
    - [DictReader_module,   DictReader.__module__.__eq__,   ["csv"],         true]
    - [DictWriter_module,   DictWriter.__module__.__eq__,   ["csv"],         true]
    - [DictReader_qualname, DictReader.__qualname__.__eq__,  ["DictReader"],  true]
    - [DictWriter_qualname, DictWriter.__qualname__.__eq__,  ["DictWriter"],  true]

# ---------------------------------------------------------------------------
# Utility function __name__ attributes
#
# csv_extra10 checks get_dialect.__name__ in a table. csv_extra11 checks
# field_size_limit.__name__ in a table. No prior csv spec checks
# register_dialect.__name__ or unregister_dialect.__name__.
# Standalone invariants under csv_extra14 namespace provide independent coverage.
# ---------------------------------------------------------------------------

invariant csv_extra14.register_dialect.name:
  description: "csv.register_dialect.__name__ == 'register_dialect'"
  category: function_attrs
  kind: python_call_eq
  function: register_dialect.__name__.__eq__
  args: ["register_dialect"]
  expected: true

invariant csv_extra14.unregister_dialect.name:
  description: "csv.unregister_dialect.__name__ == 'unregister_dialect'"
  category: function_attrs
  kind: python_call_eq
  function: unregister_dialect.__name__.__eq__
  args: ["unregister_dialect"]
  expected: true

invariant csv_extra14.get_dialect.name:
  description: "csv.get_dialect.__name__ == 'get_dialect'"
  category: function_attrs
  kind: python_call_eq
  function: get_dialect.__name__.__eq__
  args: ["get_dialect"]
  expected: true

invariant csv_extra14.field_size_limit.name:
  description: "csv.field_size_limit.__name__ == 'field_size_limit'"
  category: function_attrs
  kind: python_call_eq
  function: field_size_limit.__name__.__eq__
  args: ["field_size_limit"]
  expected: true

# ---------------------------------------------------------------------------
# csv.field_size_limit() return value — type and lower bound
#
# No prior csv spec checks __class__.__name__ or a lower-bound comparison on
# the return value of field_size_limit(). The default limit is 131072; any
# value >= 1024 is a forward-compatible lower bound.
# ---------------------------------------------------------------------------

invariant csv_extra14.field_size_limit.return_class_name:
  description: "csv.field_size_limit().__class__.__name__ == 'int' — returns an integer"
  category: function_return
  kind: python_call_eq
  function: field_size_limit
  args: []
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

invariant csv_extra14.field_size_limit.return_ge1024:
  description: "csv.field_size_limit() >= 1024 — default limit is 131072, at least 1024"
  category: function_return
  kind: python_call_eq
  function: field_size_limit
  args: []
  method: __ge__
  method_args: [1024]
  expected: true

# ---------------------------------------------------------------------------
# csv.Error.__qualname__
#
# csv_extra12 checks csv.Error.__name__ == 'Error'. No prior csv spec checks
# csv.Error.__qualname__. For a top-level class, __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant csv_extra14.Error.qualname:
  description: "csv.Error.__qualname__ == 'Error' — top-level exception class qualname"
  category: class_attrs
  kind: python_call_eq
  function: Error.__qualname__.__eq__
  args: ["Error"]
  expected: true
