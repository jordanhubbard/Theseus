spec: threading_extra145
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Thread.is_alive (Python method) — qualname len 15, co_argcount 1, doc len 187; threading.Thread.daemon (property) — __class__.__name__ 'property', fget qualname len 13; threading.enumerate (Python function) — qualname len 9, doc len 237, co_argcount 0; threading.current_thread (Python function) — qualname len 14, doc len 227, co_argcount 0; threading.main_thread (Python function) — qualname len 11, doc len 131, co_argcount 0; threading.active_count (Python function) — qualname len 12, doc len 134, co_argcount 0 (Wave 272)."
    - "threading.Thread.is_alive: __qualname__ == 'Thread.is_alive' (len 15); __code__.co_argcount == 1; __doc__ len == 187. Verified with Python 3.14.3."
    - "threading.Thread.daemon: __class__.__name__ == 'property'; fget.__qualname__ == 'Thread.daemon' (len 13). Verified with Python 3.14.3."
    - "threading.enumerate: __qualname__ == 'enumerate' (len 9); __module__ == 'threading'; __doc__ len == 237; co_argcount == 0. Verified with Python 3.14.3."
    - "threading.current_thread: __qualname__ == 'current_thread' (len 14); __module__ == 'threading'; __doc__ len == 227; co_argcount == 0. Verified with Python 3.14.3."
    - "threading.main_thread: __qualname__ == 'main_thread' (len 11); __module__ == 'threading'; __doc__ len == 131; co_argcount == 0. Verified with Python 3.14.3."
    - "threading.active_count: __qualname__ == 'active_count' (len 12); __module__ == 'threading'; __doc__ len == 134; co_argcount == 0. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread.is_alive and threading.Thread.daemon — method attrs
#
# Wave 272 theme: threading.Thread lifecycle method (is_alive) and daemon
# property — lesser-visited Thread attributes.
#
# threading.Thread.is_alive.__qualname__ == 'Thread.is_alive' (len 15)
# threading.Thread.is_alive.__code__.co_argcount == 1
# len(threading.Thread.is_alive.__doc__) == 187
# threading.Thread.daemon.__class__.__name__ == 'property'
# threading.Thread.daemon.fget.__qualname__ == 'Thread.daemon' (len 13)
#
# is_alive() returns True if the thread is alive; daemon is a boolean property
# indicating whether the thread is a daemon thread. New to extra145.
# ---------------------------------------------------------------------------

