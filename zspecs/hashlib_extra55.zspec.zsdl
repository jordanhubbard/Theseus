spec: hashlib_extra55
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra54.zspec.zsdl — covers algorithms_available/__guaranteed__ __class__.__name__/__qualname__/__module__; algorithms_guaranteed.__contains__ for sha256/md5/sha1/sha512."
    - "hashlib_extra53.zspec.zsdl — covers sha256/md5/sha1/sha3_256/blake2b/new/pbkdf2_hmac __module__.__class__.__name__/__qualname__ and __module__.__len__()."
    - "hashlib_extra52.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __doc__.__class__.__name__/__qualname__.__eq__('str')."
    - "hashlib_extra51.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __name__.__class__.__name__.__eq__('str')."
    - "hashlib_extra18.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/new __name__/__qualname__ string values."
    - "hashlib_extra6.zspec.zsdl — covers sha256/md5/sha1/sha384/sha512/pbkdf2_hmac/sha3_256/blake2b/blake2s/scrypt __module__.__eq__ string values."
    - "hashlib_extra50.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __class__.__qualname__/__module__ equality."
  notes:
    - "This spec extends hashlib through hashlib_extra54; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: hashlib_extra54 covers algorithms_guaranteed.__contains__ for sha256/md5/sha1/sha512. No prior hashlib spec checks __contains__ for sha224, sha384, blake2b, blake2s, sha3_256, or sha3_512. All six are members of hashlib.algorithms_guaranteed on any conforming CPython platform per PEP 247 and the hashlib documentation. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha224') == True. sha224 (SHA-2 224-bit) is guaranteed on all CPython platforms. No prior spec checks sha224 membership in algorithms_guaranteed. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha384') == True. sha384 (SHA-2 384-bit) is guaranteed on all CPython platforms. No prior spec checks sha384 membership in algorithms_guaranteed. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('blake2b') == True. blake2b is guaranteed on all CPython platforms. No prior spec checks blake2b membership in algorithms_guaranteed. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('blake2s') == True. blake2s is guaranteed on all CPython platforms. No prior spec checks blake2s membership in algorithms_guaranteed. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_256') == True. sha3_256 is guaranteed on all CPython platforms. No prior spec checks sha3_256 membership in algorithms_guaranteed. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__contains__('sha3_512') == True. sha3_512 is guaranteed on all CPython platforms. No prior spec checks sha3_512 membership in algorithms_guaranteed. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior hashlib spec checks the __len__ of the __class__.__module__ string for algorithms_available or algorithms_guaranteed. hashlib_extra54 checks __class__.__module__.__eq__('builtins') (the value axis). The length of 'builtins' is 8. __class__.__module__.__len__() is a distinct regression vector — if the builtins module were renamed, the length would change. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__module__.__len__() == 8. len('builtins') == 8. hashlib_extra54 checks __eq__('builtins') but not __len__(). No prior spec checks __class__.__module__.__len__() for algorithms_available. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__module__.__len__() == 8. len('builtins') == 8. hashlib_extra54 checks __eq__('builtins') but not __len__(). No prior spec checks __class__.__module__.__len__() for algorithms_guaranteed. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior hashlib spec checks the module-level __name__ attribute of the hashlib module itself. hashlib_extra18 covers sha256/md5/sha1 constructor __name__ string values (the function __name__ axis), and hashlib_extra51 covers the TYPE of those __name__ attributes. But the module's own __name__ — accessed as hashlib.__name__ from outside, or simply __name__ in the module namespace — has never been checked. Under the python_module(hashlib) backend, function: __name__.__eq__ resolves to hashlib.__name__.__eq__('hashlib'). The module __name__ is a distinct object from any function __name__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.__name__ == 'hashlib'. The module's own __name__ attribute. No prior hashlib spec checks this via a string eq invariant. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.__name__.__len__() == 7. len('hashlib') == 7. Independent length regression vector for the module __name__ string. No prior spec checks this length. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_guaranteed.__contains__ for additional algorithms
#
# hashlib_extra54 covers __contains__ for sha256/md5/sha1/sha512.
# No prior hashlib spec checks __contains__ for sha224, sha384, blake2b,
# blake2s, sha3_256, or sha3_512. All six are guaranteed on every conforming
# CPython platform. This table extends membership coverage to the remaining
# commonly-used guaranteed algorithms.
# ---------------------------------------------------------------------------

table hashlib_extra55.algorithms_guaranteed_contains_extended:
  description: "hashlib.algorithms_guaranteed.__contains__ for sha224/sha384/blake2b/blake2s/sha3_256/sha3_512 == True — all six are guaranteed algorithms; extra54 covers sha256/md5/sha1/sha512; this table extends coverage to the remaining commonly-used guaranteed members"
  kind: python_call_eq
  category: algorithm_membership
  id_prefix: hashlibsets55

  columns: [id, function, args, expected]
  rows:
    - [guaranteed_contains_sha224,   algorithms_guaranteed.__contains__, ["sha224"],   true]
    - [guaranteed_contains_sha384,   algorithms_guaranteed.__contains__, ["sha384"],   true]
    - [guaranteed_contains_blake2b,  algorithms_guaranteed.__contains__, ["blake2b"],  true]
    - [guaranteed_contains_blake2s,  algorithms_guaranteed.__contains__, ["blake2s"],  true]
    - [guaranteed_contains_sha3_256, algorithms_guaranteed.__contains__, ["sha3_256"], true]
    - [guaranteed_contains_sha3_512, algorithms_guaranteed.__contains__, ["sha3_512"], true]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available / algorithms_guaranteed __class__.__module__.__len__
#
# hashlib_extra54 checks __class__.__module__.__eq__('builtins') for both
# attributes (value axis). No prior hashlib spec checks __class__.__module__.__len__()
# for either attribute. The __class__.__module__ of set and frozenset is
# 'builtins' (8 chars). This provides an independent length regression vector:
# if the builtins module were renamed, both the __eq__ and __len__ checks
# would detect the change, but the __len__ axis catches partial renames.
# ---------------------------------------------------------------------------

table hashlib_extra55.algorithms_class_module_lengths:
  description: "hashlib.algorithms_available/__class__/__module__.__len__()==8 and algorithms_guaranteed/__class__/__module__.__len__()==8 — len('builtins')==8; extra54 checks __class__.__module__.__eq__('builtins') (value axis); no prior spec checks __class__.__module__.__len__() for algorithms_available or algorithms_guaranteed"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibsets55

  columns: [id, function, args, expected]
  rows:
    - [algorithms_available_class_module_len,  algorithms_available.__class__.__module__.__len__,  [], 8]
    - [algorithms_guaranteed_class_module_len, algorithms_guaranteed.__class__.__module__.__len__, [], 8]

# ---------------------------------------------------------------------------
# hashlib module-level __name__ attribute
#
# No prior hashlib spec checks the module's own __name__ attribute.
# hashlib_extra18 covers function __name__ string values (sha256.__name__, etc.).
# hashlib_extra51 covers the TYPE of function __name__ attributes.
# But the module object's own __name__ — hashlib.__name__ == 'hashlib' —
# has never been checked. Under python_module(hashlib), function: __name__.__eq__
# resolves to hashlib.__name__.__eq__('hashlib'). The __len__ check provides
# an independent length regression vector.
# ---------------------------------------------------------------------------

invariant hashlib_extra55.module.name_eq:
  description: "hashlib.__name__ == 'hashlib' — the module's own __name__ attribute; no prior hashlib spec checks the module object's __name__.__eq__ value; distinct from any function or class __name__ attribute"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["hashlib"]
  expected: true

invariant hashlib_extra55.module.name_len:
  description: "hashlib.__name__.__len__() == 7 — len('hashlib') == 7; independent length regression vector complementing the __eq__ check above; no prior spec checks __name__.__len__() for the hashlib module object"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 7
