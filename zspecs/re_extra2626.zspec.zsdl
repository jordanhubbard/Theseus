spec: re_extra2626
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
    - "re_extra2611.zspec.zsdl — covers __init_subclass__/__subclasshook__/__class_getitem__ dict-presence"
  notes:
    - "Wave 622 (re_extra2626) theme: __length_hint__, __missing__, and __reversed__ dict-presence checks."
    - "Neither re.Pattern nor re.Match defines __length_hint__, __missing__, or __reversed__ in its own __dict__."
    - "__length_hint__ is a sized-iterator protocol; regex objects are not iterators."
    - "__missing__ is a dict subclass hook; re.Pattern and re.Match are C extension types, not dict subclasses."
    - "__reversed__ is a reverse-iteration protocol; regex compiled patterns and match objects do not support reverse iteration."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2626.no_length_hint_in_re_classes:
  description: "__length_hint__ is absent from re.Pattern and re.Match __dict__s — regex objects are not sized iterators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2626

  columns: [id, function, args, expected]
  rows:
    - ["re2626001", "re.Pattern.__dict__.__contains__", ["__length_hint__"], false]
    - ["re2626002", "re.Match.__dict__.__contains__",   ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# __missing__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2626.no_missing_in_re_classes:
  description: "__missing__ is absent from re.Pattern and re.Match __dict__s — regex classes are not dict subclasses"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2626

  columns: [id, function, args, expected]
  rows:
    - ["re2626003", "re.Pattern.__dict__.__contains__", ["__missing__"], false]
    - ["re2626004", "re.Match.__dict__.__contains__",   ["__missing__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2626.no_reversed_in_re_classes:
  description: "__reversed__ is absent from re.Pattern and re.Match __dict__s — regex objects do not support reverse iteration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2626

  columns: [id, function, args, expected]
  rows:
    - ["re2626005", "re.Pattern.__dict__.__contains__", ["__reversed__"], false]
    - ["re2626006", "re.Match.__dict__.__contains__",   ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern and re.Match HAVE regex methods but NOT container/iterator protocol methods
# Confirms the absence of container hooks while retaining the __class_getitem__ established in wave 621
# ---------------------------------------------------------------------------

table re_extra2626.re_has_regex_methods_not_container_hooks:
  description: "re.Pattern defines match/search/findall/sub but NOT __length_hint__/__missing__/__reversed__; re.Match defines group/groups/start/end similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2626

  columns: [id, function, args, expected]
  rows:
    - ["re2626007", "re.Pattern.__dict__.__contains__", ["match"],           true]
    - ["re2626008", "re.Pattern.__dict__.__contains__", ["search"],          true]
    - ["re2626009", "re.Pattern.__dict__.__contains__", ["findall"],         true]
    - ["re2626010", "re.Pattern.__dict__.__contains__", ["sub"],             true]
    - ["re2626011", "re.Pattern.__dict__.__contains__", ["__length_hint__"], false]
    - ["re2626012", "re.Pattern.__dict__.__contains__", ["__missing__"],     false]
    - ["re2626013", "re.Pattern.__dict__.__contains__", ["__reversed__"],    false]
    - ["re2626014", "re.Match.__dict__.__contains__",   ["group"],           true]
    - ["re2626015", "re.Match.__dict__.__contains__",   ["groups"],          true]
    - ["re2626016", "re.Match.__dict__.__contains__",   ["start"],           true]
    - ["re2626017", "re.Match.__dict__.__contains__",   ["end"],             true]
    - ["re2626018", "re.Match.__dict__.__contains__",   ["__length_hint__"], false]
    - ["re2626019", "re.Match.__dict__.__contains__",   ["__missing__"],     false]
    - ["re2626020", "re.Match.__dict__.__contains__",   ["__reversed__"],    false]
