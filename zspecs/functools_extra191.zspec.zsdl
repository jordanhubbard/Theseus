spec: functools_extra191
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.partial instance attribute names via class descriptors — functools.partial.func is a member_descriptor (not getset_descriptor); functools.partial.args is a member_descriptor; functools.partial.keywords is a member_descriptor; functools.partial.__doc__ is a str; functools.partial.__class__.__name__ is 'type'; functools.partialmethod.__doc__ is a str; functools.partial.__module__ == 'functools'; functools.partialmethod.__module__ == 'functools'."
    - "functools.partial.func.__class__.__name__ == 'member_descriptor' — the .func slot on the partial class is exposed as a member_descriptor (not a getset_descriptor); verified with Python 3.14.3 on macOS/Darwin 25.4.0."
    - "functools.partial.args.__class__.__name__ == 'member_descriptor' — the .args slot on the partial class is exposed as a member_descriptor; verified with Python 3.14.3."
    - "functools.partial.keywords.__class__.__name__ == 'member_descriptor' — the .keywords slot on the partial class is exposed as a member_descriptor; verified with Python 3.14.3."
    - "functools.partial.__doc__.__class__.__name__ == 'str' — the class docstring is a plain Python str; verified with Python 3.14.3."
    - "functools.partial.__class__.__name__ == 'type' — partial is a class, so its metaclass is 'type'; verified with Python 3.14.3."
    - "functools.partialmethod.__doc__.__class__.__name__ == 'str' — partialmethod's class docstring is a plain Python str; verified with Python 3.14.3."
    - "functools.partial.__module__.__eq__('functools') == True — partial reports __module__=='functools' (not '_functools'); verified with Python 3.14.3."
    - "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod reports __module__=='functools'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial slot descriptor class names (func, args, keywords)
#
# functools.partial.func.__class__.__name__ == 'member_descriptor'
# functools.partial.args.__class__.__name__ == 'member_descriptor'
# functools.partial.keywords.__class__.__name__ == 'member_descriptor'
#
# The .func, .args, and .keywords attributes of the functools.partial class are
# implemented as C-level slot members, exposed to Python as member_descriptor
# objects (not getset_descriptor). This is the actual type in Python 3.14.3.
# New to extra191.
# ---------------------------------------------------------------------------

table functools_extra191.partial_slot_descriptor_types:
  description: "functools.partial.func/args/keywords are member_descriptor objects (not getset_descriptor); each slot's __class__.__name__ == 'member_descriptor'; new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: functpartialattrs191

  columns: [id, function, args, expected, description]
  rows:
    - [func_descriptor_class_eq,
       partial.func.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.func.__class__.__name__.__eq__('member_descriptor') == True — the .func slot on functools.partial is a C member slot, exposed as a member_descriptor (not getset_descriptor); verified with Python 3.14.3; new to extra191"]
    - [args_descriptor_class_eq,
       partial.args.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.args.__class__.__name__.__eq__('member_descriptor') == True — the .args slot on functools.partial is a C member slot, exposed as a member_descriptor; verified with Python 3.14.3; new to extra191"]
    - [keywords_descriptor_class_eq,
       partial.keywords.__class__.__name__.__eq__,
       ["member_descriptor"],
       true,
       "functools.partial.keywords.__class__.__name__.__eq__('member_descriptor') == True — the .keywords slot on functools.partial is a C member slot, exposed as a member_descriptor; verified with Python 3.14.3; new to extra191"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial and functools.partialmethod __doc__ and __class__
#
# functools.partial.__doc__.__class__.__name__ == 'str'
# functools.partial.__class__.__name__ == 'type'
# functools.partialmethod.__doc__.__class__.__name__ == 'str'
# functools.partialmethod.__class__.__name__ == 'type'
#
# Both partial and partialmethod are classes (metaclass is 'type'), and their
# class-level docstrings are plain Python str objects. New to extra191.
# ---------------------------------------------------------------------------

table functools_extra191.partial_and_partialmethod_doc_and_class:
  description: "functools.partial.__doc__ is str; partial.__class__.__name__=='type'; partialmethod.__doc__ is str; partialmethod.__class__.__name__=='type'; new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: functpartialattrs191

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_class_eq,
       partial.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — the docstring of the partial class is a plain Python str; __doc__ is set at class definition time; str.__eq__('str') returns True; new to extra191"]
    - [partial_class_name_eq,
       partial.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a class whose metaclass is the built-in 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra191"]
    - [partialmethod_doc_class_eq,
       partialmethod.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partialmethod.__doc__.__class__.__name__.__eq__('str') == True — the docstring of the partialmethod class is a plain Python str; str.__eq__('str') returns True; new to extra191"]
    - [partialmethod_class_name_eq,
       partialmethod.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partialmethod.__class__.__name__.__eq__('type') == True — partialmethod is a class whose metaclass is the built-in 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra191"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial and functools.partialmethod __module__
#
# functools.partial.__module__ == 'functools'
# functools.partialmethod.__module__ == 'functools'
#
# Both classes report __module__=='functools' (not '_functools' which is used
# by the C-level builtins cmp_to_key and reduce). New to extra191.
# ---------------------------------------------------------------------------

table functools_extra191.partial_and_partialmethod_module:
  description: "functools.partial.__module__=='functools' and functools.partialmethod.__module__=='functools'; not '_functools'; new to extra191"
  kind: python_call_eq
  category: identity
  id_prefix: functpartialattrs191

  columns: [id, function, args, expected, description]
  rows:
    - [partial_module_eq,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial reports __module__=='functools' (not '_functools'); str.__eq__('functools') returns True; new to extra191"]
    - [partialmethod_module_eq,
       partialmethod.__module__.__eq__,
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod reports __module__=='functools'; str.__eq__('functools') returns True; new to extra191"]
    - [partial_module_len_9,
       partial.__module__.__len__,
       [],
       9,
       "functools.partial.__module__.__len__() == 9 — the module name 'functools' has exactly 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; new to extra191"]
    - [partialmethod_module_len_9,
       partialmethod.__module__.__len__,
       [],
       9,
       "functools.partialmethod.__module__.__len__() == 9 — the module name 'functools' has exactly 9 characters; str.__len__() returns 9; new to extra191"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra191
# ---------------------------------------------------------------------------

invariant functools_extra191.partial_func_is_member_descriptor:
  description: "functools.partial.func.__class__.__name__ == 'member_descriptor' — the .func slot attribute on the partial class is a C member slot exposed as member_descriptor (not getset_descriptor); verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: partial.func.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra191.partial_args_is_member_descriptor:
  description: "functools.partial.args.__class__.__name__ == 'member_descriptor' — the .args slot attribute on the partial class is a C member slot exposed as member_descriptor; verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: partial.args.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra191.partial_keywords_is_member_descriptor:
  description: "functools.partial.keywords.__class__.__name__ == 'member_descriptor' — the .keywords slot attribute on the partial class is a C member slot exposed as member_descriptor; verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: partial.keywords.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant functools_extra191.partial_doc_is_str:
  description: "functools.partial.__doc__.__class__.__name__ == 'str' — the class docstring is a plain Python str object; __doc__.__class__.__name__ is 'str'; verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: partial.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra191.partial_class_is_type:
  description: "functools.partial.__class__.__name__ == 'type' — partial is a class so its metaclass is the built-in 'type'; __class__.__name__ is 'type'; verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra191.partialmethod_doc_is_str:
  description: "functools.partialmethod.__doc__.__class__.__name__ == 'str' — the partialmethod class docstring is a plain Python str; __doc__.__class__.__name__ is 'str'; verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: partialmethod.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra191.partial_module_is_functools:
  description: "functools.partial.__module__.__eq__('functools') == True — partial reports __module__=='functools', distinguishing it from C builtins that report '_functools'; verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra191.partialmethod_module_is_functools:
  description: "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod reports __module__=='functools'; it is defined in Lib/functools.py; verified with Python 3.14.3; new to extra191"
  category: identity
  kind: python_call_eq
  function: partialmethod.__module__.__eq__
  args: ["functools"]
  expected: true

