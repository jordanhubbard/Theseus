spec: struct_extra250
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 250 theme: struct module __all__ contents and function __qualname__ identity."
    - "struct.__all__ == ['calcsize', 'pack', 'pack_into', 'unpack', 'unpack_from', 'iter_unpack', 'Struct', 'error']. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__qualname__ == 'pack'. pack is a C builtin function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__ == 'unpack'. unpack is a C builtin function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__ == 'calcsize'. calcsize is a C builtin function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__qualname__ == 'pack_into'. pack_into is a C builtin function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__ == 'unpack_from'. unpack_from is a C builtin function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__ == 'iter_unpack'. iter_unpack is a C builtin function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__ == 'Struct'. Struct is a C extension type. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__spec__.__class__.__name__ == 'ModuleSpec'. struct.__spec__ is an importlib ModuleSpec. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.__all__ is a list of 8 names: the 6 public functions (calcsize/pack/pack_into/unpack/unpack_from/iter_unpack), the Struct class, and the error exception class."
    - "Note: All struct functions are C builtins (__class__.__name__ == 'builtin_function_or_method'); Struct is a C extension type (__class__.__name__ == 'type')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.__all__.__contains__('pack') == True
# struct.__all__.__contains__('unpack') == True
# struct.__all__.__contains__('calcsize') == True
# struct.__all__.__contains__('Struct') == True
# struct.__all__.__contains__('error') == True
# struct.__all__.__contains__('iter_unpack') == True
#
# Wave 250 theme: struct.__all__ public API membership.
#
# struct.__all__ is a list of 8 names defining the module's public API:
# ['calcsize', 'pack', 'pack_into', 'unpack', 'unpack_from', 'iter_unpack',
# 'Struct', 'error']. All 6 module-level functions, the Struct compiled class,
# and the error exception are in __all__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra250.all_membership:
  description: "struct.__all__ public API membership — 'pack'/'unpack'/'calcsize'/'Struct'/'error'/'iter_unpack' are all in struct.__all__ — struct.__all__ is a list of 8 names covering all 6 public C functions, the Struct class, and the error exception; wave 250 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structall250

  columns: [id, function, args, expected, description]
  rows:
    - [all_pack,        __all__.__contains__,  ["pack"],        true, "'pack' in struct.__all__; pack is in the public API"]
    - [all_unpack,      __all__.__contains__,  ["unpack"],      true, "'unpack' in struct.__all__; unpack is in the public API"]
    - [all_calcsize,    __all__.__contains__,  ["calcsize"],    true, "'calcsize' in struct.__all__; calcsize is in the public API"]
    - [all_Struct,      __all__.__contains__,  ["Struct"],      true, "'Struct' in struct.__all__; Struct compiled class is in the public API"]
    - [all_error,       __all__.__contains__,  ["error"],       true, "'error' in struct.__all__; error exception class is in the public API"]
    - [all_iter_unpack, __all__.__contains__,  ["iter_unpack"], true, "'iter_unpack' in struct.__all__; iter_unpack is in the public API"]

# ---------------------------------------------------------------------------
# struct.pack.__qualname__.__eq__('pack')
# struct.unpack.__qualname__.__eq__('unpack')
# struct.calcsize.__qualname__.__eq__('calcsize')
# struct.pack_into.__qualname__.__eq__('pack_into')
# struct.unpack_from.__qualname__.__eq__('unpack_from')
# struct.iter_unpack.__qualname__.__eq__('iter_unpack')
#
# Wave 250 theme: struct C function __qualname__ identity.
#
# All 6 struct module-level functions are C builtins from Modules/_struct.c.
# Their __qualname__ equals their __name__ (no class prefix), confirming they
# are module-level functions not methods. pack/unpack/calcsize/pack_into/
# unpack_from/iter_unpack all have simple unqualified names.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra250.function_qualname_identity:
  description: "struct module function __qualname__ identity — pack/unpack/calcsize/pack_into/unpack_from/iter_unpack all have __qualname__ equal to their simple name — all struct functions are C builtins with unqualified __qualname__ (no class prefix); wave 250 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structfn250

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qualname,        pack.__qualname__.__eq__,        ["pack"],        true, "struct.pack.__qualname__ == 'pack'; C builtin module-level function"]
    - [unpack_qualname,      unpack.__qualname__.__eq__,      ["unpack"],      true, "struct.unpack.__qualname__ == 'unpack'; C builtin module-level function"]
    - [calcsize_qualname,    calcsize.__qualname__.__eq__,    ["calcsize"],    true, "struct.calcsize.__qualname__ == 'calcsize'; C builtin module-level function"]
    - [pack_into_qualname,   pack_into.__qualname__.__eq__,   ["pack_into"],   true, "struct.pack_into.__qualname__ == 'pack_into'; C builtin module-level function"]
    - [unpack_from_qualname, unpack_from.__qualname__.__eq__,  ["unpack_from"], true, "struct.unpack_from.__qualname__ == 'unpack_from'; C builtin module-level function"]
    - [iter_unpack_qualname, iter_unpack.__qualname__.__eq__,  ["iter_unpack"], true, "struct.iter_unpack.__qualname__ == 'iter_unpack'; C builtin module-level function"]

# ---------------------------------------------------------------------------
# struct.Struct.__qualname__.__eq__('Struct')
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec')
#
# Wave 250 theme: Struct class qualname and module spec type identity.
#
# struct.Struct.__qualname__ is 'Struct' — the compiled Struct class is a C
# extension type at module level; its __qualname__ is the simple unqualified
# name. struct.__spec__ is the importlib.machinery.ModuleSpec for the struct
# C extension module; its __class__.__name__ is 'ModuleSpec'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra250.Struct_and_spec_identity:
  description: "struct.Struct.__qualname__ and struct.__spec__ class identity — Struct.__qualname__.__eq__('Struct')==True / __spec__.__class__.__name__.__eq__('ModuleSpec')==True — Struct is a C extension type at module level with unqualified __qualname__; __spec__ is the importlib ModuleSpec for the C extension; wave 250 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structcls250

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_qualname,  Struct.__qualname__.__eq__,              ["Struct"],     true, "struct.Struct.__qualname__ == 'Struct'; C extension type at module level"]
    - [spec_class,       __spec__.__class__.__name__.__eq__,      ["ModuleSpec"], true, "struct.__spec__.__class__.__name__ == 'ModuleSpec'; importlib ModuleSpec for C extension module"]

# ---------------------------------------------------------------------------
# struct.pack.__qualname__.__eq__('pack') — standalone
#
# struct.pack.__qualname__ is 'pack'. struct.pack is the primary packing
# function: it takes a format string and values, packs them into a bytes
# object according to the format. The format string uses type characters
# (e.g., 'b' for signed byte, 'H' for unsigned short, 'f' for float) preceded
# by an optional endianness marker ('<' little-endian, '>' big-endian,
# '!' network/big-endian, '=' native, '@' native with alignment). pack is
# implemented in Modules/_struct.c as a C builtin; its __qualname__ is the
# simple name 'pack' (no class prefix) because it is a module-level function
# not a method. This is the first standalone anchor for pack.__qualname__
# under structfn250. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra250.pack_qualname:
  description: "struct.pack.__qualname__.__eq__('pack') == True — pack takes a format string (with optional endianness marker) and values; packs them into bytes; format uses type chars b/H/f/etc.; implemented in Modules/_struct.c as C builtin; __qualname__=='pack' (no class prefix) as it is module-level; first standalone for pack.__qualname__ under structfn250; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: pack.__qualname__.__eq__
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__qualname__.__eq__('Struct') — standalone
#
# struct.Struct.__qualname__ is 'Struct'. struct.Struct is the compiled
# struct object class providing a reusable struct descriptor. Unlike the
# module-level functions (which recompile the format string on every call),
# Struct pre-compiles the format string once at construction time and caches
# the result. Struct instances expose pack, unpack, pack_into, unpack_from,
# and iter_unpack as methods along with a size property. Struct is implemented
# as a C extension type in Modules/_struct.c. Its __qualname__ is the simple
# name 'Struct' (no module prefix), confirming it is a top-level type in the
# struct namespace. This is the first standalone anchor for Struct.__qualname__
# under structcls250. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra250.Struct_qualname:
  description: "struct.Struct.__qualname__.__eq__('Struct') == True — Struct pre-compiles a format string once for reuse; exposes pack/unpack/pack_into/unpack_from/iter_unpack methods plus size property; more efficient than module-level functions for repeated calls with same format; C extension type in Modules/_struct.c; __qualname__=='Struct' (top-level); first standalone for Struct.__qualname__ under structcls250; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: Struct.__qualname__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# struct.__spec__.__class__.__name__ is 'ModuleSpec'. Every imported module
# in Python 3.4+ has a __spec__ attribute containing the ModuleSpec object
# used by importlib to load the module. ModuleSpec stores the module's name,
# origin (path to the .so file for C extensions), loader, and submodule search
# locations. For struct (a C extension module), __spec__.origin is the path to
# the _struct.cpython-*.so file and __spec__.loader is an ExtensionFileLoader.
# __spec__.__class__.__name__ is 'ModuleSpec' from importlib.machinery.
# This is the first standalone anchor for __spec__.__class__.__name__ under
# structcls250. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra250.spec_class_name:
  description: "struct.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — every Python 3.4+ module has __spec__ containing the ModuleSpec used by importlib; for C extension struct: __spec__.origin is path to _struct.cpython-*.so; __spec__.loader is ExtensionFileLoader; __class__.__name__=='ModuleSpec' from importlib.machinery; first standalone for __spec__.__class__.__name__ under structcls250; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true
