spec: asyncio_extra250
version: ">=3.8"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-exceptions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-exceptions.html — asyncio exceptions documentation"
    - "https://docs.python.org/3/library/asyncio-stream.html#asyncio.IncompleteReadError — IncompleteReadError"
    - "https://docs.python.org/3/library/asyncio-stream.html#asyncio.LimitOverrunError — LimitOverrunError"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/exceptions.py (internal implementation)"
  notes:
    - "asyncio.CancelledError.__name__ == 'CancelledError' (len=14); __module__ == 'asyncio.exceptions' (len=18); __bases__[0].__name__ == 'BaseException' (len=13)."
    - "asyncio.TimeoutError.__name__ == 'TimeoutError' (len=12); __module__ == 'builtins' (len=8); __bases__[0].__name__ == 'OSError' (len=7); TimeoutError is an alias for the built-in TimeoutError (subclass of OSError)."
    - "asyncio.InvalidStateError.__name__ == 'InvalidStateError' (len=17); __module__ == 'asyncio.exceptions' (len=18); __bases__[0].__name__ == 'Exception' (len=9)."
    - "asyncio.IncompleteReadError.__name__ == 'IncompleteReadError' (len=19); __module__ == 'asyncio.exceptions' (len=18); __bases__[0].__name__ == 'EOFError' (len=8)."
    - "asyncio.LimitOverrunError.__name__ == 'LimitOverrunError' (len=17); __module__ == 'asyncio.exceptions' (len=18); __bases__[0].__name__ == 'Exception' (len=9)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio exception class identity — CancelledError
#
# CancelledError.__name__ == 'CancelledError' (len=14)
# CancelledError.__module__ == 'asyncio.exceptions' (len=18)
# CancelledError.__bases__[0].__name__ == 'BaseException' (len=13)
# ---------------------------------------------------------------------------

table asyncio_extra250.cancelled_error_identity:
  description: "asyncio.CancelledError class identity — CancelledError.__name__.__eq__('CancelledError')==True (len=14); CancelledError.__module__.__eq__('asyncio.exceptions')==True (len=18; defined in asyncio.exceptions submodule); CancelledError.__bases__[0].__name__.__eq__('BaseException')==True (len=13; inherits directly from BaseException, not Exception — important for Python 3.8+ where it was promoted from Exception to BaseException); all verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: aio250ce

  columns: [id, function, args, expected, description]
  rows:
    - [ce_name_eq,   CancelledError.__name__.__eq__,                   ["CancelledError"],        true, "asyncio.CancelledError.__name__ == 'CancelledError'; verified with Python 3.14.3"]
    - [ce_name_len,  CancelledError.__name__.__len__,                  [],                        14,   "asyncio.CancelledError.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [ce_mod_eq,    CancelledError.__module__.__eq__,                 ["asyncio.exceptions"],    true, "asyncio.CancelledError.__module__ == 'asyncio.exceptions'; verified with Python 3.14.3"]
    - [ce_mod_len,   CancelledError.__module__.__len__,                [],                        18,   "asyncio.CancelledError.__module__.__len__() == 18; verified with Python 3.14.3"]
    - [ce_base_eq,   "CancelledError.__bases__[0].__name__.__eq__",    ["BaseException"],         true, "asyncio.CancelledError.__bases__[0].__name__ == 'BaseException'; verified with Python 3.14.3"]
    - [ce_base_len,  "CancelledError.__bases__[0].__name__.__len__",   [],                        13,   "asyncio.CancelledError.__bases__[0].__name__.__len__() == 13; verified with Python 3.14.3"]

