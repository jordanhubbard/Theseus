# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra250
# ---------------------------------------------------------------------------

invariant asyncio_extra250.cancelled_error_base_is_base_exception:
  description: "asyncio.CancelledError.__bases__[0].__name__.__eq__('BaseException') returns True — in Python 3.8+ CancelledError was promoted from a subclass of Exception to a direct subclass of BaseException; this means it is not caught by bare 'except Exception' blocks; asyncio.CancelledError.__name__ == 'CancelledError' (len=14); asyncio.CancelledError.__module__ == 'asyncio.exceptions' (len=18); contrast with InvalidStateError and LimitOverrunError which have __bases__[0].__name__ == 'Exception'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "CancelledError.__bases__[0].__name__.__eq__"
  args: ["BaseException"]
  expected: true

invariant asyncio_extra250.timeout_error_module_is_builtins:
  description: "asyncio.TimeoutError.__module__.__eq__('builtins') returns True — asyncio.TimeoutError is an alias for the built-in TimeoutError; its __module__ attribute is 'builtins' (len=8), not 'asyncio.exceptions' (len=18); this makes it unique among the asyncio exceptions in this spec; TimeoutError.__name__ == 'TimeoutError' (len=12); TimeoutError.__bases__[0].__name__ == 'OSError' (len=7); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: TimeoutError.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant asyncio_extra250.incomplete_read_error_base_is_eoferror:
  description: "asyncio.IncompleteReadError.__bases__[0].__name__.__eq__('EOFError') returns True — IncompleteReadError signals that a stream ended before the expected number of bytes were read; it inherits from EOFError (len=8) rather than plain Exception (len=9); IncompleteReadError.__name__ == 'IncompleteReadError' (len=19); IncompleteReadError.__module__ == 'asyncio.exceptions' (len=18); contrast LimitOverrunError.__bases__[0].__name__ == 'Exception'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "IncompleteReadError.__bases__[0].__name__.__eq__"
  args: ["EOFError"]
  expected: true

invariant asyncio_extra250.cancelled_error_bases_index_1_raises:
  description: "asyncio.CancelledError.__bases__[1].__name__.__eq__ raises IndexError — CancelledError has exactly one direct base class (BaseException); __bases__ is a 1-element tuple; accessing __bases__[1] is out of range and raises IndexError; this confirms single-inheritance: CancelledError -> BaseException; CancelledError.__name__ == 'CancelledError' (len=14); verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: "CancelledError.__bases__[1].__name__.__eq__"
  args: ["ShouldNotReach"]
  raises: IndexError
