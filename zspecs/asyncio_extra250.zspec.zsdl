table asyncio_extra250.timeout_error_identity:
  description: "asyncio.TimeoutError class identity — TimeoutError.__name__.__eq__('TimeoutError')==True (len=12); TimeoutError.__module__.__eq__('builtins')==True (len=8; asyncio.TimeoutError is an alias for the built-in TimeoutError which lives in builtins, not asyncio.exceptions); TimeoutError.__bases__[0].__name__.__eq__('OSError')==True (len=7; TimeoutError is a subclass of OSError, unlike CancelledError which is a BaseException); all verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: aio250te

  columns: [id, function, args, expected, description]
  rows:
    - [te_name_eq,   TimeoutError.__name__.__eq__,                   ["TimeoutError"],   true, "asyncio.TimeoutError.__name__ == 'TimeoutError'; verified with Python 3.14.3"]
    - [te_name_len,  TimeoutError.__name__.__len__,                  [],                 12,   "asyncio.TimeoutError.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [te_mod_eq,    TimeoutError.__module__.__eq__,                 ["builtins"],       true, "asyncio.TimeoutError.__module__ == 'builtins' (built-in alias); verified with Python 3.14.3"]
    - [te_mod_len,   TimeoutError.__module__.__len__,                [],                 8,    "asyncio.TimeoutError.__module__.__len__() == 8; verified with Python 3.14.3"]
    - [te_base_eq,   "TimeoutError.__bases__[0].__name__.__eq__",    ["OSError"],        true, "asyncio.TimeoutError.__bases__[0].__name__ == 'OSError'; verified with Python 3.14.3"]
    - [te_base_len,  "TimeoutError.__bases__[0].__name__.__len__",   [],                 7,    "asyncio.TimeoutError.__bases__[0].__name__.__len__() == 7; verified with Python 3.14.3"]

