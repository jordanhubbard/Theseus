spec: socket_extra260
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl, socket_extra.zspec.zsdl, and socket_extra2.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket.zspec.zsdl covers: AF_INET/AF_INET6/AF_UNIX constants; SOCK_STREAM/SOCK_DGRAM/SOCK_RAW; IPPROTO_IP/TCP/UDP; SOL_SOCKET; SHUT_RD/WR/RDWR; socket/herror/gaierror class names; function names; getdefaulttimeout()==None; inet_aton/htonl vectors."
    - "socket_extra.zspec.zsdl covers: create_connection/create_server/setdefaulttimeout/htons/ntohs function names; setdefaulttimeout(None)==None; inet_aton broadcast/len; inet_ntoa loopback/broadcast/zero; htons/ntohs/ntohl zero; htonl(1) little-endian."
    - "socket_extra2.zspec.zsdl covers: AddressFamily/SocketKind enum class names; AF_INET/SOCK_STREAM/SOCK_DGRAM integer values; gethostname()/getfqdn() return str; socket.error.__name__=='OSError'; socket.timeout.__name__=='TimeoutError'; socket.timeout.__bases__[0].__name__=='OSError'."
    - "This spec focuses on: socket.socket class __qualname__ and __module__; socket.socket.__doc__ contains 'makefile'; socket.timeout module identity (__module__=='builtins'); socket.error module identity (__module__=='builtins')."
    - "socket.socket.__qualname__ == 'socket' — the class qualified name is the bare name 'socket' (Python's socket.socket is defined as class socket inside the socket module)."
    - "socket.socket.__module__ == 'socket' — the class lives in the socket module."
    - "socket.socket.__doc__ contains 'makefile' — CPython's socket.socket adds makefile() on top of _socket.socket."
    - "socket.timeout.__module__ == 'builtins' — socket.timeout is an alias for TimeoutError which is a builtin."
    - "socket.error.__module__ == 'builtins' — socket.error is an alias for OSError which is a builtin."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket class identity: __qualname__ and __module__
# (class names already covered in socket.zspec.zsdl via __name__;
#  __qualname__ and __module__ are new)
# ---------------------------------------------------------------------------

invariant socket_extra260.socket.qualname:
  description: "socket.socket.__qualname__ == 'socket' — the class qualified name is the bare class name"
  category: class_metadata
  kind: python_call_eq
  function: socket.__qualname__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra260.socket.module:
  description: "socket.socket.__module__ == 'socket' — the class lives in the socket module"
  category: class_metadata
  kind: python_call_eq
  function: socket.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__doc__ — contains 'makefile'
# CPython's socket.socket adds the makefile() method on top of _socket.socket;
# the docstring reflects this.
# ---------------------------------------------------------------------------

invariant socket_extra260.socket.doc_contains_makefile:
  description: "socket.socket.__doc__ contains 'makefile' — the docstring mentions the makefile() method"
  category: class_metadata
  kind: python_call_eq
  function: socket.__doc__.__contains__
  args: ["makefile"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout — module identity
# socket.timeout is an alias for TimeoutError (Python 3.3+); TimeoutError is
# a builtin, so __module__ == 'builtins'.
# (__name__ and __bases__[0] already covered in socket_extra2)
# ---------------------------------------------------------------------------

invariant socket_extra260.timeout.module:
  description: "socket.timeout.__module__ == 'builtins' — timeout is an alias for TimeoutError, a builtin"
  category: exceptions
  kind: python_call_eq
  function: timeout.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# socket.error — module identity
# socket.error is an alias for OSError (Python 3.3+); OSError is a builtin,
# so __module__ == 'builtins'.
# (__name__ already covered in socket_extra2)
# ---------------------------------------------------------------------------

invariant socket_extra260.error.module:
  description: "socket.error.__module__ == 'builtins' — error is an alias for OSError, a builtin"
  category: exceptions
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["builtins"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout — additional base class check
# socket.timeout.__bases__[0].__name__ already in socket_extra2 ('OSError');
# here we also verify the base class module is 'builtins'.
# ---------------------------------------------------------------------------

invariant socket_extra260.timeout.base_module:
  description: "socket.timeout.__bases__[0].__module__ == 'builtins' — TimeoutError's base OSError is a builtin"
  category: exceptions
  kind: python_call_eq
  function: timeout.__bases__.__getitem__
  args: [0]
  method: __module__.__eq__
  method_args: ["builtins"]
  expected: true
