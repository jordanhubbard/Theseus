spec: hashlib_extra811
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - hashlib module CPython source
    - Python documentation for hashlib
  not_derived_from:
    - any third-party hash library
  notes:
    - covers qualname and module identity for md5, sha1, sha224, sha256, sha384, sha512, blake2b, blake2s
  created_at: "2026-04-12"

table hashlib_extra811.qualnames_and_modules:
  description: hashlib md5/sha1/sha256/sha512 qualnames and module identities
  kind: python_call_eq
  category: identity
  id_prefix: hl811xx
  columns: [id, function, args, expected]
  rows:
    - [hl811xx001, hashlib.md5.__qualname__.__eq__, ["md5"], true]
    - [hl811xx002, hashlib.md5.__module__.__eq__, ["hashlib"], true]
    - [hl811xx003, hashlib.sha1.__qualname__.__eq__, ["sha1"], true]
    - [hl811xx004, hashlib.sha1.__module__.__eq__, ["hashlib"], true]
    - [hl811xx005, hashlib.sha224.__qualname__.__eq__, ["sha224"], true]
    - [hl811xx006, hashlib.sha256.__qualname__.__eq__, ["sha256"], true]
    - [hl811xx007, hashlib.sha256.__module__.__eq__, ["hashlib"], true]
    - [hl811xx008, hashlib.sha384.__qualname__.__eq__, ["sha384"], true]
    - [hl811xx009, hashlib.sha512.__qualname__.__eq__, ["sha512"], true]
    - [hl811xx010, hashlib.sha512.__module__.__eq__, ["hashlib"], true]
    - [hl811xx011, hashlib.blake2b.__module__.__eq__, ["hashlib"], true]
    - [hl811xx012, hashlib.blake2s.__module__.__eq__, ["hashlib"], true]
