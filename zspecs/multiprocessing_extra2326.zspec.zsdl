spec: multiprocessing_extra2326
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2326 (_extra2326): numeric constants and fixed-size attributes — class __name__ and callable class-name checks."
    - "multiprocessing.Queue is a bound method of the default context, not a bare class; its __name__ is still 'Queue'."
    - "multiprocessing.Pipe is a bound method; __name__ is 'Pipe'."
    - "multiprocessing.get_start_method and cpu_count are bound methods (__class__.__name__ == 'method')."
    - "multiprocessing.current_process is a plain function (__class__.__name__ == 'function')."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table multiprocessing_extra2326.class_names:
  description: "multiprocessing Process class __name__ check"
  kind: python_call_eq
  category: class_name
  id_prefix: mp2326

  columns: [id, function, args, expected]
  rows:
    - ["mp2326001", "multiprocessing.Process.__name__", [], "Process"]

table multiprocessing_extra2326.factory_names:
  description: "multiprocessing context-bound factory callable __name__ checks"
  kind: python_call_eq
  category: callable_name
  id_prefix: mp2326

  columns: [id, function, args, expected]
  rows:
    - ["mp2326002", "multiprocessing.Queue.__name__", [], "Queue"]
    - ["mp2326003", "multiprocessing.Pipe.__name__", [], "Pipe"]

table multiprocessing_extra2326.callable_class_names:
  description: "multiprocessing module-level callable __class__.__name__ checks"
  kind: python_call_eq
  category: type_name
  id_prefix: mp2326

  columns: [id, function, args, expected]
  rows:
    - ["mp2326004", "multiprocessing.get_start_method.__class__.__name__", [], "method"]
    - ["mp2326005", "multiprocessing.cpu_count.__class__.__name__", [], "method"]
    - ["mp2326006", "multiprocessing.current_process.__class__.__name__", [], "function"]

table multiprocessing_extra2326.exception_names:
  description: "multiprocessing exception class __name__ attribute checks"
  kind: python_call_eq
  category: class_name
  id_prefix: mp2326

  columns: [id, function, args, expected]
  rows:
    - ["mp2326007", "multiprocessing.AuthenticationError.__name__", [], "AuthenticationError"]
    - ["mp2326008", "multiprocessing.ProcessError.__name__", [], "ProcessError"]
    - ["mp2326009", "multiprocessing.TimeoutError.__name__", [], "TimeoutError"]
    - ["mp2326010", "multiprocessing.BufferTooShort.__name__", [], "BufferTooShort"]

table multiprocessing_extra2326.exception_base_names:
  description: "multiprocessing exception class __bases__ first element __name__ checks (hierarchy)"
  kind: python_call_eq
  category: class_name
  id_prefix: mp2326

  columns: [id, function, args, expected]
  rows:
    - ["mp2326011", "multiprocessing.ProcessError.__bases__.__class__.__name__", [], "tuple"]
