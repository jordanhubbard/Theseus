spec: functools_extra152
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.__all__ (list, len 15); functools.singledispatch (Python function) — __name__ 'singledispatch' len 14, __module__ 'functools', __doc__ len 339, co_argcount 1, co_varnames len 3, co_consts len 9; functools.partial (C type) — __name__ 'partial' len 7, __module__ 'functools', __doc__ len 83, __bases__[0].__name__ 'object', MRO len 2; functools.cmp_to_key (C builtin) — __qualname__ 'cmp_to_key', __module__ '_functools', __doc__ len 94 (Wave 275)."
    - "functools.__all__ is a list of 15 names exported by the functools module. Verified with Python 3.14.3."
    - "functools.singledispatch is a Python function defined in Lib/functools.py; __name__ == 'singledispatch' (len 14); __module__ == 'functools'; len(__doc__) == 339; co_argcount == 1; len(co_varnames) == 3 (func, weakref, wrapper); len(co_consts) == 9. Verified with Python 3.14.3."
    - "functools.partial is a C extension type from _functoolsmodule.c; __class__.__name__ == 'type'; __name__ == 'partial' (len 7); __module__ == 'functools'; len(__doc__) == 83; __bases__[0].__name__ == 'object'; len(__mro__) == 2. Verified with Python 3.14.3."
    - "functools.cmp_to_key is a C builtin function from _functoolsmodule.c; __class__.__name__ == 'builtin_function_or_method'; __qualname__ == 'cmp_to_key'; __module__ == '_functools'; len(__doc__) == 94. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.__all__ — module export list identity
#
# Wave 275 theme: functools.__all__ is a list of 15 names.
#
# functools.__all__.__class__.__name__ == 'list'
# len(functools.__all__) == 15
#
# The __all__ variable controls what `from functools import *` exports.
# In Python 3.14.3 it has 15 entries. New to extra152.
# ---------------------------------------------------------------------------

table functools_extra152.all_list_identity:
  description: "functools.__all__: list, len 15; contains public API names exported by the module; wave 275; new to extra152"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsall152

  columns: [id, function, args, expected, description]
  rows:
    - [all_class_name_eq_list,
       "__all__.__class__.__name__.__eq__",
       ["list"],
       true,
       "functools.__all__.__class__.__name__.__eq__('list') == True — functools.__all__ is a plain Python list that enumerates the public names exported by the module; __class__.__name__ is 'list'; str.__eq__('list') returns True; new to extra152"]
    - [all_len_eq_15,
       "__all__.__len__",
       [],
       15,
       "functools.__all__.__len__() == 15 — the functools module exports 15 public names in Python 3.14.3: update_wrapper, wraps, WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, total_ordering, cache, cmp_to_key, lru_cache, reduce, partial, partialmethod, singledispatch, singledispatchmethod, cached_property, Placeholder; len == 15; new to extra152"]

# ---------------------------------------------------------------------------
# Table 2: functools.singledispatch — Python function identity and code attrs
#
# Wave 275 theme: functools.singledispatch — decorator that transforms a function
# into a single-dispatch generic function; the dispatching is on the type of the
# first argument.
#
# functools.singledispatch.__class__.__name__ == 'function'
# functools.singledispatch.__name__ == 'singledispatch' (len 14)
# functools.singledispatch.__qualname__ == 'singledispatch' (len 14)
# functools.singledispatch.__module__ == 'functools'
# len(functools.singledispatch.__doc__) == 339
# functools.singledispatch.__code__.co_argcount == 1
# len(functools.singledispatch.__code__.co_varnames) == 3
# len(functools.singledispatch.__code__.co_consts) == 9
#
# singledispatch(func) wraps func in a dispatch function that checks the type
# of its first argument and dispatches to registered implementations.
# Defined in Lib/functools.py. New to extra152.
# ---------------------------------------------------------------------------

table functools_extra152.singledispatch_attrs:
  description: "functools.singledispatch: Python function, __name__ 'singledispatch' len 14, __module__ 'functools', __doc__ len 339, co_argcount 1, co_varnames len 3, co_consts len 9; wave 275; new to extra152"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolssd152

  columns: [id, function, args, expected, description]
  rows:
    - [singledispatch_class_eq_function,
       "singledispatch.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a Python function defined in Lib/functools.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra152"]
    - [singledispatch_name_eq,
       "singledispatch.__name__.__eq__",
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__.__eq__('singledispatch') == True — the function's __name__ is 'singledispatch'; str.__eq__('singledispatch') returns True; new to extra152"]
    - [singledispatch_name_len_eq_14,
       "singledispatch.__name__.__len__",
       [],
       14,
       "functools.singledispatch.__name__.__len__() == 14 — __name__ is 'singledispatch' which has 14 characters; len('singledispatch') == 14; new to extra152"]
    - [singledispatch_module_eq_functools,
       "singledispatch.__module__.__eq__",
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra152"]
    - [singledispatch_doc_len_eq_339,
       "singledispatch.__doc__.__len__",
       [],
       339,
       "functools.singledispatch.__doc__.__len__() == 339 — the singledispatch docstring has 339 characters in Python 3.14.3; len(__doc__) == 339; verified with Python 3.14.3; new to extra152"]
    - [singledispatch_co_argcount_eq_1,
       "singledispatch.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.singledispatch.__code__.co_argcount.__eq__(1) == True — singledispatch takes exactly 1 positional-or-keyword argument: func (the function to wrap); co_argcount is 1; int.__eq__(1) returns True; new to extra152"]
    - [singledispatch_co_varnames_len_eq_3,
       "singledispatch.__code__.co_varnames.__len__",
       [],
       3,
       "functools.singledispatch.__code__.co_varnames.__len__() == 3 — co_varnames has 3 entries: func, weakref, wrapper; len() == 3; verified with Python 3.14.3; new to extra152"]
    - [singledispatch_co_consts_len_eq_9,
       "singledispatch.__code__.co_consts.__len__",
       [],
       9,
       "functools.singledispatch.__code__.co_consts.__len__() == 9 — co_consts includes the function's constant values (docstring, None, integer constants, nested code objects, etc.); len() == 9; verified with Python 3.14.3; new to extra152"]

# ---------------------------------------------------------------------------
# Table 3: functools.partial — C extension type identity and attrs
#
# Wave 275 theme: functools.partial — a C extension type that stores a function
# and partial argument application for later completion.
#
# functools.partial.__class__.__name__ == 'type'
# functools.partial.__name__ == 'partial' (len 7)
# functools.partial.__qualname__ == 'partial' (len 7)
# functools.partial.__module__ == 'functools'
# len(functools.partial.__doc__) == 83
# functools.partial.__bases__[0].__name__ == 'object'
# len(functools.partial.__mro__) == 2
#
# partial is a C extension type defined in _functoolsmodule.c and exposed in
# functools. New to extra152.
# ---------------------------------------------------------------------------

table functools_extra152.partial_attrs:
  description: "functools.partial: C type, __name__ 'partial' len 7, __module__ 'functools', __doc__ len 83, __bases__[0].__name__ 'object', MRO len 2; wave 275; new to extra152"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolspartial152

  columns: [id, function, args, expected, description]
  rows:
    - [partial_class_eq_type,
       "partial.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a C extension type defined in _functoolsmodule.c; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra152"]
    - [partial_name_eq,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — the C extension type's __name__ is 'partial'; str.__eq__('partial') returns True; new to extra152"]
    - [partial_name_len_eq_7,
       "partial.__name__.__len__",
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — __name__ is 'partial' which has 7 characters; len('partial') == 7; new to extra152"]
    - [partial_module_eq_functools,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial.__module__ is set to 'functools' by the module initializer in _functoolsmodule.c; str.__eq__('functools') returns True; new to extra152"]
    - [partial_doc_len_eq_83,
       "partial.__doc__.__len__",
       [],
       83,
       "functools.partial.__doc__.__len__() == 83 — the partial docstring has 83 characters; len(__doc__) == 83; verified with Python 3.14.3; new to extra152"]
    - [partial_bases_first_eq_object,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — the partial C extension type inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra152"]
    - [partial_mro_len_eq_2,
       "partial.__mro__.__len__",
       [],
       2,
       "functools.partial.__mro__.__len__() == 2 — partial inherits only from object; MRO is [partial, object]; len(__mro__) == 2; new to extra152"]

# ---------------------------------------------------------------------------
# Table 4: functools.cmp_to_key — C builtin identity
#
# Wave 275 theme: functools.cmp_to_key — a C builtin function that converts
# a comparison function to a key function for use with sort().
#
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
# functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len 10)
# functools.cmp_to_key.__module__ == '_functools'
# len(functools.cmp_to_key.__doc__) == 94
#
# cmp_to_key is defined in _functoolsmodule.c. New to extra152.
# ---------------------------------------------------------------------------

table functools_extra152.cmp_to_key_attrs:
  description: "functools.cmp_to_key: C builtin, __qualname__ 'cmp_to_key' len 10, __module__ '_functools', __doc__ len 94; wave 275; new to extra152"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsctk152

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_to_key_class_eq_builtin,
       "cmp_to_key.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — cmp_to_key is a C builtin function from _functoolsmodule.c; __class__.__name__ is 'builtin_function_or_method'; str.__eq__ returns True; new to extra152"]
    - [cmp_to_key_qualname_eq,
       "cmp_to_key.__qualname__.__eq__",
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True — the C builtin's __qualname__ is 'cmp_to_key'; str.__eq__('cmp_to_key') returns True; new to extra152"]
    - [cmp_to_key_qualname_len_eq_10,
       "cmp_to_key.__qualname__.__len__",
       [],
       10,
       "functools.cmp_to_key.__qualname__.__len__() == 10 — __qualname__ is 'cmp_to_key' which has 10 characters; len('cmp_to_key') == 10; new to extra152"]
    - [cmp_to_key_module_eq__functools,
       "cmp_to_key.__module__.__eq__",
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is implemented in _functoolsmodule.c; __module__ is '_functools'; str.__eq__('_functools') returns True; new to extra152"]
    - [cmp_to_key_doc_len_eq_94,
       "cmp_to_key.__doc__.__len__",
       [],
       94,
       "functools.cmp_to_key.__doc__.__len__() == 94 — the cmp_to_key docstring has 94 characters; len(__doc__) == 94; verified with Python 3.14.3; new to extra152"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra152
# ---------------------------------------------------------------------------

invariant functools_extra152.all_len:
  description: "len(functools.__all__) == 15 — functools exports 15 public names in Python 3.14.3; wave 275; new to extra152"
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 15

invariant functools_extra152.all_class_list:
  description: "functools.__all__.__class__.__name__ == 'list' — __all__ is a plain Python list; wave 275; new to extra152"
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant functools_extra152.singledispatch_name_len:
  description: "len(functools.singledispatch.__name__) == 14 — __name__ is 'singledispatch'; wave 275; new to extra152"
  kind: python_call_eq
  function: singledispatch.__name__.__len__
  args: []
  expected: 14

invariant functools_extra152.singledispatch_doc_len:
  description: "len(functools.singledispatch.__doc__) == 339 — the singledispatch docstring has 339 characters; wave 275; new to extra152"
  kind: python_call_eq
  function: singledispatch.__doc__.__len__
  args: []
  expected: 339

invariant functools_extra152.singledispatch_co_argcount:
  description: "functools.singledispatch.__code__.co_argcount == 1 — takes func as the single argument; wave 275; new to extra152"
  kind: python_call_eq
  function: singledispatch.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant functools_extra152.singledispatch_co_consts_len:
  description: "len(functools.singledispatch.__code__.co_consts) == 9 — co_consts has 9 entries; wave 275; new to extra152"
  kind: python_call_eq
  function: singledispatch.__code__.co_consts.__len__
  args: []
  expected: 9

invariant functools_extra152.partial_name_len:
  description: "len(functools.partial.__name__) == 7 — __name__ is 'partial'; wave 275; new to extra152"
  kind: python_call_eq
  function: partial.__name__.__len__
  args: []
  expected: 7

invariant functools_extra152.partial_mro_len:
  description: "len(functools.partial.__mro__) == 2 — MRO is [partial, object]; wave 275; new to extra152"
  kind: python_call_eq
  function: partial.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra152.partial_bases_object:
  description: "functools.partial.__bases__[0].__name__ == 'object' — partial inherits only from object; wave 275; new to extra152"
  kind: python_call_eq
  function: "partial.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra152.cmp_to_key_doc_len:
  description: "len(functools.cmp_to_key.__doc__) == 94 — the cmp_to_key docstring has 94 characters; wave 275; new to extra152"
  kind: python_call_eq
  function: cmp_to_key.__doc__.__len__
  args: []
  expected: 94

invariant functools_extra152.cmp_to_key_module:
  description: "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is implemented in _functoolsmodule.c; wave 275; new to extra152"
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true
