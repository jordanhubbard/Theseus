spec: abc_extra661
backend: python_module(abc)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — ABCMeta, abstractmethod, and related class identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers ABCMeta __subclasses__ and abstractmethod deeper identity; abc.abstractclassmethod, abstractstaticmethod, and abstractproperty are deprecated but still present in the module"]
  created_at: "2026-04-12T00:00:00Z"

table abc_extra661.abcmeta_identity:
  description: "abc.ABCMeta class and method identity checks"
  kind: python_call_eq
  category: abcmeta_identity
  id_prefix: ab661am
  columns: [id, function, args, expected]
  rows:
    - [ab661am001, abc.ABCMeta.__subclasses__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ab661am002, abc.ABCMeta.__init_subclass__.__qualname__.__eq__, ["type.__init_subclass__"], true]
    - [ab661am003, abc.ABCMeta.__name__.__eq__, ["ABCMeta"], true]
    - [ab661am004, abc.ABCMeta.register.__name__.__eq__, ["register"], true]

table abc_extra661.abstractmethod_identity:
  description: "abc.abstractmethod and related decorator identity checks"
  kind: python_call_eq
  category: abstractmethod_identity
  id_prefix: ab661ad
  columns: [id, function, args, expected]
  rows:
    - [ab661ad001, abc.abstractmethod.__class__.__name__.__eq__, ["function"], true]
    - [ab661ad002, abc.abstractmethod.__name__.__eq__, ["abstractmethod"], true]
    - [ab661ad003, abc.abstractclassmethod.__name__.__eq__, ["abstractclassmethod"], true]
    - [ab661ad004, abc.abstractstaticmethod.__name__.__eq__, ["abstractstaticmethod"], true]
    - [ab661ad005, abc.abstractproperty.__name__.__eq__, ["abstractproperty"], true]

table abc_extra661.abc_class_identity:
  description: "abc.ABC class and subclasshook identity checks"
  kind: python_call_eq
  category: abc_class_identity
  id_prefix: ab661ac
  columns: [id, function, args, expected]
  rows:
    - [ab661ac001, abc.ABC.__name__.__eq__, ["ABC"], true]
    - [ab661ac002, abc.ABC.__subclasshook__.__name__.__eq__, ["__subclasshook__"], true]

table abc_extra661.get_cache_token_identity:
  description: "abc.get_cache_token name identity check"
  kind: python_call_eq
  category: get_cache_token_identity
  id_prefix: ab661gc
  columns: [id, function, args, expected]
  rows:
    - [ab661gc001, abc.get_cache_token.__name__.__eq__, ["ABCMeta.__abstractmethods__"], true]
