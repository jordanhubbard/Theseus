spec: theseus_pathlib_cr4
version: ">=3.9"
backend: python_cleanroom(theseus_pathlib_cr4)
blocks: pathlib

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html"
  notes:
    - "Clean-room extended pathlib utilities. Do NOT import pathlib."
    - "PurePosixPath and PureWindowsPath: pure path objects with no I/O."
    - "PurePath.with_name(name): return new path with changed filename."
    - "PurePath.with_suffix(suffix): return new path with changed suffix."
    - "PurePath.relative_to(other): return path relative to another."
    - "pathlib4_with_name(): PurePosixPath('/a/b/c.txt').with_name('d.txt') == PurePosixPath('/a/b/d.txt')."
    - "pathlib4_with_suffix(): PurePosixPath('/a/b.txt').with_suffix('.py').suffix == '.py'."
    - "pathlib4_relative_to(): PurePosixPath('/a/b/c').relative_to('/a') == PurePosixPath('b/c')."
    - "Implement as pure string manipulation without os.path — only string operations allowed."
    - "Export: PurePosixPath, PureWindowsPath, PurePath."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_pathlib_cr4.with_name:
  description: "PurePosixPath('/a/b/c.txt').with_name('d.txt').name == 'd.txt'"
  category: pure_path
  kind: python_call_eq
  function: pathlib4_with_name
  args: []
  expected: "d.txt"

invariant theseus_pathlib_cr4.with_suffix:
  description: "PurePosixPath('/a/b.txt').with_suffix('.py').suffix == '.py'"
  category: pure_path
  kind: python_call_eq
  function: pathlib4_with_suffix
  args: []
  expected: ".py"

invariant theseus_pathlib_cr4.relative_to:
  description: "PurePosixPath('/a/b/c').relative_to('/a') == 'b/c'"
  category: pure_path
  kind: python_call_eq
  function: pathlib4_relative_to
  args: []
  expected: "b/c"
