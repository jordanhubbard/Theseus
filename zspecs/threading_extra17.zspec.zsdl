spec: threading_extra17
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading.zspec.zsdl and threading_extra through threading_extra16."
    - "threading.zspec.zsdl covers: class __name__ table (Thread/Lock/RLock/Condition/Semaphore/BoundedSemaphore/Event/Timer/Barrier); function __name__ table (current_thread/main_thread/active_count/enumerate); TIMEOUT_MAX.__ge__(1e9); active_count() >= 1."
    - "threading_extra covers: TIMEOUT_MAX.__class__.__name__ == 'float'; local.__name__; stack_size() returns int."
    - "threading_extra5 covers: TIMEOUT_MAX.__class__.__name__ == 'float' (table form)."
    - "threading_extra11 covers: TIMEOUT_MAX.__eq__(9223372036.0); TIMEOUT_MAX.__class__.__name__ == 'float' (standalone)."
    - "threading_extra4 covers: settrace/__name__, active_count/__name__, enumerate/__name__ standalone invariants."
    - "threading_extra6 covers: settrace/__name__, setprofile/__name__, stack_size/__name__ (table)."
    - "threading_extra16 covers: Thread/__name__/__module__/__qualname__/__class__.__name__; Barrier/__name__/__module__/__qualname__; Timer/__name__/__module__/__qualname__; Event/__module__; Semaphore/__module__; Condition/__name__/__module__; Lock.__name__=='lock'."
    - "NOT yet covered in any prior spec: TIMEOUT_MAX.__gt__(0) == True — greater-than comparison with zero."
    - "NOT yet covered: TIMEOUT_MAX.__lt__(1e18) == True — upper-bound sanity check."
    - "NOT yet covered: TIMEOUT_MAX.__class__.__name__.__class__.__name__ == 'str' — the class name string is itself a str."
    - "NOT yet covered: active_count.__class__.__name__ == 'builtin_function_or_method' — active_count is a C builtin."
    - "NOT yet covered: current_thread.__class__.__name__ == 'builtin_function_or_method'."
    - "NOT yet covered: main_thread.__class__.__name__ == 'builtin_function_or_method'."
    - "NOT yet covered: settrace.__class__.__name__ == 'function' — settrace is a Python function."
    - "NOT yet covered: setprofile.__class__.__name__ == 'function'."
    - "NOT yet covered: stack_size.__class__.__name__ == 'builtin_function_or_method'."
    - "NOT yet covered: enumerate.__class__.__name__ == 'builtin_function_or_method'."
    - "threading.active_count/__class__.__name__ == 'builtin_function_or_method' — C-level function from _thread."
    - "threading.settrace/__class__.__name__ == 'function' — Python-level function defined in threading.py."
    - "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is strictly positive."
    - "threading.TIMEOUT_MAX.__lt__(1e18) == True — TIMEOUT_MAX is below 1e18 on CPython."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TIMEOUT_MAX arithmetic comparisons
#
# threading.zspec.zsdl covers TIMEOUT_MAX.__ge__(1e9).
# threading_extra11 covers TIMEOUT_MAX.__eq__(9223372036.0).
# No prior spec checks TIMEOUT_MAX.__gt__(0) or TIMEOUT_MAX.__lt__(1e18).
# TIMEOUT_MAX is a large finite float (~9.2e9 on CPython/macOS), so it is
# strictly greater than 0 and strictly less than 1e18.
# ---------------------------------------------------------------------------

invariant threading_extra17.TIMEOUT_MAX.gt_zero:
  description: "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is strictly positive"
  category: constants
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [0]
  expected: true

invariant threading_extra17.TIMEOUT_MAX.lt_large:
  description: "threading.TIMEOUT_MAX.__lt__(1e18) == True — TIMEOUT_MAX is below 1e18"
  category: constants
  kind: python_call_eq
  function: TIMEOUT_MAX.__lt__
  args: [1.0e18]
  expected: true

invariant threading_extra17.TIMEOUT_MAX.classname_is_str:
  description: "threading.TIMEOUT_MAX.__class__.__name__.__class__.__name__ == 'str' — the class name is a str"
  category: constants
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function __class__.__name__ checks
#
# No prior threading spec checks __class__.__name__ for module-level functions.
# active_count, current_thread, main_thread, enumerate, and stack_size are
# C-level builtins from _thread, so their __class__.__name__ is
# 'builtin_function_or_method'. settrace and setprofile are Python functions
# defined in threading.py, so their __class__.__name__ is 'function'.
# ---------------------------------------------------------------------------

table threading_extra17.builtin_function_class_names:
  description: "threading C-level functions have __class__.__name__ == 'builtin_function_or_method'"
  kind: python_call_eq
  category: function_types
  id_prefix: bfcname17

  columns: [id, function, args, expected]
  rows:
    - [active_count,   active_count.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [current_thread, current_thread.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [main_thread,    main_thread.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [enumerate,      enumerate.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [stack_size,     stack_size.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]

table threading_extra17.python_function_class_names:
  description: "threading Python-level functions have __class__.__name__ == 'function'"
  kind: python_call_eq
  category: function_types
  id_prefix: pfcname17

  columns: [id, function, args, expected]
  rows:
    - [settrace,   settrace.__class__.__name__.__eq__,   ["function"], true]
    - [setprofile, setprofile.__class__.__name__.__eq__, ["function"], true]
