spec: st3046
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct: Interpret bytes as packed binary data"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (st3046): __enter__, __exit__, __aenter__ dict-presence checks for struct types."
    - "struct.Struct is a C extension type for packing/unpacking binary data — it does not implement the context manager protocol and defines neither __enter__, __exit__, nor __aenter__ in its own __dict__."
    - "type(struct.Struct('!I')) is identical to struct.Struct — verified on Python 3.14.4."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table st3046.enter:
  description: "struct types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st3046
  columns: [id, function, args, expected]
  rows:
    - ["st3046001", operator.contains, [struct.Struct.__dict__,             "__enter__"], false]
    - ["st3046002", operator.contains, [type(struct.Struct('!I')).__dict__, "__enter__"], false]

