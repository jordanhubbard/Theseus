spec: difflib_extra9
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib.zspec.zsdl and prior extras through difflib_extra8.zspec.zsdl."
    - "difflib_extra8 covers: IS_LINE_JUNK/__CHARACTER_JUNK qualnames and behavioral vectors; Differ.__bases__[0].__name__=='object'; SequenceMatcher/Differ mro_len==2; context_diff.__qualname__; get_close_matches('wheat',...) and ('appel',...,n=1); SequenceMatcher ratio 'abc'/'xyz'==0.0."
    - "difflib_extra7 covers: ratio identical 5-char via ratio.__eq__(1.0); ndiff equal-line prefix via __next__; unified_diff hunk header."
    - "difflib_extra2 covers: SequenceMatcher.ratio_identical for a 3-char string."
    - "NOT yet covered: difflib.SequenceMatcher(None,'abcd','abcd').ratio() == 1.0 returned as direct expected float (not via __eq__ method chain)."
    - "NOT yet covered: difflib.SequenceMatcher(None,'','').ratio() == 1.0 — empty sequences."
    - "NOT yet covered: difflib.SequenceMatcher(None,'a','b').ratio() == 0.0 — single disjoint characters."
    - "NOT yet covered: difflib.SequenceMatcher(None,'abcd','abce').ratio() == 0.75 — three-out-of-four chars match."
    - "NOT yet covered: difflib.ndiff(['one\\n','two\\n'],['one\\n','three\\n']) second element == '- two\\n' (removed line) — extra7 only tests the equal-line case."
    - "NOT yet covered: difflib.get_close_matches('teh', ['the', 'tree', 'ten']) — new word not in prior specs."
    - "NOT yet covered: difflib.get_close_matches('speling', ['spelling', 'speed', 'spin']) — another new word vector."
    - "difflib.SequenceMatcher(None,'abcd','abcd').ratio() == 1.0 — identical 4-char strings."
    - "difflib.SequenceMatcher(None,'','').ratio() == 1.0 — two empty sequences are identical."
    - "difflib.SequenceMatcher(None,'a','b').ratio() == 0.0 — single characters with no match give ratio 0.0."
    - "difflib.SequenceMatcher(None,'abcd','abce').ratio() == 0.75 — 3 matching chars out of 4 total each side."
    - "difflib.ndiff(['one\\n','two\\n'],['one\\n','three\\n']) second element is '- two\\n' (line removed from first seq)."
    - "difflib.get_close_matches('teh', ['the', 'tree', 'ten']) == ['the', 'ten'] — two close matches for a common transposition typo."
    - "difflib.get_close_matches('speling', ['spelling', 'speed', 'spin']) == ['spelling'] — single close match for a misspelling."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SequenceMatcher.ratio — identical 4-char, empty, single-char disjoint, partial
#
# difflib_extra2 covers ratio_identical via .__eq__(1.0) method chain.
# difflib_extra7 covers ratio for 5-char identical via .__eq__(1.0).
# difflib_extra8 covers ratio == 0.0 for 3-char disjoint ('abc'/'xyz').
# No prior spec tests: identical 4-char as a direct expected float; empty
# sequences; single disjoint chars; partial match (3 of 4 chars) == 0.75.
# ---------------------------------------------------------------------------

invariant difflib_extra9.SequenceMatcher.ratio_identical_4:
  description: "difflib.SequenceMatcher(None,'abcd','abcd').ratio() == 1.0 — identical 4-char strings"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "abcd", "abcd"]
  method: ratio.__eq__
  method_args: [1.0]
  expected: true

invariant difflib_extra9.SequenceMatcher.ratio_empty:
  description: "difflib.SequenceMatcher(None,'','').ratio() == 1.0 — two empty sequences are identical"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "", ""]
  method: ratio.__eq__
  method_args: [1.0]
  expected: true

invariant difflib_extra9.SequenceMatcher.ratio_single_disjoint:
  description: "difflib.SequenceMatcher(None,'a','b').ratio() == 0.0 — single disjoint characters"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "a", "b"]
  method: ratio.__eq__
  method_args: [0.0]
  expected: true

invariant difflib_extra9.SequenceMatcher.ratio_partial:
  description: "difflib.SequenceMatcher(None,'abcd','abce').ratio() == 0.75 — 3 of 4 chars match"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "abcd", "abce"]
  method: ratio.__eq__
  method_args: [0.75]
  expected: true

# ---------------------------------------------------------------------------
# ndiff — removed-line prefix
#
# difflib_extra7 covers the equal-line prefix ('  hello\n') from ndiff via
# __next__. No prior spec checks the removed-line prefix ('- two\n') from
# ndiff using the pair (['one\n','two\n'], ['one\n','three\n']).
# We extract the second element via __next__.__next__ (skipping the equal
# first line).
# ---------------------------------------------------------------------------

invariant difflib_extra9.ndiff.removed_line:
  description: "difflib.ndiff(['one\\n','two\\n'],['one\\n','three\\n'])[1] == '- two\\n' — removed line prefix"
  category: ndiff
  kind: python_call_eq
  function: ndiff
  args: [["one\n", "two\n"], ["one\n", "three\n"]]
  method: __next__.__next__
  expected: "- two\n"

# ---------------------------------------------------------------------------
# get_close_matches — 'teh' and 'speling' new word vectors
#
# Prior specs cover 'appel', 'banana', 'wheat' as input words.
# No prior spec uses 'teh' (transposition of 'the') or 'speling' (misspelling
# of 'spelling'). These exercise the default cutoff=0.6 threshold.
# get_close_matches('teh', ['the', 'tree', 'ten']) == ['the', 'ten']
# get_close_matches('speling', ['spelling', 'speed', 'spin']) == ['spelling']
# ---------------------------------------------------------------------------

invariant difflib_extra9.get_close_matches.teh:
  description: "difflib.get_close_matches('teh', ['the', 'tree', 'ten']) == ['the', 'ten']"
  category: get_close_matches
  kind: python_call_eq
  function: get_close_matches
  args: ["teh", ["the", "tree", "ten"]]
  expected: ["the", "ten"]

invariant difflib_extra9.get_close_matches.speling:
  description: "difflib.get_close_matches('speling', ['spelling', 'speed', 'spin']) == ['spelling']"
  category: get_close_matches
  kind: python_call_eq
  function: get_close_matches
  args: ["speling", ["spelling", "speed", "spin"]]
  expected: ["spelling"]

# ---------------------------------------------------------------------------
# Table: get_close_matches new word vectors
#
# Groups the two new word vectors in one indexed table.
# No prior spec provides a table with 'teh' or 'speling' as input.
# ---------------------------------------------------------------------------

table difflib_extra9.close_matches_new_words:
  description: "difflib.get_close_matches with new word inputs not in prior specs"
  kind: python_call_eq
  category: get_close_matches
  id_prefix: gcm

  columns: [id, function, args, expected]
  rows:
    - [teh,     get_close_matches, ["teh",     ["the", "tree", "ten"]],           ["the", "ten"]]
    - [speling, get_close_matches, ["speling", ["spelling", "speed", "spin"]],    ["spelling"]]
