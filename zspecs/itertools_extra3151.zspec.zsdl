spec: it3151
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 657 (it3151): __setitem__, __delitem__, __contains__ dict-presence checks for itertools types."
    - "No itertools iterator type defines __setitem__, __delitem__, or __contains__ in its own __dict__."
    - "All 18 itertools iterator types are C-level types; they are iterable via __iter__/__next__, not via mapping or container protocols."
    - "itertools.pairwise requires Python >= 3.10."
    - "All 18 itertools iterator types are checked."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table it3151.setitem:
