# ---------------------------------------------------------------------------
# abc ABCMeta and ABC __bases__[0].__name__ extended checks — extra63
#
# Wave 234 theme: base class name identity.
#
# ABCMeta.__bases__[0].__name__ == 'type'  (ABCMeta is a metaclass inheriting type)
# ABC.__bases__[0].__name__ == 'object'   (ABC directly subclasses object)
# Note: function values containing '[' in table rows MUST be double-quoted.
# ---------------------------------------------------------------------------

table abc_extra63.abc_bases_extended:
  description: "abc ABCMeta.__bases__[0].__name__ and ABC.__bases__[0].__name__ equality checks in abckw63 namespace — wave 234 theme: base class name identity; ABCMeta.__bases__[0].__name__=='type' (ABCMeta inherits from type as a metaclass); ABC.__bases__[0].__name__=='object' (ABC directly subclasses object); function values containing '[' are double-quoted per ZSDL rules; NEW in extra63: first __bases__[0].__name__.__eq__ checks for ABCMeta and ABC in the abckw63 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abckw63c

  columns: [id, function, args, expected, description]
  rows:
    - ["abcmeta_bases_0_name", "ABCMeta.__bases__[0].__name__.__eq__", ["type"],   true, "ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta is a metaclass that inherits from the built-in type; ABCMeta.__bases__ is (type,); ABCMeta.__bases__[0] is type; type.__name__ is 'type'; NEW in extra63: first __bases__[0].__name__.__eq__('type') check for ABCMeta in the abckw63 namespace; verified with Python 3.14.3"]
    - ["abc_bases_0_name",     "ABC.__bases__[0].__name__.__eq__",     ["object"], true, "ABC.__bases__[0].__name__ == 'object' — ABC is a helper class with ABCMeta as metaclass; it inherits directly from object; ABC.__bases__ is (object,); ABC.__bases__[0] is object; object.__name__ is 'object'; NEW in extra63: first __bases__[0].__name__.__eq__('object') check for ABC in the abckw63 namespace; verified with Python 3.14.3"]

