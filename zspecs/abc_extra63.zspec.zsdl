invariant abc_extra63.abstractmethod_kwdefaults_NoneType:
  description: "abc.abstractmethod.__kwdefaults__.__class__.__name__.__eq__('NoneType') returns True — abstractmethod(funcobj) has no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra63: first standalone __kwdefaults__.__class__.__name__.__eq__('NoneType') invariant for abstractmethod in the abckw63 namespace; wave 234 first __kwdefaults__ NoneType identity invariant for abstractmethod; verified with Python 3.14.3"
  category: kwdefaults
  kind: python_call_eq
  function: abstractmethod.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant abc_extra63.ABCMeta_subclasscheck_co_varnames_tuple:
  description: "abc.ABCMeta.__subclasscheck__.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — co_varnames is a tuple of strings naming all local variables (parameters first, then locals); the type of co_varnames is always tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra63: first standalone co_varnames type identity invariant for ABCMeta.__subclasscheck__ in the abckw63 namespace; wave 234 first co_varnames type invariant for ABCMeta.__subclasscheck__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant abc_extra63.ABCMeta_subclasscheck_co_consts_tuple:
  description: "abc.ABCMeta.__subclasscheck__.__code__.co_consts.__class__.__name__.__eq__('tuple') returns True — co_consts is a tuple of constants used by the bytecode; the type of co_consts is always tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra63: first standalone co_consts type identity invariant for ABCMeta.__subclasscheck__ in the abckw63 namespace; wave 234 first co_consts type invariant for ABCMeta.__subclasscheck__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__code__.co_consts.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant abc_extra63.ABCMeta_subclasscheck_co_nlocals_int:
  description: "abc.ABCMeta.__subclasscheck__.__code__.co_nlocals.__class__.__name__.__eq__('int') returns True — co_nlocals is the total number of local variables; it is always a Python int; int.__class__.__name__ is 'int'; NEW in extra63: first standalone co_nlocals type identity invariant for ABCMeta.__subclasscheck__ in the abckw63 namespace; wave 234 first co_nlocals type invariant for ABCMeta.__subclasscheck__; verified with Python 3.14.3"
  category: code
