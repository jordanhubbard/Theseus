spec: abc_extra63
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python function __kwdefaults__ and code object documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra62.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all abc exports, abstractproperty/abstractclassmethod/abstractstaticmethod lengths/qualnames/bases, ABCMeta.register qualname lengths/equality, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2)/abstractproperty(3)/abstractclassmethod(3)/abstractstaticmethod(3), __bases__[0].__name__.__len__(), __dict__.__class__.__name__/__len__() tables, ABCMeta/__dict__.__class__.__name__/__qualname__, ABC/__dict__.__class__.__name__/__qualname__, abstractproperty/abstractclassmethod/abstractstaticmethod __dict__.__class__.__name__, abc module __dict__.__class__.__name__/__qualname__, abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta', __class__.__qualname__ string equality, abstractmethod/__class__.__module__=='builtins', abstractproperty/__class__.__module__=='builtins', ABC/__class__.__module__=='abc', ABCMeta/__class__.__module__=='builtins', abstractclassmethod/abstractstaticmethod __class__.__module__=='builtins', abstractproperty/__init__.__class__.__name__=='wrapper_descriptor', abstractmethod/__init__.__class__.__name__=='method-wrapper', __class__.__module__.__len__() cross-checks, __repr__.__class__.__name__ for all abc objects, __weakref__.__class__.__name__ for abstractproperty/abstractclassmethod/abstractstaticmethod, ABCMeta.__instancecheck__/__subclasscheck__.__class__.__name__.__eq__('function'), ABC/ABCMeta __eq__.__class__.__name__.__eq__('wrapper_descriptor'), abc.__package__.__eq__(''), ABC/ABCMeta/abstractmethod/get_cache_token __doc__.__class__.__name__.__eq__('str'), ABCMeta.__instancecheck__.__qualname__.__eq__, __loader__.__class__.__name__/__name__, __spec__/__file__ class names, ABCMeta.__instancecheck__.__qualname__.__len__()==25, __spec__ attributes, ABCMeta.register/__instancecheck__/__subclasscheck__/update_abstractmethods __qualname__.__eq__, abstractproperty.__init__.__qualname__.__eq__, abstractmethod/__annotations__/__globals__ class identity, ABCMeta/__doc__.__contains__('Abstract'), get_cache_token/__class__.__name__.__eq__('builtin_function_or_method'), abstractmethod/__defaults__/__code__/__closure__/__class__.__name__ checks, update_abstractmethods/__defaults__/__code__/__class__.__name__ checks (extra58), abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ __code__.co_name equality and co_argcount values (extra59), abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ co_varnames/co_filename/co_flags attribute chains (extra60), abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__ co_consts/co_nlocals/co_stacksize type identity (extra61), abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__/ABCMeta.__subclasscheck__ __defaults__.__class__.__name__=='NoneType', ABCMeta.__subclasscheck__ method identity, ABCMeta.register extended identity (extra62)."
    - "This spec covers (abckw63 namespace): wave 234 theme — __kwdefaults__ NoneType identity for abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__/ABCMeta.__subclasscheck__; ABCMeta.__subclasscheck__ code attribute type chains (co_varnames/co_consts/__class__.__name__=='tuple'; co_nlocals/co_stacksize/__class__.__name__=='int'); update_abstractmethods code attribute type chains (co_consts/__class__.__name__=='tuple'; co_nlocals/__class__.__name__=='int'); abc_bases_extended (__bases__[0].__name__ equality for ABCMeta and ABC). NEW in extra63: abstractmethod.__kwdefaults__.__class__.__name__=='NoneType'; update_abstractmethods.__kwdefaults__.__class__.__name__=='NoneType'; ABCMeta.__instancecheck__.__kwdefaults__.__class__.__name__=='NoneType'; ABCMeta.__subclasscheck__.__kwdefaults__.__class__.__name__=='NoneType'; ABCMeta.__subclasscheck__.__code__.co_varnames.__class__.__name__=='tuple'; ABCMeta.__subclasscheck__.__code__.co_consts.__class__.__name__=='tuple'; ABCMeta.__subclasscheck__.__code__.co_nlocals.__class__.__name__=='int'; ABCMeta.__subclasscheck__.__code__.co_stacksize.__class__.__name__=='int'; update_abstractmethods.__code__.co_consts.__class__.__name__=='tuple'; update_abstractmethods.__code__.co_nlocals.__class__.__name__=='int'; ABCMeta.__bases__[0].__name__=='type'; ABC.__bases__[0].__name__=='object'."
    - "abc.abstractmethod.__kwdefaults__ is None. abstractmethod(funcobj) has no keyword-only parameters. __kwdefaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__kwdefaults__ is None. update_abstractmethods(cls) has no keyword-only parameters. __kwdefaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__kwdefaults__ is None. ABCMeta.__instancecheck__(cls, instance) has no keyword-only parameters. __kwdefaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__kwdefaults__ is None. ABCMeta.__subclasscheck__(cls, subclass) has no keyword-only parameters. __kwdefaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is always a tuple of strings naming local variables. tuple.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__code__.co_consts.__class__.__name__ == 'tuple'. co_consts is a tuple of constants used by the bytecode. tuple.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__code__.co_nlocals.__class__.__name__ == 'int'. co_nlocals is the number of local variables; it is an integer. int.__class__.__name__ is 'int'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__code__.co_stacksize.__class__.__name__ == 'int'. co_stacksize is the required stack size; it is an integer. int.__class__.__name__ is 'int'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_consts.__class__.__name__ == 'tuple'. co_consts is a tuple of constants used by the bytecode. tuple.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__code__.co_nlocals.__class__.__name__ == 'int'. co_nlocals is the number of local variables; it is an integer. int.__class__.__name__ is 'int'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__bases__[0].__name__ == 'type'. ABCMeta inherits from type (it is a metaclass). ABCMeta.__bases__ is (type,). ABCMeta.__bases__[0] is type. type.__name__ is 'type'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__bases__[0].__name__ == 'object'. ABC is a helper class defined with ABCMeta as its metaclass; it inherits directly from object. ABC.__bases__ is (object,). ABC.__bases__[0] is object. object.__name__ is 'object'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc __kwdefaults__ NoneType checks — extra63
#
# Wave 234 theme: __kwdefaults__ NoneType identity.
#
# abstractmethod(funcobj) has no keyword-only parameters; __kwdefaults__ is None.
# update_abstractmethods(cls) has no keyword-only parameters; __kwdefaults__ is None.
# ABCMeta.__instancecheck__(cls, instance) has no keyword-only parameters; None.
# ABCMeta.__subclasscheck__(cls, subclass) has no keyword-only parameters; None.
# ---------------------------------------------------------------------------

table abc_extra63.none_kwdefaults:
  description: "abc abstractmethod/update_abstractmethods/ABCMeta.__instancecheck__/ABCMeta.__subclasscheck__ __kwdefaults__.__class__.__name__.__eq__('NoneType') checks in abckw63 namespace — wave 234 theme: __kwdefaults__ NoneType identity; none of these functions have keyword-only parameters; __kwdefaults__ is None for all; None.__class__.__name__ is 'NoneType'; NEW in extra63: first __kwdefaults__.__class__.__name__.__eq__('NoneType') checks for all four in the abckw63 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: kwdefaults
  id_prefix: abckw63

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_kwdefaults_class,   abstractmethod.__kwdefaults__.__class__.__name__.__eq__,            ["NoneType"], true, "abstractmethod.__kwdefaults__.__class__.__name__ == 'NoneType' — abstractmethod(funcobj) has no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra63: first __kwdefaults__.__class__.__name__.__eq__ check for abstractmethod in the abckw63 namespace; verified with Python 3.14.3"]
    - [uam_kwdefaults_class,              update_abstractmethods.__kwdefaults__.__class__.__name__.__eq__,    ["NoneType"], true, "update_abstractmethods.__kwdefaults__.__class__.__name__ == 'NoneType' — update_abstractmethods(cls) has no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra63: first __kwdefaults__.__class__.__name__.__eq__ check for update_abstractmethods in the abckw63 namespace; verified with Python 3.14.3"]
    - [instancecheck_kwdefaults_class,    ABCMeta.__instancecheck__.__kwdefaults__.__class__.__name__.__eq__, ["NoneType"], true, "ABCMeta.__instancecheck__.__kwdefaults__.__class__.__name__ == 'NoneType' — ABCMeta.__instancecheck__(cls, instance) has no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra63: first __kwdefaults__.__class__.__name__.__eq__ check for ABCMeta.__instancecheck__ in the abckw63 namespace; verified with Python 3.14.3"]
    - [subclasscheck_kwdefaults_class,    ABCMeta.__subclasscheck__.__kwdefaults__.__class__.__name__.__eq__, ["NoneType"], true, "ABCMeta.__subclasscheck__.__kwdefaults__.__class__.__name__ == 'NoneType' — ABCMeta.__subclasscheck__(cls, subclass) has no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra63: first __kwdefaults__.__class__.__name__.__eq__ check for ABCMeta.__subclasscheck__ in the abckw63 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABCMeta.__subclasscheck__ code attribute type chains — extra63
#
# Wave 234 theme: code object attribute type identity chains.
#
# ABCMeta.__subclasscheck__.__code__.co_varnames is a tuple (always).
# ABCMeta.__subclasscheck__.__code__.co_consts is a tuple (always).
# ABCMeta.__subclasscheck__.__code__.co_nlocals is an int (always).
# ABCMeta.__subclasscheck__.__code__.co_stacksize is an int (always).
# ---------------------------------------------------------------------------

table abc_extra63.ABCMeta_subclasscheck_code_chains:
  description: "abc ABCMeta.__subclasscheck__ code attribute type identity chain checks in abckw63 namespace — wave 234 theme: code object attribute type identity; co_varnames.__class__.__name__=='tuple'; co_consts.__class__.__name__=='tuple'; co_nlocals.__class__.__name__=='int'; co_stacksize.__class__.__name__=='int'; NEW in extra63: first type identity chain checks for ABCMeta.__subclasscheck__ code attributes in the abckw63 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: abckw63a

  columns: [id, function, args, expected, description]
  rows:
    - [subclasscheck_co_varnames_class,  ABCMeta.__subclasscheck__.__code__.co_varnames.__class__.__name__.__eq__,  ["tuple"], true, "ABCMeta.__subclasscheck__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple of strings naming all local variables (parameters first, then locals); the type of co_varnames is always tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra63: first co_varnames.__class__.__name__.__eq__ check for ABCMeta.__subclasscheck__ in the abckw63 namespace; verified with Python 3.14.3"]
    - [subclasscheck_co_consts_class,    ABCMeta.__subclasscheck__.__code__.co_consts.__class__.__name__.__eq__,   ["tuple"], true, "ABCMeta.__subclasscheck__.__code__.co_consts.__class__.__name__ == 'tuple' — co_consts is a tuple of constants used by the bytecode; the type of co_consts is always tuple; tuple.__class__.__name__ is 'tuple'; NEW in extra63: first co_consts.__class__.__name__.__eq__ check for ABCMeta.__subclasscheck__ in the abckw63 namespace; verified with Python 3.14.3"]
    - [subclasscheck_co_nlocals_class,   ABCMeta.__subclasscheck__.__code__.co_nlocals.__class__.__name__.__eq__,  ["int"],   true, "ABCMeta.__subclasscheck__.__code__.co_nlocals.__class__.__name__ == 'int' — co_nlocals is the total number of local variables; it is always a Python int; int.__class__.__name__ is 'int'; NEW in extra63: first co_nlocals.__class__.__name__.__eq__ check for ABCMeta.__subclasscheck__ in the abckw63 namespace; verified with Python 3.14.3"]
    - [subclasscheck_co_stacksize_class, ABCMeta.__subclasscheck__.__code__.co_stacksize.__class__.__name__.__eq__, ["int"],   true, "ABCMeta.__subclasscheck__.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the required stack size for the code object; it is always a Python int; int.__class__.__name__ is 'int'; NEW in extra63: first co_stacksize.__class__.__name__.__eq__ check for ABCMeta.__subclasscheck__ in the abckw63 namespace; verified with Python 3.14.3"]

