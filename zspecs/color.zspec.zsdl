spec: color
version: ">=4.0.0"
backend: node(color)

docs: https://github.com/Qix-/color#readme

provenance:
  derived_from:
    - "color README — https://github.com/Qix-/color#readme"
    - "CSS Color Module Level 4 — https://www.w3.org/TR/css-color-4/"
    - "Test vectors verified with color via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "color source"
  notes:
    - "Qix's `color` is a JS color manipulation library (sibling to `color-string` / `color-name`)."
    - "Install: npm install color"
    - "v4+ is ESM with a CJS shim; the factory is exposed as default."
    - "Color('red').hex() returns UPPERCASE hex (#FF0000), differing from chroma-js's lowercase."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; throws on invalid color strings."
  stderr: "null"
  stickiness: "N/A — Color instances immutable."
  codes: {}

# Color(input).hex() — basic round-trip
table color.hex:
  kind: node_chain_eq
  category: hex
  entry: named
  function: default
  id_prefix: hex

  columns: [id, entry_args, chain, expected]
  rows:
    - [named_red,    ["red"],     [{method: hex, args: []}], "#FF0000"]
    - [named_blue,   ["blue"],    [{method: hex, args: []}], "#0000FF"]
    - [hex_input,    ["#ff0000"], [{method: hex, args: []}], "#FF0000"]

# Color(input).rgb().array() — extract RGB triplet
invariant color.rgb_array_red:
  description: "Color('red').rgb().array() yields [255, 0, 0]"
  category: rgb
  kind: node_chain_eq
  entry: named
  function: default
  entry_args: ["red"]
  chain:
    - {method: rgb, args: []}
    - {method: array, args: []}
  expected: [255, 0, 0]

# Color.rgb(r,g,b).hex() — explicit factory variant via static method
invariant color.rgb_factory:
  description: "Color.rgb(255,0,0).hex() == '#FF0000'"
  category: factories
  kind: node_chain_eq
  entry: named
  function: default.rgb
  entry_args: [255, 0, 0]
  chain:
    - {method: hex, args: []}
  expected: "#FF0000"

# Color(input).red() — primary component access
table color.components:
  kind: node_chain_eq
  category: components
  entry: named
  function: default
  id_prefix: comp

  columns: [id, entry_args, chain, expected]
  rows:
    - [red_component,  ["red"],   [{method: red, args: []}],   255]
    - [green_blue,     ["green"], [{method: green, args: []}], 128]
    - [blue_max,       ["blue"],  [{method: blue, args: []}],  255]

# luminosity / luminance
invariant color.white_luminosity_one:
  description: "Color('white').luminosity() == 1"
  category: luminosity
  kind: node_chain_eq
  entry: named
  function: default
  entry_args: ["white"]
  chain:
    - {method: luminosity, args: []}
  expected: 1

invariant color.black_luminosity_zero:
  description: "Color('black').luminosity() == 0"
  category: luminosity
  kind: node_chain_eq
  entry: named
  function: default
  entry_args: ["black"]
  chain:
    - {method: luminosity, args: []}
  expected: 0

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:22:49Z
  iterations: 1
  pass_count: 10
  fail_count: 0
  total_invariants: 10
  notes: Synthesis succeeded in 1 iteration(s). 10 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
