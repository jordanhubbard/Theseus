spec: just_kebab_case
version: ">=4.2.0"
backend: node(just-kebab-case)

docs: https://www.npmjs.com/package/just-kebab-case

provenance:
  derived_from:
    - "just-kebab-case README — https://www.npmjs.com/package/just-kebab-case"
    - "Test vectors verified with just-kebab-case via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "just-kebab-case source"
  notes:
    - "just-kebab-case is an npm package. Install: npm install just-kebab-case"
    - "Converts a string to kebab-case."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_kebab_case.convert:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: jkc

  columns: [id, args, expected]
  rows:
    - [from_camel,  ["fooBar"],   "foo-bar"]
    - [from_snake,  ["foo_bar"],  "foo-bar"]
    - [from_space,  ["Foo Bar"],  "foo-bar"]

