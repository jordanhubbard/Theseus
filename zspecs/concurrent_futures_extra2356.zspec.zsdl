spec: concurrent_futures_extra2356
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes:
    - "Checks .__init__.__class__.__name__ and .__new__.__class__.__name__ for concurrent.futures classes"
    - "Future, ThreadPoolExecutor, ProcessPoolExecutor all define custom __init__ — class name is 'function'"
    - "Executor base class inherits __init__ from object — class name is 'wrapper_descriptor'"
    - "All classes inherit __new__ from object — class name is 'builtin_function_or_method'"
  created_at: "2026-04-12"
error_model: python_exceptions

table concurrent_futures_extra2356.future_init_type:
  description: "__init__ and __new__ implementation type for concurrent.futures.Future (pure Python)"
  kind: python_call_eq
  category: init_type
  id_prefix: cf2356
  columns: [id, function, args, expected]
  rows:
    - ["cf2356001", concurrent.futures.Future.__init__.__class__.__name__.__eq__, ["function"],                 true]
    - ["cf2356002", concurrent.futures.Future.__new__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

table concurrent_futures_extra2356.thread_pool_executor_init_type:
  description: "__init__ and __new__ implementation type for concurrent.futures.ThreadPoolExecutor (pure Python)"
  kind: python_call_eq
  category: init_type
  id_prefix: cf2356
  columns: [id, function, args, expected]
  rows:
    - ["cf2356003", concurrent.futures.ThreadPoolExecutor.__init__.__class__.__name__.__eq__, ["function"],                 true]
    - ["cf2356004", concurrent.futures.ThreadPoolExecutor.__new__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

table concurrent_futures_extra2356.process_pool_executor_init_type:
  description: "__init__ and __new__ implementation type for concurrent.futures.ProcessPoolExecutor (pure Python)"
  kind: python_call_eq
  category: init_type
  id_prefix: cf2356
  columns: [id, function, args, expected]
  rows:
    - ["cf2356005", concurrent.futures.ProcessPoolExecutor.__init__.__class__.__name__.__eq__, ["function"],                 true]
    - ["cf2356006", concurrent.futures.ProcessPoolExecutor.__new__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

table concurrent_futures_extra2356.executor_init_type:
  description: "__init__ and __new__ implementation type for concurrent.futures.Executor (abstract base, no custom __init__)"
  kind: python_call_eq
  category: init_type
  id_prefix: cf2356
  columns: [id, function, args, expected]
  rows:
    - ["cf2356007", concurrent.futures.Executor.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"],       true]
    - ["cf2356008", concurrent.futures.Executor.__new__.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

table concurrent_futures_extra2356.init_type_contrast:
  description: "Cross-class contrast: Executor (no custom __init__) vs concrete executors (custom __init__)"
  kind: python_call_eq
  category: init_type
  id_prefix: cf2356
  columns: [id, function, args, expected]
  rows:
    - ["cf2356009",  concurrent.futures.Executor.__init__.__class__.__name__.__eq__,             ["function"],          false]
    - ["cf2356010",  concurrent.futures.Future.__init__.__class__.__name__.__eq__,               ["wrapper_descriptor"], false]
    - ["cf2356011",  concurrent.futures.ThreadPoolExecutor.__init__.__class__.__name__.__eq__,   ["wrapper_descriptor"], false]
    - ["cf2356012",  concurrent.futures.ProcessPoolExecutor.__init__.__class__.__name__.__eq__,  ["wrapper_descriptor"], false]
    - ["cf2356013",  concurrent.futures.Executor.__init__.__class__.__name__.__eq__,             ["wrapper_descriptor"], true]
    - ["cf2356014",  concurrent.futures.Future.__init__.__class__.__name__.__eq__,               ["function"],          true]
    - ["cf2356015",  concurrent.futures.ThreadPoolExecutor.__init__.__class__.__name__.__eq__,   ["function"],          true]
    - ["cf2356016",  concurrent.futures.ProcessPoolExecutor.__init__.__class__.__name__.__eq__,  ["function"],          true]
    - ["cf2356017",  concurrent.futures.Future.__new__.__class__.__name__.__eq__,                ["wrapper_descriptor"], false]
    - ["cf2356018",  concurrent.futures.ThreadPoolExecutor.__new__.__class__.__name__.__eq__,    ["wrapper_descriptor"], false]
    - ["cf2356019",  concurrent.futures.ProcessPoolExecutor.__new__.__class__.__name__.__eq__,   ["wrapper_descriptor"], false]
    - ["cf2356020",  concurrent.futures.Executor.__new__.__class__.__name__.__eq__,              ["wrapper_descriptor"], false]
