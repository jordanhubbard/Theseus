spec: theseus_bisect_cr
version: ">=3.8"
backend: python_cleanroom(theseus_bisect_cr)
blocks: bisect

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/bisect.html"
  not_derived_from:
    - "CPython source: Lib/bisect.py (internal implementation)"
  notes:
    - "Clean-room bisect module. Do NOT import bisect."

error_model: python_exceptions

invariant theseus_bisect_cr.bisect2_insort:
  description: "insort keeps list sorted after insertion"
  category: insort
  kind: python_call_eq
  function: bisect2_insort
  args: []
  expected: true

invariant theseus_bisect_cr.bisect2_left:
  description: "bisect_left returns correct insertion index"
  category: bisect_left
  kind: python_call_eq
  function: bisect2_left
  args: []
  expected: 2

invariant theseus_bisect_cr.bisect2_right:
  description: "bisect_right returns index after existing element"
  category: bisect_right
  kind: python_call_eq
  function: bisect2_right
  args: []
  expected: 3
