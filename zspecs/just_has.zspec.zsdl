spec: just_has
version: ">=2.3.0"
backend: node(just-has)

docs: https://www.npmjs.com/package/just-has

provenance:
  derived_from:
    - "just-has README — https://www.npmjs.com/package/just-has"
    - "Test vectors verified with just-has via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-has source"
  notes:
    - "just-has is an npm package. Install: npm install just-has"
    - "The module exports a single function that checks if an object has a nested property via dotted path."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_has.has:
  kind: node_module_call_eq
  function: ~
  category: predicate
  id_prefix: jhas

  columns: [id, args, expected]
  rows:
    - [nested_found,   [{"a": {"b": 1}}, "a.b"], true]
    - [nested_missing, [{"a": {"b": 1}}, "a.x"], false]
    - [top_level,      [{"a": 1}, "a"],           true]
