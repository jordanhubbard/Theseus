spec: pprint_extra4
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends prior pprint specs."
    - "Focus: __module__ and __name__ for pprint functions and classes; PrettyPrinter attributes."
    - "pprint.PrettyPrinter.__name__ == 'PrettyPrinter'."
    - "pprint.PrettyPrinter.__module__ == 'pprint'."
    - "pprint.pformat.__name__ == 'pformat'."
    - "pprint.pprint.__name__ == 'pprint'."
    - "pprint.isreadable.__name__ == 'isreadable'."
    - "pprint.isrecursive.__name__ == 'isrecursive'."
    - "pprint.saferepr.__name__ == 'saferepr'."
    - "pprint.pp.__name__ == 'pp' (Python 3.8+)."
    - "pprint.PrettyPrinter().indent == 1 (default)."
    - "pprint.PrettyPrinter().width == 80 (default)."
    - "pprint.PrettyPrinter().depth is None (default — unlimited)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table pprint_extra4.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [PrettyPrinter, PrettyPrinter.__name__.__eq__, ["PrettyPrinter"], true]

table pprint_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [pformat,     pformat.__name__.__eq__,     ["pformat"],     true]
    - [pprint,      pprint.__name__.__eq__,      ["pprint"],      true]
    - [isreadable,  isreadable.__name__.__eq__,  ["isreadable"],  true]
    - [isrecursive, isrecursive.__name__.__eq__, ["isrecursive"], true]
    - [saferepr,    saferepr.__name__.__eq__,    ["saferepr"],    true]
    - [pp,          pp.__name__.__eq__,          ["pp"],          true]

invariant pprint_extra4.PrettyPrinter.module:
  description: "pprint.PrettyPrinter.__module__ == 'pprint'"
  category: module
  kind: python_call_eq
  function: PrettyPrinter.__module__.__eq__
  args: ["pprint"]
  expected: true

invariant pprint_extra4.pformat.module:
  description: "pprint.pformat.__module__ == 'pprint'"
  category: module
  kind: python_call_eq
  function: pformat.__module__.__eq__
  args: ["pprint"]
  expected: true

invariant pprint_extra4.PrettyPrinter.indent_default:
  description: "pprint.PrettyPrinter().indent == 1"
  category: PrettyPrinter_defaults
  kind: python_call_eq
  function: PrettyPrinter
  args: []
  method: _indent_per_level.__eq__
  method_args: [1]
  expected: true

invariant pprint_extra4.PrettyPrinter.width_default:
  description: "pprint.PrettyPrinter().width == 80"
  category: PrettyPrinter_defaults
  kind: python_call_eq
  function: PrettyPrinter
  args: []
  method: _width.__eq__
  method_args: [80]
  expected: true

invariant pprint_extra4.PrettyPrinter.instance_class:
  description: "pprint.PrettyPrinter().__class__.__name__ == 'PrettyPrinter'"
  category: PrettyPrinter
  kind: python_call_eq
  function: PrettyPrinter
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["PrettyPrinter"]
  expected: true

invariant pprint_extra4.isreadable.on_int:
  description: "pprint.isreadable(42) == True"
  category: isreadable
  kind: python_call_eq
  function: isreadable
  args: [42]
  expected: true

invariant pprint_extra4.isrecursive.on_list:
  description: "pprint.isrecursive([1, 2, 3]) == False"
  category: isrecursive
  kind: python_call_eq
  function: isrecursive
  args: [[1, 2, 3]]
  expected: false

invariant pprint_extra4.saferepr.on_string:
  description: "pprint.saferepr('hello') == \"'hello'\""
  category: saferepr
  kind: python_call_eq
  function: saferepr
  args: ["hello"]
  expected: "'hello'"

invariant pprint_extra4.pformat.on_list:
  description: "pprint.pformat([1, 2, 3]) == '[1, 2, 3]'"
  category: pformat
  kind: python_call_eq
  function: pformat
  args: [[1, 2, 3]]
  expected: "[1, 2, 3]"
