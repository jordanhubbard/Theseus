spec: smtplib_extra
version: ">=3.6"
backend: python_module(smtplib)

docs: https://docs.python.org/3/library/smtplib.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/smtplib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "smtplib source: internal CPython socket/TLS implementation details"
  notes:
    - "This spec provides additional identity invariants beyond smtplib.zspec.zsdl."
    - "smtplib.SMTP.__name__ == 'SMTP'; smtplib.SMTP_SSL.__name__ == 'SMTP_SSL'."
    - "smtplib.SMTPException.__name__ == 'SMTPException'."
    - "smtplib.SMTPConnectError.__name__ == 'SMTPConnectError'."
    - "smtplib.SMTPAuthenticationError.__name__ == 'SMTPAuthenticationError'."
    - "smtplib.SMTPException.__bases__[0].__name__ == 'OSError' — SMTPException is a subclass of OSError."
    - "smtplib.SMTP_PORT.__class__.__name__ == 'int' — the standard SMTP port constant is an int."
    - "smtplib.SMTP_PORT == 25 — standard SMTP port."
    - "No actual SMTP connections are made; all invariants are stateless attribute reads."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant smtplib_extra.classes.SMTP_name:
  description: "smtplib.SMTP.__name__ == 'SMTP'"
  category: class_names
  kind: python_call_eq
  function: SMTP.__name__.__eq__
  args: ["SMTP"]
  expected: true

invariant smtplib_extra.classes.SMTP_SSL_name:
  description: "smtplib.SMTP_SSL.__name__ == 'SMTP_SSL'"
  category: class_names
  kind: python_call_eq
  function: SMTP_SSL.__name__.__eq__
  args: ["SMTP_SSL"]
  expected: true

invariant smtplib_extra.classes.SMTPException_name:
  description: "smtplib.SMTPException.__name__ == 'SMTPException'"
  category: class_names
  kind: python_call_eq
  function: SMTPException.__name__.__eq__
  args: ["SMTPException"]
  expected: true

invariant smtplib_extra.classes.SMTPConnectError_name:
  description: "smtplib.SMTPConnectError.__name__ == 'SMTPConnectError'"
  category: class_names
  kind: python_call_eq
  function: SMTPConnectError.__name__.__eq__
  args: ["SMTPConnectError"]
  expected: true

invariant smtplib_extra.classes.SMTPAuthenticationError_name:
  description: "smtplib.SMTPAuthenticationError.__name__ == 'SMTPAuthenticationError'"
  category: class_names
  kind: python_call_eq
  function: SMTPAuthenticationError.__name__.__eq__
  args: ["SMTPAuthenticationError"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy
# SMTPException -> OSError
# ---------------------------------------------------------------------------

invariant smtplib_extra.hierarchy.SMTPException_base:
  description: "smtplib.SMTPException.__bases__[0].__name__ == 'OSError'"
  category: hierarchy
  kind: python_call_eq
  function: SMTPException.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# Port constant — type and value checks
# ---------------------------------------------------------------------------

invariant smtplib_extra.constants.SMTP_PORT_type:
  description: "smtplib.SMTP_PORT.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: SMTP_PORT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant smtplib_extra.constants.SMTP_PORT_value:
  description: "smtplib.SMTP_PORT == 25"
  category: constants
  kind: python_call_eq
  function: SMTP_PORT.__eq__
  args: [25]
  expected: true
