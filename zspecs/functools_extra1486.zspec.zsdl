spec: functools_extra1486
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "Wave 546 theme: __enter__ and __exit__ context manager protocol checks for functools classes."
    - "functools.partial: no __enter__, no __exit__ in __dict__. Verified with Python 3.12."
    - "functools.cached_property: no __enter__, no __exit__ in __dict__. Verified with Python 3.12."
    - "functools.singledispatchmethod: no __enter__, no __exit__ in __dict__. Verified with Python 3.12."
    - "functools.partialmethod: no __enter__, no __exit__ in __dict__. Verified with Python 3.12."
    - "None of the functools wrapper/decorator classes implement the context manager protocol; they are callable wrappers, descriptors, or dispatch helpers only."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial — __enter__ and __exit__ absence checks
#
# Wave 546 theme: functools.partial — partial application of a callable.
#
# functools.partial.__dict__.__contains__("__enter__") == False
# functools.partial.__dict__.__contains__("__exit__") == False
#
# partial wraps another callable with preset positional and keyword arguments.
# It does not implement the context manager protocol. New to extra1486.
# ---------------------------------------------------------------------------

table functools_extra1486.partial_context_manager_absence:
  description: "functools.partial has no __enter__ or __exit__ in __dict__; partial is a callable wrapper, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1486pa

  columns: [id, function, args, expected, description]
  rows:
    - [fu1486pa001,
       "partial.__dict__.__contains__",
       ["__enter__"],
       false,
       "functools.partial.__dict__.__contains__('__enter__') == False — partial is a callable wrapper that partially applies arguments to another callable; it does not implement the context manager protocol; __enter__ is not defined in partial.__dict__; verified with Python 3.12; new to extra1486"]
    - [fu1486pa002,
       "partial.__dict__.__contains__",
       ["__exit__"],
       false,
       "functools.partial.__dict__.__contains__('__exit__') == False — partial does not implement __exit__ and cannot be used as a context manager; __exit__ is not defined in partial.__dict__; verified with Python 3.12; new to extra1486"]
    - [fu1486pa003,
       "partial.__dict__.__contains__",
       ["__call__"],
       true,
       "functools.partial.__dict__.__contains__('__call__') == True — partial IS callable and defines __call__ in its __dict__; this distinguishes it from its non-context-manager status; verified with Python 3.12; new to extra1486"]
    - [fu1486pa004,
       "partial.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a class object whose metaclass is the built-in type; str.__eq__('type') returns True; new to extra1486"]
    - [fu1486pa005,
       "partial.__dict__.__contains__",
       ["func"],
       false,
       "functools.partial.__dict__.__contains__('func') == False — 'func' is an instance attribute on partial objects, not a class-level entry in partial.__dict__; verified with Python 3.12; new to extra1486"]
    - [fu1486pa006,
       "partial.__dict__.__contains__",
       ["args"],
       false,
       "functools.partial.__dict__.__contains__('args') == False — 'args' is an instance attribute on partial objects, not a class-level entry in partial.__dict__; verified with Python 3.12; new to extra1486"]

# ---------------------------------------------------------------------------
# Table 2: functools.cached_property — __enter__ and __exit__ absence checks
#
# Wave 546 theme: functools.cached_property — descriptor that caches the
# result of a method as a per-instance attribute.
#
# functools.cached_property.__dict__.__contains__("__enter__") == False
# functools.cached_property.__dict__.__contains__("__exit__") == False
#
# cached_property is a data descriptor. Instances cache computed values in
# the instance __dict__. It has __get__ and __set_name__ but does not
# implement the context manager protocol. New to extra1486.
# ---------------------------------------------------------------------------

table functools_extra1486.cached_property_context_manager_absence:
  description: "functools.cached_property has no __enter__ or __exit__ in __dict__; cached_property is a descriptor, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1486cp

  columns: [id, function, args, expected, description]
  rows:
    - [fu1486cp001,
       "cached_property.__dict__.__contains__",
       ["__enter__"],
       false,
       "functools.cached_property.__dict__.__contains__('__enter__') == False — cached_property is a descriptor class whose instances cache computed property values in the instance __dict__; it does not implement the context manager protocol; __enter__ is not in cached_property.__dict__; verified with Python 3.12; new to extra1486"]
    - [fu1486cp002,
       "cached_property.__dict__.__contains__",
       ["__exit__"],
       false,
       "functools.cached_property.__dict__.__contains__('__exit__') == False — cached_property cannot be used as a context manager; __exit__ is not defined in cached_property.__dict__; verified with Python 3.12; new to extra1486"]
    - [fu1486cp003,
       "cached_property.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.cached_property.__dict__.__contains__('__get__') == True — cached_property IS a descriptor and defines __get__ in its __dict__; this is its primary protocol, distinct from the context manager protocol; verified with Python 3.12; new to extra1486"]
    - [fu1486cp004,
       "cached_property.__dict__.__contains__",
       ["__set_name__"],
       true,
       "functools.cached_property.__dict__.__contains__('__set_name__') == True — cached_property defines __set_name__ to record the attribute name at class creation time; __set_name__ IS in cached_property.__dict__; verified with Python 3.12; new to extra1486"]
    - [fu1486cp005,
       "cached_property.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a class object whose metaclass is the built-in type; str.__eq__('type') returns True; new to extra1486"]
    - [fu1486cp006,
       "cached_property.__dict__.__contains__",
       ["__set__"],
       false,
       "functools.cached_property.__dict__.__contains__('__set__') == False — cached_property intentionally omits __set__ so the instance __dict__ takes precedence on attribute lookup; __set__ is not in cached_property.__dict__; verified with Python 3.12; new to extra1486"]

# ---------------------------------------------------------------------------
# Table 3: functools.singledispatchmethod and partialmethod — absence checks
#
# Wave 546 theme: functools.singledispatchmethod and functools.partialmethod —
# descriptor-based decorator classes for dispatch and method wrapping.
#
# functools.singledispatchmethod.__dict__.__contains__("__enter__") == False
# functools.singledispatchmethod.__dict__.__contains__("__exit__") == False
# functools.partialmethod.__dict__.__contains__("__enter__") == False
# functools.partialmethod.__dict__.__contains__("__exit__") == False
#
# Both are descriptors used as decorators. Neither is a context manager.
# New to extra1486.
# ---------------------------------------------------------------------------

table functools_extra1486.singledispatchmethod_partialmethod_context_manager_absence:
  description: "functools.singledispatchmethod and partialmethod have no __enter__ or __exit__ in __dict__; both are descriptor decorators, not context managers; wave 546; new to extra1486"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1486sd

  columns: [id, function, args, expected, description]
  rows:
    - [fu1486sd001,
       "singledispatchmethod.__dict__.__contains__",
       ["__enter__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__enter__') == False — singledispatchmethod is a descriptor for single-dispatch generic methods; it dispatches based on the type of the first non-self argument but does not implement the context manager protocol; __enter__ is not in singledispatchmethod.__dict__; verified with Python 3.12; new to extra1486"]
    - [fu1486sd002,
       "singledispatchmethod.__dict__.__contains__",
       ["__exit__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__exit__') == False — singledispatchmethod cannot be used as a context manager; __exit__ is not defined in singledispatchmethod.__dict__; verified with Python 3.12; new to extra1486"]
    - [fu1486sd003,
       "singledispatchmethod.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.singledispatchmethod.__dict__.__contains__('__get__') == True — singledispatchmethod IS a descriptor and defines __get__ in its __dict__; the descriptor protocol is its primary interface, not the context manager protocol; verified with Python 3.12; new to extra1486"]
    - [fu1486sd004,
       "partialmethod.__dict__.__contains__",
       ["__enter__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__enter__') == False — partialmethod is a descriptor that creates partial methods for use inside class bodies; it does not implement the context manager protocol; __enter__ is not in partialmethod.__dict__; verified with Python 3.12; new to extra1486"]
    - [fu1486sd005,
       "partialmethod.__dict__.__contains__",
       ["__exit__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__exit__') == False — partialmethod cannot be used as a context manager; __exit__ is not defined in partialmethod.__dict__; verified with Python 3.12; new to extra1486"]
    - [fu1486sd006,
       "partialmethod.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.partialmethod.__dict__.__contains__('__get__') == True — partialmethod IS a descriptor and defines __get__ in its __dict__; descriptor protocol is its primary interface, not the context manager protocol; verified with Python 3.12; new to extra1486"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1486
# ---------------------------------------------------------------------------

invariant functools_extra1486.partial_no_enter:
  description: "functools.partial.__dict__ does not contain '__enter__' — partial is a callable wrapper, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__enter__"]
  expected: false

invariant functools_extra1486.partial_no_exit:
  description: "functools.partial.__dict__ does not contain '__exit__' — partial does not implement the context manager protocol; wave 546; new to extra1486"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__exit__"]
  expected: false

invariant functools_extra1486.cached_property_no_enter:
  description: "functools.cached_property.__dict__ does not contain '__enter__' — cached_property is a descriptor, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__enter__"]
  expected: false

invariant functools_extra1486.cached_property_no_exit:
  description: "functools.cached_property.__dict__ does not contain '__exit__' — cached_property does not implement the context manager protocol; wave 546; new to extra1486"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__exit__"]
  expected: false

invariant functools_extra1486.singledispatchmethod_no_enter:
  description: "functools.singledispatchmethod.__dict__ does not contain '__enter__' — singledispatchmethod is a dispatch descriptor, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  function: singledispatchmethod.__dict__.__contains__
  args: ["__enter__"]
  expected: false

invariant functools_extra1486.partialmethod_no_enter:
  description: "functools.partialmethod.__dict__ does not contain '__enter__' — partialmethod is a method-wrapping descriptor, not a context manager; wave 546; new to extra1486"
  kind: python_call_eq
  function: partialmethod.__dict__.__contains__
  args: ["__enter__"]
  expected: false
