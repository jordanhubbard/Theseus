spec: errno_extra4
version: ">=3.9"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/errno.html"
    - "POSIX.1-2017 — IEEE Std 1003.1, errno.h error codes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "Extends errno.zspec.zsdl, errno_extra.zspec.zsdl, errno_extra2.zspec.zsdl, and errno_extra3.zspec.zsdl."
    - "errno.zspec covers: EPERM=1, ENOENT=2, ESRCH=3, EINTR=4, EIO=5, EBADF=9, ENOMEM=12, EACCES=13, EINVAL=22 values; ENOTSUP type; errorcode type and lookups for keys 1, 2, 22."
    - "errno_extra covers: ENOENT/EACCES/EEXIST/EPERM class names and values; errorcode class/contains/lookup for key 2."
    - "errno_extra2 covers: class names for EPERM/ENOENT/ESRCH/EINTR/EIO/ENXIO/EACCES/EEXIST/ENOTDIR/EISDIR; errorcode class name and len>=50; EPERM/ENOENT/EACCES positivity."
    - "errno_extra3 covers: class names for EBADF/ENOMEM/EINVAL; errorcode lookups for keys 9 and 12; errorcode __contains__ for keys 9 and 12."
    - "This spec adds: class name checks for ENOSPC, EPIPE, ERANGE, EMFILE, ENFILE (not yet covered by any prior spec); errorcode reverse-lookups for keys 5 (EIO), 13 (EACCES), 22 (EINVAL), 28 (ENOSPC), 32 (EPIPE); positivity checks for ESRCH, EINTR, EIO."
    - "errno.ENOSPC == 28 on POSIX (no space left on device)."
    - "errno.EPIPE == 32 on POSIX (broken pipe)."
    - "errno.ERANGE == 34 on POSIX (result too large)."
    - "errno.EMFILE == 24 on POSIX (too many open files by process)."
    - "errno.ENFILE == 23 on POSIX (too many open files in system)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name checks — ENOSPC, EPIPE, ERANGE, EMFILE, ENFILE
# None of these constants have been checked in prior specs.
# ---------------------------------------------------------------------------

table errno_extra4.constant_class_names:
  description: "ENOSPC, EPIPE, ERANGE, EMFILE, ENFILE are plain int objects"
  kind: python_call_eq
  category: constant_types
  id_prefix: cls

  columns: [id, function, args, expected]
  rows:
    - [ENOSPC, ENOSPC.__class__.__name__.__eq__, ["int"], true]
    - [EPIPE,  EPIPE.__class__.__name__.__eq__,  ["int"], true]
    - [ERANGE, ERANGE.__class__.__name__.__eq__, ["int"], true]
    - [EMFILE, EMFILE.__class__.__name__.__eq__, ["int"], true]
    - [ENFILE, ENFILE.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# errorcode reverse-lookups — keys not yet covered by prior specs
# errno.zspec covers 1, 2, 22; errno_extra3 covers 9, 12.
# New here: 5 (EIO), 13 (EACCES), 22 already done so skip; 28 (ENOSPC), 32 (EPIPE).
# ---------------------------------------------------------------------------

invariant errno_extra4.errorcode.eio_lookup:
  description: "errno.errorcode[5] == 'EIO' — reverse-lookup of errno 5 (I/O error)"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [5]
  expected: "EIO"

invariant errno_extra4.errorcode.eacces_lookup:
  description: "errno.errorcode[13] == 'EACCES' — reverse-lookup of errno 13 (permission denied)"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [13]
  expected: "EACCES"

invariant errno_extra4.errorcode.enospc_lookup:
  description: "errno.errorcode[28] == 'ENOSPC' — reverse-lookup of errno 28 (no space left)"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [28]
  expected: "ENOSPC"

invariant errno_extra4.errorcode.epipe_lookup:
  description: "errno.errorcode[32] == 'EPIPE' — reverse-lookup of errno 32 (broken pipe)"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [32]
  expected: "EPIPE"

# ---------------------------------------------------------------------------
# Positivity checks — ESRCH, EINTR, EIO not yet covered
# errno_extra2 covers EPERM, ENOENT, EACCES; new here: ESRCH, EINTR, EIO.
# ---------------------------------------------------------------------------

invariant errno_extra4.ESRCH_positive:
  description: "errno.ESRCH > 0 — ESRCH == 3 is a positive integer"
  category: positivity
  kind: python_call_eq
  function: ESRCH.__gt__
  args: [0]
  expected: true

invariant errno_extra4.EINTR_positive:
  description: "errno.EINTR > 0 — EINTR == 4 is a positive integer"
  category: positivity
  kind: python_call_eq
  function: EINTR.__gt__
  args: [0]
  expected: true

invariant errno_extra4.EIO_positive:
  description: "errno.EIO > 0 — EIO == 5 is a positive integer"
  category: positivity
  kind: python_call_eq
  function: EIO.__gt__
  args: [0]
  expected: true
