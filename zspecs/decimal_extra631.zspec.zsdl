spec: decimal_extra631
version: ">=3.9"
backend: python_module(decimal)
docs: "Behavioral spec for decimal signal class identity and module membership"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Decimal signal classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Signal classes are verified as type objects via __class__.__name__"
    - "__module__ confirms all signal classes belong to the decimal namespace"
  created_at: "2026-04-12T00:00:00Z"

table decimal_extra631.signal_class_identity:
  description: "Class identity checks confirming decimal signal classes are type objects"
  kind: python_call_eq
  category: class_identity
  id_prefix: de631sg
  columns: [id, function, args, expected]
  rows:
    - [de631sg001, decimal.InvalidOperation.__class__.__name__.__eq__, ["type"], true]
    - [de631sg002, decimal.DivisionByZero.__class__.__name__.__eq__, ["type"], true]
    - [de631sg003, decimal.Overflow.__class__.__name__.__eq__, ["type"], true]
    - [de631sg004, decimal.Underflow.__class__.__name__.__eq__, ["type"], true]
    - [de631sg005, decimal.Inexact.__class__.__name__.__eq__, ["type"], true]
    - [de631sg006, decimal.Rounded.__class__.__name__.__eq__, ["type"], true]
    - [de631sg007, decimal.Subnormal.__class__.__name__.__eq__, ["type"], true]
    - [de631sg008, decimal.FloatOperation.__class__.__name__.__eq__, ["type"], true]

table decimal_extra631.signal_module_identity:
  description: "Module identity checks confirming decimal signal classes belong to the decimal namespace"
  kind: python_call_eq
  category: module_identity
  id_prefix: de631cx
  columns: [id, function, args, expected]
  rows:
    - [de631cx001, decimal.InvalidOperation.__module__.__eq__, ["decimal"], true]
    - [de631cx002, decimal.DivisionByZero.__module__.__eq__, ["decimal"], true]
    - [de631cx003, decimal.Overflow.__module__.__eq__, ["decimal"], true]
    - [de631cx004, decimal.Underflow.__module__.__eq__, ["decimal"], true]
    - [de631cx005, decimal.Inexact.__module__.__eq__, ["decimal"], true]
    - [de631cx006, decimal.Rounded.__module__.__eq__, ["decimal"], true]
