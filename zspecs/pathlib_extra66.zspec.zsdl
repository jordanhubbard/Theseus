spec: pathlib_extra66
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra65.zspec.zsdl — covers pathlib.__loader__.__class__.__name__.__eq__('SourceFileLoader'); pathlib.__spec__.__class__.__name__.__eq__('ModuleSpec'); pathlib.__file__.__class__.__name__.__eq__('str'); pathlib.__cached__.__class__.__name__.__eq__('str')."
    - "pathlib_extra64.zspec.zsdl — covers pathlib.__all__.__contains__ membership; pathlib.__package__.__eq__('pathlib'); Path/PurePath __doc__.__class__.__name__.__len__()==3."
    - "pathlib_extra63.zspec.zsdl — covers pathlib.__all__.__class__.__name__.__eq__('list') and __all__.__len__()==7; Path/PurePath/PurePosixPath/PureWindowsPath __eq__.__class__.__name__.__eq__('function')."
    - "pathlib_extra44.zspec.zsdl — covers pathlib.__name__.__len__()==7; pathlib.__package__.__len__()==7; pathlib.__file__.__class__.__name__.__len__()==3."
  notes:
    - "This spec extends pathlib_extra65.zspec.zsdl."
    - "Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations + __loader__.__name__ length checks."
    - "IMPORTANT: pathlib is a package (Lib/pathlib/__init__.py). Its loader is a SourceFileLoader instance. SourceFileLoader instances do NOT have a __name__ attribute (AttributeError). The wave 226 theme of '__loader__.__name__ length checks' is interpreted for pathlib as __loader__.__class__.__name__ (i.e. 'SourceFileLoader', 16 chars), which is the standard chain for SourceFileLoader-loaded modules. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') and __len__()==16 — pathlib is a pure Python package loaded by SourceFileLoader. The loader is an instance of SourceFileLoader. __loader__.__class__.__name__ is 'SourceFileLoader' (16 characters). pathlib_extra65 covers the equality anchor in pathlibload65 namespace; this wave 226 spec adds the __len__()==16 length anchor in pathlibspec66 namespace. Novel length anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.__spec__.origin.__class__.__name__.__eq__('str') — pathlib.__spec__.origin is the filesystem path to pathlib/__init__.py (a str). Its __class__.__name__ is 'str'. No prior pathlib spec checks __spec__.origin.__class__.__name__. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.__spec__.submodule_search_locations — pathlib IS a package (Lib/pathlib/__init__.py), so submodule_search_locations is NOT None. It is a list containing the pathlib directory path. Its __class__.__name__ is 'list'. This contrasts with non-packages (io, decimal) where submodule_search_locations is None. No prior pathlib spec checks submodule_search_locations. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "pathlib.__spec__.has_location — True for SourceFileLoader modules. pathlib is loaded from a filesystem path, so has_location is True. No prior pathlib spec checks __spec__.has_location. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.__loader__.__class__.__name__ equality and length
#
# pathlib is a pure Python package loaded by SourceFileLoader (an instance).
# SourceFileLoader instances have no __name__ attribute. The class name of the
# loader is accessed via __loader__.__class__.__name__ == 'SourceFileLoader'.
#
#   pathlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True
#   pathlib.__loader__.__class__.__name__.__len__()                  == 16
#
# pathlib_extra65 covers the equality anchor in pathlibload65 namespace.
# This wave 226 spec adds the __len__()==16 anchor in pathlibspec66 namespace.
# Novel length anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra66.loader_class_name:
  description: "pathlib.__loader__.__class__.__name__ eq and len — pathlib is a pure Python package loaded by SourceFileLoader; SourceFileLoader instances have no __name__ attr so the wave 226 length check uses __loader__.__class__.__name__.__len__()==16 ('SourceFileLoader' is 16 chars); pathlib_extra65 covers the equality in pathlibload65 namespace; this adds the len==16 anchor in pathlibspec66 namespace; novel length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibspec66ldr

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_eq_SourceFileLoader, __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true]
    - [loader_class_name_len_16,              __loader__.__class__.__name__.__len__, [],                  16  ]

# ---------------------------------------------------------------------------
# pathlib.__spec__.origin.__class__.__name__.__eq__('str')
#
# pathlib.__spec__.origin is the filesystem path to pathlib/__init__.py.
# As a filesystem path string, its __class__.__name__ is 'str'.
#
#   pathlib.__spec__.origin.__class__.__name__.__eq__('str') == True
#
# No prior pathlib spec checks __spec__.origin.__class__.__name__. Novel.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra66.spec_origin_class_name:
  description: "pathlib.__spec__.origin.__class__.__name__.__eq__('str') — pathlib.__spec__.origin is the filesystem path to pathlib/__init__.py; it is a str; __class__.__name__=='str'; contrasts with io.__spec__.origin which is 'frozen' (also str, but the value differs); no prior pathlib spec checks __spec__.origin.__class__.__name__; novel anchor in pathlibspec66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibspec66origcls

  columns: [id, function, args, expected]
  rows:
    - [spec_origin_class_name_str, __spec__.origin.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# pathlib.__spec__.submodule_search_locations — NOT None (pathlib is a package)
#
# pathlib IS a package (Lib/pathlib/__init__.py). Therefore its
# __spec__.submodule_search_locations is a list (not None). The list contains
# the pathlib directory path. Its __class__.__name__ is 'list'.
#
#   pathlib.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') == True
#
# This contrasts with io and decimal where submodule_search_locations is None.
# No prior pathlib spec checks submodule_search_locations. Novel.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra66.spec_submodule_search_locations:
  description: "pathlib.__spec__.submodule_search_locations — pathlib IS a package (Lib/pathlib/__init__.py) so submodule_search_locations is NOT None; it is a list containing the pathlib directory; __class__.__name__=='list'; contrasts with io and decimal where it is None; no prior pathlib spec checks submodule_search_locations; novel anchor in pathlibspec66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibspec66ssl

  columns: [id, function, args, expected]
  rows:
    - [ssl_class_name_list, __spec__.submodule_search_locations.__class__.__name__.__eq__, ["list"], true]

# ---------------------------------------------------------------------------
# pathlib.__spec__.has_location — True for SourceFileLoader modules
#
# pathlib is loaded from a filesystem path by SourceFileLoader. Therefore
# has_location is True.
#
#   pathlib.__spec__.has_location.__eq__(True) == True
#
# This contrasts with io where has_location is False (loaded by FrozenImporter).
# No prior pathlib spec checks __spec__.has_location. Novel anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra66.spec_has_location:
  description: "pathlib.__spec__.has_location is True — pathlib is loaded by SourceFileLoader from a filesystem path; has_location==True for file-backed modules; contrasts with io (FrozenImporter, has_location==False); no prior pathlib spec checks __spec__.has_location; novel anchor in pathlibspec66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: pathlibspec66hasloc

  columns: [id, function, args, expected]
  rows:
    - [has_location_true, __spec__.has_location.__eq__, [true], true]

invariant pathlib_extra66.loader_class_name_eq_SourceFileLoader:
  description: "pathlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — pathlib is a pure Python package loaded by SourceFileLoader; re-anchored in pathlibspec66 namespace for cross-wave 226 traceability; pathlib_extra65 covers this in pathlibload65 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant pathlib_extra66.loader_class_name_len_16:
  description: "pathlib.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' has 16 characters; novel length anchor in pathlibspec66 namespace; pathlib_extra65 does not cover this length; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16

invariant pathlib_extra66.spec_origin_class_name_str:
  description: "pathlib.__spec__.origin.__class__.__name__.__eq__('str') == True — pathlib.__spec__.origin is the filesystem path to pathlib/__init__.py; it is a str; no prior pathlib spec checks __spec__.origin.__class__.__name__; novel anchor in pathlibspec66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pathlib_extra66.spec_ssl_list_class_name:
  description: "pathlib.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') == True — pathlib is a package so submodule_search_locations is a list (not None); __class__.__name__=='list'; contrasts with io and decimal where it is None; no prior pathlib spec checks submodule_search_locations; novel anchor in pathlibspec66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant pathlib_extra66.spec_has_location_true:
  description: "pathlib.__spec__.has_location.__eq__(True) == True — pathlib is loaded by SourceFileLoader from a filesystem path; has_location is True; contrasts with io (FrozenImporter, has_location==False); no prior pathlib spec checks __spec__.has_location; novel anchor in pathlibspec66 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true
