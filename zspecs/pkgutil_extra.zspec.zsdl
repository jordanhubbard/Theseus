spec: pkgutil_extra
version: ">=3.9"
backend: python_module(pkgutil)

docs: https://docs.python.org/3/library/pkgutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pkgutil.html — Python pkgutil module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pkgutil.py"
  notes:
    - "This spec extends pkgutil.zspec.zsdl — it does NOT duplicate invariants already present there."
    - "pkgutil.zspec.zsdl covers: walk_packages, iter_modules, get_data, extend_path, resolve_name __name__ and type checks; ModuleInfo _fields length and items; resolve_name('builtins.len') behavior; extend_path returns list."
    - "This spec adds: walk_packages/__qualname__, extend_path/__qualname__, iter_modules/__qualname__, read_code/__name__ (Python 3.9+ private but importable), get_data/__qualname__, ModuleInfo.__module__, ImpImporter class name check (deprecated, present <3.12)."
    - "pkgutil.get_loader was deprecated in Python 3.12 and removed in 3.14; it is excluded from this spec."
    - "pkgutil.find_loader was deprecated in Python 3.12 and removed in 3.14; it is excluded from this spec."
    - "walk_packages, iter_modules, get_data, extend_path, resolve_name are all plain Python functions; their __qualname__ equals their __name__ (top-level functions)."
    - "ModuleInfo.__module__ == 'pkgutil' — the namedtuple is defined in the pkgutil module."
    - "read_code is a public function in pkgutil on Python 3.9+ that reads a .pyc code object from an open file."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ checks — top-level functions have qualname == name
# ---------------------------------------------------------------------------

table pkgutil_extra.function_qualnames:
  kind: python_call_eq
  category: functions
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [walk_packages, walk_packages.__qualname__.__eq__, ["walk_packages"], true]
    - [iter_modules,  iter_modules.__qualname__.__eq__,  ["iter_modules"],  true]
    - [get_data,      get_data.__qualname__.__eq__,      ["get_data"],      true]
    - [extend_path,   extend_path.__qualname__.__eq__,   ["extend_path"],   true]
    - [resolve_name,  resolve_name.__qualname__.__eq__,  ["resolve_name"],  true]

# ---------------------------------------------------------------------------
# read_code function — name check (Python 3.9+ public function)
# ---------------------------------------------------------------------------

invariant pkgutil_extra.read_code.name:
  description: "pkgutil.read_code.__name__ == 'read_code'"
  category: functions
  kind: python_call_eq
  function: read_code.__name__.__eq__
  args: ["read_code"]
  expected: true

invariant pkgutil_extra.read_code.qualname:
  description: "pkgutil.read_code.__qualname__ == 'read_code' — top-level function"
  category: functions
  kind: python_call_eq
  function: read_code.__qualname__.__eq__
  args: ["read_code"]
  expected: true

invariant pkgutil_extra.read_code.is_function:
  description: "type(pkgutil.read_code).__name__ == 'function'"
  category: functions
  kind: python_call_eq
  function: read_code.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# ModuleInfo namedtuple — module affiliation and field names
# (pkgutil.zspec.zsdl covers _fields length, _fields[1] and _fields[2];
#  this spec adds __module__ and _fields[0])
# ---------------------------------------------------------------------------

invariant pkgutil_extra.ModuleInfo.module:
  description: "pkgutil.ModuleInfo.__module__ == 'pkgutil'"
  category: ModuleInfo
  kind: python_call_eq
  function: ModuleInfo.__module__.__eq__
  args: ["pkgutil"]
  expected: true

invariant pkgutil_extra.ModuleInfo.field_module_finder:
  description: "pkgutil.ModuleInfo._fields[0] == 'module_finder' — first field is 'module_finder'"
  category: ModuleInfo
  kind: python_call_eq
  function: ModuleInfo._fields.__getitem__
  args: [0]
  expected: "module_finder"

# ---------------------------------------------------------------------------
# ModuleInfo — qualname is 'ModuleInfo' (top-level namedtuple)
# ---------------------------------------------------------------------------

invariant pkgutil_extra.ModuleInfo.qualname:
  description: "pkgutil.ModuleInfo.__qualname__ == 'ModuleInfo'"
  category: ModuleInfo
  kind: python_call_eq
  function: ModuleInfo.__qualname__.__eq__
  args: ["ModuleInfo"]
  expected: true

# ---------------------------------------------------------------------------
# Function __doc__ checks — all public pkgutil functions are documented
# ---------------------------------------------------------------------------

table pkgutil_extra.function_docs:
  kind: python_call_eq
  category: functions
  id_prefix: has_doc

  columns: [id, function, args, expected]
  rows:
    - [walk_packages, walk_packages.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [iter_modules,  iter_modules.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [get_data,      get_data.__doc__.__class__.__name__.__eq__,      ["str"], true]
    - [extend_path,   extend_path.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [resolve_name,  resolve_name.__doc__.__class__.__name__.__eq__,  ["str"], true]

# ---------------------------------------------------------------------------
# resolve_name — resolves dotted names to attributes
# (pkgutil.zspec.zsdl covers resolve_name('builtins.len') -> __name__ == 'len';
#  this spec tests resolution of a different target)
# ---------------------------------------------------------------------------

invariant pkgutil_extra.resolve_name.builtins_int:
  description: "pkgutil.resolve_name('builtins.int').__name__ == 'int'"
  category: resolve_name
  kind: python_call_eq
  function: resolve_name
  args: ["builtins.int"]
  method: __name__
  expected: "int"

# ---------------------------------------------------------------------------
# resolve_name — bad name raises ModuleNotFoundError or AttributeError
# ---------------------------------------------------------------------------

invariant pkgutil_extra.resolve_name.bad_module_raises:
  description: "pkgutil.resolve_name('_no_such_module_xyz.attr') raises ModuleNotFoundError"
  category: resolve_name
  kind: python_call_raises
  function: resolve_name
  args: ["_no_such_module_xyz.attr"]
  expected: ModuleNotFoundError
