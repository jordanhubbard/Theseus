spec: multiprocessing_extra231
version: ">=3.4"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers multiprocessing.Manager and multiprocessing.cpu_count function identity."
    - "multiprocessing.Manager is a bound method of BaseContext — Manager.__name__ == 'Manager'."
    - "multiprocessing.Manager.__module__ == 'multiprocessing.context' — 23 characters."
    - "multiprocessing.Manager.__class__.__name__ == 'method' — bound method of the default context."
    - "multiprocessing.Manager.__qualname__ == 'BaseContext.Manager' — 19 characters."
    - "multiprocessing.cpu_count.__name__ == 'cpu_count' — 9 characters."
    - "multiprocessing.cpu_count.__module__ == 'multiprocessing.context' — 23 characters."
    - "multiprocessing.cpu_count.__class__.__name__ == 'method' — bound method of the default context."
    - "multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count' — 21 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Manager identity contracts
#
# Manager is a bound method of BaseContext (the default context object).
# Covers __name__, __module__, __class__.__name__, and __qualname__.
# ---------------------------------------------------------------------------

table multiprocessing_extra231.manager_identity:
  description: "multiprocessing.Manager identity: name, module, class, qualname; new to extra231"
  kind: python_call_eq
  category: function_identity
  id_prefix: mpmgr231

  columns: [id, function, args, expected, description]
  rows:
    - [mgr_name_eq,
       Manager.__name__.__eq__,
       ["Manager"],
       true,
       "multiprocessing.Manager.__name__.__eq__('Manager') == True — bound method carries its simple name; new to extra231"]
    - [mgr_module_eq,
       Manager.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.Manager.__module__.__eq__('multiprocessing.context') == True — defined in context submodule; new to extra231"]
    - [mgr_class_name_eq,
       Manager.__class__.__name__.__eq__,
       ["method"],
       true,
       "multiprocessing.Manager.__class__.__name__ == 'method' — bound method of the default context; new to extra231"]
    - [mgr_qualname_eq,
       Manager.__qualname__.__eq__,
       ["BaseContext.Manager"],
       true,
       "multiprocessing.Manager.__qualname__.__eq__('BaseContext.Manager') == True — qualname includes class prefix; new to extra231"]
    - [mgr_name_len_7,
       Manager.__name__.__len__,
       [],
       7,
       "multiprocessing.Manager.__name__.__len__() == 7 — 'Manager' has 7 characters; new to extra231"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.Manager module and qualname lengths
#
# Covers string lengths of module and qualname attributes.
# ---------------------------------------------------------------------------

table multiprocessing_extra231.manager_lengths:
  description: "multiprocessing.Manager module and qualname string lengths; new to extra231"
  kind: python_call_eq
  category: function_identity
  id_prefix: mpmgr231

  columns: [id, function, args, expected, description]
  rows:
    - [mgr_module_len_23,
       Manager.__module__.__len__,
       [],
       23,
       "multiprocessing.Manager.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters; new to extra231"]
    - [mgr_qualname_len_19,
       Manager.__qualname__.__len__,
       [],
       19,
       "multiprocessing.Manager.__qualname__.__len__() == 19 — 'BaseContext.Manager' has 19 characters; new to extra231"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.cpu_count identity contracts
#
# cpu_count is a bound method of BaseContext.
# Covers __name__, __module__, __class__.__name__, and __qualname__.
# ---------------------------------------------------------------------------

table multiprocessing_extra231.cpu_count_identity:
  description: "multiprocessing.cpu_count identity: name, module, class, qualname; new to extra231"
  kind: python_call_eq
  category: function_identity
  id_prefix: mpcpu231

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_name_eq,
       cpu_count.__name__.__eq__,
       ["cpu_count"],
       true,
       "multiprocessing.cpu_count.__name__.__eq__('cpu_count') == True — bound method carries its simple name; new to extra231"]
    - [cpu_module_eq,
       cpu_count.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.cpu_count.__module__.__eq__('multiprocessing.context') == True — defined in context submodule; new to extra231"]
    - [cpu_class_name_eq,
       cpu_count.__class__.__name__.__eq__,
       ["method"],
       true,
       "multiprocessing.cpu_count.__class__.__name__ == 'method' — bound method of the default context; new to extra231"]
    - [cpu_qualname_eq,
       cpu_count.__qualname__.__eq__,
       ["BaseContext.cpu_count"],
       true,
       "multiprocessing.cpu_count.__qualname__.__eq__('BaseContext.cpu_count') == True — qualname includes class prefix; new to extra231"]
    - [cpu_name_len_9,
       cpu_count.__name__.__len__,
       [],
       9,
       "multiprocessing.cpu_count.__name__.__len__() == 9 — 'cpu_count' has 9 characters; new to extra231"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra231
# ---------------------------------------------------------------------------

invariant multiprocessing_extra231.Manager.name:
  description: "multiprocessing.Manager.__name__ == 'Manager'; new to extra231"
  category: function_identity
  kind: python_call_eq
  function: Manager.__name__.__eq__
  args: ["Manager"]
  expected: true

invariant multiprocessing_extra231.Manager.module:
  description: "multiprocessing.Manager.__module__ == 'multiprocessing.context'; new to extra231"
  category: function_identity
  kind: python_call_eq
  function: Manager.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra231.Manager.class_name:
  description: "multiprocessing.Manager.__class__.__name__ == 'method' — bound method; new to extra231"
  category: function_identity
  kind: python_call_eq
  function: Manager.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra231.Manager.qualname:
  description: "multiprocessing.Manager.__qualname__ == 'BaseContext.Manager'; new to extra231"
  category: function_identity
  kind: python_call_eq
  function: Manager.__qualname__.__eq__
  args: ["BaseContext.Manager"]
  expected: true

invariant multiprocessing_extra231.Manager.module_len:
  description: "multiprocessing.Manager.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters; new to extra231"
  category: function_identity
  kind: python_call_eq
  function: Manager.__module__.__len__
  args: []
  expected: 23

invariant multiprocessing_extra231.Manager.qualname_len:
  description: "multiprocessing.Manager.__qualname__.__len__() == 19 — 'BaseContext.Manager' has 19 characters; new to extra231"
  category: function_identity
  kind: python_call_eq
  function: Manager.__qualname__.__len__
  args: []
  expected: 19

invariant multiprocessing_extra231.cpu_count.name:
  description: "multiprocessing.cpu_count.__name__ == 'cpu_count'; new to extra231"
  category: function_identity
  kind: python_call_eq
  function: cpu_count.__name__.__eq__
  args: ["cpu_count"]
  expected: true

invariant multiprocessing_extra231.cpu_count.module:
  description: "multiprocessing.cpu_count.__module__ == 'multiprocessing.context'; new to extra231"
  category: function_identity
  kind: python_call_eq
  function: cpu_count.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra231.cpu_count.class_name:
  description: "multiprocessing.cpu_count.__class__.__name__ == 'method' — bound method; new to extra231"
  category: function_identity
  kind: python_call_eq
  function: cpu_count.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra231.cpu_count.qualname:
  description: "multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count'; new to extra231"
  category: function_identity
  kind: python_call_eq
  function: cpu_count.__qualname__.__eq__
  args: ["BaseContext.cpu_count"]
  expected: true

invariant multiprocessing_extra231.cpu_count.name_len:
  description: "multiprocessing.cpu_count.__name__.__len__() == 9 — 'cpu_count' has 9 characters; new to extra231"
  category: function_identity
  kind: python_call_eq
  function: cpu_count.__name__.__len__
  args: []
  expected: 9

invariant multiprocessing_extra231.cpu_count.module_len:
  description: "multiprocessing.cpu_count.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters; new to extra231"
  category: function_identity
