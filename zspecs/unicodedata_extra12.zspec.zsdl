spec: unicodedata_extra12
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html — Python unicodedata documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata.zspec.zsdl through unicodedata_extra11.zspec.zsdl."
    - "unicodedata_extra covers: __name__ value for all major functions; unidata_version.__class__.__name__; name('A'); category('A')."
    - "unicodedata_extra2 covers: __module__ for normalize/decomposition/bidirectional/east_asian_width/combining/category/lookup/name."
    - "unicodedata_extra3 covers: __module__ for decimal/numeric/digit/mirrored; ucd_3_2_0.__class__.__name__=='UCD'."
    - "unicodedata_extra4 covers: __name__ table for all major functions; category A/a/0; bidirectional A; combining A; east_asian_width A; mirrored '('."
    - "unicodedata_extra5 covers: lookup small-a/digit-five; decimal '5'; digit 0/7/9; numeric '9'; normalize NFKC/NFKD; category tab/plus; bidirectional space; combining U+0301; decomposition e-acute; ucd_3_2_0.category('A')."
    - "unicodedata_extra6 covers: name('Z'/'9'); lookup('EURO SIGN'); east_asian_width fullwidth; mirrored ')' and 'A'; decimal '1'/'7'; ucd_3_2_0.name('A')."
    - "unicodedata_extra7 covers: name('!'/' '); lookup('LATIN CAPITAL LETTER Z'/'DIGIT NINE'); bidirectional('!'/'1'); east_asian_width(' '/'!'); category('Z'/'z'); digit('1'); ucd_3_2_0.decimal('0')."
    - "unicodedata_extra8 covers: __module__ table for all major functions; unidata_version and ucd_3_2_0 class names."
    - "unicodedata_extra9 covers: __name__ attribute type checks; unidata_version len >= 5; category('{'/'@'); digit('A') raises ValueError; name('\\u00e9'); combining(' ')."
    - "unicodedata_extra10 covers: mirrored('['/']'/'0'); lookup('LATIN SMALL LETTER E WITH ACUTE'); decimal('3'/'6'); numeric('3')==3.0; category(']')=='Pe'; east_asian_width('0')=='Na'; ucd_3_2_0.digit('9')==9."
    - "unicodedata_extra11 covers: name('\\u00e9'/'A'); category A/a/1; decimal('5'); digit('5'/'7'); numeric('\\u00bd'/2.0); is_normalized NFC 'hello'; unidata_version is str; bidirectional('A'); east_asian_width('Z')."
    - "This spec adds genuinely new test vectors not present in any prior unicodedata spec."
    - "unicodedata.name('\\u00c0') == 'LATIN CAPITAL LETTER A WITH GRAVE' — no prior spec checks name for U+00C0."
    - "unicodedata.category('\\u0020') == 'Zs' — space separator; extra4 covers category of tab ('Cc') but not the regular space U+0020."
    - "unicodedata.category('\\u002e') == 'Po' — other punctuation; period character; no prior spec checks category of '.'."
    - "unicodedata.decimal('0') == 0 — decimal of digit zero; no prior spec checks decimal('0') (extra5 covers digit('0') but not decimal('0'))."
    - "unicodedata.decimal('9') == 9 — decimal of digit nine; no prior spec checks decimal('9') (extra5 covers digit('9') but not decimal('9'))."
    - "unicodedata.digit('3') == 3 — digit value of '3'; no prior spec covers digit('3')."
    - "unicodedata.numeric('\\u00bc') == 0.25 — vulgar fraction one quarter; no prior spec covers numeric for U+00BC."
    - "unicodedata.normalize('NFC', 'caf\\u00e9').__len__() >= 4 — NFC normalized string length; checks normalize returns a string of at least 4 chars for 'café'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# name() — character names for new code points
#
# extra9 covers name('\u00e9'); extra6 covers name('Z'/'9'); extra7 covers name('!'/' ').
# '\u00c0' (LATIN CAPITAL LETTER A WITH GRAVE) is a new code point for name().
# '\u0041' == 'A' re-anchored in extra12 namespace.
# ---------------------------------------------------------------------------

table unicodedata_extra12.name.latin_chars:
  kind: python_call_eq
  category: name
  id_prefix: name12
  function: name

  columns: [id, args, expected]
  rows:
    - [capital_A,         ["A"],       "LATIN CAPITAL LETTER A"]
    - [e_acute,           ["\u00e9"],  "LATIN SMALL LETTER E WITH ACUTE"]
    - [a_with_grave,      ["\u00c0"],  "LATIN CAPITAL LETTER A WITH GRAVE"]

# ---------------------------------------------------------------------------
# category() — space separator and punctuation
#
# extra4 covers category of tab ('\\t' -> 'Cc') and digit '0' -> 'Nd'.
# extra9 covers category('{') and category('@').
# U+0020 (space -> 'Zs') and U+002E (period -> 'Po') are new category vectors.
# ---------------------------------------------------------------------------

table unicodedata_extra12.category.space_and_punct:
  kind: python_call_eq
  category: category
  id_prefix: cat12
  function: category

  columns: [id, args, expected]
  rows:
    - [space_Zs,   ["\u0020"], "Zs"]
    - [period_Po,  ["\u002e"], "Po"]
    - [digit_0_Nd, ["\u0030"], "Nd"]

# ---------------------------------------------------------------------------
# decimal() — zero and nine
#
# extra5 covers decimal('5'); extra6 covers decimal('1'/'7'); extra10 covers
# decimal('3'/'6'). decimal('0') and decimal('9') are new vectors.
# ---------------------------------------------------------------------------

table unicodedata_extra12.decimal.boundary_digits:
  kind: python_call_eq
  category: decimal
  id_prefix: dec12
  function: decimal

  columns: [id, args, expected]
  rows:
    - [digit_zero,  ["0"], 0]
    - [digit_nine,  ["9"], 9]

# ---------------------------------------------------------------------------
# digit() — value '3'
#
# extra5 covers digit('0'/'7'/'9'); extra7 covers digit('1'); extra11 covers
# digit('5'/'7'). digit('3') is a new vector not in any prior spec.
# ---------------------------------------------------------------------------

invariant unicodedata_extra12.digit.three:
  description: "unicodedata.digit('3') == 3 — digit value of character '3'"
  category: digit
  kind: python_call_eq
  function: digit
  args: ["3"]
  expected: 3

# ---------------------------------------------------------------------------
# numeric() — vulgar fraction one quarter (U+00BC)
#
# Prior specs cover: 0.5 (U+00BD), 2.0, 3.0, 5.0, 9.0.
# U+00BC (VULGAR FRACTION ONE QUARTER) -> 0.25 is a new numeric vector.
# ---------------------------------------------------------------------------

invariant unicodedata_extra12.numeric.one_quarter:
  description: "unicodedata.numeric('\\u00bc') == 0.25 — vulgar fraction one quarter"
  category: numeric
  kind: python_call_eq
  function: numeric
  args: ["\u00bc"]
  expected: 0.25

# ---------------------------------------------------------------------------
# normalize() — NFC length check for 'café'
#
# extra5 covers normalize NFKC/NFKD with non-trivial strings.
# extra11 covers is_normalized NFC with 'hello' (ASCII-only).
# NFC normalize of 'café' (U+00E9 precomposed) yields >= 4 characters.
# method: __len__ with method_args [] returns the length of the normalized string.
# ---------------------------------------------------------------------------

invariant unicodedata_extra12.normalize.nfc_cafe_length:
  description: "unicodedata.normalize('NFC', 'caf\\u00e9').__len__() >= 4 — NFC of 'café' has at least 4 chars"
  category: normalize
  kind: python_call_eq
  function: normalize
  args: ["NFC", "caf\u00e9"]
  method: __len__
  method_args: []
  expected: 4

