spec: bezier_easing
version: ">=2.0.0"
backend: node(bezier-easing)

docs: https://github.com/gre/bezier-easing#readme

provenance:
  derived_from:
    - "bezier-easing README — https://github.com/gre/bezier-easing#readme"
    - "CSS Cubic Bezier — https://www.w3.org/TR/css-easing/"
    - "Test vectors verified with bezier-easing via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "bezier-easing source"
  notes:
    - "Cubic Bezier easing function — same model as CSS cubic-bezier()."
    - "Install: npm install bezier-easing"
    - "Module export IS the factory: bezier(p1x, p1y, p2x, p2y) returns an easing function f(t) for t in [0,1]."
    - "All easing functions satisfy f(0)=0 and f(1)=1 by construction."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; throws on out-of-range control points (x must be in [0,1])."
  stderr: "null"
  stickiness: "N/A — each easing function is reusable."
  codes: {}

# Linear easing — bezier(0, 0, 1, 1) is f(t) = t
invariant bezier_easing.linear_at_quarter:
  description: "Linear easing(0,0,1,1)(0.25) = 0.25"
  category: linear
  kind: node_chain_eq
  entry: module
  entry_args: [0, 0, 1, 1]
  chain:
    - {call: [0.25]}
  expected: 0.25

invariant bezier_easing.linear_at_half:
  description: "Linear easing at 0.5 returns 0.5"
  category: linear
  kind: node_chain_eq
  entry: module
  entry_args: [0, 0, 1, 1]
  chain:
    - {call: [0.5]}
  expected: 0.5

# All easings satisfy f(0)=0 and f(1)=1
invariant bezier_easing.ease_in_out_at_zero:
  description: "ease-in-out (0.25,0.1,0.25,1) at 0 = 0"
  category: identity
  kind: node_chain_eq
  entry: module
  entry_args: [0.25, 0.1, 0.25, 1.0]
  chain:
    - {call: [0]}
  expected: 0

invariant bezier_easing.ease_in_out_at_one:
  description: "ease-in-out at 1 = 1"
  category: identity
  kind: node_chain_eq
  entry: module
  entry_args: [0.25, 0.1, 0.25, 1.0]
  chain:
    - {call: [1]}
  expected: 1

# ease-in-out at midpoint — known approximate
invariant bezier_easing.ease_in_out_at_half:
  description: "ease-in-out (0.25,0.1,0.25,1) at 0.5 ≈ 0.8024"
  category: known_value
  kind: node_chain_eq
  entry: module
  entry_args: [0.25, 0.1, 0.25, 1.0]
  chain:
    - {call: [0.5]}
    - {method: toFixed, args: [4]}
  expected: "0.8024"

# ease-in only (CSS 'ease-in')
invariant bezier_easing.css_ease_in_at_zero:
  description: "CSS ease-in (0.42, 0, 1, 1) at 0 = 0"
  category: identity
  kind: node_chain_eq
  entry: module
  entry_args: [0.42, 0, 1.0, 1.0]
  chain:
    - {call: [0]}
  expected: 0

invariant bezier_easing.css_ease_in_at_one:
  description: "CSS ease-in (0.42, 0, 1, 1) at 1 = 1"
  category: identity
  kind: node_chain_eq
  entry: module
  entry_args: [0.42, 0, 1.0, 1.0]
  chain:
    - {call: [1]}
  expected: 1

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:51:53Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
