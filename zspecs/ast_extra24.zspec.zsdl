spec: ast_extra24
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "ast_extra23.zspec.zsdl — covers stmt/expr class __qualname__ values (Module/FunctionDef/AsyncFunctionDef/ClassDef/Return/Import/Assign/If/For/While/AST) as standalone invariants"
    - "ast_extra22.zspec.zsdl — covers NodeVisitor.visit/__qualname__.__eq__ and NodeTransformer.generic_visit/__qualname__.__eq__; qualname __len__() for parse/dump/literal_eval and these two methods"
    - "ast_extra21.zspec.zsdl — covers AST/__qualname__.__eq__ and AST/__qualname__.__len__(); qualname lengths for get_docstring/copy_location/increment_lineno/unparse/fix_missing_locations/walk"
    - "ast_extra20.zspec.zsdl — covers Module/__qualname__.__eq__ standalone; stmt-subclass and expr-subclass qualname tables"
    - "ast_extra19.zspec.zsdl — covers walk/fix_missing_locations/copy_location/increment_lineno/get_docstring __qualname__.__eq__"
    - "ast_extra18.zspec.zsdl — covers parse/__qualname__.__eq__, dump/__qualname__.__eq__, literal_eval/__qualname__.__eq__"
    - "ast_extra17.zspec.zsdl — covers Module/__qualname__; AST/__module__; Module/Expression/Interactive __bases__[0].__name__"
    - "ast_extra16.zspec.zsdl — covers NodeVisitor/__qualname__.__eq__; NodeTransformer/__qualname__.__eq__"
  notes:
    - "This spec extends ast_extra23.zspec.zsdl."
    - "Focus: __module__ attribute invariants for core ast functions and classes (parse, dump, literal_eval, fix_missing_locations, walk, unparse, AST, Module, NodeVisitor, NodeTransformer); __bases__[0].__name__ for NodeVisitor and NodeTransformer; ast.unparse.__qualname__ standalone."
    - "ast.parse.__module__ == 'ast' — no prior ast spec covers parse.__module__ as a standalone __eq__ invariant."
    - "ast.dump.__module__ == 'ast' — no prior ast spec covers dump.__module__ as a standalone __eq__ invariant."
    - "ast.literal_eval.__module__ == 'ast' — no prior ast spec covers literal_eval.__module__ as a standalone __eq__ invariant."
    - "ast.fix_missing_locations.__module__ == 'ast' — no prior ast spec covers fix_missing_locations.__module__ as a standalone __eq__ invariant."
    - "ast.walk.__module__ == 'ast' — no prior ast spec covers walk.__module__ as a standalone __eq__ invariant."
    - "ast.unparse.__module__ == 'ast' — no prior ast spec covers unparse.__module__ as a standalone __eq__ invariant."
    - "ast.unparse.__qualname__ == 'unparse' — ast_extra19 covers unparse/__qualname__.__eq__; distinct standalone in ast_extra24 namespace."
    - "ast.AST.__module__ == 'ast' — ast_extra17 covers AST/__module__ in that namespace; distinct standalone in ast_extra24 namespace."
    - "ast.Module.__module__ == 'ast' — no prior ast spec covers Module.__module__ as a standalone __eq__ invariant."
    - "ast.NodeVisitor.__module__ == 'ast' — no prior ast spec covers NodeVisitor.__module__ as a standalone __eq__ invariant."
    - "ast.NodeTransformer.__module__ == 'ast' — no prior ast spec covers NodeTransformer.__module__ as a standalone __eq__ invariant."
    - "ast.NodeVisitor.__bases__[0].__name__ == 'object' — ast_extra17 covers Module/Expression/Interactive __bases__[0].__name__; NodeVisitor base is new."
    - "ast.NodeTransformer.__bases__[0].__name__ == 'NodeVisitor' — no prior ast spec covers NodeTransformer's direct base class name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Core function __module__ == 'ast' — standalone invariants
# (ast_extra24 namespace)
#
# No prior ast spec covers __module__ for parse/dump/literal_eval/
# fix_missing_locations/walk/unparse as standalone __eq__ invariants.
# All functions are defined in the ast standard library module.
# ---------------------------------------------------------------------------

table ast_extra24.core_function_modules:
  description: "__module__ == 'ast' for core ast module functions"
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [parse,                parse.__module__.__eq__,                ["ast"], true]
    - [dump,                 dump.__module__.__eq__,                 ["ast"], true]
    - [literal_eval,         literal_eval.__module__.__eq__,         ["ast"], true]
    - [fix_missing_locations, fix_missing_locations.__module__.__eq__, ["ast"], true]
    - [walk,                 walk.__module__.__eq__,                 ["ast"], true]
    - [unparse,              unparse.__module__.__eq__,              ["ast"], true]

# ---------------------------------------------------------------------------
# Class __module__ == 'ast' — standalone invariants
# (ast_extra24 namespace)
#
# ast_extra17 covers AST/__module__ in that namespace; distinct in ast_extra24.
# No prior ast spec covers Module/__module__, NodeVisitor/__module__, or
# NodeTransformer/__module__ as standalone __eq__ invariants.
# ---------------------------------------------------------------------------

invariant ast_extra24.AST.module:
  description: "ast.AST.__module__ == 'ast'"
  category: class_modules
  kind: python_call_eq
  function: AST.__module__.__eq__
  args: ["ast"]
  expected: true

invariant ast_extra24.Module.module:
  description: "ast.Module.__module__ == 'ast'"
  category: class_modules
  kind: python_call_eq
  function: Module.__module__.__eq__
  args: ["ast"]
  expected: true

invariant ast_extra24.NodeVisitor.module:
  description: "ast.NodeVisitor.__module__ == 'ast'"
  category: class_modules
  kind: python_call_eq
  function: NodeVisitor.__module__.__eq__
  args: ["ast"]
  expected: true

invariant ast_extra24.NodeTransformer.module:
  description: "ast.NodeTransformer.__module__ == 'ast'"
  category: class_modules
  kind: python_call_eq
  function: NodeTransformer.__module__.__eq__
  args: ["ast"]
  expected: true

# ---------------------------------------------------------------------------
# NodeVisitor and NodeTransformer __bases__[0].__name__
# (ast_extra24 namespace)
#
# ast_extra17 covers Module/Expression/Interactive __bases__[0].__name__.
# NodeVisitor's base is 'object'; NodeTransformer's base is 'NodeVisitor'.
# No prior ast spec covers these two base class names.
# ---------------------------------------------------------------------------

invariant ast_extra24.NodeVisitor.base_is_object:
  description: "ast.NodeVisitor.__bases__[0].__name__ == 'object' — NodeVisitor inherits directly from object"
  category: class_bases
  kind: python_call_eq
  function: "NodeVisitor.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant ast_extra24.NodeTransformer.base_is_NodeVisitor:
  description: "ast.NodeTransformer.__bases__[0].__name__ == 'NodeVisitor' — NodeTransformer inherits from NodeVisitor"
  category: class_bases
  kind: python_call_eq
  function: "NodeTransformer.__bases__[0].__name__.__eq__"
  args: ["NodeVisitor"]
  expected: true

# ---------------------------------------------------------------------------
# ast.unparse __qualname__ — standalone invariant
# (ast_extra24 namespace)
#
# ast_extra19 covers unparse/__qualname__.__eq__ in the ast_extra19 namespace.
# This is a distinct standalone invariant in the ast_extra24 namespace.
# ---------------------------------------------------------------------------

invariant ast_extra24.unparse.qualname:
  description: "ast.unparse.__qualname__ == 'unparse'"
  category: function_qualnames
  kind: python_call_eq
  function: unparse.__qualname__.__eq__
  args: ["unparse"]
  expected: true
