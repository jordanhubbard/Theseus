spec: asyncio_extra1936
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol, __set_name__, __class__ checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "asyncio.Task, Future, Event, Lock, Queue, Semaphore, Condition, BoundedSemaphore, TaskGroup, Timeout, Runner are not descriptor types."
    - "None of the asyncio classes define __get__, __set__, __delete__, or __set_name__ in their own __dict__."
    - "asyncio module __class__.__name__ == 'module'; asyncio class objects have __class__.__name__ == 'type'."
  created_at: "2026-04-12"
error_model: python_exceptions

table asyncio_extra1936.descriptor_get:
  description: "asyncio types __get__ dict-presence checks — none define __get__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1936

  columns: [id, function, args, expected]
  rows:
    - ["as1936001", "asyncio.Task.__dict__.__contains__",             ["__get__"], false]
    - ["as1936002", "asyncio.Future.__dict__.__contains__",           ["__get__"], false]
    - ["as1936003", "asyncio.Event.__dict__.__contains__",            ["__get__"], false]
    - ["as1936004", "asyncio.Lock.__dict__.__contains__",             ["__get__"], false]
    - ["as1936005", "asyncio.Queue.__dict__.__contains__",            ["__get__"], false]
    - ["as1936006", "asyncio.Semaphore.__dict__.__contains__",        ["__get__"], false]
    - ["as1936007", "asyncio.Condition.__dict__.__contains__",        ["__get__"], false]
    - ["as1936008", "asyncio.BoundedSemaphore.__dict__.__contains__", ["__get__"], false]

