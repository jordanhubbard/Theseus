table asyncio_extra1936.class_name:
  description: "__class__.__name__ checks: asyncio module is 'module'; asyncio classes are 'type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: as1936

  columns: [id, function, args, expected]
  rows:
    - ["as1936033", "asyncio.__class__.__name__.__eq__",             ["module"], true]
    - ["as1936034", "asyncio.Task.__class__.__name__.__eq__",        ["type"],   true]
    - ["as1936035", "asyncio.Future.__class__.__name__.__eq__",      ["type"],   true]
