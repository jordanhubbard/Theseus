spec: inspect_extra109
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra108.zspec.zsdl."
    - "This spec covers: inspect.Parameter.kind enum values — POSITIONAL_ONLY (0), POSITIONAL_OR_KEYWORD (1), VAR_POSITIONAL (2), KEYWORD_ONLY (3), VAR_KEYWORD (4) — integer equality using __eq__; _ParameterKind class identity (__class__.__module__ == 'inspect', __class__.__bases__[0].__name__ == 'IntEnum'); inspect.Parameter.empty type identity; enum member .name attributes; wave 261."
    - "int(inspect.Parameter.POSITIONAL_ONLY) == 0. Verified with Python 3.14.3."
    - "int(inspect.Parameter.POSITIONAL_OR_KEYWORD) == 1. Verified with Python 3.14.3."
    - "int(inspect.Parameter.VAR_POSITIONAL) == 2. Verified with Python 3.14.3."
    - "int(inspect.Parameter.KEYWORD_ONLY) == 3. Verified with Python 3.14.3."
    - "int(inspect.Parameter.VAR_KEYWORD) == 4. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind'. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__bases__[0].__name__ == 'IntEnum'. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.__class__.__mro__.__len__() == 6. Verified with Python 3.14.3."
    - "type(inspect.Parameter.empty).__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY'. Verified with Python 3.14.3."
    - "inspect.Parameter.POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD'. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL'. Verified with Python 3.14.3."
    - "inspect.Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY'. Verified with Python 3.14.3."
    - "inspect.Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter.kind enum integer values
#
# Wave 261 theme: inspect.Parameter._ParameterKind is an IntEnum subclass
# defined inside Lib/inspect.py. It defines five members representing the
# possible kinds of parameters a function can have:
#   POSITIONAL_ONLY (0)      — parameters before /
#   POSITIONAL_OR_KEYWORD (1) — regular parameters
#   VAR_POSITIONAL (2)       — *args
#   KEYWORD_ONLY (3)         — parameters after *args or bare *
#   VAR_KEYWORD (4)          — **kwargs
# Because _ParameterKind inherits from IntEnum (which inherits from int),
# each member's __eq__ method compares as an integer.
#
# inspect.Parameter.POSITIONAL_ONLY.__eq__(0) == True
# inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True
# inspect.Parameter.VAR_POSITIONAL.__eq__(2) == True
# inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True
# inspect.Parameter.VAR_KEYWORD.__eq__(4) == True
#
# New to extra109.
# ---------------------------------------------------------------------------

table inspect_extra109.parameter_kind_int_values:
  description: "inspect.Parameter kind enum integer values: POSITIONAL_ONLY==0, POSITIONAL_OR_KEYWORD==1, VAR_POSITIONAL==2, KEYWORD_ONLY==3, VAR_KEYWORD==4; IntEnum __eq__ compares as integer; wave 261; new to extra109"
  kind: python_call_eq
  category: int_equality
  id_prefix: inspectpkv109

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_eq_0,
       "Parameter.POSITIONAL_ONLY.__eq__",
       [0],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__eq__(0) == True — POSITIONAL_ONLY is the first _ParameterKind enum member with integer value 0; positional-only parameters appear before the / separator; since _ParameterKind extends IntEnum which extends int, its __eq__ compares as an integer; int.__eq__(0) returns True; new to extra109"]
    - [positional_or_keyword_eq_1,
       "Parameter.POSITIONAL_OR_KEYWORD.__eq__",
       [1],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.__eq__(1) == True — POSITIONAL_OR_KEYWORD is the _ParameterKind member with integer value 1; these are regular parameters that can be passed positionally or by keyword; _ParameterKind inherits from IntEnum so __eq__ compares as integer; int.__eq__(1) returns True; new to extra109"]
    - [var_positional_eq_2,
       "Parameter.VAR_POSITIONAL.__eq__",
       [2],
       true,
       "inspect.Parameter.VAR_POSITIONAL.__eq__(2) == True — VAR_POSITIONAL is the _ParameterKind member with integer value 2; it represents *args parameters that collect extra positional arguments; _ParameterKind extends IntEnum so __eq__ compares as integer; int.__eq__(2) returns True; new to extra109"]
    - [keyword_only_eq_3,
       "Parameter.KEYWORD_ONLY.__eq__",
       [3],
       true,
       "inspect.Parameter.KEYWORD_ONLY.__eq__(3) == True — KEYWORD_ONLY is the _ParameterKind member with integer value 3; keyword-only parameters appear after *args or a bare * in the function signature; _ParameterKind extends IntEnum so __eq__ compares as integer; int.__eq__(3) returns True; new to extra109"]
    - [var_keyword_eq_4,
       "Parameter.VAR_KEYWORD.__eq__",
       [4],
       true,
       "inspect.Parameter.VAR_KEYWORD.__eq__(4) == True — VAR_KEYWORD is the _ParameterKind member with integer value 4; it represents **kwargs parameters that collect extra keyword arguments; _ParameterKind extends IntEnum so __eq__ compares as integer; int.__eq__(4) returns True; new to extra109"]

# ---------------------------------------------------------------------------
# Table 2: inspect.Parameter._ParameterKind class identity
#
# Wave 261 theme: the _ParameterKind enum class itself can be introspected.
# Its __module__ is 'inspect' (defined in Lib/inspect.py). Its direct base
# class is IntEnum (__bases__[0].__name__ == 'IntEnum'). The MRO of
# _ParameterKind has depth 6: [_ParameterKind, IntEnum, ReprEnum, int,
# Enum, object] — enum types have deep MROs.
#
# inspect.Parameter.POSITIONAL_ONLY.__class__.__module__ == 'inspect'
# inspect.Parameter.POSITIONAL_ONLY.__class__.__bases__[0].__name__ == 'IntEnum'
# inspect.Parameter.POSITIONAL_ONLY.__class__.__mro__.__len__() == 6
#
# New to extra109.
# ---------------------------------------------------------------------------

table inspect_extra109.parameter_kind_class_identity:
  description: "inspect.Parameter._ParameterKind class identity: __module__ == 'inspect'; __bases__[0].__name__ == 'IntEnum'; MRO depth 6; inspect.Parameter.empty type is 'type'; wave 261; new to extra109"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspectpkc109

  columns: [id, function, args, expected, description]
  rows:
    - [pk_class_module_inspect,
       "Parameter.POSITIONAL_ONLY.__class__.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__module__.__eq__('inspect') == True — the _ParameterKind enum class is defined inside Lib/inspect.py; its __module__ is 'inspect'; all five kind members share the same __class__ so this applies to all of them; str.__eq__('inspect') returns True; new to extra109"]
    - [pk_class_base_intenum,
       "Parameter.POSITIONAL_ONLY.__class__.__bases__[0].__name__.__eq__",
       ["IntEnum"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__bases__[0].__name__.__eq__('IntEnum') == True — _ParameterKind directly inherits from IntEnum (from the enum module); this gives each kind member integer comparison semantics via int; __bases__[0].__name__ is 'IntEnum'; str.__eq__('IntEnum') returns True; new to extra109"]
    - [pk_class_mro_len_6,
       "Parameter.POSITIONAL_ONLY.__class__.__mro__.__len__",
       [],
       6,
       "inspect.Parameter.POSITIONAL_ONLY.__class__.__mro__.__len__() == 6 — _ParameterKind's MRO is [_ParameterKind, IntEnum, ReprEnum, int, Enum, object] with length 6; enum types have deep MROs due to the multiple base classes in the enum module hierarchy; int.__eq__(6) returns True; new to extra109"]
    - [pk_class_name_parameterkind,
       "Parameter.VAR_KEYWORD.__class__.__name__.__eq__",
       ["_ParameterKind"],
       true,
       "inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__('_ParameterKind') == True — all five kind members share the same _ParameterKind class; VAR_KEYWORD is the last member (value 4); its __class__.__name__ is '_ParameterKind'; str.__eq__('_ParameterKind') returns True; new to extra109"]
    - [parameter_empty_type_name,
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — inspect.Parameter.empty is a sentinel class object (not an instance); it is a class created with type() whose __class__ is 'type' (the metaclass); it is used to indicate missing default values in parameter signatures; str.__eq__('type') returns True; new to extra109"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter kind enum member .name attributes
#
# Wave 261 theme: each _ParameterKind enum member has a .name attribute
# equal to the member name string (a standard enum property). The names
# are the five strings: 'POSITIONAL_ONLY', 'POSITIONAL_OR_KEYWORD',
# 'VAR_POSITIONAL', 'KEYWORD_ONLY', 'VAR_KEYWORD'.
#
# inspect.Parameter.POSITIONAL_ONLY.name == 'POSITIONAL_ONLY'
# inspect.Parameter.POSITIONAL_OR_KEYWORD.name == 'POSITIONAL_OR_KEYWORD'
# inspect.Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL'
# inspect.Parameter.KEYWORD_ONLY.name == 'KEYWORD_ONLY'
# inspect.Parameter.VAR_KEYWORD.name == 'VAR_KEYWORD'
#
# New to extra109.
# ---------------------------------------------------------------------------

table inspect_extra109.parameter_kind_names:
  description: "inspect.Parameter kind enum member .name attributes: POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD; standard IntEnum .name property; wave 261; new to extra109"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectpkn109

  columns: [id, function, args, expected, description]
  rows:
    - [positional_only_name_eq,
       "Parameter.POSITIONAL_ONLY.name.__eq__",
       ["POSITIONAL_ONLY"],
       true,
       "inspect.Parameter.POSITIONAL_ONLY.name.__eq__('POSITIONAL_ONLY') == True — _ParameterKind inherits from IntEnum which inherits from Enum; all Enum members have a .name attribute equal to the member name string; for POSITIONAL_ONLY the name is 'POSITIONAL_ONLY'; str.__eq__('POSITIONAL_ONLY') returns True; new to extra109"]
    - [positional_or_keyword_name_eq,
       "Parameter.POSITIONAL_OR_KEYWORD.name.__eq__",
       ["POSITIONAL_OR_KEYWORD"],
       true,
       "inspect.Parameter.POSITIONAL_OR_KEYWORD.name.__eq__('POSITIONAL_OR_KEYWORD') == True — POSITIONAL_OR_KEYWORD is the _ParameterKind member for regular parameters; its .name is 'POSITIONAL_OR_KEYWORD'; str.__eq__('POSITIONAL_OR_KEYWORD') returns True; new to extra109"]
    - [var_positional_name_eq,
       "Parameter.VAR_POSITIONAL.name.__eq__",
       ["VAR_POSITIONAL"],
       true,
       "inspect.Parameter.VAR_POSITIONAL.name.__eq__('VAR_POSITIONAL') == True — VAR_POSITIONAL is the _ParameterKind member for *args parameters; its .name is 'VAR_POSITIONAL'; str.__eq__('VAR_POSITIONAL') returns True; new to extra109"]
    - [keyword_only_name_eq,
       "Parameter.KEYWORD_ONLY.name.__eq__",
       ["KEYWORD_ONLY"],
       true,
       "inspect.Parameter.KEYWORD_ONLY.name.__eq__('KEYWORD_ONLY') == True — KEYWORD_ONLY is the _ParameterKind member for parameters after *args or bare *; its .name is 'KEYWORD_ONLY'; str.__eq__('KEYWORD_ONLY') returns True; new to extra109"]
    - [var_keyword_name_eq,
       "Parameter.VAR_KEYWORD.name.__eq__",
       ["VAR_KEYWORD"],
       true,
       "inspect.Parameter.VAR_KEYWORD.name.__eq__('VAR_KEYWORD') == True — VAR_KEYWORD is the _ParameterKind member for **kwargs parameters; its .name is 'VAR_KEYWORD'; str.__eq__('VAR_KEYWORD') returns True; new to extra109"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra109
# ---------------------------------------------------------------------------

invariant inspect_extra109.positional_only_int_0:
  description: "inspect.Parameter.POSITIONAL_ONLY.__eq__(0) == True — POSITIONAL_ONLY has integer value 0; wave 261; new to extra109"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__eq__
  args: [0]
  expected: true

invariant inspect_extra109.var_keyword_int_4:
  description: "inspect.Parameter.VAR_KEYWORD.__eq__(4) == True — VAR_KEYWORD has integer value 4; the highest-valued kind; wave 261; new to extra109"
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.__eq__
  args: [4]
  expected: true

invariant inspect_extra109.pk_class_base_intenum:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__bases__[0].__name__ == 'IntEnum' — _ParameterKind directly inherits from IntEnum; wave 261; new to extra109"
  kind: python_call_eq
  function: "Parameter.POSITIONAL_ONLY.__class__.__bases__[0].__name__.__eq__"
  args: ["IntEnum"]
  expected: true

invariant inspect_extra109.pk_class_mro_len:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__mro__.__len__() == 6 — [_ParameterKind, IntEnum, ReprEnum, int, Enum, object]; enum MRO depth; wave 261; new to extra109"
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__mro__.__len__
  args: []
  expected: 6

invariant inspect_extra109.var_positional_name:
  description: "inspect.Parameter.VAR_POSITIONAL.name == 'VAR_POSITIONAL' — enum member .name attribute; *args kind; wave 261; new to extra109"
  kind: python_call_eq
  function: Parameter.VAR_POSITIONAL.name.__eq__
  args: ["VAR_POSITIONAL"]
  expected: true
