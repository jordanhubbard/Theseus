spec: abc_extra144
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers abc class __dict__ sizes and __dict__.__class__.__name__ attributes. abc.ABCMeta.__dict__.__len__()==11 (mappingproxy; keys: __module__, __firstlineno__, __doc__, __new__, register, __instancecheck__, __subclasscheck__, _dump_registry, _abc_registry_clear, _abc_caches_clear, __static_attributes__). abc.ABC.__dict__.__len__()==7 (mappingproxy; keys: __module__, __firstlineno__, __doc__, __slots__, __static_attributes__, __abstractmethods__, _abc_impl). abc.abstractmethod.__dict__.__len__()==0 (plain dict, empty; abstractmethod is a C-level decorator function whose __dict__ is a regular empty dict, not a mappingproxy). abc.abstractproperty.__dict__.__len__()==7 (mappingproxy, tied with ABC at 7; keys: __module__, __firstlineno__, __doc__, __isabstractmethod__, __static_attributes__, __dict__, __weakref__). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.abstractmethod.__dict__.__class__.__name__=='dict' (plain dict, NOT mappingproxy — abstractmethod is a function/class and its __dict__ is a regular dict, not a class mappingproxy). abc.ABCMeta.__dict__.__class__.__name__=='mappingproxy' and abc.ABC.__dict__.__class__.__name__=='mappingproxy' (type.__dict__ for classes always returns a mappingproxy). abc.abstractproperty.__dict__.__class__.__name__=='mappingproxy' (it is a class). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta and abc.ABC __dict__ sizes — extra144
#
# abc.ABCMeta.__dict__.__len__()          == 11
# abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'
# abc.ABC.__dict__.__len__()              == 7
# abc.ABC.__dict__.__class__.__name__     == 'mappingproxy'
# ---------------------------------------------------------------------------

table abc_extra144.abc_abcmeta_and_abc_dicts:
  description: "abc.ABCMeta and abc.ABC __dict__ size and type checks in abc_dict144 namespace — abc.ABCMeta.__dict__.__len__()==11 (11 entries in the ABCMeta class namespace mappingproxy: '__module__', '__firstlineno__', '__doc__', '__new__', 'register', '__instancecheck__', '__subclasscheck__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear', '__static_attributes__'; these are all the methods and attributes ABCMeta adds beyond what type already provides); abc.ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy')==True (class __dict__ is always a mappingproxy); abc.ABC.__dict__.__len__()==7 (7 entries: '__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl'; ABC is a thin helper class using ABCMeta as metaclass); abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy')==True; the __len__() count for ABCMeta(11) > abstractproperty(7, tied with ABC) > abstractmethod(0); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc_dict144

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_len,  abc.ABCMeta.__dict__.__len__,                         [],               11,    "abc.ABCMeta.__dict__.__len__() == 11; verified with Python 3.14.3"]
    - [abcmeta_dict_cls,  abc.ABCMeta.__dict__.__class__.__name__.__eq__,        ["mappingproxy"],  true,  "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [abc_dict_len,      abc.ABC.__dict__.__len__,                              [],               7,     "abc.ABC.__dict__.__len__() == 7; verified with Python 3.14.3"]
    - [abc_dict_cls,      abc.ABC.__dict__.__class__.__name__.__eq__,            ["mappingproxy"],  true,  "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractmethod and abc.abstractproperty __dict__ — extra144
#
# abc.abstractmethod.__dict__.__len__()          == 0
# abc.abstractmethod.__dict__.__class__.__name__ == 'dict'     (NOT mappingproxy)
# abc.abstractproperty.__dict__.__len__()        == 7
# abc.abstractproperty.__dict__.__class__.__name__ == 'mappingproxy'
# ---------------------------------------------------------------------------

table abc_extra144.abc_abstractmethod_and_abstractproperty_dicts:
  description: "abc.abstractmethod and abc.abstractproperty __dict__ size and type checks in abc_dict144 namespace — abc.abstractmethod.__dict__.__len__()==0 (abc.abstractmethod is a function/decorator class; its instance __dict__ is a plain empty dict with 0 entries — there are no extra attributes attached to the abstractmethod callable itself; the __isabstractmethod__ flag is placed on decorated methods, not on abstractmethod's own __dict__); abc.abstractmethod.__dict__.__class__.__name__.__eq__('dict')==True (plain 'dict' NOT 'mappingproxy'; this distinguishes function/callable instance __dict__ from class __dict__); abc.abstractproperty.__dict__.__len__()==7 (7 entries in the abstractproperty class namespace mappingproxy: '__module__', '__firstlineno__', '__doc__', '__isabstractmethod__', '__static_attributes__', '__dict__', '__weakref__'; tied with abc.ABC at 7; abstractproperty is a class, not a function, so its __dict__ is a mappingproxy); abc.abstractproperty.__dict__.__class__.__name__.__eq__('mappingproxy')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc_amd144

  columns: [id, function, args, expected, description]
  rows:
    - [am_dict_len,    abc.abstractmethod.__dict__.__len__,                        [],         0,     "abc.abstractmethod.__dict__.__len__() == 0 (empty plain dict); verified with Python 3.14.3"]
    - [am_dict_cls,    abc.abstractmethod.__dict__.__class__.__name__.__eq__,      ["dict"],   true,  "abc.abstractmethod.__dict__.__class__.__name__ == 'dict' (NOT mappingproxy); verified with Python 3.14.3"]
    - [ap_dict_len,    abc.abstractproperty.__dict__.__len__,                      [],         7,     "abc.abstractproperty.__dict__.__len__() == 7 (tied with abc.ABC); verified with Python 3.14.3"]
    - [ap_dict_cls,    abc.abstractproperty.__dict__.__class__.__name__.__eq__,    ["mappingproxy"], true, "abc.abstractproperty.__dict__.__class__.__name__ == 'mappingproxy' (it is a class); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta and abc.ABC __dict__.__class__.__name__ cross-check — extra144
#
# abc.ABCMeta.__dict__.__class__.__name__.__len__() == 12  ('mappingproxy' len=12)
# abc.ABC.__dict__.__class__.__name__.__len__()     == 12  ('mappingproxy' len=12)
# abc.abstractproperty.__dict__.__class__.__name__.__len__() == 12
# abc.ABCMeta.__dict__.__len__().__eq__(11)         == True  (standalone eq)
# ---------------------------------------------------------------------------

table abc_extra144.abc_dict_proxy_name_lengths:
  description: "abc class __dict__.__class__.__name__ length checks in abc_dict144 namespace — abc.ABCMeta.__dict__.__class__.__name__.__len__()==12 ('mappingproxy' is 12 chars: 'm'+'a'+'p'+'p'+'i'+'n'+'g'+'p'+'r'+'o'+'x'+'y'=12; all class __dict__ objects return a mappingproxy which has this 12-char type name); abc.ABC.__dict__.__class__.__name__.__len__()==12 (same; all three class types in this spec have mappingproxy __dict__); abc.abstractproperty.__dict__.__class__.__name__.__len__()==12 (also a class, also mappingproxy); abc.ABCMeta.__dict__.__len__.__eq__ is not directly callable here — instead verify with __class__ name length that all class dicts are mappingproxy; abc.abstractmethod.__dict__.__class__.__name__.__len__()==4 ('dict' is 4 chars, not 12; distinguishes the function-instance dict from the class mappingproxy); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc_prxy144

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_prxy_len,  abc.ABCMeta.__dict__.__class__.__name__.__len__,       [],  12,  "abc.ABCMeta.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'=12 chars); verified with Python 3.14.3"]
    - [abc_prxy_len,      abc.ABC.__dict__.__class__.__name__.__len__,            [],  12,  "abc.ABC.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'=12 chars); verified with Python 3.14.3"]
    - [ap_prxy_len,       abc.abstractproperty.__dict__.__class__.__name__.__len__, [], 12,  "abc.abstractproperty.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'=12 chars); verified with Python 3.14.3"]
    - [am_dict_name_len,  abc.abstractmethod.__dict__.__class__.__name__.__len__, [],  4,   "abc.abstractmethod.__dict__.__class__.__name__.__len__() == 4 ('dict'=4 chars, NOT mappingproxy); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra144
# ---------------------------------------------------------------------------

invariant abc_extra144.ABCMeta_dict_len_11:
  description: "abc.ABCMeta.__dict__.__len__() == 11 — abc.ABCMeta.__dict__ has 11 entries (a mappingproxy): '__module__', '__firstlineno__', '__doc__', '__new__', 'register', '__instancecheck__', '__subclasscheck__', '_dump_registry', '_abc_registry_clear', '_abc_caches_clear', '__static_attributes__'; ABCMeta subclasses type (ABCMeta.__bases__[0].__name__=='type') and adds these 11 entries on top of type's own __dict__; abc.ABCMeta.__dict__.__class__.__name__=='mappingproxy'; this is larger than ABC (7) and abstractproperty (7) and abstractmethod (0); NEW in extra144: first standalone abc.ABCMeta __dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__len__
  args: []
  expected: 11

invariant abc_extra144.ABC_dict_len_7:
  description: "abc.ABC.__dict__.__len__() == 7 — abc.ABC.__dict__ has 7 entries (a mappingproxy): '__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl'; abc.ABC is a simple helper class that uses ABCMeta as its metaclass (ABC.__class__.__name__=='ABCMeta'); it subclasses object directly (ABC.__bases__[0].__name__=='object'); abc.ABC.__dict__.__class__.__name__=='mappingproxy'; ABC.__dict__.__len__()==7 ties with abstractproperty.__dict__.__len__()==7; both are fewer than ABCMeta at 11 and more than abstractmethod at 0; NEW in extra144: first standalone abc.ABC __dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__len__
  args: []
  expected: 7

invariant abc_extra144.abstractmethod_dict_len_0:
  description: "abc.abstractmethod.__dict__.__len__() == 0 — abc.abstractmethod.__dict__ is an empty plain dict (0 entries); abc.abstractmethod is a callable (a class used as a decorator); unlike class __dict__ which is a mappingproxy, abstractmethod's instance __dict__ is a plain regular dict with no extra attributes stored on it; abc.abstractmethod.__dict__.__class__.__name__=='dict' (4 chars, not 'mappingproxy' which is 12 chars); the emptiness (0 entries) reflects that abstractmethod stores no instance attributes; compare to class __dict__ sizes: ABCMeta=11, ABC=7, abstractproperty=7; NEW in extra144: first standalone abc.abstractmethod __dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__dict__.__len__
  args: []
  expected: 0

invariant abc_extra144.abstractmethod_dict_class_is_dict:
  description: "abc.abstractmethod.__dict__.__class__.__name__.__eq__('dict') returns True — abc.abstractmethod.__dict__.__class__.__name__ is 'dict' (4 chars); this distinguishes abstractmethod (a callable/decorator) from the actual classes ABCMeta, ABC, and abstractproperty whose __dict__ is a 'mappingproxy'; abstractmethod.__dict__ is a plain dict because abstractmethod is itself a class but its instance __dict__ — the dict returned when you access .__dict__ directly — uses the plain dict; abc.abstractmethod.__dict__.__len__()==0 (empty); abc.ABCMeta.__dict__.__class__.__name__=='mappingproxy' (12 chars) for comparison; NEW in extra144: first standalone abc.abstractmethod __dict__ class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant abc_extra144.abstractproperty_dict_len_7:
  description: "abc.abstractproperty.__dict__.__len__() == 7 — abc.abstractproperty.__dict__ has 7 entries (a mappingproxy): '__module__', '__firstlineno__', '__doc__', '__isabstractmethod__', '__static_attributes__', '__dict__', '__weakref__'; abc.abstractproperty is a class (not just a function), so its __dict__ is a mappingproxy; abc.abstractproperty.__dict__.__class__.__name__=='mappingproxy'; abstractproperty.__dict__.__len__()==7 ties with abc.ABC.__dict__.__len__()==7; both are fewer than ABCMeta (11) and more than abstractmethod (0); abc.abstractproperty.__name__=='abstractproperty' (len=16); abc.abstractproperty.__bases__[0].__name__=='property'; NEW in extra144: first standalone abc.abstractproperty __dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractproperty.__dict__.__len__
  args: []
  expected: 7

invariant abc_extra144.ABCMeta_dict_class_is_mappingproxy:
  description: "abc.ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — abc.ABCMeta.__dict__.__class__.__name__ is 'mappingproxy' (12 chars: the type name of the class __dict__ proxy); all Python class __dict__ objects are instances of mappingproxy, which is a read-only view of the underlying dict; ABCMeta.__dict__.__class__.__name__.__len__()==12; abc.ABC.__dict__.__class__.__name__=='mappingproxy' also (same 12-char type name); abc.abstractmethod.__dict__.__class__.__name__=='dict' (4 chars) for contrast; abc.ABCMeta.__dict__.__len__()==11; NEW in extra144: first standalone abc.ABCMeta __dict__ class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra144.ABC_dict_class_is_mappingproxy:
  description: "abc.ABC.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — abc.ABC.__dict__.__class__.__name__ is 'mappingproxy' (12 chars); abc.ABC is a class, so its __dict__ is a mappingproxy (read-only view of the class namespace); abc.ABC.__dict__.__class__.__name__.__len__()==12; abc.ABC.__dict__.__len__()==7 (7 entries including __slots__ and _abc_impl); abc.abstractproperty.__dict__.__class__.__name__=='mappingproxy' also (tied with ABC at 7 entries and same 12-char class name); abc.abstractmethod.__dict__.__class__.__name__=='dict' (4 chars, not 12) for contrast; NEW in extra144: first standalone abc.ABC __dict__ class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
