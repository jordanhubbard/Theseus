# ---------------------------------------------------------------------------

invariant uuid_extra137.doc_len_1948:
  description: "uuid.__doc__.__len__() == 1948 — module docstring (str) documents RFC 4122 UUIDs, UUID class, uuid1/uuid3/uuid4/uuid5/getnode functions, and SafeUUID enum; 1948 chars; uuid(1948) < socket(2021) < hashlib(2098) by module docstring length; no prior uuid spec anchors this as a standalone; first standalone under uuiddict137"
  category: doc_lengths
  kind: python_call_eq
  function: __doc__.__len__
