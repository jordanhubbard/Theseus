spec: uuid_extra137
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra136.zspec.zsdl — covers uuid.UUID.__lt__/__gt__/__le__/__ge__ comparison operator __qualname__ string equality (all 'UUID.<method>', len 11) / UUID.__int__ __qualname__.__eq__('UUID.__int__') and __len__()==12 / __lt__/__gt__/__le__/__ge__/__eq__ all __class__.__name__=='function' / UUID.__ne__.__class__.__name__=='wrapper_descriptor' (table + invariants)."
    - "uuid_extra135.zspec.zsdl — covers uuid.UUID property descriptor __class__.__name__ == 'property' for hex/urn/variant/version/bytes/fields / UUID.int/__class__.__name__ == 'member_descriptor' / property fget __qualname__ lengths for hex/urn/variant/version/fields/node/time (table + invariants)."
    - "uuid_extra134.zspec.zsdl — covers uuid.UUID.__init__/__str__/__repr__/__hash__/__eq__/__lt__ __qualname__ lengths / __qualname__ equality strings / __slots__ class name/length / UUID.__bases__[0].__name__=='object' (table + invariants)."
    - "uuid_extra133.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5/UUID __doc__.__class__.__name__=='str' / uuid3 vs uuid5 __doc__ inequality and gap (2) / uuid1 vs uuid4 gap (235) / UUID class vs __init__ doc gap (1367)."
    - "uuid_extra132.zspec.zsdl — covers uuid1/uuid4/uuid3/uuid5/getnode __code__.co_consts lengths / co_varnames lengths / UUID.__init__.__code__ attribute counts."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/qualname / UUID method qualname equality and length."
    - "uuid_extra98.zspec.zsdl — covers UUID NAMESPACE constants __class__.__name__, hex values, str() values, version attributes."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality for hex/bytes/bytes_le/fields/node/time/clock_seq/version/variant / type(UUID.hex).__name__=='property'."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality / UUID.__module__.__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / SafeUUID.__name__/__qualname__.__eq__ / SafeUUID.__bases__[0].__name__=='Enum'."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra136."
    - "Wave 309 theme: uuid.UUID class __dict__ contents — UUID.__dict__.__contains__('hex') (True) / __dict__.__contains__('int') (True) / __dict__.__contains__('bytes') (True) / __dict__.__contains__('version') (True) / __dict__.__contains__('__slots__') (True) / __dict__.__contains__('__init__') (True) / UUID.__dict__.__class__.__name__.__eq__('mappingproxy') / uuid.__spec__.name.__eq__('uuid') / uuid.__doc__.__class__.__name__.__eq__('str')."
    - "uuid.UUID.__dict__.__contains__('hex') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('int') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('bytes') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('version') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__slots__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__init__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__spec__.name == 'uuid' (len 4). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(uuid.__doc__) == 1948. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.__dict__ is a mappingproxy (read-only view of the class namespace) with 37 entries. The entries include all property descriptors (hex, bytes, bytes_le, int, fields, node, time, clock_seq, version, variant, urn), the __slots__ tuple, all dunder methods (__init__, __str__, __repr__, __hash__, __eq__, __lt__, __gt__, __le__, __ge__, __int__), and various class-level constants. The mappingproxy prevents direct external modification of the class namespace."
    - "Note: The __dict__.__contains__ method (inherited from the mappingproxy type) returns True when the key is present in the class namespace. Checking '__contains__' calls verifies that specific attributes are present as direct class attributes of UUID (not inherited from object or accessible only via instance attribute lookup)."
    - "Note: uuid.__spec__.name is 'uuid' (4 chars) — the shortest module spec name in the stdlib modules covered by this spec series. For comparison, hashlib.__spec__.name is 'hashlib' (7 chars) and struct.__spec__.name is 'struct' (6 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('hex')
# uuid.UUID.__dict__.__contains__('int')
# uuid.UUID.__dict__.__contains__('bytes')
# uuid.UUID.__dict__.__contains__('version')
#
# Wave 309 theme: uuid.UUID class __dict__ contains core attribute names.
#
# The UUID class __dict__ is a mappingproxy containing all property descriptors
# and slot descriptors defined on the class. hex, int, bytes, and version are
# all present as direct class attributes. extra97 anchors these as property/member
# descriptors; no prior uuid spec anchors __dict__.__contains__ as a table under
# uuiddict137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra137.UUID_dict_contains_core_attributes:
  description: "uuid.UUID.__dict__.__contains__('hex')==True / __dict__.__contains__('int')==True / __dict__.__contains__('bytes')==True / __dict__.__contains__('version')==True — all four are direct class attributes of UUID (not inherited); hex/bytes/version are property descriptors; int is a member_descriptor slot; extra97 anchors their descriptor types; first uuiddict137 anchor for __dict__.__contains__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddict137

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_hex,     UUID.__dict__.__contains__, ["hex"],     true, "uuid.UUID.__dict__.__contains__('hex') == True (property descriptor returning 32-char hex string)"]
    - [dict_contains_int,     UUID.__dict__.__contains__, ["int"],     true, "uuid.UUID.__dict__.__contains__('int') == True (member_descriptor slot storing 128-bit integer)"]
    - [dict_contains_bytes,   UUID.__dict__.__contains__, ["bytes"],   true, "uuid.UUID.__dict__.__contains__('bytes') == True (property descriptor returning 16-byte big-endian form)"]
    - [dict_contains_version, UUID.__dict__.__contains__, ["version"], true, "uuid.UUID.__dict__.__contains__('version') == True (property descriptor returning UUID version 1-5 or None)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('__slots__')
# uuid.UUID.__dict__.__contains__('__init__')
# uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy')
# uuid.UUID.__dict__.__class__.__name__.__len__()==12
#
# Wave 309 theme: uuid.UUID __dict__ contains __slots__ and __init__; is a mappingproxy.
#
# UUID.__dict__ is a mappingproxy (12 chars), the standard read-only class namespace
# view. It contains __slots__ (the tuple of slot names defining the memory layout)
# and __init__ (the constructor). extra94 anchors __slots__ contents; extra134 anchors
# __init__ qualname; no prior uuid spec anchors __dict__.__contains__('__slots__'/
# '__init__') or __dict__.__class__.__name__ as a table under uuiddict137.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra137.UUID_dict_class_and_dunder_contains:
  description: "uuid.UUID.__dict__.__contains__('__slots__')==True / __dict__.__contains__('__init__')==True / __dict__.__class__.__name__.__eq__('mappingproxy')==True / __class__.__name__.__len__()==12 — __slots__ is present (defines the memory layout); __init__ is present (the constructor); __dict__ is a 12-char mappingproxy (read-only class namespace view); extra94 anchors __slots__ contents; first uuiddict137 anchor for dunder contains and dict class"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddict137

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_slots,     UUID.__dict__.__contains__,          ["__slots__"],    true, "uuid.UUID.__dict__.__contains__('__slots__') == True (tuple defining int and is_safe slot storage)"]
    - [dict_contains_init,      UUID.__dict__.__contains__,          ["__init__"],     true, "uuid.UUID.__dict__.__contains__('__init__') == True (UUID constructor, qualname 'UUID.__init__')"]
    - [dict_class_mappingproxy, UUID.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "uuid.UUID.__dict__.__class__.__name__ == 'mappingproxy' (12 chars; read-only class namespace view)"]
    - [dict_class_name_len,     UUID.__dict__.__class__.__name__.__len__, [],           12,   "uuid.UUID.__dict__.__class__.__name__.__len__() is 12 ('mappingproxy' = 12 chars)"]

# ---------------------------------------------------------------------------
# uuid.__spec__.name.__eq__('uuid')
# uuid.__spec__.name.__len__()==4
# uuid.__doc__.__class__.__name__.__eq__('str')
# uuid.__doc__.__len__()==1948
#
# Wave 309 theme: uuid module-level __spec__.name and __doc__ identity.
#
# uuid.__spec__.name is 'uuid' (4 chars) — the shortest module spec name in the
# stdlib modules covered by this spec series (vs hashlib=7, struct=6, socket=6).
# uuid.__doc__ is a 'str' of length 1948, documenting RFC 4122 UUIDs.
# No prior uuid spec anchors __spec__.name equality string or __doc__.__len__()==1948
# as a table under uuiddict137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra137.module_spec_and_doc_identity:
  description: "uuid.__spec__.name.__eq__('uuid')==True / __spec__.name.__len__()==4 / uuid.__doc__.__class__.__name__.__eq__('str')==True / __doc__.__len__()==1948 — __spec__.name 'uuid' (4 chars) is the shortest module spec name among stdlib modules covered by this series; module docstring is a 1948-char str documenting RFC 4122 UUID classes and functions; no prior uuid spec anchors these under uuiddict137"
  kind: python_call_eq
  category: identity
  id_prefix: uuiddict137

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,    __spec__.name.__eq__,              ["uuid"], true, "uuid.__spec__.name == 'uuid' (4 chars; public module name in ModuleSpec)"]
    - [spec_name_len,   __spec__.name.__len__,             [],       4,    "uuid.__spec__.name.__len__() is 4 ('uuid' = 4 chars; shortest in stdlib module series)"]
    - [doc_class_str,   __doc__.__class__.__name__.__eq__, ["str"],  true, "uuid.__doc__.__class__.__name__ == 'str' (module docstring is a regular Python string)"]
    - [doc_len_1948,    __doc__.__len__,                   [],       1948, "uuid.__doc__.__len__() is 1948 (RFC 4122 UUID module docstring; 1948 chars)"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('hex') — standalone
#
# uuid.UUID.__dict__.__contains__('hex') is True. The 'hex' attribute is a property
# descriptor present directly in the UUID class dictionary. It returns the UUID as a
# 32-character lowercase hexadecimal string with no hyphens (e.g.,
# '12345678123412341234123456789abc'). The property fget function has qualname
# 'UUID.hex' (8 chars, anchored in extra97/extra135). No prior uuid spec anchors
# UUID.__dict__.__contains__('hex') as a standalone under uuiddict137.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra137.UUID_dict_contains_hex:
  description: "uuid.UUID.__dict__.__contains__('hex') == True — 'hex' is a direct class attribute (property descriptor); returns 32-char hex string without hyphens; fget qualname 'UUID.hex' (8 chars, anchored extra97/extra135); no prior uuid spec anchors this as a standalone; first standalone under uuiddict137"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["hex"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('int') — standalone
#
# uuid.UUID.__dict__.__contains__('int') is True. The 'int' attribute is a
# member_descriptor (slot descriptor) present directly in the UUID class dictionary.
# It stores the 128-bit integer value that is the fundamental representation of the
# UUID. All other computed UUID attributes (hex, bytes, bytes_le, fields, variant,
# version, etc.) derive from this single int slot. extra94/extra135 anchor UUID.int
# as a member_descriptor; no prior uuid spec anchors UUID.__dict__.__contains__('int')
# as a standalone under uuiddict137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra137.UUID_dict_contains_int:
  description: "uuid.UUID.__dict__.__contains__('int') == True — 'int' is a direct class attribute (member_descriptor slot); stores the fundamental 128-bit UUID integer; all computed attributes derive from this slot; extra94/extra135 anchor UUID.int as member_descriptor; first standalone under uuiddict137"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('version') — standalone
#
# uuid.UUID.__dict__.__contains__('version') is True. The 'version' attribute is a
# property descriptor present directly in the UUID class dictionary. It returns an
# integer (1-5) indicating the UUID version, or raises ValueError if the UUID does
# not have a version (i.e., variant is not RFC_4122). The property fget function
# has qualname 'UUID.version' (12 chars, anchored in extra97/extra135). No prior
# uuid spec anchors UUID.__dict__.__contains__('version') as a standalone under
# uuiddict137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra137.UUID_dict_contains_version:
  description: "uuid.UUID.__dict__.__contains__('version') == True — 'version' is a direct class attribute (property descriptor); returns integer 1-5 or raises ValueError for non-RFC_4122 UUIDs; fget qualname 'UUID.version' (12 chars, anchored extra97/extra135); no prior uuid spec anchors this as a standalone; first standalone under uuiddict137"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["version"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# uuid.UUID.__dict__.__class__.__name__ is 'mappingproxy' (12 chars). The mappingproxy
# type is used for all Python class __dict__ attributes to prevent external code from
# directly modifying the class namespace (e.g., adding or removing class attributes
# without going through type.__setattr__). The 37 entries in UUID.__dict__ include
# all property descriptors, slot descriptors, and dunder methods. extra136 anchors
# socket.socket.__dict__.__class__.__name__ == 'mappingproxy' (for the socket module);
# no prior uuid spec anchors UUID.__dict__.__class__.__name__ == 'mappingproxy'
# as a standalone under uuiddict137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra137.UUID_dict_class_mappingproxy:
  description: "uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy') == True — 'mappingproxy' (12 chars); read-only view of class namespace with 37 entries; prevents direct external modification; same type as all Python class __dict__ attributes; no prior uuid spec anchors this as a standalone; first standalone under uuiddict137"
  category: identity
  kind: python_call_eq
  function: UUID.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.__spec__.name.__eq__('uuid') — standalone
#
# uuid.__spec__.name is 'uuid' (4 chars). The ModuleSpec.name attribute identifies
# the module in the import system. 'uuid' (4 chars) is the shortest module spec name
# among the stdlib modules covered by the current spec series: uuid(4) < struct(6) ==
# socket(6) < hashlib(7). The 4-char name is short because 'uuid' is an acronym
# (Universally Unique IDentifier) that was standardized as a 4-char abbreviation in
# RFC 4122. No prior uuid spec anchors uuid.__spec__.name.__eq__('uuid') as a
# standalone under uuiddict137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra137.spec_name_eq_uuid:
  description: "uuid.__spec__.name.__eq__('uuid') == True — 'uuid' (4 chars); shortest module spec name in the stdlib series: uuid(4) < struct(6) == socket(6) < hashlib(7); 4-char acronym for Universally Unique IDentifier from RFC 4122; no prior uuid spec anchors this as a standalone; first standalone under uuiddict137"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["uuid"]
  expected: true

