spec: inspect_extra2
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect.zspec.zsdl — covers isfunction/isbuiltin/isclass/ismodule/isroutine/isgeneratorfunction/iscoroutinefunction __name__; Signature/Parameter classnames; CO_* constants; false-cases tables"
    - "inspect_extra.zspec.zsdl — covers ismethod/isgenerator/iscoroutine/getsourcefile __name__; ismodule/isclass/isfunction/ismethod/isbuiltin/isgenerator/iscoroutine/getmembers/getdoc/getsourcefile __module__; isclass(int)/isclass(str)/isbuiltin(len)/isfunction(len); Parameter/Signature __name__"
    - "inspect_signature.zspec.zsdl — covers BoundArguments/__name__/__module__, Signature/__module__, Parameter/__module__/__name__, Parameter kind constants, Signature.empty, signature(len)"
  notes:
    - "ismodule(inspect) == True — inspect is a module object; this tests the True case for ismodule."
    - "isbuiltin(print) == True — print is a C-level built-in function (not to be confused with isfunction)."
    - "isclass(type) == True — type is a metaclass and therefore also a class."
    - "isfunction.__qualname__ == 'isfunction' — qualname equals name for module-level functions."
    - "isclass.__qualname__ == 'isclass' — same pattern."
    - "ismodule.__qualname__ == 'ismodule' — same pattern."
    - "isbuiltin.__qualname__ == 'isbuiltin' — same pattern."
    - "ismethod.__qualname__ == 'ismethod' — same pattern."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Behavioral true cases — not covered in inspect.zspec.zsdl or inspect_extra
# ---------------------------------------------------------------------------

invariant inspect_extra2.ismodule.inspect_is_module:
  description: "inspect.ismodule(inspect) == True — inspect is a module object"
  category: behavior
  kind: python_call_eq
  function: ismodule
  args: [inspect]
  expected: true

invariant inspect_extra2.isbuiltin.print_is_builtin:
  description: "inspect.isbuiltin(print) == True — print is a C-level built-in function"
  category: behavior
  kind: python_call_eq
  function: isbuiltin
  args: [print]
  expected: true

invariant inspect_extra2.isclass.type_is_class:
  description: "inspect.isclass(type) == True — type is a metaclass and also a class"
  category: behavior
  kind: python_call_eq
  function: isclass
  args: [type]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ checks — module-level functions have qualname == name
# (inspect.zspec.zsdl covers __name__; __qualname__ is new coverage here)
# ---------------------------------------------------------------------------

table inspect_extra2.function_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [isfunction, isfunction.__qualname__.__eq__, ["isfunction"], true]
    - [ismethod,   ismethod.__qualname__.__eq__,   ["ismethod"],   true]
    - [isclass,    isclass.__qualname__.__eq__,    ["isclass"],    true]
    - [ismodule,   ismodule.__qualname__.__eq__,   ["ismodule"],   true]
    - [isbuiltin,  isbuiltin.__qualname__.__eq__,  ["isbuiltin"],  true]
