spec: tempfile_extra15
version: ">=3.9"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tempfile.html — Python tempfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
    - "tempfile_extra14.zspec.zsdl — covers __qualname__ equality and __len__() for NamedTemporaryFile/TemporaryDirectory/SpooledTemporaryFile/TemporaryFile; tempdir.__class__.__name__.__eq__('NoneType')."
  notes:
    - "This spec extends tempfile_extra14.zspec.zsdl."
    - "Prior specs covered: __qualname__ equality and lengths for class/factory names; __qualname__/__module__ equality for mkstemp/mkdtemp/gettempdir/gettempprefix; tempdir default None."
    - "This spec covers: __all__.__len__()==13; __all__.__class__.__name__.__len__()==4; __doc__.__class__.__name__.__len__()==3; __name__.__len__()==8; SpooledTemporaryFile and TemporaryDirectory __dict__.__class__.__name__.__len__()==12 (mappingproxy); SpooledTemporaryFile.__mro__.__len__()==4; TemporaryDirectory.__mro__.__len__()==2; __bases__[0].__name__ for SpooledTemporaryFile (IOBase, len 6) and TemporaryDirectory (object, len 6); __module__.__len__()==8 for classes and functions; qualname lengths for mkstemp/mkdtemp/gettempdir/gettempprefix/gettempdirb/gettempprefixb; TMP_MAX class name len."
    - "SpooledTemporaryFile.__bases__[0].__name__ == 'IOBase' — SpooledTemporaryFile inherits from io.IOBase. Verified."
    - "TemporaryDirectory.__bases__[0].__name__ == 'object' — TemporaryDirectory inherits directly from object. Verified."
    - "SpooledTemporaryFile.__mro__.__len__() == 4: SpooledTemporaryFile -> io.IOBase -> _io._IOBase -> object. Verified."
    - "TemporaryDirectory.__mro__.__len__() == 2: TemporaryDirectory -> object. Verified."
    - "SpooledTemporaryFile.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Verified."
    - "TemporaryDirectory.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Verified."
    - "tempfile.__name__ == 'tempfile' — len 8. Verified."
    - "All __module__ values for tempfile classes/functions are 'tempfile' (len 8). Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __module__.__len__() for tempfile public functions and classes
#
# All tempfile classes and functions are defined in the tempfile module, so
# __module__ == 'tempfile' (len 8) for each. tempfile_extra13 confirms
# __module__ string equality; this table checks the numeric length.
# ---------------------------------------------------------------------------

table tempfile_extra15.module_lengths:
  description: "__module__.__len__() == 8 for tempfile public functions and classes"
  kind: python_call_eq
  category: module_identity
  id_prefix: tmlen15

  columns: [id, function, args, expected]
  rows:
    - [mkstemp,              mkstemp.__module__.__len__,              [], 8]
    - [mkdtemp,              mkdtemp.__module__.__len__,              [], 8]
    - [gettempdir,           gettempdir.__module__.__len__,           [], 8]
    - [gettempprefix,        gettempprefix.__module__.__len__,        [], 8]
    - [SpooledTemporaryFile, SpooledTemporaryFile.__module__.__len__, [], 8]
    - [TemporaryDirectory,   TemporaryDirectory.__module__.__len__,   [], 8]

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for tempfile utility functions
#
# tempfile_extra13 covers __qualname__ equality for mkstemp/mkdtemp/
# gettempdir/gettempprefix. This table checks the numeric *length* of those
# qualnames — a distinct axis — and adds the byte-path variants.
# Lengths: mkstemp=7, mkdtemp=7, gettempdir=10, gettempprefix=13,
#          gettempdirb=11, gettempprefixb=14.
# ---------------------------------------------------------------------------

table tempfile_extra15.function_qualname_lengths:
  description: "__qualname__.__len__() for tempfile utility functions"
  kind: python_call_eq
  category: qualname
  id_prefix: fqlen15

  columns: [id, function, args, expected]
  rows:
    - [mkstemp,        mkstemp.__qualname__.__len__,        [], 7]
    - [mkdtemp,        mkdtemp.__qualname__.__len__,        [], 7]
    - [gettempdir,     gettempdir.__qualname__.__len__,     [], 10]
    - [gettempprefix,  gettempprefix.__qualname__.__len__,  [], 13]
    - [gettempdirb,    gettempdirb.__qualname__.__len__,    [], 11]
    - [gettempprefixb, gettempprefixb.__qualname__.__len__, [], 14]

# ---------------------------------------------------------------------------
# Standalone: tempfile.__all__.__len__() == 13
#
# tempfile.__all__ has 13 entries. No prior tempfile spec checks __all__.__len__().
# Verified: 13.
# ---------------------------------------------------------------------------

invariant tempfile_extra15.all.len:
  description: "tempfile.__all__.__len__() == 13 — 13 public names exported"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# Standalone: tempfile.__all__.__class__.__name__.__len__() == 4
#
# __all__ is a list object; 'list' has 4 characters.
# No prior tempfile spec checks __all__.__class__.__name__.__len__().
# Verified: 4.
# ---------------------------------------------------------------------------

invariant tempfile_extra15.all.class_name_len:
  description: "tempfile.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list'"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: tempfile.__doc__.__class__.__name__.__len__() == 3
#
# The module docstring is a str object; 'str' has 3 characters.
# No prior tempfile spec checks __doc__.__class__.__name__.__len__().
# Verified: 3.
# ---------------------------------------------------------------------------

invariant tempfile_extra15.doc.class_name_len:
  description: "tempfile.__doc__.__class__.__name__.__len__() == 3 — module docstring is a 'str'"
  category: doc_attrs
  kind: python_call_eq
  function: __doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Standalone: tempfile.__name__.__len__() == 8
#
# tempfile.__name__ == 'tempfile'; 'tempfile' has 8 characters.
# No prior tempfile spec checks __name__.__len__() at the module level.
# Verified: 8.
# ---------------------------------------------------------------------------

invariant tempfile_extra15.module_name_len:
  description: "tempfile.__name__.__len__() == 8 — module name 'tempfile' has 8 characters"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Standalone: tempfile.SpooledTemporaryFile.__dict__.__class__.__name__.__len__() == 12
#
# SpooledTemporaryFile.__dict__ is a mappingproxy; 'mappingproxy' has 12 characters.
# No prior tempfile spec checks __dict__.__class__.__name__.__len__().
# Verified: 12.
# ---------------------------------------------------------------------------

invariant tempfile_extra15.SpooledTemporaryFile.dict_class_name_len:
  description: "tempfile.SpooledTemporaryFile.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters"
  category: class_attrs
  kind: python_call_eq
  function: SpooledTemporaryFile.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Standalone: tempfile.TemporaryDirectory.__dict__.__class__.__name__.__len__() == 12
#
# TemporaryDirectory.__dict__ is also a mappingproxy; 'mappingproxy' has 12 characters.
# No prior tempfile spec checks TemporaryDirectory.__dict__.__class__.__name__.__len__().
# Verified: 12.
# ---------------------------------------------------------------------------

invariant tempfile_extra15.TemporaryDirectory.dict_class_name_len:
  description: "tempfile.TemporaryDirectory.__dict__.__class__.__name__.__len__() == 12 — 'mappingproxy' has 12 characters"
  category: class_attrs
  kind: python_call_eq
  function: TemporaryDirectory.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Standalone: tempfile.SpooledTemporaryFile.__mro__.__len__() == 4
#
# SpooledTemporaryFile MRO: SpooledTemporaryFile -> io.IOBase -> _io._IOBase
# -> object (4 entries). No prior tempfile spec checks __mro__.__len__().
# Verified: 4.
# ---------------------------------------------------------------------------

invariant tempfile_extra15.SpooledTemporaryFile.mro_len:
  description: "tempfile.SpooledTemporaryFile.__mro__.__len__() == 4 — MRO has 4 entries"
  category: class_attrs
  kind: python_call_eq
  function: SpooledTemporaryFile.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: tempfile.TemporaryDirectory.__mro__.__len__() == 2
#
# TemporaryDirectory MRO: TemporaryDirectory -> object (2 entries).
# No prior tempfile spec checks TemporaryDirectory.__mro__.__len__().
# Verified: 2.
# ---------------------------------------------------------------------------

invariant tempfile_extra15.TemporaryDirectory.mro_len:
  description: "tempfile.TemporaryDirectory.__mro__.__len__() == 2 — MRO has 2 entries (TemporaryDirectory + object)"
  category: class_attrs
  kind: python_call_eq
  function: TemporaryDirectory.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Standalone: tempfile.SpooledTemporaryFile.__bases__[0].__name__.__len__() == 6
#
# SpooledTemporaryFile inherits from io.IOBase; 'IOBase' has 6 characters.
# No prior tempfile spec checks __bases__[0].__name__.__len__().
# The base is io.IOBase (not 'object') — SpooledTemporaryFile is a proper IO class.
# Verified: 6.
# ---------------------------------------------------------------------------

invariant tempfile_extra15.SpooledTemporaryFile.base_name_len:
  description: "tempfile.SpooledTemporaryFile.__bases__[0].__name__.__len__() == 6 — base class 'IOBase' has 6 characters"
  category: class_attrs
  kind: python_call_eq
  function: "SpooledTemporaryFile.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Standalone: tempfile.TemporaryDirectory.__bases__[0].__name__.__len__() == 6
#
# TemporaryDirectory inherits directly from object; 'object' has 6 characters.
# No prior tempfile spec checks TemporaryDirectory.__bases__[0].__name__.__len__().
# Verified: 6.
# ---------------------------------------------------------------------------

invariant tempfile_extra15.TemporaryDirectory.base_name_len:
  description: "tempfile.TemporaryDirectory.__bases__[0].__name__.__len__() == 6 — base class 'object' has 6 characters"
  category: class_attrs
  kind: python_call_eq
  function: "TemporaryDirectory.__bases__[0].__name__.__len__"
  args: []
  expected: 6
