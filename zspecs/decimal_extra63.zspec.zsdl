spec: decimal_extra63
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
    - "decimal_extra62.zspec.zsdl — covers Decimal/__name__.__eq__('Decimal'); Decimal/__qualname__/__module__.__contains__('decimal'); Decimal/__bases__[0].__name__=='object'; Decimal/__mro__.__len__()==2; DecimalException/__bases__[0].__name__=='ArithmeticError'; DecimalException/__mro__.__len__()==5; InvalidOperation/DivisionByZero/Overflow/__bases__[0].__name__=='DecimalException'."
    - "decimal_extra61.zspec.zsdl — covers ROUND_* constant __class__/__len__ checks; getcontext/__class__.__name__ check."
    - "decimal_extra60.zspec.zsdl — covers Decimal/__doc__ and ROUND_HALF_UP/ROUND_HALF_EVEN __contains__ checks."
  notes:
    - "This spec extends decimal_extra62.zspec.zsdl."
    - "Theme: decimal exception hierarchy — MRO lengths and __name__/__module__ identity for InvalidOperation/Clamped/Rounded/Inexact; DivisionByZero has MRO length 7 due to also inheriting from ZeroDivisionError."
    - "Decimal and decimal exceptions are C extension types — no __code__."
    - "InvalidOperation.__mro__.__len__() == 6 — MRO is [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]; 6 entries. InvalidOperation inherits directly from DecimalException. No prior decimal spec checks InvalidOperation.__mro__.__len__() in decimalexc63 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Clamped.__mro__.__len__() == 6 — MRO is [Clamped, DecimalException, ArithmeticError, Exception, BaseException, object]; 6 entries. Clamped inherits directly from DecimalException. No prior decimal spec checks Clamped.__mro__.__len__() in decimalexc63 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Rounded.__mro__.__len__() == 6 — MRO is [Rounded, DecimalException, ArithmeticError, Exception, BaseException, object]; 6 entries. Rounded inherits directly from DecimalException. No prior decimal spec checks Rounded.__mro__.__len__() in decimalexc63 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Inexact.__mro__.__len__() == 6 — MRO is [Inexact, DecimalException, ArithmeticError, Exception, BaseException, object]; 6 entries. Inexact inherits directly from DecimalException. No prior decimal spec checks Inexact.__mro__.__len__() in decimalexc63 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "DivisionByZero.__mro__.__len__() == 7 — MRO is [DivisionByZero, DecimalException, ZeroDivisionError, ArithmeticError, Exception, BaseException, object]; 7 entries. DivisionByZero has an extra entry because it also inherits from ZeroDivisionError. No prior decimal spec checks DivisionByZero.__mro__.__len__() in decimalexc63 namespace. Novel anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "InvalidOperation.__name__ == 'InvalidOperation', Clamped.__name__ == 'Clamped', Rounded.__name__ == 'Rounded', Inexact.__name__ == 'Inexact' — all top-level class names. No prior decimal spec checks __name__.__eq__ for these in decimalexc63 namespace. Novel name identity anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "InvalidOperation/__module__.__contains__('decimal') == True — module is 'decimal' or '_decimal'; both contain 'decimal'. No prior decimal spec checks __module__.__contains__('decimal') for InvalidOperation/DivisionByZero/Clamped in decimalexc63 namespace. Novel module identity anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Inexact.__bases__[0].__name__ == 'DecimalException' — Inexact inherits directly from DecimalException. No prior decimal spec checks Inexact.__bases__[0].__name__ in decimalexc63 namespace. Novel hierarchy anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Table row function values containing '[' must be double-quoted per ZSDL rules."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Direct DecimalException subclasses: __mro__.__len__() == 6
#
# InvalidOperation, Clamped, Rounded, and Inexact each inherit directly from
# DecimalException, giving them a 6-entry MRO:
#   [ExcClass, DecimalException, ArithmeticError, Exception, BaseException, object]
#
# Note: DivisionByZero has a 7-entry MRO because it also inherits from
# ZeroDivisionError (see separate table below). Only exceptions with a
# single direct parent (DecimalException) are included here.
#
# No prior decimal spec checks __mro__.__len__() for any of these in the
# decimalexc63 namespace. Novel MRO length anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra63.direct_decimal_exception_mro:
  description: "InvalidOperation/Clamped/Rounded/Inexact __mro__.__len__()==6 — each inherits directly from DecimalException; MRO is [ExcClass, DecimalException, ArithmeticError, Exception, BaseException, object] with 6 entries; DivisionByZero is excluded (its MRO length is 7 due to ZeroDivisionError); no prior decimal spec checks __mro__.__len__() for InvalidOperation/Clamped/Rounded/Inexact in decimalexc63 namespace; novel MRO length anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: decimalexc63mro

  columns: [id, function, args, expected]
  rows:
    - [invalid_operation_mro_6,  InvalidOperation.__mro__.__len__,  [], 6]
    - [clamped_mro_6,            Clamped.__mro__.__len__,            [], 6]
    - [rounded_mro_6,            Rounded.__mro__.__len__,            [], 6]
    - [inexact_mro_6,            Inexact.__mro__.__len__,            [], 6]

# ---------------------------------------------------------------------------
# Inexact hierarchy: __bases__[0].__name__ and __mro__.__len__()
#
# Inexact inherits directly from DecimalException:
#   Inexact.__bases__[0].__name__ == 'DecimalException'
#   Inexact.__mro__.__len__()     == 6
#
# No prior decimal spec checks Inexact.__bases__[0].__name__ in decimalexc63
# namespace. Function values containing '[' must be double-quoted in table rows.
# Novel hierarchy anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
#
# Also: DivisionByZero.__mro__.__len__() == 7 because DivisionByZero
# inherits from both DecimalException and ZeroDivisionError, adding an
# extra entry to the MRO.
# ---------------------------------------------------------------------------

table decimal_extra63.Inexact_hierarchy:
  description: "Inexact/__bases__[0].__name__=='DecimalException'; Inexact/__mro__.__len__()==6; DivisionByZero/__mro__.__len__()==7 — Inexact inherits directly from DecimalException; DivisionByZero has MRO length 7 because it also inherits from ZeroDivisionError; no prior decimal spec checks Inexact.__bases__[0].__name__ or DivisionByZero.__mro__.__len__() in decimalexc63 namespace; function value with '[' is double-quoted; novel hierarchy anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: decimalexc63inexact

  columns: [id, function, args, expected]
  rows:
    - [inexact_bases_decimalexc,   "Inexact.__bases__[0].__name__.__eq__",  ["DecimalException"], true]
    - [inexact_mro_len_6,          Inexact.__mro__.__len__,                  [],                   6]
    - [divbyzero_mro_len_7,        DivisionByZero.__mro__.__len__,           [],                   7]

# ---------------------------------------------------------------------------
# Decimal exception __name__.__eq__ identity
#
# InvalidOperation, DivisionByZero, Clamped, and Rounded are top-level
# classes in the decimal module. Their __name__ attributes are their simple
# class names:
#   InvalidOperation.__name__ == 'InvalidOperation'
#   DivisionByZero.__name__   == 'DivisionByZero'
#   Clamped.__name__          == 'Clamped'
#   Rounded.__name__          == 'Rounded'
#
# No prior decimal spec checks __name__.__eq__ for any of these in
# decimalexc63 namespace. Novel name identity anchors.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra63.decimal_exception_names:
  description: "InvalidOperation/DivisionByZero/Clamped/Rounded __name__.__eq__ — all are top-level decimal exception classes; __name__ is their simple class name; no prior decimal spec checks __name__.__eq__ for any of these in decimalexc63 namespace; novel name identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalexc63names

  columns: [id, function, args, expected]
  rows:
    - [invalid_operation_name,  InvalidOperation.__name__.__eq__,  ["InvalidOperation"], true]
    - [division_by_zero_name,   DivisionByZero.__name__.__eq__,    ["DivisionByZero"],   true]
    - [clamped_name_clamped,    Clamped.__name__.__eq__,            ["Clamped"],          true]
    - [rounded_name_rounded,    Rounded.__name__.__eq__,            ["Rounded"],          true]

# ---------------------------------------------------------------------------
# Decimal exception __module__.__contains__('decimal')
#
# InvalidOperation, DivisionByZero, and Clamped are C extension types whose
# __module__ is 'decimal' or '_decimal' depending on the implementation.
# Both module name strings contain the substring 'decimal':
#   InvalidOperation.__module__.__contains__('decimal') == True
#   DivisionByZero.__module__.__contains__('decimal')   == True
#   Clamped.__module__.__contains__('decimal')          == True
#
# No prior decimal spec checks __module__.__contains__('decimal') for any
# of these exceptions in decimalexc63 namespace.
# Novel module identity anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra63.decimal_exception_modules:
  description: "InvalidOperation/DivisionByZero/Clamped __module__.__contains__('decimal')==True — module is 'decimal' or '_decimal'; both strings contain 'decimal'; robust across both pure-Python and C extension implementations; no prior decimal spec checks __module__.__contains__('decimal') for these exceptions in decimalexc63 namespace; novel module identity anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalexc63mod

  columns: [id, function, args, expected]
  rows:
    - [invalid_operation_module,  InvalidOperation.__module__.__contains__,  ["decimal"], true]
    - [division_by_zero_module,   DivisionByZero.__module__.__contains__,    ["decimal"], true]
    - [clamped_module,            Clamped.__module__.__contains__,            ["decimal"], true]

invariant decimal_extra63.InvalidOperation_mro_6:
  description: "InvalidOperation.__mro__.__len__() == 6 — the MRO for InvalidOperation is [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object] with 6 entries; InvalidOperation inherits directly from DecimalException; no prior decimal spec checks InvalidOperation.__mro__.__len__() in decimalexc63 namespace; novel MRO length anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: exception_hierarchy
  kind: python_call_eq
  function: InvalidOperation.__mro__.__len__
  args: []
  expected: 6

invariant decimal_extra63.DivisionByZero_mro_7:
  description: "DivisionByZero.__mro__.__len__() == 7 — the MRO for DivisionByZero is [DivisionByZero, DecimalException, ZeroDivisionError, ArithmeticError, Exception, BaseException, object] with 7 entries; DivisionByZero inherits from both DecimalException and ZeroDivisionError, adding an extra entry; no prior decimal spec checks DivisionByZero.__mro__.__len__() in decimalexc63 namespace; novel MRO length anchor distinguishing DivisionByZero from single-parent decimal exceptions; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: exception_hierarchy
  kind: python_call_eq
  function: DivisionByZero.__mro__.__len__
  args: []
  expected: 7

invariant decimal_extra63.Inexact_bases_DecimalException:
  description: "Inexact.__bases__[0].__name__.__eq__('DecimalException') == True — Inexact inherits directly from DecimalException; __bases__[0] is DecimalException; DecimalException.__name__ is 'DecimalException'; no prior decimal spec checks Inexact.__bases__[0].__name__ in decimalexc63 namespace; novel hierarchy anchor; function value contains '[' so it is double-quoted; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: exception_hierarchy
  kind: python_call_eq
  function: "Inexact.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra63.Rounded_name_Rounded:
  description: "Rounded.__name__.__eq__('Rounded') == True — Rounded is a top-level decimal exception class; its simple class name is 'Rounded' (7 chars); no prior decimal spec checks Rounded.__name__.__eq__('Rounded') in decimalexc63 namespace; novel name identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: Rounded.__name__.__eq__
  args: ["Rounded"]
  expected: true

invariant decimal_extra63.InvalidOperation_module_decimal:
  description: "InvalidOperation.__module__.__contains__('decimal') == True — InvalidOperation.__module__ is 'decimal' (or '_decimal' in some builds); both strings contain 'decimal'; no prior decimal spec checks InvalidOperation.__module__.__contains__('decimal') in decimalexc63 namespace; novel module identity anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: InvalidOperation.__module__.__contains__
  args: ["decimal"]
  expected: true
