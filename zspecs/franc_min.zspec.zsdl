spec: franc_min
version: ">=6.2.0"
backend: node(franc-min)

docs: https://www.npmjs.com/package/franc-min

provenance:
  derived_from:
    - "franc-min README — https://www.npmjs.com/package/franc-min"
    - "Test vectors verified with franc-min via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "franc-min source"
  notes:
    - "franc-min is an npm package. Install: npm install franc-min"
    - "Detects the language of a text string; returns an ISO 639-3 language code."
    - "Short or ambiguous strings may return 'und' (undetermined)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an ISO 639-3 language code string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table franc_min.franc:
  kind: node_module_call_eq
  function: franc
  category: detect
  id_prefix: franc

  columns: [id, args, expected]
  rows:
    - [french,  ["bonjour le monde bonsoir comment allez vous"], "fra"]
    - [short,   ["hello"],                                       "und"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: infeasible
  model: claude-cli
  attempted_at: 2026-05-04T18:19:24Z
  iterations: 1
  pass_count: 0
  fail_count: 0
  total_invariants: 2
  notes: "LLM unavailable: claude CLI timed out after 300s"
  infeasible_reason: llm_unavailable
  invariant_annotations: {}
