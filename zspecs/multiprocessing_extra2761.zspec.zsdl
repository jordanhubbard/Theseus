spec: multiprocessing_extra2761
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
    - "multiprocessing_extra.zspec.zsdl — covers Process.__module__, base class, factory __name__ checks"
    - "multiprocessing_extra2.zspec.zsdl — covers factory __module__ checks, extra primitive names"
  notes:
    - "Wave 631 theme: __matmul__, __truediv__, and __iadd__ dict-presence checks."
    - "None of the multiprocessing public classes define __matmul__, __truediv__, or __iadd__ in their __dict__."
    - "multiprocessing.Process is a real class (Lib/multiprocessing/process.py); Pool and ApplyResult are in Lib/multiprocessing/pool.py."
    - "multiprocessing.pool.AsyncResult is an alias for multiprocessing.pool.ApplyResult; __name__ is 'ApplyResult' in Python 3.14.4."
    - "Process, Pool, and ApplyResult are process-management/coordination classes, not numeric types."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Process — __matmul__/__truediv__/__iadd__ dict-presence checks
#
# Process is the core class for spawning new OS processes. It manages process
# lifecycle (start, join, terminate) and does not implement arithmetic dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2761.process_operator_dict:
  description: "multiprocessing.Process __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2761p

  columns: [id, function, args, expected]
  rows:
    - ["mp2761p_matmul",  multiprocessing.Process.__dict__.__contains__, ["__matmul__"],  false]
    - ["mp2761p_truediv", multiprocessing.Process.__dict__.__contains__, ["__truediv__"], false]
    - ["mp2761p_iadd",    multiprocessing.Process.__dict__.__contains__, ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool — __matmul__/__truediv__/__iadd__ dict-presence checks
#
# Pool is a process pool manager providing map/apply/starmap/imap interfaces.
# It coordinates worker processes and does not define numeric operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2761.pool_operator_dict:
  description: "multiprocessing.pool.Pool __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2761pl

  columns: [id, function, args, expected]
  rows:
    - ["mp2761pl_matmul",  multiprocessing.pool.Pool.__dict__.__contains__, ["__matmul__"],  false]
    - ["mp2761pl_truediv", multiprocessing.pool.Pool.__dict__.__contains__, ["__truediv__"], false]
    - ["mp2761pl_iadd",    multiprocessing.pool.Pool.__dict__.__contains__, ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# multiprocessing.pool.ApplyResult — __matmul__/__truediv__/__iadd__ dict-presence checks
#
# ApplyResult (also exported as AsyncResult) is the result object returned by
# Pool.apply_async(). It wraps a pending result and provides get()/ready()/wait().
# It does not implement arithmetic operator dunders.
# ---------------------------------------------------------------------------

table multiprocessing_extra2761.applyresult_operator_dict:
  description: "multiprocessing.pool.ApplyResult __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2761ar

  columns: [id, function, args, expected]
  rows:
    - ["mp2761ar_matmul",  multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__matmul__"],  false]
    - ["mp2761ar_truediv", multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__truediv__"], false]
    - ["mp2761ar_iadd",    multiprocessing.pool.ApplyResult.__dict__.__contains__, ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Full 3×3 cross-type matrix — Process, Pool, ApplyResult × three operator dunders
#
# Consolidates the complete 3×3 dict-presence check in one table.
# Every cell is False: Process, Pool, and ApplyResult do not define @, /, or +=
# operator dunders in their respective __dict__ attributes.
# ---------------------------------------------------------------------------

table multiprocessing_extra2761.all_types_matmul_truediv_iadd_matrix:
  description: "Full 3×3 dict-presence matrix for multiprocessing types vs __matmul__/__truediv__/__iadd__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: mp2761mx

  columns: [id, function, args, expected]
  rows:
    - ["mp2761mx_p_mm",   multiprocessing.Process.__dict__.__contains__,          ["__matmul__"],  false]
    - ["mp2761mx_p_td",   multiprocessing.Process.__dict__.__contains__,          ["__truediv__"], false]
    - ["mp2761mx_p_ia",   multiprocessing.Process.__dict__.__contains__,          ["__iadd__"],    false]
    - ["mp2761mx_pl_mm",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__matmul__"],  false]
    - ["mp2761mx_pl_td",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__truediv__"], false]
    - ["mp2761mx_pl_ia",  multiprocessing.pool.Pool.__dict__.__contains__,        ["__iadd__"],    false]
    - ["mp2761mx_ar_mm",  multiprocessing.pool.ApplyResult.__dict__.__contains__,  ["__matmul__"],  false]
    - ["mp2761mx_ar_td",  multiprocessing.pool.ApplyResult.__dict__.__contains__,  ["__truediv__"], false]
    - ["mp2761mx_ar_ia",  multiprocessing.pool.ApplyResult.__dict__.__contains__,  ["__iadd__"],    false]
