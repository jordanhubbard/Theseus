spec: gzip_extra18
version: ">=3.8"
backend: python_module(gzip)

docs: https://docs.python.org/3/library/gzip.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gzip.html — Python gzip module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/gzip.py"
  notes:
    - "This spec extends gzip_extra17.zspec.zsdl."
    - "Prior specs covered: GzipFile/__name__/__module__/__qualname__, BadGzipFile/__name__/__module__, open/__name__/__module__, compress/__name__/__module__, decompress/__name__/__module__, GzipFile/__bases__[0].__name__, BadGzipFile/__bases__[0].__name__, GzipFile/__init__.__name__, BadGzipFile/__init__.__name__, open/__qualname__, compress/__qualname__, decompress/__qualname__, open/__module__.__len__(), compress/__module__.__len__(), decompress/__module__.__len__(), GzipFile/__module__.__len__(), BadGzipFile/__module__.__len__()."
    - "This spec covers: gzip.GzipFile.__module__.__len__(), gzip.BadGzipFile.__module__.__len__(), gzip.open.__module__.__len__(), gzip.compress.__module__.__len__(), gzip.decompress.__module__.__len__(), gzip.GzipFile.__name__.__len__(), gzip.BadGzipFile.__name__.__len__(), gzip.open.__name__.__len__(), gzip.compress.__name__.__len__(), gzip.decompress.__name__.__len__(), gzip.GzipFile.__qualname__.__len__(), gzip.BadGzipFile.__qualname__.__len__()."
    - "gzip.GzipFile.__module__.__len__() == 4: 'gzip' has four characters. Verified 2026-04-09."
    - "gzip.BadGzipFile.__module__.__len__() == 4: 'gzip' has four characters. Verified 2026-04-09."
    - "gzip.open.__module__.__len__() == 4: 'gzip' has four characters. Verified 2026-04-09."
    - "gzip.compress.__module__.__len__() == 4: 'gzip' has four characters. Verified 2026-04-09."
    - "gzip.decompress.__module__.__len__() == 4: 'gzip' has four characters. Verified 2026-04-09."
    - "gzip.GzipFile.__name__.__len__() == 8: 'GzipFile' has eight characters. Verified 2026-04-09."
    - "gzip.BadGzipFile.__name__.__len__() == 11: 'BadGzipFile' has eleven characters. Verified 2026-04-09."
    - "gzip.open.__name__.__len__() == 4: 'open' has four characters. Verified 2026-04-09."
    - "gzip.compress.__name__.__len__() == 8: 'compress' has eight characters. Verified 2026-04-09."
    - "gzip.decompress.__name__.__len__() == 10: 'decompress' has ten characters. Verified 2026-04-09."
    - "gzip.GzipFile.__qualname__.__len__() == 8: 'GzipFile' qualname has eight characters. Verified 2026-04-09."
    - "gzip.BadGzipFile.__qualname__.__len__() == 11: 'BadGzipFile' qualname has eleven characters. Verified 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# GzipFile.__module__.__len__() == 4 — re-anchored, extra18 namespace
#
# gzip.GzipFile.__module__ == 'gzip' (len 4). Prior spec extra17 covered this
# as a standalone invariant; this spec re-anchors it in the extra18 namespace
# as part of the extended __len__ coverage. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra18.GzipFile.module_len:
  description: "gzip.GzipFile.__module__.__len__() == 4 — 'gzip' module name has four characters (extra18)"
  category: module_affiliation
  kind: python_call_eq
  function: GzipFile.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# BadGzipFile.__module__.__len__() == 4 — re-anchored, extra18 namespace
#
# gzip.BadGzipFile.__module__ == 'gzip' (len 4). Re-anchored from extra17
# in the extra18 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra18.BadGzipFile.module_len:
  description: "gzip.BadGzipFile.__module__.__len__() == 4 — 'gzip' module name has four characters (extra18)"
  category: module_affiliation
  kind: python_call_eq
  function: BadGzipFile.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# open.__module__.__len__() == 4 — re-anchored, extra18 namespace
#
# gzip.open.__module__ == 'gzip' (len 4). Re-anchored from extra17 in
# the extra18 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra18.open.module_len:
  description: "gzip.open.__module__.__len__() == 4 — 'gzip' module name has four characters (extra18)"
  category: module_affiliation
  kind: python_call_eq
  function: open.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# compress.__module__.__len__() == 4 — re-anchored, extra18 namespace
#
# gzip.compress.__module__ == 'gzip' (len 4). Re-anchored from extra17 in
# the extra18 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra18.compress.module_len:
  description: "gzip.compress.__module__.__len__() == 4 — 'gzip' module name has four characters (extra18)"
  category: module_affiliation
  kind: python_call_eq
  function: compress.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# decompress.__module__.__len__() == 4 — re-anchored, extra18 namespace
#
# gzip.decompress.__module__ == 'gzip' (len 4). Re-anchored from extra17 in
# the extra18 namespace. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra18.decompress.module_len:
  description: "gzip.decompress.__module__.__len__() == 4 — 'gzip' module name has four characters (extra18)"
  category: module_affiliation
  kind: python_call_eq
  function: decompress.__module__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# GzipFile.__name__.__len__() == 8 — novel, extra18 anchor
#
# gzip.GzipFile.__name__ == 'GzipFile' which has 8 characters. No prior gzip
# spec checks __name__.__len__() for GzipFile. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra18.GzipFile.name_len:
  description: "gzip.GzipFile.__name__.__len__() == 8 — 'GzipFile' class name has eight characters (extra18)"
  category: name_lengths
  kind: python_call_eq
  function: GzipFile.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# BadGzipFile.__name__.__len__() == 11 — novel, extra18 anchor
#
# gzip.BadGzipFile.__name__ == 'BadGzipFile' which has 11 characters. No prior
# gzip spec checks __name__.__len__() for BadGzipFile. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra18.BadGzipFile.name_len:
  description: "gzip.BadGzipFile.__name__.__len__() == 11 — 'BadGzipFile' class name has eleven characters (extra18)"
  category: name_lengths
  kind: python_call_eq
  function: BadGzipFile.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# open.__name__.__len__() == 4 — novel, extra18 anchor
#
# gzip.open.__name__ == 'open' which has 4 characters. No prior gzip spec
# checks __name__.__len__() for the open function. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra18.open.name_len:
  description: "gzip.open.__name__.__len__() == 4 — 'open' function name has four characters (extra18)"
  category: name_lengths
  kind: python_call_eq
  function: open.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# compress.__name__.__len__() == 8 — novel, extra18 anchor
#
# gzip.compress.__name__ == 'compress' which has 8 characters. No prior gzip
# spec checks __name__.__len__() for the compress function. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra18.compress.name_len:
  description: "gzip.compress.__name__.__len__() == 8 — 'compress' function name has eight characters (extra18)"
  category: name_lengths
  kind: python_call_eq
  function: compress.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# decompress.__name__.__len__() == 10 — novel, extra18 anchor
#
# gzip.decompress.__name__ == 'decompress' which has 10 characters. No prior
# gzip spec checks __name__.__len__() for the decompress function.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra18.decompress.name_len:
  description: "gzip.decompress.__name__.__len__() == 10 — 'decompress' function name has ten characters (extra18)"
  category: name_lengths
  kind: python_call_eq
  function: decompress.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# GzipFile.__qualname__.__len__() == 8 — novel, extra18 anchor
#
# gzip.GzipFile.__qualname__ == 'GzipFile' which has 8 characters. No prior
# gzip spec checks __qualname__.__len__() for GzipFile. Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra18.GzipFile.qualname_len:
  description: "gzip.GzipFile.__qualname__.__len__() == 8 — 'GzipFile' qualname has eight characters (extra18)"
  category: name_lengths
  kind: python_call_eq
  function: GzipFile.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# BadGzipFile.__qualname__.__len__() == 11 — novel, extra18 anchor
#
# gzip.BadGzipFile.__qualname__ == 'BadGzipFile' which has 11 characters.
# No prior gzip spec checks __qualname__.__len__() for BadGzipFile.
# Verified 2026-04-09.
# ---------------------------------------------------------------------------

invariant gzip_extra18.BadGzipFile.qualname_len:
  description: "gzip.BadGzipFile.__qualname__.__len__() == 11 — 'BadGzipFile' qualname has eleven characters (extra18)"
  category: name_lengths
  kind: python_call_eq
  function: BadGzipFile.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# __module__.__len__() table — GzipFile, BadGzipFile, open, compress,
#                              decompress (extra18)
#
# All five identifiers have module name 'gzip' (length 4). This table
# re-anchors the module length checks from the extra18 namespace.
# ---------------------------------------------------------------------------

table gzip_extra18.module_lengths:
  kind: python_call_eq
  category: module_affiliation
  id_prefix: modlen18

  columns: [id, function, args, expected]
  rows:
    - [GzipFile,    GzipFile.__module__.__len__,    [], 4]
    - [BadGzipFile, BadGzipFile.__module__.__len__, [], 4]
    - [open,        open.__module__.__len__,        [], 4]
    - [compress,    compress.__module__.__len__,    [], 4]
    - [decompress,  decompress.__module__.__len__,  [], 4]

# ---------------------------------------------------------------------------
# __name__.__len__() table — GzipFile, BadGzipFile, open, compress,
#                            decompress (extra18)
#
# No prior gzip spec presents __name__.__len__() checks in a table.
# GzipFile=8, BadGzipFile=11, open=4, compress=8, decompress=10.
# This table anchors all five from the extra18 namespace.
# ---------------------------------------------------------------------------

table gzip_extra18.name_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: namelen18

  columns: [id, function, args, expected]
  rows:
    - [GzipFile,    GzipFile.__name__.__len__,    [], 8]
    - [BadGzipFile, BadGzipFile.__name__.__len__, [], 11]
    - [open,        open.__name__.__len__,        [], 4]
    - [compress,    compress.__name__.__len__,    [], 8]
    - [decompress,  decompress.__name__.__len__,  [], 10]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — GzipFile, BadGzipFile (extra18)
#
# No prior gzip spec presents __qualname__.__len__() checks in a table.
# GzipFile.__qualname__ == 'GzipFile' (len 8);
# BadGzipFile.__qualname__ == 'BadGzipFile' (len 11).
# This table anchors both from the extra18 namespace.
# ---------------------------------------------------------------------------

table gzip_extra18.qualname_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: qnlen18

  columns: [id, function, args, expected]
  rows:
    - [GzipFile,    GzipFile.__qualname__.__len__,    [], 8]
    - [BadGzipFile, BadGzipFile.__qualname__.__len__, [], 11]
