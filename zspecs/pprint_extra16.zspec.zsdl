spec: pprint_extra16
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint.zspec.zsdl through pprint_extra15.zspec.zsdl."
    - "pprint_extra14 covers: module-level function __qualname__ for pprint/pformat/isreadable/isrecursive/saferepr as standalone invariants."
    - "pprint_extra15 covers: PrettyPrinter.__init__.__qualname__=='PrettyPrinter.__init__'; PrettyPrinter.__init__.__name__=='__init__'."
    - "No prior spec verifies PrettyPrinter.pprint.__qualname__, PrettyPrinter.pformat.__qualname__, PrettyPrinter.isreadable.__qualname__, or PrettyPrinter.isrecursive.__qualname__ as standalone invariants."
    - "This spec covers: PrettyPrinter.pprint.__qualname__=='PrettyPrinter.pprint'; PrettyPrinter.pformat.__qualname__=='PrettyPrinter.pformat'; PrettyPrinter.isreadable.__qualname__=='PrettyPrinter.isreadable'; PrettyPrinter.isrecursive.__qualname__=='PrettyPrinter.isrecursive'."
    - "PrettyPrinter methods defined in the class body have __qualname__ of the form 'PrettyPrinter.<method_name>'. Verified at runtime."
    - "pprint.PrettyPrinter.pprint.__qualname__ == 'PrettyPrinter.pprint' — method qualname includes owning class. Verified at runtime."
    - "pprint.PrettyPrinter.pformat.__qualname__ == 'PrettyPrinter.pformat' — method qualname includes owning class. Verified at runtime."
    - "pprint.PrettyPrinter.isreadable.__qualname__ == 'PrettyPrinter.isreadable' — method qualname includes owning class. Verified at runtime."
    - "pprint.PrettyPrinter.isrecursive.__qualname__ == 'PrettyPrinter.isrecursive' — method qualname includes owning class. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PrettyPrinter.pprint method __qualname__
#
# pprint_extra14 covers the module-level pprint.__qualname__ == 'pprint'.
# No prior spec verifies PrettyPrinter.pprint.__qualname__ as a standalone
# invariant. For a method defined in PrettyPrinter, __qualname__ takes the
# form 'PrettyPrinter.pprint'. Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra16.PrettyPrinter.pprint_qualname:
  description: "pprint.PrettyPrinter.pprint.__qualname__ == 'PrettyPrinter.pprint' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter.pprint.__qualname__.__eq__
  args: ["PrettyPrinter.pprint"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter.pformat method __qualname__
#
# pprint_extra14 covers the module-level pformat.__qualname__ == 'pformat'.
# No prior spec verifies PrettyPrinter.pformat.__qualname__ as a standalone
# invariant. Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra16.PrettyPrinter.pformat_qualname:
  description: "pprint.PrettyPrinter.pformat.__qualname__ == 'PrettyPrinter.pformat' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter.pformat.__qualname__.__eq__
  args: ["PrettyPrinter.pformat"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter.isreadable method __qualname__
#
# pprint_extra14 covers the module-level isreadable.__qualname__ == 'isreadable'.
# No prior spec verifies PrettyPrinter.isreadable.__qualname__ as a standalone
# invariant. Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra16.PrettyPrinter.isreadable_qualname:
  description: "pprint.PrettyPrinter.isreadable.__qualname__ == 'PrettyPrinter.isreadable' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter.isreadable.__qualname__.__eq__
  args: ["PrettyPrinter.isreadable"]
  expected: true

# ---------------------------------------------------------------------------
# PrettyPrinter.isrecursive method __qualname__
#
# pprint_extra14 covers the module-level isrecursive.__qualname__ == 'isrecursive'.
# No prior spec verifies PrettyPrinter.isrecursive.__qualname__ as a standalone
# invariant. Verified at runtime.
# ---------------------------------------------------------------------------

invariant pprint_extra16.PrettyPrinter.isrecursive_qualname:
  description: "pprint.PrettyPrinter.isrecursive.__qualname__ == 'PrettyPrinter.isrecursive' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: PrettyPrinter.isrecursive.__qualname__.__eq__
  args: ["PrettyPrinter.isrecursive"]
  expected: true

# ---------------------------------------------------------------------------
# Table: PrettyPrinter method __qualname__ attributes
#
# Groups all four PrettyPrinter method qualname checks in one indexed table.
# No prior table covers PrettyPrinter instance method __qualname__ values.
# All verified at runtime: each __qualname__ takes the form 'PrettyPrinter.<name>'.
# ---------------------------------------------------------------------------

table pprint_extra16.PrettyPrinter_method_qualnames:
  description: "pprint.PrettyPrinter method __qualname__ attributes — all include owning class prefix"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [pprint_extra16.PrettyPrinter_method_qualnames.pprint,
       PrettyPrinter.pprint.__qualname__.__eq__,
       ["PrettyPrinter.pprint"],
       true,
       "PrettyPrinter.pprint.__qualname__ == 'PrettyPrinter.pprint'"]
    - [pprint_extra16.PrettyPrinter_method_qualnames.pformat,
       PrettyPrinter.pformat.__qualname__.__eq__,
       ["PrettyPrinter.pformat"],
       true,
       "PrettyPrinter.pformat.__qualname__ == 'PrettyPrinter.pformat'"]
    - [pprint_extra16.PrettyPrinter_method_qualnames.isreadable,
       PrettyPrinter.isreadable.__qualname__.__eq__,
       ["PrettyPrinter.isreadable"],
       true,
       "PrettyPrinter.isreadable.__qualname__ == 'PrettyPrinter.isreadable'"]
    - [pprint_extra16.PrettyPrinter_method_qualnames.isrecursive,
       PrettyPrinter.isrecursive.__qualname__.__eq__,
       ["PrettyPrinter.isrecursive"],
       true,
       "PrettyPrinter.isrecursive.__qualname__ == 'PrettyPrinter.isrecursive'"]
