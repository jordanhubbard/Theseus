spec: concurrent_futures_extra210
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers: __doc__ string contains checks for concurrent.futures. NEW in extra210: concurrent.futures.Future.__doc__.__contains__('asynchronous')==True (len=53); concurrent.futures.Future.__doc__.__contains__('computation')==True; concurrent.futures.Executor.__doc__.__contains__('abstract')==True (len=67); concurrent.futures.as_completed.__doc__.__contains__('iterator')==True (len=570); concurrent.futures.as_completed.__doc__.__contains__('yields')==True; concurrent.futures.as_completed.__doc__.__contains__('future')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__doc__ is None — no docstring. concurrent.futures.ProcessPoolExecutor.__doc__ is None — no docstring. Only Future, Executor, and as_completed have non-None __doc__ strings. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.__doc__ == 'Represents the result of an asynchronous computation.' (len=53). __contains__('asynchronous')==True; __contains__('computation')==True; __contains__('future')==False (the word 'future' does not appear in the brief docstring). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Executor.__doc__ == 'This is an abstract base class for concrete asynchronous executors.' (len=67). __contains__('abstract')==True; __contains__('submit')==False. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.as_completed.__doc__ starts with 'An iterator over the given futures that yields each as it completes.' (len=570). __contains__('iterator')==True; __contains__('yields')==True; __contains__('future')==True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future __doc__ contains checks — extra210
#
# concurrent.futures.Future.__doc__ == 'Represents the result of an asynchronous computation.'
# len == 53
# __contains__('asynchronous') == True
# __contains__('computation') == True
# __contains__('future') == False
# ---------------------------------------------------------------------------

table concurrent_futures_extra210.cf_future_doc_contains:
  description: "concurrent.futures.Future.__doc__ contains checks in cfe210future namespace — wave 210 theme: concurrent.futures __doc__ string inspection; Future.__doc__.__contains__('asynchronous')==True (docstring: 'Represents the result of an asynchronous computation.' — 'asynchronous' modifies 'computation'); Future.__doc__.__contains__('computation')==True ('computation' appears at end of docstring); Future.__doc__.__contains__('future')==False ('future' is the class name but lowercase 'future' does not appear in the docstring); Future.__doc__.__len__()==53 ('Represents the result of an asynchronous computation.' = 53 chars); NOTE: ThreadPoolExecutor.__doc__ and ProcessPoolExecutor.__doc__ are None — only Future, Executor, and as_completed have non-None __doc__ strings; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfe210future

  columns: [id, function, args, expected, description]
  rows:
    - [future_doc_has_async,   concurrent.futures.Future.__doc__.__contains__, ["asynchronous"], true,  "Future.__doc__.__contains__('asynchronous') == True; verified with Python 3.14.3"]
    - [future_doc_has_compute, concurrent.futures.Future.__doc__.__contains__, ["computation"],  true,  "Future.__doc__.__contains__('computation') == True; verified with Python 3.14.3"]
    - [future_doc_no_future,   concurrent.futures.Future.__doc__.__contains__, ["future"],       false, "Future.__doc__.__contains__('future') == False — 'future' not in brief docstring; verified with Python 3.14.3"]
    - [future_doc_len,         concurrent.futures.Future.__doc__.__len__,      [],               53,    "Future.__doc__.__len__() == 53 ('Represents the result of an asynchronous computation.'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Executor __doc__ contains checks — extra210
#
# concurrent.futures.Executor.__doc__ == 'This is an abstract base class for concrete asynchronous executors.'
# len == 67
# __contains__('abstract') == True
# __contains__('submit') == False
# ---------------------------------------------------------------------------

table concurrent_futures_extra210.cf_executor_doc_contains:
  description: "concurrent.futures.Executor.__doc__ contains checks in cfe210executor namespace — wave 210 theme: Executor.__doc__.__contains__('abstract')==True (docstring: 'This is an abstract base class for concrete asynchronous executors.' — 'abstract' in 'abstract base class'); Executor.__doc__.__contains__('submit')==False ('submit' is the key Executor method but does not appear in the class-level docstring); Executor.__doc__.__len__()==67 ('This is an abstract base class for concrete asynchronous executors.' = 67 chars); Executor is the abstract base for ThreadPoolExecutor and ProcessPoolExecutor; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfe210executor

  columns: [id, function, args, expected, description]
  rows:
    - [executor_doc_has_abstract, concurrent.futures.Executor.__doc__.__contains__, ["abstract"], true,  "Executor.__doc__.__contains__('abstract') == True; verified with Python 3.14.3"]
    - [executor_doc_no_submit,    concurrent.futures.Executor.__doc__.__contains__, ["submit"],   false, "Executor.__doc__.__contains__('submit') == False — 'submit' not in class docstring; verified with Python 3.14.3"]
    - [executor_doc_len,          concurrent.futures.Executor.__doc__.__len__,      [],           67,    "Executor.__doc__.__len__() == 67 ('This is an abstract base class for concrete asynchronous executors.'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.as_completed __doc__ contains checks — extra210
#
# concurrent.futures.as_completed.__doc__ starts with 'An iterator over the given futures that yields each as it completes.'
# len == 570
# __contains__('iterator') == True
# __contains__('yields') == True
# __contains__('future') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra210.cf_as_completed_doc_contains:
  description: "concurrent.futures.as_completed.__doc__ contains checks in cfe210asc namespace — wave 210 theme: as_completed.__doc__.__contains__('iterator')==True ('An iterator over the given futures...'); as_completed.__doc__.__contains__('yields')==True ('that yields each as it completes'); as_completed.__doc__.__contains__('future')==True ('given futures' and 'future' appear multiple times in the 570-char docstring); as_completed.__doc__.__len__()==570 (longest __doc__ in this spec by far — describes Args, Yields, and Raises sections); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfe210asc

  columns: [id, function, args, expected, description]
  rows:
    - [asc_doc_has_iterator, concurrent.futures.as_completed.__doc__.__contains__, ["iterator"], true, "as_completed.__doc__.__contains__('iterator') == True; verified with Python 3.14.3"]
    - [asc_doc_has_yields,   concurrent.futures.as_completed.__doc__.__contains__, ["yields"],   true, "as_completed.__doc__.__contains__('yields') == True; verified with Python 3.14.3"]
    - [asc_doc_has_future,   concurrent.futures.as_completed.__doc__.__contains__, ["future"],   true, "as_completed.__doc__.__contains__('future') == True; verified with Python 3.14.3"]
    - [asc_doc_len,          concurrent.futures.as_completed.__doc__.__len__,      [],           570,  "as_completed.__doc__.__len__() == 570 (full docstring with Args/Yields/Raises); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra210
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra210.future_doc_len_53:
  description: "concurrent.futures.Future.__doc__.__len__() == 53 — Future.__doc__ is 'Represents the result of an asynchronous computation.' (53 chars); Future.__doc__.__contains__('asynchronous') is True; Future.__doc__.__contains__('computation') is True; Future.__doc__.__contains__('future') is False (class name absent from brief docstring); doc length ordering: Future=53 < Executor=67 << as_completed=570; concurrent.futures.ThreadPoolExecutor.__doc__ is None and ProcessPoolExecutor.__doc__ is None — these classes have no docstrings; Future is a non-abstract class (Executor is abstract); NEW in extra210: first standalone Future __doc__ length invariant; wave 210; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__doc__.__len__
  args: []
  expected: 53

invariant concurrent_futures_extra210.executor_doc_has_abstract:
  description: "concurrent.futures.Executor.__doc__.__contains__('abstract') returns True — Executor.__doc__ is 'This is an abstract base class for concrete asynchronous executors.' (len=67); 'abstract' appears in 'abstract base class'; Executor.__doc__.__contains__('submit') is False (the key Executor.submit method is not mentioned in the class-level docstring); Executor.__doc__.__len__()==67; Executor is the ABC from which ThreadPoolExecutor and ProcessPoolExecutor both inherit; concurrent.futures.Future.__doc__.__len__()==53 (shorter than Executor=67); NEW in extra210: first standalone Executor __doc__ abstract contains invariant; wave 210; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.__doc__.__contains__
  args: ["abstract"]
  expected: true

invariant concurrent_futures_extra210.as_completed_doc_len_570:
  description: "concurrent.futures.as_completed.__doc__.__len__() == 570 — as_completed has the longest __doc__ in this spec (570 chars); __contains__('iterator') is True; __contains__('yields') is True; __contains__('future') is True; doc length ordering: Future=53 < Executor=67 << as_completed=570 (as_completed is 8.5x longer than Executor); as_completed's lengthy docstring describes the Args (fs, timeout), Yields (completed futures), and Raises (TimeoutError) sections in a Google-style docstring format; NEW in extra210: first standalone as_completed __doc__ length invariant; wave 210; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.as_completed.__doc__.__len__
  args: []
  expected: 570

invariant concurrent_futures_extra210.as_completed_doc_has_yields:
  description: "concurrent.futures.as_completed.__doc__.__contains__('yields') returns True — as_completed.__doc__ contains 'yields each as it completes'; __contains__('iterator') is also True ('An iterator over the given futures'); __contains__('future') is also True; as_completed.__doc__.__len__()==570; as_completed is a generator function that yields each Future from the input set as it completes, in completion order rather than submission order; compare: concurrent.futures.Future.__doc__.__contains__('future') is False (unlike as_completed which explicitly mentions 'future' in its docstring); NEW in extra210: first standalone as_completed __doc__ yields contains invariant; wave 210; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.as_completed.__doc__.__contains__
  args: ["yields"]
  expected: true
