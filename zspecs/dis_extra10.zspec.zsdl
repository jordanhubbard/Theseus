spec: dis_extra10
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis.zspec.zsdl — covers __name__ for Instruction/Bytecode/dis/disassemble/code_info/show_code/get_instructions/stack_effect; opname class/length; opmap contains/values; stack_effect values; haslocal/hasname"
    - "dis_extra.zspec.zsdl — covers dis.__name__ (module name), distb/__name__, findlinestarts/__name__, findlabels/__name__, disassemble/__name__, code_info/__name__, show_code/__name__, get_instructions/__name__, stack_effect/__name__, Instruction/__name__/__module__, opname/__class__/__name__, opmap/__class__/__name__, HAVE_ARGUMENT/__class__/__name__"
    - "dis_extra2.zspec.zsdl — covers __module__ for dis/disassemble/get_instructions/findlinestarts/findlabels/code_info; Instruction/__name__/__module__/__bases__[0]; Bytecode/__name__/__module__/__bases__[0]; opname/opmap class checks; HAVE_ARGUMENT class check"
    - "dis_extra3.zspec.zsdl — covers __name__/__module__ for Instruction/Bytecode (table); __name__ for findlinestarts/findlabels/get_instructions/stack_effect (table); opname class/length; opmap class/contains; HAVE_ARGUMENT value; Bytecode.__module__"
    - "dis_extra4.zspec.zsdl — covers Instruction.__qualname__; Instruction._fields class/contains-opname/contains-opcode; opname.__len__ >= 100; dis/disassemble/get_instructions/findlinestarts __qualname__ (table)"
    - "dis_extra5.zspec.zsdl — covers __qualname__ for code_info/show_code/stack_effect/findlabels/distb; Bytecode.__qualname__; Instruction._fields[0]=='opname'; show_code/__module__; distb/__module__"
    - "dis_extra6.zspec.zsdl — covers hasjabs empty list; hasjrel/hasconst/hascompare/hasfree class+len; Instruction._fields[1]/'opcode' and _fields[2]/'arg'; opmap LOAD_CONST/LOAD_GLOBAL/RETURN_VALUE/STORE_NAME values; opname[82]=='LOAD_CONST'"
    - "dis_extra7.zspec.zsdl — covers Instruction._fields[3]/'argval' and _fields[4]/'argrepr'; hasexc class and nonempty; hasarg class and nonempty; Bytecode.__bases__[0].__name__=='object'; opmap BINARY_OP/CALL/RESUME; opname idx31/idx116/idx35"
    - "dis_extra8.zspec.zsdl — covers standalone __module__ invariants for all major dis public names; Bytecode/__name__/__module__; Instruction/__name__/__module__"
    - "dis_extra9.zspec.zsdl — covers Instruction._fields[5]-[11]; _fields.__len__==12; opmap BUILD_TUPLE/BUILD_LIST/COMPARE_OP/IMPORT_NAME/IMPORT_FROM; opname[51]/[46]/[56]/[73]/[72]"
  notes:
    - "This spec covers new opmap entries for control-flow and exception-handling opcodes not verified in any prior spec."
    - "dis.opmap['JUMP_FORWARD'] — unconditional forward jump; opcode value not yet verified."
    - "dis.opmap['POP_JUMP_IF_FALSE'] — conditional jump on false; not verified in any prior spec."
    - "dis.opmap['POP_JUMP_IF_TRUE'] — conditional jump on true; not verified in any prior spec."
    - "dis.opmap['FOR_ITER'] — loop iterator advance; not verified in any prior spec."
    - "dis.opmap['MAKE_FUNCTION'] — function object creation; not verified in any prior spec."
    - "dis.opmap contains 'JUMP_FORWARD' — boolean membership check not covered."
    - "dis.opmap contains 'FOR_ITER' — boolean membership check not covered."
    - "dis.opmap contains 'MAKE_FUNCTION' — boolean membership check not covered."
    - "dis.Bytecode.__bases__.__len__() == 1 — single direct base (object); not verified in any prior spec."
    - "dis.Instruction.__bases__[0].__name__ == 'tuple' — Instruction is a namedtuple subclass; extra2 covers Instruction/__bases__[0] but via a different axis."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# opmap membership checks — control-flow and exception opcodes
#
# dis_extra6 checks hasjrel/hasconst/hascompare/hasfree membership.
# No prior dis spec checks opmap.__contains__ for JUMP_FORWARD, FOR_ITER,
# or MAKE_FUNCTION as standalone boolean invariants.
# ---------------------------------------------------------------------------

invariant dis_extra10.opmap.contains_JUMP_FORWARD:
  description: "dis.opmap.__contains__('JUMP_FORWARD') == True"
  category: opmap
  kind: python_call_eq
  function: opmap.__contains__
  args: ["JUMP_FORWARD"]
  expected: true

invariant dis_extra10.opmap.contains_FOR_ITER:
  description: "dis.opmap.__contains__('FOR_ITER') == True"
  category: opmap
  kind: python_call_eq
  function: opmap.__contains__
  args: ["FOR_ITER"]
  expected: true

invariant dis_extra10.opmap.contains_MAKE_FUNCTION:
  description: "dis.opmap.__contains__('MAKE_FUNCTION') == True"
  category: opmap
  kind: python_call_eq
  function: opmap.__contains__
  args: ["MAKE_FUNCTION"]
  expected: true

# ---------------------------------------------------------------------------
# opmap value checks — control-flow opcodes
#
# dis_extra6 covers LOAD_CONST/LOAD_GLOBAL/RETURN_VALUE/STORE_NAME.
# dis_extra7 covers BINARY_OP/CALL/RESUME.
# dis_extra9 covers BUILD_TUPLE/BUILD_LIST/COMPARE_OP/IMPORT_NAME/IMPORT_FROM.
# New here: JUMP_FORWARD, FOR_ITER, MAKE_FUNCTION, POP_TOP.
# ---------------------------------------------------------------------------

table dis_extra10.opmap_control_flow:
  kind: python_call_eq
  category: opmap
  id_prefix: opmap

  columns: [id, function, args, expected]
  rows:
    - [JUMP_FORWARD,  opmap.__getitem__, ["JUMP_FORWARD"],  110]
    - [FOR_ITER,      opmap.__getitem__, ["FOR_ITER"],      68]
    - [MAKE_FUNCTION, opmap.__getitem__, ["MAKE_FUNCTION"], 100]
    - [POP_TOP,       opmap.__getitem__, ["POP_TOP"],       1]

# ---------------------------------------------------------------------------
# opname round-trip for control-flow opcodes
#
# dis_extra6/7/9 verify opname round-trips for various opcodes.
# New here: opname[110]=JUMP_FORWARD, opname[68]=FOR_ITER,
# opname[100]=MAKE_FUNCTION, opname[1]=POP_TOP.
# ---------------------------------------------------------------------------

table dis_extra10.opname_control_flow:
  kind: python_call_eq
  category: opname
  id_prefix: opname

  columns: [id, function, args, expected]
  rows:
    - [idx110, opname.__getitem__, [110], "JUMP_FORWARD"]
    - [idx68,  opname.__getitem__, [68],  "FOR_ITER"]
    - [idx100, opname.__getitem__, [100], "MAKE_FUNCTION"]
    - [idx1,   opname.__getitem__, [1],   "POP_TOP"]

# ---------------------------------------------------------------------------
# Bytecode.__bases__.__len__ — single direct base
#
# dis_extra7 covers Bytecode.__bases__[0].__name__ == 'object'.
# No prior dis spec checks the __len__ of Bytecode.__bases__.
# Bytecode inherits directly from object, so __bases__ has exactly one entry.
# ---------------------------------------------------------------------------

invariant dis_extra10.Bytecode.bases_len:
  description: "dis.Bytecode.__bases__.__len__() == 1 — Bytecode has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Bytecode.__bases__.__len__
  args: []
  expected: 1
