spec: threading_extra781
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "threading stdlib module"
    - "Python language reference"
  not_derived_from:
    - "any third-party library"
  notes:
    - "Covers threading.Condition and threading.Barrier method qualnames"
    - "All invariants verify __qualname__ string equality for class methods"
  created_at: "2026-04-12"

table threading_extra781.name:
  description: "threading.Condition and threading.Barrier method qualname identity checks"
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: th781xx
  columns: [id, function, args, expected]
  rows:
    - [th781xx001, "threading.Condition.__init__.__qualname__.__eq__", ["Condition.__init__"], true]
    - [th781xx002, "threading.Condition.acquire.__qualname__.__eq__", ["Condition.acquire"], true]
    - [th781xx003, "threading.Condition.release.__qualname__.__eq__", ["Condition.release"], true]
    - [th781xx004, "threading.Condition.wait.__qualname__.__eq__", ["Condition.wait"], true]
    - [th781xx005, "threading.Condition.wait_for.__qualname__.__eq__", ["Condition.wait_for"], true]
    - [th781xx006, "threading.Condition.notify.__qualname__.__eq__", ["Condition.notify"], true]
    - [th781xx007, "threading.Condition.notify_all.__qualname__.__eq__", ["Condition.notify_all"], true]
    - [th781xx008, "threading.Condition.__enter__.__qualname__.__eq__", ["Condition.__enter__"], true]
    - [th781xx009, "threading.Condition.__exit__.__qualname__.__eq__", ["Condition.__exit__"], true]
    - [th781xx010, "threading.Barrier.__init__.__qualname__.__eq__", ["Barrier.__init__"], true]
    - [th781xx011, "threading.Barrier.wait.__qualname__.__eq__", ["Barrier.wait"], true]
    - [th781xx012, "threading.Barrier.reset.__qualname__.__eq__", ["Barrier.reset"], true]
