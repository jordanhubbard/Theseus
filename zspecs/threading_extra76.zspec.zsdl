spec: threading_extra76
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra75.zspec.zsdl."
    - "This spec covers: threading RLock deeper identity + Semaphore/BoundedSemaphore class hierarchy (Wave 241)."
    - "RLock.__class__.__name__ == 'function' — RLock is a Python factory function, not a class. Verified in prior waves."
    - "RLock.__code__.co_name == 'RLock' — the code object's co_name matches the def statement name 'RLock'. Verified with Python 3.14.3."
    - "RLock.__code__.co_argcount == 0 — RLock() takes no required positional arguments. Verified with Python 3.14.3."
    - "BoundedSemaphore.__name__ == 'BoundedSemaphore' — BoundedSemaphore is a pure-Python class in Lib/threading.py. Verified with Python 3.14.3."
    - "BoundedSemaphore.__module__ == 'threading' — BoundedSemaphore is defined in the threading module. Verified with Python 3.14.3."
    - "BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore inherits from Semaphore. Verified with Python 3.14.3."
    - "BoundedSemaphore.__mro__.__len__() == 3 — MRO is [BoundedSemaphore, Semaphore, object]. Verified with Python 3.14.3."
    - "Semaphore.__name__ == 'Semaphore' — Semaphore is a pure-Python class in Lib/threading.py. Verified with Python 3.14.3."
    - "Semaphore.__module__ == 'threading' — Semaphore is defined in the threading module. Verified with Python 3.14.3."
    - "Semaphore.__bases__[0].__name__ == 'object' — Semaphore inherits directly from object. Verified with Python 3.14.3."
    - "Semaphore.__mro__.__len__() == 2 — MRO is [Semaphore, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# RLock code attributes — extra76
#
# Wave 241 theme: RLock is a Python factory function; code object attrs.
#
# threading.RLock.__code__.co_name     == 'RLock'
# threading.RLock.__code__.co_argcount == 0
#
# No prior threading spec checks RLock.__code__ attrs via thrdmore76. New to extra76.
# ---------------------------------------------------------------------------

table threading_extra76.RLock_code:
  description: "RLock.__code__.co_name=='RLock', co_argcount==0; wave 241 RLock factory function code attrs; new to extra76"
  kind: python_call_eq
  category: code_attributes
  id_prefix: thrdmore76

  columns: [id, function, args, expected, description]
  rows:
    - [RLock_co_name_eq_RLock,
       RLock.__code__.co_name.__eq__,
       ["RLock"],
       true,
       "threading.RLock.__code__.co_name.__eq__('RLock') == True — RLock is a pure-Python factory function in Lib/threading.py (not a class); its code object's co_name stores the name from the def statement which is 'RLock' (5 chars); str.__eq__('RLock') returns True; no prior threading spec checks RLock.__code__.co_name via thrdmore76; new to extra76"]
    - [RLock_co_argcount_eq_0,
       RLock.__code__.co_argcount.__eq__,
       [0],
       true,
       "threading.RLock.__code__.co_argcount.__eq__(0) == True — RLock() is a factory function that takes no required positional parameters (it may accept keyword args passed to the underlying C type); co_argcount counts only positional-or-keyword parameters in the def signature and equals 0; int.__eq__(0) returns True; no prior threading spec checks RLock.__code__.co_argcount via thrdmore76; new to extra76"]

# ---------------------------------------------------------------------------
# BoundedSemaphore name/module identity — extra76
#
# Wave 241 theme: BoundedSemaphore class identity.
#
# threading.BoundedSemaphore.__name__   == 'BoundedSemaphore'
# threading.BoundedSemaphore.__module__ == 'threading'
#
# No prior threading spec checks BoundedSemaphore __name__/__module__ via thrdmore76. New to extra76.
# ---------------------------------------------------------------------------

table threading_extra76.BoundedSemaphore_name_module:
  description: "BoundedSemaphore.__name__=='BoundedSemaphore', __module__=='threading'; wave 241 BoundedSemaphore identity; new to extra76"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdmore76

  columns: [id, function, args, expected, description]
  rows:
    - [BoundedSemaphore_name_eq_BoundedSemaphore,
       BoundedSemaphore.__name__.__eq__,
       ["BoundedSemaphore"],
       true,
       "threading.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') == True — BoundedSemaphore is a pure-Python class defined in Lib/threading.py that is a subclass of Semaphore with an upper bound; its __name__ attribute stores the class name as a str 'BoundedSemaphore' (16 chars); str.__eq__('BoundedSemaphore') returns True; no prior threading spec checks BoundedSemaphore.__name__ via thrdmore76; new to extra76"]
    - [BoundedSemaphore_module_eq_threading,
       BoundedSemaphore.__module__.__eq__,
       ["threading"],
       true,
       "threading.BoundedSemaphore.__module__.__eq__('threading') == True — BoundedSemaphore is defined in Lib/threading.py and its __module__ attribute records the module name as the str 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks BoundedSemaphore.__module__ via thrdmore76; new to extra76"]

# ---------------------------------------------------------------------------
# BoundedSemaphore base class and MRO — extra76
#
# Wave 241 theme: BoundedSemaphore inherits from Semaphore.
#
# threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
# threading.BoundedSemaphore.__mro__.__len__()     == 3
#
# No prior threading spec checks BoundedSemaphore __bases__/__mro__ via thrdmore76. New to extra76.
# ---------------------------------------------------------------------------

table threading_extra76.BoundedSemaphore_bases_mro:
  description: "BoundedSemaphore.__bases__[0].__name__=='Semaphore', __mro__.__len__()==3; wave 241 BoundedSemaphore hierarchy; new to extra76"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdmore76

  columns: [id, function, args, expected, description]
  rows:
    - [BoundedSemaphore_bases0_name_eq_Semaphore,
       "BoundedSemaphore.__bases__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — BoundedSemaphore is a subclass of Semaphore that adds an upper bound check; __bases__[0] is Semaphore and Semaphore.__name__ == 'Semaphore' (9 chars); str.__eq__('Semaphore') returns True; no prior threading spec checks BoundedSemaphore.__bases__[0].__name__ via thrdmore76; new to extra76"]
    - [BoundedSemaphore_mro_len_eq_3,
       BoundedSemaphore.__mro__.__len__,
       [],
       3,
       "threading.BoundedSemaphore.__mro__.__len__() == 3 — BoundedSemaphore's MRO is [BoundedSemaphore, Semaphore, object] with exactly 3 entries; tuple.__len__() returns 3; no prior threading spec checks BoundedSemaphore.__mro__.__len__ via thrdmore76; new to extra76"]

# ---------------------------------------------------------------------------
# Semaphore name/module/bases/MRO identity — extra76
#
# Wave 241 theme: Semaphore class identity and hierarchy.
#
# threading.Semaphore.__name__              == 'Semaphore'
# threading.Semaphore.__module__            == 'threading'
# threading.Semaphore.__bases__[0].__name__ == 'object'
# threading.Semaphore.__mro__.__len__()     == 2
#
# No prior threading spec checks Semaphore hierarchy via thrdmore76. New to extra76.
# ---------------------------------------------------------------------------

table threading_extra76.Semaphore_identity_and_hierarchy:
  description: "Semaphore.__name__=='Semaphore', __module__=='threading', __bases__[0].__name__=='object', __mro__.__len__()==2; wave 241 Semaphore identity; new to extra76"
  kind: python_call_eq
  category: type_identity
  id_prefix: thrdmore76

  columns: [id, function, args, expected, description]
  rows:
    - [Semaphore_name_eq_Semaphore,
       Semaphore.__name__.__eq__,
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore is a pure-Python class defined in Lib/threading.py that implements a semaphore synchronization primitive; its __name__ attribute stores the class name as a str 'Semaphore' (9 chars); str.__eq__('Semaphore') returns True; no prior threading spec checks Semaphore.__name__ via thrdmore76; new to extra76"]
    - [Semaphore_module_eq_threading,
       Semaphore.__module__.__eq__,
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is defined in Lib/threading.py and its __module__ attribute records the module name as the str 'threading' (9 chars); str.__eq__('threading') returns True; no prior threading spec checks Semaphore.__module__ via thrdmore76; new to extra76"]
    - [Semaphore_bases0_name_eq_object,
       "Semaphore.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Semaphore.__bases__[0].__name__.__eq__('object') == True — Semaphore inherits directly from object with no intermediate base classes; __bases__[0] is object and object.__name__ == 'object' (6 chars); str.__eq__('object') returns True; no prior threading spec checks Semaphore.__bases__[0].__name__ via thrdmore76; new to extra76"]
    - [Semaphore_mro_len_eq_2,
       Semaphore.__mro__.__len__,
       [],
       2,
       "threading.Semaphore.__mro__.__len__() == 2 — Semaphore inherits directly from object; its MRO is [Semaphore, object] with exactly 2 entries; tuple.__len__() returns 2; no prior threading spec checks Semaphore.__mro__.__len__ via thrdmore76; new to extra76"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra76
# ---------------------------------------------------------------------------

invariant threading_extra76.RLock_co_name:
  description: "threading.RLock.__code__.co_name.__eq__('RLock') == True — RLock factory function co_name is 'RLock'; wave 241 RLock code attrs; new to extra76"
  kind: python_call_eq
  function: RLock.__code__.co_name.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra76.RLock_co_argcount:
  description: "threading.RLock.__code__.co_argcount.__eq__(0) == True — RLock factory function co_argcount is 0 (no required positional args); wave 241 RLock code attrs; new to extra76"
  kind: python_call_eq
  function: RLock.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant threading_extra76.BoundedSemaphore_mro_len:
  description: "threading.BoundedSemaphore.__mro__.__len__() == 3 — BoundedSemaphore MRO has 3 entries [BoundedSemaphore, Semaphore, object]; wave 241 BoundedSemaphore hierarchy; new to extra76"
  kind: python_call_eq
  function: BoundedSemaphore.__mro__.__len__
  args: []
  expected: 3

invariant threading_extra76.Semaphore_name:
  description: "threading.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore class name is 'Semaphore'; wave 241 Semaphore identity; new to extra76"
  kind: python_call_eq
  function: Semaphore.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra76.Semaphore_mro_len:
  description: "threading.Semaphore.__mro__.__len__() == 2 — Semaphore MRO has 2 entries [Semaphore, object]; wave 241 Semaphore hierarchy; new to extra76"
  kind: python_call_eq
  function: Semaphore.__mro__.__len__
  args: []
  expected: 2
