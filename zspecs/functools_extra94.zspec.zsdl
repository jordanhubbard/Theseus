spec: functools_extra94
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra93

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra93.zspec.zsdl."
    - "This spec covers: functools.WRAPPER_ASSIGNMENTS and functools.WRAPPER_UPDATES tuple membership and lengths (Wave 250)."
    - "functools.WRAPPER_ASSIGNMENTS is ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__') in Python 3.14.3."
    - "Python 3.14 replaced '__annotations__' with '__annotate__' and added '__type_params__' in WRAPPER_ASSIGNMENTS."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is the first element. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — '__name__' is the second element. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — '__qualname__' is the third element. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — '__doc__' is the fourth element. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True — '__annotate__' is the fifth element (Python 3.14+). Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__type_params__') == True — '__type_params__' is the sixth element (Python 3.14+). Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotations__') == False — '__annotations__' was replaced by '__annotate__' in Python 3.14. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__dict__') == False — '__dict__' is in WRAPPER_UPDATES not WRAPPER_ASSIGNMENTS. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__contains__('__wrapped__') == False — '__wrapped__' is added by wraps() as a side effect, not in WRAPPER_ASSIGNMENTS. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — six elements in Python 3.14.3. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is the only element in WRAPPER_UPDATES. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__len__() == 1 — only one element '__dict__'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS membership group 1: __module__, __name__, __qualname__, __doc__
#
# Wave 250 theme: functools.WRAPPER_ASSIGNMENTS tuple membership — first four elements.
#
# functools.WRAPPER_ASSIGNMENTS.__contains__('__module__')   == True
# functools.WRAPPER_ASSIGNMENTS.__contains__('__name__')     == True
# functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True
# functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__')      == True
#
# Prior spec extra93 checked WRAPPER_ASSIGNMENTS.__class__.__name__. This spec (extra94) checks membership. New to extra94.
# ---------------------------------------------------------------------------

table functools_extra94.wrapper_assignments_membership_group1:
  description: "__module__/__name__/__qualname__/__doc__ are in WRAPPER_ASSIGNMENTS; tuple.__contains__ checks; wave 250; new to extra94"
  kind: python_call_eq
  category: membership
  id_prefix: functoolswrapper94

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_ASSIGNMENTS_contains_module,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — WRAPPER_ASSIGNMENTS is the tuple ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__') in Python 3.14.3; '__module__' is the first element (index 0); tuple.__contains__('__module__') returns True; prior spec extra93 checked WRAPPER_ASSIGNMENTS.__class__.__name__; this spec (extra94) checks membership; new to extra94"]
    - [WRAPPER_ASSIGNMENTS_contains_name,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — WRAPPER_ASSIGNMENTS is the tuple ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'); '__name__' is the second element (index 1); tuple.__contains__('__name__') returns True; new to extra94"]
    - [WRAPPER_ASSIGNMENTS_contains_qualname,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__qualname__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — WRAPPER_ASSIGNMENTS tuple in Python 3.14.3; '__qualname__' is the third element (index 2); tuple.__contains__('__qualname__') returns True; new to extra94"]
    - [WRAPPER_ASSIGNMENTS_contains_doc,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__doc__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — WRAPPER_ASSIGNMENTS tuple in Python 3.14.3; '__doc__' is the fourth element (index 3); tuple.__contains__('__doc__') returns True; new to extra94"]

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS membership group 2: __annotate__, __type_params__, and negative checks
#
# Wave 250 theme: functools.WRAPPER_ASSIGNMENTS tuple membership — Python 3.14 additions and negatives.
#
# functools.WRAPPER_ASSIGNMENTS.__contains__('__annotate__')    == True  (Python 3.14+)
# functools.WRAPPER_ASSIGNMENTS.__contains__('__type_params__') == True  (Python 3.14+)
# functools.WRAPPER_ASSIGNMENTS.__contains__('__annotations__') == False (replaced in 3.14)
# functools.WRAPPER_ASSIGNMENTS.__contains__('__wrapped__')     == False (not in this tuple)
#
# New checks for Python 3.14 contents. New to extra94.
# ---------------------------------------------------------------------------

table functools_extra94.wrapper_assignments_membership_group2:
  description: "__annotate__/__type_params__ in WRAPPER_ASSIGNMENTS (Python 3.14+); __annotations__/__wrapped__ not in WRAPPER_ASSIGNMENTS; wave 250; new to extra94"
  kind: python_call_eq
  category: membership
  id_prefix: functoolswrapper94

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_ASSIGNMENTS_contains_annotate,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__annotate__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True — '__annotate__' is the fifth element of WRAPPER_ASSIGNMENTS in Python 3.14.3; Python 3.14 replaced '__annotations__' with '__annotate__' in this tuple; tuple.__contains__('__annotate__') returns True; new to extra94"]
    - [WRAPPER_ASSIGNMENTS_contains_type_params,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__type_params__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__type_params__') == True — '__type_params__' is the sixth element of WRAPPER_ASSIGNMENTS in Python 3.14.3; added in a Python 3.12+ release to support PEP 695 type parameters; tuple.__contains__('__type_params__') returns True; new to extra94"]
    - [WRAPPER_ASSIGNMENTS_not_contains_annotations,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__annotations__"],
       false,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotations__') == False — '__annotations__' was removed from WRAPPER_ASSIGNMENTS in Python 3.14 and replaced by '__annotate__'; tuple.__contains__('__annotations__') returns False; Python < 3.14 had '__annotations__' instead; this confirms the Python 3.14 change; new to extra94"]
    - [WRAPPER_ASSIGNMENTS_not_contains_wrapped,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__wrapped__"],
       false,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__wrapped__') == False — '__wrapped__' is NOT in WRAPPER_ASSIGNMENTS; it is added by functools.wraps() as a direct assignment in update_wrapper (not via WRAPPER_ASSIGNMENTS), pointing to the original wrapped function; tuple.__contains__('__wrapped__') returns False; new to extra94"]

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES membership + lengths
#
# Wave 250 theme: functools.WRAPPER_UPDATES membership and tuple lengths.
#
# functools.WRAPPER_UPDATES.__contains__('__dict__') == True
# functools.WRAPPER_UPDATES.__len__()                == 1
# functools.WRAPPER_ASSIGNMENTS.__len__()            == 6
# functools.WRAPPER_UPDATES.__contains__('__wrapped__') == False
#
# New to extra94.
# ---------------------------------------------------------------------------

table functools_extra94.wrapper_updates_membership_and_lengths:
  description: "WRAPPER_UPDATES membership and lengths; WRAPPER_ASSIGNMENTS __len__==6; wave 250; new to extra94"
  kind: python_call_eq
  category: membership
  id_prefix: functoolswrapper94

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_UPDATES_contains_dict,
       WRAPPER_UPDATES.__contains__,
       ["__dict__"],
       true,
       "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — WRAPPER_UPDATES is the tuple ('__dict__',) in Python 3.14.3; '__dict__' is the only element; update_wrapper merges the wrapper's __dict__ with the wrapped function's __dict__; tuple.__contains__('__dict__') returns True; new to extra94"]
    - [WRAPPER_UPDATES_len_eq_1,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is ('__dict__',) with exactly one element; tuple.__len__() returns 1; new to extra94"]
    - [WRAPPER_ASSIGNMENTS_len_eq_6,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS is ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__') in Python 3.14.3 with exactly six elements; tuple.__len__() returns 6; prior Python versions had 5 elements (__annotations__ instead of __annotate__ and no __type_params__); new to extra94"]
    - [WRAPPER_UPDATES_not_contains_wrapped,
       WRAPPER_UPDATES.__contains__,
       ["__wrapped__"],
       false,
       "functools.WRAPPER_UPDATES.__contains__('__wrapped__') == False — '__wrapped__' is not in WRAPPER_UPDATES; it is added directly by update_wrapper as a plain attribute assignment, not through either WRAPPER_ASSIGNMENTS or WRAPPER_UPDATES; tuple.__contains__('__wrapped__') returns False; new to extra94"]

# ---------------------------------------------------------------------------
# Cross-checks: WRAPPER_ASSIGNMENTS vs WRAPPER_UPDATES membership distinctions
#
# Wave 250 theme: cross-checking that __dict__ is in UPDATES not ASSIGNMENTS, etc.
#
# functools.WRAPPER_ASSIGNMENTS.__contains__('__dict__')  == False
# functools.WRAPPER_UPDATES.__contains__('__module__')    == False
# functools.WRAPPER_UPDATES.__contains__('__annotate__')  == False
# functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True (re-confirm)
#
# New to extra94.
# ---------------------------------------------------------------------------

table functools_extra94.wrapper_cross_checks:
  description: "__dict__ not in WRAPPER_ASSIGNMENTS; __module__ not in WRAPPER_UPDATES; cross-check partition between the two tuples; wave 250; new to extra94"
  kind: python_call_eq
  category: membership
  id_prefix: functoolswrapper94

  columns: [id, function, args, expected, description]
  rows:
    - [WRAPPER_ASSIGNMENTS_not_contains_dict,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__dict__"],
       false,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__dict__') == False — '__dict__' is in WRAPPER_UPDATES (merged) not WRAPPER_ASSIGNMENTS (copied); WRAPPER_ASSIGNMENTS contains attribute names that are copied directly; WRAPPER_UPDATES contains attribute names whose values are updated (merged) into the wrapper; tuple.__contains__('__dict__') returns False; new to extra94"]
    - [WRAPPER_UPDATES_not_contains_module,
       WRAPPER_UPDATES.__contains__,
       ["__module__"],
       false,
       "functools.WRAPPER_UPDATES.__contains__('__module__') == False — '__module__' is in WRAPPER_ASSIGNMENTS (copied directly) not WRAPPER_UPDATES; each attribute name appears in exactly one of the two tuples; tuple.__contains__('__module__') returns False; confirms clean partition between WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES; new to extra94"]
    - [WRAPPER_UPDATES_not_contains_annotate,
       WRAPPER_UPDATES.__contains__,
       ["__annotate__"],
       false,
       "functools.WRAPPER_UPDATES.__contains__('__annotate__') == False — '__annotate__' is in WRAPPER_ASSIGNMENTS not WRAPPER_UPDATES; tuple.__contains__('__annotate__') returns False; new to extra94"]
    - [WRAPPER_ASSIGNMENTS_contains_module_reconfirm,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — re-confirms '__module__' is in WRAPPER_ASSIGNMENTS; tuple.__contains__('__module__') returns True; new to extra94"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra94
# ---------------------------------------------------------------------------

invariant functools_extra94.WRAPPER_ASSIGNMENTS_contains_module:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is in WRAPPER_ASSIGNMENTS tuple; wave 250; new to extra94"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__module__"]
  expected: true

invariant functools_extra94.WRAPPER_ASSIGNMENTS_len_eq_6:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS has 6 elements in Python 3.14.3; wave 250; new to extra94"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra94.WRAPPER_UPDATES_contains_dict:
  description: "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is the sole element of WRAPPER_UPDATES; wave 250; new to extra94"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true

invariant functools_extra94.WRAPPER_UPDATES_len_eq_1:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES has exactly one element; wave 250; new to extra94"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra94.WRAPPER_ASSIGNMENTS_not_contains_wrapped:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__wrapped__') == False — '__wrapped__' is not in WRAPPER_ASSIGNMENTS; wave 250; new to extra94"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__wrapped__"]
  expected: false
