spec: socket_extra45
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra44.zspec.zsdl — covers socket.socket recvfrom/sendto/connect_ex/recv_into/recvfrom_into __name__.__eq__ string values."
    - "socket_extra43.zspec.zsdl — covers socket.socket settimeout/gettimeout/shutdown/sendall __name__.__eq__ string values."
    - "socket_extra41.zspec.zsdl — covers socket.socket setblocking/getpeername/getsockname/makefile/detach/dup __name__.__eq__; socket.gethostname __name__/__module__.__eq__."
    - "socket_extra9.zspec.zsdl — covers socket.gethostname/__module__.__eq__('_socket') and socket.getaddrinfo/__module__.__eq__('socket'); also incorrectly covers socket.getnameinfo/__module__.__eq__('socket') with stale value — actual value is '_socket' not 'socket'."
    - "socket_extra8.zspec.zsdl — covers __qualname__.__eq__ for gethostname/gethostbyname/getaddrinfo/getfqdn/create_connection via table; does NOT include getnameinfo or gethostbyaddr."
    - "socket_extra4.zspec.zsdl — covers gethostbyname/__name__.__eq__, gethostbyaddr/__name__.__eq__, getnameinfo/__name__.__eq__."
    - "socket_extra3.zspec.zsdl — covers getaddrinfo/__name__, gethostbyname/__name__, getnameinfo/__name__, getfqdn/__name__ via standalone invariants."
  notes:
    - "This spec extends socket through socket_extra44; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: socket_extra4 covers gethostbyname/__name__.__eq__('gethostbyname') and socket_extra8 covers gethostbyname/__qualname__.__eq__('gethostbyname'). But NO prior spec checks socket.gethostbyname.__module__.__eq__('_socket'). socket_extra9 covers gethostname/__module__.__eq__('_socket') and getaddrinfo/__module__.__eq__('socket'), but not gethostbyname/__module__. gethostbyname is a C function in the _socket extension. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__module__ == '_socket'. gethostbyname is implemented in the _socket C extension, not the Python socket wrapper. No prior spec checks gethostbyname.__module__.__eq__('_socket'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: socket_extra4 covers getnameinfo/__name__.__eq__('getnameinfo'). socket_extra9 covers getnameinfo/__module__.__eq__('socket') — this is a STALE value; the actual module is '_socket'. NO prior spec checks getnameinfo.__qualname__.__eq__('getnameinfo'): socket_extra8's table includes gethostname/gethostbyname/getaddrinfo/getfqdn/create_connection but NOT getnameinfo. NO prior spec provides the CORRECT getnameinfo.__module__.__eq__('_socket') value. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.getnameinfo.__qualname__ == 'getnameinfo'. C builtin in _socket; __qualname__ == __name__ for C builtins. socket_extra8's qualname table omits getnameinfo. No prior spec checks getnameinfo.__qualname__.__eq__('getnameinfo'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.getnameinfo.__module__ == '_socket'. The actual module is '_socket', not 'socket'. socket_extra9 has a stale invariant with value 'socket' (incorrect on Python 3.14 macOS). No prior spec covers the correct '_socket' value for getnameinfo.__module__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: socket_extra4 covers gethostbyaddr/__name__.__eq__('gethostbyaddr'). But NO prior spec checks gethostbyaddr.__qualname__.__eq__('gethostbyaddr') or gethostbyaddr.__module__.__eq__('_socket'). socket_extra8's qualname table does not include gethostbyaddr. gethostbyaddr is a C function in the _socket extension. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gethostbyaddr.__qualname__ == 'gethostbyaddr'. C builtin; __qualname__ == __name__. socket_extra4 covers __name__.__eq__; socket_extra8's table omits gethostbyaddr. No prior spec checks gethostbyaddr.__qualname__.__eq__('gethostbyaddr'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "socket.gethostbyaddr.__module__ == '_socket'. gethostbyaddr is implemented in the _socket C extension. No prior spec checks gethostbyaddr.__module__.__eq__('_socket'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.gethostbyname __module__ string eq check
#
# socket_extra4 covers gethostbyname.__name__.__eq__('gethostbyname').
# socket_extra8 covers gethostbyname.__qualname__.__eq__('gethostbyname').
# socket_extra9 covers gethostname/__module__.__eq__('_socket') and
#   getaddrinfo/__module__.__eq__('socket') but NOT gethostbyname/__module__.
# gethostbyname is a C builtin from the _socket extension.
# No prior spec checks gethostbyname.__module__.__eq__('_socket').
# ---------------------------------------------------------------------------

invariant socket_extra45.gethostbyname.module_eq:
  description: "socket.gethostbyname.__module__ == '_socket' — C builtin from _socket extension; novel: extra4 covers __name__.__eq__; extra8 covers __qualname__.__eq__; extra9 covers gethostname/__module__ but NOT gethostbyname/__module__; no prior spec checks gethostbyname.__module__.__eq__"
  category: function_module
  kind: python_call_eq
  function: gethostbyname.__module__.__eq__
  args: ["_socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getnameinfo __qualname__ and __module__ string eq checks
#
# socket_extra4 covers getnameinfo.__name__.__eq__('getnameinfo').
# socket_extra8's qualname table covers gethostname/gethostbyname/getaddrinfo/
#   getfqdn/create_connection but NOT getnameinfo.
# socket_extra9 covers getnameinfo.__module__.__eq__('socket') — STALE value;
#   actual module is '_socket' on Python 3.14 macOS/Darwin.
# No prior spec checks getnameinfo.__qualname__.__eq__('getnameinfo').
# No prior spec provides the correct getnameinfo.__module__.__eq__('_socket').
# ---------------------------------------------------------------------------

table socket_extra45.getnameinfo_qualname_module_eq:
  description: "socket.getnameinfo __qualname__.__eq__('getnameinfo') and __module__.__eq__('_socket') — novel: extra8 qualname table omits getnameinfo; extra9 covers __module__.__eq__('socket') with stale incorrect value; no prior spec checks getnameinfo __qualname__.__eq__ or correct __module__.__eq__('_socket')"
  kind: python_call_eq
  category: function_names
  id_prefix: sgnqme45

  columns: [id, function, args, expected]
  rows:
    - [getnameinfo_qualname_eq, getnameinfo.__qualname__.__eq__, ["getnameinfo"], true]
    - [getnameinfo_module_eq,   getnameinfo.__module__.__eq__,   ["_socket"],     true]

# ---------------------------------------------------------------------------
# socket.gethostbyaddr __qualname__ and __module__ string eq checks
#
# socket_extra4 covers gethostbyaddr.__name__.__eq__('gethostbyaddr').
# socket_extra8's qualname table does NOT include gethostbyaddr.
# No prior spec checks gethostbyaddr.__qualname__.__eq__('gethostbyaddr') or
#   gethostbyaddr.__module__.__eq__('_socket').
# gethostbyaddr is a C builtin from the _socket extension; __qualname__ == __name__.
# ---------------------------------------------------------------------------

table socket_extra45.gethostbyaddr_qualname_module_eq:
  description: "socket.gethostbyaddr __qualname__.__eq__('gethostbyaddr') and __module__.__eq__('_socket') — novel: extra4 covers __name__.__eq__ only; extra8 qualname table omits gethostbyaddr; no prior spec checks gethostbyaddr __qualname__.__eq__ or __module__.__eq__"
  kind: python_call_eq
  category: function_names
  id_prefix: sghaqme45

  columns: [id, function, args, expected]
  rows:
    - [gethostbyaddr_qualname_eq, gethostbyaddr.__qualname__.__eq__, ["gethostbyaddr"], true]
    - [gethostbyaddr_module_eq,   gethostbyaddr.__module__.__eq__,   ["_socket"],       true]
