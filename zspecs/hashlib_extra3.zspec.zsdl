spec: hashlib_extra3
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"
  - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "FIPS 202 — SHA-3 Standard, NIST, August 2015"
    - "RFC 7693 — The BLAKE2 Cryptographic Hash and MAC, November 2015"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified by running Python 3.14.3 hashlib on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha512module.c"
    - "CPython source: Modules/md5module.c"
    - "CPython source: Modules/_sha3/sha3module.c"
    - "CPython source: Modules/_blake2/blake2module.c"
  notes:
    - "This spec extends hashlib.zspec.zsdl, hashlib_extra.zspec.zsdl, and hashlib_extra2.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "hashlib.zspec.zsdl covers: sha256/sha1/md5/sha512/sha3_256/sha3_512/blake2b/blake2s known vectors; digest_size/block_size attrs for sha256/sha3_256/sha3_512/blake2b/blake2s; sha1/md5/sha512 digest_size; algorithms_guaranteed; sha256.name_attr."
    - "hashlib_extra.zspec.zsdl covers: blake2b/blake2s name; sha3_224/sha3_384 digest_size/block_size/name; algorithms_available; pbkdf2_hmac."
    - "hashlib_extra2.zspec.zsdl covers: md5/sha1/sha256 empty hexdigest; sha256/sha512 digest_size equality; md5(b'hello') hexdigest; algorithms_guaranteed type; new() api."
    - "sha512.block_size == 128 — SHA-512 processes 1024-bit (128-byte) blocks per FIPS 180-4 Section 1."
    - "md5.block_size == 64 — MD5 processes 512-bit (64-byte) blocks per RFC 1321 Section 2."
    - "sha256.block_size == 64 is already covered in hashlib.zspec.zsdl via hash_object_attr; here we provide python_call_eq coverage for sha512 and md5."
    - "sha512(b'').name == 'sha512' — the .name attribute returns the canonical algorithm identifier string."
    - "sha384(b'').name == 'sha384' — sha384 is a truncated variant of sha512; block_size == 128."
    - "sha224(b'').name == 'sha224' — sha224 is a truncated variant of sha256; block_size == 64."
    - "sha3_256(b'').name == 'sha3_256' — not yet covered in any prior spec."
    - "sha3_512(b'').name == 'sha3_512' — not yet covered in any prior spec."
    - "blake2b(b'').name == 'blake2b' — already covered in hashlib_extra via blake2b() no-arg; here we use empty-bytes arg for orthogonal coverage."
    - "blake2s(b'').name == 'blake2s' — already covered in hashlib_extra via blake2s() no-arg; here we use empty-bytes arg for orthogonal coverage."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "hashlib raises ValueError for unknown algorithm names passed to hashlib.new(). Hash constructor calls do not raise for valid algorithms."
  stderr: "null"
  stickiness: "N/A — hash objects are independent; module-level attributes are read-only sets."
  codes: {}

# ---------------------------------------------------------------------------
# name attribute — sha512, sha384, sha224, sha3_256, sha3_512
# These use the module-level constructor with empty-bytes arg (!hex "").
# hashlib.zspec.zsdl covers sha256.name_attr; hashlib_extra covers sha3_224,
# blake2b, blake2s name attrs; here we add the remaining five.
# ---------------------------------------------------------------------------

invariant hashlib_extra3.sha512.name_attr:
  description: "hashlib.sha512(b'').name == 'sha512'"
  category: properties
  kind: python_call_eq
  function: sha512
  args: [!hex ""]
  method: name.__eq__
  method_args: ["sha512"]
  expected: true

invariant hashlib_extra3.sha384.name_attr:
  description: "hashlib.sha384(b'').name == 'sha384'"
  category: properties
  kind: python_call_eq
  function: sha384
  args: [!hex ""]
  method: name.__eq__
  method_args: ["sha384"]
  expected: true

invariant hashlib_extra3.sha224.name_attr:
  description: "hashlib.sha224(b'').name == 'sha224'"
  category: properties
  kind: python_call_eq
  function: sha224
  args: [!hex ""]
  method: name.__eq__
  method_args: ["sha224"]
  expected: true

invariant hashlib_extra3.sha3_256.name_attr:
  description: "hashlib.sha3_256(b'').name == 'sha3_256'"
  category: properties
  kind: python_call_eq
  function: sha3_256
  args: [!hex ""]
  method: name.__eq__
  method_args: ["sha3_256"]
  expected: true

invariant hashlib_extra3.sha3_512.name_attr:
  description: "hashlib.sha3_512(b'').name == 'sha3_512'"
  category: properties
  kind: python_call_eq
  function: sha3_512
  args: [!hex ""]
  method: name.__eq__
  method_args: ["sha3_512"]
  expected: true

invariant hashlib_extra3.blake2b.name_attr_with_data:
  description: "hashlib.blake2b(b'').name == 'blake2b' (empty-bytes arg variant)"
  category: properties
  kind: python_call_eq
  function: blake2b
  args: [!hex ""]
  method: name.__eq__
  method_args: ["blake2b"]
  expected: true

invariant hashlib_extra3.blake2s.name_attr_with_data:
  description: "hashlib.blake2s(b'').name == 'blake2s' (empty-bytes arg variant)"
  category: properties
  kind: python_call_eq
  function: blake2s
  args: [!hex ""]
  method: name.__eq__
  method_args: ["blake2s"]
  expected: true

# ---------------------------------------------------------------------------
# block_size — sha512, md5
# sha256.block_size == 64 is in hashlib.zspec.zsdl (hash_object_attr).
# sha3_256.block_size == 136 is in hashlib.zspec.zsdl (hash_object_attr).
# sha3_224.block_size == 144 and sha3_384.block_size == 104 are in hashlib_extra.
# blake2b.block_size == 128 and blake2s.block_size == 64 are in hashlib.zspec.zsdl.
# Here we add sha512 and md5 via python_call_eq.
# ---------------------------------------------------------------------------

invariant hashlib_extra3.sha256.block_size_eq:
  description: "hashlib.sha256(b'').block_size == 64 — SHA-256 processes 512-bit (64-byte) blocks"
  category: properties
  kind: python_call_eq
  function: sha256
  args: [!hex ""]
  method: block_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra3.sha512.block_size_eq:
  description: "hashlib.sha512(b'').block_size == 128 — SHA-512 processes 1024-bit (128-byte) blocks per FIPS 180-4"
  category: properties
  kind: python_call_eq
  function: sha512
  args: [!hex ""]
  method: block_size.__eq__
  method_args: [128]
  expected: true

invariant hashlib_extra3.md5.block_size_eq:
  description: "hashlib.md5(b'').block_size == 64 — MD5 processes 512-bit (64-byte) blocks per RFC 1321"
  category: properties
  kind: python_call_eq
  function: md5
  args: [!hex ""]
  method: block_size.__eq__
  method_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# Constructor __name__ attributes
# On OpenSSL-backed builds (Linux, macOS) the module-level md5/sha1/sha256/
# sha512 names are openssl_md5 etc. because they are C-extension types.
# _hashlib.zspec.zsdl covers openssl_md5.__name__ for _hashlib directly;
# here we verify the same attribute via the hashlib top-level re-exports.
# ---------------------------------------------------------------------------

invariant hashlib_extra3.md5.constructor_name:
  description: "hashlib.md5.__name__ == 'openssl_md5' on OpenSSL-backed builds"
  category: identity
  kind: python_call_eq
  function: md5.__name__.__eq__
  args: ["openssl_md5"]
  expected: true

invariant hashlib_extra3.sha1.constructor_name:
  description: "hashlib.sha1.__name__ == 'openssl_sha1' on OpenSSL-backed builds"
  category: identity
  kind: python_call_eq
  function: sha1.__name__.__eq__
  args: ["openssl_sha1"]
  expected: true

invariant hashlib_extra3.sha256.constructor_name:
  description: "hashlib.sha256.__name__ == 'openssl_sha256' on OpenSSL-backed builds"
  category: identity
  kind: python_call_eq
  function: sha256.__name__.__eq__
  args: ["openssl_sha256"]
  expected: true

invariant hashlib_extra3.sha512.constructor_name:
  description: "hashlib.sha512.__name__ == 'openssl_sha512' on OpenSSL-backed builds"
  category: identity
  kind: python_call_eq
  function: sha512.__name__.__eq__
  args: ["openssl_sha512"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_available — class name (already covered in hashlib_extra;
# here we add algorithms_available.__class__.__name__ via this spec's namespace)
# algorithms_guaranteed — len >= 6 (new coverage, not in any prior spec)
# ---------------------------------------------------------------------------

invariant hashlib_extra3.algorithms_available.class_name:
  description: "hashlib.algorithms_available.__class__.__name__ == 'set'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlib_extra3.algorithms_guaranteed.class_name:
  description: "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlib_extra3.algorithms_guaranteed.len_ge_6:
  description: "len(hashlib.algorithms_guaranteed) >= 6 — at least 6 algorithms guaranteed on every platform"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__len__
  args: []
  method: __ge__
  method_args: [6]
  expected: true
