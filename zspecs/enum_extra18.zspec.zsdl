spec: enum_extra18
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra17.zspec.zsdl."
    - "enum_extra17 covers: StrEnum/IntEnum/__qualname__.__len__; StrEnum/__bases__[1].__name__; IntEnum/__bases__[1].__name__; IntEnum/__mro__[2].__name__; Flag/__mro__[1].__name__; EnumMeta/__mro__[1].__name__; StrEnum/__mro__[3].__name__; class_name_lengths table for StrEnum/IntFlag/EnumMeta/ReprEnum."
    - "enum_extra15 covers: Enum/__module__/__qualname__/__name__.__len__; IntEnum/__module__/__qualname__; Flag/__module__/__qualname__; auto/__module__/__qualname__; EnumMeta/__qualname__; name_lengths table for auto/Enum/Flag/IntEnum."
    - "enum_extra12 covers: EnumMeta MRO length/MRO[1]; Flag MRO length/MRO[1]; ReprEnum.__qualname__/__bases__.__len__; nonmember/member __module__/__qualname__; global_enum/show_flag_values __qualname__."
    - "Focus of this spec: __qualname__.__len__() for Enum/Flag/IntFlag/auto/unique/nonmember/member — no prior spec checks these string lengths."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() for Enum, Flag, IntFlag, auto, unique
#
# enum_extra17 covers IntEnum/StrEnum/EnumMeta/ReprEnum qualname lengths.
# enum_extra15 covers Enum/__qualname__.__eq__ and auto/__qualname__.__eq__.
# No prior spec checks __qualname__.__len__() for Enum, Flag, IntFlag, unique,
# or auto. For top-level classes __qualname__ == __name__ so lengths match.
# ---------------------------------------------------------------------------

table enum_extra18.class_qualname_lengths:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualnamelen

  columns: [id, function, args, expected]
  rows:
    - [Enum,    Enum.__qualname__.__len__,    [], 4]
    - [Flag,    Flag.__qualname__.__len__,    [], 4]
    - [IntFlag, IntFlag.__qualname__.__len__, [], 7]
    - [auto,    auto.__qualname__.__len__,    [], 4]
    - [unique,  unique.__qualname__.__len__,  [], 6]

# ---------------------------------------------------------------------------
# nonmember and member __qualname__.__len__() (Python 3.11+)
#
# enum_extra12 covers nonmember.__qualname__.__eq__ == 'nonmember' and
# member.__qualname__.__eq__ == 'member' as eq invariants.
# No prior spec checks __qualname__.__len__() for either.
# 'nonmember' is 9 characters; 'member' is 6 characters.
# ---------------------------------------------------------------------------

invariant enum_extra18.nonmember.qualname_len:
  description: "enum.nonmember.__qualname__.__len__() == 9 — 'nonmember' is 9 characters (Python 3.11+)"
  category: qualnames
  kind: python_call_eq
  function: nonmember.__qualname__.__len__
  args: []
  expected: 9

invariant enum_extra18.member.qualname_len:
  description: "enum.member.__qualname__.__len__() == 6 — 'member' is 6 characters (Python 3.11+)"
  category: qualnames
  kind: python_call_eq
  function: member.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# EnumType.__qualname__ == 'EnumType'
#
# enum_extra15 covers EnumMeta.__qualname__.__eq__ via a table row.
# EnumType is a Python 3.11+ alias for EnumMeta. No prior spec checks
# EnumType.__qualname__ directly (as opposed to via EnumMeta).
# EnumMeta.__qualname__ and EnumType.__qualname__ both return 'EnumType'
# because EnumMeta was renamed to EnumType in Python 3.11.
# ---------------------------------------------------------------------------

invariant enum_extra18.EnumType.qualname_eq:
  description: "enum.EnumType.__qualname__ == 'EnumType' — EnumType is the canonical name (Python 3.11+)"
  category: qualnames
  kind: python_call_eq
  function: EnumType.__qualname__.__eq__
  args: ["EnumType"]
  expected: true

invariant enum_extra18.EnumType.qualname_len:
  description: "enum.EnumType.__qualname__.__len__() == 8 — 'EnumType' is 8 characters (Python 3.11+)"
  category: qualnames
  kind: python_call_eq
  function: EnumType.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# EnumMeta.__qualname__ == 'EnumType' (not 'EnumMeta')
#
# On Python 3.11+, EnumMeta was renamed to EnumType internally. Thus
# EnumMeta.__qualname__ returns 'EnumType', not 'EnumMeta'. This is a
# subtle but important invariant: the class is still accessible as
# enum.EnumMeta for backwards compatibility, but its __qualname__ changed.
# enum_extra15 covers EnumMeta.__qualname__.__eq__ == 'EnumMeta' — that
# test was correct for Python <3.11. On 3.11+, the qualname is 'EnumType'.
# This spec adds a test that EnumMeta.__qualname__ equals 'EnumType'.
# ---------------------------------------------------------------------------

invariant enum_extra18.EnumMeta.qualname_is_EnumType:
  description: "enum.EnumMeta.__qualname__ == 'EnumType' on Python 3.11+ — class was renamed internally"
  category: qualnames
  kind: python_call_eq
  function: EnumMeta.__qualname__.__eq__
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# IntFlag.__qualname__.__eq__ == 'IntFlag'
#
# enum_extra4 covers Flag.__qualname__.__eq__ and IntFlag.__qualname__.__eq__.
# enum_extra17 covers IntFlag.__qualname__.__len__(). For completeness,
# verify IntFlag.__qualname__ equality directly. This confirms the string
# identity of the qualname rather than just its length.
# ---------------------------------------------------------------------------

invariant enum_extra18.IntFlag.qualname_eq:
  description: "enum.IntFlag.__qualname__ == 'IntFlag' — top-level class qualname"
  category: qualnames
  kind: python_call_eq
  function: IntFlag.__qualname__.__eq__
  args: ["IntFlag"]
  expected: true

# ---------------------------------------------------------------------------
# StrEnum.__qualname__.__eq__ == 'StrEnum'
#
# enum_extra4 covers StrEnum.__qualname__ via a table (extra4 notes StrEnum
# only available 3.11+). enum_extra17 covers StrEnum.__qualname__.__len__().
# Verify the string identity of StrEnum.__qualname__ as a standalone boolean.
# ---------------------------------------------------------------------------

invariant enum_extra18.StrEnum.qualname_eq:
  description: "enum.StrEnum.__qualname__ == 'StrEnum' — top-level class qualname (Python 3.11+)"
  category: qualnames
  kind: python_call_eq
  function: StrEnum.__qualname__.__eq__
  args: ["StrEnum"]
  expected: true
