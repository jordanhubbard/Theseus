spec: inspect_extra_rust
version: ">=3.9"
backend: rust_module(inspect_extra_rust)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect stdlib"
  notes:
    - "inspect provides introspection of Python objects."
    - "inspect.isfunction(lambda: None) is True."
    - "inspect.isclass(int) is True."
    - "inspect.getmembers(str) is a list."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant inspect_extra_rust.isfunction_lambda:
  description: "inspect.isfunction(lambda: None) is True"
  category: isfunction
  kind: python_call_eq
  function: inspect_extra_isfunction_lambda
  args: []
  expected: true

invariant inspect_extra_rust.isclass_int:
  description: "inspect.isclass(int) is True"
  category: isclass
  kind: python_call_eq
  function: inspect_extra_isclass_int
  args: []
  expected: true

invariant inspect_extra_rust.getmembers_str_nonempty:
  description: "inspect.getmembers(str) is non-empty list"
  category: getmembers
  kind: python_call_eq
  function: inspect_extra_getmembers_str_nonempty
  args: []
  expected: true

