spec: uuid_extra158
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra157.zspec.zsdl — covers uuid.UUID.__name__=='UUID' / UUID.__module__=='uuid' / UUID.__bases__[0].__name__=='object' / NAMESPACE_DNS/URL/OID/X500.__class__.__name__=='UUID' (table + invariants)."
    - "uuid_extra156.zspec.zsdl — covers uuid.UUID.__dict__ property membership ('hex'/'int'/'bytes'/'version'/'variant'/'__init__'/'__str__'/'__repr__') and meta-attributes (__len__()==37/__class__.__name__=='mappingproxy') (table + invariants)."
    - "uuid_extra155.zspec.zsdl — covers uuid.UUID.__init__.__code__.co_argcount==7 / co_name / __qualname__ / co_varnames.__len__()==15 (table + invariants)."
    - "uuid_extra154.zspec.zsdl — covers uuid.UUID.__lt__/__le__/__gt__/__ge__/__eq__ qualname strings and lengths (table + invariants)."
    - "uuid_extra153.zspec.zsdl — covers uuid.UUID.__slots__ attribute details (table + invariants)."
    - "uuid_extra149.zspec.zsdl — covers uuid.UUID.__init__.__qualname__/__code__.co_argcount==7 (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra157."
    - "Wave 348 theme: uuid module-level generator function identity — uuid.uuid1/__uuid3/__uuid4/__uuid5 .__name__/__module__/__class__.__name__. uuid_extra157 anchors UUID class identity (UUID.__name__=='UUID' / UUID.__module__=='uuid' / UUID.__bases__). This spec anchors the four uuid generator functions (uuid1/uuid3/uuid4/uuid5) as the primary novel content. Also: UUID.__dict__.__len__()==37 (anchored in uuid_extra156 as table row and standalone) and UUID.__dict__.__class__.__name__=='mappingproxy' (anchored in uuid_extra156) — confirmed but not re-anchored as primary novel content here."
    - "uuid.uuid4.__name__ == 'uuid4'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__name__ == 'uuid1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__name__ == 'uuid3'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__name__ == 'uuid5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.uuid4.__name__ == 'uuid4' (5 chars = 'uuid'=4 + '4'=1). The uuid4() function generates a random UUID (version 4). Its __name__ is the bare function name 'uuid4' (5 chars). uuid4.__module__ == 'uuid' (4 chars; defined in Lib/uuid.py). uuid4.__class__.__name__ == 'function' (8 chars; it is a regular Python function, not a C builtin). All four generator functions (uuid1/uuid3/uuid4/uuid5) share __class__.__name__ == 'function' and __module__ == 'uuid'."
    - "Note: uuid.uuid1.__name__ == 'uuid1' (5 chars). uuid1() generates a time-based UUID (version 1) using the host MAC address and current time. uuid.uuid3.__name__ == 'uuid3' (5 chars). uuid3() generates a name-based UUID (version 3) using MD5 hashing. uuid.uuid5.__name__ == 'uuid5' (5 chars). uuid5() generates a name-based UUID (version 5) using SHA-1 hashing. All four names have the same 5-char length: 'uuid1'=='uuid3'=='uuid4'=='uuid5'==5 chars."
    - "Note: All four generator functions have __module__ == 'uuid' (4 chars) — they are pure Python functions defined in Lib/uuid.py. This contrasts with hashlib hash constructors which have __module__ == '_hashlib' (8 chars, private C extension)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid4.__name__.__eq__('uuid4')
# uuid.uuid4.__module__.__eq__('uuid')
# uuid.uuid1.__name__.__eq__('uuid1')
# uuid.uuid1.__module__.__eq__('uuid')
#
# Wave 348 theme: uuid4 and uuid1 generator function identity.
#
# uuid4.__name__ == 'uuid4' (5 chars; random UUID generator; version 4).
# uuid4.__module__ == 'uuid' (4 chars; pure Python; defined in Lib/uuid.py).
# uuid1.__name__ == 'uuid1' (5 chars; time-based UUID generator; version 1).
# uuid1.__module__ == 'uuid' (4 chars; same module as uuid4).
# No prior uuid spec anchors uuid4.__name__ or uuid1.__name__ as a table under uuidgen158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra158.uuid4_uuid1_name_and_module:
  description: "uuid.uuid4.__name__.__eq__('uuid4')==True / uuid4.__module__.__eq__('uuid')==True / uuid1.__name__.__eq__('uuid1')==True / uuid1.__module__.__eq__('uuid')==True — uuid4.__name__ is 'uuid4' (5 chars = 'uuid'=4 + '4'=1; the version-4 random UUID generator function; version 4 UUIDs are generated from random or pseudo-random numbers per RFC 4122; 'uuid4' is the bare function name as defined in Lib/uuid.py; uuid4.__qualname__=='uuid4' (same as __name__ for module-level functions)); uuid4.__module__ is 'uuid' (4 chars; defined in Lib/uuid.py; pure Python function; not from a C extension; uuid4.__class__.__name__=='function' (8 chars; regular Python function)); uuid1.__name__ is 'uuid1' (5 chars = 'uuid'=4 + '1'=1; the version-1 time-based UUID generator; version 1 UUIDs incorporate the host MAC address and a timestamp; 'uuid1'(5) == 'uuid4'(5) in length; all four generators share the same 5-char __name__ length); uuid1.__module__ is 'uuid' (4 chars; same module as uuid4; all four generator functions are defined in Lib/uuid.py; 'uuid'(4) < 'uuid1'/'uuid4'(5) by 1 char — module name is shorter than function name); first uuidgen158 anchor for uuid4 and uuid1 name/module identity"
  kind: python_call_eq
  category: identity
  id_prefix: uuidgen158

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_name,   "uuid4.__name__.__eq__",   ["uuid4"], true, "uuid.uuid4.__name__ == 'uuid4' (5 chars; version-4 random UUID generator; 'uuid'=4 + '4'=1; bare function name from Lib/uuid.py)"]
    - [uuid4_module, "uuid4.__module__.__eq__",  ["uuid"],  true, "uuid.uuid4.__module__ == 'uuid' (4 chars; pure Python function in Lib/uuid.py; 'uuid'(4) < 'uuid4'(5) by 1 char)"]
    - [uuid1_name,   "uuid1.__name__.__eq__",   ["uuid1"], true, "uuid.uuid1.__name__ == 'uuid1' (5 chars; version-1 time-based UUID generator; MAC address + timestamp; same length as 'uuid4'=5)"]
    - [uuid1_module, "uuid1.__module__.__eq__",  ["uuid"],  true, "uuid.uuid1.__module__ == 'uuid' (4 chars; same module as uuid4; all four generators are in Lib/uuid.py)"]

# ---------------------------------------------------------------------------
# uuid.uuid3.__name__ and __module__
# uuid.uuid5.__name__ and __module__
#
# Wave 348 theme: uuid3 and uuid5 name-based UUID generator identity.
#
# uuid3.__name__ == 'uuid3' (5 chars; MD5-based name UUID; version 3).
# uuid3.__module__ == 'uuid' (4 chars; pure Python; defined in Lib/uuid.py).
# uuid5.__name__ == 'uuid5' (5 chars; SHA-1-based name UUID; version 5).
# uuid5.__module__ == 'uuid' (4 chars; same module as uuid3).
# No prior uuid spec anchors uuid3.__name__ or uuid5.__name__ as a table under uuidgen158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra158.uuid3_uuid5_name_and_module:
  description: "uuid.uuid3.__name__.__eq__('uuid3')==True / uuid3.__module__.__eq__('uuid')==True / uuid5.__name__.__eq__('uuid5')==True / uuid5.__module__.__eq__('uuid')==True — uuid3.__name__ is 'uuid3' (5 chars = 'uuid'=4 + '3'=1; the version-3 name-based UUID generator using MD5 hashing; takes a namespace UUID and a name string; generates deterministic UUIDs (same namespace+name always yields same UUID); uuid3 and uuid5 both generate name-based UUIDs but use different hash functions); uuid3.__module__ is 'uuid' (4 chars; defined in Lib/uuid.py; pure Python function; no C extension; all four generators share __module__=='uuid'); uuid5.__name__ is 'uuid5' (5 chars = 'uuid'=4 + '5'=1; the version-5 name-based UUID generator using SHA-1 hashing; preferred over uuid3 for new applications because SHA-1 is stronger than MD5; same deterministic property as uuid3: same namespace+name always yields same UUID; uuid5.__name__(5) == uuid3.__name__(5) == uuid4.__name__(5) == uuid1.__name__(5) in length); uuid5.__module__ is 'uuid' (4 chars; same as uuid3.__module__; all four generators in Lib/uuid.py; 'uuid'(4) < 'uuid3'/'uuid5'(5) by 1 char consistently); first uuidgen158 anchor for uuid3 and uuid5 name/module identity"
  kind: python_call_eq
  category: identity
  id_prefix: uuidgen158

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_name,   "uuid3.__name__.__eq__",   ["uuid3"], true, "uuid.uuid3.__name__ == 'uuid3' (5 chars; version-3 name-based UUID; MD5 hashing; deterministic from namespace+name; same 5-char length as uuid1/uuid4/uuid5)"]
    - [uuid3_module, "uuid3.__module__.__eq__",  ["uuid"],  true, "uuid.uuid3.__module__ == 'uuid' (4 chars; pure Python in Lib/uuid.py; 'uuid'(4) < 'uuid3'(5) by 1 char)"]
    - [uuid5_name,   "uuid5.__name__.__eq__",   ["uuid5"], true, "uuid.uuid5.__name__ == 'uuid5' (5 chars; version-5 name-based UUID; SHA-1 hashing; preferred over uuid3 for new use; same length as uuid3=5)"]
    - [uuid5_module, "uuid5.__module__.__eq__",  ["uuid"],  true, "uuid.uuid5.__module__ == 'uuid' (4 chars; same module as uuid3; all four generators in Lib/uuid.py)"]

# ---------------------------------------------------------------------------
# uuid generator function class names
#
# Wave 348 theme: all four uuid generator functions are 'function' type.
#
# uuid4.__class__.__name__ == 'function' (8 chars; regular Python function).
# uuid1.__class__.__name__ == 'function' (8 chars; same type as uuid4).
# uuid3.__name__.__eq__('uuid3') (confirmed).
# uuid5.__name__.__eq__('uuid5') (confirmed).
# No prior uuid spec anchors uuid generator __class__.__name__ as a table under uuidgen158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra158.uuid_generator_class_names:
  description: "uuid.uuid4.__class__.__name__.__eq__('function')==True / uuid1.__class__.__name__.__eq__('function')==True / uuid3.__name__.__eq__('uuid3')==True / uuid5.__name__.__eq__('uuid5')==True — uuid4.__class__.__name__ is 'function' (8 chars; uuid4 is a regular Python function defined in Lib/uuid.py; 'function' is the type name for def-defined Python functions; contrasts with hashlib hash constructors which are 'builtin_function_or_method' (25 chars) because those come from C extensions; 'function'(8) > 'uuid'(4) > 'uuid4'(5) is NOT in ascending order — note 'function'(8) > 'uuid4'(5) > 'uuid'(4)); uuid1.__class__.__name__ is 'function' (8 chars; same type as uuid4; both uuid1 and uuid4 are pure Python functions; all four generators (uuid1/uuid3/uuid4/uuid5) are 'function' type); uuid3.__name__ is 'uuid3' (confirmed; 5 chars; MD5-based name UUID); uuid5.__name__ is 'uuid5' (confirmed; 5 chars; SHA-1-based name UUID; preferred over uuid3); first uuidgen158 anchor for uuid generator __class__.__name__"
  kind: python_call_eq
  category: identity
  id_prefix: uuidgen158

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_class_function, "uuid4.__class__.__name__.__eq__", ["function"], true, "uuid.uuid4.__class__.__name__ == 'function' (8 chars; regular Python def-function; contrasts with C-extension 'builtin_function_or_method')"]
    - [uuid1_class_function, "uuid1.__class__.__name__.__eq__", ["function"], true, "uuid.uuid1.__class__.__name__ == 'function' (8 chars; same type as uuid4; all four uuid generators are Python functions)"]
    - [uuid3_name_b,         "uuid3.__name__.__eq__",           ["uuid3"],    true, "uuid.uuid3.__name__ == 'uuid3' (confirmed; 5 chars; MD5-based name-based UUID generator)"]
    - [uuid5_name_b,         "uuid5.__name__.__eq__",           ["uuid5"],    true, "uuid.uuid5.__name__ == 'uuid5' (confirmed; 5 chars; SHA-1-based name-based UUID generator; preferred over uuid3)"]

# ---------------------------------------------------------------------------
# uuid generator function name lengths
#
# Wave 348 theme: all four uuid generators have 5-char __name__ and 4-char __module__.
#
# uuid4.__name__.__len__() == 5 ('uuid4' = 5 chars).
# uuid1.__name__.__len__() == 5 ('uuid1' = 5 chars).
# uuid4.__module__.__len__() == 4 ('uuid' = 4 chars).
# uuid3.__class__.__name__.__eq__('function') (confirmed).
# No prior uuid spec anchors these name lengths as a table under uuidgen158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra158.uuid_generator_name_lengths:
  description: "uuid.uuid4.__name__.__len__()==5 / uuid1.__name__.__len__()==5 / uuid4.__module__.__len__()==4 / uuid3.__class__.__name__.__eq__('function')==True — uuid4.__name__.__len__() is 5 ('uuid4' = 'uuid'=4 + '4'=1 = 5 chars; all four generators uuid1/uuid3/uuid4/uuid5 have the same 5-char __name__: 'uuid'=4 common prefix + single digit suffix '1'/'3'/'4'/'5'=1 char each); uuid1.__name__.__len__() is 5 ('uuid1' = 5 chars; confirmed same length as uuid4.__name__.__len__()==5; uuid1/uuid3/uuid4/uuid5 all share __name__.__len__()==5); uuid4.__module__.__len__() is 4 ('uuid' = 4 chars; the module name is 1 char shorter than each function's __name__: 'uuid'(4) < 'uuid4'(5) by 1 char consistently across all four generators); uuid3.__class__.__name__ is 'function' (confirmed; 8 chars; 'function'(8) > 'uuid3'(5) > 'uuid'(4) in length; all four generators are 'function' type); first uuidgen158 anchor for generator name lengths"
  kind: python_call_eq
  category: identity
  id_prefix: uuidgen158

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_name_len_5,   "uuid4.__name__.__len__",           [], 5,           "uuid.uuid4.__name__.__len__() is 5 ('uuid4' = 'uuid'=4 + '4'=1 = 5 chars; all four generators share 5-char __name__ length)"]
    - [uuid1_name_len_5,   "uuid1.__name__.__len__",           [], 5,           "uuid.uuid1.__name__.__len__() is 5 ('uuid1' = 5 chars; same as uuid4.__name__.__len__()==5; common 4-char prefix + 1-char digit suffix)"]
    - [uuid4_module_len_4, "uuid4.__module__.__len__",         [], 4,           "uuid.uuid4.__module__.__len__() is 4 ('uuid' = 4 chars; 1 char shorter than 'uuid4'=5; module name shorter than function name by 1)"]
    - [uuid3_cls_function, "uuid3.__class__.__name__.__eq__",  ["function"],   true, "uuid.uuid3.__class__.__name__ == 'function' (confirmed; 8 chars; pure Python function; uuid1/uuid3/uuid4/uuid5 are all 'function' type)"]

# ---------------------------------------------------------------------------
# uuid.uuid4.__name__.__eq__('uuid4') — standalone
#
# uuid.uuid4.__name__ is 'uuid4' (5 chars). uuid4 is the version-4 UUID generator defined
# in Lib/uuid.py. Version-4 UUIDs are generated from random or pseudo-random numbers as
# specified in RFC 4122 Section 4.4. uuid4().__version__ == 4 and six bits are set to
# specific values (variant=RFC_4122, version=4) while the remaining 122 bits are random.
# uuid4 is the most commonly used UUID generator for generating unique identifiers without
# coordination. uuid4.__name__ == 'uuid4' confirms the bare function name as defined in
# the source code. No prior uuid spec anchors uuid4.__name__ as a standalone under uuidgen158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra158.uuid4_name_eq_uuid4:
  description: "uuid.uuid4.__name__.__eq__('uuid4') == True — 'uuid4' (5 chars = 'uuid'=4 + '4'=1); version-4 random UUID generator; 122 random bits + 6 fixed bits (variant+version per RFC 4122 §4.4); most commonly used UUID generator; uuid4.__module__=='uuid'(4 chars); uuid4.__class__.__name__=='function'(8 chars); all four generators share __name__.__len__()==5; first uuidgen158 standalone for uuid4.__name__"
  category: identity
  kind: python_call_eq
  function: uuid4.__name__.__eq__
  args: ["uuid4"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4.__module__.__eq__('uuid') — standalone
#
# uuid.uuid4.__module__ is 'uuid' (4 chars). uuid4 is a pure Python function defined in
# Lib/uuid.py. Its __module__ is 'uuid' (4 chars) — the module name. This contrasts with
# hashlib hash constructors (e.g., hashlib.sha256.__module__ == '_hashlib', a private C
# extension). uuid4.__module__ == 'uuid' (4 chars) == UUID.__module__ (4 chars) — both the
# class and the generator functions are in the same module. 'uuid' (4 chars) is 1 char
# shorter than each generator's __name__ (all 5 chars). No prior uuid spec anchors
# uuid4.__module__ as a standalone under uuidgen158. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra158.uuid4_module_eq_uuid:
  description: "uuid.uuid4.__module__.__eq__('uuid') == True — 'uuid' (4 chars; same module as UUID class: UUID.__module__=='uuid'(4 chars)); uuid4 is a pure Python function in Lib/uuid.py (not a C extension); 'uuid'(4) < 'uuid4'(5) by 1 char; all four generators (uuid1/uuid3/uuid4/uuid5) share __module__=='uuid'(4 chars); contrasts with hashlib hash constructors having __module__=='_hashlib'(8 chars, private C extension); first uuidgen158 standalone for uuid4.__module__"
  category: identity
  kind: python_call_eq
  function: uuid4.__module__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid1.__name__.__eq__('uuid1') — standalone
#
# uuid.uuid1.__name__ is 'uuid1' (5 chars). uuid1 is the version-1 time-based UUID generator
# defined in Lib/uuid.py. Version-1 UUIDs incorporate the host's MAC address and the current
# time as specified in RFC 4122 Section 4.2. uuid1().__version__ == 1. The 60-bit timestamp
# encodes 100-nanosecond intervals since October 15, 1582 (the Gregorian calendar reform date).
# uuid1 may leak the host's MAC address (a privacy concern), which is why uuid4 is often
# preferred for new applications. uuid1.__name__ == 'uuid1' (5 chars) == uuid4.__name__.__len__().
# No prior uuid spec anchors uuid1.__name__ as a standalone under uuidgen158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra158.uuid1_name_eq_uuid1:
  description: "uuid.uuid1.__name__.__eq__('uuid1') == True — 'uuid1' (5 chars = 'uuid'=4 + '1'=1); version-1 time-based UUID; incorporates host MAC address + 60-bit timestamp (100-ns intervals since October 15, 1582); RFC 4122 §4.2; uuid1.__module__=='uuid'(4 chars); uuid1.__class__.__name__=='function'(8 chars); 'uuid1'(5)==uuid4.__name__.__len__()==uuid3.__name__.__len__()==uuid5.__name__.__len__()==5; first uuidgen158 standalone for uuid1.__name__"
  category: identity
  kind: python_call_eq
  function: uuid1.__name__.__eq__
  args: ["uuid1"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid1.__module__.__eq__('uuid') — standalone
#
# uuid.uuid1.__module__ is 'uuid' (4 chars). uuid1 is a pure Python function in Lib/uuid.py.
# All four UUID generator functions (uuid1/uuid3/uuid4/uuid5) share __module__ == 'uuid'.
# This is expected since they are all defined in the same source file Lib/uuid.py.
# uuid1.__module__ (4 chars) is 1 char shorter than uuid1.__name__ (5 chars) — consistently
# for all four generators, the module name is 1 char shorter than the function name.
# No prior uuid spec anchors uuid1.__module__ as a standalone under uuidgen158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra158.uuid1_module_eq_uuid:
  description: "uuid.uuid1.__module__.__eq__('uuid') == True — 'uuid' (4 chars; pure Python function in Lib/uuid.py); all four generators share __module__=='uuid'(4 chars); 'uuid'(4) < 'uuid1'(5) by 1 char — module name consistently 1 char shorter than any generator's __name__; uuid1.__class__.__name__=='function'(8 chars); first uuidgen158 standalone for uuid1.__module__"
  category: identity
  kind: python_call_eq
  function: uuid1.__module__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid3.__name__.__eq__('uuid3') — standalone
#
# uuid.uuid3.__name__ is 'uuid3' (5 chars). uuid3 is the version-3 name-based UUID generator
# defined in Lib/uuid.py. Version-3 UUIDs are generated by hashing a namespace UUID and a
# name string using MD5 (per RFC 4122 Section 4.3). The result is deterministic: the same
# namespace and name always produce the same UUID. uuid3 is considered deprecated in favor
# of uuid5 (which uses SHA-1 instead of MD5) for new applications.
# uuid3.__name__ == 'uuid3' (5 chars) == uuid5.__name__.__len__() == uuid4.__name__.__len__().
# No prior uuid spec anchors uuid3.__name__ as a standalone under uuidgen158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra158.uuid3_name_eq_uuid3:
  description: "uuid.uuid3.__name__.__eq__('uuid3') == True — 'uuid3' (5 chars = 'uuid'=4 + '3'=1); version-3 name-based UUID; MD5 hashing of namespace+name (RFC 4122 §4.3); deterministic (same namespace+name always yields same UUID); deprecated in favor of uuid5 (SHA-1) for new use; uuid3.__module__=='uuid'(4); uuid3.__class__.__name__=='function'(8); 'uuid3'(5)==uuid5.__name__.__len__()==uuid4.__name__.__len__()==uuid1.__name__.__len__(); first uuidgen158 standalone for uuid3.__name__"
  category: identity
  kind: python_call_eq
  function: uuid3.__name__.__eq__
  args: ["uuid3"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid5.__name__.__eq__('uuid5') — standalone
#
# uuid.uuid5.__name__ is 'uuid5' (5 chars). uuid5 is the version-5 name-based UUID generator
# defined in Lib/uuid.py. Version-5 UUIDs are generated by hashing a namespace UUID and a
# name string using SHA-1 (per RFC 4122 Section 4.3). uuid5 is preferred over uuid3 for
# new applications because SHA-1 is stronger than MD5. Like uuid3, uuid5 is deterministic.
# uuid5 with NAMESPACE_DNS and a hostname generates a stable UUID for that host.
# uuid5 with NAMESPACE_URL and a URL generates a stable UUID for that URL.
# No prior uuid spec anchors uuid5.__name__ as a standalone under uuidgen158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra158.uuid5_name_eq_uuid5:
  description: "uuid.uuid5.__name__.__eq__('uuid5') == True — 'uuid5' (5 chars = 'uuid'=4 + '5'=1); version-5 name-based UUID; SHA-1 hashing of namespace+name (RFC 4122 §4.3); preferred over uuid3 (MD5) for new applications; deterministic (same namespace+name always yields same UUID); uuid5.__module__=='uuid'(4); uuid5.__class__.__name__=='function'(8); used with NAMESPACE_DNS/URL/OID/X500 constants; 'uuid5'(5)==uuid3.__name__.__len__()==uuid4.__name__.__len__()==uuid1.__name__.__len__()==5; first uuidgen158 standalone for uuid5.__name__"
  category: identity
  kind: python_call_eq
  function: uuid5.__name__.__eq__
  args: ["uuid5"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid5.__module__.__eq__('uuid') — standalone
#
# uuid.uuid5.__module__ is 'uuid' (4 chars). uuid5 is a pure Python function in Lib/uuid.py.
# All four UUID generator functions share __module__ == 'uuid' (4 chars). The module name
# 'uuid' is 1 char shorter than each generator's __name__ ('uuid1'/'uuid3'/'uuid4'/'uuid5'
# are all 5 chars). uuid5.__module__ (4 chars) == UUID.__module__ (4 chars) — both the
# UUID class and its generator functions live in the same 'uuid' module.
# No prior uuid spec anchors uuid5.__module__ as a standalone under uuidgen158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
