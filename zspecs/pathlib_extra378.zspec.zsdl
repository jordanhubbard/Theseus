spec: pathlib_extra378
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pathlib.Path.suffix, stem, name, parent, parts, anchor, drive are all Python descriptors; their __class__.__name__ is 'property'"
    - "All Path path-component attributes are implemented as properties on the class, not as regular methods or class variables"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path path-component descriptor types — all are 'property'
# ---------------------------------------------------------------------------

table pathlib_extra378.path_component_descriptors:
  description: "pathlib.Path path-component attributes are properties — suffix, stem, name, parent, parts, anchor, drive each have __class__.__name__ == 'property'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: plprop378

  columns: [id, function, args, expected]
  rows:
    - [suffix_class, pathlib.Path.suffix.__class__.__name__.__eq__, ["property"], true]
    - [stem_class,   pathlib.Path.stem.__class__.__name__.__eq__,   ["property"], true]
    - [name_class,   pathlib.Path.name.__class__.__name__.__eq__,   ["property"], true]
    - [parent_class, pathlib.Path.parent.__class__.__name__.__eq__, ["property"], true]
    - [parts_class,  pathlib.Path.parts.__class__.__name__.__eq__,  ["property"], true]
    - [anchor_class, pathlib.Path.anchor.__class__.__name__.__eq__, ["property"], true]
    - [drive_class,  pathlib.Path.drive.__class__.__name__.__eq__,  ["property"], true]
