spec: threading_extra261
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading.zspec.zsdl — covers Barrier, BoundedSemaphore, Condition classnames; function names; TIMEOUT_MAX; Lock, Event, Semaphore, current_thread.is_alive"
    - "threading_extra.zspec.zsdl — covers BoundedSemaphore/Condition/Semaphore/Event/RLock __module__; local.__name__/__module__; get_ident; TIMEOUT_MAX; stack_size"
  notes:
    - "threading.local.__name__ == '_local' — the C-level class name is '_local', not 'local'."
    - "threading.local.__module__ == '_thread' — implemented in the C-level _thread extension."
    - "threading.local.__bases__[0].__name__ == 'object' — inherits directly from object."
    - "threading.current_thread.__name__ == 'current_thread'; __qualname__ == 'current_thread'; __module__ == 'threading'; __class__.__name__ == 'function'."
    - "threading.main_thread.__name__ == 'main_thread'; __qualname__ == 'main_thread'; __module__ == 'threading'."
    - "threading.active_count.__name__ == 'active_count'; __qualname__ == 'active_count'; __module__ == 'threading'."
    - "threading.enumerate.__name__ == 'enumerate'; __qualname__ == 'enumerate'; __module__ == 'threading'."
    - "threading.enumerate is NOT the builtin enumerate — it is a threading module function returning active Thread objects."
    - "All values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.local — class identity
#
# threading.local is a C-level type from the _thread extension.
# Its __name__ is '_local' (the internal C name) and __module__ is '_thread'.
# Its sole base class is object.
# ---------------------------------------------------------------------------

invariant threading_extra261.local.name:
  description: "threading.local.__name__ == '_local' — the C-level class name"
  category: identity
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra261.local.module:
  description: "threading.local.__module__ == '_thread' — implemented in C extension"
  category: identity
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra261.local.base_name:
  description: "threading.local.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: local.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# threading.current_thread — function identity
# ---------------------------------------------------------------------------

invariant threading_extra261.current_thread.name:
  description: "threading.current_thread.__name__ == 'current_thread'"
  category: identity
  kind: python_call_eq
  function: current_thread.__name__.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra261.current_thread.qualname:
  description: "threading.current_thread.__qualname__ == 'current_thread'"
  category: identity
  kind: python_call_eq
  function: current_thread.__qualname__.__eq__
  args: ["current_thread"]
  expected: true

invariant threading_extra261.current_thread.module:
  description: "threading.current_thread.__module__ == 'threading'"
  category: identity
  kind: python_call_eq
  function: current_thread.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra261.current_thread.class_name:
  description: "threading.current_thread.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: current_thread.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# threading.main_thread — function identity
# ---------------------------------------------------------------------------

invariant threading_extra261.main_thread.name:
  description: "threading.main_thread.__name__ == 'main_thread'"
  category: identity
  kind: python_call_eq
  function: main_thread.__name__.__eq__
  args: ["main_thread"]
  expected: true

invariant threading_extra261.main_thread.qualname:
  description: "threading.main_thread.__qualname__ == 'main_thread'"
  category: identity
  kind: python_call_eq
  function: main_thread.__qualname__.__eq__
  args: ["main_thread"]
  expected: true

# ---------------------------------------------------------------------------
# threading.active_count and threading.enumerate — function identity
# ---------------------------------------------------------------------------

table threading_extra261.function_names:
  description: "active_count and enumerate __name__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [active_count, active_count.__name__.__eq__, ["active_count"], true]
    - [enumerate,    enumerate.__name__.__eq__,    ["enumerate"],    true]

table threading_extra261.function_qualnames:
  description: "active_count and enumerate __qualname__ checks"
  kind: python_call_eq
  category: identity
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [active_count, active_count.__qualname__.__eq__, ["active_count"], true]
    - [enumerate,    enumerate.__qualname__.__eq__,    ["enumerate"],    true]

invariant threading_extra261.enumerate.module:
  description: "threading.enumerate.__module__ == 'threading' — distinct from builtin enumerate"
  category: identity
  kind: python_call_eq
  function: enumerate.__module__.__eq__
  args: ["threading"]
  expected: true
