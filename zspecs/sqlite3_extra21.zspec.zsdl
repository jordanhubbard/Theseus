spec: sqlite3_extra21
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra20.zspec.zsdl."
    - "sqlite3_extra14 covers: Connection/__qualname__; Cursor/__qualname__; Row/__qualname__; connect/__qualname__."
    - "sqlite3_extra5 covers: Error/__qualname__; OperationalError/__qualname__; IntegrityError/__qualname__."
    - "sqlite3_extra18 covers: __qualname__.__class__.__name__ type axis for Connection, Cursor, Row, Error, OperationalError, connect."
    - "sqlite3_extra19 covers: Connection execute/executemany/executescript/cursor/commit/rollback/close __qualname__; Cursor execute/fetchone/fetchall __qualname__."
    - "sqlite3_extra20 covers: Connection.create_function/__qualname__; Connection.create_aggregate/__qualname__; DatabaseError/__qualname__; Cursor.rowcount descriptor type."
    - "No prior spec covers Connection.__module__, Cursor.__module__, or Row.__module__ as standalone invariants."
    - "No prior spec covers Error.__bases__[0].__name__ or OperationalError.__bases__[0].__name__ as standalone invariants."
    - "No prior spec covers PARSE_DECLTYPES.__class__.__name__ or PARSE_COLNAMES.__class__.__name__ as standalone invariants."
    - "No prior spec covers connect.__module__ as a standalone invariant."
    - "No prior spec covers Warning.__qualname__, Warning.__bases__[0].__name__, InterfaceError.__qualname__, or InterfaceError.__bases__[0].__name__ as standalone invariants."
    - "No prior spec covers NotSupportedError.__qualname__ or NotSupportedError.__bases__[0].__name__ as standalone invariants."
    - "sqlite3.Connection.__module__ == 'sqlite3' — C-extension class exposed via the sqlite3 package. Verified at runtime."
    - "sqlite3.Cursor.__module__ == 'sqlite3' — C-extension class exposed via the sqlite3 package. Verified at runtime."
    - "sqlite3.Row.__module__ == 'sqlite3' — C-extension class exposed via the sqlite3 package. Verified at runtime."
    - "sqlite3.Error.__bases__[0].__name__ == 'Exception' — Error is a direct subclass of the built-in Exception. Verified at runtime."
    - "sqlite3.OperationalError.__bases__[0].__name__ == 'DatabaseError' — OperationalError inherits from DatabaseError. Verified at runtime."
    - "sqlite3.PARSE_DECLTYPES.__class__.__name__ == 'int' — PARSE_DECLTYPES is an integer constant (value 1). Verified at runtime."
    - "sqlite3.PARSE_COLNAMES.__class__.__name__ == 'int' — PARSE_COLNAMES is an integer constant (value 2). Verified at runtime."
    - "sqlite3.connect.__module__ == '_sqlite3' — connect is implemented in the C-extension module _sqlite3. Verified at runtime."
    - "sqlite3.Warning.__qualname__ == 'Warning' — top-level exception class. Verified at runtime."
    - "sqlite3.Warning.__bases__[0].__name__ == 'Exception' — Warning is a direct subclass of the built-in Exception. Verified at runtime."
    - "sqlite3.InterfaceError.__qualname__ == 'InterfaceError' — top-level exception class. Verified at runtime."
    - "sqlite3.InterfaceError.__bases__[0].__name__ == 'Error' — InterfaceError inherits directly from Error. Verified at runtime."
    - "sqlite3.NotSupportedError.__qualname__ == 'NotSupportedError' — top-level exception class. Verified at runtime."
    - "sqlite3.NotSupportedError.__bases__[0].__name__ == 'DatabaseError' — NotSupportedError inherits from DatabaseError. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sqlite3.Connection — __module__
#
# sqlite3_extra14 covers Connection.__qualname__ == 'Connection'. No prior spec
# verifies Connection.__module__ as a standalone invariant. Connection is a
# C-extension type exposed through the sqlite3 package namespace.
# Verified at runtime: 'sqlite3'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra21.Connection.module:
  description: "sqlite3.Connection.__module__ == 'sqlite3' — C-extension class exposed via the sqlite3 package"
  category: class_identity
  kind: python_call_eq
  function: Connection.__module__.__eq__
  args: ["sqlite3"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Cursor — __module__
#
# sqlite3_extra14 covers Cursor.__qualname__ == 'Cursor'. No prior spec verifies
# Cursor.__module__ as a standalone invariant.
# Verified at runtime: 'sqlite3'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra21.Cursor.module:
  description: "sqlite3.Cursor.__module__ == 'sqlite3' — C-extension class exposed via the sqlite3 package"
  category: class_identity
  kind: python_call_eq
  function: Cursor.__module__.__eq__
  args: ["sqlite3"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Row — __module__
#
# sqlite3_extra14 covers Row.__qualname__ == 'Row'. No prior spec verifies
# Row.__module__ as a standalone invariant.
# Verified at runtime: 'sqlite3'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra21.Row.module:
  description: "sqlite3.Row.__module__ == 'sqlite3' — C-extension class exposed via the sqlite3 package"
  category: class_identity
  kind: python_call_eq
  function: Row.__module__.__eq__
  args: ["sqlite3"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Error — __bases__[0].__name__
#
# sqlite3_extra5 covers Error.__qualname__ == 'Error'. No prior spec verifies
# Error.__bases__[0].__name__ as a standalone invariant. Error is the root of
# the sqlite3 exception hierarchy and inherits directly from Exception.
# Verified at runtime: 'Exception'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra21.Error.base_name:
  description: "sqlite3.Error.__bases__[0].__name__ == 'Exception' — Error is a direct subclass of the built-in Exception"
  category: exception_hierarchy
  kind: python_call_eq
  function: "Error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.OperationalError — __bases__[0].__name__
#
# sqlite3_extra5 covers OperationalError.__qualname__ == 'OperationalError'. No
# prior spec verifies OperationalError.__bases__[0].__name__ as a standalone
# invariant. OperationalError inherits from DatabaseError.
# Verified at runtime: 'DatabaseError'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra21.OperationalError.base_name:
  description: "sqlite3.OperationalError.__bases__[0].__name__ == 'DatabaseError' — OperationalError inherits from DatabaseError"
  category: exception_hierarchy
  kind: python_call_eq
  function: "OperationalError.__bases__[0].__name__.__eq__"
  args: ["DatabaseError"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.PARSE_DECLTYPES — __class__.__name__
#
# No prior spec verifies PARSE_DECLTYPES.__class__.__name__ as a standalone
# invariant. PARSE_DECLTYPES is an integer constant (value 1) used as a flag
# for the detect_types parameter of connect(). __class__.__name__ == 'int'.
# Verified at runtime: 'int'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra21.PARSE_DECLTYPES.class_name:
  description: "sqlite3.PARSE_DECLTYPES.__class__.__name__ == 'int' — PARSE_DECLTYPES is an integer constant"
  category: module_constants
  kind: python_call_eq
  function: PARSE_DECLTYPES.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.PARSE_COLNAMES — __class__.__name__
#
# No prior spec verifies PARSE_COLNAMES.__class__.__name__ as a standalone
# invariant. PARSE_COLNAMES is an integer constant (value 2) used as a flag
# for the detect_types parameter of connect(). __class__.__name__ == 'int'.
# Verified at runtime: 'int'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra21.PARSE_COLNAMES.class_name:
  description: "sqlite3.PARSE_COLNAMES.__class__.__name__ == 'int' — PARSE_COLNAMES is an integer constant"
  category: module_constants
  kind: python_call_eq
  function: PARSE_COLNAMES.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.connect — __module__
#
# sqlite3_extra14 covers connect.__qualname__ == 'connect'. No prior spec
# verifies connect.__module__ as a standalone invariant. connect is implemented
# in the C-extension _sqlite3, so __module__ == '_sqlite3'.
# Verified at runtime: '_sqlite3'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra21.connect.module:
  description: "sqlite3.connect.__module__ == '_sqlite3' — connect is implemented in the C-extension module _sqlite3"
  category: function_identity
  kind: python_call_eq
  function: connect.__module__.__eq__
  args: ["_sqlite3"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.Warning — __qualname__ and __bases__[0].__name__
#
# No prior sqlite3 spec covers Warning.__qualname__ or Warning.__bases__[0].__name__.
# Warning is the root warning class in the sqlite3 hierarchy and inherits from
# the built-in Exception. Verified at runtime: 'Warning' and 'Exception'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra21.Warning.qualname:
  description: "sqlite3.Warning.__qualname__ == 'Warning' — top-level exception class qualname"
  category: exception_qualnames
  kind: python_call_eq
  function: Warning.__qualname__.__eq__
  args: ["Warning"]
  expected: true

invariant sqlite3_extra21.Warning.base_name:
  description: "sqlite3.Warning.__bases__[0].__name__ == 'Exception' — Warning is a direct subclass of the built-in Exception"
  category: exception_hierarchy
  kind: python_call_eq
  function: "Warning.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.InterfaceError — __qualname__ and __bases__[0].__name__
#
# No prior sqlite3 spec covers InterfaceError.__qualname__ or
# InterfaceError.__bases__[0].__name__. InterfaceError inherits from Error.
# Verified at runtime: 'InterfaceError' and 'Error'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra21.InterfaceError.qualname:
  description: "sqlite3.InterfaceError.__qualname__ == 'InterfaceError' — top-level exception class qualname"
  category: exception_qualnames
  kind: python_call_eq
  function: InterfaceError.__qualname__.__eq__
  args: ["InterfaceError"]
  expected: true

invariant sqlite3_extra21.InterfaceError.base_name:
  description: "sqlite3.InterfaceError.__bases__[0].__name__ == 'Error' — InterfaceError inherits directly from Error"
  category: exception_hierarchy
  kind: python_call_eq
  function: "InterfaceError.__bases__[0].__name__.__eq__"
  args: ["Error"]
  expected: true

# ---------------------------------------------------------------------------
# sqlite3.NotSupportedError — __qualname__ and __bases__[0].__name__
#
# No prior sqlite3 spec covers NotSupportedError.__qualname__ or
# NotSupportedError.__bases__[0].__name__. NotSupportedError inherits from
# DatabaseError. Verified at runtime: 'NotSupportedError' and 'DatabaseError'.
# ---------------------------------------------------------------------------

invariant sqlite3_extra21.NotSupportedError.qualname:
  description: "sqlite3.NotSupportedError.__qualname__ == 'NotSupportedError' — top-level exception class qualname"
  category: exception_qualnames
  kind: python_call_eq
  function: NotSupportedError.__qualname__.__eq__
  args: ["NotSupportedError"]
  expected: true

invariant sqlite3_extra21.NotSupportedError.base_name:
  description: "sqlite3.NotSupportedError.__bases__[0].__name__ == 'DatabaseError' — NotSupportedError inherits from DatabaseError"
  category: exception_hierarchy
  kind: python_call_eq
  function: "NotSupportedError.__bases__[0].__name__.__eq__"
  args: ["DatabaseError"]
  expected: true

# ---------------------------------------------------------------------------
# Table: class __module__ checks for Connection, Cursor, Row
#
# No prior spec groups Connection/__module__, Cursor/__module__, and
# Row/__module__ into a single table. All three are C-extension types
# exposed through the sqlite3 package namespace.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table sqlite3_extra21.class_modules:
  description: "sqlite3 class __module__ values — Connection, Cursor, Row all resolve to 'sqlite3'"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [Connection_module,
       Connection.__module__.__eq__,
       ["sqlite3"],
       true,
       "Connection.__module__ == 'sqlite3'"]
    - [Cursor_module,
       Cursor.__module__.__eq__,
       ["sqlite3"],
       true,
       "Cursor.__module__ == 'sqlite3'"]
    - [Row_module,
       Row.__module__.__eq__,
       ["sqlite3"],
       true,
       "Row.__module__ == 'sqlite3'"]

# ---------------------------------------------------------------------------
# Table: exception hierarchy base class names and PARSE_* constant types
#
# No prior spec groups Error/__bases__, OperationalError/__bases__,
# PARSE_DECLTYPES/__class__.__name__, and PARSE_COLNAMES/__class__.__name__
# into a single table. Also covers connect/__module__,
# Warning/InterfaceError/NotSupportedError qualnames and bases.
# All values verified at runtime.
# ---------------------------------------------------------------------------

table sqlite3_extra21.exception_bases_and_constants:
  description: "sqlite3 exception base class names, PARSE_* constant types, connect __module__, and additional exception qualnames"
  kind: python_call_eq
  category: exception_hierarchy
  columns: [id, function, args, expected, description]
  rows:
    - [Error_base,
       "Error.__bases__[0].__name__.__eq__",
       ["Exception"],
       true,
       "Error.__bases__[0].__name__ == 'Exception'"]
    - [OperationalError_base,
       "OperationalError.__bases__[0].__name__.__eq__",
       ["DatabaseError"],
       true,
       "OperationalError.__bases__[0].__name__ == 'DatabaseError'"]
    - [PARSE_DECLTYPES_type,
       PARSE_DECLTYPES.__class__.__name__.__eq__,
       ["int"],
       true,
       "PARSE_DECLTYPES.__class__.__name__ == 'int'"]
    - [PARSE_COLNAMES_type,
       PARSE_COLNAMES.__class__.__name__.__eq__,
       ["int"],
       true,
       "PARSE_COLNAMES.__class__.__name__ == 'int'"]
    - [connect_module,
       connect.__module__.__eq__,
       ["_sqlite3"],
       true,
       "connect.__module__ == '_sqlite3'"]
    - [Warning_qualname,
       Warning.__qualname__.__eq__,
       ["Warning"],
       true,
       "Warning.__qualname__ == 'Warning'"]
    - [Warning_base,
       "Warning.__bases__[0].__name__.__eq__",
       ["Exception"],
       true,
       "Warning.__bases__[0].__name__ == 'Exception'"]
    - [InterfaceError_qualname,
       InterfaceError.__qualname__.__eq__,
       ["InterfaceError"],
       true,
       "InterfaceError.__qualname__ == 'InterfaceError'"]
    - [InterfaceError_base,
       "InterfaceError.__bases__[0].__name__.__eq__",
       ["Error"],
       true,
       "InterfaceError.__bases__[0].__name__ == 'Error'"]
    - [NotSupportedError_qualname,
       NotSupportedError.__qualname__.__eq__,
       ["NotSupportedError"],
       true,
       "NotSupportedError.__qualname__ == 'NotSupportedError'"]
    - [NotSupportedError_base,
       "NotSupportedError.__bases__[0].__name__.__eq__",
       ["DatabaseError"],
       true,
       "NotSupportedError.__bases__[0].__name__ == 'DatabaseError'"]
