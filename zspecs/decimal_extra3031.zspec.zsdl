spec: dc3031
version: ">=3.9"
backend: python_module(decimal)
docs: https://docs.python.org/3/library/decimal.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 649 (dc3031): __missing__, __init_subclass__, __class_getitem__ dict-presence for decimal types."
    - "decimal.Decimal is an arbitrary-precision numeric type; it is not a mapping and does not define __missing__."
    - "decimal.Context holds rounding/precision configuration; it does not define any of these hooks."
    - "decimal.DecimalException and all its subclasses are exception types; none define __missing__, __init_subclass__, or __class_getitem__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __missing__ dict-presence — operator.contains(Cls.__dict__, '__missing__')
#
# decimal types are numeric/exception types, not mappings; none define __missing__; all false.
# ---------------------------------------------------------------------------

table dc3031.missing:
  description: "decimal types __missing__ dict-presence checks; wave 649"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc3031
  columns: [id, function, args, expected]
  rows:
    - ["dc3031001", operator.contains, [decimal.Decimal.__dict__,          "__missing__"], false]
    - ["dc3031002", operator.contains, [decimal.Context.__dict__,          "__missing__"], false]
    - ["dc3031003", operator.contains, [decimal.DecimalException.__dict__, "__missing__"], false]
    - ["dc3031004", operator.contains, [decimal.InvalidOperation.__dict__, "__missing__"], false]
    - ["dc3031005", operator.contains, [decimal.Overflow.__dict__,         "__missing__"], false]
    - ["dc3031006", operator.contains, [decimal.Underflow.__dict__,        "__missing__"], false]

