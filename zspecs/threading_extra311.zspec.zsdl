spec: threading_extra311
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.Lock().__class__.__name__ == 'lock' (lowercase) — Lock() returns a C-level _thread.lock instance; type name is lowercase 'lock'."
    - "threading.RLock().__class__.__name__ == 'RLock' — RLock() returns an _RLock instance; type name is 'RLock'."
    - "threading.Event().__class__.__name__ == 'Event' — Event is a pure-Python class."
    - "threading.Condition().__class__.__name__ == 'Condition' — Condition is a pure-Python class."
    - "threading.Semaphore().__class__.__name__ == 'Semaphore' — Semaphore is a pure-Python class."
    - "threading.BoundedSemaphore().__class__.__name__ == 'BoundedSemaphore' — BoundedSemaphore is a pure-Python class."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread."
    - "threading.Thread.__module__ == 'threading' — Thread is defined in the threading module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Lock and RLock instance class names
#
# threading.Lock() returns a C-level _thread.lock instance.
# Its __class__.__name__ is 'lock' (lowercase) — the C type name.
# threading.RLock() returns an _RLock instance whose __class__.__name__ is 'RLock'.
# ---------------------------------------------------------------------------

invariant threading_extra311.lock_instance_class_name:
  description: "threading.Lock().__class__.__name__ == 'lock' — C-level lock type name is lowercase 'lock'"
  category: instance_class_names
  kind: python_call_eq
  function: Lock().__class__.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra311.rlock_instance_class_name:
  description: "threading.RLock().__class__.__name__ == 'RLock' — RLock() returns an _RLock instance"
  category: instance_class_names
  kind: python_call_eq
  function: RLock().__class__.__name__.__eq__
  args: ["RLock"]
  expected: true

# ---------------------------------------------------------------------------
# Event, Condition, Semaphore, BoundedSemaphore instance class names
#
# All four are pure-Python classes defined in threading.
# Their instances' __class__.__name__ matches the class name exactly.
# ---------------------------------------------------------------------------

invariant threading_extra311.event_instance_class_name:
  description: "threading.Event().__class__.__name__ == 'Event'"
  category: instance_class_names
  kind: python_call_eq
  function: Event().__class__.__name__.__eq__
  args: ["Event"]
  expected: true

invariant threading_extra311.condition_instance_class_name:
  description: "threading.Condition().__class__.__name__ == 'Condition'"
  category: instance_class_names
  kind: python_call_eq
  function: Condition().__class__.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant threading_extra311.semaphore_instance_class_name:
  description: "threading.Semaphore().__class__.__name__ == 'Semaphore'"
  category: instance_class_names
  kind: python_call_eq
  function: Semaphore().__class__.__name__.__eq__
  args: ["Semaphore"]
  expected: true

invariant threading_extra311.bounded_semaphore_instance_class_name:
  description: "threading.BoundedSemaphore().__class__.__name__ == 'BoundedSemaphore'"
  category: instance_class_names
  kind: python_call_eq
  function: BoundedSemaphore().__class__.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

# ---------------------------------------------------------------------------
# Timer base class and Thread module identity
#
# threading.Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread.
# threading.Thread.__module__ == 'threading'.
# ---------------------------------------------------------------------------

invariant threading_extra311.timer_base_is_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread"
  category: class_hierarchy
  kind: python_call_eq
  function: Timer.__bases__.__getitem__(0).__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra311.thread_module_is_threading:
  description: "threading.Thread.__module__ == 'threading' — Thread is defined in the threading module"
  category: class_hierarchy
  kind: python_call_eq
  function: Thread.__module__.__eq__
  args: ["threading"]
  expected: true
