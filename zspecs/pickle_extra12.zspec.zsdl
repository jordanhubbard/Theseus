spec: pickle_extra12
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl through pickle_extra11.zspec.zsdl."
    - "pickle_extra11 covers: Pickler/Unpickler __name__; PickleError/PicklingError/UnpicklingError __name__ (table); PickleError/__bases__[0].__name__; PicklingError/__bases__[0].__name__; UnpicklingError/__bases__[0].__name__; dumps(42).__len__()>=2; HIGHEST_PROTOCOL.__ge__(4); DEFAULT_PROTOCOL.__ge__(2)."
    - "pickle_extra10 covers: dumps(42).__class__.__name__; HIGHEST_PROTOCOL/DEFAULT_PROTOCOL __class__.__name__; PickleError/PicklingError/UnpicklingError __qualname__; dumps/loads __name__; module __name__."
    - "pickle_extra9 covers: format_version value/type; STOP/MARK/NONE opcodes; dumps(None,protocol=0); PickleBuffer callable; PickleError/PicklingError/UnpicklingError MRO[1]; Pickler/Unpickler __qualname__."
    - "Focus: new axes — Pickler/Unpickler __module__/__qualname__; exception __module__ attrs; dumps/loads __module__; dumps return-type checks for various input types."
    - "pickle.Pickler.__module__ == '_pickle' — C-accelerated class lives in _pickle; no prior spec checks Pickler.__module__."
    - "pickle.Unpickler.__module__ == '_pickle' — same rationale as Pickler.__module__."
    - "pickle.PickleError.__module__ == 'pickle' — Python-level exception; no prior spec checks PickleError.__module__."
    - "pickle.PicklingError.__module__ == 'pickle' — same rationale."
    - "pickle.UnpicklingError.__module__ == 'pickle' — same rationale."
    - "pickle.dumps.__module__ == 'pickle' — no prior spec checks dumps.__module__ as a standalone invariant."
    - "pickle.loads.__module__ == 'pickle' — no prior spec checks loads.__module__ as a standalone invariant."
    - "pickle.dumps(None).__class__.__name__ == 'bytes' — None input; no prior spec checks __class__.__name__ for dumps(None)."
    - "pickle.dumps([]).__class__.__name__ == 'bytes' — empty list input; new vector."
    - "pickle.dumps({}).__class__.__name__ == 'bytes' — empty dict input; new vector."
    - "pickle.dumps('').__class__.__name__ == 'bytes' — empty string input; new vector."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pickler and Unpickler __module__
#
# pickle_extra9 checks Pickler/Unpickler __qualname__; pickle_extra11 checks
# __name__. No prior spec checks __module__ for Pickler or Unpickler.
# The C-accelerated implementations live in the _pickle extension module.
# ---------------------------------------------------------------------------

invariant pickle_extra12.Pickler.module:
  description: "pickle.Pickler.__module__ == '_pickle' — C-accelerated class lives in _pickle"
  category: class_attrs
  kind: python_call_eq
  function: Pickler.__module__.__eq__
  args: ["_pickle"]
  expected: true

invariant pickle_extra12.Unpickler.module:
  description: "pickle.Unpickler.__module__ == '_pickle' — C-accelerated class lives in _pickle"
  category: class_attrs
  kind: python_call_eq
  function: Unpickler.__module__.__eq__
  args: ["_pickle"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class __module__ attributes
#
# pickle_extra10 checks PickleError/PicklingError/UnpicklingError __qualname__.
# pickle_extra11 checks their __name__ and __bases__[0].__name__.
# No prior spec checks __module__ for any of the three exception classes.
# ---------------------------------------------------------------------------

table pickle_extra12.exception_modules:
  kind: python_call_eq
  category: class_attrs
  id_prefix: pem12

  columns: [id, function, args, expected]
  rows:
    - [PickleError,      PickleError.__module__.__eq__,      ["pickle"],  true]
    - [PicklingError,    PicklingError.__module__.__eq__,    ["pickle"],  true]
    - [UnpicklingError,  UnpicklingError.__module__.__eq__,  ["pickle"],  true]

# ---------------------------------------------------------------------------
# pickle.dumps and pickle.loads __module__
#
# pickle_extra10 checks dumps/loads __name__ and module __name__.
# No prior spec checks dumps.__module__ or loads.__module__ as standalone invariants.
# ---------------------------------------------------------------------------

invariant pickle_extra12.dumps.module:
  description: "pickle.dumps.__module__ == 'pickle'"
  category: function_attrs
  kind: python_call_eq
  function: dumps.__module__.__eq__
  args: ["pickle"]
  expected: true

invariant pickle_extra12.loads.module:
  description: "pickle.loads.__module__ == 'pickle'"
  category: function_attrs
  kind: python_call_eq
  function: loads.__module__.__eq__
  args: ["pickle"]
  expected: true

# ---------------------------------------------------------------------------
# pickle.dumps() return type — various input types
#
# pickle_extra10 checks dumps(42).__class__.__name__ == 'bytes'.
# pickle_extra8 checks dumps(b'hello').__len__() == 20.
# No prior spec checks __class__.__name__ on the return of dumps() for
# None, empty list, empty dict, or empty string inputs.
# ---------------------------------------------------------------------------

invariant pickle_extra12.dumps_none.class_name:
  description: "pickle.dumps(None).__class__.__name__ == 'bytes' — None serialises to bytes"
  category: return_type
  kind: python_call_eq
  function: dumps
  args: [~]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant pickle_extra12.dumps_list.class_name:
  description: "pickle.dumps([]).__class__.__name__ == 'bytes' — empty list serialises to bytes"
  category: return_type
  kind: python_call_eq
  function: dumps
  args: [[]]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant pickle_extra12.dumps_dict.class_name:
  description: "pickle.dumps({}).__class__.__name__ == 'bytes' — empty dict serialises to bytes"
  category: return_type
  kind: python_call_eq
  function: dumps
  args: [{}]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant pickle_extra12.dumps_str.class_name:
  description: "pickle.dumps('').__class__.__name__ == 'bytes' — empty string serialises to bytes"
  category: return_type
  kind: python_call_eq
  function: dumps
  args: [""]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true
