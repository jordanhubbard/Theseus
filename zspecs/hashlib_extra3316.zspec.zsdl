spec: hl3316
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 668 (hl3316): __ipow__, __ilshift__, __irshift__ dict-presence checks for hashlib types."
    - "Theme: __ipow__/__ilshift__/__irshift__ dict-presence (in-place **=, <<=, >>=)."
    - "All values False — hash objects do not define in-place power or bitwise shift protocol methods in their own __dict__."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __ipow__, __ilshift__, or __irshift__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3316.ipow:
  description: "hashlib types __ipow__ dict-presence checks; wave 668"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3316
  columns: [id, function, args, expected]
  rows:
    - ["hl3316001", operator.contains, [type(hashlib.md5()).__dict__,        "__ipow__"], false]
    - ["hl3316002", operator.contains, [type(hashlib.sha1()).__dict__,       "__ipow__"], false]
    - ["hl3316003", operator.contains, [type(hashlib.sha256()).__dict__,     "__ipow__"], false]
    - ["hl3316004", operator.contains, [type(hashlib.sha512()).__dict__,     "__ipow__"], false]
    - ["hl3316005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__ipow__"], false]

