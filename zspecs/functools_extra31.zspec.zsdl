spec: functools_extra31
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra30.zspec.zsdl."
    - "functools_extra30 covers: singledispatch/total_ordering/cached_property/wraps __module__; total_ordering/cmp_to_key qualnames; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES lengths and types; cmp_to_key.__module__."
    - "functools_extra29 covers: partial/cached_property/singledispatch class-level qualnames."
    - "functools_extra28 covers: partial.__call__, partial.__new__; cached_property.__set_name__/__get__; partialmethod.__get__; lru_cache qualname."
    - "functools_extra26 covers: combined __qualname__.__eq__ table for reduce/lru_cache/cache/wraps/total_ordering/singledispatch/cached_property/partialmethod."
    - "No prior functools spec records __module__ for partial/lru_cache/reduce/update_wrapper/partialmethod, or __bases__[0].__name__ for partial/partialmethod, together in the extra31 namespace."
    - "Focus: partial/__module__ and __bases__[0].__name__; reduce/__module__ (C extension); update_wrapper/partialmethod qualnames and modules; lru_cache __module__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
    - "Note: functools.reduce.__module__ == '_functools' because reduce is implemented in the C extension module."
    - "Note: functools.partial.__module__ == 'functools' even though partial is C-level; it is attributed to the public namespace."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__eq__ table — Python-level functools callable module membership
#
# partial, lru_cache, update_wrapper, and partialmethod are attributed to the
# public 'functools' module. partial and lru_cache are C-level types, but their
# __module__ is 'functools' not '_functools'. update_wrapper and partialmethod
# are Python-level. No prior functools spec records all four __module__ values
# together in the extra31 namespace.
# ---------------------------------------------------------------------------

table functools_extra31.callable_modules:
  kind: python_call_eq
  category: module_membership
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra31.callable_modules.partial,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__ == 'functools'"]
    - [functools_extra31.callable_modules.lru_cache,
       lru_cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.lru_cache.__module__ == 'functools'"]
    - [functools_extra31.callable_modules.update_wrapper,
       update_wrapper.__module__.__eq__,
       ["functools"],
       true,
       "functools.update_wrapper.__module__ == 'functools'"]
    - [functools_extra31.callable_modules.partialmethod,
       partialmethod.__module__.__eq__,
       ["functools"],
       true,
       "functools.partialmethod.__module__ == 'functools'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — update_wrapper and partialmethod class qualnames
#
# functools.update_wrapper is a Python-level function defined at module scope;
# its qualname is 'update_wrapper'. functools.partialmethod is a Python-level
# class; its qualname is 'partialmethod'. Neither has been recorded together
# as a group in any prior functools spec in the extra31 namespace.
# ---------------------------------------------------------------------------

table functools_extra31.wrapper_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra31.wrapper_qualnames.update_wrapper,
       update_wrapper.__qualname__.__eq__,
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__qualname__ == 'update_wrapper'"]
    - [functools_extra31.wrapper_qualnames.partialmethod,
       partialmethod.__qualname__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__qualname__ == 'partialmethod'"]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — base classes for partial and partialmethod
#
# functools.partial is a C-level type that inherits directly from object.
# functools.partialmethod is a Python-level class that also inherits directly
# from object. No prior functools spec records these base class names together
# in the extra31 namespace.
# ---------------------------------------------------------------------------

table functools_extra31.callable_bases:
  kind: python_call_eq
  category: inheritance
  columns: [id, function, args, expected, description]
  rows:
    - [functools_extra31.callable_bases.partial,
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__ == 'object'"]
    - [functools_extra31.callable_bases.partialmethod,
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# reduce.__module__.__eq__ — C-extension module membership
#
# functools.reduce is implemented in the C extension _functools. Its __module__
# is '_functools', not 'functools'. This distinguishes it from Python-level
# functools callables like update_wrapper and partialmethod which report
# 'functools'. No prior functools spec records this standalone in the extra31
# namespace.
# ---------------------------------------------------------------------------

invariant functools_extra31.reduce.module:
  description: "functools.reduce.__module__ == '_functools' (C-extension)"
  category: module_membership
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

# ---------------------------------------------------------------------------
# reduce.__qualname__.__eq__ — standalone function qualname
#
# functools.reduce is a C-level builtin function. Its qualname is 'reduce', a
# simple name confirming it is not nested inside any class or function scope.
# functools_extra26 records reduce qualname in a combined table; this standalone
# records it in the extra31 namespace.
# No prior functools spec records this standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra31.reduce.qualname:
  description: "functools.reduce.__qualname__ == 'reduce'"
  category: qualnames
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true

# ---------------------------------------------------------------------------
# partial.__module__.__eq__ — standalone module membership
#
# functools.partial is a C-level type attributed to the public 'functools'
# module. Its __module__ is 'functools', not '_functools', distinguishing it
# from reduce which is also C-level but reports '_functools'.
# No prior functools spec records this standalone in the extra31 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra31.partial.module:
  description: "functools.partial.__module__ == 'functools'"
  category: module_membership
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true
