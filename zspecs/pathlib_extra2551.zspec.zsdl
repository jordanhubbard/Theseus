spec: pathlib_extra2551
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2551 (_extra2551): __reduce__, __reduce_ex__, __getnewargs__ dict-presence checks for pathlib classes."
    - "pathlib.PurePath defines __reduce__ (True) but not __reduce_ex__ or __getnewargs__."
    - "pathlib.Path, pathlib.PurePosixPath, pathlib.PureWindowsPath do NOT define __reduce__ in their own __dict__."
    - "Path inherits __reduce__ from PurePath but does not override it in its own class dict."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table pathlib_extra2551.reduce_protocol:
  description: "pathlib classes __reduce__ dict-presence — PurePath=True, all others False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2551

  columns: [id, function, args, expected]
  rows:
    - ["pp2551001", "pathlib.PurePath.__dict__.__contains__",        ["__reduce__"], true]
    - ["pp2551002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__reduce__"], false]
    - ["pp2551003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__reduce__"], false]
    - ["pp2551004", "pathlib.Path.__dict__.__contains__",            ["__reduce__"], false]

table pathlib_extra2551.reduce_ex_protocol:
  description: "pathlib classes __reduce_ex__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2551x

  columns: [id, function, args, expected]
  rows:
    - ["pp2551x001", "pathlib.PurePath.__dict__.__contains__",        ["__reduce_ex__"], false]
    - ["pp2551x002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__reduce_ex__"], false]
    - ["pp2551x003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["pp2551x004", "pathlib.Path.__dict__.__contains__",            ["__reduce_ex__"], false]

table pathlib_extra2551.getnewargs_protocol:
  description: "pathlib classes __getnewargs__, __getnewargs_ex__, __getstate__, __setstate__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2551g

  columns: [id, function, args, expected]
  rows:
    - ["pp2551g001", "pathlib.PurePath.__dict__.__contains__",        ["__getnewargs__"],    false]
    - ["pp2551g002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__getnewargs__"],    false]
    - ["pp2551g003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__getnewargs__"],    false]
    - ["pp2551g004", "pathlib.Path.__dict__.__contains__",            ["__getnewargs__"],    false]
    - ["pp2551g005", "pathlib.PurePath.__dict__.__contains__",        ["__getnewargs_ex__"], false]
    - ["pp2551g006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__getnewargs_ex__"], false]
    - ["pp2551g007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__getnewargs_ex__"], false]
    - ["pp2551g008", "pathlib.Path.__dict__.__contains__",            ["__getnewargs_ex__"], false]
    - ["pp2551g009", "pathlib.PurePath.__dict__.__contains__",        ["__getstate__"],      false]
    - ["pp2551g010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__getstate__"],      false]
    - ["pp2551g011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__getstate__"],      false]
    - ["pp2551g012", "pathlib.Path.__dict__.__contains__",            ["__getstate__"],      false]
