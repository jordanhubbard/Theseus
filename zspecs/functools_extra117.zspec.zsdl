# ---------------------------------------------------------------------------
# Table 1: functools module identity attributes — __name__, __package__, __spec__
#
# Wave 263 theme: functools is a pure-Python module in Lib/functools.py (with
# some C helpers). Its __name__ is 'functools' (9 characters). Its __package__
# is '' (empty string, length 0) because functools is a top-level module, not
# inside a package. The __spec__ is a ModuleSpec instance with .name == 'functools'
# and .has_location == True (because it is a file-based module, not built-in).
# type(functools.__name__).__name__ == 'str'.
#
# functools.__name__ == 'functools'
# len(functools.__name__) == 9
# functools.__package__ == ''
# len(functools.__package__) == 0
# type(functools.__name__).__name__ == 'str'
# functools.__spec__.__class__.__name__ == 'ModuleSpec'
# functools.__spec__.name == 'functools'
# functools.__spec__.has_location == True
#
# New to extra117.
# ---------------------------------------------------------------------------

table functools_extra117.module_identity:
  description: "functools module identity: __name__='functools'(9), __package__=''(0), type str; __spec__ is ModuleSpec with name='functools' and has_location=True; wave 263; new to extra117"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsmi117

  columns: [id, function, args, expected, description]
  rows:
    - [functools_name_eq,
       "__name__.__eq__",
       ["functools"],
       true,
       "functools.__name__.__eq__('functools') == True — functools is a top-level pure-Python module in Lib/functools.py; its __name__ attribute is the string 'functools' matching the module's canonical name; str.__eq__('functools') returns True; new to extra117"]
    - [functools_name_len_9,
       "__name__.__len__",
       [],
       9,
       "functools.__name__.__len__() == 9 — 'functools' has 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; int.__eq__(9) returns True; new to extra117"]
    - [functools_package_empty,
       "__package__.__eq__",
       [""],
       true,
       "functools.__package__.__eq__('') == True — functools is a top-level module (not inside a package); its __package__ attribute is the empty string ''; str.__eq__('') returns True; new to extra117"]
    - [functools_package_len_0,
       "__package__.__len__",
       [],
       0,
       "functools.__package__.__len__() == 0 — functools.__package__ is '' (empty string); len('') == 0; str.__len__() returns 0; int.__eq__(0) returns True; new to extra117"]
    - [functools_name_type_str,
       "__name__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.__name__.__class__.__name__.__eq__('str') == True — functools.__name__ is a plain Python string; type(functools.__name__).__name__ is 'str'; str.__eq__('str') returns True; new to extra117"]
    - [functools_spec_class_modulespec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "functools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — functools.__spec__ is an instance of importlib.machinery.ModuleSpec; this is the standard module specification object created by the import system; str.__eq__('ModuleSpec') returns True; new to extra117"]
    - [functools_spec_name_eq,
       "__spec__.name.__eq__",
       ["functools"],
       true,
       "functools.__spec__.name.__eq__('functools') == True — the ModuleSpec for functools has its .name attribute set to 'functools'; this is the fully-qualified module name stored in the spec; str.__eq__('functools') returns True; new to extra117"]
    - [functools_spec_has_location_true,
       "__spec__.has_location.__eq__",
       [true],
       true,
       "functools.__spec__.has_location.__eq__(True) == True — functools is a file-based module (Lib/functools.py exists on disk); its ModuleSpec.has_location is True; bool.__eq__(True) returns True; new to extra117"]

# ---------------------------------------------------------------------------
# Table 2: functools.WRAPPER_ASSIGNMENTS element string values
#
# Wave 263 theme: functools.WRAPPER_ASSIGNMENTS is a tuple of 6 strings listing
# the attributes that functools.wraps() copies from the wrapped function to the
# wrapper. As of Python 3.14.3 the tuple is:
#   ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__')
# Note: Python 3.14 added '__annotate__' and '__type_params__' compared to earlier
# versions which only had '__wrapped__' appended via WRAPPER_UPDATES semantics.
# The 6 elements cover: the module, name, qualname, docstring, annotation accessor
# (new in 3.14), and type parameters (new in 3.12).
# len(WRAPPER_ASSIGNMENTS) == 6.
#
# functools.WRAPPER_ASSIGNMENTS[0] == '__module__'
# functools.WRAPPER_ASSIGNMENTS[1] == '__name__'
# functools.WRAPPER_ASSIGNMENTS[2] == '__qualname__'
# functools.WRAPPER_ASSIGNMENTS[3] == '__doc__'
# functools.WRAPPER_ASSIGNMENTS[4] == '__annotate__'
# functools.WRAPPER_ASSIGNMENTS[5] == '__type_params__'
# len(functools.WRAPPER_ASSIGNMENTS) == 6
#
# New to extra117.
# ---------------------------------------------------------------------------

table functools_extra117.wrapper_assignments_elements:
  description: "functools.WRAPPER_ASSIGNMENTS elements: [0]='__module__', [1]='__name__', [2]='__qualname__', [3]='__doc__', [4]='__annotate__', [5]='__type_params__'; len==6; wave 263; new to extra117"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswa117

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_0_module,
       "WRAPPER_ASSIGNMENTS.__getitem__(0).__eq__",
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(0).__eq__('__module__') == True — functools.WRAPPER_ASSIGNMENTS[0] is '__module__'; this is the first attribute copied by wraps() so the wrapper reports the same module as the wrapped function; str.__eq__('__module__') returns True; new to extra117"]
    - [wrapper_assignments_1_name,
       "WRAPPER_ASSIGNMENTS.__getitem__(1).__eq__",
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(1).__eq__('__name__') == True — functools.WRAPPER_ASSIGNMENTS[1] is '__name__'; wraps() copies __name__ so the wrapper has the same name as the wrapped function; str.__eq__('__name__') returns True; new to extra117"]
    - [wrapper_assignments_2_qualname,
       "WRAPPER_ASSIGNMENTS.__getitem__(2).__eq__",
       ["__qualname__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(2).__eq__('__qualname__') == True — functools.WRAPPER_ASSIGNMENTS[2] is '__qualname__'; wraps() copies __qualname__ so the wrapper reports the correct dotted name of the wrapped function; str.__eq__('__qualname__') returns True; new to extra117"]
    - [wrapper_assignments_3_doc,
       "WRAPPER_ASSIGNMENTS.__getitem__(3).__eq__",
       ["__doc__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(3).__eq__('__doc__') == True — functools.WRAPPER_ASSIGNMENTS[3] is '__doc__'; wraps() copies __doc__ so the wrapper's docstring matches the wrapped function's docstring; str.__eq__('__doc__') returns True; new to extra117"]
    - [wrapper_assignments_4_annotate,
       "WRAPPER_ASSIGNMENTS.__getitem__(4).__eq__",
       ["__annotate__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(4).__eq__('__annotate__') == True — functools.WRAPPER_ASSIGNMENTS[4] is '__annotate__'; __annotate__ is the annotation accessor added in Python 3.14 (PEP 749); wraps() copies it so the wrapper's annotations reflect those of the wrapped function; str.__eq__('__annotate__') returns True; new to extra117"]
    - [wrapper_assignments_5_type_params,
       "WRAPPER_ASSIGNMENTS.__getitem__(5).__eq__",
       ["__type_params__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(5).__eq__('__type_params__') == True — functools.WRAPPER_ASSIGNMENTS[5] is '__type_params__'; __type_params__ stores PEP 695 type parameter objects for generic functions; added to WRAPPER_ASSIGNMENTS in Python 3.12; wraps() copies it so the wrapper preserves type parameter information; str.__eq__('__type_params__') returns True; new to extra117"]
    - [wrapper_assignments_len_6,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS is a tuple of 6 string elements: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'; tuple.__len__() returns 6; int.__eq__(6) returns True; new to extra117"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_UPDATES and WRAPPER_ASSIGNMENTS element lengths
#
# Wave 263 theme: functools.WRAPPER_UPDATES is a tuple of 1 element: '__dict__'.
# len('__dict__') == 8. This is the attribute that wraps() updates (merges) rather
# than copies — the wrapped function's __dict__ is merged into the wrapper's
# __dict__ using update(). The element string lengths of WRAPPER_ASSIGNMENTS are:
# '__module__'=10, '__name__'=8, '__qualname__'=12, '__doc__'=7,
# '__annotate__'=12, '__type_params__'=15.
#
# functools.WRAPPER_UPDATES[0] == '__dict__'
# len(functools.WRAPPER_UPDATES) == 1
# len(functools.WRAPPER_UPDATES[0]) == 8
# len(functools.WRAPPER_ASSIGNMENTS[0]) == 10  (__module__)
# len(functools.WRAPPER_ASSIGNMENTS[1]) == 8   (__name__)
# len(functools.WRAPPER_ASSIGNMENTS[5]) == 15  (__type_params__)
#
# New to extra117.
# ---------------------------------------------------------------------------

table functools_extra117.wrapper_updates_and_lengths:
  description: "functools.WRAPPER_UPDATES: [0]='__dict__'(8), len==1; WRAPPER_ASSIGNMENTS element lengths: [0]=10, [1]=8, [5]=15; wave 263; new to extra117"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswul117

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_updates_0_dict,
       "WRAPPER_UPDATES.__getitem__(0).__eq__",
       ["__dict__"],
       true,
       "functools.WRAPPER_UPDATES.__getitem__(0).__eq__('__dict__') == True — functools.WRAPPER_UPDATES[0] is '__dict__'; wraps() uses update() to merge the wrapped function's __dict__ into the wrapper's __dict__ (rather than replacing it); this preserves any attributes already set on the wrapper; str.__eq__('__dict__') returns True; new to extra117"]
    - [wrapper_updates_len_1,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES is a tuple of 1 element ('__dict__'); tuple.__len__() returns 1; int.__eq__(1) returns True; new to extra117"]
    - [wrapper_updates_0_len_8,
       "WRAPPER_UPDATES.__getitem__(0).__len__",
       [],
       8,
       "functools.WRAPPER_UPDATES.__getitem__(0).__len__() == 8 — '__dict__' has 8 characters: _-_-d-i-c-t-_-_; str.__len__() returns 8; int.__eq__(8) returns True; new to extra117"]
    - [wrapper_assignments_0_len_10,
       "WRAPPER_ASSIGNMENTS.__getitem__(0).__len__",
       [],
       10,
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(0).__len__() == 10 — '__module__' has 10 characters: _-_-m-o-d-u-l-e-_-_; str.__len__() returns 10; int.__eq__(10) returns True; new to extra117"]
    - [wrapper_assignments_1_len_8,
       "WRAPPER_ASSIGNMENTS.__getitem__(1).__len__",
       [],
       8,
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(1).__len__() == 8 — '__name__' has 8 characters: _-_-n-a-m-e-_-_; str.__len__() returns 8; int.__eq__(8) returns True; new to extra117"]
    - [wrapper_assignments_5_len_15,
       "WRAPPER_ASSIGNMENTS.__getitem__(5).__len__",
       [],
       15,
       "functools.WRAPPER_ASSIGNMENTS.__getitem__(5).__len__() == 15 — '__type_params__' has 15 characters: _-_-t-y-p-e-_-p-a-r-a-m-s-_-_; str.__len__() returns 15; int.__eq__(15) returns True; new to extra117"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra117
# ---------------------------------------------------------------------------

invariant functools_extra117.module_name_len:
  description: "len(functools.__name__) == 9 — 'functools' is 9 characters; top-level module identity; wave 263; new to extra117"
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 9

invariant functools_extra117.module_package_empty:
  description: "functools.__package__ == '' — empty string; functools is a top-level module not inside any package; wave 263; new to extra117"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant functools_extra117.spec_has_location:
  description: "functools.__spec__.has_location == True — file-based module (Lib/functools.py); not built-in; has disk location; wave 263; new to extra117"
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

invariant functools_extra117.wrapper_assignments_len:
  description: "len(functools.WRAPPER_ASSIGNMENTS) == 6 — 6 elements in Python 3.14: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; wave 263; new to extra117"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra117.wrapper_updates_dict:
  description: "functools.WRAPPER_UPDATES[0] == '__dict__' — single element tuple; wraps() updates (merges) __dict__ rather than copying; wave 263; new to extra117"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__getitem__(0).__eq__
  args: ["__dict__"]
  expected: true

