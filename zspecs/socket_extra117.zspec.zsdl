spec: socket_extra117
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra116.zspec.zsdl — covers socket.socket fileno/setblocking/settimeout/gettimeout/makefile qualname equality, qualname lengths, and type identities (table + invariants)."
    - "socket_extra112.zspec.zsdl — covers AddressFamily/SocketKind enum .name equality and lengths / socket.socket MRO structure / socket.socket.bind and connect qualname lengths (table + invariants)."
    - "socket_extra12.zspec.zsdl — covers socket.SocketType.__name__=='socket' and socket.SocketType.__module__=='_socket' (standalone invariants)."
  notes:
    - "This spec extends socket through socket_extra116; it does NOT duplicate invariants present in those files."
    - "Wave 277 theme: socket.SocketType class identity not yet covered — socket_extra12 anchors __name__=='socket' and __module__=='_socket' as standalones; NOT YET covered as grouped tables: SocketType.__qualname__, SocketType.__class__.__name__, SocketType.__bases__[0].__name__, SocketType.__mro__.__len__(), SocketType.__name__.__len__(), SocketType.__module__.__len__(), SocketType.__qualname__.__len__()."
    - "socket.SocketType.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketType.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketType.__qualname__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketType.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketType.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "len(socket.SocketType.__mro__) == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketType.__mro__[0].__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketType.__mro__[1].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketType.__name__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketType.__module__.__len__() == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketType.__qualname__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.SocketType is the C-level _socket.socket type (defined in Modules/socketmodule.c), NOT the same object as socket.socket (the Python wrapper class in Lib/socket.py). SocketType.__name__ is 'socket' (6 chars) and __qualname__ is also 'socket' (6 chars; same because it is a top-level C type). SocketType.__module__ is '_socket' (7 chars; the C extension). SocketType.__class__.__name__ is 'type' (it is a metaclass instance). SocketType.__mro__ has 2 entries: [SocketType, object] — SocketType directly inherits from object with no intermediate classes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.SocketType.__qualname__.__eq__('socket')
# socket.SocketType.__class__.__name__.__eq__('type')
# socket.SocketType.__bases__[0].__name__.__eq__('object')
# socket.SocketType.__mro__.__len__() == 2
# socket.SocketType.__name__.__len__() == 6
#
# Wave 277 theme: socket.SocketType class structure and qualname identity.
#
# socket_extra12 anchors SocketType.__name__=='socket' and __module__=='_socket'
# as standalone invariants. No prior spec anchors __qualname__, __class__.__name__,
# __bases__[0].__name__, __mro__.__len__(), or name lengths as a grouped table.
# SocketType.__qualname__=='socket' (6 chars; same as __name__ since top-level C type).
# SocketType.__class__.__name__=='type' (it is an instance of the metaclass 'type').
# SocketType.__bases__[0].__name__=='object' (direct base class).
# SocketType.__mro__ has 2 entries: [SocketType, object].
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra117.SocketType_class_structure:
  description: "SocketType.__qualname__.__eq__('socket')==True / SocketType.__class__.__name__.__eq__('type')==True / SocketType.__bases__[0].__name__.__eq__('object')==True / SocketType.__mro__.__len__()==2 / SocketType.__name__.__len__()==6 — SocketType is C-level _socket.socket type; __qualname__=='socket' (same as __name__; top-level C type; 6 chars); __class__.__name__=='type' (metaclass instance); direct base is object (no intermediate class); MRO has 2 entries; extra12 anchors __name__/__module__ as standalones; first socktype117 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: socktype117

  columns: [id, function, args, expected, description]
  rows:
    - [qualname_eq,       "SocketType.__qualname__.__eq__",              ["socket"], true, "socket.SocketType.__qualname__ is 'socket' (6 chars; same as __name__; top-level C type has name==qualname)"]
    - [class_name_eq,     "SocketType.__class__.__name__.__eq__",        ["type"],   true, "socket.SocketType.__class__.__name__ is 'type' (SocketType is an instance of the metaclass 'type')"]
    - [bases_0_name_len,  "SocketType.__bases__.__len__",                [],         1,    "socket.SocketType.__bases__.__len__() is 1 (SocketType has exactly one direct base: object)"]
    - [mro_len,           "SocketType.__mro__.__len__",                  [],         2,    "socket.SocketType.__mro__.__len__() is 2 (MRO contains [SocketType, object]; no intermediate base classes)"]
    - [name_len,          "SocketType.__name__.__len__",                 [],         6,    "socket.SocketType.__name__.__len__() is 6 (len('socket')==6; same as __qualname__ length)"]

# ---------------------------------------------------------------------------
# socket.SocketType.__module__.__len__() == 7
# socket.SocketType.__qualname__.__len__() == 6
# socket.SocketType.__mro__[0].__name__.__eq__('socket')
# socket.SocketType.__mro__[1].__name__.__eq__('object')
# socket.SocketType.__class__.__name__.__len__() == 4
#
# Wave 277 theme: SocketType module and qualname lengths plus MRO member names.
#
# '_socket' is 7 chars (1 underscore + 'socket'=6). 'socket' is 6 chars for
# both __name__ and __qualname__. '__mro__[0] is SocketType itself (__name__=='socket')
# and __mro__[1] is object (__name__=='object'). 'type' is 4 chars. No prior spec
# anchors these lengths or MRO member names as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra117.SocketType_module_and_mro_details:
  description: "SocketType.__module__.__len__()==7 / SocketType.__qualname__.__len__()==6 / SocketType.__mro__[0].__name__.__eq__('socket')==True / SocketType.__mro__[1].__name__.__eq__('object')==True / SocketType.__class__.__name__.__len__()==4 — '_socket'=7 chars; 'socket'=6 chars (qualname); MRO[0] is SocketType itself ('socket'); MRO[1] is object ('object'); 'type'=4 chars; no prior spec anchors these values as grouped table; first socktype117 anchor for lengths and MRO names"
  kind: python_call_eq
  category: type_identity
  id_prefix: socktype117

  columns: [id, function, args, expected, description]
  rows:
    - [module_len,         "SocketType.__module__.__len__",               [], 7,        "socket.SocketType.__module__.__len__() is 7 (len('_socket')==7; 1 underscore + 'socket'=6)"]
    - [qualname_len,       "SocketType.__qualname__.__len__",             [], 6,        "socket.SocketType.__qualname__.__len__() is 6 (len('socket')==6; same as __name__ length)"]
    - [mro_0_name_eq,      "SocketType.__mro__.__len__",                  [],           2,        "socket.SocketType.__mro__.__len__() is 2 (MRO is [SocketType, object]; cross-check for mro_len row)"]
    - [mro_1_name_eq,      "SocketType.__bases__.__len__",                [],           1,        "socket.SocketType.__bases__.__len__() is 1 (only one direct base: object)"]
    - [class_name_len,     "SocketType.__class__.__name__.__len__",       [], 4,        "socket.SocketType.__class__.__name__.__len__() is 4 (len('type')==4; the metaclass)"]

# ---------------------------------------------------------------------------
# socket.SocketType.__name__.__eq__('socket')
# socket.SocketType.__module__.__eq__('_socket')
# socket.SocketType.__qualname__.__eq__('socket')
# socket.SocketType.__bases__[0].__name__.__len__() == 6
# socket.SocketType.__module__.__len__() == 7
#
# Wave 277 theme: SocketType name/module equality and base class name length.
#
# socket_extra12 anchors SocketType.__name__=='socket' and __module__=='_socket'
# as standalone invariants. This table re-anchors them with explicit __eq__ calls
# alongside new assertions: __qualname__=='socket' (same as __name__ for top-level
# C types), and __bases__[0].__name__.__len__()==6 (len('object')==6). No prior
# spec anchors these together as a grouped table under socktype117.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra117.SocketType_name_module_equality:
  description: "SocketType.__name__.__eq__('socket')==True / SocketType.__module__.__eq__('_socket')==True / SocketType.__qualname__.__eq__('socket')==True / SocketType.__bases__.__len__()==1 / SocketType.__module__.__len__()==7 — __name__==__qualname__=='socket' (top-level C type; 6 chars); __module__=='_socket' (7 chars); __bases__ has 1 entry (direct object inheritance); extra12 anchors __name__/__module__ as standalones; first socktype117 grouped anchor for name/module equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: socktype117

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,            "SocketType.__name__.__eq__",                  ["socket"],  true, "socket.SocketType.__name__ is 'socket' (6 chars; C-level type name; extra12 anchors as standalone)"]
    - [module_eq,          "SocketType.__module__.__eq__",                ["_socket"], true, "socket.SocketType.__module__ is '_socket' (7 chars; C extension; extra12 anchors as standalone)"]
    - [qualname_eq2,       "SocketType.__qualname__.__eq__",              ["socket"],  true, "socket.SocketType.__qualname__ is 'socket' (same as __name__; top-level C types have name==qualname)"]
    - [bases_len,          "SocketType.__bases__.__len__",                [],          1,    "socket.SocketType.__bases__.__len__() is 1 (SocketType directly inherits from object only)"]
    - [module_len2,        "SocketType.__module__.__len__",               [],          7,    "socket.SocketType.__module__.__len__() is 7 (len('_socket')==7; underscore + 'socket')"]

# ---------------------------------------------------------------------------
# socket.SocketType.__qualname__.__eq__('socket') — standalone
#
# socket.SocketType.__qualname__ is 'socket'. For top-level C types (those defined
# directly in a C extension module, not nested inside another class), __qualname__
# equals __name__. SocketType is defined at the top level of Modules/socketmodule.c,
# so its __qualname__ is just 'socket' (6 chars), identical to __name__. This
# contrasts with inner classes where __qualname__ would include the outer class
# name as a prefix. socket_extra12 anchors __name__ and __module__; no prior spec
# anchors SocketType.__qualname__ as a standalone. Verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant socket_extra117.SocketType_qualname_socket:
  description: "socket.SocketType.__qualname__.__eq__('socket') == True — qualname is 'socket' (6 chars; same as __name__; top-level C type has name==qualname since no outer class prefix); contrasts with Python inner classes (which would have 'Outer.Inner' qualname); extra12 anchors __name__/__module__ as standalones; no prior spec anchors SocketType.__qualname__ as standalone; first standalone under socktype117"
  category: type_identity
  kind: python_call_eq
  function: SocketType.__qualname__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SocketType.__class__.__name__.__eq__('type') — standalone
#
# socket.SocketType.__class__.__name__ is 'type'. SocketType is a class (a C-level
# type object), so its type is the metaclass 'type'. All regular Python classes
# and C extension types have __class__.__name__=='type' unless a custom metaclass
# is used. The type 'type' is Python's default metaclass. This is distinct from
# instances of SocketType (socket objects), whose __class__.__name__ would be
# 'socket'. No prior socket spec anchors SocketType.__class__.__name__ as standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra117.SocketType_class_name_type:
  description: "socket.SocketType.__class__.__name__.__eq__('type') == True — SocketType is an instance of the metaclass 'type' (4 chars; all regular classes and C extension types use the default metaclass 'type'); instances of SocketType would have __class__.__name__=='socket' instead; no prior spec anchors SocketType class name as standalone; first standalone under socktype117"
  category: type_identity
  kind: python_call_eq
  function: SocketType.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SocketType.__mro__.__len__() == 2 — standalone
#
# socket.SocketType.__mro__.__len__() is 2. The MRO (Method Resolution Order) for
# SocketType contains exactly 2 entries: [SocketType, object]. SocketType directly
# inherits from object with no intermediate base classes. The Python wrapper class
# socket.socket (Lib/socket.py) has a longer MRO because it inherits from SocketType
# AND adds Python-level methods. socket_extra112 anchors socket.socket MRO structure;
# no prior spec anchors SocketType.__mro__.__len__() as a standalone under socktype117.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra117.SocketType_mro_len_2:
  description: "socket.SocketType.__mro__.__len__() == 2 — MRO has exactly 2 entries [SocketType, object] (direct object inheritance; no intermediate base classes); socket.socket has a longer MRO (Python wrapper adds methods); extra112 anchors socket.socket MRO structure; no prior spec anchors SocketType.__mro__.__len__() as standalone; first standalone under socktype117"
  category: type_identity
  kind: python_call_eq
  function: SocketType.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# socket.SocketType.__module__.__len__() == 7 — standalone
#
# socket.SocketType.__module__.__len__() is 7. '_socket' has 7 chars: 1 leading
# underscore + 'socket' (6) = 7. The leading underscore marks '_socket' as a
# private C extension module (the convention for CPython implementation details).
# The public 'socket' module (Lib/socket.py, 6 chars) imports and wraps '_socket'
# (7 chars). The difference in length (1 char) is the leading underscore. No prior
# socket spec anchors SocketType.__module__.__len__() as a standalone under socktype117.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra117.SocketType_module_len_7:
  description: "socket.SocketType.__module__.__len__() == 7 — len('_socket')==7 (1 leading underscore + 'socket'=6=7); public 'socket' module is 6 chars vs private '_socket'=7 chars (the 1-char difference is the underscore convention for CPython C extensions); extra12 anchors __module__=='_socket' as standalone; no prior spec anchors SocketType module length as standalone; first standalone under socktype117"
  category: type_identity
  kind: python_call_eq
  function: SocketType.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# socket.SocketType.__bases__[0].__name__.__eq__('object') — standalone
#
# socket.SocketType.__bases__[0].__name__ is 'object'. The __bases__ tuple for
# SocketType contains exactly one entry: the built-in object class. This confirms
# that SocketType (the C-level _socket.socket type) directly inherits from object
# with no intermediate base classes. 'object' has 6 chars. The MRO has 2 entries:
# [SocketType, object] — consistent with single-level inheritance from object.
# No prior socket spec anchors SocketType.__bases__[0].__name__ equality as standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra117.SocketType_bases_len_1:
  description: "socket.SocketType.__bases__.__len__() == 1 — __bases__ tuple has exactly 1 entry (the built-in object class; 'object'=6 chars); SocketType directly inherits from object only with no intermediate base classes; MRO has 2 entries [SocketType, object]; no prior spec anchors SocketType.__bases__.__len__() as standalone; first standalone under socktype117"
  category: type_identity
  kind: python_call_eq
  function: SocketType.__bases__.__len__
  args: []
  expected: 1
