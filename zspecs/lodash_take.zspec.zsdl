spec: lodash_take
version: ">=4.0.0"
backend: node(lodash.take)

docs: https://lodash.com/docs/#take

provenance:
  derived_from:
    - "lodash.take README — https://www.npmjs.com/package/lodash.take"
    - "Test vectors verified with lodash.take@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.take exports the _.take function directly as module.exports."
    - "take(array, n) returns a slice of n elements taken from the beginning."
    - "Defaults to n=1 if omitted."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array slice. Returns [] for n=0."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_take.take:
  kind: node_module_call_eq
  function: ~
  category: take
  id_prefix: ltake

  columns: [id, args, expected]
  rows:
    - [take3,  [[1, 2, 3, 4, 5], 3],  [1, 2, 3]]
    - [take1,  [[1, 2, 3, 4, 5], 1],  [1]]
    - [take0,  [[1, 2, 3], 0],        []]
    - [all,    [[1, 2, 3], 3],        [1, 2, 3]]
