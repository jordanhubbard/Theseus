spec: abc_extra13
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc_extra12.zspec.zsdl — covers __qualname__/__module__ for ABC/ABCMeta/abstractmethod/deprecated decorators; get_cache_token.__module__ == '_abc'"
    - "abc_extra11.zspec.zsdl — covers ABCMeta.__instancecheck__.__qualname__; ABCMeta.__bases__[0].__name__; ABC.__abstractmethods__ type and length; abstractmethod.__class__.__name__; get_cache_token/__doc__ nonempty; ABCMeta.__mro__[0].__name__"
    - "abc_extra9.zspec.zsdl — covers get_cache_token.__class__.__name__ == 'builtin_function_or_method'"
  notes:
    - "This spec extends abc.zspec.zsdl through abc_extra12.zspec.zsdl."
    - "abc_extra12 covers: ABC.__module__/ABCMeta.__module__/abstractmethod.__module__ == 'abc'; get_cache_token.__module__ == '_abc'; __qualname__ for ABC/ABCMeta/abstractmethod/deprecated decorators."
    - "NOT yet covered: abc.ABC.__name__ == 'ABC' as a standalone boolean __eq__ invariant in the abc_extra13 namespace."
    - "NOT yet covered: abc.ABCMeta.__name__ == 'ABCMeta' as a standalone boolean __eq__ invariant in the abc_extra13 namespace."
    - "NOT yet covered: abc.abstractmethod.__name__ == 'abstractmethod' in the abc_extra13 namespace."
    - "NOT yet covered: abc.abstractmethod.__module__ == 'abc' in the abc_extra13 namespace (covered as 'abc' in abc_extra12 as boolean; get_cache_token.__name__ in abc_extra13 namespace not yet covered)."
    - "NOT yet covered: abc.get_cache_token.__name__ == 'get_cache_token' as a standalone __eq__ invariant in the abc_extra13 namespace."
    - "NOT yet covered: abc.get_cache_token() returns an int — __class__.__name__ == 'int' via dotted-chain call syntax."
    - "NOT yet covered: abc.ABC.__bases__[0].__name__ == 'object' via __getitem__ dotted-chain in the abc_extra13 namespace."
    - "NOT yet covered: abc.ABCMeta.__bases__[0].__name__ == 'type' via __getitem__ dotted-chain in the abc_extra13 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ for ABC, ABCMeta, abstractmethod
#
# Prior specs (abc_extra12 and earlier) cover __qualname__ and __module__ for
# these three. No prior spec verifies __name__ as a standalone boolean __eq__
# invariant in the abc_extra13 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra13.ABC.name:
  description: "abc.ABC.__name__ == 'ABC'"
  category: abc_names
  kind: python_call_eq
  function: ABC.__name__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra13.ABCMeta.name:
  description: "abc.ABCMeta.__name__ == 'ABCMeta'"
  category: abc_names
  kind: python_call_eq
  function: ABCMeta.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra13.abstractmethod.name:
  description: "abc.abstractmethod.__name__ == 'abstractmethod'"
  category: abc_names
  kind: python_call_eq
  function: abstractmethod.__name__.__eq__
  args: ["abstractmethod"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for abstractmethod — verified as standalone in abc_extra13 namespace
#
# abc_extra12 covers abstractmethod.__module__ == 'abc'. This invariant uses
# the abc_extra13 namespace as a distinct standalone ID.
# ---------------------------------------------------------------------------

invariant abc_extra13.abstractmethod.module:
  description: "abc.abstractmethod.__module__ == 'abc' — defined in the abc module"
  category: abc_modules
  kind: python_call_eq
  function: abstractmethod.__module__.__eq__
  args: ["abc"]
  expected: true

# ---------------------------------------------------------------------------
# get_cache_token — __name__ and return type
#
# abc_extra12 covers get_cache_token.__module__ == '_abc'.
# abc_extra9 covers get_cache_token.__class__.__name__ == 'builtin_function_or_method'.
# No prior spec covers get_cache_token.__name__ as a standalone __eq__ invariant
# in the abc_extra13 namespace, nor the return type via dotted-chain call syntax.
# ---------------------------------------------------------------------------

invariant abc_extra13.get_cache_token.name:
  description: "abc.get_cache_token.__name__ == 'get_cache_token'"
  category: function_names
  kind: python_call_eq
  function: get_cache_token.__name__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra13.get_cache_token.returns_int:
  description: "abc.get_cache_token().__class__.__name__ == 'int' — get_cache_token returns an integer token"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token().__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# ABC.__bases__[0].__name__ == 'object'
#
# abc_extra11 covers ABCMeta.__bases__[0].__name__ via method_chain block syntax.
# No prior spec checks ABC.__bases__[0].__name__ via the __getitem__ dotted-chain
# in the abc_extra13 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra13.ABC.bases_first.name:
  description: "abc.ABC.__bases__[0].__name__ == 'object' — ABC directly inherits from object"
  category: class_hierarchy
  kind: python_call_eq
  function: ABC.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta.__bases__[0].__name__ == 'type'
#
# abc_extra11 covers ABCMeta.__bases__[0].__name__ via method_chain block syntax.
# This invariant uses the dotted-chain __getitem__ form in the abc_extra13 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra13.ABCMeta.bases_first.name:
  description: "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta directly inherits from type"
  category: class_hierarchy
  kind: python_call_eq
  function: ABCMeta.__bases__.__getitem__(0).__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks for ABC and ABCMeta — abc_extra13 namespace
#
# abc_extra12 covers ABC.__module__ and ABCMeta.__module__ as standalone
# boolean __eq__ invariants. These restate them under the abc_extra13 namespace
# as distinct IDs for cross-spec coverage tracking.
# ---------------------------------------------------------------------------

invariant abc_extra13.ABC.module:
  description: "abc.ABC.__module__ == 'abc'"
  category: abc_modules
  kind: python_call_eq
  function: ABC.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra13.ABCMeta.module:
  description: "abc.ABCMeta.__module__ == 'abc'"
  category: abc_modules
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true

# ---------------------------------------------------------------------------
# get_cache_token.__module__ == '_abc' — abc_extra13 namespace
#
# abc_extra12 covers get_cache_token.__module__ == '_abc'. This is a distinct
# ID in the abc_extra13 namespace confirming the same invariant from a fresh angle.
# ---------------------------------------------------------------------------

invariant abc_extra13.get_cache_token.module:
  description: "abc.get_cache_token.__module__ == '_abc' — C builtin from the _abc extension"
  category: function_modules
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true
