spec: tortoise_orm_rust
version: ">=3.9"
backend: rust_module(tortoise_orm_rust)

docs: https://tortoise.github.io/

provenance:
  derived_from:
    - "https://tortoise.github.io/ — Tortoise ORM documentation"
  not_derived_from:
    - "tortoise source: tortoise/__init__.py"
  notes:
    - "Tortoise ORM provides async ORM for Python."
    - "tortoise.Tortoise is available."
    - "tortoise.fields is available."
    - "tortoise.fields.IntField is available."
    - "tortoise.fields.CharField is available."
    - "tortoise.__version__ is a non-empty string."
    - "Expose tortoise_has_tortoise() -> bool: hasattr(tortoise, 'Tortoise')."
    - "Expose tortoise_has_fields() -> bool: hasattr(tortoise, 'fields')."
    - "Expose tortoise_version_nonempty() -> bool: len(tortoise.__version__) > 0."
    - "All test vectors verified against tortoise-orm 0.22.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# tortoise_has_tortoise — Tortoise class present
invariant tortoise_orm_rust.module.has_tortoise:
  description: "tortoise.Tortoise is available"
  category: module
  kind: python_call_eq
  function: tortoise_has_tortoise
  args: []
  expected: true

# tortoise_has_fields — fields module present
invariant tortoise_orm_rust.module.has_fields:
  description: "tortoise.fields is available"
  category: module
  kind: python_call_eq
  function: tortoise_has_fields
  args: []
  expected: true

# tortoise_version_nonempty — version non-empty
invariant tortoise_orm_rust.version.nonempty:
  description: "tortoise.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: tortoise_version_nonempty
  args: []
  expected: true

