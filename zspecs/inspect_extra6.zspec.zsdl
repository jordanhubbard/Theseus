spec: inspect_extra6
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect.zspec.zsdl, inspect_extra.zspec.zsdl, inspect_extra2.zspec.zsdl, inspect_extra3.zspec.zsdl, inspect_extra5.zspec.zsdl, and inspect_signature.zspec.zsdl."
    - "Focus: __name__ and __module__ for named types (FrameInfo, Traceback, BlockFinder, Parameter, Signature), and ParameterKind enum member class names."
    - "inspect.Parameter.POSITIONAL_ONLY, POSITIONAL_OR_KEYWORD, VAR_POSITIONAL, KEYWORD_ONLY, VAR_KEYWORD are ParameterKind enum members."
    - "inspect.Parameter.empty is the sentinel for missing defaults; its class is named '_empty'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Named type __name__ checks
# ---------------------------------------------------------------------------

invariant inspect_extra6.FrameInfo.name:
  description: "inspect.FrameInfo.__name__ == 'FrameInfo'"
  category: class_names
  kind: python_call_eq
  function: FrameInfo.__name__.__eq__
  args: ["FrameInfo"]
  expected: true

invariant inspect_extra6.FrameInfo.module:
  description: "inspect.FrameInfo.__module__ == 'inspect'"
  category: class_names
  kind: python_call_eq
  function: FrameInfo.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra6.Traceback.name:
  description: "inspect.Traceback.__name__ == 'Traceback'"
  category: class_names
  kind: python_call_eq
  function: Traceback.__name__.__eq__
  args: ["Traceback"]
  expected: true

invariant inspect_extra6.BlockFinder.name:
  description: "inspect.BlockFinder.__name__ == 'BlockFinder'"
  category: class_names
  kind: python_call_eq
  function: BlockFinder.__name__.__eq__
  args: ["BlockFinder"]
  expected: true

invariant inspect_extra6.Parameter.name:
  description: "inspect.Parameter.__name__ == 'Parameter'"
  category: class_names
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra6.Signature.name:
  description: "inspect.Signature.__name__ == 'Signature'"
  category: class_names
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

# ---------------------------------------------------------------------------
# Parameter.empty sentinel — __class__.__name__ == '_empty'
# ---------------------------------------------------------------------------

invariant inspect_extra6.Parameter.empty_class_name:
  description: "inspect.Parameter.empty.__class__.__name__ == '_empty'"
  category: parameter_kind
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["_empty"]
  expected: true

# ---------------------------------------------------------------------------
# ParameterKind enum members — __class__.__name__ == 'ParameterKind'
# ---------------------------------------------------------------------------

table inspect_extra6.parameter_kind.class_names:
  kind: python_call_eq
  category: parameter_kind
  id_prefix: kind

  columns: [id, function, args, expected]
  rows:
    - [POSITIONAL_ONLY,         Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__,         ["ParameterKind"], true]
    - [POSITIONAL_OR_KEYWORD,   Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__,   ["ParameterKind"], true]
    - [VAR_POSITIONAL,          Parameter.VAR_POSITIONAL.__class__.__name__.__eq__,          ["ParameterKind"], true]
    - [KEYWORD_ONLY,            Parameter.KEYWORD_ONLY.__class__.__name__.__eq__,            ["ParameterKind"], true]
    - [VAR_KEYWORD,             Parameter.VAR_KEYWORD.__class__.__name__.__eq__,             ["ParameterKind"], true]
