spec: theseus_ssl_cr
version: ">=3.0"
backend: python_cleanroom(theseus_ssl_cr)
blocks: ssl

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ssl.html"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
  notes:
    - "Clean-room ssl module. Do NOT import ssl."

error_model: python_exceptions

invariant theseus_ssl_cr.ssl2_protocols:
  description: "PROTOCOL_TLS_CLIENT and PROTOCOL_TLS_SERVER exist"
  category: behavior
  kind: python_call_eq
  function: ssl2_protocols
  args: []
  expected: true

invariant theseus_ssl_cr.ssl2_context:
  description: "SSLContext can be created"
  category: behavior
  kind: python_call_eq
  function: ssl2_context
  args: []
  expected: true

invariant theseus_ssl_cr.ssl2_cert_required:
  description: "CERT_NONE, CERT_OPTIONAL, CERT_REQUIRED constants exist"
  category: behavior
  kind: python_call_eq
  function: ssl2_cert_required
  args: []
  expected: true
