spec: io_extra2821
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "Wave 635 theme: __radd__, __rsub__, and __rmul__ dict-presence checks (reflected arithmetic operators)."
    - "io classes are I/O stream objects, not numeric types — none define reflected arithmetic operators."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase do NOT define __radd__, __rsub__, or __rmul__."
    - "io.BytesIO, io.StringIO, io.FileIO do NOT define any reflected arithmetic operators."
    - "io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper also absent for all three."
    - "Absence is consistent across all 11 io classes tested — io streams have no arithmetic semantics."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __radd__ dict-presence — absent from all io ABC and concrete classes
# ---------------------------------------------------------------------------

table io_extra2821.radd_protocol:
  description: "__radd__ is absent from all io class __dict__s — io streams are not numeric types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2821

  columns: [id, function, args, expected]
  rows:
    - ["io2821001", "io.IOBase.__dict__.__contains__",        ["__radd__"], false]
    - ["io2821002", "io.RawIOBase.__dict__.__contains__",     ["__radd__"], false]
    - ["io2821003", "io.BufferedIOBase.__dict__.__contains__", ["__radd__"], false]
    - ["io2821004", "io.TextIOBase.__dict__.__contains__",    ["__radd__"], false]
    - ["io2821005", "io.BytesIO.__dict__.__contains__",       ["__radd__"], false]
    - ["io2821006", "io.StringIO.__dict__.__contains__",      ["__radd__"], false]
    - ["io2821007", "io.FileIO.__dict__.__contains__",        ["__radd__"], false]
    - ["io2821008", "io.BufferedReader.__dict__.__contains__", ["__radd__"], false]
    - ["io2821009", "io.BufferedWriter.__dict__.__contains__", ["__radd__"], false]
    - ["io2821010", "io.BufferedRandom.__dict__.__contains__", ["__radd__"], false]
    - ["io2821011", "io.TextIOWrapper.__dict__.__contains__", ["__radd__"], false]

