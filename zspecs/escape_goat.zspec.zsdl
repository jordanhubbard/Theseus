spec: escape_goat
version: ">=4.0.0"
backend: node(escape-goat)

docs: https://github.com/sindresorhus/escape-goat#readme

provenance:
  derived_from:
    - "escape-goat README — https://github.com/sindresorhus/escape-goat#readme"
    - "WHATWG HTML Standard — Named character references"
    - "Test vectors verified with escape-goat via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "escape-goat source"
  notes:
    - "Tiny HTML escape/unescape utility (sindresorhus). Sibling/alternative to html-entities."
    - "Install: npm install escape-goat"
    - "htmlEscape(str): escapes &, <, >, \", '."
    - "htmlUnescape(str): reverses the same five characters."
    - "Module exposes htmlEscape/htmlUnescape as direct named exports (CJS)."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table escape_goat.htmlEscape:
  kind: node_module_call_eq
  category: htmlEscape
  function: htmlEscape
  id_prefix: esc

  columns: [id, args, expected]
  rows:
    - [angle_brackets,   ["<script>"],    "&lt;script&gt;"]
    - [ampersand,        ["A & B"],       "A &amp; B"]
    - [double_quote,     ["\"hi\""],      "&quot;hi&quot;"]
    - [single_quote,     ["it's"],        "it&#39;s"]
    - [no_special,       ["plain"],        "plain"]
    - [empty,            [""],             ""]
    - [unicode_passthrough, ["Café"],     "Café"]

table escape_goat.htmlUnescape:
  kind: node_module_call_eq
  category: htmlUnescape
  function: htmlUnescape
  id_prefix: unesc

  columns: [id, args, expected]
  rows:
    - [angle_brackets,   ["&lt;script&gt;"],     "<script>"]
    - [ampersand,        ["A &amp; B"],           "A & B"]
    - [double_quote,     ["&quot;hi&quot;"],      "\"hi\""]
    - [single_quote,     ["it&#39;s"],             "it's"]
    - [no_entities,      ["plain"],                "plain"]
    - [empty,            [""],                     ""]

# Round-trip identity for the 5 escape-worthy chars
invariant escape_goat.roundtrip:
  description: "htmlUnescape(htmlEscape(s)) == s for inputs containing all 5 escape chars"
  category: roundtrip
  kind: node_module_call_eq
  function: htmlUnescape
  args: ["&lt;a href=&quot;x&quot;&gt;a &amp; b&lt;/a&gt;"]
  expected: "<a href=\"x\">a & b</a>"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:42:31Z
  iterations: 1
  pass_count: 14
  fail_count: 0
  total_invariants: 14
  notes: Synthesis succeeded in 1 iteration(s). 14 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
