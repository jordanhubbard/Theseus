spec: socket_extra386
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "socket.inet_aton.__name__ == 'inet_aton', __module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.inet_ntoa.__name__ == 'inet_ntoa', __module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.htons.__name__ == 'htons', __module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.htonl.__name__ == 'htonl', __module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.ntohs.__name__ == 'ntohs', __module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.ntohl.__name__ == 'ntohl', __module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All six functions originate in the _socket C extension module (Modules/socketmodule.c). Their __module__ is '_socket', not 'socket', because the type objects are created in the C extension. The socket module (Lib/socket.py) re-exports them."
    - "Note: inet_aton converts a dotted-quad IPv4 string to 4 packed bytes. inet_ntoa performs the reverse. Both are wrappers around POSIX inet_aton(3)/inet_ntoa(3)."
    - "Note: htons/htonl convert host-to-network byte order (short/long); ntohs/ntohl convert network-to-host. On big-endian systems these are no-ops; on little-endian (macOS x86/ARM) they swap bytes."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.inet_aton, socket.inet_ntoa — function identity
# socket.htons, socket.htonl, socket.ntohs, socket.ntohl — function identity
#
# Wave 386 theme: socket module network byte-order and IP address conversion
# function identity (__name__ and __module__).
#
# All six functions are implemented in Modules/socketmodule.c and belong to
# the _socket C extension. Their __module__ attribute is '_socket' (not
# 'socket'), because the function objects are created in the C extension before
# being re-exported by Lib/socket.py. This mirrors the pattern seen for other
# C-backed socket functions like htons, htonl, etc.
#
# inet_aton: converts dotted-quad IPv4 address string to 4-byte packed
# representation (big-endian network byte order). Wraps POSIX inet_aton(3).
#
# inet_ntoa: converts 4-byte packed IPv4 address (network byte order) to
# dotted-quad string. Wraps POSIX inet_ntoa(3).
#
# htons (host-to-network short): converts a 16-bit integer from host byte
# order to network byte order (big-endian).
#
# htonl (host-to-network long): converts a 32-bit integer from host byte
# order to network byte order.
#
# ntohs (network-to-host short): converts a 16-bit integer from network byte
# order to host byte order.
#
# ntohl (network-to-host long): converts a 32-bit integer from network byte
# order to host byte order.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra386.inet_function_names:
  description: "socket.inet_aton and socket.inet_ntoa __name__ values — inet_aton.__name__ is 'inet_aton', inet_ntoa.__name__ is 'inet_ntoa'; C builtins in _socket wrapping POSIX inet_aton(3)/inet_ntoa(3); verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: socketinetname386

  columns: [id, function, args, expected]
  rows:
    - [inet_aton_name,  inet_aton.__name__.__eq__,  ["inet_aton"],  true]
    - [inet_ntoa_name,  inet_ntoa.__name__.__eq__,  ["inet_ntoa"],  true]

table socket_extra386.inet_function_modules:
  description: "socket.inet_aton and socket.inet_ntoa __module__ values — both have __module__ '_socket' because they originate in the _socket C extension (Modules/socketmodule.c); re-exported by Lib/socket.py; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: socketinetmod386

  columns: [id, function, args, expected]
  rows:
    - [inet_aton_module, inet_aton.__module__.__eq__, ["_socket"], true]
    - [inet_ntoa_module, inet_ntoa.__module__.__eq__, ["_socket"], true]

# ---------------------------------------------------------------------------
# socket.htons, socket.htonl, socket.ntohs, socket.ntohl — __name__ identity
#
# These four byte-order conversion functions are also C builtins in the
# _socket extension. Their __name__ values match the POSIX function names
# they wrap: htons, htonl, ntohs, ntohl.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra386.byteorder_function_names:
  description: "socket byte-order conversion function __name__ values — htons/htonl/ntohs/ntohl all have __name__ matching their POSIX counterpart; C builtins in _socket extension; on little-endian macOS these perform byte swaps; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: socketboname386

  columns: [id, function, args, expected]
  rows:
    - [htons_name,  htons.__name__.__eq__,  ["htons"],  true]
    - [htonl_name,  htonl.__name__.__eq__,  ["htonl"],  true]
    - [ntohs_name,  ntohs.__name__.__eq__,  ["ntohs"],  true]
    - [ntohl_name,  ntohl.__name__.__eq__,  ["ntohl"],  true]

# ---------------------------------------------------------------------------
# socket.htons, socket.htonl, socket.ntohs, socket.ntohl — __module__ identity
#
# All four byte-order conversion functions have __module__ == '_socket',
# consistent with inet_aton, inet_ntoa, and all other socket C builtins.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra386.byteorder_function_modules:
  description: "socket byte-order conversion function __module__ values — htons/htonl/ntohs/ntohl all have __module__ '_socket'; originate in _socket C extension; re-exported by Lib/socket.py wrapper module; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: socketbomod386

  columns: [id, function, args, expected]
  rows:
    - [htons_module,  htons.__module__.__eq__,  ["_socket"], true]
    - [htonl_module,  htonl.__module__.__eq__,  ["_socket"], true]
    - [ntohs_module,  ntohs.__module__.__eq__,  ["_socket"], true]
    - [ntohl_module,  ntohl.__module__.__eq__,  ["_socket"], true]
