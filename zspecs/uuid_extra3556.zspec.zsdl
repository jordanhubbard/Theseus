spec: uu3556
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 684 (uu3556): __reduce__, __reduce_ex__, __getstate__ dict-presence checks for uuid types."
    - "uuid.UUID defines __getstate__ (true): UUID implements __getstate__ to return its internal integer for efficient copy/pickle support."
    - "uuid.UUID does NOT define __reduce__ or __reduce_ex__ in its own __dict__ (false)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

