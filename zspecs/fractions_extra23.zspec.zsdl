spec: fractions_extra23
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions_extra22.zspec.zsdl."
    - "Prior specs covered: Fraction arithmetic, __name__/__module__/__qualname__, __bases__, Fraction(1,2) numerator/denominator, limit_denominator/from_float/from_decimal, __str__/__repr__/__abs__/__neg__/__pos__ __name__, Fraction instances' __class__.__name__."
    - "This spec covers: fractions.Fraction.__module__.__len__(), fractions.Fraction.__name__.__len__() (standalone form), fractions.Fraction.__qualname__.__len__(), fractions.Fraction.__str__/__abs__/__neg__/__pos__ __qualname__, fractions.Fraction.limit_denominator/__name__/__qualname__, fractions.Fraction.from_float/__name__/__qualname__, fractions.Fraction.from_decimal/__name__."
    - "Fraction.__module__ == 'fractions' (9 chars); __name__ == 'Fraction' (8 chars); __qualname__ == 'Fraction' (8 chars)."
    - "fractions_extra22 records Fraction.__name__.__len__() == 8 and Fraction.__str__.__name__; this spec records __qualname__ for the unary dunder methods."
    - "__str__/__abs__/__neg__/__pos__ all have __qualname__ of the form 'Fraction.<dunder>'."
    - "limit_denominator and from_float are class methods; their __qualname__ is 'Fraction.limit_denominator' and 'Fraction.from_float'."
    - "from_decimal.__name__ == 'from_decimal' — the bare method name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# fractions.Fraction.__module__.__len__()
#
# fractions_extra22 records Fraction.__module__ as an equality invariant but
# does not record its length.  Fraction.__module__ == 'fractions' (9 chars).
# ---------------------------------------------------------------------------

invariant fractions_extra23.Fraction.module_len:
  description: "len(fractions.Fraction.__module__) == 9 — 'fractions' is 9 chars"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__module__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# fractions.Fraction.__name__.__len__() (complementary form)
#
# fractions_extra22 records Fraction.__name__.__len__() == 8 as part of the
# class_name invariant group.  Recorded here as a standalone invariant for
# this spec's series continuity.
# ---------------------------------------------------------------------------

invariant fractions_extra23.Fraction.name_len:
  description: "len(fractions.Fraction.__name__) == 8 — 'Fraction' is 8 chars"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# fractions.Fraction.__qualname__.__len__()
#
# Fraction is a top-level class; __qualname__ == __name__ == 'Fraction'.
# No prior spec records Fraction.__qualname__.__len__() as a standalone.
# ---------------------------------------------------------------------------

invariant fractions_extra23.Fraction.qualname_len:
  description: "len(fractions.Fraction.__qualname__) == 8 — 'Fraction' is 8 chars"
  category: class_identity
  kind: python_call_eq
  function: Fraction.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# fractions.Fraction.__str__.__qualname__
#
# fractions_extra22 records Fraction.__str__.__name__ == '__str__'.
# No prior spec records Fraction.__str__.__qualname__.
# For instance methods defined directly on Fraction, __qualname__ takes the
# form 'Fraction.<dunder>'.
# ---------------------------------------------------------------------------

invariant fractions_extra23.Fraction.str_qualname:
  description: "fractions.Fraction.__str__.__qualname__ == 'Fraction.__str__'"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__str__.__qualname__.__eq__
  args: ["Fraction.__str__"]
  expected: true

invariant fractions_extra23.Fraction.str_qualname_len:
  description: "len(fractions.Fraction.__str__.__qualname__) == 16 — 'Fraction.__str__' is 16 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__str__.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# Unary arithmetic method __qualname__ values: __abs__, __neg__, __pos__
#
# fractions_extra22 records __name__ for these three methods.
# No prior spec records their __qualname__ values.
# Each takes the form 'Fraction.<dunder>'.
# ---------------------------------------------------------------------------

table fractions_extra23.unary_method_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [abs, Fraction.__abs__.__qualname__.__eq__, ["Fraction.__abs__"], true, "fractions.Fraction.__abs__.__qualname__ == 'Fraction.__abs__'"]
    - [neg, Fraction.__neg__.__qualname__.__eq__, ["Fraction.__neg__"], true, "fractions.Fraction.__neg__.__qualname__ == 'Fraction.__neg__'"]
    - [pos, Fraction.__pos__.__qualname__.__eq__, ["Fraction.__pos__"], true, "fractions.Fraction.__pos__.__qualname__ == 'Fraction.__pos__'"]

invariant fractions_extra23.Fraction.abs_qualname_len:
  description: "len(fractions.Fraction.__abs__.__qualname__) == 16 — 'Fraction.__abs__' is 16 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__abs__.__qualname__.__len__
  args: []
  expected: 16

invariant fractions_extra23.Fraction.neg_qualname_len:
  description: "len(fractions.Fraction.__neg__.__qualname__) == 16 — 'Fraction.__neg__' is 16 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__neg__.__qualname__.__len__
  args: []
  expected: 16

invariant fractions_extra23.Fraction.pos_qualname_len:
  description: "len(fractions.Fraction.__pos__.__qualname__) == 16 — 'Fraction.__pos__' is 16 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__pos__.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# fractions.Fraction.limit_denominator — __name__ and __qualname__
#
# fractions_extra21 records limit_denominator.__qualname__ in a table.
# No prior spec records limit_denominator.__name__ as a standalone invariant.
# limit_denominator is a regular method; __name__ == 'limit_denominator',
# __qualname__ == 'Fraction.limit_denominator'.
# ---------------------------------------------------------------------------

invariant fractions_extra23.Fraction.limit_denominator_name:
  description: "fractions.Fraction.limit_denominator.__name__ == 'limit_denominator'"
  category: method_identity
  kind: python_call_eq
  function: Fraction.limit_denominator.__name__.__eq__
  args: ["limit_denominator"]
  expected: true

invariant fractions_extra23.Fraction.limit_denominator_name_len:
  description: "len(fractions.Fraction.limit_denominator.__name__) == 17 — 'limit_denominator' is 17 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.limit_denominator.__name__.__len__
  args: []
  expected: 17

invariant fractions_extra23.Fraction.limit_denominator_qualname:
  description: "fractions.Fraction.limit_denominator.__qualname__ == 'Fraction.limit_denominator'"
  category: method_identity
  kind: python_call_eq
  function: Fraction.limit_denominator.__qualname__.__eq__
  args: ["Fraction.limit_denominator"]
  expected: true

invariant fractions_extra23.Fraction.limit_denominator_qualname_len:
  description: "len(fractions.Fraction.limit_denominator.__qualname__) == 26 — 'Fraction.limit_denominator' is 26 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.limit_denominator.__qualname__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# fractions.Fraction.from_float — __name__ and __qualname__
#
# fractions_extra21 records from_float.__qualname__ in a table.
# No prior spec records from_float.__name__ as a standalone invariant.
# from_float is a classmethod; its __name__ == 'from_float',
# __qualname__ == 'Fraction.from_float'.
# ---------------------------------------------------------------------------

invariant fractions_extra23.Fraction.from_float_name:
  description: "fractions.Fraction.from_float.__name__ == 'from_float'"
  category: method_identity
  kind: python_call_eq
  function: Fraction.from_float.__name__.__eq__
  args: ["from_float"]
  expected: true

invariant fractions_extra23.Fraction.from_float_name_len:
  description: "len(fractions.Fraction.from_float.__name__) == 10 — 'from_float' is 10 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.from_float.__name__.__len__
  args: []
  expected: 10

invariant fractions_extra23.Fraction.from_float_qualname:
  description: "fractions.Fraction.from_float.__qualname__ == 'Fraction.from_float'"
  category: method_identity
  kind: python_call_eq
  function: Fraction.from_float.__qualname__.__eq__
  args: ["Fraction.from_float"]
  expected: true

invariant fractions_extra23.Fraction.from_float_qualname_len:
  description: "len(fractions.Fraction.from_float.__qualname__) == 19 — 'Fraction.from_float' is 19 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.from_float.__qualname__.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# fractions.Fraction.from_decimal — __name__
#
# fractions_extra21 records from_decimal.__qualname__ in a table.
# No prior spec records from_decimal.__name__ as a standalone invariant.
# from_decimal is a classmethod; __name__ == 'from_decimal'.
# ---------------------------------------------------------------------------

invariant fractions_extra23.Fraction.from_decimal_name:
  description: "fractions.Fraction.from_decimal.__name__ == 'from_decimal'"
  category: method_identity
  kind: python_call_eq
  function: Fraction.from_decimal.__name__.__eq__
  args: ["from_decimal"]
  expected: true

invariant fractions_extra23.Fraction.from_decimal_name_len:
  description: "len(fractions.Fraction.from_decimal.__name__) == 12 — 'from_decimal' is 12 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.from_decimal.__name__.__len__
  args: []
  expected: 12
