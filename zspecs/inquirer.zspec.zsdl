spec: inquirer
version: ">=9.0.0"
backend: node(inquirer)
esm: true

docs: https://github.com/SBoudrias/Inquirer.js#readme

provenance:
  derived_from:
    - "Inquirer.js README — https://github.com/SBoudrias/Inquirer.js#readme"
    - "Test vectors verified with inquirer via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "inquirer source"
  notes:
    - "inquirer is an ESM-only package since v9. Install: npm install inquirer"
    - "Inquirer's primary surface is interactive (reads from TTY); only the Separator helper class is testable offline."
    - "In ESM, inquirer.Separator is exposed as default.Separator — accessed via the dotted-path 'class: default.Separator'."
    - "A Separator instance has .type === 'separator' and .separator (string) — used as a non-selectable item in choice lists."
    - "Default constructor produces a 14-em-dash line: '──────────────'."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Separator construction returns a plain object with .type and .separator string fields."
  stderr: "null"
  stickiness: "N/A — each Separator is independent."
  codes: {}

# ── Separator type marker ────────────────────────────────────────────────────

table inquirer.separator_type:
  kind: node_property_eq
  category: separator
  entry: constructor
  class: default.Separator
  property: type
  id_prefix: type

  columns: [id, entry_args, expected]
  rows:
    - [no_args,       [],                      "separator"]
    - [custom_string, ["---"],                 "separator"]
    - [unicode_line,  ["═══════"],             "separator"]

# ── Separator content (the .separator field) ────────────────────────────────

table inquirer.separator_content:
  kind: node_property_eq
  category: separator
  entry: constructor
  class: default.Separator
  property: separator
  id_prefix: content

  columns: [id, entry_args, expected]
  rows:
    - [default_em_dash_line, [],                       "──────────────"]
    - [custom_dashes,        ["---"],                  "---"]
    - [labeled_section,      ["=== HELLO ==="],        "=== HELLO ==="]
    - [empty_string_falls_back, [""],                  "──────────────"]
