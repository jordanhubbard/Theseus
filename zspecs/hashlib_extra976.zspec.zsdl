spec: hashlib_extra976
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks hashlib constructor and function qualnames, class names, and module-level attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra976.hash_constructor_qualnames:
  description: "hashlib hash constructor __qualname__ identity"
  kind: python_call_eq
  category: constructor_qualnames
  id_prefix: hl976cq
  columns: [id, function, args, expected]
  rows:
    - [hl976cq001, hashlib.md5.__qualname__.__eq__,         ["openssl_md5"],    false]
    - [hl976cq002, hashlib.md5.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [hl976cq003, hashlib.sha256.__qualname__.__eq__,      ["openssl_sha256"], false]
    - [hl976cq004, hashlib.sha256.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl976cq005, hashlib.sha512.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl976cq006, hashlib.sha1.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]

table hashlib_extra976.module_function_qualnames:
  description: "hashlib module-level function __qualname__ checks"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: hl976fq
  columns: [id, function, args, expected]
  rows:
    - [hl976fq001, hashlib.new.__qualname__.__eq__,           ["new"],           true]
    - [hl976fq002, hashlib.new.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]
    - [hl976fq003, hashlib.pbkdf2_hmac.__qualname__.__eq__,   ["pbkdf2_hmac"],   true]
    - [hl976fq004, hashlib.pbkdf2_hmac.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl976fq005, hashlib.scrypt.__qualname__.__eq__,        ["scrypt"],        true]
    - [hl976fq006, hashlib.scrypt.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

table hashlib_extra976.module_loader_identity:
  description: "hashlib module loader and name identity checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: hl976mi
  columns: [id, function, args, expected]
  rows:
    - [hl976mi001, hashlib.__name__.__eq__,                        ["hashlib"],   true]
    - [hl976mi002, hashlib.__loader__.__class__.__name__.__eq__,   ["BuiltinImporter"], false]
    - [hl976mi003, hashlib.__package__.__eq__,                     ["hashlib"],   false]
    - [hl976mi004, hashlib.__spec__.__class__.__name__.__eq__,     ["ModuleSpec"], true]
    - [hl976mi005, hashlib.__spec__.name.__eq__,                   ["hashlib"],   true]
