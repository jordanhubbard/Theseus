spec: itertools_extra64
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra63.zspec.zsdl."
    - "Wave 230 theme: __code__ attribute deep chains. All itertools types are C extension types (Modules/itertoolsmodule.c) and have no __code__ attribute. This spec instead extends __doc__ content checks to combinations, permutations, product, and compress — none of which have been checked in extra63 or earlier."
    - "combinations.__doc__ == 'Return successive r-length combinations of elements in the iterable.\\n\\ncombinations(range(4), 3) --> (0,1,2), (0,1,3), (0,2,3), (1,2,3)'. It contains 'combinations' (True) and 'iterable' (True) but NOT 'sorted' (False — sorted order is not mentioned in the docstring). Verified with Python 3.14.3."
    - "permutations.__doc__ contains 'permutations' (True) — the type name appears in the body of the docstring. It also contains 'elements' (True) — 'permutations of elements in the iterable'. Verified with Python 3.14.3."
    - "product.__doc__ contains 'product' (True) — 'Cartesian product of input iterables.' and 'product' appears in the example code. It contains 'Cartesian' (True) — first word of docstring. Verified with Python 3.14.3."
    - "compress.__doc__ == 'Return data elements corresponding to true selector elements.\\n\\nForms a shorter iterator from selected data elements using the selectors to\\nchoose the data elements.' It does NOT contain 'compress' (False — the type name does not appear in its docstring). It does contain 'selector' (True) — 'using the selectors to'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "No prior itertools spec checks combinations.__doc__, permutations.__doc__, product.__doc__, or compress.__doc__ content. All checks in this spec are new to extra64."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# combinations.__doc__.__contains__ — extra64
#
# Wave 230 theme: __doc__ content checks for itertools C extension types.
#
# itertools.combinations is a C extension type (Modules/itertoolsmodule.c).
# Its docstring:
#   'Return successive r-length combinations of elements in the iterable.\n\n
#    combinations(range(4), 3) --> (0,1,2), (0,1,3), (0,2,3), (1,2,3)'
#
# Key findings:
#   combinations.__doc__.__contains__('combinations') == True
#     (the type name 'combinations' appears in the example line)
#   combinations.__doc__.__contains__('iterable') == True
#     ('in the iterable' in the opening sentence)
#   combinations.__doc__.__contains__('sorted') == False
#     (sorted order is NOT mentioned in this short docstring)
#
# No prior itertools spec checks combinations.__doc__. New to extra64.
# ---------------------------------------------------------------------------

table itertools_extra64.combinations_doc_contains:
  description: "combinations.__doc__.__contains__ checks — 'combinations' True, 'iterable' True, 'sorted' False; wave 230 __doc__ content; new to extra64"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc3_64

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_doc_contains_combinations,
       combinations.__doc__.__contains__,
       ["combinations"],
       true,
       "itertools.combinations.__doc__.__contains__('combinations') == True — combinations is a C extension type (Modules/itertoolsmodule.c) that returns r-length subsequences; its docstring reads 'Return successive r-length combinations of elements in the iterable.\\n\\ncombinations(range(4), 3) --> (0,1,2), (0,1,3), (0,2,3), (1,2,3)'; the word 'combinations' appears in the example line of the docstring (the second paragraph); __contains__ returns True at that occurrence; no prior itertools spec checks combinations.__doc__.__contains__('combinations'); new to extra64"]
    - [combinations_doc_contains_iterable,
       combinations.__doc__.__contains__,
       ["iterable"],
       true,
       "itertools.combinations.__doc__.__contains__('iterable') == True — combinations.__doc__ opens with 'Return successive r-length combinations of elements in the iterable.'; the word 'iterable' appears at the end of the opening sentence referring to the first positional argument; __contains__ returns True; no prior itertools spec checks combinations.__doc__.__contains__('iterable'); new to extra64"]
    - [combinations_doc_not_contains_sorted,
       combinations.__doc__.__contains__,
       ["sorted"],
       false,
       "itertools.combinations.__doc__.__contains__('sorted') == False — combinations.__doc__ reads 'Return successive r-length combinations of elements in the iterable.\\n\\ncombinations(range(4), 3) --> (0,1,2), (0,1,3), (0,2,3), (1,2,3)'; neither the word 'sorted' nor the concept of sort order is mentioned in this concise docstring even though combinations yields results in lexicographic order when the input is sorted; the docstring omits this detail; __contains__ returns False; this False result is important for calibration; no prior itertools spec checks combinations.__doc__.__contains__('sorted'); new to extra64"]

# ---------------------------------------------------------------------------
# permutations.__doc__.__contains__ — extra64
#
# Wave 230 theme: __doc__ content checks for itertools C extension types.
#
# itertools.permutations is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'Return successive r-length permutations of elements in the iterable.\n\n
#    permutations(...) --> ...'
#
# Key findings:
#   permutations.__doc__.__contains__('permutations') == True
#   permutations.__doc__.__contains__('elements') == True
#
# No prior itertools spec checks permutations.__doc__. New to extra64.
# ---------------------------------------------------------------------------

table itertools_extra64.permutations_doc_contains:
  description: "permutations.__doc__.__contains__ checks — 'permutations' True, 'elements' True; wave 230 __doc__ content; new to extra64"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc3_64

  columns: [id, function, args, expected, description]
  rows:
    - [permutations_doc_contains_permutations,
       permutations.__doc__.__contains__,
       ["permutations"],
       true,
       "itertools.permutations.__doc__.__contains__('permutations') == True — permutations is a C extension type (Modules/itertoolsmodule.c) that returns successive r-length permutations of elements; its docstring opens with 'Return successive r-length permutations of elements in the iterable.' and includes the type name 'permutations' in the example code in the second paragraph; __contains__ returns True; no prior itertools spec checks permutations.__doc__.__contains__('permutations'); new to extra64"]
    - [permutations_doc_contains_elements,
       permutations.__doc__.__contains__,
       ["elements"],
       true,
       "itertools.permutations.__doc__.__contains__('elements') == True — permutations.__doc__ opens with 'Return successive r-length permutations of elements in the iterable.'; the word 'elements' appears in this opening sentence describing what is being permuted; __contains__ returns True; no prior itertools spec checks permutations.__doc__.__contains__('elements'); new to extra64"]

# ---------------------------------------------------------------------------
# product.__doc__.__contains__ — extra64
#
# Wave 230 theme: __doc__ content checks for itertools C extension types.
#
# itertools.product is a C extension type (Modules/itertoolsmodule.c).
# Its docstring opens with:
#   'Cartesian product of input iterables.  Equivalent to nested for-loops.\n\n
#    For example, ...'
#
# Key findings:
#   product.__doc__.__contains__('product') == True
#     (appears in example code 'product(A, repeat=4)' later in docstring)
#   product.__doc__.__contains__('Cartesian') == True
#     (very first word of docstring)
#
# No prior itertools spec checks product.__doc__. New to extra64.
# ---------------------------------------------------------------------------

table itertools_extra64.product_doc_contains:
  description: "product.__doc__.__contains__ checks — 'product' True, 'Cartesian' True; wave 230 __doc__ content; new to extra64"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc3_64

  columns: [id, function, args, expected, description]
  rows:
    - [product_doc_contains_product,
       product.__doc__.__contains__,
       ["product"],
       true,
       "itertools.product.__doc__.__contains__('product') == True — product is a C extension type (Modules/itertoolsmodule.c) implementing the Cartesian product of iterables; its docstring opens with 'Cartesian product of input iterables.' and the word 'product' appears in the example code in the body of the docstring (e.g. 'product(A, repeat=4)'); __contains__ returns True at the first occurrence; no prior itertools spec checks product.__doc__.__contains__('product'); new to extra64"]
    - [product_doc_contains_Cartesian,
       product.__doc__.__contains__,
       ["Cartesian"],
       true,
       "itertools.product.__doc__.__contains__('Cartesian') == True — product.__doc__ opens with the word 'Cartesian' (capital C) as in 'Cartesian product of input iterables.'; 'Cartesian' is the very first word of the docstring describing the mathematical concept this type implements; __contains__ is case-sensitive and 'Cartesian' with capital C appears as the first word; __contains__ returns True; no prior itertools spec checks product.__doc__.__contains__('Cartesian'); new to extra64"]

# ---------------------------------------------------------------------------
# compress.__doc__.__contains__ — extra64
#
# Wave 230 theme: __doc__ content checks for itertools C extension types.
#
# itertools.compress is a C extension type (Modules/itertoolsmodule.c).
# Its docstring:
#   'Return data elements corresponding to true selector elements.\n\n
#    Forms a shorter iterator from selected data elements using the selectors to\n
#    choose the data elements.'
#
# Key findings:
#   compress.__doc__.__contains__('compress') == False
#     (the type name does NOT appear in its own docstring)
#   compress.__doc__.__contains__('selector') == True
#     ('using the selectors to' in the second paragraph)
#
# No prior itertools spec checks compress.__doc__. New to extra64.
# ---------------------------------------------------------------------------

table itertools_extra64.compress_doc_contains:
  description: "compress.__doc__.__contains__ checks — 'compress' False (name absent), 'selector' True; wave 230 __doc__ content; new to extra64"
  kind: python_call_eq
  category: doc_content
  id_prefix: itertdoc3_64

  columns: [id, function, args, expected, description]
  rows:
    - [compress_doc_not_contains_compress,
       compress.__doc__.__contains__,
       ["compress"],
       false,
       "itertools.compress.__doc__.__contains__('compress') == False — compress is a C extension type (Modules/itertoolsmodule.c) that filters one iterable using boolean values from another; its docstring reads 'Return data elements corresponding to true selector elements.\\n\\nForms a shorter iterator from selected data elements using the selectors to\\nchoose the data elements.'; the word 'compress' (the type's own name) does not appear anywhere in this docstring; __contains__ returns False; this is a calibration check demonstrating that a C type's docstring need not mention the type name; no prior itertools spec checks compress.__doc__.__contains__('compress'); new to extra64"]
    - [compress_doc_contains_selector,
       compress.__doc__.__contains__,
       ["selector"],
       true,
       "itertools.compress.__doc__.__contains__('selector') == True — compress.__doc__ reads 'Return data elements corresponding to true selector elements.\\n\\nForms a shorter iterator from selected data elements using the selectors to\\nchoose the data elements.'; the word 'selector' appears in the first sentence ('true selector elements') and as 'selectors' in the second paragraph; __contains__ finds 'selector' as a substring of 'selectors' (which also starts with 'selector') so it returns True at the first occurrence in the opening sentence; no prior itertools spec checks compress.__doc__.__contains__('selector'); new to extra64"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra64
# ---------------------------------------------------------------------------

invariant itertools_extra64.combinations_doc_contains_combinations:
  description: "itertools.combinations.__doc__.__contains__('combinations') == True — type name appears in docstring example code; wave 230 __doc__ content; new to extra64"
  kind: python_call_eq
  function: combinations.__doc__.__contains__
  args: ["combinations"]
  expected: true

invariant itertools_extra64.combinations_doc_not_contains_sorted:
  description: "itertools.combinations.__doc__.__contains__('sorted') == False — short docstring omits sort-order description; wave 230 __doc__ content; new to extra64"
  kind: python_call_eq
  function: combinations.__doc__.__contains__
  args: ["sorted"]
  expected: false

invariant itertools_extra64.product_doc_contains_Cartesian:
  description: "itertools.product.__doc__.__contains__('Cartesian') == True — 'Cartesian' is the first word of the product docstring; wave 230 __doc__ content; new to extra64"
  kind: python_call_eq
  function: product.__doc__.__contains__
  args: ["Cartesian"]
  expected: true

invariant itertools_extra64.compress_doc_not_contains_compress:
  description: "itertools.compress.__doc__.__contains__('compress') == False — compress's docstring does not mention the type name; wave 230 __doc__ content; new to extra64"
  kind: python_call_eq
  function: compress.__doc__.__contains__
  args: ["compress"]
  expected: false
