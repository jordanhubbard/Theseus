spec: io_extra292
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module constants, open/open_code functions, and UnsupportedOperation exception"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "io.DEFAULT_BUFFER_SIZE is 131072 (128KB) on macOS/Darwin in Python 3.14, not 8192 as the docs once suggested"
    - "io.SEEK_SET=0, io.SEEK_CUR=1, io.SEEK_END=2 match POSIX seek whence constants"
    - "io.UnsupportedOperation inherits from both OSError and ValueError; __bases__[0] is OSError"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table io_extra292.constants:
  description: "io module seek and buffer size constants"
  kind: python_call_eq
  category: identity
  id_prefix: io292c

  columns: [id, function, args, expected, description]
  rows:
    - [io292c001, io.SEEK_SET.__class__.__name__, [], "int", "SEEK_SET is an int"]
    - [io292c002, io.SEEK_CUR.__class__.__name__, [], "int", "SEEK_CUR is an int"]
    - [io292c003, io.SEEK_END.__class__.__name__, [], "int", "SEEK_END is an int"]
    - [io292c004, io.DEFAULT_BUFFER_SIZE.__class__.__name__, [], "int", "DEFAULT_BUFFER_SIZE is an int"]

table io_extra292.function_identity:
  description: "io.open and io.open_code function name identity"
  kind: python_call_eq
  category: identity
  id_prefix: io292f

  columns: [id, function, args, expected, description]
  rows:
    - [io292f001, io.open.__name__, [], "open", "io.open.__name__ is 'open'"]
    - [io292f002, io.open.__module__, [], "io", "io.open.__module__ is 'io'"]
    - [io292f003, io.open_code.__name__, [], "open_code", "io.open_code.__name__ is 'open_code'"]
    - [io292f004, io.open_code.__module__, [], "io", "io.open_code.__module__ is 'io'"]

invariant io_extra292.seek_set_value:
  description: "io.SEEK_SET equals 0"
  category: identity
  kind: python_call_eq
  function: io.SEEK_SET.__class__.__name__
  args: []
  expected: "int"

invariant io_extra292.seek_set_zero:
  description: "io.SEEK_SET is 0"
  category: identity
  kind: python_call_eq
  function: io.SEEK_SET.__eq__
  args: [0]
  expected: true

invariant io_extra292.seek_cur_one:
  description: "io.SEEK_CUR is 1"
  category: identity
  kind: python_call_eq
  function: io.SEEK_CUR.__eq__
  args: [1]
  expected: true

invariant io_extra292.seek_end_two:
  description: "io.SEEK_END is 2"
  category: identity
  kind: python_call_eq
  function: io.SEEK_END.__eq__
  args: [2]
  expected: true

invariant io_extra292.default_buffer_size_value:
  description: "io.DEFAULT_BUFFER_SIZE is 131072 on macOS/Darwin Python 3.14"
  category: identity
  kind: python_call_eq
  function: io.DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra292.unsupported_operation_name:
  description: "io.UnsupportedOperation.__name__ is 'UnsupportedOperation'"
  category: identity
  kind: python_call_eq
  function: io.UnsupportedOperation.__name__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io_extra292.unsupported_operation_module:
  description: "io.UnsupportedOperation.__module__ is 'io'"
  category: identity
  kind: python_call_eq
  function: io.UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra292.unsupported_operation_base:
  description: "io.UnsupportedOperation.__bases__[0].__name__ is 'OSError'"
  category: identity
  kind: python_call_eq
  function: "io.UnsupportedOperation.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant io_extra292.default_buffer_size_class:
  description: "io.DEFAULT_BUFFER_SIZE is an int"
  category: identity
  kind: python_call_eq
  function: io.DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true
