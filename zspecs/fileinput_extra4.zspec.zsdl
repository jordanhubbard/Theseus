spec: fileinput_extra4
version: ">=3.9"
backend: python_module(fileinput)

docs: https://docs.python.org/3/library/fileinput.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fileinput.html — Python fileinput module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fileinput.py"
  notes:
    - "This spec extends fileinput.zspec.zsdl and all prior fileinput_extra specs."
    - "fileinput.zspec.zsdl covers: FileInput.__name__/__module__; function_names table for all 11 module-level functions."
    - "fileinput_extra.zspec.zsdl covers: standalone __name__ invariants for all module-level functions and FileInput; FileInput class type check; callability checks for input/hook_compressed/hook_encoded."
    - "fileinput_extra2.zspec.zsdl covers: __module__ checks for all module-level functions; FileInput.__qualname__; FileInput.__bases__[0].__name__=='object'; function qualnames table."
    - "fileinput_extra3.zspec.zsdl covers: hook_compressed/__module__/__qualname__; hook_encoded/__module__/__qualname__; nextfile/__qualname__; close/__qualname__; FileInput.__name__/__module__/__qualname__/__bases__ anchor invariants."
    - "This spec adds new axes: __name__ length checks for input, filename, FileInput, and hook_compressed; __name__ is-str checks for those same four symbols; hook_compressed.__name__[0] and FileInput.__name__[0] character checks."
    - "fileinput.input.__name__ has length 5 ('input')."
    - "fileinput.filename.__name__ has length 8 ('filename')."
    - "fileinput.FileInput.__name__ has length 9 ('FileInput')."
    - "fileinput.hook_compressed.__name__ has length 15 ('hook_compressed')."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ length checks — input, filename, FileInput, hook_compressed
# All prior specs verify __name__ via equality; none verify the length of
# the __name__ string. This is a distinct uncovered axis.
# ---------------------------------------------------------------------------

table fileinput_extra4.name_lengths:
  description: "__name__ attribute lengths for selected fileinput symbols"
  kind: python_call_eq
  category: name_lengths
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [input,           input.__name__.__len__,           [], 5]
    - [filename,        filename.__name__.__len__,        [], 8]
    - [FileInput,       FileInput.__name__.__len__,       [], 9]
    - [hook_compressed, hook_compressed.__name__.__len__, [], 15]

# ---------------------------------------------------------------------------
# __name__ is-str checks — input, filename, FileInput, hook_compressed
# None of the prior fileinput specs verify that __name__ is a str object.
# ---------------------------------------------------------------------------

table fileinput_extra4.name_is_str:
  description: "__name__ attributes are str objects for selected fileinput symbols"
  kind: python_call_eq
  category: name_types
  id_prefix: namestr

  columns: [id, function, args, expected]
  rows:
    - [input,           input.__name__.__class__.__name__.__eq__,           ["str"], true]
    - [filename,        filename.__name__.__class__.__name__.__eq__,        ["str"], true]
    - [FileInput,       FileInput.__name__.__class__.__name__.__eq__,       ["str"], true]
    - [hook_compressed, hook_compressed.__name__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# __name__ first-character checks — FileInput starts 'F', hook_compressed starts 'h'
# Distinct vector from equality or length checks; not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant fileinput_extra4.FileInput.name_starts_F:
  description: "fileinput.FileInput.__name__[0] == 'F' — class name begins with 'F'"
  category: name_prefix
  kind: python_call_eq
  function: FileInput.__name__.__getitem__
  args: [0]
  expected: "F"

invariant fileinput_extra4.hook_compressed.name_starts_h:
  description: "fileinput.hook_compressed.__name__[0] == 'h' — function name begins with 'h'"
  category: name_prefix
  kind: python_call_eq
  function: hook_compressed.__name__.__getitem__
  args: [0]
  expected: "h"

invariant fileinput_extra4.input.name_starts_i:
  description: "fileinput.input.__name__[0] == 'i' — function name begins with 'i'"
  category: name_prefix
  kind: python_call_eq
  function: input.__name__.__getitem__
  args: [0]
  expected: "i"

invariant fileinput_extra4.filename.name_starts_f:
  description: "fileinput.filename.__name__[0] == 'f' — function name begins with 'f'"
  category: name_prefix
  kind: python_call_eq
  function: filename.__name__.__getitem__
  args: [0]
  expected: "f"
