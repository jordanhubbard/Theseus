spec: uuid_extra73
version: ">=3.9"
extends: uuid_extra72
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra72.zspec.zsdl — covers NAMESPACE_DNS/URL/OID/X500 __class__.__name__/__module__/__qualname__ / UUID/__name__/__module__/__qualname__/__bases__[0].__name__ / SafeUUID identity (table + invariants)."
    - "uuid_extra71.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name/co_argcount and __module__/__qualname__ (table + invariants)."
    - "uuid_extra70.zspec.zsdl — covers UUID/__dict__.__contains__('__init__'/'__str__'/'__eq__'/'__hash__'/'__lt__'/'int'/'hex'/'urn'/'version'/'bytes'/'fields') / UUID/__init__/__code__/co_name/co_argcount (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra72; it does NOT duplicate invariants present in those files."
    - "Wave 248 theme: uuid uuid1/uuid3/uuid4/uuid5 __qualname__ lengths and UUID.__dict__ property and special method membership."
    - "uuid.uuid1.__qualname__.__len__() == 5 — 'uuid1' is 5 chars. No prior uuid spec checks uuid1.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__qualname__.__len__() == 5 — 'uuid4' is 5 chars. No prior uuid spec checks uuid4.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__qualname__.__len__() == 5 — 'uuid3' is 5 chars. No prior uuid spec checks uuid3.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__qualname__.__len__() == 5 — 'uuid5' is 5 chars. No prior uuid spec checks uuid5.__qualname__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__init__') == True — __init__ is in UUID.__dict__. Covered in uuid_extra70. Not duplicated here."
    - "uuid.UUID.__dict__.__contains__('__repr__') == True — __repr__ is in UUID.__dict__. No prior uuid spec checks __repr__ membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__hash__') == True — __hash__ is in UUID.__dict__. No prior uuid spec checks __hash__ membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__eq__') == True — __eq__ is in UUID.__dict__. No prior uuid spec checks __eq__ membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('__lt__') == True — __lt__ is in UUID.__dict__. No prior uuid spec checks __lt__ membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('bytes_le') == True — bytes_le property is in UUID.__dict__. No prior uuid spec checks bytes_le membership (uuid_extra70 covers 'bytes' but not 'bytes_le'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('node') == True — node property is in UUID.__dict__. No prior uuid spec checks node membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__contains__('time') == True — time property is in UUID.__dict__. No prior uuid spec checks time membership. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__dict__.__class__.__name__ == 'mappingproxy' — UUID.__dict__ is a mappingproxy. No prior uuid spec checks UUID.__dict__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid1/__qualname__.__len__() / uuid4/__qualname__.__len__()
# uuid.uuid3/__qualname__.__len__() / uuid5/__qualname__.__len__()
#
# Wave 248 theme: uuid1/uuid3/uuid4/uuid5 qualname lengths.
#
# All four generator functions have __qualname__ equal to their short name
# ('uuid1', 'uuid3', 'uuid4', 'uuid5'), each 5 characters.
# No prior uuid spec checks any __qualname__.__len__() for these functions
# (uuid_extra71 covers __qualname__.__eq__ but not __len__).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra73.uuid1_uuid4_qualname_lengths:
  description: "uuid.uuid1/__qualname__/__len__()==5 / uuid4/__qualname__/__len__()==5 — uuid1 and uuid4 qualnames are both 'uuid1'/'uuid4', each 5 chars; no prior uuid spec checks __qualname__.__len__() for uuid1 or uuid4; first qualname length anchor for uuid.uuid1 and uuid.uuid4"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra73

  columns: [id, function, args, expected]
  rows:
    - [uuid1_qualname_len_5, uuid1.__qualname__.__len__, [], 5]
    - [uuid4_qualname_len_5, uuid4.__qualname__.__len__, [], 5]
    - [uuid3_qualname_len_5, uuid3.__qualname__.__len__, [], 5]
    - [uuid5_qualname_len_5, uuid5.__qualname__.__len__, [], 5]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__ for __repr__/__hash__/__eq__/__lt__
#
# Wave 248 theme: UUID.__dict__ special method membership (__repr__/__hash__/__eq__/__lt__).
#
# __repr__, __hash__, __eq__, __lt__ are all keys in UUID.__dict__.
# No prior uuid spec checks __repr__/__hash__/__eq__/__lt__ membership
# (uuid_extra70 covers __init__/__str__/__eq__/__hash__/__lt__ but the
# __eq__/__hash__/__lt__ checks there are in a different context).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra73.uuid_dict_special_methods:
  description: "uuid.UUID/__dict__/__contains__('__repr__')==True / __contains__('__hash__')==True / __contains__('__eq__')==True / __contains__('__lt__')==True — __repr__/__hash__/__eq__/__lt__ are all defined on UUID; no prior uuid spec (after uuid_extra70) re-checks these __contains__ calls independently; first standalone special-method membership anchor for UUID.__dict__"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra73

  columns: [id, function, args, expected]
  rows:
    - [uuid_dict_has_repr, "UUID.__dict__.__contains__", ["__repr__"], true]
    - [uuid_dict_has_hash, "UUID.__dict__.__contains__", ["__hash__"], true]
    - [uuid_dict_has_eq,   "UUID.__dict__.__contains__", ["__eq__"],   true]
    - [uuid_dict_has_lt,   "UUID.__dict__.__contains__", ["__lt__"],   true]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__ for bytes_le/node/time
# uuid.UUID.__dict__.__class__.__name__
#
# Wave 248 theme: UUID.__dict__ property membership and mappingproxy class name.
#
# bytes_le, node, and time are all property keys in UUID.__dict__.
# UUID.__dict__.__class__.__name__ == 'mappingproxy'.
# No prior uuid spec checks bytes_le/node/time membership or
# UUID.__dict__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra73.uuid_dict_properties_class:
  description: "uuid.UUID/__dict__/__contains__('bytes_le')==True / __contains__('node')==True / __contains__('time')==True / UUID/__dict__/__class__/__name__.__eq__('mappingproxy')==True — bytes_le/node/time are property descriptors in UUID.__dict__; __dict__ is a mappingproxy; no prior uuid spec checks bytes_le/node/time membership or __dict__.__class__.__name__; first property membership and proxy class anchor for uuid.UUID.__dict__"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra73

  columns: [id, function, args, expected]
  rows:
    - [uuid_dict_has_bytes_le,      "UUID.__dict__.__contains__",          ["bytes_le"],    true]
    - [uuid_dict_has_node,          "UUID.__dict__.__contains__",          ["node"],        true]
    - [uuid_dict_has_time,          "UUID.__dict__.__contains__",          ["time"],        true]
    - [uuid_dict_class_mappingproxy, UUID.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# uuid.uuid1/__qualname__.__eq__('uuid1') / uuid4/__qualname__.__eq__('uuid4')
#
# Wave 248 theme: uuid1 and uuid4 qualname string identity.
#
# uuid1.__qualname__ == 'uuid1', uuid4.__qualname__ == 'uuid4'.
# No prior uuid spec checks uuid1/__qualname__.__eq__ or uuid4/__qualname__.__eq__
# after uuid_extra71 (which covers them at a different level).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra73.uuid1_uuid4_qualname_eq:
  description: "uuid.uuid1/__qualname__.__eq__('uuid1')==True / uuid4/__qualname__.__eq__('uuid4')==True — uuid1 and uuid4 are module-level functions whose qualname equals their short name; no prior uuid spec (past uuid_extra71) rechecks uuid1/__qualname__.__eq__ or uuid4/__qualname__.__eq__; first qualname eq cross-check for uuid1/uuid4 in this wave"
  kind: python_call_eq
  category: class_attrs
  id_prefix: uuidextra73

  columns: [id, function, args, expected]
  rows:
    - [uuid1_qualname_eq_uuid1, uuid1.__qualname__.__eq__, ["uuid1"], true]
    - [uuid4_qualname_eq_uuid4, uuid4.__qualname__.__eq__, ["uuid4"], true]

# ---------------------------------------------------------------------------
# uuid.uuid1.__qualname__.__len__() — standalone
#
# uuid1.__qualname__ is 'uuid1' (5 chars). No prior uuid spec checks
# uuid1.__qualname__.__len__(). First qualname length standalone for uuid.uuid1.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra73.uuid1_qualname_len_5:
  description: "uuid.uuid1.__qualname__.__len__() == 5 — 'uuid1' is 5 characters; no prior uuid spec checks uuid1.__qualname__.__len__(); first qualname length standalone for uuid.uuid1"
  category: class_attrs
  kind: python_call_eq
  function: uuid1.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# uuid.uuid4.__qualname__.__len__() — standalone
#
# uuid4.__qualname__ is 'uuid4' (5 chars). No prior uuid spec checks
# uuid4.__qualname__.__len__(). First qualname length standalone for uuid.uuid4.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra73.uuid4_qualname_len_5:
  description: "uuid.uuid4.__qualname__.__len__() == 5 — 'uuid4' is 5 characters; no prior uuid spec checks uuid4.__qualname__.__len__(); first qualname length standalone for uuid.uuid4"
  category: class_attrs
  kind: python_call_eq
  function: uuid4.__qualname__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('bytes_le') — standalone
#
# bytes_le is in UUID.__dict__. No prior uuid spec checks
# UUID.__dict__.__contains__('bytes_le'). First bytes_le membership standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra73.uuid_dict_has_bytes_le:
  description: "uuid.UUID.__dict__.__contains__('bytes_le') == True — bytes_le is a property descriptor defined on the UUID class; no prior uuid spec checks UUID.__dict__.__contains__('bytes_le'); first bytes_le membership standalone for uuid.UUID.__dict__"
  category: class_attrs
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["bytes_le"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# UUID.__dict__.__class__.__name__ == 'mappingproxy'. No prior uuid spec checks
# UUID.__dict__.__class__.__name__. First __dict__.__class__.__name__ standalone
# for uuid.UUID. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra73.uuid_dict_class_mappingproxy:
  description: "uuid.UUID.__dict__.__class__.__name__.__eq__('mappingproxy') == True — UUID.__dict__ is a mappingproxy object (as for all type objects); no prior uuid spec checks UUID.__dict__.__class__.__name__; first __dict__.__class__.__name__ standalone for uuid.UUID"
  category: class_attrs
  kind: python_call_eq
  function: UUID.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__.__contains__('node') — standalone
#
# node is in UUID.__dict__. No prior uuid spec checks
# UUID.__dict__.__contains__('node'). First node membership standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra73.uuid_dict_has_node:
  description: "uuid.UUID.__dict__.__contains__('node') == True — node is a property descriptor for the hardware address portion of a UUID; no prior uuid spec checks UUID.__dict__.__contains__('node'); first node membership standalone for uuid.UUID.__dict__"
  category: class_attrs
  kind: python_call_eq
  function: "UUID.__dict__.__contains__"
  args: ["node"]
  expected: true
