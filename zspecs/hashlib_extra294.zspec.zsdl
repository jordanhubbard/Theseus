spec: hashlib_extra294
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "hashlib.md5(b'hello').hexdigest() == '5d41402abc4b2a76b9719d911017c592' — RFC 1321 test vector."
    - "hashlib.sha256(b'').hexdigest() is the well-known SHA-256 hash of the empty string."
    - "hexdigest() always returns exactly 2*digest_size hex characters."
    - "MD5 digest_size == 16 bytes (128 bits); SHA-256 digest_size == 32 bytes (256 bits)."
    - "SHA-256 block_size == 64 bytes (512-bit block)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "hashlib raises ValueError for unknown algorithm names."
  stderr: "null"
  stickiness: "N/A — hash objects are independent; results are deterministic for fixed inputs."
  codes: {}

# ---------------------------------------------------------------------------
# MD5 — known test vector for b'hello'
# ---------------------------------------------------------------------------

invariant hashlib_extra294.md5.hexdigest_hello:
  description: "hashlib.md5(b'hello').hexdigest() == '5d41402abc4b2a76b9719d911017c592'"
  category: hash_vectors
  kind: python_call_eq
  function: md5
  args: ["hello"]
  method: hexdigest.__eq__
  method_args: ["5d41402abc4b2a76b9719d911017c592"]
  expected: true

invariant hashlib_extra294.md5.digest_size:
  description: "hashlib.md5(b'hello').digest_size == 16 (128-bit MD5 output)"
  category: properties
  kind: python_call_eq
  function: md5
  args: ["hello"]
  method: digest_size.__eq__
  method_args: [16]
  expected: true

# ---------------------------------------------------------------------------
# SHA-256 — empty-string test vector and properties
# ---------------------------------------------------------------------------

invariant hashlib_extra294.sha256.hexdigest_empty:
  description: "hashlib.sha256(b'').hexdigest() == 'e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855'"
  category: hash_vectors
  kind: python_call_eq
  function: sha256
  args: [""]
  method: hexdigest.__eq__
  method_args: ["e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"]
  expected: true

invariant hashlib_extra294.sha256.hexdigest_length:
  description: "hashlib.sha256(b'hello').hexdigest().__len__() == 64 (32 bytes * 2 hex chars each)"
  category: properties
  kind: python_call_eq
  function: sha256
  args: ["hello"]
  method: hexdigest.__len__
  method_args: []
  expected: 64

invariant hashlib_extra294.sha256.digest_size:
  description: "hashlib.sha256(b'hello').digest_size == 32 (256-bit SHA-256 output)"
  category: properties
  kind: python_call_eq
  function: sha256
  args: ["hello"]
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra294.sha256.block_size:
  description: "hashlib.sha256(b'hello').block_size == 64 (512-bit block size)"
  category: properties
  kind: python_call_eq
  function: sha256
  args: ["hello"]
  method: block_size.__eq__
  method_args: [64]
  expected: true
