spec: pathlib_extra52
version: ">=3.13"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra51.zspec.zsdl — covers PurePath.suffixes.fget.__qualname__.__len__()==17; PurePath.with_segments.__qualname__.__len__()==22; Path.info.fget.__qualname__.__len__()==9; UnsupportedOperation.__qualname__.__len__()==20."
    - "pathlib_extra50.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__len__(); Path.cwd(8)/Path.home(9) __qualname__.__len__()."
    - "pathlib_extra47.zspec.zsdl — covers Path.cwd(8)/Path.home(9)/Path.stat(9)/Path.exists(11)/Path.is_file(12)/Path.is_dir(11)/Path.open(9)/Path.read_text(14)/Path.write_text(15) __qualname__.__len__()."
    - "pathlib_extra44.zspec.zsdl — covers PurePath.full_match.__qualname__.__len__()==19; Path.readlink.__qualname__.__len__()==13."
    - "pathlib_extra42.zspec.zsdl — covers PurePath.__eq__(15)/__lt__(15)/__hash__(17)/__repr__(17)/__bytes__(18)/__rtruediv__(21) __qualname__.__len__(); PurePath.as_uri.__qualname__.__len__()==15."
    - "pathlib_extra41.zspec.zsdl — covers PurePath.with_stem(18) __qualname__.__len__(); PurePath property fget lengths for drive(14)/root(13)/anchor(15)/parents(16)."
    - "pathlib_extra39.zspec.zsdl — covers PurePath method/property lengths: is_relative_to(23)/relative_to(20)/match(14); PurePath fget name(13)/parent(15)/suffix(15)/stem(13)/parts(14)."
    - "pathlib_extra38.zspec.zsdl — covers PurePath.joinpath(17)/with_name(18)/with_suffix(20)/as_posix(17) __qualname__.__len__()."
    - "pathlib_extra37.zspec.zsdl — covers Path.iterdir(12)/glob(9)/rglob(10)/resolve(12) __qualname__.__len__()."
  notes:
    - "This spec extends pathlib_extra51.zspec.zsdl."
    - "VERSION NOTE: Path.walk() was added in Python 3.12. Path.from_uri() was added in Python 3.13. This spec targets Python >= 3.13."
    - "Prior specs collectively covered: all six pathlib class __qualname__.__len__() and __qualname__.__eq__(); all PurePath property fget __qualname__.__len__() for name/parent/stem/suffix/parts/drive/root/anchor/parents/suffixes; all major PurePath method __qualname__.__len__(); all major Path method __qualname__.__len__() including glob/rglob/iterdir/resolve/rename/unlink/rmdir/chmod/symlink_to/read_text/write_text/read_bytes/write_bytes/stat/exists/is_file/is_dir/open; PurePath dunder __qualname__.__len__() for __eq__/__lt__/__hash__/__repr__/__bytes__/__rtruediv__. No prior pathlib spec covers Path.walk.__qualname__.__len__() or PurePath.__truediv__.__qualname__.__len__() or Path.from_uri.__qualname__.__len__()."
    - "This spec covers: pathlib.Path.walk.__qualname__.__len__()==9 (NOVEL — Path.walk() was added in Python 3.12 for recursive directory traversal; pathlib_extra37 covers iterdir/glob/rglob/resolve but NOT walk; no prior pathlib spec checks Path.walk.__qualname__.__len__(); novel); pathlib.PurePath.__truediv__.__qualname__.__len__()==20 (NOVEL — pathlib_extra42 covers PurePath.__rtruediv__.__qualname__.__len__()==21 but NOT __truediv__; the '/' operator giving __truediv__ has 20 chars vs __rtruediv__ at 21; no prior pathlib spec checks __truediv__.__qualname__.__len__(); novel); pathlib.Path.from_uri.__qualname__.__len__()==13 (NOVEL — Path.from_uri() added in Python 3.13 creates a Path from a file:// URI; pathlib_extra44 covers Path.readlink.__qualname__.__len__()==13 (same length); no prior pathlib spec covers Path.from_uri at all; novel)."
    - "pathlib.Path.walk.__qualname__ == 'Path.walk' — 9 characters. Path.walk() was added in Python 3.12 for os.walk()-style recursive directory traversal. pathlib_extra37 covers iterdir(12)/glob(9)/rglob(10)/resolve(12) qualname lengths but not walk. No prior pathlib spec checks Path.walk.__qualname__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__truediv__.__qualname__ == 'PurePath.__truediv__' — 20 characters. This is the '/' operator for path joining (e.g., PurePath('/etc') / 'init.d'). pathlib_extra42 covers __rtruediv__.__qualname__.__len__()==21 but not __truediv__. No prior pathlib spec checks PurePath.__truediv__.__qualname__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.from_uri.__qualname__ == 'Path.from_uri' — 13 characters. Path.from_uri() was added in Python 3.13 to construct a Path from a file:// URI string (e.g., Path.from_uri('file:///etc/hosts')). No prior pathlib spec covers Path.from_uri at all. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.walk.__qualname__.__len__()
#
# Path.walk() was added in Python 3.12 as an object-oriented equivalent of
# os.walk(). It yields (dirpath, dirnames, filenames) tuples for recursive
# directory traversal. Its __qualname__ follows the standard class.method
# pattern:
#
#   Path.walk.__qualname__ == 'Path.walk'   -> len 9
#
# pathlib_extra37 covers Path.iterdir(12)/glob(9)/rglob(10)/resolve(12)
# __qualname__.__len__() in a table, but does NOT include walk.
# No prior pathlib spec checks Path.walk.__qualname__.__len__().
# NOVEL in pathlib_extra52 namespace. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra52.Path_walk_qualname_len:
  description: "pathlib.Path.walk.__qualname__.__len__() == 9 — 'Path.walk' has 9 characters; Path.walk added in Python 3.12 for os.walk()-style traversal; pathlib_extra37 covers iterdir/glob/rglob/resolve but NOT walk; novel in pathlib_extra52 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: Path.walk.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# pathlib.PurePath.__truediv__.__qualname__.__len__()
#
# PurePath.__truediv__ implements the '/' operator for path joining:
#   PurePath('/etc') / 'init.d'  ->  PurePath('/etc/init.d')
#
# Its __qualname__ follows the standard class.dunder pattern:
#
#   PurePath.__truediv__.__qualname__ == 'PurePath.__truediv__'  -> len 20
#
# pathlib_extra42 covers PurePath.__rtruediv__.__qualname__.__len__()==21
# (the reverse operator, one char longer), but does NOT cover __truediv__.
# No prior pathlib spec checks PurePath.__truediv__.__qualname__.__len__().
# NOVEL in pathlib_extra52 namespace. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra52.PurePath_truediv_qualname_len:
  description: "pathlib.PurePath.__truediv__.__qualname__.__len__() == 20 — 'PurePath.__truediv__' has 20 characters; this is the '/' operator for path joining; pathlib_extra42 covers __rtruediv__(21) but NOT __truediv__(20); novel in pathlib_extra52 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: PurePath.__truediv__.__qualname__.__len__
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# pathlib.Path.from_uri.__qualname__.__len__()
#
# Path.from_uri() was added in Python 3.13 to create a Path object from a
# file:// URI string. For example:
#   Path.from_uri('file:///etc/hosts')  ->  PosixPath('/etc/hosts')
#
# Its __qualname__ follows the standard class.method pattern:
#
#   Path.from_uri.__qualname__ == 'Path.from_uri'  -> len 13
#
# pathlib_extra44 covers Path.readlink.__qualname__.__len__()==13 (same
# length, different method). No prior pathlib spec covers Path.from_uri
# at all — it is new in Python 3.13.
# NOVEL in pathlib_extra52 namespace. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra52.Path_from_uri_qualname_len:
  description: "pathlib.Path.from_uri.__qualname__.__len__() == 13 — 'Path.from_uri' has 13 characters; Path.from_uri added in Python 3.13 to create Path from file:// URI; no prior pathlib spec covers Path.from_uri; novel in pathlib_extra52 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: Path.from_uri.__qualname__.__len__
  args: []
  expected: 13
