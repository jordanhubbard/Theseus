spec: theseus_errno_cr
version: ">=3.8"
backend: python_cleanroom(theseus_errno_cr)
blocks: errno

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/errno.html"
  not_derived_from:
    - "CPython source: Lib/errno.py"
  notes:
    - "Clean-room errno module. Do NOT import errno."

error_model: python_exceptions

invariant theseus_errno_cr.errno2_enoent:
  description: "ENOENT is defined with correct value 2"
  category: constants
  kind: python_call_eq
  function: errno2_enoent
  args: []
  expected: true

invariant theseus_errno_cr.errno2_eacces:
  description: "EACCES is defined"
  category: constants
  kind: python_call_eq
  function: errno2_eacces
  args: []
  expected: true

invariant theseus_errno_cr.errno2_errorcode:
  description: "errorcode maps integer to symbolic name"
  category: behavior
  kind: python_call_eq
  function: errno2_errorcode
  args: []
  expected: true
