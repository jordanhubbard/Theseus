spec: io_extra165
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.RawIOBase and io.FileIO class identity attributes, plus io.DEFAULT_BUFFER_SIZE."
    - "A key discovery: io.RawIOBase.__module__ == 'io' (the public module), while io.FileIO.__module__ == '_io' (the private C extension module). This asymmetry reveals that RawIOBase is re-exported from the public 'io' namespace, but FileIO is a C-level type whose __module__ reflects its C origin in '_io'."
    - "io.RawIOBase.__name__ == 'RawIOBase' (len=9); io.RawIOBase.__module__ == 'io' (len=2); io.RawIOBase.__bases__[0].__name__ == '_RawIOBase'."
    - "io.FileIO.__name__ == 'FileIO' (len=6); io.FileIO.__module__ == '_io' (len=3); io.FileIO.__bases__[0].__name__ == '_RawIOBase'."
    - "Both RawIOBase and FileIO share the same __bases__[0].__name__ == '_RawIOBase'. This private C type '_RawIOBase' is the common C-level base for both the abstract RawIOBase and the concrete FileIO."
    - "io.DEFAULT_BUFFER_SIZE == 131072 (128 KiB = 128 * 1024); type is int."
    - "DEFAULT_BUFFER_SIZE of 131072 is used by BufferedReader and BufferedWriter as the default buffer size for the internal buffer."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.RawIOBase class identity attributes
# __name__ = 'RawIOBase' (len=9), __module__ = 'io' (len=2)
# __bases__[0].__name__ = '_RawIOBase' (private C base)
# RawIOBase is the abstract base for all raw I/O implementations.
# ---------------------------------------------------------------------------

table io_extra165.RawIOBase_class_identity:
  description: "io.RawIOBase class identity: __name__='RawIOBase' (len=9), __module__='io' (len=2), __bases__[0].__name__='_RawIOBase'; RawIOBase is an abstract raw I/O base class"
  kind: python_call_eq
  category: identity
  id_prefix: rawio165

  columns: [id, function, args, expected, description]
  rows:
    - [rawio_name,     RawIOBase.__name__.__eq__,                  ["RawIOBase"],   true, "io.RawIOBase.__name__ == 'RawIOBase' (RawIOBase is the abstract base class for raw binary I/O; raw I/O provides no buffering and is the lowest level in the io hierarchy; 'RawIOBase' has 9 characters; RawIOBase defines the interface for read(), readinto(), and write() at the raw (unbuffered) level; the public class name is 'RawIOBase' — no underscore prefix despite being an abstract class)"]
    - [rawio_mod,      RawIOBase.__module__.__eq__,                 ["io"],          true, "io.RawIOBase.__module__ == 'io' (the public module name; contrast with io.FileIO.__module__ == '_io' — the private C extension module; RawIOBase.__module__ is 'io' because it is re-exported through the public Python-level 'io' namespace, even though its C implementation lives in '_io'; 'io' has 2 characters — the shortest possible module name in this io spec)"]
    - [rawio_base0,    "RawIOBase.__bases__[0].__name__.__eq__",    ["_RawIOBase"],  true, "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' (the first base class of RawIOBase is the private C type '_RawIOBase' in the '_io' extension module; this reveals the two-layer structure: the public Python 'RawIOBase' wraps the private C '_RawIOBase'; '_RawIOBase' has 10 characters including the leading underscore; the same '_RawIOBase' is also the base of FileIO, making _RawIOBase the shared C foundation for both abstract and concrete raw I/O classes)"]
    - [rawio_name_len, RawIOBase.__name__.__len__,                  [],              9,    "io.RawIOBase.__name__.__len__() == 9 ('RawIOBase' has 9 characters: 'Raw' (3) + 'IO' (2) + 'Base' (4) = 9; the name encodes the class role — 'Raw' signals no buffering, 'IO' signals I/O capability, 'Base' signals abstract base; compare with 'FileIO' (6 chars) which drops the 'Base' suffix and adds 'File' to signal a concrete implementation; RawIOBase.__name__ length of 9 matches Path.stat.__qualname__ length of 9 established in pathlib_extra165)"]

# ---------------------------------------------------------------------------
# io.FileIO class identity attributes
# __name__ = 'FileIO' (len=6), __module__ = '_io' (len=3)
# __bases__[0].__name__ = '_RawIOBase' — same as RawIOBase's first base.
# FileIO is the concrete raw I/O implementation for file descriptors.
# ---------------------------------------------------------------------------

table io_extra165.FileIO_class_identity:
  description: "io.FileIO class identity: __name__='FileIO' (len=6), __module__='_io' (len=3), __bases__[0].__name__='_RawIOBase'; FileIO is the concrete raw I/O class for file descriptors"
  kind: python_call_eq
  category: identity
  id_prefix: fileio165

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_name,     FileIO.__name__.__eq__,                  ["FileIO"],      true, "io.FileIO.__name__ == 'FileIO' (FileIO is the concrete implementation of raw binary file I/O; it opens a file descriptor and exposes raw read/write operations without buffering; 'FileIO' has 6 characters: 'File' (4) + 'IO' (2) = 6; shorter than 'RawIOBase' (9) because FileIO is concrete (no 'Base' suffix) and specialized (adds 'File' instead of 'Raw'); FileIO is what open() uses internally in raw mode)"]
    - [fileio_mod,      FileIO.__module__.__eq__,                ["_io"],         true, "io.FileIO.__module__ == '_io' (the private C extension module; this is the key asymmetry: RawIOBase.__module__ == 'io' while FileIO.__module__ == '_io'; FileIO is a C-level type and its __module__ reflects the C extension '_io' rather than the public Python wrapper 'io'; '_io' has 3 characters — one more than 'io' (2) due to the leading underscore; code accessing io.FileIO through the 'io' module still works because 'io' imports and re-exports FileIO from '_io')"]
    - [fileio_base0,    "FileIO.__bases__[0].__name__.__eq__",   ["_RawIOBase"],  true, "io.FileIO.__bases__[0].__name__ == '_RawIOBase' (FileIO's first base is the same private C type '_RawIOBase' that is also RawIOBase's first base; this shared C base '_RawIOBase' creates the common abstract interface for all raw I/O in CPython; FileIO is more specialized than RawIOBase — it provides a concrete implementation with an actual file descriptor, while RawIOBase is the abstract interface; '_RawIOBase' (10 chars) is 4 chars longer than 'FileIO' (6 chars))"]
    - [fileio_name_len, FileIO.__name__.__len__,                 [],              6,    "io.FileIO.__name__.__len__() == 6 ('FileIO' has 6 characters: 'File' (4) + 'IO' (2) = 6; the shortest class name among the io classes covered in this spec; compare with RawIOBase (9), _RawIOBase (10); the absence of a 'Base' suffix and the use of 'File' (4 chars) instead of 'Raw' (3 chars) keeps FileIO at 6; FileIO.__name__ length of 6 is the same as Path.lstat.__qualname__ length of 10... wait — both io.FileIO.__name__ (6) and pathlib.Path.open.__qualname__ (9) are short identifiers in their respective module contexts)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra165.RawIOBase_module_is_public_io:
  description: "io.RawIOBase.__module__ == 'io' — RawIOBase's __module__ is the public 'io' namespace (not '_io'); this contrasts with io.FileIO.__module__ == '_io' which reveals the C extension origin; RawIOBase is abstract and is re-exported through the public 'io' module, giving it a public module name; 'io' has 2 characters, the shortest module name in this spec; this public vs private module asymmetry between RawIOBase and FileIO is a defining identity fact about the io module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: RawIOBase.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra165.FileIO_module_is_private_io:
  description: "io.FileIO.__module__ == '_io' — FileIO's __module__ is the private C extension '_io', not the public 'io' wrapper; this is the key asymmetry: abstract RawIOBase has __module__='io' while concrete FileIO has __module__='_io'; '_io' has 3 characters — one more than 'io' due to the leading underscore; the '_io' C extension provides the actual implementation of Python's I/O system; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: FileIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra165.RawIOBase_and_FileIO_share_base_RawIOBase:
  description: "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' — both RawIOBase and FileIO share the same first base class name '_RawIOBase'; this private C type is the common foundation of all raw I/O in CPython; '_RawIOBase' has 10 characters: '_' (1) + 'RawIOBase' (9) = 10; the shared C base '_RawIOBase' defines the raw I/O protocol at the C level, while the Python-level RawIOBase and FileIO add Python-visible behavior; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "RawIOBase.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra165.DEFAULT_BUFFER_SIZE_is_131072:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 — the default buffer size used by BufferedReader and BufferedWriter is 131072 bytes (128 KiB = 128 * 1024); the value is an int; this constant is defined in the '_io' C extension and exported through the public 'io' module; 131072 bytes is chosen as a practical trade-off between memory usage and I/O efficiency for buffered I/O; 8192 (8 KiB) would be too small for many modern workloads; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

