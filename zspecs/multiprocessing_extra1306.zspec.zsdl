spec: multiprocessing_extra1306
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for bad argument types and values."
    - "multiprocessing.Semaphore(-1) raises OSError (EINVAL) — negative initial value rejected by OS semaphore."
    - "multiprocessing.Semaphore('a') raises TypeError — 'str' object cannot be interpreted as an integer."
    - "multiprocessing.BoundedSemaphore(-1) raises OSError (EINVAL) — negative initial value rejected by OS semaphore."
    - "multiprocessing.BoundedSemaphore('a') raises TypeError — 'str' object cannot be interpreted as an integer."
    - "multiprocessing.Queue('a') raises TypeError — '<=' not supported between instances of 'str' and 'int'."
    - "multiprocessing.Pool(processes=-1) raises ValueError — Number of processes must be at least 1."
    - "multiprocessing.Pool(processes=0) raises ValueError — Number of processes must be at least 1."
    - "multiprocessing.Pool(processes='a') raises TypeError — '<' not supported between instances of 'str' and 'int'."
    - "multiprocessing.Value('x', 0) raises TypeError — 'x' is not a valid ctypes type code."
    - "multiprocessing.Array('x', 0) raises TypeError — 'x' is not a valid ctypes type code."
    - "multiprocessing.RLock(42) raises TypeError — BaseContext.RLock() takes 1 positional argument but 2 were given."
    - "multiprocessing.Lock(42) raises TypeError — BaseContext.Lock() takes 1 positional argument but 2 were given."
    - "multiprocessing.Event(42) raises TypeError — BaseContext.Event() takes 1 positional argument but 2 were given."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra1306.semaphore_errors:
  description: "multiprocessing.Semaphore and BoundedSemaphore raise OSError for negative values and TypeError for non-integer arguments"
  kind: python_call_raises
  category: constructor_errors
  id_prefix: mp1306se
  columns: [id, function, args, exception]
  rows:
    - [mp1306se001, multiprocessing.Semaphore,        [-1],  "OSError"]
    - [mp1306se002, multiprocessing.Semaphore,        [-2],  "OSError"]
    - [mp1306se003, multiprocessing.Semaphore,        ["a"], "TypeError"]
    - [mp1306se004, multiprocessing.BoundedSemaphore, [-1],  "OSError"]
    - [mp1306se005, multiprocessing.BoundedSemaphore, [-5],  "OSError"]
    - [mp1306se006, multiprocessing.BoundedSemaphore, ["a"], "TypeError"]

table multiprocessing_extra1306.pool_errors:
  description: "multiprocessing.Pool raises ValueError for non-positive process counts and TypeError for non-integer process counts"
  kind: python_call_raises
  category: constructor_errors
  id_prefix: mp1306po
  columns: [id, function, args, exception]
  rows:
    - [mp1306po001, multiprocessing.Pool, [{processes: -1}], "ValueError"]
    - [mp1306po002, multiprocessing.Pool, [{processes: 0}],  "ValueError"]
    - [mp1306po003, multiprocessing.Pool, [{processes: -10}],"ValueError"]
    - [mp1306po004, multiprocessing.Pool, [{processes: "a"}],"TypeError"]
    - [mp1306po005, multiprocessing.Pool, [{processes: "1"}],"TypeError"]
    - [mp1306po006, multiprocessing.Pool, [{processes: []}], "TypeError"]

table multiprocessing_extra1306.primitive_type_errors:
  description: "multiprocessing primitives raise TypeError for wrong argument types: Queue, Lock, RLock, Event reject bad args; Value and Array reject invalid type codes"
  kind: python_call_raises
  category: type_errors
  id_prefix: mp1306pt
  columns: [id, function, args, exception]
  rows:
    - [mp1306pt001, multiprocessing.Queue, ["a"],      "TypeError"]
    - [mp1306pt002, multiprocessing.Lock,  [42],       "TypeError"]
    - [mp1306pt003, multiprocessing.RLock, [42],       "TypeError"]
    - [mp1306pt004, multiprocessing.Event, [42],       "TypeError"]
    - [mp1306pt005, multiprocessing.Value, ["x", 0],   "TypeError"]
    - [mp1306pt006, multiprocessing.Array, ["x", 0],   "TypeError"]
