spec: abc_extra139
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers: abc.ABC.__subclasshook__ — __qualname__=='ABC.__subclasshook__' (len=20); __doc__.__len__()==308 (multi-paragraph doc about customizing issubclass). abc.ABC.__init_subclass__ — __qualname__=='ABC.__init_subclass__' (len=21); __doc__.__len__()==135 (describes the method called when a class is subclassed). abc.ABC.__bases__[0].__name__=='object' (len=6: ABC inherits directly from object). abc.ABCMeta.__bases__[0].__name__=='type' (len=4: ABCMeta inherits directly from type, making it a metaclass). abc.ABCMeta.__new__.__code__.co_varnames.__len__()==6 ('mcls','name','bases','namespace','kwargs','cls'). abc.ABCMeta._dump_registry.__code__.co_varnames.__len__()==6 ('cls','file','_abc_registry','_abc_cache','_abc_negative_cache','_abc_negative_cache_version'). abc.ABCMeta._abc_registry_clear.__code__.co_argcount==1 ('cls' only). abc.ABCMeta._abc_caches_clear.__code__.co_argcount==1 ('cls' only). abc.ABCMeta.register.__code__.co_consts.__len__()==1 (only the docstring — no True constant because register delegates to _abc). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__subclasshook__ and abc.ABC.__init_subclass__ are built-in methods (type 'builtin_function_or_method') so they have no __code__ attribute; qualname and __doc__ are accessible. ABC.__bases__[0].__name__=='object' (len=6) while ABCMeta.__bases__[0].__name__=='type' (len=4); these reveal the inheritance structure: ABC is a plain class with metaclass ABCMeta, while ABCMeta itself is a subclass of type. ABCMeta.register.__code__.co_consts.__len__()==1 (only the docstring; no True constant because the register implementation delegates to _abc.register rather than directly setting __isabstractmethod__). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC.__subclasshook__ and __init_subclass__ — extra139
#
# abc.ABC.__subclasshook__.__qualname__    == 'ABC.__subclasshook__'   (len=20)
# abc.ABC.__subclasshook__.__doc__.__len__() == 308
# abc.ABC.__init_subclass__.__qualname__   == 'ABC.__init_subclass__'  (len=21)
# abc.ABC.__init_subclass__.__doc__.__len__() == 135
# ---------------------------------------------------------------------------

table abc_extra139.abc_subclasshook_init_subclass:
  description: "abc.ABC.__subclasshook__ and __init_subclass__ qualname and doc checks — __subclasshook__.__qualname__.__eq__('ABC.__subclasshook__')==True (len=20: 'ABC'=3+'.'=1+'__subclasshook__'=16=20); __subclasshook__.__doc__.__len__()==308 (multi-paragraph doc beginning 'Abstract classes can override this to customize issubclass().' and describing the three possible return values: True, False, NotImplemented); __init_subclass__.__qualname__.__eq__('ABC.__init_subclass__')==True (len=21: 'ABC'=3+'.'=1+'__init_subclass__'=17=21, the longest of the two; 1 more than __subclasshook__); __init_subclass__.__doc__.__len__()==135 (doc beginning 'This method is called when a class is subclassed.' with note that the default does nothing); both are built-in methods (type 'builtin_function_or_method') — no __code__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcsubhook139

  columns: [id, function, args, expected, description]
  rows:
    - [sh_qn_eq,   abc.ABC.__subclasshook__.__qualname__.__eq__,   ["ABC.__subclasshook__"],   true,  "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (len=20); verified with Python 3.14.3"]
    - [sh_qn_len,  abc.ABC.__subclasshook__.__qualname__.__len__,   [],                         20,    "abc.ABC.__subclasshook__.__qualname__.__len__() == 20; verified with Python 3.14.3"]
    - [sh_doc_len, abc.ABC.__subclasshook__.__doc__.__len__,        [],                         308,   "abc.ABC.__subclasshook__.__doc__.__len__() == 308; verified with Python 3.14.3"]
    - [is_qn_eq,   abc.ABC.__init_subclass__.__qualname__.__eq__,  ["ABC.__init_subclass__"],   true,  "abc.ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' (len=21); verified with Python 3.14.3"]
    - [is_qn_len,  abc.ABC.__init_subclass__.__qualname__.__len__,  [],                         21,    "abc.ABC.__init_subclass__.__qualname__.__len__() == 21; verified with Python 3.14.3"]
    - [is_doc_len, abc.ABC.__init_subclass__.__doc__.__len__,       [],                         135,   "abc.ABC.__init_subclass__.__doc__.__len__() == 135; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC and abc.ABCMeta base class names — extra139
#
# abc.ABC.__bases__[0].__name__     == 'object' (len=6)
# abc.ABCMeta.__bases__[0].__name__ == 'type'   (len=4)
# ---------------------------------------------------------------------------

table abc_extra139.abc_abcmeta_bases:
  description: "abc.ABC and abc.ABCMeta base class name checks — ABC.__bases__[0].__name__ values reveal the class hierarchy: ABC inherits from object (the root of all Python classes, len=6); ABCMeta inherits from type (the root metaclass, len=4: 'type'=4, 2 shorter than 'object'=6); this hierarchy means ABCMeta is a metaclass (subclass of type) that installs itself as the metaclass of ABC; any class that inherits from ABC will have ABCMeta as its metaclass; the relationship between ABC.__bases__[0] ('object') and ABCMeta.__bases__[0] ('type') mirrors the relationship between regular classes and metaclasses in Python's object model; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcbases139

  columns: [id, function, args, expected, description]
  rows:
    - [abc_base_eq,      "abc.ABC.__bases__[0].__name__.__eq__",       ["object"],  true,  "abc.ABC.__bases__[0].__name__ == 'object' (len=6); verified with Python 3.14.3"]
    - [abc_base_len,     "abc.ABC.__bases__[0].__name__.__len__",       [],          6,     "abc.ABC.__bases__[0].__name__.__len__() == 6 ('object'); verified with Python 3.14.3"]
    - [meta_base_eq,     "abc.ABCMeta.__bases__[0].__name__.__eq__",   ["type"],    true,  "abc.ABCMeta.__bases__[0].__name__ == 'type' (len=4); verified with Python 3.14.3"]
    - [meta_base_len,    "abc.ABCMeta.__bases__[0].__name__.__len__",   [],          4,     "abc.ABCMeta.__bases__[0].__name__.__len__() == 4 ('type'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__new__ and internal method code introspection — extra139
#
# ABCMeta.__new__.__code__.co_varnames len     == 6
# ABCMeta._dump_registry.__code__.co_varnames len == 6
# ABCMeta._abc_registry_clear co_argcount      == 1
# ABCMeta._abc_caches_clear co_argcount        == 1
# ABCMeta.register.__code__.co_consts len      == 1
# ---------------------------------------------------------------------------

table abc_extra139.abcmeta_code_introspection:
  description: "abc.ABCMeta internal method code introspection — ABCMeta.__new__.__code__.co_varnames.__len__()==6 ('mcls','name','bases','namespace','kwargs','cls' — 4 params + 2 additional locals); ABCMeta._dump_registry.__code__.co_varnames.__len__()==6 ('cls','file','_abc_registry','_abc_cache','_abc_negative_cache','_abc_negative_cache_version' — 2 params + 4 locals); ABCMeta._abc_registry_clear.__code__.co_argcount.__eq__(1)==True ('cls' only — a classmethod that takes no additional arguments beyond the class itself); ABCMeta._abc_caches_clear.__code__.co_argcount.__eq__(1)==True ('cls' only — same pattern as _abc_registry_clear); ABCMeta.register.__code__.co_consts.__len__()==1 (only the docstring — no True constant because register delegates to _abc.register); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmeta_code139

  columns: [id, function, args, expected, description]
  rows:
    - [new_vlen,    abc.ABCMeta.__new__.__code__.co_varnames.__len__,           [],    6,     "abc.ABCMeta.__new__.__code__.co_varnames.__len__() == 6 ('mcls','name','bases','namespace','kwargs','cls'); verified with Python 3.14.3"]
    - [dr_vlen,     abc.ABCMeta._dump_registry.__code__.co_varnames.__len__,    [],    6,     "abc.ABCMeta._dump_registry.__code__.co_varnames.__len__() == 6 ('cls','file','_abc_registry','_abc_cache','_abc_negative_cache','_abc_negative_cache_version'); verified with Python 3.14.3"]
    - [arc_argc,    abc.ABCMeta._abc_registry_clear.__code__.co_argcount.__eq__, [1],  true,  "abc.ABCMeta._abc_registry_clear.__code__.co_argcount == 1 ('cls' only); verified with Python 3.14.3"]
    - [acc_argc,    abc.ABCMeta._abc_caches_clear.__code__.co_argcount.__eq__,  [1],   true,  "abc.ABCMeta._abc_caches_clear.__code__.co_argcount == 1 ('cls' only); verified with Python 3.14.3"]
    - [reg_consts,  abc.ABCMeta.register.__code__.co_consts.__len__,             [],    1,     "abc.ABCMeta.register.__code__.co_consts.__len__() == 1 (only the docstring); verified with Python 3.14.3"]

