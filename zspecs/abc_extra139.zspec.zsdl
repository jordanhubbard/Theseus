invariant abc_extra139.abc_subclasshook_qualname_len_20:
  description: "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 — abc.ABC.__subclasshook__.__qualname__ is 'ABC.__subclasshook__' (20 chars: 'ABC'=3+'.'=1+'__subclasshook__'=16=20); __subclasshook__ is a built-in classmethod on ABC with no __code__; __doc__.__len__()==308 (the longer of the two ABC built-in methods in this spec, compare __init_subclass__=135); one shorter than ABC.__init_subclass__.__qualname__.__len__()==21; NEW in extra139: first standalone ABC.__subclasshook__ qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__subclasshook__.__qualname__.__len__
  args: []
  expected: 20

invariant abc_extra139.abc_init_subclass_qualname_len_21:
  description: "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 — abc.ABC.__init_subclass__.__qualname__ is 'ABC.__init_subclass__' (21 chars: 'ABC'=3+'.'=1+'__init_subclass__'=17=21); one more than ABC.__subclasshook__.__qualname__.__len__()==20; __init_subclass__ is a built-in classmethod with no __code__; __doc__.__len__()==135 (shorter than __subclasshook__.__doc__.__len__()==308); NEW in extra139: first standalone ABC.__init_subclass__ qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__init_subclass__.__qualname__.__len__
  args: []
  expected: 21

invariant abc_extra139.abc_subclasshook_doc_len_308:
  description: "abc.ABC.__subclasshook__.__doc__.__len__() == 308 — abc.ABC.__subclasshook__.__doc__ is a 308-char multi-paragraph doc beginning 'Abstract classes can override this to customize issubclass().' and explaining that the method should return True, False, or NotImplemented; this is the longest __doc__ of the two built-in ABC methods in this spec (compare __init_subclass__=135); NEW in extra139: first standalone ABC.__subclasshook__ doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__subclasshook__.__doc__.__len__
  args: []
  expected: 308

invariant abc_extra139.abc_bases_object_len_6:
  description: "abc.ABC.__bases__[0].__name__.__len__() == 6 — abc.ABC.__bases__[0].__name__ is 'object' (6 chars); ABC has a single direct base class: object (the root of the Python class hierarchy); ABC uses ABCMeta as its metaclass but inherits from plain object; contrast with ABCMeta.__bases__[0].__name__=='type' (len=4, 2 shorter); NEW in extra139: first standalone ABC.__bases__[0].__name__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  "function": "abc.ABC.__bases__[0].__name__.__len__"
  args: []
  expected: 6

invariant abc_extra139.abcmeta_bases_type_len_4:
  description: "abc.ABCMeta.__bases__[0].__name__.__len__() == 4 — abc.ABCMeta.__bases__[0].__name__ is 'type' (4 chars: the root metaclass); ABCMeta inherits from type, making it a proper metaclass; contrast with ABC.__bases__[0].__name__=='object' (len=6, 2 longer); __bases__[0].__name__=='type' means ABCMeta is a type (metaclass) whereas ABC's base 'object' means ABC is a regular class; NEW in extra139: first standalone ABCMeta.__bases__[0].__name__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  "function": "abc.ABCMeta.__bases__[0].__name__.__len__"
  args: []
  expected: 4

invariant abc_extra139.abcmeta_new_varnames_len_6:
  description: "abc.ABCMeta.__new__.__code__.co_varnames.__len__() == 6 — abc.ABCMeta.__new__.__code__.co_varnames is ('mcls','name','bases','namespace','kwargs','cls') (6 elements: 4 named params + 'kwargs' for **kwargs + 'cls' local variable for the newly created class); ABCMeta.__new__.__code__.co_argcount==4 ('mcls','name','bases','namespace'); the 6-element varnames vs 4-element argcount reveals 2 additional captures; NEW in extra139: first standalone ABCMeta.__new__ co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
