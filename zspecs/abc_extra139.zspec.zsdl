invariant abc_extra139.abcmeta_register_consts_len_1:
  description: "abc.ABCMeta.register.__code__.co_consts.__len__() == 1 — abc.ABCMeta.register.__code__.co_consts contains exactly 1 constant: the docstring ('Register a virtual subclass of an ABC.\\n\\nReturns the subclass, to allow usage as a class decorator.\\n', len=99); contrast with abstractmethod.__code__.co_consts.__len__()==2 (which also has True); register has only the docstring because its body delegates to _abc.register rather than directly setting __isabstractmethod__=True; register co_argcount==2 ('cls','subclass'); NEW in extra139: first standalone ABCMeta.register co_consts length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.register.__code__.co_consts.__len__
  args: []
  expected: 1

invariant abc_extra139.abcmeta_dump_registry_varnames_len_6:
  description: "abc.ABCMeta._dump_registry.__code__.co_varnames.__len__() == 6 — abc.ABCMeta._dump_registry.__code__.co_varnames is ('cls','file','_abc_registry','_abc_cache','_abc_negative_cache','_abc_negative_cache_version') (6 elements: 2 params + 4 locals that hold the debug registry data extracted from the _abc C extension); co_argcount==2 ('cls','file'); this ties with ABCMeta.__new__.__code__.co_varnames.__len__()==6; _dump_registry.__qualname__=='ABCMeta._dump_registry' (len=22); NEW in extra139: first standalone _dump_registry co_varnames length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
