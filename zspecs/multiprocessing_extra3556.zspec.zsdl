spec: mp3556
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 684 (mp3556): __reduce__, __reduce_ex__, __getstate__ dict-presence checks for multiprocessing types."
    - "multiprocessing.pool.Pool defines __reduce__ (true): Pool implements custom pickle support for inter-process communication."
    - "multiprocessing.Process, multiprocessing.pool.AsyncResult, multiprocessing.pool.MapResult, multiprocessing.managers.SyncManager: all false."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __reduce__ dict-presence — operator.contains(Cls.__dict__, '__reduce__')
#
# multiprocessing.pool.Pool defines __reduce__ for pickling support.
# ---------------------------------------------------------------------------

table mp3556.reduce:
  description: "multiprocessing types __reduce__ dict-presence checks; wave 684"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: mp3556
  columns: [id, function, args, expected]
  rows:
    - ["mp3556001", operator.contains, [multiprocessing.Process.__dict__,                 "__reduce__"], false]
    - ["mp3556002", operator.contains, [multiprocessing.pool.Pool.__dict__,               "__reduce__"], true]
    - ["mp3556003", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,        "__reduce__"], false]
    - ["mp3556004", operator.contains, [multiprocessing.pool.MapResult.__dict__,          "__reduce__"], false]
    - ["mp3556005", operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__reduce__"], false]

