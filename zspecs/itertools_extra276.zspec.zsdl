spec: itertools_extra276
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "itertools.count, cycle, and repeat are C-level types; __class__.__name__ == 'type'."
    - "All three have __module__ == 'itertools' and __name__ matching their export symbol."
    - "count.__name__ == 'count' (5 chars); cycle.__name__ == 'cycle' (5 chars); repeat.__name__ == 'repeat' (6 chars)."
    - "repeat.__doc__ is not None — repeat ships with a docstring describing its behavior."
    - "All three are lazy infinite (or bounded) iterators implemented as C extension types."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# itertools.count and itertools.cycle — C-level type identity
#
# Both are C-level types: __class__.__name__ == 'type'.
# __module__ == 'itertools' for both.
# count.__name__ == 'count' (5 chars); cycle.__name__ == 'cycle' (5 chars).
# ---------------------------------------------------------------------------

table itertools_extra276.count_cycle_identity:
  description: "itertools.count and cycle C-level type identity — __name__, __module__, __class__.__name__; name lengths; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex276cc

  columns: [id, function, args, expected, description]
  rows:
    - [ct_name_eq,  count.__name__.__eq__,            ["count"],     true, "itertools.count.__name__ == 'count'; verified with Python 3.14.3"]
    - [ct_name_len, count.__name__.__len__,            [],            5,    "itertools.count.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [ct_mod_eq,   count.__module__.__eq__,           ["itertools"], true, "itertools.count.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [ct_cls_eq,   count.__class__.__name__.__eq__,   ["type"],      true, "itertools.count.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [cy_name_eq,  cycle.__name__.__eq__,             ["cycle"],     true, "itertools.cycle.__name__ == 'cycle'; verified with Python 3.14.3"]
    - [cy_name_len, cycle.__name__.__len__,             [],            5,    "itertools.cycle.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [cy_mod_eq,   cycle.__module__.__eq__,            ["itertools"], true, "itertools.cycle.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [cy_cls_eq,   cycle.__class__.__name__.__eq__,    ["type"],      true, "itertools.cycle.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# itertools.repeat — C-level type identity and doc presence
#
# repeat is a C-level type: __class__.__name__ == 'type'.
# repeat.__module__ == 'itertools'; repeat.__name__ == 'repeat' (6 chars).
# repeat.__doc__ is not None — the C-level type ships with a docstring.
# ---------------------------------------------------------------------------

table itertools_extra276.repeat_identity:
  description: "itertools.repeat C-level type identity — __name__, __module__, __class__.__name__; doc presence; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: itex276ri

  columns: [id, function, args, expected, description]
  rows:
    - [rp_name_eq,   repeat.__name__.__eq__,           ["repeat"],    true,  "itertools.repeat.__name__ == 'repeat'; verified with Python 3.14.3"]
    - [rp_name_len,  repeat.__name__.__len__,           [],            6,     "itertools.repeat.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [rp_mod_eq,    repeat.__module__.__eq__,          ["itertools"], true,  "itertools.repeat.__module__ == 'itertools'; verified with Python 3.14.3"]
    - [rp_cls_eq,    repeat.__class__.__name__.__eq__,  ["type"],      true,  "itertools.repeat.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [rp_doc_none,  repeat.__doc__.__eq__,             [null],        false, "itertools.repeat.__doc__ is not None — repeat ships with a docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra276
# ---------------------------------------------------------------------------

invariant itertools_extra276.count_class_is_type:
  description: "itertools.count.__class__.__name__ == 'type' — count is a C-level type, not a Python function"
  category: identity
  kind: python_call_eq
  function: count.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra276.count_module_is_itertools:
  description: "itertools.count.__module__ == 'itertools' — C-level type registered under the itertools module"
  category: identity
  kind: python_call_eq
  function: count.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra276.count_name_length_is_5:
  description: "itertools.count.__name__.__len__() == 5 — 'count' has 5 characters"
  category: identity
  kind: python_call_eq
  function: count.__name__.__len__
  args: []
  expected: 5

invariant itertools_extra276.cycle_class_is_type:
  description: "itertools.cycle.__class__.__name__ == 'type' — cycle is a C-level type, not a Python function"
  category: identity
  kind: python_call_eq
  function: cycle.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra276.cycle_module_is_itertools:
  description: "itertools.cycle.__module__ == 'itertools' — C-level type registered under the itertools module"
  category: identity
  kind: python_call_eq
  function: cycle.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra276.repeat_class_is_type:
  description: "itertools.repeat.__class__.__name__ == 'type' — repeat is a C-level type, not a Python function"
  category: identity
  kind: python_call_eq
  function: repeat.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant itertools_extra276.repeat_module_is_itertools:
  description: "itertools.repeat.__module__ == 'itertools' — C-level type registered under the itertools module"
  category: identity
  kind: python_call_eq
  function: repeat.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra276.repeat_has_docstring:
  description: "itertools.repeat.__doc__.__eq__(None) == False — repeat ships with a non-None docstring describing its lazy repetition behavior"
  category: behavior
  kind: python_call_eq
  function: repeat.__doc__.__eq__
  args: [null]
  expected: false

invariant itertools_extra276.repeat_name_length_is_6:
  description: "itertools.repeat.__name__.__len__() == 6 — 'repeat' has 6 characters"
  category: identity
  kind: python_call_eq
  function: repeat.__name__.__len__
  args: []
  expected: 6
