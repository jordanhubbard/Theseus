spec: threading_extra305
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.Barrier(0) raises ValueError — parties must be >= 1."
    - "threading.Semaphore(-1) raises ValueError — semaphore initial value must be >= 0."
    - "threading.enumerate.__name__ == 'enumerate'; __module__ == 'threading'."
    - "threading.settrace.__name__ == 'settrace'; __module__ == 'threading'."
    - "threading.setprofile.__name__ == 'setprofile'; __module__ == 'threading'."
    - "threading.stack_size.__name__ == 'stack_size'."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Barrier(0) raises ValueError
#
# threading.Barrier(parties) requires parties >= 1. Passing 0 raises
# ValueError immediately at construction time.
#
# Verified: Barrier(0) -> ValueError: parties must be >= 1
# ---------------------------------------------------------------------------

invariant threading_extra305.Barrier_zero_ValueError:
  description: "threading.Barrier(0) raises ValueError — parties must be >= 1"
  category: errors
  kind: python_call_raises
  function: Barrier
  args: [0]
  expected: ValueError

# ---------------------------------------------------------------------------
# Semaphore(-1) raises ValueError
#
# threading.Semaphore(value) requires value >= 0. The initial value represents
# a count of available resources and cannot be negative.
#
# Verified: Semaphore(-1) -> ValueError: semaphore initial value must be >= 0
# ---------------------------------------------------------------------------

invariant threading_extra305.Semaphore_negative_ValueError:
  description: "threading.Semaphore(-1) raises ValueError — semaphore initial value must be >= 0"
  category: errors
  kind: python_call_raises
  function: Semaphore
  args: [-1]
  expected: ValueError

# ---------------------------------------------------------------------------
# enumerate function identity
#
# threading.enumerate is a Python function defined in the threading module.
# __name__ == 'enumerate', __module__ == 'threading'.
# ---------------------------------------------------------------------------

invariant threading_extra305.enumerate_name:
  description: "threading.enumerate.__name__ == 'enumerate'"
  category: identity
  kind: python_call_eq
  function: enumerate.__name__.__eq__
  args: ["enumerate"]
  expected: true

invariant threading_extra305.enumerate_module:
  description: "threading.enumerate.__module__ == 'threading'"
  category: identity
  kind: python_call_eq
  function: enumerate.__module__.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# settrace function identity
#
# threading.settrace is a Python function defined in the threading module.
# __name__ == 'settrace', __module__ == 'threading'.
# ---------------------------------------------------------------------------

invariant threading_extra305.settrace_name:
  description: "threading.settrace.__name__ == 'settrace'"
  category: identity
  kind: python_call_eq
  function: settrace.__name__.__eq__
  args: ["settrace"]
  expected: true

invariant threading_extra305.settrace_module:
  description: "threading.settrace.__module__ == 'threading'"
  category: identity
  kind: python_call_eq
  function: settrace.__module__.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# setprofile function identity
#
# threading.setprofile is a Python function defined in the threading module.
# __name__ == 'setprofile', __module__ == 'threading'.
# ---------------------------------------------------------------------------

invariant threading_extra305.setprofile_name:
  description: "threading.setprofile.__name__ == 'setprofile'"
  category: identity
  kind: python_call_eq
  function: setprofile.__name__.__eq__
  args: ["setprofile"]
  expected: true

invariant threading_extra305.setprofile_module:
  description: "threading.setprofile.__module__ == 'threading'"
  category: identity
  kind: python_call_eq
  function: setprofile.__module__.__eq__
  args: ["threading"]
  expected: true

# ---------------------------------------------------------------------------
# stack_size function identity
#
# threading.stack_size.__name__ == 'stack_size'.
# ---------------------------------------------------------------------------

invariant threading_extra305.stack_size_name:
  description: "threading.stack_size.__name__ == 'stack_size'"
  category: identity
  kind: python_call_eq
  function: stack_size.__name__.__eq__
  args: ["stack_size"]
  expected: true

# ---------------------------------------------------------------------------
# TIMEOUT_MAX type identity
#
# threading.TIMEOUT_MAX is a float constant representing the maximum value
# accepted by blocking calls with a timeout parameter.
# __class__.__name__ == 'float'.
# Verified: threading.TIMEOUT_MAX == 9223372036.0 on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant threading_extra305.TIMEOUT_MAX_is_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is a float constant"
  category: identity
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true
