spec: _heapq
version: ">=3.0"
backend: python_module(_heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/heapq.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "_heapq source: Modules/_heapqmodule.c (PSF; C extension)"
  not_derived_from:
    - "_heapq source: internal siftup/siftdown implementation details"
  notes:
    - "_heapq is the C-extension backend for the heapq stdlib module."
    - "heapify([3,1,2]) modifies the list in-place and returns None."
    - "heappush and heappop maintain the heap invariant: heap[0] is always the smallest element."
    - "heapreplace(heap, item) pops the smallest element and pushes item, more efficient than heappop+heappush."
    - "heappushpop(heap, item) pushes item then pops the smallest; equivalent to heappush+heappop but faster."
    - "nlargest(n, iterable) returns the n largest elements in descending order."
    - "nsmallest(n, iterable) returns the n smallest elements in ascending order."
    - "heappop([1,2,3]) returns 1 — 1 is the minimum of an already valid min-heap."
    - "All expected values verified by running Python 3.12 _heapq module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name checks — all public _heapq functions
# ---------------------------------------------------------------------------

table _heapq.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [heappush,    heappush.__name__.__eq__,    ["heappush"],    true]
    - [heappop,     heappop.__name__.__eq__,     ["heappop"],     true]
    - [heapify,     heapify.__name__.__eq__,     ["heapify"],     true]
    - [heapreplace, heapreplace.__name__.__eq__, ["heapreplace"], true]
    - [heappushpop, heappushpop.__name__.__eq__, ["heappushpop"], true]
    - [nlargest,    nlargest.__name__.__eq__,    ["nlargest"],    true]
    - [nsmallest,   nsmallest.__name__.__eq__,   ["nsmallest"],   true]

# ---------------------------------------------------------------------------
# Function module checks — all functions report __module__ == '_heapq'
# ---------------------------------------------------------------------------

table _heapq.function_modules:
  kind: python_call_eq
  category: functions
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [heappush,    heappush.__module__.__eq__,    ["_heapq"], true]
    - [heappop,     heappop.__module__.__eq__,     ["_heapq"], true]
    - [heapify,     heapify.__module__.__eq__,     ["_heapq"], true]
    - [heapreplace, heapreplace.__module__.__eq__, ["_heapq"], true]
    - [heappushpop, heappushpop.__module__.__eq__, ["_heapq"], true]
    - [nlargest,    nlargest.__module__.__eq__,    ["_heapq"], true]
    - [nsmallest,   nsmallest.__module__.__eq__,   ["_heapq"], true]

# ---------------------------------------------------------------------------
# heapify — modifies in-place, returns None
# ---------------------------------------------------------------------------

invariant _heapq.heapify_returns_none:
  description: "heapify([3,1,2]) returns None — in-place operation has no return value"
  category: behavioral
  kind: python_call_eq
  function: heapify
  args: [[3, 1, 2]]
  expected: ~

# ---------------------------------------------------------------------------
# heappop — returns minimum from a valid min-heap
# ---------------------------------------------------------------------------

invariant _heapq.heappop_min:
  description: "heappop([1,2,3]) == 1 — returns the minimum element"
  category: behavioral
  kind: python_call_eq
  function: heappop
  args: [[1, 2, 3]]
  expected: 1

# ---------------------------------------------------------------------------
# nlargest — returns top-n in descending order
# ---------------------------------------------------------------------------

invariant _heapq.nlargest_two:
  description: "nlargest(2, [3,1,4,1,5]) == [5, 4]"
  category: behavioral
  kind: python_call_eq
  function: nlargest
  args: [2, [3, 1, 4, 1, 5]]
  expected: [5, 4]

invariant _heapq.nlargest_one:
  description: "nlargest(1, [3,1,4,1,5]) == [5] — returns list with single maximum"
  category: behavioral
  kind: python_call_eq
  function: nlargest
  args: [1, [3, 1, 4, 1, 5]]
  expected: [5]

# ---------------------------------------------------------------------------
# nsmallest — returns bottom-n in ascending order
# ---------------------------------------------------------------------------

invariant _heapq.nsmallest_two:
  description: "nsmallest(2, [3,1,4,1,5]) == [1, 1] — returns two smallest values"
  category: behavioral
  kind: python_call_eq
  function: nsmallest
  args: [2, [3, 1, 4, 1, 5]]
  expected: [1, 1]

invariant _heapq.nsmallest_one:
  description: "nsmallest(1, [3,1,4,1,5]) == [1] — returns list with single minimum"
  category: behavioral
  kind: python_call_eq
  function: nsmallest
  args: [1, [3, 1, 4, 1, 5]]
  expected: [1]

