spec: array_extra19
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array.zspec.zsdl — baseline typecode, itemsize, and instance vectors."
    - "array_extra.zspec.zsdl through array_extra18.zspec.zsdl — prior extras."
  notes:
    - "This spec extends array.zspec.zsdl through array_extra18.zspec.zsdl."
    - "Focus: module-level identity attributes and typecodes string cross-checks."
    - "array_extra4 covers array.array.__qualname__ == 'array'."
    - "array_extra5 covers array.ArrayType.__qualname__ == 'array'."
    - "array_extra8 covers typecodes.__class__.__name__ via __eq__ chain."
    - "array_extra14 covers array.array.__qualname__.__len__() == 5."
    - "array_extra18 covers __bases__, __module__, typecodes.is_str, typecodes.length, typecodes.membership."
    - "This spec adds NEW axes:"
    - "  (1) array module __name__ == 'array' — module-level attribute (not array.array.__name__)."
    - "  (2) array module __package__ == '' — array has no parent package."
    - "  (3) array module __name__ and __package__ are plain str."
    - "  (4) array.typecodes.__eq__('bBuwhHiIlLqQfd') — exact string value of typecodes."
    - "  (5) array.ArrayType.__qualname__.__len__() == 5 — len('array') == 5."
    - "array module __name__ == 'array' — Verified Python 3.12 macOS."
    - "array module __package__ == '' — array is a top-level module with no package prefix. Verified."
    - "array.typecodes == 'bBuwhHiIlLqQfd' — Verified (14 typecodes on Python 3.12)."
    - "array.ArrayType.__qualname__.__len__() == 5 — len('array') == 5. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# array module-level __name__ attribute
#
# array_extra covers array.array.__name__ (class __name__ == 'array').
# No prior array spec checks the module's own __name__ attribute.
# In python_module(array) backend, function: __name__.__eq__ accesses
# array.__name__.__eq__, evaluating to 'array'.
# ---------------------------------------------------------------------------

invariant array_extra19.module.name:
  description: "array module __name__ == 'array' — the module's own __name__ attribute"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["array"]
  expected: true

# ---------------------------------------------------------------------------
# array module-level __package__ attribute
#
# array is a top-level module; its __package__ is an empty string.
# No prior array spec checks __package__. Under python_module(array),
# function: __package__.__eq__ accesses array.__package__.__eq__('').
# ---------------------------------------------------------------------------

invariant array_extra19.module.package:
  description: "array module __package__ == '' — array is a top-level module with no package prefix"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# array module __name__ and __package__ type checks
#
# Both __name__ and __package__ are plain Python str objects.
# No prior array spec checks the type of these module-level attributes.
# ---------------------------------------------------------------------------

table array_extra19.module_attr_types:
  description: "array module __name__ and __package__ are plain str objects"
  kind: python_call_eq
  category: module_identity
  id_prefix: mat19

  columns: [id, function, args, expected]
  rows:
    - [name_is_str,    __name__.__class__.__name__.__eq__,    ["str"], true]
    - [package_is_str, __package__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# array.typecodes exact string value
#
# array_extra18 checks typecodes.__class__.__name__ == 'str' and
# typecodes.__len__() == 14 and membership for all 14 typecodes.
# No prior array spec checks the exact value of the typecodes string.
# In Python 3.12 macOS: array.typecodes == 'bBuwhHiIlLqQfd'.
# ---------------------------------------------------------------------------

invariant array_extra19.typecodes.exact_value:
  description: "array.typecodes == 'bBuwhHiIlLqQfd' — exact typecodes string in Python 3.12"
  category: typecodes
  kind: python_call_eq
  function: typecodes.__eq__
  args: ["bBuwhHiIlLqQfd"]
  expected: true

# ---------------------------------------------------------------------------
# array.ArrayType.__qualname__.__len__() == 5
#
# array_extra5 verifies ArrayType.__qualname__ == 'array'.
# array_extra14 checks array.array.__qualname__.__len__() == 5.
# No prior spec checks the __len__() of ArrayType.__qualname__ specifically.
# len('array') == 5. Cross-check from the extra19 namespace.
# ---------------------------------------------------------------------------

invariant array_extra19.ArrayType.qualname_len:
  description: "array.ArrayType.__qualname__.__len__() == 5 — len('array') == 5"
  category: class_identity
  kind: python_call_eq
  function: ArrayType.__qualname__.__len__
  args: []
  expected: 5
