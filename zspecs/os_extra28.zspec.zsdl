spec: os_extra28
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "os_extra27.zspec.zsdl — covers __qualname__ equality table for getcwd/listdir/makedirs/remove/rename/mkdir/rmdir/stat/walk; qualname length invariants for getcwd/listdir/makedirs/remove/walk/rename"
  notes:
    - "This spec extends os.zspec.zsdl and all prior os_extra specs through os_extra27.zspec.zsdl."
    - "Focus: os.getenv.__qualname__ (new — not covered in any prior os spec) and qualname length invariants for mkdir/rmdir/stat/getenv."
    - "os.getenv.__qualname__ == 'getenv' — getenv is a pure-Python wrapper defined in os.py; no prior os spec covers getenv.__qualname__."
    - "os.mkdir.__qualname__ == 'mkdir' — covered in extra27 equality table but NOT as a standalone length invariant; len=5."
    - "os.rmdir.__qualname__ == 'rmdir' — covered in extra27 equality table but NOT as a standalone length invariant; len=5."
    - "os.stat.__qualname__ == 'stat' — covered in extra27 equality table but NOT as a standalone length invariant; len=4."
    - "Qualname length facts: getenv=6, mkdir=5, rmdir=5, stat=4."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# getenv __qualname__ equality — new coverage in extra28 namespace
#
# os.getenv is a pure-Python function defined in os.py. Its __qualname__
# equals the plain function name 'getenv'. No prior os spec covers getenv
# in any __qualname__ context. This table groups getenv with three other
# os functions whose qualname lengths were not yet covered as standalone
# invariants in os_extra27.
# ---------------------------------------------------------------------------

table os_extra28.function_qualnames:
  description: "__qualname__ for getenv and qualname-length companions mkdir/rmdir/stat"
  kind: python_call_eq
  category: function_identity
  id_prefix: qualname28

  columns: [id, function, args, expected]
  rows:
    - [getenv, getenv.__qualname__.__eq__, ["getenv"], true]
    - [mkdir,  mkdir.__qualname__.__eq__,  ["mkdir"],  true]
    - [rmdir,  rmdir.__qualname__.__eq__,  ["rmdir"],  true]
    - [stat,   stat.__qualname__.__eq__,   ["stat"],   true]

# ---------------------------------------------------------------------------
# __qualname__ length invariants — getenv, mkdir, rmdir, stat
#
# os_extra27 provided length invariants for getcwd/listdir/makedirs/remove/
# walk/rename. This spec fills the gap with length invariants for getenv
# (entirely new), mkdir, rmdir, and stat (equality in extra27 table but no
# standalone length invariant).
# ---------------------------------------------------------------------------

invariant os_extra28.getenv.qualname_length:
  description: "os.getenv.__qualname__.__len__() == 6 — 'getenv' has 6 characters"
  category: function_identity
  kind: python_call_eq
  function: getenv.__qualname__.__len__
  args: []
  expected: 6

invariant os_extra28.mkdir.qualname_length:
  description: "os.mkdir.__qualname__.__len__() == 5 — 'mkdir' has 5 characters"
  category: function_identity
  kind: python_call_eq
  function: mkdir.__qualname__.__len__
  args: []
  expected: 5

invariant os_extra28.rmdir.qualname_length:
  description: "os.rmdir.__qualname__.__len__() == 5 — 'rmdir' has 5 characters"
  category: function_identity
  kind: python_call_eq
  function: rmdir.__qualname__.__len__
  args: []
  expected: 5

invariant os_extra28.stat.qualname_length:
  description: "os.stat.__qualname__.__len__() == 4 — 'stat' has 4 characters"
  category: function_identity
  kind: python_call_eq
  function: stat.__qualname__.__len__
  args: []
  expected: 4
