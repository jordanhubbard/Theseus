spec: itertools_extra119
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra118.zspec.zsdl."
    - "This spec covers: itertools.starmap and itertools.filterfalse class slot qualname attributes not yet covered — starmap.__next__.__qualname__ ('starmap.__next__', len 16), starmap.__iter__.__qualname__ ('starmap.__iter__', len 16), filterfalse.__next__.__qualname__ ('filterfalse.__next__', len 20), filterfalse.__iter__.__qualname__ ('filterfalse.__iter__', len 20), starmap.__class__.__name__ ('starmap'); wave 270."
    - "itertools.starmap.__next__.__qualname__ == 'starmap.__next__'. Verified with Python 3.14.3."
    - "len(itertools.starmap.__next__.__qualname__) == 16. Verified with Python 3.14.3."
    - "itertools.starmap.__iter__.__qualname__ == 'starmap.__iter__'. Verified with Python 3.14.3."
    - "len(itertools.starmap.__iter__.__qualname__) == 16. Verified with Python 3.14.3."
    - "itertools.filterfalse.__next__.__qualname__ == 'filterfalse.__next__'. Verified with Python 3.14.3."
    - "len(itertools.filterfalse.__next__.__qualname__) == 20. Verified with Python 3.14.3."
    - "itertools.filterfalse.__iter__.__qualname__ == 'filterfalse.__iter__'. Verified with Python 3.14.3."
    - "len(itertools.filterfalse.__iter__.__qualname__) == 20. Verified with Python 3.14.3."
    - "itertools.starmap.__next__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__next__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.starmap.__next__ and __iter__ slot qualnames
#
# Wave 270 theme: itertools.starmap is a C-extension iterator type. Its
# tp_iternext slot is exposed as __next__ and its tp_iter slot as __iter__.
# The qualname pattern for C iterator slots is '<classname>.<slotname>'.
# 'starmap' has 7 chars, so both slot qualnames have length 7+1+8 = 16:
# 'starmap.__next__' and 'starmap.__iter__' (both 16 chars). This is 2 more
# than repeat/islice (15, 6-char names) and 2 more than count/cycle/chain (14,
# 5-char names). Prior spec extra118 covered count (14), cycle (14), and
# repeat (15). New here: starmap (16), filterfalse (20).
#
# starmap.__next__.__qualname__ == 'starmap.__next__'  (len 16)
# starmap.__iter__.__qualname__ == 'starmap.__iter__'  (len 16)
#
# New to extra119.
# ---------------------------------------------------------------------------

table itertools_extra119.starmap_next_iter_qualnames:
  description: "itertools.starmap slot qualnames: __next__='starmap.__next__'(16), __iter__='starmap.__iter__'(16); both len=16; 7-char class name gives 7+1+8=16; two more than repeat/islice (15); wrapper_descriptor; wave 270; new to extra119"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolssmniq119

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_next_qualname_eq,
       "starmap.__next__.__qualname__.__eq__",
       ["starmap.__next__"],
       true,
       "itertools.starmap.__next__.__qualname__.__eq__('starmap.__next__') == True — starmap exposes its tp_iternext C slot as __next__; qualname is 'starmap.__next__' (16 chars); str.__eq__('starmap.__next__') returns True; new to extra119"]
    - [starmap_next_qualname_len,
       "starmap.__next__.__qualname__.__len__",
       [],
       16,
       "itertools.starmap.__next__.__qualname__.__len__() == 16 — 'starmap.__next__' has 16 chars: starmap(7)+dot(1)+__next__(8); two more than repeat (15) because 'starmap' is 7 chars vs 6; str.__len__() returns 16; new to extra119"]
    - [starmap_iter_qualname_eq,
       "starmap.__iter__.__qualname__.__eq__",
       ["starmap.__iter__"],
       true,
       "itertools.starmap.__iter__.__qualname__.__eq__('starmap.__iter__') == True — starmap exposes its tp_iter C slot as __iter__; qualname is 'starmap.__iter__' (16 chars); str.__eq__('starmap.__iter__') returns True; new to extra119"]
    - [starmap_iter_qualname_len,
       "starmap.__iter__.__qualname__.__len__",
       [],
       16,
       "itertools.starmap.__iter__.__qualname__.__len__() == 16 — 'starmap.__iter__' has 16 chars: starmap(7)+dot(1)+__iter__(8); same length as starmap.__next__.__qualname__; str.__len__() returns 16; new to extra119"]
    - [starmap_next_class_name,
       "starmap.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.starmap.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — C tp_iternext slots on extension types are exposed as wrapper_descriptor objects; same type as count.__next__, cycle.__next__, repeat.__next__; str.__eq__('wrapper_descriptor') returns True; new to extra119"]

# ---------------------------------------------------------------------------
# Table 2: itertools.filterfalse.__next__ and __iter__ slot qualnames
#
# Wave 270 theme: itertools.filterfalse is a C-extension iterator type that
# yields elements for which the predicate is false. Its class name is
# 'filterfalse' (11 chars), so its slot qualnames have length 11+1+8 = 20:
# 'filterfalse.__next__' and 'filterfalse.__iter__' (both 20 chars). This is
# 4 more than starmap (16) and 6 more than repeat/islice (15). 'filterfalse'
# is the longest standard itertools class name (11 chars). Previously covered:
# filterfalse __name__, __qualname__, __module__, __doc__ type. Not previously
# covered: __next__ and __iter__ slot qualnames. New here.
#
# filterfalse.__next__.__qualname__ == 'filterfalse.__next__'  (len 20)
# filterfalse.__iter__.__qualname__ == 'filterfalse.__iter__'  (len 20)
#
# New to extra119.
# ---------------------------------------------------------------------------

table itertools_extra119.filterfalse_next_iter_qualnames:
  description: "itertools.filterfalse slot qualnames: __next__='filterfalse.__next__'(20), __iter__='filterfalse.__iter__'(20); both len=20; 11-char class name gives 11+1+8=20; longest standard itertools qualname; wave 270; new to extra119"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsffniq119

  columns: [id, function, args, expected, description]
  rows:
    - [filterfalse_next_qualname_eq,
       "filterfalse.__next__.__qualname__.__eq__",
       ["filterfalse.__next__"],
       true,
       "itertools.filterfalse.__next__.__qualname__.__eq__('filterfalse.__next__') == True — filterfalse exposes its tp_iternext slot as __next__; qualname is 'filterfalse.__next__' (20 chars); str.__eq__('filterfalse.__next__') returns True; new to extra119"]
    - [filterfalse_next_qualname_len,
       "filterfalse.__next__.__qualname__.__len__",
       [],
       20,
       "itertools.filterfalse.__next__.__qualname__.__len__() == 20 — 'filterfalse.__next__' has 20 chars: filterfalse(11)+dot(1)+__next__(8); 4 more than starmap (16) because 'filterfalse' is 11 chars vs 7; str.__len__() returns 20; new to extra119"]
    - [filterfalse_iter_qualname_eq,
       "filterfalse.__iter__.__qualname__.__eq__",
       ["filterfalse.__iter__"],
       true,
       "itertools.filterfalse.__iter__.__qualname__.__eq__('filterfalse.__iter__') == True — filterfalse exposes its tp_iter slot as __iter__; qualname is 'filterfalse.__iter__' (20 chars); str.__eq__('filterfalse.__iter__') returns True; new to extra119"]
    - [filterfalse_iter_qualname_len,
       "filterfalse.__iter__.__qualname__.__len__",
       [],
       20,
       "itertools.filterfalse.__iter__.__qualname__.__len__() == 20 — 'filterfalse.__iter__' has 20 chars: filterfalse(11)+dot(1)+__iter__(8); same length as filterfalse.__next__.__qualname__; str.__len__() returns 20; new to extra119"]
    - [filterfalse_next_class_name,
       "filterfalse.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.filterfalse.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — C tp_iternext slot on filterfalse is a wrapper_descriptor; same type as starmap.__next__, count.__next__, cycle.__next__, repeat.__next__; str.__eq__('wrapper_descriptor') returns True; new to extra119"]

# ---------------------------------------------------------------------------
# Table 3: starmap vs filterfalse qualname length comparison
#
# Wave 270 theme: The qualname lengths of C iterator slot descriptors scale
# with the class name length. 'starmap' (7 chars) gives qualname length 16;
# 'filterfalse' (11 chars) gives qualname length 20. The difference is 4,
# equal to the class name length difference (11-7=4). This generalises the
# pattern observed in extra118: count(5)=14, cycle(5)=14, repeat(6)=15.
# Adding starmap(7)=16 and filterfalse(11)=20 confirms the formula.
# Additional checks: starmap.__name__ == 'starmap' (7 chars) and
# filterfalse.__name__ == 'filterfalse' (11 chars).
#
# starmap.__next__.__qualname__.__len__()     == 16
# filterfalse.__next__.__qualname__.__len__() == 20
# starmap.__name__.__len__()                  == 7
# filterfalse.__name__.__len__()              == 11
#
# New to extra119.
# ---------------------------------------------------------------------------

table itertools_extra119.starmap_filterfalse_len_comparison:
  description: "itertools starmap vs filterfalse qualname lengths: starmap=16 (7-char name), filterfalse=20 (11-char name); difference=4 equals class-name diff (11-7); extends pattern from extra118; wave 270; new to extra119"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolssfflen119

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_next_len_16,
       "starmap.__next__.__qualname__.__len__",
       [],
       16,
       "itertools.starmap.__next__.__qualname__.__len__() == 16 — 'starmap' is 7 chars giving qualname len 7+1+8=16; 2 more than repeat (15) and 1 more than a hypothetical 6-char class; str.__len__() returns 16; new to extra119"]
    - [filterfalse_next_len_20,
       "filterfalse.__next__.__qualname__.__len__",
       [],
       20,
       "itertools.filterfalse.__next__.__qualname__.__len__() == 20 — 'filterfalse' is 11 chars giving qualname len 11+1+8=20; 4 more than starmap (16); longest standard itertools slot qualname; str.__len__() returns 20; new to extra119"]
    - [starmap_name_len,
       "starmap.__name__.__len__",
       [],
       7,
       "itertools.starmap.__name__.__len__() == 7 — 'starmap' has 7 chars: s-t-a-r-m-a-p; one more than 6-char names like islice and repeat; drives qualname length 16 for its slots; str.__len__() returns 7; new to extra119"]
    - [filterfalse_name_len,
       "filterfalse.__name__.__len__",
       [],
       11,
       "itertools.filterfalse.__name__.__len__() == 11 — 'filterfalse' has 11 chars: f-i-l-t-e-r(6)+f-a-l-s-e(5); the longest standard itertools class name; drives qualname length 20 for its slots; str.__len__() returns 11; new to extra119"]
    - [starmap_iter_class_name,
       "starmap.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.starmap.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — C tp_iter slot on starmap is a wrapper_descriptor; same type as starmap.__next__ and all other itertools slot descriptors; str.__eq__('wrapper_descriptor') returns True; new to extra119"]
    - [filterfalse_iter_class_name,
       "filterfalse.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.filterfalse.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — C tp_iter slot on filterfalse is a wrapper_descriptor; same type as filterfalse.__next__ and all other itertools slot descriptors in this series; str.__eq__('wrapper_descriptor') returns True; new to extra119"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra119
# ---------------------------------------------------------------------------

invariant itertools_extra119.starmap_next_qualname:
  description: "itertools.starmap.__next__.__qualname__ == 'starmap.__next__' — tp_iternext slot; qualname length 16; 7-char class name; wave 270; new to extra119"
  kind: python_call_eq
  function: starmap.__next__.__qualname__.__eq__
  args: ["starmap.__next__"]
  expected: true

invariant itertools_extra119.starmap_iter_qualname:
  description: "itertools.starmap.__iter__.__qualname__ == 'starmap.__iter__' — tp_iter slot; qualname length 16; equal to starmap.__next__ qualname length; wave 270; new to extra119"
  kind: python_call_eq
  function: starmap.__iter__.__qualname__.__eq__
  args: ["starmap.__iter__"]
  expected: true

invariant itertools_extra119.filterfalse_next_qualname:
  description: "itertools.filterfalse.__next__.__qualname__ == 'filterfalse.__next__' — tp_iternext slot; qualname length 20; 11-char class name; longest itertools slot qualname; wave 270; new to extra119"
  kind: python_call_eq
  function: filterfalse.__next__.__qualname__.__eq__
  args: ["filterfalse.__next__"]
  expected: true

invariant itertools_extra119.filterfalse_iter_qualname:
  description: "itertools.filterfalse.__iter__.__qualname__ == 'filterfalse.__iter__' — tp_iter slot; qualname length 20; equal to filterfalse.__next__ qualname length; wave 270; new to extra119"
  kind: python_call_eq
  function: filterfalse.__iter__.__qualname__.__eq__
  args: ["filterfalse.__iter__"]
  expected: true

invariant itertools_extra119.filterfalse_name_len:
  description: "itertools.filterfalse.__name__.__len__() == 11 — 'filterfalse' is 11 chars; the longest standard itertools class name; drives slot qualname length 20; wave 270; new to extra119"
  kind: python_call_eq
  function: filterfalse.__name__.__len__
  args: []
  expected: 11
