spec: hashlib_extra271
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra270.zspec.zsdl — covers algorithms_guaranteed set membership for sha256/md5/sha1/sha512/sha224/sha384/sha3_256/blake2b/blake2s; __contains__/__class__/__name__ identity."
    - "hashlib_extra269.zspec.zsdl — covers HASH class method __name__/__class__/__qualname__ identity; sha3/shake __module__; hashlib.new/__hash_new and file_digest identity."
    - "hashlib_extra268.zspec.zsdl — covers sha3_256/sha3_512/shake_128/shake_256 constructor __name__ and __class__.__name__; scrypt/pbkdf2_hmac kdf identity; algorithms_available/algorithms_guaranteed class names."
  notes:
    - "hashlib.algorithms_available is a set of algorithm names available on the current platform (superset of algorithms_guaranteed). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha256' in hashlib.algorithms_available == True — sha256 is in algorithms_available on all platforms. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'md5' in hashlib.algorithms_available == True — md5 is in algorithms_available. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha512' in hashlib.algorithms_available == True — sha512 is in algorithms_available. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha1' in hashlib.algorithms_available == True — sha1 is in algorithms_available. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha3_256' in hashlib.algorithms_available == True — sha3_256 is in algorithms_available. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha3_512' in hashlib.algorithms_available == True — sha3_512 is in algorithms_available. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'blake2b' in hashlib.algorithms_available == True — blake2b is in algorithms_available. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'blake2s' in hashlib.algorithms_available == True — blake2s is in algorithms_available. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha224' in hashlib.algorithms_available == True — sha224 is in algorithms_available. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha384' in hashlib.algorithms_available == True — sha384 is in algorithms_available. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.algorithms_available.__class__.__name__ == 'set' — algorithms_available is a plain Python set. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.algorithms_available.__contains__.__class__.__name__ == 'builtin_function_or_method' — C builtin method on set. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.algorithms_available set identity
# algorithms_available is a set of algorithm names available on the current
# platform. __class__.__name__ == 'set'; __contains__ is a C builtin method.
# ---------------------------------------------------------------------------

table hashlib_extra271.algorithms_available_set_identity:
  description: "hashlib.algorithms_available set identity — __class__.__name__/'set', __contains__.__name__/'__contains__', __contains__.__class__.__name__/'builtin_function_or_method'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: hashaval271

  columns: [id, function, args, expected, description]
  rows:
    - [avail_class,         algorithms_available.__class__.__name__.__eq__,                    ["set"],                         true, "hashlib.algorithms_available.__class__.__name__ == 'set' — algorithms_available is a plain Python set"]
    - [avail_contains_name, algorithms_available.__contains__.__name__.__eq__,                 ["__contains__"],                true, "hashlib.algorithms_available.__contains__.__name__ == '__contains__' — standard set membership method"]
    - [avail_contains_cls,  algorithms_available.__contains__.__class__.__name__.__eq__,       ["builtin_function_or_method"],  true, "hashlib.algorithms_available.__contains__.__class__.__name__ == 'builtin_function_or_method' — C builtin on set"]
    - [gtd_class,           algorithms_guaranteed.__class__.__name__.__eq__,                   ["set"],                         true, "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — algorithms_guaranteed is also a plain Python set"]
    - [gtd_contains_name,   algorithms_guaranteed.__contains__.__name__.__eq__,                ["__contains__"],                true, "hashlib.algorithms_guaranteed.__contains__.__name__ == '__contains__' — same method on both set objects"]

# ---------------------------------------------------------------------------
# hashlib.algorithms_available membership — core and extended algorithms
# All major algorithms are present in algorithms_available on CPython/macOS.
# ---------------------------------------------------------------------------

invariant hashlib_extra271.algorithms_available_sha256:
  description: "'sha256' in hashlib.algorithms_available == True — sha256 is available on this platform; algorithms_available.__contains__ returns True; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: algorithms_available.__contains__
  args: ["sha256"]
  expected: true

invariant hashlib_extra271.algorithms_available_md5:
  description: "'md5' in hashlib.algorithms_available == True — md5 is available on this platform; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: algorithms_available.__contains__
  args: ["md5"]
  expected: true

