spec: io_extra297
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module public API and __all__ membership"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c, Lib/io.py"
  notes:
    - "io.__all__ is a list of publicly exported names for the io module"
    - "Membership verified for all core I/O classes, constants, and exceptions"
    - "DEFAULT_BUFFER_SIZE is 8192 by default"
    - "SEEK_SET=0, SEEK_CUR=1, SEEK_END=2 match POSIX seek constants"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table io_extra297.all_core_classes:
  description: "io.__all__ membership for core I/O classes"
  kind: python_call_eq
  category: identity
  id_prefix: io297a

  columns: [id, function, args, expected, description]
  rows:
    - [io297a001, io.__all__.__contains__, ["BytesIO"], true, "BytesIO is in io.__all__"]
    - [io297a002, io.__all__.__contains__, ["StringIO"], true, "StringIO is in io.__all__"]
    - [io297a003, io.__all__.__contains__, ["FileIO"], true, "FileIO is in io.__all__"]
    - [io297a004, io.__all__.__contains__, ["BufferedReader"], true, "BufferedReader is in io.__all__"]
    - [io297a005, io.__all__.__contains__, ["BufferedWriter"], true, "BufferedWriter is in io.__all__"]
    - [io297a006, io.__all__.__contains__, ["BufferedRandom"], true, "BufferedRandom is in io.__all__"]
    - [io297a007, io.__all__.__contains__, ["BufferedRWPair"], true, "BufferedRWPair is in io.__all__"]
    - [io297a008, io.__all__.__contains__, ["TextIOWrapper"], true, "TextIOWrapper is in io.__all__"]
    - [io297a009, io.__all__.__contains__, ["IOBase"], true, "IOBase is in io.__all__"]
    - [io297a010, io.__all__.__contains__, ["RawIOBase"], true, "RawIOBase is in io.__all__"]
    - [io297a011, io.__all__.__contains__, ["BufferedIOBase"], true, "BufferedIOBase is in io.__all__"]
    - [io297a012, io.__all__.__contains__, ["TextIOBase"], true, "TextIOBase is in io.__all__"]
    - [io297a013, io.__all__.__contains__, ["open"], true, "open is in io.__all__"]

table io_extra297.all_constants_exceptions:
  description: "io.__all__ membership for constants and exceptions"
  kind: python_call_eq
  category: identity
  id_prefix: io297b

  columns: [id, function, args, expected, description]
  rows:
    - [io297b001, io.__all__.__contains__, ["DEFAULT_BUFFER_SIZE"], true, "DEFAULT_BUFFER_SIZE is in io.__all__"]
    - [io297b002, io.__all__.__contains__, ["SEEK_SET"], true, "SEEK_SET is in io.__all__"]
    - [io297b003, io.__all__.__contains__, ["SEEK_CUR"], true, "SEEK_CUR is in io.__all__"]
    - [io297b004, io.__all__.__contains__, ["SEEK_END"], true, "SEEK_END is in io.__all__"]
    - [io297b005, io.__all__.__contains__, ["UnsupportedOperation"], true, "UnsupportedOperation is in io.__all__"]
    - [io297b006, io.__all__.__contains__, ["BlockingIOError"], true, "BlockingIOError is in io.__all__"]
    - [io297b007, io.__all__.__contains__, ["open_code"], true, "open_code is in io.__all__"]

invariant io_extra297.module_name:
  description: "io module __name__ is 'io'"
  category: identity
  kind: python_call_eq
  function: io.__name__.__eq__
  args: ["io"]
  expected: true

invariant io_extra297.all_is_list:
  description: "io.__all__ is a list"
  category: identity
  kind: python_call_eq
  function: io.__all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant io_extra297.all_len:
  description: "io.__all__ has at least 18 members"
  category: identity
  kind: python_call_eq
  function: io.__all__.__len__
  args: []
  expected: 20
