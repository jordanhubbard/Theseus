spec: itertools_extra586
version: ">=3.9"
backend: python_module(itertools)
docs: "Identity invariants for itertools class __qualname__ and __module__ properties"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__ identity for ten itertools classes"
    - "Covers __module__ identity for chain, cycle, product, and count"
  created_at: "2026-04-12T00:00:00Z"

table it586qn:
  description: "itertools class __qualname__ identity"
  columns: [id, function, args, expected]
  rows:
    - [it586qn01, itertools.chain.__qualname__.__eq__, ["chain"], true]
    - [it586qn02, itertools.cycle.__qualname__.__eq__, ["cycle"], true]
    - [it586qn03, itertools.product.__qualname__.__eq__, ["product"], true]
    - [it586qn04, itertools.count.__qualname__.__eq__, ["count"], true]
    - [it586qn05, itertools.combinations.__qualname__.__eq__, ["combinations"], true]
    - [it586qn06, itertools.permutations.__qualname__.__eq__, ["permutations"], true]
    - [it586qn07, itertools.groupby.__qualname__.__eq__, ["groupby"], true]
    - [it586qn08, itertools.islice.__qualname__.__eq__, ["islice"], true]
    - [it586qn09, itertools.compress.__qualname__.__eq__, ["compress"], true]
    - [it586qn10, itertools.repeat.__qualname__.__eq__, ["repeat"], true]

table it586md:
  description: "itertools class __module__ identity"
  columns: [id, function, args, expected]
  rows:
    - [it586md01, itertools.chain.__module__.__eq__, ["itertools"], true]
    - [it586md02, itertools.cycle.__module__.__eq__, ["itertools"], true]
    - [it586md03, itertools.product.__module__.__eq__, ["itertools"], true]
    - [it586md04, itertools.count.__module__.__eq__, ["itertools"], true]
