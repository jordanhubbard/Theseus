spec: abc_extra79
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra78.zspec.zsdl."
    - "This spec covers: wave 246 theme — abc module ABCMeta/ABC __dict__ method count and get_cache_token/update_abstractmethods identity. NOTE: abc module does not define __all__ in Python 3.14.3. NEW in extra79: ABCMeta.__dict__.__len__()==11; ABC.__dict__.__len__()==7; abstractmethod.__dict__.__len__()==0; ABCMeta.__dict__.__contains__('register')==True; ABCMeta.__dict__.__contains__('__new__')==True; ABCMeta.__dict__.__contains__('__instancecheck__')==True; ABCMeta.__dict__.__contains__('__subclasscheck__')==True; ABC.__dict__.__contains__('__slots__')==True; ABC.__dict__.__contains__('__abstractmethods__')==True; ABC.__dict__.__contains__('_abc_impl')==True; get_cache_token.__class__.__name__=='builtin_function_or_method'; update_abstractmethods.__class__.__name__=='function'; get_cache_token.__module__=='_abc'; update_abstractmethods.__module__=='abc'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__len__() == 11. ABCMeta defines 11 entries in its class dict including __new__, register, __instancecheck__, __subclasscheck__, etc. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__len__() == 7. ABC defines 7 entries in its class dict including __slots__, __abstractmethods__, _abc_impl, etc. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__dict__.__len__() == 0. abstractmethod has an empty instance dict (it uses __slots__ or stores attributes on instances directly). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('register') == True. register is defined directly on ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('__new__') == True. __new__ is defined directly on ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True. __instancecheck__ is defined directly on ABCMeta to support isinstance() with abstract classes. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True. __subclasscheck__ is defined directly on ABCMeta to support issubclass() with abstract classes. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__contains__('__slots__') == True. ABC defines __slots__ directly. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__contains__('__abstractmethods__') == True. ABC defines __abstractmethods__ directly. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__contains__('_abc_impl') == True. ABC defines _abc_impl directly. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method'. get_cache_token is a C-level builtin from _abc module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__class__.__name__ == 'function'. update_abstractmethods is a regular Python function defined in abc.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__module__ == '_abc'. get_cache_token is defined in the C extension _abc module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__module__ == 'abc'. update_abstractmethods is defined in the abc Python module. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc ABCMeta and ABC __dict__.__len__() checks — extra79
#
# Wave 246 theme: abc ABCMeta/ABC __dict__ method count and helper function identity.
#
# ABCMeta.__dict__.__len__() == 11
# ABC.__dict__.__len__() == 7
# abstractmethod.__dict__.__len__() == 0
# ---------------------------------------------------------------------------

table abc_extra79.dict_lengths:
  description: "abc ABCMeta, ABC, and abstractmethod __dict__.__len__() checks in abcextra79 namespace — wave 246 theme: abc module ABCMeta/ABC __dict__ method count; ABCMeta.__dict__.__len__()==11 (ABCMeta defines 11 entries including __new__, register, __instancecheck__, __subclasscheck__); ABC.__dict__.__len__()==7 (ABC defines 7 entries including __slots__, __abstractmethods__, _abc_impl); abstractmethod.__dict__.__len__()==0 (abstractmethod class has an empty instance dict); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra79

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_len,  "ABCMeta.__dict__.__len__",      [], 11, "ABCMeta.__dict__.__len__() == 11 — ABCMeta defines 11 entries in its class dict; verified with Python 3.14.3"]
    - [abc_dict_len,      "ABC.__dict__.__len__",          [], 7,  "ABC.__dict__.__len__() == 7 — ABC defines 7 entries in its class dict; verified with Python 3.14.3"]
    - [am_dict_len,       "abstractmethod.__dict__.__len__", [], 0, "abstractmethod.__dict__.__len__() == 0 — abstractmethod has an empty instance dict; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABCMeta __dict__ membership checks — extra79
#
# ABCMeta.__dict__.__contains__('register') == True
# ABCMeta.__dict__.__contains__('__new__') == True
# ABCMeta.__dict__.__contains__('__instancecheck__') == True
# ABCMeta.__dict__.__contains__('__subclasscheck__') == True
# ---------------------------------------------------------------------------

table abc_extra79.ABCMeta_dict_membership:
  description: "abc ABCMeta __dict__ membership checks in abcextra79 namespace — wave 246 theme: abc ABCMeta __dict__ method count and membership; ABCMeta.__dict__.__contains__('register')==True (register is defined directly on ABCMeta); ABCMeta.__dict__.__contains__('__new__')==True; ABCMeta.__dict__.__contains__('__instancecheck__')==True (supports isinstance() with abstract classes); ABCMeta.__dict__.__contains__('__subclasscheck__')==True (supports issubclass() with abstract classes); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra79a

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_has_register,         "ABCMeta.__dict__.__contains__", ["register"],         true, "ABCMeta.__dict__.__contains__('register') == True — register is defined directly on ABCMeta; verified with Python 3.14.3"]
    - [abcmeta_has_new,              "ABCMeta.__dict__.__contains__", ["__new__"],          true, "ABCMeta.__dict__.__contains__('__new__') == True — __new__ is defined directly on ABCMeta; verified with Python 3.14.3"]
    - [abcmeta_has_instancecheck,    "ABCMeta.__dict__.__contains__", ["__instancecheck__"], true, "ABCMeta.__dict__.__contains__('__instancecheck__') == True — supports isinstance() with abstract classes; verified with Python 3.14.3"]
    - [abcmeta_has_subclasscheck,    "ABCMeta.__dict__.__contains__", ["__subclasscheck__"], true, "ABCMeta.__dict__.__contains__('__subclasscheck__') == True — supports issubclass() with abstract classes; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABC __dict__ membership checks — extra79
#
# ABC.__dict__.__contains__('__slots__') == True
# ABC.__dict__.__contains__('__abstractmethods__') == True
# ABC.__dict__.__contains__('_abc_impl') == True
# ---------------------------------------------------------------------------

table abc_extra79.ABC_dict_membership:
  description: "abc ABC __dict__ membership checks in abcextra79 namespace — wave 246 theme: abc ABC __dict__ membership; ABC.__dict__.__contains__('__slots__')==True; ABC.__dict__.__contains__('__abstractmethods__')==True; ABC.__dict__.__contains__('_abc_impl')==True; ABCMeta.__dict__.__contains__('register')==True (cross-check); these entries confirm ABC's lightweight structure with slots and abstract method tracking; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra79b

  columns: [id, function, args, expected, description]
  rows:
    - [abc_has_slots,           "ABC.__dict__.__contains__", ["__slots__"],          true, "ABC.__dict__.__contains__('__slots__') == True — ABC defines __slots__ directly; verified with Python 3.14.3"]
    - [abc_has_abstractmethods, "ABC.__dict__.__contains__", ["__abstractmethods__"], true, "ABC.__dict__.__contains__('__abstractmethods__') == True — ABC defines __abstractmethods__ directly; verified with Python 3.14.3"]
    - [abc_has_abc_impl,        "ABC.__dict__.__contains__", ["_abc_impl"],          true, "ABC.__dict__.__contains__('_abc_impl') == True — ABC defines _abc_impl directly; verified with Python 3.14.3"]
    - [abcmeta_reg_cross,       "ABCMeta.__dict__.__contains__", ["register"],       true, "ABCMeta.__dict__.__contains__('register') == True — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc get_cache_token and update_abstractmethods identity — extra79
#
# get_cache_token.__class__.__name__ == 'builtin_function_or_method'
# update_abstractmethods.__class__.__name__ == 'function'
# get_cache_token.__module__ == '_abc'
# update_abstractmethods.__module__ == 'abc'
# ---------------------------------------------------------------------------

table abc_extra79.helper_function_identity:
  description: "abc get_cache_token and update_abstractmethods identity checks in abcextra79 namespace — wave 246 theme: abc helper function identity; get_cache_token.__class__.__name__=='builtin_function_or_method' (get_cache_token is a C-level builtin from _abc module); update_abstractmethods.__class__.__name__=='function' (update_abstractmethods is a regular Python function); get_cache_token.__module__=='_abc' (defined in C extension _abc); update_abstractmethods.__module__=='abc' (defined in abc.py); ABCMeta.__dict__.__len__()==11 (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcextra79c

  columns: [id, function, args, expected, description]
  rows:
    - [gct_class,   get_cache_token.__class__.__name__.__eq__,    ["builtin_function_or_method"], true, "get_cache_token.__class__.__name__ == 'builtin_function_or_method' — get_cache_token is a C-level builtin from _abc; verified with Python 3.14.3"]
    - [uam_class,   update_abstractmethods.__class__.__name__.__eq__, ["function"],               true, "update_abstractmethods.__class__.__name__ == 'function' — update_abstractmethods is a regular Python function; verified with Python 3.14.3"]
    - [gct_module,  get_cache_token.__module__.__eq__,            ["_abc"],                       true, "get_cache_token.__module__ == '_abc' — defined in the C extension _abc module; verified with Python 3.14.3"]
    - [uam_module,  update_abstractmethods.__module__.__eq__,     ["abc"],                        true, "update_abstractmethods.__module__ == 'abc' — defined in the abc Python module; verified with Python 3.14.3"]
    - [abcmeta_len_cross, "ABCMeta.__dict__.__len__",             [],                             11,   "ABCMeta.__dict__.__len__() == 11 — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra79
# ---------------------------------------------------------------------------

invariant abc_extra79.ABCMeta_dict_len:
  description: "abc.ABCMeta.__dict__.__len__() == 11 — ABCMeta defines 11 entries in its class dict including __new__, register, __instancecheck__, __subclasscheck__, _dump_registry, _abc_registry_clear, _abc_caches_clear, and other dunder methods; NEW in extra79: first standalone __dict__.__len__ invariant for ABCMeta in abcextra79 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__dict__.__len__
  args: []
  expected: 11

invariant abc_extra79.ABC_dict_len:
  description: "abc.ABC.__dict__.__len__() == 7 — ABC defines 7 entries in its class dict: __module__, __firstlineno__, __doc__, __slots__, __static_attributes__, __abstractmethods__, _abc_impl; NEW in extra79: first standalone __dict__.__len__ invariant for ABC in abcextra79 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABC.__dict__.__len__
  args: []
  expected: 7

invariant abc_extra79.ABCMeta_has_register:
  description: "abc.ABCMeta.__dict__.__contains__('register') returns True — register is defined directly on ABCMeta to allow registering virtual subclasses; NEW in extra79: first standalone __dict__.__contains__ invariant for ABCMeta.register in abcextra79 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__dict__.__contains__
  args: ["register"]
  expected: true

invariant abc_extra79.get_cache_token_module:
  description: "abc.get_cache_token.__module__.__eq__('_abc') returns True — get_cache_token is implemented in the C extension _abc module, not in the pure-Python abc module; NEW in extra79: first standalone __module__ invariant for get_cache_token in abcextra79 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra79.update_abstractmethods_class:
  description: "abc.update_abstractmethods.__class__.__name__.__eq__('function') returns True — update_abstractmethods is a regular Python function defined in abc.py, unlike get_cache_token which is a C-level builtin; NEW in extra79: first standalone __class__.__name__ invariant for update_abstractmethods in abcextra79 namespace; wave 246; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: update_abstractmethods.__class__.__name__.__eq__
  args: ["function"]
  expected: true
