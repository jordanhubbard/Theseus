spec: io_extra2191
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2191: context manager protocol dict-presence checks — __enter__, __exit__, __aenter__, __aexit__, acquire, release, __wrapped__, __closure__."
    - "io.IOBase is a Python-level ABC; its __dict__ does NOT contain __enter__ or __exit__ because the concrete implementation lives in _io._IOBase (C extension)."
    - "io.RawIOBase, io.BufferedIOBase, io.TextIOBase are also Python ABCs with similarly sparse __dict__ entries."
    - "io.StringIO, io.BytesIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.TextIOWrapper are thin wrappers over the corresponding _io C classes; none define __enter__ or __exit__ in their own __dict__."
    - "No io-module class defines __aenter__, __aexit__, acquire, release, __wrapped__, or __closure__ in its own __dict__."
    - "The actual context manager support for all file-like objects is provided by _io._IOBase.__enter__ and _io._IOBase.__exit__ via the C type slot mechanism, not by Python-level __dict__ entries."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table io_extra2191.iobase_context_protocol:
  description: "io.IOBase dict-presence checks for context manager and lock protocol keys"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2191

  columns: [id, function, args, expected]
  rows:
    - ["io2191001", "io.IOBase.__dict__.__contains__", ["__enter__"], false]
    - ["io2191002", "io.IOBase.__dict__.__contains__", ["__exit__"], false]
    - ["io2191003", "io.IOBase.__dict__.__contains__", ["__aenter__"], false]
    - ["io2191004", "io.IOBase.__dict__.__contains__", ["__aexit__"], false]
    - ["io2191005", "io.IOBase.__dict__.__contains__", ["acquire"], false]
    - ["io2191006", "io.IOBase.__dict__.__contains__", ["release"], false]
    - ["io2191007", "io.IOBase.__dict__.__contains__", ["__wrapped__"], false]
    - ["io2191008", "io.IOBase.__dict__.__contains__", ["__closure__"], false]

