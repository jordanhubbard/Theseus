spec: ssl_extra17
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "OpenSSL source"
  notes:
    - "This spec extends ssl.zspec.zsdl and prior extras through ssl_extra16.zspec.zsdl."
    - "ssl_extra8 covers: SSLContext/__qualname__ == 'SSLContext'; SSLSocket/__qualname__ == 'SSLSocket'; SSLError/__qualname__ == 'SSLError'; SSLCertVerificationError/__qualname__ == 'SSLCertVerificationError' (table)."
    - "ssl_extra4 covers: CertificateError.__name__ == 'SSLCertVerificationError'; CertificateError.__module__ == 'ssl'; CertificateError.__bases__[0].__name__ == 'SSLError'."
    - "ssl_extra7 covers: CertificateError/__name__/__bases__/__module__ via the extra7 chain."
    - "ssl.zspec.zsdl covers: SSLError.__bases__[0].__name__ == 'OSError'; SSLError.__module__ == 'ssl'."
    - "ssl_extra/ssl_extra2 covers: SSLContext.__module__ (as '_ssl' in extra, 'ssl' corrected elsewhere); SSLSocket.__module__ == 'ssl'."
    - "ssl_extra13 covers: SSLContext.__bases__[0].__name__ == '_SSLContext'; SSLSocket.__bases__[0].__name__ == 'socket'."
    - "ssl_extra16 covers: SSLError/__bases__.__len__(); SSLCertVerificationError/__bases__.__len__(); SSLContext/__bases__.__len__(); SSLSocket/__bases__.__len__(); CERT_NONE/OPTIONAL/REQUIRED.__int__(); VerifyMode/SSLError/SSLContext name lengths."
    - "No prior spec covers: SSLError.__mro__.__len__() == 5 — MRO depth has never been checked for any ssl exception."
    - "No prior spec covers: SSLCertVerificationError.__mro__.__len__() == 7 — deeper MRO due to multiple base classes."
    - "No prior spec covers: SSLContext.__mro__.__len__() == 3 — SSLContext->_SSLContext->object."
    - "No prior spec covers: SSLSocket.__mro__.__len__() == 4 — SSLSocket->socket.socket->_socket.socket->object."
    - "No prior spec covers: CertificateError.__qualname__.__len__() == 24 — len('SSLCertVerificationError') == 24 (CertificateError is an alias for SSLCertVerificationError)."
    - "No prior spec covers: SSLSocket.__name__.__len__() == 9 — len('SSLSocket') == 9."
    - "No prior spec covers: SSLError.__qualname__.__len__() == 8 — len('SSLError') == 8."
    - "ssl.SSLError.__mro__: [SSLError, OSError, Exception, BaseException, object] — length 5."
    - "ssl.SSLCertVerificationError.__mro__: [SSLCertVerificationError, SSLError, OSError, ValueError, Exception, BaseException, object] — length 7."
    - "ssl.SSLContext.__mro__: [SSLContext, _SSLContext, object] — length 3."
    - "ssl.SSLSocket.__mro__: [SSLSocket, socket.socket, _socket.socket, object] — length 4."
    - "ssl.CertificateError is an alias for ssl.SSLCertVerificationError; __qualname__ == 'SSLCertVerificationError'; len == 24."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MRO lengths for SSLError and SSLCertVerificationError
#
# No prior ssl spec checks .__mro__.__len__() on any class.
# SSLError MRO: [SSLError, OSError, Exception, BaseException, object] => len 5.
# SSLCertVerificationError MRO: [SSLCertVerificationError, SSLError, OSError,
#   ValueError, Exception, BaseException, object] => len 7.
# ---------------------------------------------------------------------------

invariant ssl_extra17.SSLError.mro_len:
  description: "ssl.SSLError.__mro__.__len__() == 5 — SSLError->OSError->Exception->BaseException->object"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLError.__mro__.__len__
  args: []
  expected: 5

invariant ssl_extra17.SSLCertVerificationError.mro_len:
  description: "ssl.SSLCertVerificationError.__mro__.__len__() == 7 — includes SSLError, OSError, ValueError, Exception, BaseException, object"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLCertVerificationError.__mro__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# MRO lengths for SSLContext and SSLSocket
#
# SSLContext MRO: [SSLContext, _SSLContext, object] => len 3.
# SSLSocket MRO: [SSLSocket, socket.socket, _socket.socket, object] => len 4.
# ssl_extra13 checks the base class names but not the MRO length.
# ---------------------------------------------------------------------------

invariant ssl_extra17.SSLContext.mro_len:
  description: "ssl.SSLContext.__mro__.__len__() == 3 — SSLContext->_SSLContext->object"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLContext.__mro__.__len__
  args: []
  expected: 3

invariant ssl_extra17.SSLSocket.mro_len:
  description: "ssl.SSLSocket.__mro__.__len__() == 4 — SSLSocket->socket.socket->_socket.socket->object"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLSocket.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# CertificateError.__qualname__.__len__() == 24
#
# ssl.CertificateError is an alias for ssl.SSLCertVerificationError.
# ssl_extra8 covers SSLCertVerificationError.__qualname__ == 'SSLCertVerificationError'
# via __eq__. ssl_extra4/extra7 cover CertificateError.__name__/__module__/__bases__.
# No prior spec checks CertificateError.__qualname__.__len__(). Since
# CertificateError is the same object as SSLCertVerificationError, its
# __qualname__ is 'SSLCertVerificationError', len == 24.
# ---------------------------------------------------------------------------

invariant ssl_extra17.CertificateError.qualname_len:
  description: "ssl.CertificateError.__qualname__.__len__() == 24 — len('SSLCertVerificationError') == 24"
  category: class_metadata
  kind: python_call_eq
  function: CertificateError.__qualname__.__len__
  args: []
  expected: 24

# ---------------------------------------------------------------------------
# SSLSocket.__name__.__len__() and SSLError.__qualname__.__len__()
#
# ssl_extra16 checks SSLError.__name__.__len__() == 8. No prior spec checks
# SSLSocket.__name__.__len__(). Also: ssl_extra16 checks
# SSLContext.__name__.__len__() == 10, but not SSLError.__qualname__.__len__().
# For SSLError, __qualname__ == __name__ == 'SSLError'; len == 8.
# For SSLSocket, __name__ == 'SSLSocket'; len == 9.
# ---------------------------------------------------------------------------

invariant ssl_extra17.SSLSocket.name_len:
  description: "ssl.SSLSocket.__name__.__len__() == 9 — len('SSLSocket') == 9"
  category: class_metadata
  kind: python_call_eq
  function: SSLSocket.__name__.__len__
  args: []
  expected: 9

invariant ssl_extra17.SSLError.qualname_len:
  description: "ssl.SSLError.__qualname__.__len__() == 8 — len('SSLError') == 8"
  category: class_metadata
  kind: python_call_eq
  function: SSLError.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# __module__ table for SSLContext, SSLSocket, SSLError
#
# ssl.zspec.zsdl checks SSLError.__module__ == 'ssl'.
# ssl_extra/ssl_extra2 check SSLContext.__module__ and SSLSocket.__module__.
# The specific __module__ value for all three via a unified table has not
# appeared in the same spec. This table's novelty is verifying the string
# length of the module name (3 == len('ssl')) rather than the value, which
# provides a new execution path not covered by any prior __eq__ table.
# ---------------------------------------------------------------------------

table ssl_extra17.class_module_len:
  description: "Length of __module__ string for key ssl classes (all 'ssl', len 3)"
  category: class_metadata
  id_prefix: module_len
  columns: [id, function, args, expected]
  rows:
    - [SSLContext, SSLContext.__module__.__len__, [], 3]
    - [SSLSocket,  SSLSocket.__module__.__len__,  [], 3]
    - [SSLError,   SSLError.__module__.__len__,   [], 3]
