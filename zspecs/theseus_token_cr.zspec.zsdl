spec: theseus_token_cr
version: ">=3.8"
backend: python_cleanroom(theseus_token_cr)
blocks: token

docs: https://docs.python.org/3/library/token.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/token.html"
  not_derived_from:
    - "CPython source: Lib/token.py (internal implementation)"
  notes:
    - "Clean-room token constants. Do NOT import token."
    - "Constants: ENDMARKER=0, NAME=1, NUMBER=2, STRING=3, OP=54, etc."
    - "tok_name: dict mapping token type int to name string."
    - "EXACT_TYPE: dict mapping op string to token type."
    - "iseof(type): True if type == ENDMARKER."

error_model: python_exceptions

invariant theseus_token_cr.token2_name_value:
  description: "NAME == 1"
  category: constants
  kind: python_call_eq
  function: token2_name_value
  args: []
  expected: 1

invariant theseus_token_cr.token2_tok_name:
  description: "tok_name[1] == 'NAME'"
  category: tok_name
  kind: python_call_eq
  function: token2_tok_name
  args: []
  expected: "NAME"

invariant theseus_token_cr.token2_iseof:
  description: "iseof(ENDMARKER) is True"
  category: iseof
  kind: python_call_eq
  function: token2_iseof
  args: []
  expected: true
