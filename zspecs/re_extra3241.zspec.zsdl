spec: re3241
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 663 (re3241): __rtruediv__, __rfloordiv__, __rmod__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __rtruediv__, __rfloordiv__, __rmod__ dict-presence (reflected division/modulo)."
    - "No re class defines __rtruediv__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; re.RegexFlag is an IntFlag subclass but reflected division is not part of the IntFlag protocol."
    - "No re class defines __rfloordiv__ in its own __dict__: re types are not numeric operands; reflected floor division is not defined on any re type."
    - "No re class defines __rmod__ in its own __dict__: reflected modulo is not defined on any re type."
    - "re.RegexFlag is defined as class RegexFlag(enum.IntFlag): the reflected division/modulo methods __rtruediv__, __rfloordiv__, __rmod__ are not defined on IntFlag; these are not bitwise flag operations."
    - "operator.contains(re.RegexFlag.__dict__, '__rtruediv__') = False: not present in the class-own dict."
    - "Key finding: decimal.Decimal defines all 3 reflected operators — consistent with wave 662 (__radd__/__rsub__/__rmul__ all true)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __rtruediv__ dict-presence — operator.contains(Cls.__dict__, '__rtruediv__')
#
# No re class defines __rtruediv__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but reflected division is not part of the flag protocol.
# ---------------------------------------------------------------------------

table re3241.rtruediv:
  description: "re types __rtruediv__ dict-presence checks; wave 663"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3241

  columns: [id, function, args, expected]
  rows:
    - ["re3241001", operator.contains, [re.Pattern.__dict__,   "__rtruediv__"], false]
    - ["re3241002", operator.contains, [re.Match.__dict__,     "__rtruediv__"], false]
    - ["re3241003", operator.contains, [re.RegexFlag.__dict__, "__rtruediv__"], false]

