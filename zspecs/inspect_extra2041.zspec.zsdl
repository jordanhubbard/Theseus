spec: inspect_extra2041
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rshift__, __and__, __or__, __xor__, __invert__ dict-presence checks."
    - "inspect.Parameter, inspect.Signature, and inspect.BoundArguments are not bitwise types — none define bitwise operators."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table inspect_extra2041.lshift_protocol:
  description: "inspect types __lshift__/__rlshift__/__ilshift__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2041
  columns: [id, function, args, expected]
  rows:
    - ["in2041001", "inspect.Parameter.__dict__.__contains__",      ["__lshift__"],  false]
    - ["in2041002", "inspect.Signature.__dict__.__contains__",      ["__lshift__"],  false]
    - ["in2041003", "inspect.BoundArguments.__dict__.__contains__", ["__lshift__"],  false]
    - ["in2041004", "inspect.Parameter.__dict__.__contains__",      ["__rlshift__"], false]
    - ["in2041005", "inspect.Signature.__dict__.__contains__",      ["__rlshift__"], false]
    - ["in2041006", "inspect.BoundArguments.__dict__.__contains__", ["__rlshift__"], false]
    - ["in2041007", "inspect.Parameter.__dict__.__contains__",      ["__ilshift__"], false]
    - ["in2041008", "inspect.Signature.__dict__.__contains__",      ["__ilshift__"], false]
    - ["in2041009", "inspect.BoundArguments.__dict__.__contains__", ["__ilshift__"], false]

