spec: wide_align
version: ">=1.0.0"
backend: node(wide-align)

docs: https://github.com/iarna/wide-align#readme

provenance:
  derived_from:
    - "wide-align README — https://github.com/iarna/wide-align#readme"
    - "Test vectors verified with wide-align via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "wide-align source"
  notes:
    - "Pad strings left/right/center accounting for Unicode display width."
    - "Install: npm install wide-align"
    - "v1 CJS; named exports left / right / center."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant wide_align.left_pads_right:
  description: "left('hi', 10) is 'hi' followed by 8 spaces"
  category: align
  kind: node_chain_eq
  entry: named
  function: left
  entry_args: ["hi", 10]
  chain: []
  expected: "hi        "

invariant wide_align.right_pads_left:
  description: "right('hi', 10) is 8 spaces followed by 'hi'"
  category: align
  kind: node_chain_eq
  entry: named
  function: right
  entry_args: ["hi", 10]
  chain: []
  expected: "        hi"

invariant wide_align.center_balances:
  description: "center('hi', 10) is '    hi    ' (4 spaces each side)"
  category: align
  kind: node_chain_eq
  entry: named
  function: center
  entry_args: ["hi", 10]
  chain: []
  expected: "    hi    "

invariant wide_align.left_already_wide_passthrough:
  description: "left('hello world', 5) returns input unchanged when wider than target"
  category: align
  kind: node_chain_eq
  entry: named
  function: left
  entry_args: ["hello world", 5]
  chain: []
  expected: "hello world"

invariant wide_align.left_exact_length:
  description: "left('hello', 5) returns input unchanged"
  category: align
  kind: node_chain_eq
  entry: named
  function: left
  entry_args: ["hello", 5]
  chain: []
  expected: "hello"

invariant wide_align.left_zero_target_passthrough:
  description: "left('hi', 0) returns input unchanged"
  category: edge
  kind: node_chain_eq
  entry: named
  function: left
  entry_args: ["hi", 0]
  chain: []
  expected: "hi"

invariant wide_align.right_already_wide_passthrough:
  description: "right on already-wide input passes through"
  category: align
  kind: node_chain_eq
  entry: named
  function: right
  entry_args: ["hello", 3]
  chain: []
  expected: "hello"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:26:50Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
