# ---------------------------------------------------------------------------
# Table 2: functools.total_ordering — Python function doc, qualname, argcount
#
# Wave 269 theme: functools.total_ordering — pure Python class decorator.
#
# functools.total_ordering.__doc__.__class__.__name__ == 'str'
# len(functools.total_ordering.__doc__) == 54
# functools.total_ordering.__qualname__ == 'total_ordering' (len 14)
# functools.total_ordering.__module__ == 'functools' (len 9)
# functools.total_ordering.__code__.co_argcount == 1
#
# total_ordering fills in missing comparison methods (__lt__, __le__, etc.)
# given __eq__ and one of __lt__/__le__/__gt__/__ge__. New to extra146.
# ---------------------------------------------------------------------------

