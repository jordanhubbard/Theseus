spec: functools_extra146
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.cmp_to_key (C builtin), functools.total_ordering (Python function), functools.singledispatch (Python function), functools.singledispatchmethod (Python class) — doc string class, doc string len, __qualname__, __module__, co_argcount, co_cellvars, MRO (Wave 269)."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — C builtin from _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__doc__ len == 94. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len 10). Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == '_functools' (len 10). Verified with Python 3.14.3."
    - "functools.total_ordering.__doc__ len == 54. Verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering' (len 14). Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_argcount == 1 (cls). Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__ len == 339. Verified with Python 3.14.3."
    - "functools.singledispatch.__qualname__ == 'singledispatch' (len 14). Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_argcount == 1 (func). Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_cellvars len == 7. Verified with Python 3.14.3."
    - "functools.singledispatch.__code__.co_freevars len == 0. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__doc__ len == 84. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__name__ == 'singledispatchmethod' (len 20). Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__module__ == 'functools' (len 9). Verified with Python 3.14.3."
    - "len(functools.singledispatchmethod.__mro__) == 2 — MRO is [singledispatchmethod, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.cmp_to_key — C builtin identity, doc, qualname, module
#
# Wave 269 theme: functools.cmp_to_key — C builtin_function_or_method.
#
# functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method'
# len(functools.cmp_to_key.__doc__) == 94
# functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len 10)
# functools.cmp_to_key.__module__ == '_functools' (len 10)
#
# cmp_to_key wraps an old-style comparison function into a key function.
# It is implemented in _functoolsmodule.c alongside reduce. New to extra146.
# ---------------------------------------------------------------------------

