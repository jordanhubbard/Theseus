spec: hashlib_extra165
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra164.zspec.zsdl — covers hashlib.algorithms_available and hashlib.algorithms_guaranteed set membership — algorithms_available.__class__.__name__.__eq__('set') / algorithms_guaranteed.__class__.__name__.__eq__('set') / algorithms_guaranteed.__contains__('sha256') / algorithms_guaranteed.__contains__('md5') / algorithms_guaranteed.__len__()==14 / algorithms_available.__len__()==19 (table + invariants)."
    - "hashlib_extra163.zspec.zsdl — covers hashlib sha3 family and blake2 family constructor __name__ and __module__ identity (sha3_256/__name__/__module__, sha3_512/__name__/__module__, blake2b/__name__/__module__, blake2s/__name__/__module__); also sha3/blake2 __name__ length comparison table."
    - "hashlib_extra162.zspec.zsdl — covers hashlib.sha256.__name__.__eq__('openssl_sha256') / md5.__name__.__eq__('openssl_md5') / sha256.__module__.__eq__('_hashlib') / md5.__module__.__eq__('_hashlib') / sha256/__doc__/__len__() / md5/__doc__/__len__() ordering (table + invariants)."
    - "hashlib_extra160.zspec.zsdl — covers hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') / new.__qualname__.__eq__('__hash_new') / new.__class__.__name__.__eq__('function') / algorithms_guaranteed.__class__.__name__.__eq__('set') (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra164."
    - "Wave 344 theme: hashlib sha256/md5/sha512 constructor class-level type identity — sha256.__class__.__name__.__eq__('builtin_function_or_method') / md5.__class__.__name__.__eq__('builtin_function_or_method') / sha512.__class__.__name__.__eq__('builtin_function_or_method') / sha256.__module__.__eq__('_hashlib') / sha256.__doc__.__class__.__name__.__eq__('str') / sha256.__doc__.__len__()==66 / md5.__doc__.__len__()==63. All are class-level attributes of the constructor objects, requiring no instance creation."
    - "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__doc__.__len__() == 66. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__ == '_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__doc__.__len__() == 63. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__class__.__name__.__len__() == 26. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.sha256.__class__.__name__ == 'builtin_function_or_method' (26 chars = 'builtin_function_or_method'). The sha256 constructor is a builtin_function_or_method from the _hashlib C extension, not a Python 'type' or 'function'. It is the C-level function that creates HASH instances when called. The class name 'builtin_function_or_method' (26 chars) is the same for sha256, md5, and sha512, because all three are C-extension constructors from _hashlib. Contrast with blake2b and blake2s which are 'type' objects (extra163 anchors blake2b.__class__.__name__=='type'... wait, actually blake2b.__class__.__name__ is 'type' as a class). Here sha256 is a builtin_function_or_method (not a type). These are class-level attributes accessed without creating an instance."
    - "Note: hashlib.sha256.__doc__.__len__() == 66. The sha256 constructor docstring is 66 chars long. It describes the sha256() constructor signature. This is distinct from the HASH instance methods doc. sha256.__doc__.__class__.__name__ == 'str' (the docstring is a str object). md5.__doc__.__len__() == 63 (3 chars shorter than sha256 because the algorithm name 'openssl_md5' = 11 chars vs 'openssl_sha256' = 14 chars). The docstrings are generated at the C level for each builtin_function_or_method."
    - "Note: hashlib.sha256.__module__ == '_hashlib' (8 chars). sha256 and md5 share the same __module__ == '_hashlib'. The leading underscore indicates a private C extension module. '_hashlib' is the module where both sha256 and md5 constructors are defined. extra162 anchors sha256.__module__=='_hashlib' as a table row; this spec anchors the __class__.__name__ as the primary novel content. sha256.__class__.__name__=='builtin_function_or_method' (26 chars) reflects that sha256 is a callable C function, not a type object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha512.__class__.__name__.__eq__('builtin_function_or_method')
# hashlib.sha256.__module__.__eq__('_hashlib')
#
# Wave 344 theme: sha256/md5/sha512 constructor class-level type identity.
#
# sha256.__class__.__name__ == 'builtin_function_or_method' (26 chars).
# md5.__class__.__name__ == 'builtin_function_or_method' (26 chars; ties sha256).
# sha512.__class__.__name__ == 'builtin_function_or_method' (26 chars; ties sha256/md5).
# sha256.__module__ == '_hashlib' (8 chars; same module as md5/sha512).
# No prior hashlib spec anchors sha256/__class__.__name__ as a table under hashcls165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra165.sha256_md5_sha512_constructor_class_identity:
  description: "hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method')==True / md5.__class__.__name__.__eq__('builtin_function_or_method')==True / sha512.__class__.__name__.__eq__('builtin_function_or_method')==True / sha256.__module__.__eq__('_hashlib')==True — sha256.__class__.__name__ is 'builtin_function_or_method' (26 chars; C-level callable from _hashlib; NOT a 'type' object; sha256 is a constructor function, not a class; extra162 anchors sha256.__module__=='_hashlib' as a row); md5.__class__.__name__ is 'builtin_function_or_method' (26 chars; ties sha256; same C extension; extra162 anchors md5.__module__=='_hashlib'); sha512.__class__.__name__ is 'builtin_function_or_method' (26 chars; ties sha256 and md5; all three OpenSSL-backed constructors share same type); sha256.__module__ is '_hashlib' (8 chars; confirmed; extra162 anchors as row; repeated here for completeness); first hashcls165 anchor for sha256/__class__/__name__ as a table"
  kind: python_call_eq
  category: identity
  id_prefix: hashcls165

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_cls_bfom,   "sha256.__class__.__name__.__eq__",  ["builtin_function_or_method"], true, "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method' (26 chars; C callable from _hashlib; not a 'type'; constructor function)"]
    - [md5_cls_bfom,      "md5.__class__.__name__.__eq__",     ["builtin_function_or_method"], true, "hashlib.md5.__class__.__name__ == 'builtin_function_or_method' (26 chars; ties sha256; same C extension; extra162 anchors md5.__module__)"]
    - [sha512_cls_bfom,   "sha512.__class__.__name__.__eq__",  ["builtin_function_or_method"], true, "hashlib.sha512.__class__.__name__ == 'builtin_function_or_method' (26 chars; ties sha256 and md5; all three OpenSSL-backed constructors)"]
    - [sha256_module_hashlib, "sha256.__module__.__eq__",      ["_hashlib"],                   true, "hashlib.sha256.__module__ == '_hashlib' (8 chars; extra162 anchors as row; '_hashlib' is the C extension module for sha256/md5/sha512)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__class__.__name__.__eq__('str')
# hashlib.sha256.__doc__.__len__()==66
# hashlib.md5.__doc__.__len__()==63
# hashlib.md5.__module__.__eq__('_hashlib')
#
# Wave 344 theme: sha256 and md5 constructor docstring type and length identity.
#
# sha256.__doc__.__class__.__name__ == 'str' (3 chars; docstring is a str object).
# sha256.__doc__.__len__() == 66 (66-char constructor docstring).
# md5.__doc__.__len__() == 63 (63-char docstring; 3 chars shorter than sha256 due to name length).
# md5.__module__ == '_hashlib' (8 chars; same module as sha256).
# No prior hashlib spec anchors sha256/__doc__/__class__/__name__ or doc lengths as a table
# under hashcls165. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra165.sha256_md5_doc_type_and_length:
  description: "hashlib.sha256.__doc__.__class__.__name__.__eq__('str')==True / sha256.__doc__.__len__()==66 / md5.__doc__.__len__()==63 / md5.__module__.__eq__('_hashlib')==True — sha256.__doc__.__class__.__name__ is 'str' (3 chars; constructor docstring is a str object; C-level docstrings are exposed as str in Python); sha256.__doc__.__len__() is 66 (66 chars; the openssl_sha256 constructor docstring describes its signature); md5.__doc__.__len__() is 63 (63 chars; 3 chars shorter than sha256 because 'openssl_md5' = 11 chars vs 'openssl_sha256' = 14 chars, a 3-char difference); md5.__module__ is '_hashlib' (8 chars; confirmed; same C extension as sha256); ordering: md5_doc(63) < sha256_doc(66); difference of 3 matches the name length difference; first hashcls165 anchor for constructor doc type and lengths"
  kind: python_call_eq
  category: identity
  id_prefix: hashcls165

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_doc_class_str,    "sha256.__doc__.__class__.__name__.__eq__", ["str"], true, "hashlib.sha256.__doc__.__class__.__name__ == 'str' (3 chars; constructor docstring is a str object; C-level docstring exposed as Python str)"]
    - [sha256_doc_len_66,       "sha256.__doc__.__len__",                   [],     66,   "hashlib.sha256.__doc__.__len__() == 66 (66 chars; openssl_sha256 constructor docstring; Python 3.14.3 specific length)"]
    - [md5_doc_len_63,          "md5.__doc__.__len__",                      [],     63,   "hashlib.md5.__doc__.__len__() == 63 (63 chars; 3 chars shorter than sha256 doc; name 'openssl_md5'=11 vs 'openssl_sha256'=14, diff=3)"]
    - [md5_module_hashlib,      "md5.__module__.__eq__",                    ["_hashlib"], true, "hashlib.md5.__module__ == '_hashlib' (8 chars; confirmed; same C extension as sha256; extra162 anchors as row)"]

# ---------------------------------------------------------------------------
# sha256/md5/sha512 constructor class name length and type comparison
#
# Wave 344 theme: length ordering for constructor class attributes.
#
# sha256.__class__.__name__.__len__() == 26 ('builtin_function_or_method').
# sha256.__module__.__len__() == 8 ('_hashlib').
# sha256.__doc__.__class__.__name__.__len__() == 3 ('str').
# sha256.__doc__.__len__() == 66 (doc content).
# No prior hashlib spec anchors sha256/__class__/__name__/__len__() as a table under hashcls165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra165.sha256_constructor_attribute_lengths:
  description: "hashlib.sha256.__class__.__name__.__len__()==26 / sha256.__module__.__len__()==8 / sha256.__doc__.__class__.__name__.__len__()==3 / sha256.__doc__.__len__()==66 — sha256.__class__.__name__.__len__() is 26 ('builtin_function_or_method' = 26 chars; 'builtin_'=8 + 'function'=8 + '_or_'=4 + 'method'=6 = 26; longest attribute name here by far); sha256.__module__.__len__() is 8 ('_hashlib' = 8 chars; '_'=1 + 'hashlib'=7 = 8; private C extension with leading underscore); sha256.__doc__.__class__.__name__.__len__() is 3 ('str' = 3 chars; the docstring type name; shortest here); sha256.__doc__.__len__() is 66 (66 chars of docstring content; the openssl_sha256 constructor description); length ordering: str(3) < _hashlib(8) < doc_content(66) < builtin_function_or_method(26)... sorted: str(3) < _hashlib(8) < bfom(26) < doc(66); first hashcls165 anchor for constructor attribute lengths"
  kind: python_call_eq
  category: identity
  id_prefix: hashcls165

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_cls_name_len_26,   "sha256.__class__.__name__.__len__",        [], 26, "hashlib.sha256.__class__.__name__.__len__() is 26 ('builtin_function_or_method' = 26 chars; longest attribute name anchored here)"]
    - [sha256_module_len_8,      "sha256.__module__.__len__",                [], 8,  "hashlib.sha256.__module__.__len__() is 8 ('_hashlib' = '_'=1 + 'hashlib'=7 = 8; private C extension module name)"]
    - [sha256_doc_clsname_len_3, "sha256.__doc__.__class__.__name__.__len__", [], 3, "hashlib.sha256.__doc__.__class__.__name__.__len__() is 3 ('str' = 3 chars; type name of the docstring object; shortest name here)"]
    - [sha256_doc_len_66b,       "sha256.__doc__.__len__",                   [], 66, "hashlib.sha256.__doc__.__len__() is 66 (66 chars of constructor docstring content; Python 3.14.3 macOS specific)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.sha256.__class__.__name__ is 'builtin_function_or_method' (26 chars). The sha256
# constructor is a builtin_function_or_method from the _hashlib C extension. This is the type
# of C-level callable functions and methods exposed to Python via the Python/C API. It is
# NOT a 'type' object (which would indicate a class/type), nor a 'function' (which would
# indicate a Python-level function). 'builtin_function_or_method' (26 chars) = 'builtin_'=8
# + 'function'=8 + '_or_'=4 + 'method'=6 = 26. sha256, md5, and sha512 all share this same
# class name because they are all C-level callables from _hashlib. Contrast with blake2b
# and blake2s which are 'type' objects (they are C extension types, not C functions).
# No prior hashlib spec anchors sha256.__class__.__name__ as a standalone under hashcls165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra165.sha256_cls_bfom_standalone:
  description: "hashlib.sha256.__class__.__name__.__eq__('builtin_function_or_method') == True — 26 chars = 'builtin_'=8 + 'function'=8 + '_or_'=4 + 'method'=6; C-level callable from _hashlib C extension; NOT a 'type' object (no class); NOT a Python 'function' (no def); sha256 is a C builtin callable that creates HASH instances; sha512 and md5 also have __class__.__name__=='builtin_function_or_method' (all three tie at 26 chars); blake2b and blake2s are 'type' objects (different kind of C extension object); no prior hashlib spec anchors this as a standalone; first standalone under hashcls165"
  category: identity
  kind: python_call_eq
  function: sha256.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__len__()==66 — standalone
#
# hashlib.sha256.__doc__.__len__() is 66. The sha256 constructor's docstring is 66 chars long.
# The docstring is at the C level: it describes the openssl_sha256() constructor. sha256.__doc__
# is a str object (sha256.__doc__.__class__.__name__ == 'str'). The docstring length 66 reflects
# the format of the C-generated docstring for 'openssl_sha256'. md5.__doc__.__len__() == 63
# (3 chars shorter because 'openssl_md5' = 11 chars vs 'openssl_sha256' = 14 chars; difference
# of 3 matches exactly). sha256.__doc__.__len__() == 66 is specific to Python 3.14.3 macOS.
# No prior hashlib spec anchors sha256.__doc__.__len__()==66 as a standalone under hashcls165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra165.sha256_doc_len_66:
  description: "hashlib.sha256.__doc__.__len__() == 66 — 66 chars; C-level docstring for openssl_sha256 constructor; sha256.__doc__.__class__.__name__=='str' (str type); md5.__doc__.__len__()==63 (3 chars shorter; name length difference: 'openssl_sha256'=14 vs 'openssl_md5'=11, diff=3); length ordering: md5_doc(63) < sha256_doc(66); Python 3.14.3 macOS specific length; no prior hashlib spec anchors sha256.__doc__.__len__() as a standalone; first standalone under hashcls165"
  category: identity
  kind: python_call_eq
  function: sha256.__doc__.__len__
  args: []
  expected: 66

# ---------------------------------------------------------------------------
# hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.md5.__class__.__name__ is 'builtin_function_or_method' (26 chars). Like sha256 and
# sha512, md5 is a builtin_function_or_method from the _hashlib C extension. md5.__module__
# == '_hashlib' (extra162 anchors this as a row; same C extension as sha256). md5 is the
# oldest and most widely known hash function in hashlib, but despite its well-known name it
# shares the same internal C type as sha256 and sha512: builtin_function_or_method. All
# hashlib constructors that wrap OpenSSL's EVP API are builtin_function_or_method objects.
# No prior hashlib spec anchors md5.__class__.__name__ as a standalone under hashcls165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra165.md5_cls_bfom_standalone:
  description: "hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method') == True — 26 chars; same type as sha256 and sha512; all three are C-level callables from _hashlib C extension; md5.__module__=='_hashlib' (extra162 anchors as row); 'builtin_function_or_method'=26 chars; md5 is a builtin_function_or_method despite being a hash function, not a builtin type; md5.__doc__.__len__()==63 (3 chars shorter than sha256 doc); no prior hashlib spec anchors md5.__class__.__name__ as a standalone; first standalone under hashcls165"
  category: identity
  kind: python_call_eq
  function: md5.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__class__.__name__.__eq__('str') — standalone
#
# hashlib.sha256.__doc__.__class__.__name__ is 'str' (3 chars). The sha256 constructor's
# docstring is a Python str object. C-level docstrings provided via the Python/C API's
# PyMethodDef.ml_doc or similar mechanisms are automatically converted to Python str objects.
# 'str' (3 chars) is the type name. sha256.__doc__.__len__() == 66 (the content is 66 chars).
# This is the docstring of the sha256 *constructor* (the callable), not of a HASH instance.
# All three constructors (sha256, md5, sha512) have docstrings of type 'str'. No prior hashlib
# spec anchors sha256.__doc__.__class__.__name__ as a standalone under hashcls165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra165.sha256_doc_class_str_standalone:
  description: "hashlib.sha256.__doc__.__class__.__name__.__eq__('str') == True — 'str' (3 chars); sha256 constructor docstring is a Python str object; C-level docstrings are exposed as str via Python/C API; sha256.__doc__.__len__()==66 (66-char docstring content); docstring type 'str' (3 chars) is same for md5 and sha512 constructors; sha256.__doc__ is the constructor's docstring, not an instance method's docstring; no prior hashlib spec anchors sha256.__doc__.__class__.__name__ as a standalone; first standalone under hashcls165"
  category: identity
  kind: python_call_eq
  function: sha256.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

