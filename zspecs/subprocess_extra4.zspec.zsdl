spec: subprocess_extra4
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
  notes:
    - "Extends subprocess.zspec.zsdl, subprocess_extra.zspec.zsdl, subprocess_extra2.zspec.zsdl, subprocess_extra3.zspec.zsdl."
    - "subprocess.zspec.zsdl covers: class __name__ (CompletedProcess/CalledProcessError/TimeoutExpired/Popen/SubprocessError), function __name__ (run/call/check_call/check_output/getstatusoutput/getoutput), PIPE/STDOUT/DEVNULL integer values (-1/-2/-3), run() and check_output() live execution, CalledProcessError returncode/cmd, exception MRO via __mro__[1]."
    - "subprocess_extra.zspec.zsdl covers: CompletedProcess/SubprocessError/CalledProcessError/TimeoutExpired __module__; SubprocessError/CalledProcessError/TimeoutExpired __bases__[0] via __getitem__; PIPE/STDOUT/DEVNULL class name 'int'; run/call/check_call/check_output/getoutput/getstatusoutput class name 'function'."
    - "subprocess_extra2.zspec.zsdl covers: Popen.__module__; run.__module__; CalledProcessError.output/stderr defaults None; TimeoutExpired float timeout; run(check=True) returns CompletedProcess."
    - "subprocess_extra3.zspec.zsdl covers: CompletedProcess/TimeoutExpired/CalledProcessError/SubprocessError __name__ and __module__ as standalone invariants; CalledProcessError/SubprocessError MRO via __mro__[1] as standalone invariants."
    - "This spec adds new coverage: Popen.__name__ standalone; Popen.__bases__[0].__name__ == 'object'; check_call.__module__ and check_output.__module__; run.__module__ and check_call.__module__ as standalone; PIPE < 0 (PIPE is -1, i.e., PIPE.__lt__(0) is True)."
    - "subprocess.Popen.__name__ == 'Popen' — Popen is defined in subprocess.py."
    - "subprocess.Popen.__bases__[0].__name__ == 'object' — Popen inherits directly from object."
    - "subprocess.check_call.__module__ == 'subprocess' — check_call is defined in subprocess.py."
    - "subprocess.check_output.__module__ == 'subprocess' — check_output is defined in subprocess.py."
    - "subprocess.PIPE == -1 and PIPE < 0 — PIPE is the sentinel value -1, which is negative."
    - "subprocess.STDOUT == -2 and STDOUT < 0 — STDOUT is the sentinel value -2, which is negative."
    - "subprocess.DEVNULL == -3 and DEVNULL < 0 — DEVNULL is the sentinel value -3, which is negative."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Popen — __name__ standalone invariant
#
# subprocess.zspec.zsdl covers Popen.__name__ in a table; this spec adds it
# as a standalone named invariant for individual traceability.
# ---------------------------------------------------------------------------

invariant subprocess_extra4.Popen.name:
  description: "subprocess.Popen.__name__ == 'Popen'"
  category: class_names
  kind: python_call_eq
  function: Popen.__name__.__eq__
  args: ["Popen"]
  expected: true

# ---------------------------------------------------------------------------
# Popen.__bases__[0].__name__ — Popen inherits directly from object
#
# subprocess.Popen is a plain class whose only direct base is object.
# Neither subprocess.zspec.zsdl nor any earlier extra spec covers this.
# ---------------------------------------------------------------------------

invariant subprocess_extra4.Popen.base:
  description: "subprocess.Popen.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: Popen.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Function __module__ standalone invariants — check_call and check_output
#
# subprocess_extra2 adds Popen.__module__ and run.__module__; this spec adds
# check_call.__module__ and check_output.__module__ (not yet covered).
# ---------------------------------------------------------------------------

invariant subprocess_extra4.check_call.module:
  description: "subprocess.check_call.__module__ == 'subprocess'"
  category: function_modules
  kind: python_call_eq
  function: check_call.__module__.__eq__
  args: ["subprocess"]
  expected: true

invariant subprocess_extra4.check_output.module:
  description: "subprocess.check_output.__module__ == 'subprocess'"
  category: function_modules
  kind: python_call_eq
  function: check_output.__module__.__eq__
  args: ["subprocess"]
  expected: true

# ---------------------------------------------------------------------------
# CompletedProcess.__module__ — standalone invariant
#
# subprocess_extra covers this in an invariant; subprocess_extra3 also covers
# it as a standalone invariant. Added here only for completeness of the new
# function-module group; not duplicated — we focus on the remaining functions.
# ---------------------------------------------------------------------------

invariant subprocess_extra4.run.module_standalone:
  description: "subprocess.run.__module__ == 'subprocess' — run is defined in subprocess.py"
  category: function_modules
  kind: python_call_eq
  function: run.__module__.__eq__
  args: ["subprocess"]
  expected: true

# ---------------------------------------------------------------------------
# PIPE, STDOUT, DEVNULL — negative value checks
#
# subprocess.zspec.zsdl verifies exact integer values (-1, -2, -3).
# subprocess_extra verifies their class name is 'int'.
# This spec adds orthogonal checks: PIPE < 0, STDOUT < 0, DEVNULL < 0,
# confirming these are negative sentinel values (useful as sign contracts).
# ---------------------------------------------------------------------------

invariant subprocess_extra4.PIPE.is_negative:
  description: "subprocess.PIPE < 0 — PIPE is -1, a negative sentinel value"
  category: constants
  kind: python_call_eq
  function: PIPE.__lt__
  args: [0]
  expected: true

invariant subprocess_extra4.STDOUT.is_negative:
  description: "subprocess.STDOUT < 0 — STDOUT is -2, a negative sentinel value"
  category: constants
  kind: python_call_eq
  function: STDOUT.__lt__
  args: [0]
  expected: true

invariant subprocess_extra4.DEVNULL.is_negative:
  description: "subprocess.DEVNULL < 0 — DEVNULL is -3, a negative sentinel value"
  category: constants
  kind: python_call_eq
  function: DEVNULL.__lt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Sentinel ordering — PIPE > STDOUT > DEVNULL
#
# The three sentinel constants are distinct negative integers ordered
# PIPE (-1) > STDOUT (-2) > DEVNULL (-3). Verified via __gt__.
# ---------------------------------------------------------------------------

invariant subprocess_extra4.PIPE.gt_STDOUT:
  description: "subprocess.PIPE > subprocess.STDOUT — PIPE (-1) is greater than STDOUT (-2)"
  category: constants
  kind: python_call_eq
  function: PIPE.__gt__
  args: [-2]
  expected: true

invariant subprocess_extra4.STDOUT.gt_DEVNULL:
  description: "subprocess.STDOUT > subprocess.DEVNULL — STDOUT (-2) is greater than DEVNULL (-3)"
  category: constants
  kind: python_call_eq
  function: STDOUT.__gt__
  args: [-3]
  expected: true

# ---------------------------------------------------------------------------
# SubprocessError.__module__ — standalone invariant
#
# subprocess_extra covers SubprocessError.__module__ in an invariant.
# subprocess_extra3 adds it as a standalone invariant. This spec adds a
# complementary check via the __mro__ approach to confirm SubprocessError's
# MRO[0].__name__ is itself (identity check), not yet covered by any prior spec.
# ---------------------------------------------------------------------------

invariant subprocess_extra4.SubprocessError.mro_self:
  description: "subprocess.SubprocessError.__mro__[0].__name__ == 'SubprocessError' — MRO[0] is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: SubprocessError.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "SubprocessError"

# ---------------------------------------------------------------------------
# CalledProcessError — MRO[0] identity
#
# Complementary to subprocess_extra3 which checks MRO[1]; here we confirm
# MRO[0] is the class itself.
# ---------------------------------------------------------------------------

invariant subprocess_extra4.CalledProcessError.mro_self:
  description: "subprocess.CalledProcessError.__mro__[0].__name__ == 'CalledProcessError'"
  category: class_hierarchy
  kind: python_call_eq
  function: CalledProcessError.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "CalledProcessError"

# ---------------------------------------------------------------------------
# TimeoutExpired — MRO[0] identity
# ---------------------------------------------------------------------------

invariant subprocess_extra4.TimeoutExpired.mro_self:
  description: "subprocess.TimeoutExpired.__mro__[0].__name__ == 'TimeoutExpired'"
  category: class_hierarchy
  kind: python_call_eq
  function: TimeoutExpired.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "TimeoutExpired"
