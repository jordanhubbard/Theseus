spec: abc_extra47
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra46.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all five, abstractproperty lengths, ABCMeta.register qualname lengths, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__(), various qualname length tables, ABCMeta MRO entries, ABC/__abstractmethods__/__class__/__name__=='frozenset', ABC/__abstractmethods__/__len__()==0, ABCMeta.__call__/__qualname__=='type.__call__', class qualname string equality, abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta', abstractproperty/__mro__.__len__()==3, abstractclassmethod/__mro__.__len__()==3, abstractstaticmethod/__mro__.__len__()==3 (extra40), __class__.__qualname__ string equality and __len__() for all abc exports (extra41–extra43), abstractmethod/__doc__/__class__/__name__=='str', ABCMeta/__doc__/__class__.__name__=='str', ABC/__doc__/__class__.__name__=='str', get_cache_token/__doc__/__class__.__name__=='str', abstractproperty/__doc__/__class__.__name__=='str', abc/__doc__/__class__.__name__=='str', abc/__doc__/__class__.__qualname__=='str', abstractmethod/__doc__/__class__/__qualname__=='str', ABCMeta/__doc__/__class__/__module__=='builtins', abstractmethod/__doc__/__class__/__module__=='builtins' (extra44), ABCMeta/__subclasshook__/__qualname__.__eq__('ABCMeta.__subclasshook__'), ABC/__subclasshook__/__qualname__.__eq__('ABC.__subclasshook__'), ABCMeta/__instancecheck__/__qualname__.__len__()==25, ABCMeta/__subclasscheck__/__qualname__.__len__()==25, ABCMeta/__instancecheck__/__qualname__.__eq__('ABCMeta.__instancecheck__'), ABCMeta/__subclasscheck__/__qualname__.__eq__('ABCMeta.__subclasscheck__'), abstractclassmethod/__doc__/__class__/__name__=='str', abstractstaticmethod/__doc__/__class__/__name__=='str', update_abstractmethods/__doc__/__class__/__name__=='str' (extra45), ABCMeta.register/__doc__/__class__/__name__=='str', ABCMeta.__subclasshook__/__doc__/__class__/__name__=='str', ABCMeta.__instancecheck__/__doc__/__class__/__name__=='str', ABCMeta.__subclasscheck__/__doc__/__class__/__name__=='str', ABC.__subclasshook__/__doc__/__class__/__name__=='str', ABC.__init_subclass__/__doc__/__class__/__name__=='str', abstractmethod/__code__/__class__/__name__=='code' (extra46). update_abstractmethods/__name__=='update_abstractmethods' (extra2, extra10), update_abstractmethods/__qualname__=='update_abstractmethods' (extra10, extra20), update_abstractmethods/__module__=='abc' (extra10, extra20). abc has no __all__ attribute (extra25). abstractmethod/__code__/__class__/__name__.__len__()==4 (extra31). abstractmethod/__code__/__class__/__name__=='code' as string equality (extra46)."
    - "This spec covers: abstractmethod/__code__/__class__/__qualname__=='code'; abstractmethod/__code__/__class__/__module__=='builtins'; abstractmethod/__defaults__/__class__/__name__=='NoneType'; abstractmethod/__kwdefaults__/__class__/__name__=='NoneType'. Note: abc has no __all__ attribute (confirmed in extra25 — abc does not define __all__); that proposed check is excluded."
    - "abc.abstractmethod.__code__.__class__.__qualname__ == 'code'. abstractmethod is a Python function; its __code__ attribute is the code object for the function body. The code object type is the built-in 'code' type. The built-in 'code' type has no enclosing class or function, so its __qualname__ == __name__ == 'code' (4 chars). Prior spec extra46 captured the string equality of __name__ ('code'); extra47 captures the complementary __qualname__ == 'code'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__code__.__class__.__module__ == 'builtins'. The code object type is a built-in type defined in the builtins module; therefore abstractmethod.__code__.__class__.__module__ == 'builtins'. This parallels the pattern observed for str (docstrings), function, and other built-in types: all have __class__.__module__ == 'builtins'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__defaults__ is None; therefore abstractmethod.__defaults__.__class__.__name__ == 'NoneType'. abstractmethod is defined as 'def abstractmethod(funcobj):' — a single required positional parameter with no default value. Python sets __defaults__ to None when a function has no default values (as opposed to an empty tuple, which is set only when there is at least one defaulted parameter). None.__class__ is NoneType; NoneType.__name__ == 'NoneType'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractmethod.__kwdefaults__ is None; therefore abstractmethod.__kwdefaults__.__class__.__name__ == 'NoneType'. abstractmethod has no keyword-only parameters (it takes exactly one positional parameter, the decorated function). Python sets __kwdefaults__ to None when a function has no keyword-only defaults. None.__class__ is NoneType; NoneType.__name__ == 'NoneType'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "The 'code' type is a built-in type defined in builtins, analogous to 'function', 'type', 'NoneType', and 'str'. All these types have __module__ == 'builtins' and __qualname__ == __name__ (no enclosing class). This is part of a broader pattern across the abc specs: built-in types always have __class__.__module__ == 'builtins'. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.abstractmethod.__code__.__class__.__qualname__ and __module__ — extra47
#
# abstractmethod is a plain Python function. Its __code__ attribute is the
# Python code object. The code object type ('code') is a built-in type:
#   abstractmethod.__code__.__class__.__qualname__ == 'code'
#   abstractmethod.__code__.__class__.__module__   == 'builtins'
#
# Prior spec extra46 captured __class__.__name__ == 'code' (string equality).
# Extra31 captured __class__.__name__.__len__() == 4 (length only).
# Extra47 captures the complementary __qualname__ and __module__ dimensions:
# since 'code' is a built-in type, __qualname__ == __name__ == 'code', and
# __module__ == 'builtins' (consistent with all other built-in types observed
# in prior abc specs).
# ---------------------------------------------------------------------------

table abc_extra47.abstractmethod_code_class_attrs:
  description: "abc.abstractmethod.__code__.__class__ attributes in extra47 namespace — code type has __qualname__=='code' and __module__=='builtins'"
  kind: python_call_eq
  category: class_names
  id_prefix: abcmod47codeclsattr

  columns: [id, function, args, expected, description]
  rows:
    - [qualname, abstractmethod.__code__.__class__.__qualname__.__eq__, ["code"],     true, "abstractmethod.__code__.__class__.__qualname__ == 'code' — built-in code type has __qualname__ == __name__ == 'code' (4 chars; no enclosing scope)"]
    - [module,   abstractmethod.__code__.__class__.__module__.__eq__,   ["builtins"], true, "abstractmethod.__code__.__class__.__module__ == 'builtins' — code is a built-in type defined in the builtins module; __module__ == 'builtins'"]

# ---------------------------------------------------------------------------
# abc.abstractmethod.__defaults__ and __kwdefaults__ — extra47
#
# abstractmethod is defined as:
#   def abstractmethod(funcobj): ...
# It takes exactly one required positional parameter with no default value,
# and has no keyword-only parameters. Python represents these absent defaults
# as None rather than empty tuples:
#   abstractmethod.__defaults__   is None  → __class__.__name__ == 'NoneType'
#   abstractmethod.__kwdefaults__ is None  → __class__.__name__ == 'NoneType'
#
# This is in contrast to functions with defaults, which have __defaults__ as
# a tuple. The None/__class__.__name__=='NoneType' pattern is verified by
# traversing through the None object's class: None.__class__ is type(None),
# which is NoneType, and NoneType.__name__ == 'NoneType'.
#
# No prior abc spec has examined abstractmethod's __defaults__ or __kwdefaults__.
# ---------------------------------------------------------------------------

table abc_extra47.abstractmethod_defaults_class_name:
  description: "abc.abstractmethod.__defaults__ and __kwdefaults__ __class__.__name__ in extra47 namespace — both are None; NoneType.__name__ == 'NoneType'"
  kind: python_call_eq
  category: class_names
  id_prefix: abcmod47defclsname

  columns: [id, function, args, expected, description]
  rows:
    - [defaults,   abstractmethod.__defaults__.__class__.__name__.__eq__,   ["NoneType"], true, "abstractmethod.__defaults__.__class__.__name__ == 'NoneType' — abstractmethod has no default values; Python sets __defaults__ to None; None.__class__.__name__ == 'NoneType'"]
    - [kwdefaults, abstractmethod.__kwdefaults__.__class__.__name__.__eq__, ["NoneType"], true, "abstractmethod.__kwdefaults__.__class__.__name__ == 'NoneType' — abstractmethod has no keyword-only parameters; Python sets __kwdefaults__ to None; None.__class__.__name__ == 'NoneType'"]

# ---------------------------------------------------------------------------
# abc.abstractmethod.__code__.__class__.__qualname__.__len__() — extra47
#
# 'code' has 4 characters. The __qualname__ length equals the __name__ length
# (both are 4) because built-in types have no enclosing scope. This is the
# same length as 'type' (also 4 chars), but different from 'function' (8 chars)
# and 'builtin_function_or_method' (26 chars) from prior abc specs.
# ---------------------------------------------------------------------------

invariant abc_extra47.abstractmethod_code_class_qualname_len:
  description: "abc.abstractmethod.__code__.__class__.__qualname__.__len__() == 4 — 'code' has 4 characters; same length as 'type'; __qualname__ == __name__ for built-in types"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__code__.__class__.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone invariants — extra47
# ---------------------------------------------------------------------------

invariant abc_extra47.abstractmethod_code_class_qualname_eq:
  description: "abc.abstractmethod.__code__.__class__.__qualname__ == 'code' — code is a built-in type with no enclosing scope; __qualname__ == __name__ == 'code' (4 chars); complements __name__=='code' from extra46"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__code__.__class__.__qualname__.__eq__
  args: ["code"]
  expected: true

invariant abc_extra47.abstractmethod_code_class_module_eq:
  description: "abc.abstractmethod.__code__.__class__.__module__ == 'builtins' — the code type is a built-in type defined in the builtins module; consistent with 'function', 'type', 'str', and other built-in types all reporting __module__ == 'builtins'"
  category: module_identity
  kind: python_call_eq
  function: abstractmethod.__code__.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant abc_extra47.abstractmethod_defaults_class_name_eq:
  description: "abc.abstractmethod.__defaults__.__class__.__name__ == 'NoneType' — abstractmethod takes one required positional parameter with no default; Python sets __defaults__ to None; None.__class__.__name__ == 'NoneType'"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant abc_extra47.abstractmethod_kwdefaults_class_name_eq:
  description: "abc.abstractmethod.__kwdefaults__.__class__.__name__ == 'NoneType' — abstractmethod has no keyword-only parameters; Python sets __kwdefaults__ to None; None.__class__.__name__ == 'NoneType'"
  category: class_names
  kind: python_call_eq
  function: abstractmethod.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true
