spec: hashlib_extra1411
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 541 (_extra1411): focuses on __sizeof__ and __reduce_ex__ method type checks for the _hashlib.HASH class."
    - "hashlib.new('md5').__class__ is _hashlib.HASH — the C-extension type backing all hash objects."
    - "_hashlib.HASH.__sizeof__.__class__.__name__ == 'method_descriptor' — __sizeof__ is inherited from the C-level slot and is a method_descriptor; it is NOT present in HASH.__dict__ directly."
    - "_hashlib.HASH.__reduce_ex__.__class__.__name__ == 'method_descriptor' — __reduce_ex__ is also inherited; it is NOT in HASH.__dict__ directly."
    - "__sizeof__ in _hashlib.HASH.__dict__ is False; __reduce_ex__ in _hashlib.HASH.__dict__ is False."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1411.hash_sizeof_type_checks:
  description: "_hashlib.HASH __sizeof__ method type and dict-presence checks — __sizeof__ is a method_descriptor inherited from the C layer and is absent from HASH.__dict__"
  kind: python_call_eq
  category: sizeof_checks
  id_prefix: hl1411sw
  columns: [id, function, args, expected]
  rows:
    - [hl1411sw001, hashlib.new("md5").__class__.__sizeof__.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [hl1411sw002, hashlib.new("sha1").__class__.__sizeof__.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [hl1411sw003, hashlib.new("sha256").__class__.__sizeof__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [hl1411sw004, hashlib.new("md5").__class__.__dict__.__contains__,                   ["__sizeof__"],        false]
    - [hl1411sw005, hashlib.new("sha256").__class__.__dict__.__contains__,                ["__sizeof__"],        false]
    - [hl1411sw006, hashlib.new("sha512").__class__.__dict__.__contains__,                ["__sizeof__"],        false]

table hashlib_extra1411.hash_reduce_ex_type_checks:
  description: "_hashlib.HASH __reduce_ex__ method type and dict-presence checks — __reduce_ex__ is a method_descriptor inherited and absent from HASH.__dict__"
  kind: python_call_eq
  category: reduce_ex_checks
  id_prefix: hl1411rx
  columns: [id, function, args, expected]
  rows:
    - [hl1411rx001, hashlib.new("md5").__class__.__reduce_ex__.__class__.__name__.__eq__,    ["method_descriptor"], true]
    - [hl1411rx002, hashlib.new("sha1").__class__.__reduce_ex__.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [hl1411rx003, hashlib.new("sha256").__class__.__reduce_ex__.__class__.__name__.__eq__, ["method_descriptor"], true]
    - [hl1411rx004, hashlib.new("md5").__class__.__dict__.__contains__,                      ["__reduce_ex__"],     false]
    - [hl1411rx005, hashlib.new("sha256").__class__.__dict__.__contains__,                   ["__reduce_ex__"],     false]
    - [hl1411rx006, hashlib.new("sha512").__class__.__dict__.__contains__,                   ["__reduce_ex__"],     false]

table hashlib_extra1411.hash_class_identity_checks:
  description: "_hashlib.HASH class identity checks — the backing C-extension type is named HASH and lives in the _hashlib module"
  kind: python_call_eq
  category: class_identity_checks
  id_prefix: hl1411ci
  columns: [id, function, args, expected]
  rows:
    - [hl1411ci001, hashlib.new("md5").__class__.__name__.__eq__,       ["HASH"],    true]
    - [hl1411ci002, hashlib.new("sha1").__class__.__name__.__eq__,      ["HASH"],    true]
    - [hl1411ci003, hashlib.new("sha256").__class__.__name__.__eq__,    ["HASH"],    true]
    - [hl1411ci004, hashlib.new("md5").__class__.__module__.__eq__,     ["_hashlib"], true]
    - [hl1411ci005, hashlib.new("sha256").__class__.__module__.__eq__,  ["_hashlib"], true]
    - [hl1411ci006, hashlib.new("sha512").__class__.__module__.__eq__,  ["_hashlib"], true]
