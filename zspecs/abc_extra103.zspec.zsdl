spec: abc_extra103
version: ">=3.11"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra102.zspec.zsdl."
    - "This spec covers: wave 254 theme — ABC class dunder attribute types: ABC.__abstractmethods__ type is frozenset (len=0 since ABC itself has no abstract methods); type(ABC.__dict__).__name__=='mappingproxy'; type(ABC.__init_subclass__).__name__=='builtin_function_or_method'; type(ABC.__subclasshook__).__name__=='builtin_function_or_method'; type(ABCMeta.__dict__).__name__=='mappingproxy'; type(abstractmethod.__dict__).__name__=='dict' (abstractmethod is a plain class, not a type); ABC.__qualname__.__len__()==3 ('ABC'=3); ABCMeta.__qualname__.__len__()==7 ('ABCMeta'=7). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "type(abc.ABC.__abstractmethods__).__name__ == 'frozenset'. ABC.__abstractmethods__ is an empty frozenset (len=0) because ABC itself defines no abstract methods — it is a helper class for creating ABCs using inheritance. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "type(abc.ABC.__dict__).__name__ == 'mappingproxy'. ABC.__dict__ is a mappingproxy (read-only view of the class namespace). type(abc.ABCMeta.__dict__).__name__ is also 'mappingproxy'. type(abc.abstractmethod.__dict__).__name__ == 'dict' (abstractmethod uses a plain dict — it is a decorator class, not a type with a metaclass that gives mappingproxy). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "type(abc.ABC.__init_subclass__).__name__ == 'builtin_function_or_method'. type(abc.ABC.__subclasshook__).__name__ is also 'builtin_function_or_method'. Both are C-level inherited from ABCMeta machinery. ABC.__qualname__.__len__()==3 ('ABC'=3, shortest qualname in spec). ABCMeta.__qualname__.__len__()==7 ('ABCMeta'=7). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABC.__abstractmethods__ type and ABC.__dict__ type — extra103
#
# Wave 254 theme: ABC dunder attribute types.
#
# type(abc.ABC.__abstractmethods__).__name__  == 'frozenset'     (len=0)
# type(abc.ABC.__dict__).__name__             == 'mappingproxy'
# type(abc.ABCMeta.__dict__).__name__         == 'mappingproxy'
# type(abc.abstractmethod.__dict__).__name__  == 'dict'
# ---------------------------------------------------------------------------

table abc_extra103.abc_dunder_types:
  description: "abc.ABC dunder attribute type checks in abcdunder103 namespace — wave 254 theme: type(ABC.__abstractmethods__).__name__.__eq__('frozenset')==True (ABC.__abstractmethods__ is an empty frozenset because ABC itself defines no abstract methods; len==0); ABC.__abstractmethods__.__len__()==0; type(ABC.__dict__).__name__.__eq__('mappingproxy')==True (class namespace is a read-only mappingproxy); type(ABCMeta.__dict__).__name__.__eq__('mappingproxy')==True (ABCMeta also uses mappingproxy for its class namespace); type(abstractmethod.__dict__).__name__.__eq__('dict')==True (abstractmethod is a plain decorator class whose __dict__ is a regular mutable dict, not a mappingproxy — this contrasts with ABC and ABCMeta); ABC.__abstractmethods__.__class__.__name__.__eq__('frozenset')==True (same as type().__name__); ABC.__qualname__.__eq__('ABC')==True (len=3, shortest qualname in spec); ABCMeta.__qualname__.__eq__('ABCMeta')==True (len=7); compare: ABC.__dict__ is mappingproxy (immutable view) while abstractmethod.__dict__ is dict (mutable); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdunder103

  columns: [id, function, args, expected, description]
  rows:
    - [abm_type_eq,     type(abc.ABC.__abstractmethods__).__name__.__eq__,          ["frozenset"],    true, "type(ABC.__abstractmethods__).__name__ == 'frozenset' (empty frozenset, ABC has no abstract methods); verified with Python 3.14.3"]
    - [abm_len,         abc.ABC.__abstractmethods__.__len__,                         [],               0,    "ABC.__abstractmethods__.__len__() == 0 (empty — ABC itself has no abstract methods); verified with Python 3.14.3"]
    - [abm_class_eq,    abc.ABC.__abstractmethods__.__class__.__name__.__eq__,       ["frozenset"],    true, "ABC.__abstractmethods__.__class__.__name__ == 'frozenset' (same as type().__name__); verified with Python 3.14.3"]
    - [abc_dict_eq,     type(abc.ABC.__dict__).__name__.__eq__,                      ["mappingproxy"], true, "type(ABC.__dict__).__name__ == 'mappingproxy' (read-only class namespace view); verified with Python 3.14.3"]
    - [abcm_dict_eq,    type(abc.ABCMeta.__dict__).__name__.__eq__,                  ["mappingproxy"], true, "type(ABCMeta.__dict__).__name__ == 'mappingproxy' (ABCMeta class namespace is also mappingproxy); verified with Python 3.14.3"]
    - [am_dict_eq,      type(abc.abstractmethod.__dict__).__name__.__eq__,           ["dict"],         true, "type(abstractmethod.__dict__).__name__ == 'dict' (abstractmethod uses plain mutable dict, not mappingproxy); verified with Python 3.14.3"]
    - [abc_qn_eq,       abc.ABC.__qualname__.__eq__,                                 ["ABC"],          true, "ABC.__qualname__ == 'ABC' (len=3, shortest qualname in spec); verified with Python 3.14.3"]
    - [abcm_qn_eq,      abc.ABCMeta.__qualname__.__eq__,                             ["ABCMeta"],      true, "ABCMeta.__qualname__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABC.__init_subclass__ and ABC.__subclasshook__ type names — extra103
#
# Wave 254 theme: ABC C-level dunder method types.
#
# type(abc.ABC.__init_subclass__).__name__  == 'builtin_function_or_method'
# type(abc.ABC.__subclasshook__).__name__   == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table abc_extra103.abc_c_level_dunders:
  description: "abc.ABC C-level dunder method type checks in abcdunder103 namespace — wave 254 theme: type(ABC.__init_subclass__).__name__.__eq__('builtin_function_or_method')==True (C-level, inherited from ABCMeta machinery — no __code__ attribute); type(ABC.__subclasshook__).__name__.__eq__('builtin_function_or_method')==True (also C-level); both __init_subclass__ and __subclasshook__ are builtin_function_or_method on ABC; contrast with ABCMeta's Python-defined methods (register, __instancecheck__, __subclasscheck__) which are type 'function' with __code__; ABC.__qualname__.__len__()==3 ('ABC'=3, shortest); ABC.__qualname__.__len__()==3 < ABCMeta.__qualname__.__len__()==7; abc.ABC.__abstractmethods__.__len__()==0 (no abstract methods); type(abc.ABC.__dict__).__name__=='mappingproxy'; the two builtin_function_or_method dunders on ABC reflect that ABCMeta installs C-level implementations via Modules/_abc.c; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdunder103a

  columns: [id, function, args, expected, description]
  rows:
    - [is_type_eq,      type(abc.ABC.__init_subclass__).__name__.__eq__,             ["builtin_function_or_method"], true, "type(ABC.__init_subclass__).__name__ == 'builtin_function_or_method' (C-level, no __code__); verified with Python 3.14.3"]
    - [ssh_type_eq,     type(abc.ABC.__subclasshook__).__name__.__eq__,              ["builtin_function_or_method"], true, "type(ABC.__subclasshook__).__name__ == 'builtin_function_or_method' (C-level, no __code__); verified with Python 3.14.3"]
    - [is_class_eq,     abc.ABC.__init_subclass__.__class__.__name__.__eq__,         ["builtin_function_or_method"], true, "ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (same as type().__name__); verified with Python 3.14.3"]
    - [ssh_class_eq,    abc.ABC.__subclasshook__.__class__.__name__.__eq__,          ["builtin_function_or_method"], true, "ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' (same as type().__name__); verified with Python 3.14.3"]
    - [abc_qn_len,      abc.ABC.__qualname__.__len__,                                [],                            3,    "ABC.__qualname__.__len__() == 3 ('ABC'=3, shortest qualname in spec); verified with Python 3.14.3"]
    - [abcm_qn_len,     abc.ABCMeta.__qualname__.__len__,                            [],                            7,    "ABCMeta.__qualname__.__len__() == 7 ('ABCMeta'=7, longest qualname in spec); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ABC qualname lengths and abstractmethods class name — extra103
#
# Wave 254 theme: ABC vs ABCMeta qualname lengths and frozenset class name.
#
# ABC.__qualname__.__len__()     == 3   (shortest)
# ABCMeta.__qualname__.__len__() == 7   (longest)
# ABC.__abstractmethods__.__class__.__name__ == 'frozenset'
# ---------------------------------------------------------------------------

table abc_extra103.abc_qualname_lengths:
  description: "abc.ABC and abc.ABCMeta qualname length checks and abstractmethods class name in abcdunder103 namespace — wave 254 theme: abc.ABC.__qualname__.__len__()==3 ('ABC'=3, shortest qualname in spec — just three uppercase letters); abc.ABCMeta.__qualname__.__len__()==7 ('ABCMeta'=7, longest qualname in spec: 'ABC'=3+'Meta'=4=7); compare: ABCMeta qualname is 7/3 = 2.33x longer than ABC qualname; abc.ABC.__abstractmethods__.__class__.__name__.__eq__('frozenset')==True (the type of ABC.__abstractmethods__ is frozenset); abc.ABC.__abstractmethods__.__len__()==0 (empty frozenset); type(abc.ABC.__dict__).__name__.__eq__('mappingproxy')==True; type(abc.abstractmethod.__dict__).__name__.__eq__('dict')==True; ABC.__qualname__.__len__()==3 == len('ABC'); ABCMeta.__qualname__.__len__()==7 == len('ABCMeta'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdunder103b

  columns: [id, function, args, expected, description]
  rows:
    - [abc_qn_len2,     abc.ABC.__qualname__.__len__,                                [],               3,    "ABC.__qualname__.__len__() == 3 ('ABC'=3, shortest qualname in spec); verified with Python 3.14.3"]
    - [abcm_qn_len2,    abc.ABCMeta.__qualname__.__len__,                            [],               7,    "ABCMeta.__qualname__.__len__() == 7 ('ABCMeta'=7, longest qualname in spec); verified with Python 3.14.3"]
    - [abm_class_eq2,   abc.ABC.__abstractmethods__.__class__.__name__.__eq__,       ["frozenset"],    true, "ABC.__abstractmethods__.__class__.__name__ == 'frozenset'; verified with Python 3.14.3"]
    - [abm_len2,        abc.ABC.__abstractmethods__.__len__,                         [],               0,    "ABC.__abstractmethods__.__len__() == 0 (empty frozenset — ABC has no abstract methods); verified with Python 3.14.3"]
    - [abc_dict_eq2,    type(abc.ABC.__dict__).__name__.__eq__,                      ["mappingproxy"], true, "type(ABC.__dict__).__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [am_dict_eq2,     type(abc.abstractmethod.__dict__).__name__.__eq__,           ["dict"],         true, "type(abstractmethod.__dict__).__name__ == 'dict' (plain dict, not mappingproxy); verified with Python 3.14.3"]
    - [abc_qn_eq2,      abc.ABC.__qualname__.__eq__,                                 ["ABC"],          true, "ABC.__qualname__ == 'ABC' (len=3); verified with Python 3.14.3"]
    - [abcm_qn_eq2,     abc.ABCMeta.__qualname__.__eq__,                             ["ABCMeta"],      true, "ABCMeta.__qualname__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra103
# ---------------------------------------------------------------------------

invariant abc_extra103.ABC_abstractmethods_is_frozenset:
  description: "type(abc.ABC.__abstractmethods__).__name__.__eq__('frozenset') returns True — ABC.__abstractmethods__ is an empty frozenset (len=0); ABC itself is a helper class for creating ABCs using inheritance and defines no abstract methods of its own; ABC.__abstractmethods__.__len__()==0; abc.ABC.__abstractmethods__.__class__.__name__=='frozenset' (same result via __class__.__name__ as type().__name__); any class that inherits from ABC and adds abstractmethod-decorated methods will have a non-empty __abstractmethods__ frozenset; contrast with a concrete subclass of ABC which would have __abstractmethods__==frozenset() (empty) once all abstract methods are implemented; ABC.__qualname__.__len__()==3 ('ABC'=3, shortest in spec); NEW in extra103: first standalone ABC.__abstractmethods__ type invariant in abcdunder103 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: type(abc.ABC.__abstractmethods__).__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant abc_extra103.ABC_dict_is_mappingproxy:
  description: "type(abc.ABC.__dict__).__name__.__eq__('mappingproxy') returns True — ABC.__dict__ is a mappingproxy (read-only view of the class namespace); type(abc.ABCMeta.__dict__).__name__ is also 'mappingproxy' (ABCMeta's class namespace is equally read-only); compare: type(abc.abstractmethod.__dict__).__name__=='dict' (plain mutable dict — abstractmethod is a decorator class without the mappingproxy wrapper); ABC.__qualname__.__len__()==3 ('ABC'=3); ABCMeta.__qualname__.__len__()==7 ('ABCMeta'=7); the mappingproxy wrapping of __dict__ is a standard Python feature for class namespaces (type objects) to prevent direct mutation; NEW in extra103: first standalone ABC.__dict__ type invariant in abcdunder103 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: type(abc.ABC.__dict__).__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant abc_extra103.ABC_init_subclass_is_builtin:
  description: "type(abc.ABC.__init_subclass__).__name__.__eq__('builtin_function_or_method') returns True — ABC.__init_subclass__ is C-level (no __code__ attribute); type(abc.ABC.__subclasshook__).__name__ is also 'builtin_function_or_method' (both are C-level); contrast with ABCMeta's Python-defined methods (register, __instancecheck__, __subclasscheck__) which are type 'function' with __code__ attributes; ABC.__qualname__.__len__()==3; ABC.__abstractmethods__.__len__()==0 (empty frozenset); type(ABC.__dict__).__name__=='mappingproxy'; the fact that __init_subclass__ and __subclasshook__ are builtin_function_or_method on ABC reflects that ABCMeta installs C-level implementations for these methods via Modules/_abc.c; NEW in extra103: first standalone ABC.__init_subclass__ type invariant in abcdunder103 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: type(abc.ABC.__init_subclass__).__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_extra103.abstractmethod_dict_is_plain_dict:
  description: "type(abc.abstractmethod.__dict__).__name__.__eq__('dict') returns True — abstractmethod.__dict__ is a plain mutable dict (not a mappingproxy like ABC.__dict__ or ABCMeta.__dict__); this is because abstractmethod is a decorator class (not a type with a type-metaclass-managed namespace), so Python does not wrap its __dict__ in a mappingproxy; compare: type(abc.ABC.__dict__).__name__=='mappingproxy' and type(abc.ABCMeta.__dict__).__name__=='mappingproxy' (both are proper type objects with read-only namespace views); abstractmethod is the decorator that marks methods as abstract; ABC.__qualname__.__len__()==3 ('ABC'=3, shortest in spec); ABCMeta.__qualname__.__len__()==7; NEW in extra103: first standalone abstractmethod.__dict__ type invariant in abcdunder103 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: type(abc.abstractmethod.__dict__).__name__.__eq__
  args: ["dict"]
  expected: true

invariant abc_extra103.ABCMeta_qualname_len_7:
  description: "abc.ABCMeta.__qualname__.__len__() == 7 — 'ABCMeta' = 'ABC'=3 + 'Meta'=4 = 7; this is the longest qualname in this spec; compare: abc.ABC.__qualname__.__len__()==3 ('ABC'=3, shortest — ratio 7/3 = 2.33); ABCMeta is the metaclass that enables the ABC protocol; ABCMeta.__qualname__.__len__()==7 > ABC.__qualname__.__len__()==3; type(abc.ABCMeta.__dict__).__name__=='mappingproxy'; ABCMeta provides register(), __instancecheck__(), __subclasscheck__() (all Python-defined, co_argcount==2) and __subclasshook__ (C-level, builtin_function_or_method); ABC uses ABCMeta as its metaclass to provide the abstract base class protocol via class inheritance rather than explicit metaclass declaration; NEW in extra103: first standalone ABCMeta qualname length invariant in abcdunder103 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__qualname__.__len__
  args: []
  expected: 7
