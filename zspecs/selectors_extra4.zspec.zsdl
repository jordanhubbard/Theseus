spec: selectors_extra4
version: ">=3.9"
backend: python_module(selectors)

docs: https://docs.python.org/3/library/selectors.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/selectors.html — Python selectors module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/selectors.py"
  notes:
    - "Extends selectors.zspec.zsdl through selectors_extra3.zspec.zsdl."
    - "selectors.zspec.zsdl covers: EVENT_READ/WRITE values and types; BaseSelector/SelectSelector/KqueueSelector/DefaultSelector class names and modules; SelectorKey class name, base, and _fields."
    - "selectors_extra covers: BaseSelector/SelectSelector/DefaultSelector/SelectorKey class names; EVENT_READ/WRITE types and values."
    - "selectors_extra2 covers: SelectorKey module, field count, fields by index, base class; SelectSelector/BaseSelector module; DefaultSelector name; EVENT_READ/WRITE values."
    - "selectors_extra3 covers: PollSelector class name and module; SelectSelector/KqueueSelector base class (_BaseSelectorImpl); DefaultSelector.__module__; KqueueSelector.__module__; EVENT_READ|EVENT_WRITE==3; EVENT_READ&EVENT_WRITE==0; selectors module __name__."
    - "This spec adds: __qualname__ checks for SelectSelector, KqueueSelector, PollSelector, BaseSelector, SelectorKey, and DefaultSelector (none covered by prior specs); selectors.EpollSelector raises AttributeError on macOS (epoll is Linux-only); SelectorKey._fields.__class__.__name__ == 'tuple' (type of _fields attribute)."
    - "SelectSelector.__qualname__ == 'SelectSelector' — top-level class, qualname matches name."
    - "KqueueSelector.__qualname__ == 'KqueueSelector' — top-level class, qualname matches name."
    - "PollSelector.__qualname__ == 'PollSelector' — top-level class, qualname matches name."
    - "BaseSelector.__qualname__ == 'BaseSelector' — top-level abstract class, qualname matches name."
    - "SelectorKey.__qualname__ == 'SelectorKey' — top-level namedtuple class, qualname matches name."
    - "DefaultSelector.__qualname__ == 'KqueueSelector' on macOS — alias resolves to KqueueSelector."
    - "selectors.EpollSelector does not exist on macOS; __getattribute__('EpollSelector') raises AttributeError."
    - "SelectorKey._fields.__class__.__name__ == 'tuple' — _fields is a plain tuple of strings."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Selector class __qualname__ attributes
#
# No prior selectors spec checks __qualname__ for any class.
# All selector classes are defined at module scope, so __qualname__ == __name__.
# ---------------------------------------------------------------------------

table selectors_extra4.selector_qualnames:
  description: "Selector classes have __qualname__ matching their unqualified name"
  kind: python_call_eq
  category: classnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [SelectSelector,  SelectSelector.__qualname__.__eq__,  ["SelectSelector"],  true]
    - [KqueueSelector,  KqueueSelector.__qualname__.__eq__,  ["KqueueSelector"],  true]
    - [PollSelector,    PollSelector.__qualname__.__eq__,    ["PollSelector"],    true]
    - [BaseSelector,    BaseSelector.__qualname__.__eq__,    ["BaseSelector"],    true]
    - [SelectorKey,     SelectorKey.__qualname__.__eq__,     ["SelectorKey"],     true]

# ---------------------------------------------------------------------------
# DefaultSelector.__qualname__ — platform-specific alias resolves to KqueueSelector
#
# On macOS, DefaultSelector is an alias for KqueueSelector, so its __qualname__
# is 'KqueueSelector'. No prior spec covers __qualname__ for DefaultSelector.
# ---------------------------------------------------------------------------

invariant selectors_extra4.DefaultSelector.qualname:
  description: "selectors.DefaultSelector.__qualname__ == 'KqueueSelector' on macOS"
  category: classnames
  kind: python_call_eq
  function: DefaultSelector.__qualname__.__eq__
  args: ["KqueueSelector"]
  expected: true

# ---------------------------------------------------------------------------
# SelectorKey._fields type check
#
# selectors.zspec.zsdl and selectors_extra2 check _fields membership and
# indexing. No prior spec checks the type of _fields itself.
# _fields is a plain tuple of strings (not a list or other sequence).
# ---------------------------------------------------------------------------

invariant selectors_extra4.SelectorKey.fields_type:
  description: "selectors.SelectorKey._fields.__class__.__name__ == 'tuple' — _fields is a tuple"
  category: namedtuple_fields
  kind: python_call_eq
  function: SelectorKey._fields.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# selectors.EpollSelector — not available on macOS (raises AttributeError)
#
# EpollSelector is a Linux-only selector backed by epoll(); it does not exist
# on macOS/Darwin. Accessing it via __getattribute__ raises AttributeError.
# No prior selectors spec documents this absence.
# ---------------------------------------------------------------------------

invariant selectors_extra4.EpollSelector.not_available_on_macos:
  description: "selectors.__getattribute__('EpollSelector') raises AttributeError on macOS"
  category: platform
  kind: python_call_raises
  function: __getattribute__
  args: ["EpollSelector"]
  expected: AttributeError
