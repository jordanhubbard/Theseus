spec: inspect_extra1171
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect.CO_OPTIMIZED/CO_NEWLOCALS/CO_VARARGS/CO_VARKEYWORDS/CO_NESTED/CO_GENERATOR __class__.__name__, inspect.Traceback.__module__, inspect.Arguments.__module__ — not covered in _extra976/_extra991"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra1171.co_flag_class_names:
  description: "inspect compile flag constants __class__.__name__ identity"
  kind: python_call_eq
  category: co_flag_class_names
  id_prefix: ip1171cf
  columns: [id, function, args, expected]
  rows:
    - [ip1171cf001, inspect.CO_OPTIMIZED.__class__.__name__.__eq__,    ["int"],   true]
    - [ip1171cf002, inspect.CO_NEWLOCALS.__class__.__name__.__eq__,    ["int"],   true]
    - [ip1171cf003, inspect.CO_VARARGS.__class__.__name__.__eq__,      ["int"],   true]
    - [ip1171cf004, inspect.CO_VARKEYWORDS.__class__.__name__.__eq__,  ["int"],   true]
    - [ip1171cf005, inspect.CO_NESTED.__class__.__name__.__eq__,       ["int"],   true]
    - [ip1171cf006, inspect.CO_GENERATOR.__class__.__name__.__eq__,    ["int"],   true]
    - [ip1171cf007, inspect.CO_OPTIMIZED.__eq__,                       [1],       true]
    - [ip1171cf008, inspect.CO_NEWLOCALS.__eq__,                       [2],       true]

table inspect_extra1171.traceback_arguments_module:
  description: "inspect.Traceback and Arguments namedtuple __module__ identity"
  kind: python_call_eq
  category: namedtuple_module_identity
  id_prefix: ip1171ta
  columns: [id, function, args, expected]
  rows:
    - [ip1171ta001, inspect.Traceback.__module__.__eq__,              ["inspect"],   true]
    - [ip1171ta002, inspect.Arguments.__module__.__eq__,              ["inspect"],   true]
    - [ip1171ta003, inspect.Traceback.__qualname__.__eq__,            ["Traceback"], true]
    - [ip1171ta004, inspect.Arguments.__qualname__.__eq__,            ["Arguments"], true]
    - [ip1171ta005, inspect.Traceback.__class__.__name__.__eq__,      ["type"],      true]
    - [ip1171ta006, inspect.Arguments.__class__.__name__.__eq__,      ["type"],      true]
    - [ip1171ta007, inspect.CO_VARARGS.__eq__,                        [4],           true]
    - [ip1171ta008, inspect.CO_VARKEYWORDS.__eq__,                    [8],           true]

table inspect_extra1171.co_flag_nested_generator_values:
  description: "inspect CO_NESTED and CO_GENERATOR constant values and class identity"
  kind: python_call_eq
  category: co_flag_values
  id_prefix: ip1171ng
  columns: [id, function, args, expected]
  rows:
    - [ip1171ng001, inspect.CO_NESTED.__eq__,                           [16],          true]
    - [ip1171ng002, inspect.CO_GENERATOR.__eq__,                        [32],          true]
    - [ip1171ng003, inspect.CO_OPTIMIZED.__class__.__name__.__eq__,     ["int"],       true]
    - [ip1171ng004, inspect.Traceback._fields.__class__.__name__.__eq__, ["tuple"],    true]
    - [ip1171ng005, inspect.Arguments._fields.__class__.__name__.__eq__, ["tuple"],    true]
    - [ip1171ng006, inspect.Traceback._fields.__len__,                  [],            6]
    - [ip1171ng007, inspect.Arguments._fields.__contains__,             ["args"],      true]
    - [ip1171ng008, inspect.Arguments._fields.__contains__,             ["varargs"],   true]
