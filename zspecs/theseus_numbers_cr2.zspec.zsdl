spec: theseus_numbers_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_numbers_cr2)
blocks: numbers

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html"
  notes:
    - "Clean-room extended numeric tower. Do NOT import numbers."
    - "Complex, Real, Rational, Integral: abstract base classes for numeric types."
    - "isinstance check using ABC registration."
    - "numbers2_int_is_integral(): isinstance(5, Integral) == True."
    - "numbers2_float_is_real(): isinstance(3.14, Real) == True."
    - "numbers2_complex_is_complex(): isinstance(1+2j, Complex) == True."
    - "Implement using abc.ABCMeta or simple registration: register int as Integral, float as Real, complex as Complex."
    - "Export: Number, Complex, Real, Rational, Integral."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_numbers_cr2.int_is_integral:
  description: "isinstance(5, Integral) == True"
  category: integral
  kind: python_call_eq
  function: numbers2_int_is_integral
  args: []
  expected: true

invariant theseus_numbers_cr2.float_is_real:
  description: "isinstance(3.14, Real) == True"
  category: real
  kind: python_call_eq
  function: numbers2_float_is_real
  args: []
  expected: true

invariant theseus_numbers_cr2.complex_is_complex:
  description: "isinstance(1+2j, Complex) == True"
  category: complex
  kind: python_call_eq
  function: numbers2_complex_is_complex
  args: []
  expected: true
