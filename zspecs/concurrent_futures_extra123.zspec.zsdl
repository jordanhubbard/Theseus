spec: concurrent_futures_extra123
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: wave 255 theme — concurrent.futures.wait() and as_completed() function __code__ attributes. NEW in extra123: concurrent.futures.wait.__code__.co_name=='wait' (len=4); concurrent.futures.wait.__code__.co_argcount==3 (fs, timeout, return_when — all positional); concurrent.futures.wait.__code__.co_varnames[0]=='fs'; concurrent.futures.wait.__code__.co_varnames.__len__()==7; concurrent.futures.as_completed.__code__.co_name=='as_completed' (len=12); concurrent.futures.as_completed.__code__.co_argcount==2 (fs, timeout); concurrent.futures.as_completed.__code__.co_varnames[0]=='fs'; concurrent.futures.as_completed.__code__.co_varnames.__len__()==9; wait.__module__=='concurrent.futures._base'; as_completed.__module__=='concurrent.futures._base'; both are class='function'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.wait.__code__.co_argcount == 3. wait is defined as 'def wait(fs, timeout=None, return_when=ALL_COMPLETED)' with 3 positional parameters: fs, timeout, and return_when; all three are counted by co_argcount (unlike asyncio.wait which has only 1 counted positional param because timeout and return_when are keyword-only after *). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.wait.__code__.co_varnames == ('fs', 'timeout', 'return_when', 'f', 'done', 'not_done', 'waiter'). 7 total varnames: 3 params plus 4 locals. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.as_completed.__code__.co_argcount == 2. as_completed is defined as 'def as_completed(fs, timeout=None)' with 2 positional params: fs and timeout. co_varnames.__len__() is 9 (fs, timeout, end_time, total_futures, finished, pending, waiter, wait_timeout, f). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Both wait and as_completed are in concurrent.futures._base (module='concurrent.futures._base'). They are plain functions (not coroutines), unlike asyncio.wait which is a coroutine function. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.wait __code__ attributes — extra123
#
# Wave 255 theme: concurrent.futures.wait() and as_completed() __code__ attrs.
#
# concurrent.futures.wait.__code__.co_name     == 'wait'         (len=4)
# concurrent.futures.wait.__code__.co_argcount == 3              (fs, timeout, return_when)
# concurrent.futures.wait.__code__.co_varnames[0] == 'fs'
# concurrent.futures.wait.__code__.co_varnames[1] == 'timeout'
# concurrent.futures.wait.__code__.co_varnames[2] == 'return_when'
# concurrent.futures.wait.__code__.co_varnames.__len__() == 7
# wait.__module__ == 'concurrent.futures._base'
# wait.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table concurrent_futures_extra123.cf_wait_code_attrs:
  description: "concurrent.futures.wait __code__ attribute checks in cfwaitcode123 namespace — wave 255 theme: concurrent.futures.wait is a plain function (class='function', not a coroutine) defined in Lib/concurrent/futures/_base.py; wait.__code__.co_name.__eq__('wait')==True (len=4: matches function name); wait.__code__.co_name.__len__()==4; wait.__code__.co_argcount.__eq__(3)==True (3 positional parameters: fs, timeout, return_when; unlike asyncio.wait which has co_argcount==1 because timeout and return_when are keyword-only after *; concurrent.futures.wait defines them as regular positional params with defaults); wait.__code__.co_varnames.__getitem__(0).__eq__('fs')==True (first co_varname is 'fs', the iterable of Future objects or concurrent.futures.Future); wait.__code__.co_varnames.__getitem__(1).__eq__('timeout')==True (second co_varname is 'timeout'); wait.__code__.co_varnames.__getitem__(2).__eq__('return_when')==True (third co_varname is 'return_when'); wait.__code__.co_varnames.__len__()==7 (7 total: fs, timeout, return_when plus 4 locals: f, done, not_done, waiter); wait.__module__.__eq__('concurrent.futures._base')==True; wait.__class__.__name__.__eq__('function')==True; wait.__qualname__.__eq__('wait')==True (len=4, module-level function); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: cfwaitcode123

  columns: [id, function, args, expected, description]
  rows:
    - [w_cn_eq,    "concurrent.futures.wait.__code__.co_name.__eq__",                 ["wait"],     true, "concurrent.futures.wait.__code__.co_name == 'wait' (len=4, matches function name); verified with Python 3.14.3"]
    - [w_cn_len,   "concurrent.futures.wait.__code__.co_name.__len__",                [],           4,    "concurrent.futures.wait.__code__.co_name.__len__() == 4; verified with Python 3.14.3"]
    - [w_argc,     "concurrent.futures.wait.__code__.co_argcount.__eq__",             [3],          true, "concurrent.futures.wait.__code__.co_argcount == 3 (fs, timeout, return_when; all positional unlike asyncio.wait which has co_argcount==1); verified with Python 3.14.3"]
    - [w_var0,     "concurrent.futures.wait.__code__.co_varnames.__getitem__",        [0],          "fs", "concurrent.futures.wait.__code__.co_varnames[0] == 'fs' (the iterable of Futures); verified with Python 3.14.3"]
    - [w_var1,     "concurrent.futures.wait.__code__.co_varnames.__getitem__",        [1],          "timeout", "concurrent.futures.wait.__code__.co_varnames[1] == 'timeout'; verified with Python 3.14.3"]
    - [w_var2,     "concurrent.futures.wait.__code__.co_varnames.__getitem__",        [2],          "return_when", "concurrent.futures.wait.__code__.co_varnames[2] == 'return_when'; verified with Python 3.14.3"]
    - [w_varlen,   "concurrent.futures.wait.__code__.co_varnames.__len__",            [],           7,    "concurrent.futures.wait.__code__.co_varnames.__len__() == 7 (fs, timeout, return_when + 4 locals: f, done, not_done, waiter); verified with Python 3.14.3"]
    - [w_mod_eq,   "concurrent.futures.wait.__module__.__eq__",                       ["concurrent.futures._base"], true, "concurrent.futures.wait.__module__ == 'concurrent.futures._base' (defined in _base.py); verified with Python 3.14.3"]
    - [w_cls_eq,   "concurrent.futures.wait.__class__.__name__.__eq__",               ["function"], true, "concurrent.futures.wait.__class__.__name__ == 'function' (plain function, not a coroutine unlike asyncio.wait); verified with Python 3.14.3"]

