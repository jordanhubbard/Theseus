# ---------------------------------------------------------------------------
# Standalone invariants — extra123
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra123.wait_co_argcount_is_3:
  description: "concurrent.futures.wait.__code__.co_argcount.__eq__(3) returns True — concurrent.futures.wait is defined as 'def wait(fs, timeout=None, return_when=ALL_COMPLETED)' with 3 positional parameters: fs, timeout, and return_when; co_argcount counts all three because they are regular positional params (with defaults); this contrasts with asyncio.wait (covered in asyncio_extra125) which has co_argcount==1 because its timeout and return_when are keyword-only params after * separator; concurrent.futures.wait.__code__.co_varnames[0] is 'fs'; co_varnames.__len__() is 7 (3 params + 4 locals); concurrent.futures.wait.__class__.__name__ is 'function' (plain function, not a coroutine); wait.__module__ is 'concurrent.futures._base'; NEW in extra123: first standalone wait co_argcount invariant in cfwaitcode123 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: "concurrent.futures.wait.__code__.co_argcount.__eq__"
  args: [3]
  expected: true

invariant concurrent_futures_extra123.as_completed_co_name_len_12:
  description: "concurrent.futures.as_completed.__code__.co_name.__len__() == 12 — concurrent.futures.as_completed.__code__.co_name is 'as_completed' (12 chars: 'as'=2+'_'=1+'completed'=9=12); this is the longest co_name in this spec (wait=4 vs as_completed=12); as_completed.__qualname__ is also 'as_completed' (len=12); as_completed.__code__.co_argcount is 2 (fs, timeout); as_completed.__code__.co_varnames.__len__() is 9 (2 params + 7 locals: end_time, total_futures, finished, pending, waiter, wait_timeout, f); as_completed.__module__ is 'concurrent.futures._base'; as_completed yields futures as they complete, making it suitable for processing results in completion order; NEW in extra123: first standalone as_completed co_name length invariant in cfwaitcode123 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: "concurrent.futures.as_completed.__code__.co_name.__len__"
  args: []
  expected: 12

invariant concurrent_futures_extra123.as_completed_co_varnames_len_9:
  description: "concurrent.futures.as_completed.__code__.co_varnames.__len__() == 9 — concurrent.futures.as_completed has 9 co_varnames: fs, timeout, end_time, total_futures, finished, pending, waiter, wait_timeout, f; this is 2 more than wait's 7 co_varnames; the additional locals (end_time, total_futures, finished, pending, wait_timeout compared to wait's done, not_done) reflect as_completed's generator-based implementation tracking partial completion state; as_completed.__code__.co_argcount is 2 (fs, timeout); as_completed.__code__.co_name is 'as_completed' (len=12); as_completed.__module__ is 'concurrent.futures._base'; NEW in extra123: first standalone as_completed co_varnames length invariant in cfwaitcode123 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: "concurrent.futures.as_completed.__code__.co_varnames.__len__"
  args: []
  expected: 9

invariant concurrent_futures_extra123.wait_co_varnames_len_7:
  description: "concurrent.futures.wait.__code__.co_varnames.__len__() == 7 — concurrent.futures.wait has 7 co_varnames: fs, timeout, return_when (3 positional params) plus 4 locals: f (loop variable), done (set of completed futures), not_done (set of incomplete futures), waiter (internal waiter object); the 7 co_varnames reflect wait's implementation which separates futures into done and not_done sets then uses a waiter to block until the condition is met; compare with as_completed which has 9 co_varnames (more complex generator state); wait.__code__.co_argcount is 3 (more than as_completed's 2); wait.__code__.co_name is 'wait' (len=4); wait.__module__ is 'concurrent.futures._base'; NEW in extra123: first standalone wait co_varnames length invariant in cfwaitcode123 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: "concurrent.futures.wait.__code__.co_varnames.__len__"
  args: []
  expected: 7

invariant concurrent_futures_extra123.wait_varnames_0_is_fs:
  description: "concurrent.futures.wait.__code__.co_varnames.__getitem__(0).__eq__('fs') returns 'fs' — concurrent.futures.wait.__code__.co_varnames[0] is 'fs' (the first positional parameter: an iterable of Future instances); both wait and as_completed share 'fs' as their first co_varname; 'fs' is 2 chars; concurrent.futures.wait.__code__.co_varnames[1] is 'timeout'; wait.__code__.co_varnames[2] is 'return_when'; wait.__code__.co_argcount is 3; the name 'fs' is the standard abbreviation for 'futures' in concurrent.futures API; NEW in extra123: first standalone wait co_varnames[0] invariant in cfwaitcode123 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: "concurrent.futures.wait.__code__.co_varnames.__getitem__"
  args: [0]
  expected: "fs"
