table concurrent_futures_extra123.cf_as_completed_code_attrs:
  description: "concurrent.futures.as_completed __code__ attribute checks in cfwaitcode123 namespace — wave 255 theme: concurrent.futures.as_completed is a plain generator function (class='function') defined in Lib/concurrent/futures/_base.py; as_completed.__code__.co_name.__eq__('as_completed')==True (len=12: 'as_completed'=12, the longest co_name in this spec vs wait=4); as_completed.__code__.co_name.__len__()==12; as_completed.__code__.co_argcount.__eq__(2)==True (2 positional params: fs and timeout; compare with wait which has co_argcount==3 because it also counts return_when); as_completed.__code__.co_varnames.__getitem__(0).__eq__('fs')==True (both wait and as_completed share 'fs' as their first co_varname); as_completed.__code__.co_varnames.__getitem__(1).__eq__('timeout')==True (second co_varname is 'timeout', same as wait's second co_varname); as_completed.__code__.co_varnames.__len__()==9 (9 total: fs, timeout, end_time, total_futures, finished, pending, waiter, wait_timeout, f; more locals than wait's 7 because as_completed is a generator that manages more internal state); as_completed.__module__.__eq__('concurrent.futures._base')==True (same module as wait); as_completed.__qualname__.__eq__('as_completed')==True (len=12, module-level function, qualname equals name); as_completed.__class__.__name__.__eq__('function')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: cfwaitcode123a

  columns: [id, function, args, expected, description]
  rows:
    - [ac_cn_eq,    "concurrent.futures.as_completed.__code__.co_name.__eq__",             ["as_completed"], true, "concurrent.futures.as_completed.__code__.co_name == 'as_completed' (len=12, longest in spec vs wait=4); verified with Python 3.14.3"]
    - [ac_cn_len,   "concurrent.futures.as_completed.__code__.co_name.__len__",            [],               12,   "concurrent.futures.as_completed.__code__.co_name.__len__() == 12; verified with Python 3.14.3"]
    - [ac_argc,     "concurrent.futures.as_completed.__code__.co_argcount.__eq__",         [2],              true, "concurrent.futures.as_completed.__code__.co_argcount == 2 (fs, timeout; one fewer than wait's 3 since it lacks return_when); verified with Python 3.14.3"]
    - [ac_var0,     "concurrent.futures.as_completed.__code__.co_varnames.__getitem__",    [0],              "fs", "concurrent.futures.as_completed.__code__.co_varnames[0] == 'fs' (same first varname as wait); verified with Python 3.14.3"]
    - [ac_var1,     "concurrent.futures.as_completed.__code__.co_varnames.__getitem__",    [1],              "timeout", "concurrent.futures.as_completed.__code__.co_varnames[1] == 'timeout' (same second varname as wait); verified with Python 3.14.3"]
    - [ac_varlen,   "concurrent.futures.as_completed.__code__.co_varnames.__len__",        [],               9,    "concurrent.futures.as_completed.__code__.co_varnames.__len__() == 9 (9 total locals; more than wait's 7); verified with Python 3.14.3"]
    - [ac_mod_eq,   "concurrent.futures.as_completed.__module__.__eq__",                   ["concurrent.futures._base"], true, "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base' (same as wait); verified with Python 3.14.3"]
    - [ac_qn_eq,    "concurrent.futures.as_completed.__qualname__.__eq__",                 ["as_completed"], true, "concurrent.futures.as_completed.__qualname__ == 'as_completed' (len=12, qualname equals name for module-level function); verified with Python 3.14.3"]
    - [ac_cls_eq,   "concurrent.futures.as_completed.__class__.__name__.__eq__",           ["function"],     true, "concurrent.futures.as_completed.__class__.__name__ == 'function' (plain function, not a coroutine); verified with Python 3.14.3"]

