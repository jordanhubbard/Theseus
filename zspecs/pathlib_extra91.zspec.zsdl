spec: pathlib_extra91
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra90."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes for many methods; PurePath/__dict__ membership; Path/__dict__ membership; Path properties as descriptors; Path method co_name and co_argcount for open/read_text/write_text/iterdir/mkdir/rmdir/stat/lstat/exists/unlink/rename/resolve/absolute/expanduser; PurePath/__name__/__module__/__bases__/__mro__; PosixPath identity; Path.__init__/__new__ co_name and co_argcount; Path.is_dir/is_file/is_symlink/is_mount/is_absolute/is_relative_to/exists/samefile __code__ attributes; Path.__dict__.__contains__ for read_text/write_text/read_bytes/write_bytes/mkdir/iterdir/glob/exists/is_dir/stat; Path.__dict__.__class__.__name__; Path.__qualname__/__name__/__module__ and their lengths; PurePath.__dict__.__contains__ for __str__/__repr__/__eq__/__hash__/__lt__/__truediv__/parent/name/suffix/suffixes (all True); PurePath.__dict__.__class__.__name__; PurePath.__name__; PurePath.__module__."
    - "This spec covers: pathlib.Path.__bases__[0].__name__ == 'PurePath' (Path directly inherits from PurePath on Python 3.12+); pathlib.Path.__mro__.__len__() == 3 (Path, PurePath, object); pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath'; pathlib.PurePosixPath.__mro__.__len__() == 3; pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath'; pathlib.PureWindowsPath.__mro__.__len__() == 3; pathlib.Path.__qualname__.__eq__('Path') == True; pathlib.PurePath.__qualname__.__eq__('PurePath') == True; pathlib.PosixPath.__qualname__.__eq__('PosixPath') == True; pathlib.PosixPath.__bases__[0].__name__ == 'Path'; pathlib.PosixPath.__mro__.__len__() == 5 (PosixPath, Path, PurePosixPath, PurePath, object)."
    - "pathlib.Path.__bases__[0].__name__ == 'PurePath' — on Python 3.12+, Path directly inherits from PurePath (not from PosixPath or a platform-specific class). Verified on Python 3.14.3 macOS."
    - "pathlib.Path.__mro__.__len__() == 3 — MRO is [Path, PurePath, object]; length 3. Verified on Python 3.14.3 macOS."
    - "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' — PurePosixPath inherits from PurePath."
    - "pathlib.PurePosixPath.__mro__.__len__() == 3 — MRO is [PurePosixPath, PurePath, object]; length 3."
    - "pathlib.PureWindowsPath.__bases__[0].__name__ == 'PurePath' — PureWindowsPath inherits from PurePath."
    - "pathlib.PureWindowsPath.__mro__.__len__() == 3 — MRO is [PureWindowsPath, PurePath, object]; length 3."
    - "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath directly inherits from Path."
    - "pathlib.PosixPath.__mro__.__len__() == 5 — MRO is [PosixPath, Path, PurePosixPath, PurePath, object]; length 5."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.__bases__[0].__name__ and __mro__.__len__()
# On Python 3.12+, Path inherits directly from PurePath. MRO has 3 entries.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra91.Path_bases_and_mro:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath'; Path.__mro__.__len__() == 3"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pathlibextra91

  columns: [id, function, args, expected]
  rows:
    - [path_base0,   "Path.__bases__[0].__name__.__eq__", ["PurePath"], true]
    - [path_mro_len, Path.__mro__.__len__,                [],           3]

# ---------------------------------------------------------------------------
# pathlib.PurePosixPath and PureWindowsPath __bases__ and __mro__.__len__()
# Both inherit from PurePath; MRO length is 3 for each.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra91.PurePlatformPath_bases_mro:
  description: "pathlib.PurePosixPath/PureWindowsPath __bases__[0].__name__ and __mro__.__len__()"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pathlibextra91

  columns: [id, function, args, expected]
  rows:
    - [ppx_base0,   "PurePosixPath.__bases__[0].__name__.__eq__",   ["PurePath"], true]
    - [ppx_mro_len, PurePosixPath.__mro__.__len__,                  [],           3]
    - [pwx_base0,   "PureWindowsPath.__bases__[0].__name__.__eq__", ["PurePath"], true]
    - [pwx_mro_len, PureWindowsPath.__mro__.__len__,                [],           3]

# ---------------------------------------------------------------------------
# pathlib.Path, PurePath, PosixPath __qualname__ equality
# All are top-level classes; __qualname__ equals the class name.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra91.path_qualnames:
  description: "pathlib.Path/PurePath/PosixPath __qualname__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibextra91

  columns: [id, function, args, expected]
  rows:
    - [path_qualname,     Path.__qualname__.__eq__,     ["Path"],     true]
    - [purepath_qualname, PurePath.__qualname__.__eq__,  ["PurePath"], true]
    - [posixpath_qualname, PosixPath.__qualname__.__eq__, ["PosixPath"], true]

# ---------------------------------------------------------------------------
# pathlib.PosixPath.__bases__[0].__name__ and __mro__.__len__()
# PosixPath inherits from Path; its MRO has 5 entries on macOS.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra91.PosixPath_bases_and_mro:
  description: "pathlib.PosixPath.__bases__[0].__name__ == 'Path'; PosixPath.__mro__.__len__() == 5"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: pathlibextra91

  columns: [id, function, args, expected]
  rows:
    - [px_base0,   "PosixPath.__bases__[0].__name__.__eq__", ["Path"], true]
    - [px_mro_len, PosixPath.__mro__.__len__,                [],       5]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra91.Path.base_is_PurePath:
  description: "pathlib.Path.__bases__[0].__name__ == 'PurePath' (Path directly inherits from PurePath on Python 3.12+)"
  category: class_hierarchy
  kind: python_call_eq
  function: "Path.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true

invariant pathlib_extra91.Path.mro_len:
  description: "pathlib.Path.__mro__.__len__() == 3 (MRO is [Path, PurePath, object])"
  category: class_hierarchy
  kind: python_call_eq
  function: Path.__mro__.__len__
  args: []
  expected: 3

invariant pathlib_extra91.PosixPath.base_is_Path:
  description: "pathlib.PosixPath.__bases__[0].__name__ == 'Path' (PosixPath directly inherits from Path)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PosixPath.__bases__[0].__name__.__eq__"
  args: ["Path"]
  expected: true

invariant pathlib_extra91.PosixPath.mro_len:
  description: "pathlib.PosixPath.__mro__.__len__() == 5 (MRO is [PosixPath, Path, PurePosixPath, PurePath, object])"
  category: class_hierarchy
  kind: python_call_eq
  function: PosixPath.__mro__.__len__
  args: []
  expected: 5

invariant pathlib_extra91.PurePosixPath.base_is_PurePath:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath' (PurePosixPath inherits from PurePath)"
  category: class_hierarchy
  kind: python_call_eq
  function: "PurePosixPath.__bases__[0].__name__.__eq__"
  args: ["PurePath"]
  expected: true
