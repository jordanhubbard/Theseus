spec: socket_extra224
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 793 — Transmission Control Protocol"
  - "RFC 768 — User Datagram Protocol"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.__doc__.__contains__('socket') == True — module docstring mentions 'socket'."
    - "socket.socket.__doc__.__contains__('socket') == True — socket class docstring mentions 'socket'."
    - "socket.socket.bind.__doc__.__contains__('address') == True — bind() docstring mentions 'address'."
    - "socket.socket.connect.__doc__.__contains__('address') == True — connect() docstring mentions 'address'."
    - "socket.socket.listen.__doc__.__contains__('listen') == True — listen() docstring mentions 'listen'."
    - "socket.socket.accept.__doc__.__contains__('accept') == True — accept() docstring mentions 'accept'."
    - "socket.socket.send.__doc__.__contains__('send') == True — send() docstring mentions 'send'."
    - "socket.socket.recv.__doc__.__contains__('recv') == True — recv() docstring mentions 'recv'."
    - "socket.gethostname.__doc__.__contains__('host') == True — gethostname() docstring mentions 'host'."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket __doc__ contains checks
#
# socket.__doc__.__contains__('socket')              == True
# socket.socket.__doc__.__contains__('socket')       == True
# socket.socket.bind.__doc__.__contains__('address') == True
# socket.socket.connect.__doc__.__contains__('address') == True
# socket.socket.listen.__doc__.__contains__('listen')   == True
# socket.socket.accept.__doc__.__contains__('accept')   == True
# socket.socket.send.__doc__.__contains__('send')       == True
# socket.socket.recv.__doc__.__contains__('recv')       == True
# socket.gethostname.__doc__.__contains__('host')       == True
# ---------------------------------------------------------------------------

table socket_extra224.doc_contains_checks:
  description: "socket __doc__ contains checks in socket224 namespace — wave 224 theme: module docstring contains 'socket'; socket class docstring contains 'socket'; bind() docstring contains 'address'; connect() docstring contains 'address'; listen() docstring contains 'listen'; accept() docstring contains 'accept'; send() docstring contains 'send'; recv() docstring contains 'recv'; gethostname() docstring contains 'host'; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: doc_contains
  id_prefix: socket224

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_socket,    socket.__doc__.__contains__,         ["socket"],  true, "socket.__doc__.__contains__('socket') == True — module docstring mentions socket"]
    - [class_doc_socket,     socket.socket.__doc__.__contains__,  ["socket"],  true, "socket.socket.__doc__.__contains__('socket') == True — socket class docstring mentions socket"]
    - [bind_doc_address,     socket.socket.bind.__doc__.__contains__,    ["address"], true, "socket.socket.bind.__doc__.__contains__('address') == True — bind() docstring mentions address"]
    - [connect_doc_address,  socket.socket.connect.__doc__.__contains__, ["address"], true, "socket.socket.connect.__doc__.__contains__('address') == True — connect() docstring mentions address"]
    - [listen_doc_listen,    socket.socket.listen.__doc__.__contains__,  ["listen"],  true, "socket.socket.listen.__doc__.__contains__('listen') == True — listen() docstring mentions listen"]
    - [accept_doc_accept,    socket.socket.accept.__doc__.__contains__,  ["accept"],  true, "socket.socket.accept.__doc__.__contains__('accept') == True — accept() docstring mentions accept"]
    - [send_doc_send,        socket.socket.send.__doc__.__contains__,    ["send"],    true, "socket.socket.send.__doc__.__contains__('send') == True — send() docstring mentions send"]
    - [recv_doc_recv,        socket.socket.recv.__doc__.__contains__,    ["recv"],    true, "socket.socket.recv.__doc__.__contains__('recv') == True — recv() docstring mentions recv"]
    - [gethostname_doc_host, socket.gethostname.__doc__.__contains__,    ["host"],    true, "socket.gethostname.__doc__.__contains__('host') == True — gethostname() docstring mentions host"]

# ---------------------------------------------------------------------------
# Standalone invariants for socket __doc__ contains checks
# ---------------------------------------------------------------------------

invariant socket_extra224.module_doc_contains_socket:
  description: "socket.__doc__.__contains__('socket') == True — socket module docstring is 'This module provides socket operations and some related functions...' which contains 'socket'; confirms module docstring is present; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: socket.__doc__.__contains__
  args: ["socket"]
  expected: true

invariant socket_extra224.bind_doc_contains_address:
  description: "socket.socket.bind.__doc__.__contains__('address') == True — bind() docstring is 'bind(address)\\n\\nBind the socket to a local address...' which contains 'address'; confirms the method accepts an address parameter; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: socket.socket.bind.__doc__.__contains__
  args: ["address"]
  expected: true

invariant socket_extra224.gethostname_doc_contains_host:
  description: "socket.gethostname.__doc__.__contains__('host') == True — gethostname() docstring is 'gethostname() -> string\\n\\nReturn the current host name.' which contains 'host'; confirms the function returns host information; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: socket.gethostname.__doc__.__contains__
  args: ["host"]
  expected: true
