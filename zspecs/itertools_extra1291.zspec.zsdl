# islice.__new__.__qualname__ == 'islice.__new__' (len 14)
# pairwise.__new__.__qualname__ == 'pairwise.__new__' (len 16) — added Python 3.10
# All: __init__ not in __dict__; __new__ in __dict__
# All: __init__.__class__.__name__ == 'wrapper_descriptor'
# All: __new__.__class__.__name__ == 'builtin_function_or_method'
#
# New to extra1291.
# ---------------------------------------------------------------------------

