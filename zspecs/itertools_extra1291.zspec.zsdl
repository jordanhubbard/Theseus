spec: itertools_extra1291
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra129.zspec.zsdl and prior extras."
    - "Wave 533 theme: __init__ and __new__ method presence and qualname checks for itertools C extension types."
    - "All itertools classes are C extension types from Modules/itertoolsmodule.c. They do NOT define __init__; all inherit object.__init__ (wrapper_descriptor, qualname 'object.__init__')."
    - "All itertools classes define __new__ (builtin_function_or_method) with qualname '<classname>.__new__'."
    - "itertools.chain.__init__.__qualname__ == 'object.__init__'; __init__ not in chain.__dict__; chain.__new__.__qualname__ == 'chain.__new__'. Verified with Python 3.12."
    - "itertools.cycle.__init__.__qualname__ == 'object.__init__'; __init__ not in cycle.__dict__; cycle.__new__.__qualname__ == 'cycle.__new__'. Verified with Python 3.12."
    - "itertools.repeat.__init__.__qualname__ == 'object.__init__'; __init__ not in repeat.__dict__; repeat.__new__.__qualname__ == 'repeat.__new__'. Verified with Python 3.12."
    - "itertools.accumulate.__init__.__qualname__ == 'object.__init__'; __init__ not in accumulate.__dict__; accumulate.__new__.__qualname__ == 'accumulate.__new__'. Verified with Python 3.12."
    - "itertools.combinations.__init__.__qualname__ == 'object.__init__'; __init__ not in combinations.__dict__; combinations.__new__.__qualname__ == 'combinations.__new__'. Verified with Python 3.12."
    - "itertools.product.__init__.__qualname__ == 'object.__init__'; __init__ not in product.__dict__; product.__new__.__qualname__ == 'product.__new__'. Verified with Python 3.12."
    - "itertools.islice.__init__.__qualname__ == 'object.__init__'; __init__ not in islice.__dict__; islice.__new__.__qualname__ == 'islice.__new__'. Verified with Python 3.12."
    - "itertools.pairwise.__init__.__qualname__ == 'object.__init__'; __init__ not in pairwise.__dict__; pairwise.__new__.__qualname__ == 'pairwise.__new__'. Verified with Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C extension types __init__ qualname and class name
#
# Wave 533 theme: all itertools classes are C extension types; none define
# __init__; all inherit object.__init__ (wrapper_descriptor).
#
# chain, cycle, repeat, accumulate share the same pattern:
#   __init__.__qualname__ == 'object.__init__'
#   __init__.__class__.__name__ == 'wrapper_descriptor'
#   '__init__' not in <cls>.__dict__
#
# New to extra1291.
# ---------------------------------------------------------------------------

table itertools_extra1291.chain_cycle_repeat_accum_init:
  description: "itertools.chain/cycle/repeat/accumulate all inherit object.__init__ (wrapper_descriptor); '__init__' not in their __dict__; all C extension types; wave 533; new to extra1291"
  kind: python_call_eq
  category: string_identity
  id_prefix: it1291cc

  columns: [id, function, args, expected, description]
  rows:
    - [it1291cc001,
       "chain.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "itertools.chain.__init__.__qualname__.__eq__('object.__init__') == True — chain is a C extension type that does not define __init__; it inherits object.__init__ whose __qualname__ is 'object.__init__'; str.__eq__('object.__init__') returns True; new to extra1291"]
    - [it1291cc002,
       "chain.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.chain.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — object.__init__ is a wrapper_descriptor (CPython C-level slot type); __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra1291"]
    - [it1291cc003,
       "chain.__dict__.__contains__",
       ["__init__"],
       false,
       "itertools.chain.__dict__.__contains__('__init__') == False — chain does not define __init__ in its type dict; inherits from object; dict.__contains__('__init__') returns False; new to extra1291"]
    - [it1291cc004,
       "cycle.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "itertools.cycle.__init__.__qualname__.__eq__('object.__init__') == True — cycle is a C extension type that does not define __init__; inherits object.__init__ with __qualname__ 'object.__init__'; str.__eq__('object.__init__') returns True; new to extra1291"]
    - [it1291cc005,
       "cycle.__init__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.cycle.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — object.__init__ accessed via cycle is a wrapper_descriptor; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra1291"]
    - [it1291cc006,
       "cycle.__dict__.__contains__",
       ["__init__"],
       false,
       "itertools.cycle.__dict__.__contains__('__init__') == False — cycle does not define __init__ in its type dict; dict.__contains__('__init__') returns False; new to extra1291"]
    - [it1291cc007,
       "repeat.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "itertools.repeat.__init__.__qualname__.__eq__('object.__init__') == True — repeat is a C extension type that does not define __init__; inherits object.__init__; __qualname__ is 'object.__init__'; str.__eq__('object.__init__') returns True; new to extra1291"]
    - [it1291cc008,
       "repeat.__dict__.__contains__",
       ["__init__"],
       false,
       "itertools.repeat.__dict__.__contains__('__init__') == False — repeat does not define __init__ in its type dict; dict.__contains__('__init__') returns False; new to extra1291"]
    - [it1291cc009,
       "accumulate.__init__.__qualname__.__eq__",
       ["object.__init__"],
       true,
       "itertools.accumulate.__init__.__qualname__.__eq__('object.__init__') == True — accumulate is a C extension type that does not define __init__; inherits object.__init__; __qualname__ is 'object.__init__'; str.__eq__('object.__init__') returns True; new to extra1291"]
    - [it1291cc010,
       "accumulate.__dict__.__contains__",
       ["__init__"],
       false,
       "itertools.accumulate.__dict__.__contains__('__init__') == False — accumulate does not define __init__ in its type dict; dict.__contains__('__init__') returns False; new to extra1291"]

# ---------------------------------------------------------------------------
# Table 2: itertools C extension types __new__ qualname and class name
#
# Wave 533 theme: all itertools C extension types define __new__
# (builtin_function_or_method) with qualname '<classname>.__new__'.
#
# chain.__new__.__qualname__ == 'chain.__new__' (len 13)
# cycle.__new__.__qualname__ == 'cycle.__new__' (len 13)
# repeat.__new__.__qualname__ == 'repeat.__new__' (len 14)
# accumulate.__new__.__qualname__ == 'accumulate.__new__' (len 18)
# All have __class__.__name__ == 'builtin_function_or_method'
# All have '__new__' in <cls>.__dict__
#
# New to extra1291.
# ---------------------------------------------------------------------------

table itertools_extra1291.chain_cycle_repeat_accum_new:
  description: "itertools.chain/cycle/repeat/accumulate all define __new__ (builtin_function_or_method) with qualname '<cls>.__new__'; '__new__' in their __dict__; C extension types; wave 533; new to extra1291"
  kind: python_call_eq
  category: string_identity
  id_prefix: it1291cn

  columns: [id, function, args, expected, description]
  rows:
    - [it1291cn001,
       "chain.__new__.__qualname__.__eq__",
       ["chain.__new__"],
       true,
       "itertools.chain.__new__.__qualname__.__eq__('chain.__new__') == True — chain defines __new__ as a C extension builtin_function_or_method; its __qualname__ is 'chain.__new__' (len 13); str.__eq__('chain.__new__') returns True; new to extra1291"]
    - [it1291cn002,
       "chain.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — chain.__new__ is a C-level allocation function; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra1291"]
    - [it1291cn003,
       "chain.__dict__.__contains__",
       ["__new__"],
       true,
       "itertools.chain.__dict__.__contains__('__new__') == True — chain defines __new__ in its C extension type dict (unlike __init__ which is absent); dict.__contains__('__new__') returns True; new to extra1291"]
    - [it1291cn004,
       "cycle.__new__.__qualname__.__eq__",
       ["cycle.__new__"],
       true,
       "itertools.cycle.__new__.__qualname__.__eq__('cycle.__new__') == True — cycle defines __new__ as a C extension builtin_function_or_method; __qualname__ is 'cycle.__new__' (len 13); str.__eq__('cycle.__new__') returns True; new to extra1291"]
    - [it1291cn005,
       "cycle.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.cycle.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — cycle.__new__ is a C-level function; __class__.__name__ is 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra1291"]
    - [it1291cn006,
       "repeat.__new__.__qualname__.__eq__",
       ["repeat.__new__"],
       true,
       "itertools.repeat.__new__.__qualname__.__eq__('repeat.__new__') == True — repeat defines __new__ as a C extension builtin_function_or_method; __qualname__ is 'repeat.__new__' (len 14); str.__eq__('repeat.__new__') returns True; new to extra1291"]
    - [it1291cn007,
       "accumulate.__new__.__qualname__.__eq__",
       ["accumulate.__new__"],
       true,
       "itertools.accumulate.__new__.__qualname__.__eq__('accumulate.__new__') == True — accumulate defines __new__ as a C extension builtin_function_or_method; __qualname__ is 'accumulate.__new__' (len 18); str.__eq__('accumulate.__new__') returns True; new to extra1291"]
    - [it1291cn008,
       "accumulate.__new__.__qualname__.__len__",
       [],
       18,
       "itertools.accumulate.__new__.__qualname__.__len__() == 18 — 'accumulate.__new__' has 18 characters: 'accumulate' (10) + '.' (1) + '__new__' (7) = 18; the longest __new__.__qualname__ among chain/cycle/repeat/accumulate; new to extra1291"]

# ---------------------------------------------------------------------------
# Table 3: itertools combinations, product, islice, pairwise __init__/__new__
#
# Wave 533 theme: additional itertools C extension type __init__/__new__ checks.
#
# combinations.__new__.__qualname__ == 'combinations.__new__' (len 20)
