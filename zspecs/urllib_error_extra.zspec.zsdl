spec: urllib_error_extra
version: ">=3.0"
backend: python_module(urllib.error)

docs: https://docs.python.org/3/library/urllib.error.html

provenance:
  derived_from:
    - "Python 3 urllib.error documentation — https://docs.python.org/3/library/urllib.error.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/urllib/error.py"
  notes:
    - "Complements urllib_error.zspec.zsdl."
    - "URLError.__name__ is 'URLError', HTTPError.__name__ is 'HTTPError'."
    - "HTTPError.__bases__[0].__name__ is 'URLError' — HTTPError directly subclasses URLError."
    - "All expected values verified by running Python 3.14.3 urllib.error module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Exception classes; they are raised by urllib.request operations on network failures or HTTP errors."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# class __name__ checks
# ---------------------------------------------------------------------------

invariant urllib_error_extra.urlerror.name:
  description: "urllib.error.URLError.__name__ == 'URLError'"
  category: class_names
  kind: python_call_eq
  function: URLError.__name__.__eq__
  args: ["URLError"]
  expected: true

invariant urllib_error_extra.httperror.name:
  description: "urllib.error.HTTPError.__name__ == 'HTTPError'"
  category: class_names
  kind: python_call_eq
  function: HTTPError.__name__.__eq__
  args: ["HTTPError"]
  expected: true

invariant urllib_error_extra.httperror.base_is_urlerror:
  description: "urllib.error.HTTPError.__bases__[0].__name__ == 'URLError'"
  category: class_names
  kind: python_call_eq
  function: HTTPError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "URLError"
