spec: hashlib_extra1246
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib __doc__ class checks"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks that hashlib module and key functions have str __doc__ attributes; verifies __doc__.__class__.__name__ eq str is true and eq NoneType is false"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1246.module_doc_class:
  description: "hashlib module and core functions __doc__ is a str"
  kind: python_call_eq
  category: doc_class
  id_prefix: hl1246md
  columns: [id, function, args, expected]
  rows:
    - [hl1246md001, hashlib.__doc__.__class__.__name__.__eq__,          ["str"],      true]
    - [hl1246md002, hashlib.new.__doc__.__class__.__name__.__eq__,      ["str"],      true]
    - [hl1246md003, hashlib.md5.__doc__.__class__.__name__.__eq__,      ["str"],      true]
    - [hl1246md004, hashlib.sha1.__doc__.__class__.__name__.__eq__,     ["str"],      true]
    - [hl1246md005, hashlib.sha256.__doc__.__class__.__name__.__eq__,   ["str"],      true]
    - [hl1246md006, hashlib.sha512.__doc__.__class__.__name__.__eq__,   ["str"],      true]
    - [hl1246md007, hashlib.sha224.__doc__.__class__.__name__.__eq__,   ["str"],      true]
    - [hl1246md008, hashlib.sha384.__doc__.__class__.__name__.__eq__,   ["str"],      true]
    - [hl1246md009, hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__eq__, ["str"],   true]

table hashlib_extra1246.module_doc_not_nonetype:
  description: "hashlib module and core functions __doc__ is not NoneType"
  kind: python_call_eq
  category: doc_not_nonetype
  id_prefix: hl1246mn
  columns: [id, function, args, expected]
  rows:
    - [hl1246mn001, hashlib.__doc__.__class__.__name__.__eq__,          ["NoneType"], false]
    - [hl1246mn002, hashlib.new.__doc__.__class__.__name__.__eq__,      ["NoneType"], false]
    - [hl1246mn003, hashlib.md5.__doc__.__class__.__name__.__eq__,      ["NoneType"], false]
    - [hl1246mn004, hashlib.sha1.__doc__.__class__.__name__.__eq__,     ["NoneType"], false]
    - [hl1246mn005, hashlib.sha256.__doc__.__class__.__name__.__eq__,   ["NoneType"], false]
    - [hl1246mn006, hashlib.sha512.__doc__.__class__.__name__.__eq__,   ["NoneType"], false]
    - [hl1246mn007, hashlib.sha224.__doc__.__class__.__name__.__eq__,   ["NoneType"], false]
    - [hl1246mn008, hashlib.sha384.__doc__.__class__.__name__.__eq__,   ["NoneType"], false]
    - [hl1246mn009, hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__eq__, ["NoneType"], false]

table hashlib_extra1246.doc_class_name_is_str:
  description: "hashlib __doc__ class name is itself a str (meta-level check)"
  kind: python_call_eq
  category: doc_class_name_is_str
  id_prefix: hl1246ds
  columns: [id, function, args, expected]
  rows:
    - [hl1246ds001, hashlib.__doc__.__class__.__name__.__class__.__name__.__eq__,          ["str"], true]
    - [hl1246ds002, hashlib.new.__doc__.__class__.__name__.__class__.__name__.__eq__,      ["str"], true]
    - [hl1246ds003, hashlib.md5.__doc__.__class__.__name__.__class__.__name__.__eq__,      ["str"], true]
    - [hl1246ds004, hashlib.sha1.__doc__.__class__.__name__.__class__.__name__.__eq__,     ["str"], true]
    - [hl1246ds005, hashlib.sha256.__doc__.__class__.__name__.__class__.__name__.__eq__,   ["str"], true]
    - [hl1246ds006, hashlib.sha512.__doc__.__class__.__name__.__class__.__name__.__eq__,   ["str"], true]
    - [hl1246ds007, hashlib.sha224.__doc__.__class__.__name__.__class__.__name__.__eq__,   ["str"], true]
    - [hl1246ds008, hashlib.sha384.__doc__.__class__.__name__.__class__.__name__.__eq__,   ["str"], true]
    - [hl1246ds009, hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__class__.__name__.__eq__, ["str"], true]
