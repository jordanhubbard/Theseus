spec: profile_extra4
version: ">=3.9"
backend: python_module(profile)

docs: https://docs.python.org/3/library/profile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "profile source: sys.setprofile internals"
    - "profile.zspec.zsdl — covers Profile.__name__, Profile.__module__, Profile.__bases__[0].__name__, Profile methods __name__, Profile instantiation, module __name__"
    - "profile_extra.zspec.zsdl — covers Profile.__name__, Profile.__module__, run.__name__, runctx.__name__"
    - "profile_extra2.zspec.zsdl — covers SortKey enum member values, Stats.dump_stats, Stats.add (pstats backend)"
    - "profile_extra3.zspec.zsdl — covers Profile.__qualname__, run.__module__, runctx.__module__, function_names table, Profile.__qualname__.__class__.__name__"
  notes:
    - "This spec extends profile.zspec.zsdl through profile_extra3.zspec.zsdl."
    - "Focus: Profile method __qualname__ and __module__ (not covered by any prior profile spec); Profile.__bases__.__len__; Profile.__doc__; Profile method type checks; run and runctx __qualname__."
    - "Profile.run.__qualname__ == 'Profile.run' — method qualname includes class prefix."
    - "Profile.runcall.__qualname__ == 'Profile.runcall' — likewise."
    - "Profile.runctx.__qualname__ == 'Profile.runctx' — likewise."
    - "Profile.print_stats.__qualname__ == 'Profile.print_stats' — likewise."
    - "Profile.dump_stats.__qualname__ == 'Profile.dump_stats' — likewise."
    - "Profile.run.__module__ == 'profile' — method is defined in the profile module."
    - "Profile.runcall.__module__ == 'profile' — likewise."
    - "Profile.runctx.__module__ == 'profile' — likewise."
    - "Profile.print_stats.__module__ == 'profile' — likewise."
    - "Profile.dump_stats.__module__ == 'profile' — likewise."
    - "len(Profile.__bases__) == 1 — Profile has exactly one direct base class (object)."
    - "Profile.__doc__ is a str — the class has a docstring."
    - "Profile methods are plain Python functions (not built-ins)."
    - "run.__qualname__ == 'run' — module-level function; qualname equals name."
    - "runctx.__qualname__ == 'runctx' — module-level function; qualname equals name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Profile method __qualname__ checks
# profile.zspec.zsdl covers Profile method __name__; no prior spec covers __qualname__.
# For instance methods, __qualname__ == '<ClassName>.<method_name>'.
# ---------------------------------------------------------------------------

table profile_extra4.Profile_method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: method_qualname

  columns: [id, function, args, expected]
  rows:
    - [run,        Profile.run.__qualname__.__eq__,        ["Profile.run"],        true]
    - [runcall,    Profile.runcall.__qualname__.__eq__,    ["Profile.runcall"],    true]
    - [runctx,     Profile.runctx.__qualname__.__eq__,     ["Profile.runctx"],     true]
    - [print_stats, Profile.print_stats.__qualname__.__eq__, ["Profile.print_stats"], true]
    - [dump_stats, Profile.dump_stats.__qualname__.__eq__, ["Profile.dump_stats"], true]

# ---------------------------------------------------------------------------
# Profile method __module__ checks
# No prior profile spec covers method __module__ affiliation.
# ---------------------------------------------------------------------------

table profile_extra4.Profile_method_modules:
  kind: python_call_eq
  category: method_modules
  id_prefix: method_module

  columns: [id, function, args, expected]
  rows:
    - [run,        Profile.run.__module__.__eq__,        ["profile"], true]
    - [runcall,    Profile.runcall.__module__.__eq__,    ["profile"], true]
    - [runctx,     Profile.runctx.__module__.__eq__,     ["profile"], true]
    - [print_stats, Profile.print_stats.__module__.__eq__, ["profile"], true]
    - [dump_stats, Profile.dump_stats.__module__.__eq__, ["profile"], true]

# ---------------------------------------------------------------------------
# Profile.__bases__.__len__ — base class count
# profile.zspec.zsdl checks __bases__[0].__name__ but not the count.
# ---------------------------------------------------------------------------

invariant profile_extra4.Profile.bases_len:
  description: "len(profile.Profile.__bases__) == 1 — Profile has exactly one direct base class"
  category: hierarchy
  kind: python_call_eq
  function: Profile.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# Profile method type checks — all methods are plain Python functions
# timeit_extra.zspec.zsdl covers this pattern for Timer methods;
# no prior profile spec checks Profile method types.
# ---------------------------------------------------------------------------

table profile_extra4.Profile_method_types:
  kind: python_call_eq
  category: method_types
  id_prefix: method_type

  columns: [id, function, args, expected]
  rows:
    - [run_is_function,        Profile.run.__class__.__name__.__eq__,        ["function"], true]
    - [runcall_is_function,    Profile.runcall.__class__.__name__.__eq__,    ["function"], true]
    - [runctx_is_function,     Profile.runctx.__class__.__name__.__eq__,     ["function"], true]
    - [print_stats_is_function, Profile.print_stats.__class__.__name__.__eq__, ["function"], true]
    - [dump_stats_is_function,  Profile.dump_stats.__class__.__name__.__eq__,  ["function"], true]

# ---------------------------------------------------------------------------
# Module-level function __qualname__
# profile_extra3 covers run/__module__ and runctx/__module__ and Profile/__qualname__.
# This spec adds run/__qualname__ and runctx/__qualname__, which no prior spec covers.
# ---------------------------------------------------------------------------

invariant profile_extra4.functions.run_qualname:
  description: "profile.run.__qualname__ == 'run' — module-level function qualname equals name"
  category: function_qualnames
  kind: python_call_eq
  function: run.__qualname__.__eq__
  args: ["run"]
  expected: true

invariant profile_extra4.functions.runctx_qualname:
  description: "profile.runctx.__qualname__ == 'runctx' — module-level function qualname equals name"
  category: function_qualnames
  kind: python_call_eq
  function: runctx.__qualname__.__eq__
  args: ["runctx"]
  expected: true
