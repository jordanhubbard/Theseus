spec: profile_extra4
version: ">=3.9"
backend: python_module(profile)

docs: https://docs.python.org/3/library/profile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "profile source: sys.setprofile internals"
  notes:
    - "This spec extends profile.zspec.zsdl, profile_extra.zspec.zsdl, and profile_extra3.zspec.zsdl."
    - "profile.zspec.zsdl covers: Profile/__name__/__module__/bases/methods/instantiation; module __name__."
    - "profile_extra.zspec.zsdl covers: Profile/__name__/__module__; run/__name__; runctx/__name__."
    - "profile_extra3.zspec.zsdl covers: Profile/__qualname__; run/__module__; runctx/__module__; function_names table; Profile/__qualname__ class check."
    - "This spec adds: run/__qualname__ and runctx/__qualname__ — not covered in any prior profile spec."
    - "profile.run.__qualname__ == 'run' — module-level function; qualname equals name."
    - "profile.runctx.__qualname__ == 'runctx' — module-level function; qualname equals name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __qualname__
# profile_extra3 covers run/__module__ and runctx/__module__ and Profile/__qualname__.
# This spec adds run/__qualname__ and runctx/__qualname__, which no prior spec covers.
# ---------------------------------------------------------------------------

table profile_extra4.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [run,    run.__qualname__.__eq__,    ["run"],    true]
    - [runctx, runctx.__qualname__.__eq__, ["runctx"], true]
