spec: inspect_extra16
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect.zspec.zsdl and prior extras through inspect_extra15.zspec.zsdl."
    - "inspect_extra15 covers __name__ and __qualname__ for isfunction/isbuiltin/isclass/ismodule/ismethod/ismethoddescriptor (table); Signature/BoundArguments/Parameter __module__; FullArgSpec __qualname__/__module__."
    - "inspect_extra14 covers getmembers/getmodule/getfile/getsource/getsourcelines __qualname__ (table); Signature/BoundArguments/Parameter __bases__.__len__; Parameter kind enum values."
    - "NOT yet covered as standalone invariants: isgenerator/__qualname__/__module__, iscoroutine/__qualname__/__module__, isasyncgen/__qualname__/__module__, isabstract/__qualname__/__module__."
    - "NOT yet covered: isclass/__module__, ismodule/__module__, isfunction/__module__, ismethod/__module__ as standalone named invariants (inspect_extra15 only covered __name__/__qualname__ for these)."
    - "NOT yet covered: getfile/__module__, getsource/__module__, getmodule/__module__ as standalone invariants."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Predicate function __qualname__ — isgenerator, iscoroutine, isasyncgen,
# isabstract
#
# inspect_extra15 covers __qualname__ for isfunction/isbuiltin/isclass/ismodule/
# ismethod/ismethoddescriptor. No prior inspect spec checks __qualname__ for
# isgenerator, iscoroutine, isasyncgen, or isabstract as standalone invariants.
# ---------------------------------------------------------------------------

table inspect_extra16.async_predicate_qualnames:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qname

  columns: [id, function, args, expected]
  rows:
    - [isgenerator,  isgenerator.__qualname__.__eq__,  ["isgenerator"],  true]
    - [iscoroutine,  iscoroutine.__qualname__.__eq__,  ["iscoroutine"],  true]
    - [isasyncgen,   isasyncgen.__qualname__.__eq__,   ["isasyncgen"],   true]
    - [isabstract,   isabstract.__qualname__.__eq__,   ["isabstract"],   true]

# ---------------------------------------------------------------------------
# Predicate function __module__ — isclass, ismodule, isgenerator, iscoroutine,
# isasyncgen, isabstract
#
# inspect_extra15 confirms __name__ and __qualname__ for isclass/ismodule but
# does not check __module__ for any is* predicate. All are pure Python functions
# defined in the inspect module, so __module__ == 'inspect'.
# ---------------------------------------------------------------------------

table inspect_extra16.predicate_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [isclass,      isclass.__module__.__eq__,      ["inspect"], true]
    - [ismodule,     ismodule.__module__.__eq__,     ["inspect"], true]
    - [isfunction,   isfunction.__module__.__eq__,   ["inspect"], true]
    - [ismethod,     ismethod.__module__.__eq__,     ["inspect"], true]
    - [isgenerator,  isgenerator.__module__.__eq__,  ["inspect"], true]
    - [iscoroutine,  iscoroutine.__module__.__eq__,  ["inspect"], true]
    - [isasyncgen,   isasyncgen.__module__.__eq__,   ["inspect"], true]
    - [isabstract,   isabstract.__module__.__eq__,   ["inspect"], true]

# ---------------------------------------------------------------------------
# Utility function __module__ — getfile, getsource, getmodule
#
# inspect_extra14 covers getfile/getsource/getmodule __qualname__ as part of
# a table. No prior inspect spec verifies __module__ for these three functions
# as standalone named invariants.
# ---------------------------------------------------------------------------

invariant inspect_extra16.getfile.module:
  description: "inspect.getfile.__module__ == 'inspect' — getfile is defined in the inspect module"
  category: module_attrs
  kind: python_call_eq
  function: getfile.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra16.getsource.module:
  description: "inspect.getsource.__module__ == 'inspect' — getsource is defined in the inspect module"
  category: module_attrs
  kind: python_call_eq
  function: getsource.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra16.getmodule.module:
  description: "inspect.getmodule.__module__ == 'inspect' — getmodule is defined in the inspect module"
  category: module_attrs
  kind: python_call_eq
  function: getmodule.__module__.__eq__
  args: ["inspect"]
  expected: true
