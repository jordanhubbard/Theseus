spec: uuid_extra246
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 246 theme: uuid.UUID constructor error cases and method class identity."
    - "uuid.UUID('invalid-uuid') raises ValueError: badly formed hexadecimal UUID string. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID('abc123') raises ValueError: badly formed hexadecimal UUID string (too short). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID(int=-1) raises ValueError: int is out of range (need a 128-bit value). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID(int=2**128) raises ValueError: int is out of range (need a 128-bit value). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID() with no arguments raises TypeError: one of the hex, bytes, bytes_le, fields, or int arguments must be given. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID(int=0, hex='0'*32) raises TypeError: one of the hex, bytes, bytes_le, fields, or int arguments must be given. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__class__.__name__ == 'function'. UUID.__init__ is a plain Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__class__.__name__ == 'function'. UUID.__hash__ is a plain Python function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: UUID constructor accepts exactly one of: hex (32-char string), bytes (16-byte big-endian), bytes_le (16-byte little-endian), fields (6-tuple), int (128-bit integer). No combination of two or more is valid."
    - "Note: int must be in range [0, 2**128 - 1]. Negative values and values >= 2**128 raise ValueError."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID('invalid-uuid') raises ValueError
# uuid.UUID('abc123') raises ValueError
#
# Wave 246 theme: UUID constructor raises ValueError for malformed string inputs.
#
# uuid.UUID validates its string and hex arguments against the canonical
# 8-4-4-4-12 hexadecimal format (32 hex digits with optional hyphens). Any
# string that does not conform — whether too short, too long, containing
# non-hex characters, or with wrong hyphen placement — raises ValueError with
# the message 'badly formed hexadecimal UUID string'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra246.UUID_malformed_string_raises:
  description: "uuid.UUID raises ValueError for malformed string arguments in uuiderr246a namespace — wave 246 theme: UUID('invalid-uuid') raises ValueError; UUID('abc123') raises ValueError (too short); UUID constructor validates 8-4-4-4-12 canonical format; non-conforming strings raise ValueError 'badly formed hexadecimal UUID string'; verified with Python 3.14.3"
  kind: python_call_raises
  category: errors
  id_prefix: uuiderr246a

  columns: [id, function, args, expected, description]
  rows:
    - [invalid_str,  uuid.UUID, ["invalid-uuid"],  ValueError, "uuid.UUID('invalid-uuid') raises ValueError — badly formed hexadecimal UUID string"]
    - [short_str,    uuid.UUID, ["abc123"],         ValueError, "uuid.UUID('abc123') raises ValueError — too short, not a valid 32-hex-char UUID string"]

# ---------------------------------------------------------------------------
# uuid.UUID(hex='xyz') raises ValueError
#
# Wave 246 theme: UUID constructor raises ValueError for short hex kwarg.
#
# uuid.UUID(hex='xyz') raises ValueError because the hex argument must be
# exactly 32 hexadecimal characters representing a 128-bit UUID. 'xyz' is
# only 3 characters and raises ValueError 'badly formed hexadecimal UUID string'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra246.UUID_short_hex_kwarg_raises:
  description: "uuid.UUID(hex='xyz') raises ValueError — hex kwarg must be exactly 32 hexadecimal characters (with optional hyphens); 'xyz' is 3 chars and invalid; raises ValueError 'badly formed hexadecimal UUID string'; tested as standalone because kwargs cannot be expressed in table rows; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: errors
  kind: python_call_raises
  function: uuid.UUID
  args: []
  kwargs:
    hex: "xyz"
  expected_exception: ValueError

# ---------------------------------------------------------------------------
# uuid.UUID(int=-1) raises ValueError
# uuid.UUID(int=2**128) raises ValueError
#
# Wave 246 theme: UUID constructor raises ValueError for out-of-range int arguments.
#
# The int argument to uuid.UUID must be in the range [0, 2**128 - 1]. Values
# outside this range are rejected with ValueError: 'int is out of range (need
# a 128-bit value)'. A UUID is a 128-bit number so valid integer representations
# are 0 through 340282366920938463463374607431768211455 (2**128 - 1) inclusive.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra246.UUID_negative_int_raises:
  description: "uuid.UUID(int=-1) raises ValueError — UUID int argument must be a 128-bit non-negative integer in [0, 2**128 - 1]; -1 is negative and therefore out of range; raises ValueError 'int is out of range (need a 128-bit value)'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: errors
  kind: python_call_raises
  function: uuid.UUID
  args: []
  kwargs:
    int: -1
  expected_exception: ValueError

invariant uuid_extra246.UUID_too_large_int_raises:
  description: "uuid.UUID(int=2**128) raises ValueError — UUID int argument must be in [0, 2**128 - 1]; 2**128 equals 340282366920938463463374607431768211456 which exceeds the maximum 128-bit value by 1; raises ValueError 'int is out of range (need a 128-bit value)'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: errors
  kind: python_call_raises
  function: uuid.UUID
  args: []
  kwargs:
    int: 340282366920938463463374607431768211456
  expected_exception: ValueError

# ---------------------------------------------------------------------------
# uuid.UUID() raises TypeError (no arguments)
# uuid.UUID(int=0, hex='0'*32) raises TypeError (conflicting arguments)
#
# Wave 246 theme: UUID constructor raises TypeError for missing or conflicting args.
#
# uuid.UUID() with no arguments raises TypeError because exactly one of the
# keyword arguments (hex, bytes, bytes_le, fields, int) must be supplied.
# uuid.UUID(int=0, hex='0'*32) also raises TypeError because only one of
# these mutually exclusive arguments may be given at a time.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra246.UUID_no_args_raises:
  description: "uuid.UUID() raises TypeError — UUID constructor requires exactly one of: hex, bytes, bytes_le, fields, or int keyword argument; providing none raises TypeError 'one of the hex, bytes, bytes_le, fields, or int arguments must be given'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: errors
  kind: python_call_raises
  function: uuid.UUID
  args: []
  expected_exception: TypeError

invariant uuid_extra246.UUID_conflicting_args_raises:
  description: "uuid.UUID(int=0, hex='00000000000000000000000000000000') raises TypeError — UUID constructor arguments hex/bytes/bytes_le/fields/int are mutually exclusive; providing two simultaneously raises TypeError 'one of the hex, bytes, bytes_le, fields, or int arguments must be given'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: errors
  kind: python_call_raises
  function: uuid.UUID
  args: []
  kwargs:
    int: 0
    hex: "00000000000000000000000000000000"
  expected_exception: TypeError

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__class__.__name__.__eq__('function')
# uuid.UUID.__hash__.__class__.__name__.__eq__('function')
#
# Wave 246 theme: UUID dunder method class identity.
#
# UUID.__init__ and UUID.__hash__ are plain Python functions defined in
# Lib/uuid.py. Their __class__.__name__ is 'function', confirming they are
# Python-level (not C-extension) implementations. UUID is a pure Python class
# and all its methods are Python functions.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra246.UUID_method_class_identity:
  description: "UUID.__init__ and UUID.__hash__ are Python function objects — UUID.__init__.__class__.__name__.__eq__('function')==True / UUID.__hash__.__class__.__name__.__eq__('function')==True — UUID is a pure Python class in Lib/uuid.py; all dunder methods are Python functions (not C builtins); wave 246 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmeth246

  columns: [id, function, args, expected, description]
  rows:
    - [init_class,  UUID.__init__.__class__.__name__.__eq__,  ["function"], true, "UUID.__init__.__class__.__name__ == 'function'; __init__ is a Python function in Lib/uuid.py"]
    - [hash_class,  UUID.__hash__.__class__.__name__.__eq__,  ["function"], true, "UUID.__hash__.__class__.__name__ == 'function'; __hash__ is a Python function in Lib/uuid.py"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__class__.__name__.__eq__('function') — standalone
#
# uuid.UUID.__init__.__class__.__name__ is 'function'. UUID is a pure Python
# class defined in Lib/uuid.py. Unlike built-in types (e.g., int, str) whose
# methods are C-level slot wrappers or method_descriptor objects, UUID's methods
# are plain Python functions. UUID.__init__ accepts the mutually exclusive
# keyword arguments: hex, bytes, bytes_le, fields, int; an optional version
# (1-5); and an optional is_safe parameter (SafeUUID enum). The __class__.__name__
# 'function' confirms this is Python-level code, not a C extension. This is the
# first standalone anchor for UUID.__init__.__class__.__name__ under uuidmeth246.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra246.UUID_init_class_is_function:
  description: "uuid.UUID.__init__.__class__.__name__.__eq__('function') == True — UUID is a pure Python class; __init__ accepts mutually exclusive hex/bytes/bytes_le/fields/int plus optional version (1-5) and is_safe (SafeUUID); __class__.__name__=='function' confirms Python-level implementation not C slot wrapper; first standalone for UUID.__init__.__class__.__name__ under uuidmeth246; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: UUID.__init__.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__hash__.__class__.__name__.__eq__('function') — standalone
#
# uuid.UUID.__hash__.__class__.__name__ is 'function'. UUID.__hash__ returns
# a hash of the UUID's integer value (self.int). Since UUID is immutable
# (all attributes are stored in __slots__ via object.__setattr__ to enforce
# immutability), it defines __hash__ to be consistent with __eq__ based on
# the integer value. UUID instances are therefore hashable and can be used
# as dict keys or set members. The __hash__ implementation is a plain Python
# function in Lib/uuid.py. This is the first standalone anchor for
# UUID.__hash__.__class__.__name__ under uuidmeth246.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra246.UUID_hash_class_is_function:
  description: "uuid.UUID.__hash__.__class__.__name__.__eq__('function') == True — UUID is immutable (uses __slots__ + object.__setattr__); __hash__ returns hash(self.int) enabling UUID use as dict keys and set members; __hash__ consistent with __eq__ on integer value; __class__.__name__=='function' confirms pure Python; first standalone for UUID.__hash__.__class__.__name__ under uuidmeth246; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: identity
  kind: python_call_eq
  function: UUID.__hash__.__class__.__name__.__eq__
  args: ["function"]
  expected: true
