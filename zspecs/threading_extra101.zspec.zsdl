spec: threading_extra101
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra99

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra99.zspec.zsdl."
    - "This spec covers: threading.local C-type identity (__name__=='_local', __module__=='_thread', __mro__ len==2); threading._RLock class identity (__name__=='_RLock', __module__=='threading', __bases__[0]=='object', __mro__ len==2); threading.BoundedSemaphore identity (__bases__[0]=='Semaphore', __mro__ len==3); threading.Condition/Barrier __bases__[0]=='object' and MRO lengths (Wave 257)."
    - "threading.local.__name__ == '_local' — the C extension class is named '_local'. Verified with Python 3.14.3."
    - "threading.local.__module__ == '_thread' — local is a C extension class from _threadmodule.c. Verified with Python 3.14.3."
    - "threading.local.__mro__ len == 2 — MRO is [_local, object]. Verified with Python 3.14.3."
    - "threading._RLock.__name__ == '_RLock'. Verified with Python 3.14.3."
    - "threading._RLock.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading._RLock.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading._RLock.__mro__ len == 2 — MRO is [_RLock, object]. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__mro__ len == 3 — MRO is [BoundedSemaphore, Semaphore, object]. Verified with Python 3.14.3."
    - "threading.Condition.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.Condition.__mro__ len == 2. Verified with Python 3.14.3."
    - "threading.Barrier.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "threading.Barrier.__mro__ len == 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.local C-type identity (__name__, __module__, __mro__ len)
#
# Wave 257 theme: threading.local is a C extension class named '_local'.
#
# threading.local.__name__ == '_local'
# threading.local.__qualname__ == '_local'
# threading.local.__module__ == '_thread'
# threading.local.__class__.__name__ == 'type'
# threading.local.__bases__[0].__name__ == 'object'
# len(threading.local.__mro__) == 2
#
# threading.local is actually the C extension class _thread._local defined in
# Modules/_threadmodule.c; its __name__ and __qualname__ are '_local' (lowercase
# with underscore). Its __module__ is '_thread' not 'threading'. New to extra101.
# ---------------------------------------------------------------------------

table threading_extra101.local_type_identity:
  description: "threading.local C-type identity: __name__=='_local', __qualname__=='_local', __module__=='_thread', __class__.__name__=='type', __bases__[0]=='object', __mro__ len==2; wave 257; new to extra101"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglocal101

  columns: [id, function, args, expected, description]
  rows:
    - [local_name_eq_local_c,
       "local.__name__.__eq__",
       ["_local"],
       true,
       "threading.local.__name__.__eq__('_local') == True — threading.local is the C extension class _thread._local defined in Modules/_threadmodule.c; the underlying C type name begins with an underscore; __name__ is '_local' (not 'local'); str.__eq__('_local') returns True; new to extra101"]
    - [local_qualname_eq_local_c,
       "local.__qualname__.__eq__",
       ["_local"],
       true,
       "threading.local.__qualname__.__eq__('_local') == True — the __qualname__ of the C extension type _local is also '_local'; it matches __name__ since the type is defined at module scope in the C extension; str.__eq__('_local') returns True; new to extra101"]
    - [local_module_eq_thread,
       "local.__module__.__eq__",
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — threading.local is an alias for the C extension class _thread._local; its __module__ attribute points to the underlying C extension module '_thread', not to 'threading'; str.__eq__('_thread') returns True; new to extra101"]
    - [local_class_name_eq_type,
       "local.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.local.__class__.__name__.__eq__('type') == True — threading.local is a proper class (a C extension type); its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra101"]
    - [local_bases_first_eq_object,
       "local.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.local.__bases__[0].__name__.__eq__('object') == True — the _local C type inherits directly from object with no intermediate base class; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra101"]
    - [local_mro_len_eq_2,
       "local.__mro__.__len__",
       [],
       2,
       "threading.local.__mro__.__len__() == 2 — the MRO of _local is [_local, object]; it inherits directly from object; len(__mro__) == 2; new to extra101"]

# ---------------------------------------------------------------------------
# Table 2: threading._RLock class identity (__name__, __module__, __bases__, __mro__)
#
# Wave 257 theme: threading._RLock is a pure-Python class in Lib/threading.py.
#
# threading._RLock.__name__ == '_RLock'
# threading._RLock.__qualname__ == '_RLock'
# threading._RLock.__module__ == 'threading'
# threading._RLock.__class__.__name__ == 'type'
# threading._RLock.__bases__[0].__name__ == 'object'
# len(threading._RLock.__mro__) == 2
#
# threading._RLock is the underlying class returned by threading.RLock().
# Unlike threading.RLock (a factory function), _RLock is the actual class.
# New to extra101.
# ---------------------------------------------------------------------------

table threading_extra101.rlock_class_identity:
  description: "threading._RLock class identity: __name__=='_RLock', __module__=='threading', __bases__[0]=='object', __mro__ len==2; wave 257; new to extra101"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglocal101

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_name_eq_RLock,
       "_RLock.__name__.__eq__",
       ["_RLock"],
       true,
       "threading._RLock.__name__.__eq__('_RLock') == True — threading._RLock is the pure-Python class defined as 'class _RLock:' in Lib/threading.py; its __name__ is '_RLock' (with leading underscore to indicate it is not part of the public API); str.__eq__('_RLock') returns True; new to extra101"]
    - [rlock_qualname_eq_RLock,
       "_RLock.__qualname__.__eq__",
       ["_RLock"],
       true,
       "threading._RLock.__qualname__.__eq__('_RLock') == True — _RLock is defined at module scope in Lib/threading.py; its __qualname__ equals the simple class name '_RLock'; str.__eq__('_RLock') returns True; new to extra101"]
    - [rlock_module_eq_threading,
       "_RLock.__module__.__eq__",
       ["threading"],
       true,
       "threading._RLock.__module__.__eq__('threading') == True — _RLock is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra101"]
    - [rlock_class_name_eq_type,
       "_RLock.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading._RLock.__class__.__name__.__eq__('type') == True — _RLock is a Python class; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra101"]
    - [rlock_bases_first_eq_object,
       "_RLock.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading._RLock.__bases__[0].__name__.__eq__('object') == True — _RLock inherits directly from object with no intermediate base class in Lib/threading.py; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra101"]
    - [rlock_mro_len_eq_2,
       "_RLock.__mro__.__len__",
       [],
       2,
       "threading._RLock.__mro__.__len__() == 2 — _RLock inherits only from object; its MRO is [_RLock, object]; len(__mro__) == 2; new to extra101"]

# ---------------------------------------------------------------------------
# Table 3: threading.BoundedSemaphore, Condition, Barrier MRO lengths and bases
#
# Wave 257 theme: threading primitive class hierarchy — BoundedSemaphore extends Semaphore.
#
# threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
# threading.BoundedSemaphore.__module__ == 'threading'
# len(threading.BoundedSemaphore.__mro__) == 3
# threading.Condition.__bases__[0].__name__ == 'object'
# len(threading.Condition.__mro__) == 2
# threading.Barrier.__bases__[0].__name__ == 'object'
# len(threading.Barrier.__mro__) == 2
#
# BoundedSemaphore inherits from Semaphore giving it MRO length 3.
# Condition and Barrier both inherit directly from object (MRO length 2).
# New to extra101.
# ---------------------------------------------------------------------------

table threading_extra101.bounded_semaphore_condition_barrier_identity:
  description: "threading.BoundedSemaphore bases from Semaphore (MRO len 3); Condition/Barrier bases from object (MRO len 2); wave 257; new to extra101"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglocal101

  columns: [id, function, args, expected, description]
  rows:
    - [bounded_semaphore_bases_first_eq_Semaphore,
       "BoundedSemaphore.__bases__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — BoundedSemaphore is defined as 'class BoundedSemaphore(Semaphore):' in Lib/threading.py; it adds an upper-bound check to prevent releasing beyond the initial value; its base class is Semaphore; __bases__[0].__name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra101"]
    - [bounded_semaphore_module_eq_threading,
       "BoundedSemaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.BoundedSemaphore.__module__.__eq__('threading') == True — BoundedSemaphore is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra101"]
    - [bounded_semaphore_mro_len_eq_3,
       "BoundedSemaphore.__mro__.__len__",
       [],
       3,
       "threading.BoundedSemaphore.__mro__.__len__() == 3 — BoundedSemaphore inherits from Semaphore which inherits from object; the MRO is [BoundedSemaphore, Semaphore, object]; len(__mro__) == 3; new to extra101"]
    - [condition_bases_first_eq_object,
       "Condition.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Condition.__bases__[0].__name__.__eq__('object') == True — Condition is defined as 'class Condition:' in Lib/threading.py with no explicit base (so it inherits from object); it implements a condition variable for complex thread synchronization; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra101"]
    - [condition_mro_len_eq_2,
       "Condition.__mro__.__len__",
       [],
       2,
       "threading.Condition.__mro__.__len__() == 2 — Condition inherits directly from object; its MRO is [Condition, object]; len(__mro__) == 2; new to extra101"]
    - [barrier_bases_first_eq_object,
       "Barrier.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Barrier.__bases__[0].__name__.__eq__('object') == True — Barrier is defined as 'class Barrier:' in Lib/threading.py with no explicit base; it implements a thread barrier that blocks until a fixed number of threads have called wait(); __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra101"]
    - [barrier_mro_len_eq_2,
       "Barrier.__mro__.__len__",
       [],
       2,
       "threading.Barrier.__mro__.__len__() == 2 — Barrier inherits directly from object; its MRO is [Barrier, object]; len(__mro__) == 2; new to extra101"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra101
# ---------------------------------------------------------------------------

invariant threading_extra101.local_name:
  description: "threading.local.__name__ == '_local' — C extension class named '_local' in _threadmodule.c; wave 257; new to extra101"
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra101.local_module:
  description: "threading.local.__module__ == '_thread' — _local is defined in the _thread C extension module; wave 257; new to extra101"
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra101.local_mro_len:
  description: "len(threading.local.__mro__) == 2 — MRO is [_local, object]; inherits directly from object; wave 257; new to extra101"
  kind: python_call_eq
  function: local.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra101.rlock_module:
  description: "threading._RLock.__module__ == 'threading' — _RLock is the Python class in Lib/threading.py; wave 257; new to extra101"
  kind: python_call_eq
  function: _RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra101.rlock_mro_len:
  description: "len(threading._RLock.__mro__) == 2 — MRO is [_RLock, object]; inherits directly from object; wave 257; new to extra101"
  kind: python_call_eq
  function: _RLock.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra101.bounded_semaphore_bases:
  description: "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore extends Semaphore; wave 257; new to extra101"
  kind: python_call_eq
  function: BoundedSemaphore.__bases__[0].__name__.__eq__
  args: ["Semaphore"]
  expected: true

