spec: inspect_extra2221
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2221: identity/display protocol dict-presence — __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__."
    - "inspect.Parameter defines __hash__, __repr__, __str__, __doc__, and __module__ in its own __dict__. It does NOT define __qualname__ or __name__."
    - "inspect.Signature defines __hash__, __repr__, __str__, __doc__, and __module__ in its own __dict__. It does NOT define __qualname__ or __name__."
    - "inspect.BoundArguments defines __hash__, __repr__, __doc__, and __module__ in its own __dict__. It does NOT define __str__, __qualname__, or __name__."
    - "inspect.FullArgSpec is a namedtuple subclass; it defines __repr__, __doc__, and __module__ but NOT __hash__, __str__, __qualname__, or __name__ in its own __dict__."
    - "inspect.BufferFlags (enum) defines __doc__ and __module__ but NOT __hash__, __repr__, __str__, __qualname__, or __name__ in its own __dict__."
    - "inspect.Format (enum) defines __doc__ and __module__ but NOT __hash__, __repr__, __str__, __qualname__, or __name__ in its own __dict__."
    - "inspect._ParameterKind (enum) defines __str__ and __doc__ and __module__ but NOT __hash__, __repr__, __qualname__, or __name__ in its own __dict__."
    - "__qualname__ and __name__ are never in a class __dict__ — they are metaclass-level attributes not stored as per-class dict entries."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra2221.parameter_identity_display:
  description: "inspect.Parameter dict-presence for identity/display protocol — defines __hash__, __repr__, __str__; not __qualname__ or __name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2221

  columns: [id, function, args, expected]
  rows:
    - ["in2221001", "inspect.Parameter.__dict__.__contains__", ["__hash__"], true]
    - ["in2221002", "inspect.Parameter.__dict__.__contains__", ["__repr__"], true]
    - ["in2221003", "inspect.Parameter.__dict__.__contains__", ["__str__"], true]
    - ["in2221004", "inspect.Parameter.__dict__.__contains__", ["__doc__"], true]
    - ["in2221005", "inspect.Parameter.__dict__.__contains__", ["__module__"], true]
    - ["in2221006", "inspect.Parameter.__dict__.__contains__", ["__qualname__"], false]
    - ["in2221007", "inspect.Parameter.__dict__.__contains__", ["__name__"], false]

