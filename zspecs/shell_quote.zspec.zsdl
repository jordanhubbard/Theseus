spec: shell_quote
version: ">=1.0.0"
backend: node(shell-quote)

docs: https://github.com/ljharb/shell-quote#readme

provenance:
  derived_from:
    - "shell-quote README — https://github.com/ljharb/shell-quote#readme"
    - "Test vectors verified with shell-quote via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "shell-quote source"
  notes:
    - "Quote and parse shell command strings — used by execa, npm-run-all, etc."
    - "Install: npm install shell-quote"
    - "v1 CJS; named exports quote / parse."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on string/array input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# quote: array → safe shell string
invariant shell_quote.quote_simple_no_special_chars:
  description: "['ls', '-la'] quoted unchanged (no special chars)"
  category: quote
  kind: node_chain_eq
  entry: named
  function: quote
  entry_args: [["ls", "-la"]]
  chain: []
  expected: "ls -la"

invariant shell_quote.quote_arg_with_space:
  description: "Argument with space gets single-quoted"
  category: quote
  kind: node_chain_eq
  entry: named
  function: quote
  entry_args: [["echo", "hello world"]]
  chain: []
  expected: "echo 'hello world'"

invariant shell_quote.quote_dollar_escaped:
  description: "$VAR escaped with backslash"
  category: quote
  kind: node_chain_eq
  entry: named
  function: quote
  entry_args: [["cmd", "$VAR"]]
  chain: []
  expected: "cmd \\$VAR"

# parse: string → tokens
invariant shell_quote.parse_simple:
  description: "parse('ls -la') yields ['ls','-la']"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["ls -la"]
  chain: []
  expected: ["ls", "-la"]

invariant shell_quote.parse_quoted_string:
  description: "parse('echo \"hello world\"') unwraps the quoted string"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["echo \"hello world\""]
  chain: []
  expected: ["echo", "hello world"]

invariant shell_quote.parse_pipe_operator:
  description: "parse('a | b') yields ['a',{op:'|'},'b']"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["a | b"]
  chain: []
  expected: ["a", {op: "|"}, "b"]

invariant shell_quote.parse_logical_operators:
  description: "parse('a && b || c') yields tokens with op markers"
  category: parse
  kind: node_chain_eq
  entry: named
  function: parse
  entry_args: ["a && b || c"]
  chain: []
  expected: ["a", {op: "&&"}, "b", {op: "||"}, "c"]
