spec: theseus_weakref_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_weakref_cr2)
blocks: weakref

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html"
  notes:
    - "Clean-room extended weakref utilities. Do NOT import weakref."
    - "WeakValueDictionary(): mapping where values are weak references."
    - "proxy(object): create a proxy that transparently wraps the object."
    - "ref(object): create a weak reference; call it to get the object or None."
    - "weakref2_weakvalue_dict(): WeakValueDictionary stores and retrieves — returns True."
    - "weakref2_proxy(): proxy to an object has same str() as the object — returns True."
    - "weakref2_ref_alive(): ref to object returns object while object is alive — returns True."
    - "Zero-arg invariant signatures — def weakref2_weakvalue_dict(): return bool"
    - "WeakValueDictionary: store value by key; retrieve by key as long as value is alive."
    - "proxy: calls to proxy attributes are forwarded to the underlying object."
    - "ref: callable that returns the referent or None if dead."
    - "Export: ref(obj), proxy(obj), WeakValueDictionary, WeakKeyDictionary, WeakSet."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_weakref_cr2.weakvalue_dict:
  description: "WeakValueDictionary stores and retrieves objects"
  category: WeakValueDictionary
  kind: python_call_eq
  function: weakref2_weakvalue_dict
  args: []
  expected: true

invariant theseus_weakref_cr2.proxy:
  description: "proxy to object forwards attribute access"
  category: proxy
  kind: python_call_eq
  function: weakref2_proxy
  args: []
  expected: true

invariant theseus_weakref_cr2.ref_alive:
  description: "ref to live object returns the object"
  category: ref
  kind: python_call_eq
  function: weakref2_ref_alive
  args: []
  expected: true
