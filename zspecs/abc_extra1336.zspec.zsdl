spec: abc_extra1336
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 536 (_extra1336): focuses on __hash__ and __eq__ method checks for abc module objects."
    - "abc.ABCMeta.__hash__.__qualname__ == 'object.__hash__' — ABCMeta inherits __hash__ from object (not from type)."
    - "abc.ABCMeta.__hash__.__class__.__name__ == 'wrapper_descriptor' — C-level slot descriptor."
    - "abc.ABC.__hash__.__class__.__name__ == 'wrapper_descriptor' — ABC is an instance of ABCMeta, inherits from object."
    - "abc.ABC.__hash__ is object.__hash__ — verified same identity, no override anywhere in the chain."
    - "abc.abstractmethod.__hash__.__class__.__name__ == 'method-wrapper' — abstractmethod is a class (function type), so __hash__ is a bound method-wrapper."
    - "abc.abstractmethod.__hash__.__qualname__ == 'object.__hash__' — inherits from object."
    - "abc.ABCMeta.__eq__.__qualname__ == 'object.__eq__' — ABCMeta inherits __eq__ from object, same as type.__eq__."
    - "abc.ABCMeta.__eq__ is type.__eq__ — both resolve to object.__eq__ wrapper_descriptor."
    - "abc.ABC.__eq__.__qualname__ == 'object.__eq__' — no custom equality in ABC."
    - "abc.abstractmethod.__eq__.__qualname__ == 'object.__eq__' — abstractmethod class has no custom equality."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table abc_extra1336.hash_class_names:
  description: "abc module objects: __hash__ method class checks — ABCMeta and ABC have wrapper_descriptor, abstractmethod has method-wrapper"
  kind: python_call_eq
  category: identity
  id_prefix: ab1336hc
  columns: [id, function, args, expected]
  rows:
    - [ab1336hc001, abc.ABCMeta.__hash__.__class__.__name__.__eq__,       ["wrapper_descriptor"], true]
    - [ab1336hc002, abc.ABC.__hash__.__class__.__name__.__eq__,           ["wrapper_descriptor"], true]
    - [ab1336hc003, abc.abstractmethod.__hash__.__class__.__name__.__eq__,["method-wrapper"],     true]
    - [ab1336hc004, abc.ABCMeta.__hash__.__class__.__name__.__eq__,       ["NoneType"],           false]
    - [ab1336hc005, abc.ABC.__hash__.__class__.__name__.__eq__,           ["NoneType"],           false]
    - [ab1336hc006, abc.abstractmethod.__hash__.__class__.__name__.__eq__,["NoneType"],           false]

