  rows:
    - [ab1336hq001, abc.ABCMeta.__hash__.__qualname__.__eq__,       ["object.__hash__"], true]
    - [ab1336hq002, abc.ABC.__hash__.__qualname__.__eq__,           ["object.__hash__"], true]
    - [ab1336hq003, abc.abstractmethod.__hash__.__qualname__.__eq__,["object.__hash__"], true]
    - [ab1336hq004, abc.ABCMeta.__hash__.__qualname__.__class__.__name__.__eq__,       ["str"], true]
    - [ab1336hq005, abc.ABC.__hash__.__qualname__.__class__.__name__.__eq__,           ["str"], true]
    - [ab1336hq006, abc.abstractmethod.__hash__.__qualname__.__class__.__name__.__eq__,["str"], true]

