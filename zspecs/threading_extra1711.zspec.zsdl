spec: threading_extra1711
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 561 (_extra1711): __init__ protocol dict-presence checks."
    - "threading.Thread is a pure Python class that defines __init__(self, group=None, target=None, name=None, args=(), kwargs=None, *, daemon=None) → True."
    - "threading.Event is a pure Python class that defines __init__(self) → True."
    - "threading.Condition is a pure Python class that defines __init__(self, lock=None) → True."
    - "threading.Semaphore is a pure Python class that defines __init__(self, value=1) → True."
    - "threading.Timer is a pure Python subclass of Thread that defines its own __init__(self, interval, function, args=None, kwargs=None) → True."
    - "threading.local is a C type (from _thread extension) — does NOT define __init__ in its own __dict__ → False."
    - "threading.Lock is a factory function returning a _thread.lock C object; the resulting type's __init__ is not accessible via threading.Lock.__dict__ as Lock itself is not a class with a __dict__ in the normal sense — the factory callable is checked."
    - "Cross-checks between __init__ and __new__ presence, and __init_subclass__ / __class_getitem__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __init__ dict-presence checks
#
# Wave 561 theme: which threading types define __init__ in their own __dict__.
#
# threading.Thread: pure Python; defines __init__ with name/target/args/kwargs
# parameters → True.
#
# threading.Event: pure Python; defines __init__(self) which initializes the
# internal Condition and flag → True.
#
# threading.Condition: pure Python; defines __init__(self, lock=None) → True.
#
# threading.Semaphore: pure Python; defines __init__(self, value=1) → True.
#
# threading.Timer: pure Python subclass of Thread; defines its own __init__
# to accept interval and function → True.
#
# threading.local: C type from _thread; no Python __init__ in its own __dict__
# → False.
# ---------------------------------------------------------------------------

table threading_extra1711.init_protocol:
  description: "threading types: __init__ dict-presence via __dict__.__contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1711

  columns: [id, function, args, expected]
  rows:
    - ["th1711001", "threading.Thread.__dict__.__contains__", ["__init__"], true]
    - ["th1711002", "threading.Event.__dict__.__contains__", ["__init__"], true]
    - ["th1711003", "threading.Condition.__dict__.__contains__", ["__init__"], true]
    - ["th1711004", "threading.Semaphore.__dict__.__contains__", ["__init__"], true]
    - ["th1711005", "threading.Timer.__dict__.__contains__", ["__init__"], true]
    - ["th1711006", "threading.local.__dict__.__contains__", ["__init__"], false]

# ---------------------------------------------------------------------------
# Table 2: __new__ dict-presence cross-checks
#
# Wave 561 cross-check: pure Python classes that define __init__ in their own
# __dict__ do NOT typically also define __new__ (they inherit it from object).
#
# threading.Thread: inherits __new__ from object → False.
# threading.Event: inherits __new__ from object → False.
# threading.Condition: inherits __new__ from object → False.
# threading.Semaphore: inherits __new__ from object → False.
# threading.Timer: inherits __new__ from Thread (which inherits from object) → False.
# threading.local: C type; __new__ IS defined in its own __dict__ (C types
# expose __new__ for construction) → True.
# ---------------------------------------------------------------------------

table threading_extra1711.new_protocol:
  description: "threading types: __new__ dict-presence cross-check (pure Python inherit; C type defines __new__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1711

  columns: [id, function, args, expected]
  rows:
    - ["th1711007", "threading.Thread.__dict__.__contains__", ["__new__"], false]
    - ["th1711008", "threading.Event.__dict__.__contains__", ["__new__"], false]
    - ["th1711009", "threading.Condition.__dict__.__contains__", ["__new__"], false]
    - ["th1711010", "threading.Semaphore.__dict__.__contains__", ["__new__"], false]
    - ["th1711011", "threading.Timer.__dict__.__contains__", ["__new__"], false]
    - ["th1711012", "threading.local.__dict__.__contains__", ["__new__"], true]

# ---------------------------------------------------------------------------
# Table 3: related dunder protocol cross-checks
#
# Wave 561 extension: __init_subclass__ is inherited from object and is not
# overridden by any of the threading classes above. __class_getitem__ is also
# not expected in their own __dict__ (they do not support generic syntax via
# PEP 560 class_getitem).
# ---------------------------------------------------------------------------

table threading_extra1711.related_dunder_protocol:
  description: "threading types: __init_subclass__ and __class_getitem__ dict-presence cross-checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1711

  columns: [id, function, args, expected]
  rows:
    - ["th1711013", "threading.Thread.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th1711014", "threading.Event.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th1711015", "threading.Condition.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th1711016", "threading.Semaphore.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th1711017", "threading.local.__dict__.__contains__", ["__init_subclass__"], false]
    - ["th1711018", "threading.Thread.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th1711019", "threading.Event.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th1711020", "threading.Condition.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th1711021", "threading.Semaphore.__dict__.__contains__", ["__class_getitem__"], false]
    - ["th1711022", "threading.local.__dict__.__contains__", ["__class_getitem__"], false]
