spec: pick_deep
version: ">=1.0.0"
backend: node(pick-deep)

docs: https://www.npmjs.com/package/pick-deep

provenance:
  derived_from:
    - "pick-deep README — https://www.npmjs.com/package/pick-deep"
    - "Test vectors verified with pick-deep via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "pick-deep source"
  notes:
    - "pick-deep is an npm package. Install: npm install pick-deep"
    - "Returns a new object with only the specified keys."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table pick_deep.pick:
  kind: node_module_call_eq
  function: ~
  category: objects
  id_prefix: pickd

  columns: [id, args, expected]
  rows:
    - [two_keys, [{"a": 1, "b": 2, "c": 3}, ["a", "c"]], {"a": 1, "c": 3}]
    - [nested,   [{"a": {"x": 1}, "b": {"y": 2}, "c": 3}, ["a", "c"]], {"a": {"x": 1}, "c": 3}]
    - [one_key,  [{"a": 1, "b": 2}, ["b"]], {"b": 2}]
