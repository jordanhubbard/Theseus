spec: pickle_extra19
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl through pickle_extra18.zspec.zsdl."
    - "pickle_extra18 covers: Pickler.__init__/__qualname__; Unpickler.__init__/__qualname__; PickleBuffer/__qualname__.__class__.__name__."
    - "pickle_extra17 covers: Pickler.clear_memo/__qualname__; Pickler.dispatch_table/__qualname__; Unpickler.persistent_load/__qualname__."
    - "pickle_extra16 covers: Pickler.dump/__qualname__; Pickler.persistent_id/__qualname__; Unpickler.load/__qualname__; Unpickler.find_class/__qualname__."
    - "pickle_extra14 covers: Pickler/__qualname__; Unpickler/__qualname__; PickleBuffer/__qualname__; loads/__qualname__; load/__qualname__; dump/__qualname__."
    - "pickle_extra13 covers: HIGHEST_PROTOCOL/__class__.__name__ standalone; DEFAULT_PROTOCOL/__class__.__name__ standalone; HIGHEST_PROTOCOL.__ge__(5); PickleError/PicklingError/UnpicklingError __name__ standalone; dumps/__qualname__."
    - "pickle_extra12 covers: PickleError/PicklingError/UnpicklingError __module__; dumps/__module__; loads/__module__; Pickler/__module__; Unpickler/__module__."
    - "pickle_extra11 covers: PickleError/__bases__[0].__name__; PicklingError/__bases__[0].__name__; UnpicklingError/__bases__[0].__name__."
    - "pickle_extra10 covers: HIGHEST_PROTOCOL/__class__.__name__; DEFAULT_PROTOCOL/__class__.__name__; PickleError/PicklingError/UnpicklingError __qualname__."
    - "Focus: singular dump and load __module__; type-axis (__qualname__.__class__.__name__) for PickleError/PicklingError/UnpicklingError exception classes."
    - "No prior pickle spec checks dump.__module__ (singular, not dumps)."
    - "No prior pickle spec checks load.__module__ (singular, not loads)."
    - "No prior pickle spec checks PickleError.__qualname__.__class__.__name__."
    - "No prior pickle spec checks PicklingError.__qualname__.__class__.__name__."
    - "No prior pickle spec checks UnpicklingError.__qualname__.__class__.__name__."
    - "pickle.dump.__module__ == '_pickle' — singular dump is a C builtin from _pickle extension."
    - "pickle.load.__module__ == '_pickle' — singular load is a C builtin from _pickle extension."
    - "pickle.PickleError.__qualname__.__class__.__name__ == 'str' — qualname is always a string."
    - "pickle.PicklingError.__qualname__.__class__.__name__ == 'str' — qualname is always a string."
    - "pickle.UnpicklingError.__qualname__.__class__.__name__ == 'str' — qualname is always a string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dump and load (singular) __module__
#
# pickle_extra12 checks dumps.__module__ and loads.__module__ (plural forms).
# pickle_extra14 checks dump.__qualname__ and load.__qualname__ (singular).
# No prior pickle spec checks dump.__module__ or load.__module__ (singular).
# Both are C builtins from the _pickle extension, so __module__ == '_pickle'.
# ---------------------------------------------------------------------------

invariant pickle_extra19.dump.module:
  description: "pickle.dump.__module__ == '_pickle' — singular dump is a C builtin from the _pickle extension"
  category: function_attrs
  kind: python_call_eq
  function: dump.__module__.__eq__
  args: ["_pickle"]
  expected: true

invariant pickle_extra19.load.module:
  description: "pickle.load.__module__ == '_pickle' — singular load is a C builtin from the _pickle extension"
  category: function_attrs
  kind: python_call_eq
  function: load.__module__.__eq__
  args: ["_pickle"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class __qualname__ type axis
#
# pickle_extra10 checks PickleError/PicklingError/UnpicklingError __qualname__
# values.  pickle_extra15 checks Pickler/__qualname__.__class__.__name__ and
# Unpickler/__qualname__.__class__.__name__.  No prior pickle spec checks the
# __class__.__name__ of the __qualname__ attribute for the exception classes.
# For any class, __qualname__ is a plain str.
# ---------------------------------------------------------------------------

invariant pickle_extra19.PickleError.qualname.class_name:
  description: "pickle.PickleError.__qualname__.__class__.__name__ == 'str' — qualname is a string"
  category: type_attrs
  kind: python_call_eq
  function: PickleError.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pickle_extra19.PicklingError.qualname.class_name:
  description: "pickle.PicklingError.__qualname__.__class__.__name__ == 'str' — qualname is a string"
  category: type_attrs
  kind: python_call_eq
  function: PicklingError.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pickle_extra19.UnpicklingError.qualname.class_name:
  description: "pickle.UnpicklingError.__qualname__.__class__.__name__ == 'str' — qualname is a string"
  category: type_attrs
  kind: python_call_eq
  function: UnpicklingError.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all five new invariants
#
# All five are first covered in this spec (pickle_extra19).
# ---------------------------------------------------------------------------

table pickle_extra19.dump_load_module_and_exc_qualname_types:
  description: "pickle dump/load singular __module__ and exception __qualname__ type axis"
  kind: python_call_eq
  category: function_attrs
  id_prefix: ppm19

  columns: [id, function, args, expected]
  rows:
    - [dump_module,                dump.__module__.__eq__,                               ["_pickle"], true]
    - [load_module,                load.__module__.__eq__,                               ["_pickle"], true]
    - [PickleError_qn_type,        PickleError.__qualname__.__class__.__name__.__eq__,   ["str"],     true]
    - [PicklingError_qn_type,      PicklingError.__qualname__.__class__.__name__.__eq__,  ["str"],     true]
    - [UnpicklingError_qn_type,    UnpicklingError.__qualname__.__class__.__name__.__eq__, ["str"],    true]
