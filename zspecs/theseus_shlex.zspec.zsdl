spec: theseus_shlex
version: ">=3.9"
backend: python_cleanroom(theseus_shlex)
blocks: shlex

docs: https://docs.python.org/3/library/shlex.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/shlex.html"
  notes:
    - "Clean-room shell lexer/splitter. Do NOT import shlex."
    - "split(s) tokenizes a shell-style string respecting quotes and escapes."
    - "split('ls -la /tmp') == ['ls', '-la', '/tmp']."
    - "split('echo \"hello world\"') == ['echo', 'hello world']."
    - "quote(s) wraps a string safely for shell use: quote('hello world') == \"'hello world'\"."
    - "Export: split(s: str) -> list[str], quote(s: str) -> str."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_shlex.split_simple:
  description: "split('ls -la /tmp') == ['ls', '-la', '/tmp']"
  category: split
  kind: python_call_eq
  function: shlex_split_simple
  args: []
  expected: ["ls", "-la", "/tmp"]

invariant theseus_shlex.split_quoted:
  description: "split('echo \"hello world\"') == ['echo', 'hello world']"
  category: split
  kind: python_call_eq
  function: shlex_split_quoted
  args: []
  expected: ["echo", "hello world"]

invariant theseus_shlex.quote_with_space:
  description: "quote('hello world') == \"'hello world'\""
  category: quote
  kind: python_call_eq
  function: shlex_quote_space
  args: []
  expected: "'hello world'"
