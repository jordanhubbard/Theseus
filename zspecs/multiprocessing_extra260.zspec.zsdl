spec: multiprocessing_extra260
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#connection-objects

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#connection-objects — multiprocessing connection documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/connection.py"
  notes:
    - "multiprocessing.connection.Connection inherits from _ConnectionBase; __bases__[0].__name__ == '_ConnectionBase'."
    - "multiprocessing.connection.Client is a plain function; __class__.__name__ == 'function'."
    - "multiprocessing.connection.Listener is a class that inherits from object; __bases__[0].__name__ == 'object'."
    - "Connection.send, recv, close, fileno are instance methods defined on _ConnectionBase or Connection."
    - "All __module__ values for class attributes == 'multiprocessing.connection'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Connection and Listener class identity — table
#
# connection.Connection: class name, module, base class.
# connection.Listener: class name, module, base class.
# connection.Client: function identity.
# ---------------------------------------------------------------------------

table multiprocessing_extra260.connection_identity:
  description: "multiprocessing.connection Connection, Listener, and Client identity"
  kind: python_call_eq
  category: identity
  id_prefix: connid

  columns: [id, function, args, expected, description]
  rows:
    - [conn_name,     connection.Connection.__name__.__eq__,              ["Connection"],                true, "multiprocessing.connection.Connection.__name__ == 'Connection'"]
    - [conn_module,   connection.Connection.__module__.__eq__,            ["multiprocessing.connection"], true, "multiprocessing.connection.Connection.__module__ == 'multiprocessing.connection'"]
    - [lsn_name,      connection.Listener.__name__.__eq__,                ["Listener"],                  true, "multiprocessing.connection.Listener.__name__ == 'Listener'"]
    - [lsn_module,    connection.Listener.__module__.__eq__,              ["multiprocessing.connection"], true, "multiprocessing.connection.Listener.__module__ == 'multiprocessing.connection'"]
    - [client_cls,    connection.Client.__class__.__name__.__eq__,        ["function"],                  true, "type(multiprocessing.connection.Client).__name__ == 'function'"]

# ---------------------------------------------------------------------------
# Connection method __name__ — table
#
# Connection.send, recv, close, fileno __name__ values.
# ---------------------------------------------------------------------------

table multiprocessing_extra260.connection_methods:
  description: "multiprocessing.connection.Connection method __name__ values"
  kind: python_call_eq
  category: identity
  id_prefix: connmeth

  columns: [id, function, args, expected, description]
  rows:
    - [send_name,     connection.Connection.send.__name__.__eq__,         ["send"],    true, "multiprocessing.connection.Connection.send.__name__ == 'send'"]
    - [recv_name,     connection.Connection.recv.__name__.__eq__,         ["recv"],    true, "multiprocessing.connection.Connection.recv.__name__ == 'recv'"]
    - [close_name,    connection.Connection.close.__name__.__eq__,        ["close"],   true, "multiprocessing.connection.Connection.close.__name__ == 'close'"]
    - [fileno_name,   connection.Connection.fileno.__name__.__eq__,       ["fileno"],  true, "multiprocessing.connection.Connection.fileno.__name__ == 'fileno'"]
    - [client_name,   connection.Client.__name__.__eq__,                  ["Client"],  true, "multiprocessing.connection.Client.__name__ == 'Client'"]

# ---------------------------------------------------------------------------
# Connection.__bases__[0] is _ConnectionBase — standalone invariant
# ---------------------------------------------------------------------------

invariant multiprocessing_extra260.Connection.bases0_name:
  description: "multiprocessing.connection.Connection.__bases__[0].__name__ == '_ConnectionBase'"
  category: identity
  kind: python_call_eq
  function: "connection.Connection.__bases__[0].__name__.__eq__"
  args: ["_ConnectionBase"]
  expected: true

# ---------------------------------------------------------------------------
# Listener.__bases__[0] is object — standalone invariant
# ---------------------------------------------------------------------------

invariant multiprocessing_extra260.Listener.bases0_name:
  description: "multiprocessing.connection.Listener.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "connection.Listener.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Listener method __name__ — standalone invariants
# ---------------------------------------------------------------------------

invariant multiprocessing_extra260.Listener.accept_name:
  description: "multiprocessing.connection.Listener.accept.__name__ == 'accept'"
  category: identity
  kind: python_call_eq
  function: connection.Listener.accept.__name__.__eq__
  args: ["accept"]
  expected: true

invariant multiprocessing_extra260.Listener.close_name:
  description: "multiprocessing.connection.Listener.close.__name__ == 'close'"
  category: identity
  kind: python_call_eq
  function: connection.Listener.close.__name__.__eq__
  args: ["close"]
  expected: true

invariant multiprocessing_extra260.Client.module:
  description: "multiprocessing.connection.Client.__module__ == 'multiprocessing.connection'"
  category: identity
  kind: python_call_eq
  function: connection.Client.__module__.__eq__
  args: ["multiprocessing.connection"]
  expected: true
