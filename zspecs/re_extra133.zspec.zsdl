spec: re_extra133
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.RegexFlag enum class identity (__name__, __module__, __bases__[0].__name__, __mro__.__len__()) and member __class__.__name__ values."
    - "re.RegexFlag.__name__ = 'RegexFlag'."
    - "re.RegexFlag.__module__ = 're'."
    - "re.RegexFlag.__bases__[0].__name__ = 'IntFlag' (RegexFlag directly extends IntFlag)."
    - "re.RegexFlag.__mro__.__len__() = 7 (MRO: [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object])."
    - "re.RegexFlag.__qualname__ = 'RegexFlag' (length 9)."
    - "All re flag members (MULTILINE, DOTALL, IGNORECASE, VERBOSE, ASCII, UNICODE, LOCALE, NOFLAG) have __class__.__name__ == 'RegexFlag'."
    - "re.MULTILINE.value = 8, re.DOTALL.value = 16, re.IGNORECASE.value = 2, re.VERBOSE.value = 64."
    - "re.ASCII.value = 256, re.UNICODE.value = 32, re.LOCALE.value = 4, re.NOFLAG.value = 0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.RegexFlag enum class identity
# RegexFlag.__name__ = 'RegexFlag'.
# RegexFlag.__module__ = 're'.
# RegexFlag.__bases__[0].__name__ = 'IntFlag'.
# RegexFlag.__mro__.__len__() = 7 (RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object).
# RegexFlag.__qualname__ = 'RegexFlag' (length 9).
# ---------------------------------------------------------------------------

table re_extra133.RegexFlag_class_identity:
  description: "re.RegexFlag class identity: __name__='RegexFlag', __module__='re', __bases__[0].__name__='IntFlag', __mro__.__len__()=7, __qualname__='RegexFlag'(9)"
  kind: python_call_eq
  category: class_identity
  id_prefix: reregexflag133

  columns: [id, function, args, expected]
  rows:
    - [rf_name_eq,        RegexFlag.__name__.__eq__,                    ["RegexFlag"], true]
    - [rf_module_eq,      RegexFlag.__module__.__eq__,                  ["re"],        true]
    - [rf_module_not_sre, RegexFlag.__module__.__eq__,                  ["sre"],       false]
    - [rf_base_eq,        "RegexFlag.__bases__[0].__name__.__eq__",       ["IntFlag"],   true]
    - [rf_base_not_int,   "RegexFlag.__bases__[0].__name__.__eq__",       ["int"],       false]
    - [rf_mro_len,        RegexFlag.__mro__.__len__,                    [],            7]
    - [rf_qname_eq,       RegexFlag.__qualname__.__eq__,                ["RegexFlag"], true]
    - [rf_qname_len,      RegexFlag.__qualname__.__len__,               [],            9]

# ---------------------------------------------------------------------------
# re flag member __class__.__name__ values
# All flags (MULTILINE, DOTALL, IGNORECASE, VERBOSE) have __class__.__name__ == 'RegexFlag'.
# This confirms they are proper enum members, not raw integers.
# ---------------------------------------------------------------------------

table re_extra133.flag_member_class_names:
  description: "re flag members MULTILINE, DOTALL, IGNORECASE, VERBOSE all have __class__.__name__ == 'RegexFlag'"
  kind: python_call_eq
  category: enum_members
  id_prefix: reregexflag133

  columns: [id, function, args, expected]
  rows:
    - [ml_cls_eq,   MULTILINE.__class__.__name__.__eq__,  ["RegexFlag"], true]
    - [da_cls_eq,   DOTALL.__class__.__name__.__eq__,     ["RegexFlag"], true]
    - [ic_cls_eq,   IGNORECASE.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [vb_cls_eq,   VERBOSE.__class__.__name__.__eq__,    ["RegexFlag"], true]
    - [ml_cls_not,  MULTILINE.__class__.__name__.__eq__,  ["IntFlag"],   false]
    - [da_val_eq,   DOTALL.__class__.__name__.__eq__,     ["RegexFlag"], true]

# ---------------------------------------------------------------------------
# re flag member __class__.__name__ values: ASCII, UNICODE, LOCALE, NOFLAG
# All are RegexFlag members with their canonical integer values.
# ASCII=256, UNICODE=32, LOCALE=4, NOFLAG=0.
# ---------------------------------------------------------------------------

table re_extra133.flag_member_class_names_ext:
  description: "re flag members ASCII, UNICODE, LOCALE, NOFLAG all have __class__.__name__ == 'RegexFlag'"
  kind: python_call_eq
  category: enum_members
  id_prefix: reregexflag133

  columns: [id, function, args, expected]
  rows:
    - [asc_cls_eq,    ASCII.__class__.__name__.__eq__,   ["RegexFlag"], true]
    - [uni_cls_eq,    UNICODE.__class__.__name__.__eq__,  ["RegexFlag"], true]
    - [loc_cls_eq,    LOCALE.__class__.__name__.__eq__,   ["RegexFlag"], true]
    - [nof_cls_eq,    NOFLAG.__class__.__name__.__eq__,   ["RegexFlag"], true]
    - [asc_cls_not,   ASCII.__class__.__name__.__eq__,    ["int"],       false]
    - [uni_cls_not,   UNICODE.__class__.__name__.__eq__,  ["Flag"],      false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra133.RegexFlag.name_is_RegexFlag:
  description: "re.RegexFlag.__name__ == 'RegexFlag' (the enum class name is the bare class name without module prefix)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

invariant re_extra133.RegexFlag.module_is_re:
  description: "re.RegexFlag.__module__ == 're' (RegexFlag is defined in the re package, not in _sre or sre_compile)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra133.RegexFlag.base_is_IntFlag:
  description: "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag directly extends IntFlag from the enum module, so flags can be combined with bitwise operations)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__bases__[0].__name__.__eq__
  args: ["IntFlag"]
  expected: true

invariant re_extra133.RegexFlag.mro_len_7:
  description: "re.RegexFlag.__mro__.__len__() == 7 (MRO is [RegexFlag, IntFlag, int, ReprEnum, Flag, Enum, object]; 7 entries due to the IntFlag/int/Enum inheritance chain)"
  category: class_identity
  kind: python_call_eq
  function: RegexFlag.__mro__.__len__
  args: []
  expected: 7

invariant re_extra133.MULTILINE.class_name_is_RegexFlag:
  description: "re.MULTILINE.__class__.__name__ == 'RegexFlag' (MULTILINE is an instance of RegexFlag, not a plain int; its integer value is 8)"
  category: enum_members
  kind: python_call_eq
  function: MULTILINE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true
