spec: multiprocessing_extra2
version: ">=3.4"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/ (CPython internals)"
    - "multiprocessing.zspec.zsdl — covers class/factory names, exceptions, cpu_count, current_process, active_children, get_start_method"
    - "multiprocessing_extra.zspec.zsdl — covers Process.__module__, Process base class, Queue/Pipe/Pool/Lock/Event/Semaphore/Value/Array/Manager __name__, AuthenticationError, Process metaclass"
  notes:
    - "This spec adds __module__ invariants for the top-level multiprocessing factory functions/methods."
    - "Pool, Lock, Event, Semaphore, Value, Array, Manager, Pipe, Queue are bound methods of DefaultContext; their __module__ is 'multiprocessing.context'."
    - "Process is a real class; its __module__ is also 'multiprocessing.context' (where it is re-exported from)."
    - "BoundedSemaphore, Barrier, and Condition are additional synchronization primitives; their __name__ values are verified here."
    - "RLock is also a bound method factory with __name__ == 'RLock'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ for factory functions — all are bound methods of DefaultContext
# Their __module__ is 'multiprocessing.context'
# ---------------------------------------------------------------------------

table multiprocessing_extra2.factory_modules:
  kind: python_call_eq
  category: factory_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [Pool,      Pool.__module__.__eq__,      ["multiprocessing.context"], true]
    - [Lock,      Lock.__module__.__eq__,      ["multiprocessing.context"], true]
    - [Event,     Event.__module__.__eq__,     ["multiprocessing.context"], true]
    - [Semaphore, Semaphore.__module__.__eq__, ["multiprocessing.context"], true]
    - [Value,     Value.__module__.__eq__,     ["multiprocessing.context"], true]
    - [Array,     Array.__module__.__eq__,     ["multiprocessing.context"], true]
    - [Manager,   Manager.__module__.__eq__,   ["multiprocessing.context"], true]
    - [Pipe,      Pipe.__module__.__eq__,      ["multiprocessing.context"], true]
    - [Queue,     Queue.__module__.__eq__,     ["multiprocessing.context"], true]

# ---------------------------------------------------------------------------
# Process.__module__ — Process is defined in multiprocessing.context
# (multiprocessing_extra covers 'multiprocessing.process'; here we confirm
# the module attribute resolves to 'multiprocessing.context' in Python 3.12)
# ---------------------------------------------------------------------------

invariant multiprocessing_extra2.Process.module_context:
  description: "multiprocessing.Process.__module__ == 'multiprocessing.context'"
  category: factory_modules
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

# ---------------------------------------------------------------------------
# Additional synchronisation primitive names — BoundedSemaphore, Barrier, Condition, RLock
#
# These are top-level bound method factories in the multiprocessing namespace
# not covered by multiprocessing.zspec.zsdl or multiprocessing_extra.zspec.zsdl.
# ---------------------------------------------------------------------------

table multiprocessing_extra2.extra_primitive_names:
  kind: python_call_eq
  category: primitives
  id_prefix: pname

  columns: [id, function, args, expected]
  rows:
    - [BoundedSemaphore, BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true]
    - [Barrier,          Barrier.__name__.__eq__,          ["Barrier"],          true]
    - [Condition,        Condition.__name__.__eq__,        ["Condition"],        true]
    - [RLock,            RLock.__name__.__eq__,            ["RLock"],            true]

# ---------------------------------------------------------------------------
# Additional synchronisation primitive __module__ checks
# ---------------------------------------------------------------------------

table multiprocessing_extra2.extra_primitive_modules:
  kind: python_call_eq
  category: primitives
  id_prefix: pmod

  columns: [id, function, args, expected]
  rows:
    - [BoundedSemaphore, BoundedSemaphore.__module__.__eq__, ["multiprocessing.context"], true]
    - [Barrier,          Barrier.__module__.__eq__,          ["multiprocessing.context"], true]
    - [Condition,        Condition.__module__.__eq__,        ["multiprocessing.context"], true]
    - [RLock,            RLock.__module__.__eq__,            ["multiprocessing.context"], true]
