spec: pathlib_extra826
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/pathlib.py"
  not_derived_from:
    - "any third-party path library"
  notes:
    - "Covers __qualname__ values for pathlib.Path instance methods"
    - "All qualnames follow the 'Path.method_name' pattern"
  created_at: "2026-04-12"

table pathlib_extra826.path_qualnames:
  description: "Verify __qualname__ strings for pathlib.Path instance methods"
  kind: python_call_eq
  category: qualname
  id_prefix: pl826pt
  columns: [id, function, args, expected]
  rows:
    - [pl826pt001, "pathlib.Path.stat.__qualname__.__eq__", ["Path.stat"], true]
    - [pl826pt002, "pathlib.Path.exists.__qualname__.__eq__", ["Path.exists"], true]
    - [pl826pt003, "pathlib.Path.is_file.__qualname__.__eq__", ["Path.is_file"], true]
    - [pl826pt004, "pathlib.Path.is_dir.__qualname__.__eq__", ["Path.is_dir"], true]
    - [pl826pt005, "pathlib.Path.is_symlink.__qualname__.__eq__", ["Path.is_symlink"], true]
    - [pl826pt006, "pathlib.Path.mkdir.__qualname__.__eq__", ["Path.mkdir"], true]
    - [pl826pt007, "pathlib.Path.rename.__qualname__.__eq__", ["Path.rename"], true]
    - [pl826pt008, "pathlib.Path.unlink.__qualname__.__eq__", ["Path.unlink"], true]
    - [pl826pt009, "pathlib.Path.rmdir.__qualname__.__eq__", ["Path.rmdir"], true]
    - [pl826pt010, "pathlib.Path.open.__qualname__.__eq__", ["Path.open"], true]
    - [pl826pt011, "pathlib.Path.read_text.__qualname__.__eq__", ["Path.read_text"], true]
    - [pl826pt012, "pathlib.Path.write_text.__qualname__.__eq__", ["Path.write_text"], true]
