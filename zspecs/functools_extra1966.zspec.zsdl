spec: functools_extra1966
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 578 (_extra1966): __enter__/__exit__, __aenter__/__aexit__, __del__ dict-presence checks."
    - "functools.partial, functools.partialmethod, functools.cached_property do NOT define context manager protocol."
    - "None of the functools classes define __aenter__ or __aexit__ — functools has no async context manager types."
    - "None of the functools classes define __del__ — no finalizer protocol in functools."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table functools_extra1966.context_manager_enter:
  description: "functools types __enter__ dict-presence checks — none define context manager protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft1966
  columns: [id, function, args, expected]
  rows:
    - ["ft1966001", "functools.partial.__dict__.__contains__",         ["__enter__"], false]
    - ["ft1966002", "functools.partialmethod.__dict__.__contains__",   ["__enter__"], false]
    - ["ft1966003", "functools.cached_property.__dict__.__contains__", ["__enter__"], false]

