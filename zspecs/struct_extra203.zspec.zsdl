spec: struct_extra203
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec covers: wave 255 theme — struct.Struct.__dict__ membership checks for pack, unpack, pack_into, unpack_from, iter_unpack, size, format, and __doc__. NEW in extra203: struct.Struct.__dict__.__contains__('pack')==True; struct.Struct.__dict__.__contains__('unpack')==True; struct.Struct.__dict__.__contains__('pack_into')==True; struct.Struct.__dict__.__contains__('unpack_from')==True; struct.Struct.__dict__.__contains__('iter_unpack')==True; struct.Struct.__dict__.__contains__('size')==True; struct.Struct.__dict__.__contains__('format')==True; struct.Struct.__dict__.__contains__('__doc__')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__dict__.__class__.__name__=='mappingproxy' (all class __dict__ attributes are read-only mappingproxy wrappers in CPython). struct.Struct is a C extension type defined in Modules/_struct.c; its __dict__ is a mappingproxy over the C-level type's method table. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.Struct.__dict__ contains all the core methods: pack, unpack, pack_into, unpack_from, iter_unpack (all C-level method_descriptor objects); and the attributes: size (C-level getset_descriptor), format (C-level getset_descriptor), __doc__ (str). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ membership — pack, unpack, pack_into, unpack_from — extra203
#
# Wave 255 theme: struct.Struct.__dict__ key membership for pack/unpack methods.
#
# struct.Struct.__dict__.__contains__('pack')       == True
# struct.Struct.__dict__.__contains__('unpack')     == True
# struct.Struct.__dict__.__contains__('pack_into')  == True
# struct.Struct.__dict__.__contains__('unpack_from') == True
# ---------------------------------------------------------------------------

table struct_extra203.Struct_dict_pack_methods:
  description: "struct.Struct.__dict__ membership checks for pack/unpack methods in structdict203 namespace — wave 255 theme: struct.Struct.__dict__.__contains__('pack')==True ('pack' is a method_descriptor in Struct.__dict__; Struct.pack(v1, v2, ...) packs the values into a bytes object according to the format; it is a C-level method defined in Modules/_struct.c); struct.Struct.__dict__.__contains__('unpack')==True ('unpack' is a method_descriptor; Struct.unpack(buffer) returns a tuple of values); struct.Struct.__dict__.__contains__('pack_into')==True ('pack_into' is a method_descriptor; Struct.pack_into(buffer, offset, v1, v2, ...) writes packed bytes into a writable buffer at the given offset); struct.Struct.__dict__.__contains__('unpack_from')==True ('unpack_from' is a method_descriptor; Struct.unpack_from(buffer, offset=0) reads from a buffer at the given offset without requiring exact size); struct.Struct.__dict__.__class__.__name__=='mappingproxy' (C extension type __dict__ is a mappingproxy); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: structdict203

  columns: [id, function, args, expected, description]
  rows:
    - [has_pack,         struct.Struct.__dict__.__contains__,  ["pack"],         true, "struct.Struct.__dict__.__contains__('pack') == True (C-level method_descriptor); verified with Python 3.14.3"]
    - [has_unpack,       struct.Struct.__dict__.__contains__,  ["unpack"],       true, "struct.Struct.__dict__.__contains__('unpack') == True (C-level method_descriptor); verified with Python 3.14.3"]
    - [has_pack_into,    struct.Struct.__dict__.__contains__,  ["pack_into"],    true, "struct.Struct.__dict__.__contains__('pack_into') == True (C-level method_descriptor); verified with Python 3.14.3"]
    - [has_unpack_from,  struct.Struct.__dict__.__contains__,  ["unpack_from"],  true, "struct.Struct.__dict__.__contains__('unpack_from') == True (C-level method_descriptor); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ membership — iter_unpack, size, format, __doc__ — extra203
#
# Wave 255 theme: struct.Struct.__dict__ key membership for iter_unpack and attributes.
#
# struct.Struct.__dict__.__contains__('iter_unpack') == True
# struct.Struct.__dict__.__contains__('size')        == True
# struct.Struct.__dict__.__contains__('format')      == True
# struct.Struct.__dict__.__contains__('__doc__')     == True
# ---------------------------------------------------------------------------

table struct_extra203.Struct_dict_iter_and_attrs:
  description: "struct.Struct.__dict__ membership checks for iter_unpack and descriptor attributes in structdict203 namespace — wave 255 theme: struct.Struct.__dict__.__contains__('iter_unpack')==True ('iter_unpack' is a method_descriptor; Struct.iter_unpack(buffer) returns an iterator that repeatedly applies the format string to the buffer, yielding one tuple per struct-sized chunk); struct.Struct.__dict__.__contains__('size')==True ('size' is a getset_descriptor in Struct.__dict__; Struct.size returns the struct size in bytes — equivalent to calcsize(fmt)); struct.Struct.__dict__.__contains__('format')==True ('format' is a getset_descriptor; Struct.format returns the format string as originally given to the constructor); struct.Struct.__dict__.__contains__('__doc__')==True ('__doc__' is a str in Struct.__dict__ containing the class docstring for struct.Struct); struct.Struct.__dict__.__class__.__name__=='mappingproxy'; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: structdict203a

  columns: [id, function, args, expected, description]
  rows:
    - [has_iter_unpack, struct.Struct.__dict__.__contains__,  ["iter_unpack"], true, "struct.Struct.__dict__.__contains__('iter_unpack') == True (C-level method_descriptor); verified with Python 3.14.3"]
    - [has_size,        struct.Struct.__dict__.__contains__,  ["size"],        true, "struct.Struct.__dict__.__contains__('size') == True (getset_descriptor for struct size in bytes); verified with Python 3.14.3"]
    - [has_format,      struct.Struct.__dict__.__contains__,  ["format"],      true, "struct.Struct.__dict__.__contains__('format') == True (getset_descriptor for format string); verified with Python 3.14.3"]
    - [has_doc,         struct.Struct.__dict__.__contains__,  ["__doc__"],     true, "struct.Struct.__dict__.__contains__('__doc__') == True (class docstring); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__ class identity — extra203
#
# Wave 255 theme: struct.Struct.__dict__.__class__.__name__ == 'mappingproxy'
# ---------------------------------------------------------------------------

table struct_extra203.Struct_dict_class_identity:
  description: "struct.Struct.__dict__ class identity checks in structdict203 namespace — wave 255 theme: struct.Struct.__dict__.__class__.__name__.__eq__('mappingproxy')==True (struct.Struct is a C extension type defined in Modules/_struct.c; C extension types also have their class __dict__ wrapped in a mappingproxy just like Python-defined classes; all class __dict__ attributes in CPython are read-only mappingproxy wrappers); struct.Struct.__dict__.__class__.__name__.__len__()==12 ('mappingproxy'=12: 'mapping'=7 + 'proxy'=5); struct.Struct.__dict__ contains all the core Struct methods (pack, unpack, pack_into, unpack_from, iter_unpack) plus attributes (size, format, __doc__); comparing Struct.__dict__ to ABC.__dict__: both are mappingproxy with __class__.__name__=='mappingproxy' (len=12); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_identity
  id_prefix: structdict203b

  columns: [id, function, args, expected, description]
  rows:
    - [dict_cls_eq,  struct.Struct.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true, "struct.Struct.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]
    - [dict_cls_len, struct.Struct.__dict__.__class__.__name__.__len__,  [],               12,   "struct.Struct.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'=12); verified with Python 3.14.3"]
    - [pack_true,    struct.Struct.__dict__.__contains__,                 ["pack"],         true, "struct.Struct.__dict__.__contains__('pack') cross-check; verified with Python 3.14.3"]
    - [format_true,  struct.Struct.__dict__.__contains__,                 ["format"],       true, "struct.Struct.__dict__.__contains__('format') cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra203
# ---------------------------------------------------------------------------

invariant struct_extra203.Struct_dict_contains_pack:
  description: "struct.Struct.__dict__.__contains__('pack') returns True — 'pack' is present in struct.Struct.__dict__; Struct.pack(v1, v2, ...) packs values into a bytes object according to the format string; it is a C-level method_descriptor (defined in Modules/_struct.c as Struct_pack); struct.Struct.__dict__.__class__.__name__=='mappingproxy'; struct.Struct.__dict__.__contains__('unpack')==True (complementary method); struct.Struct.__dict__.__contains__('pack_into')==True (buffer variant); first standalone Struct.__dict__ 'pack' membership invariant in structdict203 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["pack"]
  expected: true

invariant struct_extra203.Struct_dict_contains_unpack:
  description: "struct.Struct.__dict__.__contains__('unpack') returns True — 'unpack' is present in struct.Struct.__dict__; Struct.unpack(buffer) returns a tuple of values unpacked from the buffer according to the format string; the buffer must be exactly Struct.size bytes long; it is a C-level method_descriptor; struct.Struct.__dict__.__class__.__name__=='mappingproxy'; struct.Struct.__dict__.__contains__('pack')==True (complementary method); first standalone Struct.__dict__ 'unpack' membership invariant in structdict203 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["unpack"]
  expected: true

invariant struct_extra203.Struct_dict_contains_pack_into:
  description: "struct.Struct.__dict__.__contains__('pack_into') returns True — 'pack_into' is present in struct.Struct.__dict__; Struct.pack_into(buffer, offset, v1, v2, ...) packs values directly into a writable buffer (bytearray or ctypes array) at the given offset; returns None; it is a C-level method_descriptor; struct.Struct.__dict__.__contains__('unpack_from')==True (complementary method that reads from a buffer at an offset); first standalone Struct.__dict__ 'pack_into' membership invariant in structdict203 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["pack_into"]
  expected: true

invariant struct_extra203.Struct_dict_contains_unpack_from:
  description: "struct.Struct.__dict__.__contains__('unpack_from') returns True — 'unpack_from' is present in struct.Struct.__dict__; Struct.unpack_from(buffer, offset=0) reads from a buffer at the given offset — unlike unpack(), the buffer does not need to be exactly size bytes long; returns a tuple of values; it is a C-level method_descriptor; first standalone Struct.__dict__ 'unpack_from' membership invariant in structdict203 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["unpack_from"]
  expected: true

invariant struct_extra203.Struct_dict_contains_iter_unpack:
  description: "struct.Struct.__dict__.__contains__('iter_unpack') returns True — 'iter_unpack' is present in struct.Struct.__dict__; Struct.iter_unpack(buffer) returns an iterator that repeatedly applies the format to the buffer, yielding one tuple per struct-sized chunk; len(list(Struct(fmt).iter_unpack(data)))==len(data)//calcsize(fmt); it is a C-level method_descriptor; first standalone Struct.__dict__ 'iter_unpack' membership invariant in structdict203 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["iter_unpack"]
  expected: true

invariant struct_extra203.Struct_dict_contains_size:
  description: "struct.Struct.__dict__.__contains__('size') returns True — 'size' is present in struct.Struct.__dict__; Struct.size is a getset_descriptor (C-level read-only property) that returns the struct size in bytes for the given format string — equivalent to struct.calcsize(fmt); struct.Struct('>H').size==2; struct.Struct('>BHI').size==7; first standalone Struct.__dict__ 'size' membership invariant in structdict203 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["size"]
  expected: true

invariant struct_extra203.Struct_dict_contains_format:
  description: "struct.Struct.__dict__.__contains__('format') returns True — 'format' is present in struct.Struct.__dict__; Struct.format is a getset_descriptor (C-level read-only property) that returns the format string as originally given to the Struct constructor; struct.Struct('>H').format=='>H'; on Python 3.12+ format is a str (was bytes in older versions); first standalone Struct.__dict__ 'format' membership invariant in structdict203 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["format"]
  expected: true

invariant struct_extra203.Struct_dict_contains_doc:
  description: "struct.Struct.__dict__.__contains__('__doc__') returns True — '__doc__' is present in struct.Struct.__dict__; struct.Struct.__doc__ is a string containing the class docstring describing the Struct compiled format object; C extension types define __doc__ in the PyTypeObject.tp_doc field; struct.Struct.__dict__.__class__.__name__=='mappingproxy'; '__doc__' is present in the __dict__ of most Python and C-extension classes; first standalone Struct.__dict__ '__doc__' membership invariant in structdict203 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__doc__"]
  expected: true
