spec: pathlib_extra520
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pathlib.Path stat-related and navigation method names verified Python 3.14.3 macOS/Darwin 25.4.0"
    - "hardlink_to added in Python 3.10; link_to deprecated in 3.12"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra520.path_method_names:
  description: "pathlib.Path additional method __name__ identity — stat-related and navigation methods"
  kind: python_call_eq
  category: method_names
  id_prefix: pl520pm

  columns: [id, function, args, expected]
  rows:
    - [pl520pm001, pathlib.Path.chmod.__name__.__eq__,       ["chmod"],       true]
    - [pl520pm002, pathlib.Path.lchmod.__name__.__eq__,      ["lchmod"],      true]
    - [pl520pm003, pathlib.Path.lstat.__name__.__eq__,       ["lstat"],       true]
    - [pl520pm004, pathlib.Path.symlink_to.__name__.__eq__,  ["symlink_to"],  true]
    - [pl520pm005, pathlib.Path.expanduser.__name__.__eq__,  ["expanduser"],  true]
    - [pl520pm006, pathlib.Path.home.__name__.__eq__,        ["home"],        true]
    - [pl520pm007, pathlib.Path.cwd.__name__.__eq__,         ["cwd"],         true]
    - [pl520pm008, pathlib.Path.absolute.__name__.__eq__,    ["absolute"],    true]
    - [pl520pm009, pathlib.Path.samefile.__name__.__eq__,    ["samefile"],    true]
    - [pl520pm010, pathlib.Path.open.__name__.__eq__,        ["open"],        true]
    - [pl520pm011, pathlib.Path.touch.__name__.__eq__,       ["touch"],       true]
    - [pl520pm012, pathlib.Path.replace.__name__.__eq__,     ["replace"],     true]
