spec: struct_extra1231
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.__dict__.__contains__ for top-level module attributes: Struct, pack, unpack, pack_into, unpack_from, iter_unpack, calcsize, error; also struct.Struct.__dict__.__contains__ for __new__ and __init_subclass__; and module name/package attrs"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1231.module_dict_contains_functions:
  description: "struct.__dict__.__contains__ checks for top-level packing/unpacking function and class names"
  kind: python_call_eq
  category: module_dict_contains_functions
  id_prefix: st1231mf
  columns: [id, function, args, expected]
  rows:
    - [st1231mf001, struct.__dict__.__contains__,                    ["Struct"],                    true]
    - [st1231mf002, struct.__dict__.__contains__,                    ["pack"],                      true]
    - [st1231mf003, struct.__dict__.__contains__,                    ["unpack"],                    true]
    - [st1231mf004, struct.__dict__.__contains__,                    ["pack_into"],                 true]
    - [st1231mf005, struct.__dict__.__contains__,                    ["unpack_from"],               true]
    - [st1231mf006, struct.__dict__.__contains__,                    ["iter_unpack"],               true]
    - [st1231mf007, struct.__dict__.__contains__,                    ["calcsize"],                  true]
    - [st1231mf008, struct.__dict__.__contains__,                    ["error"],                     true]
    - [st1231mf009, struct.__dict__.__class__.__name__.__eq__,       ["dict"],                      true]

table struct_extra1231.module_dict_class_identity:
  description: "struct.__dict__ class identity and module-level name/package attribute checks"
  kind: python_call_eq
  category: module_dict_class_identity
  id_prefix: st1231di
  columns: [id, function, args, expected]
  rows:
    - [st1231di001, struct.__dict__.__class__.__qualname__.__eq__,   ["dict"],                      true]
    - [st1231di002, struct.__dict__.__class__.__module__.__eq__,     ["builtins"],                  true]
    - [st1231di003, struct.__dict__.__class__.__name__.__class__.__name__.__eq__, ["str"],          true]
    - [st1231di004, struct.__dict__.__class__.__module__.__class__.__name__.__eq__, ["str"],        true]
    - [st1231di005, struct.__name__.__eq__,                          ["struct"],                    true]
    - [st1231di006, struct.__name__.__class__.__name__.__eq__,       ["str"],                       true]
    - [st1231di007, struct.__dict__.__contains__,                    ["__name__"],                  true]
    - [st1231di008, struct.__dict__.__contains__,                    ["__doc__"],                   true]
    - [st1231di009, struct.__dict__.__contains__,                    ["__package__"],               true]

table struct_extra1231.struct_class_dict_extra_keys:
  description: "struct.Struct.__dict__.__contains__ checks for __new__, __init_subclass__, pack_into, and iter_unpack qualname attrs"
  kind: python_call_eq
  category: struct_class_dict_extra_keys
  id_prefix: st1231ck
  columns: [id, function, args, expected]
  rows:
    - [st1231ck001, struct.Struct.__dict__.__contains__,             ["__new__"],                   true]
    - [st1231ck002, struct.Struct.__dict__.__contains__,             ["__init_subclass__"],         true]
    - [st1231ck003, struct.Struct.pack_into.__qualname__.__eq__,     ["Struct.pack_into"],          true]
    - [st1231ck004, struct.Struct.unpack_from.__qualname__.__eq__,   ["Struct.unpack_from"],        true]
    - [st1231ck005, struct.Struct.iter_unpack.__qualname__.__eq__,   ["Struct.iter_unpack"],        true]
    - [st1231ck006, struct.Struct.calcsize.__qualname__.__eq__,      ["Struct.calcsize"],           true]
    - [st1231ck007, struct.__dict__.__contains__,                    ["__spec__"],                  true]
    - [st1231ck008, struct.__dict__.__contains__,                    ["__loader__"],                true]
    - [st1231ck009, struct.__dict__.__class__.__qualname__.__class__.__name__.__eq__, ["str"],      true]
