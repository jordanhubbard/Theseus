spec: threading_extra2236
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2236: __slots__ and slot descriptor protocol — checking __slots__, __weakref__, __dict__, __abstractmethods__ presence in class dicts."
    - "threading.Thread is a pure-Python class: no __slots__, has __weakref__ and __dict__, defines __init__ but not __new__, no __abstractmethods__."
    - "threading.Lock is actually _thread.lock (C extension): no __slots__, no __weakref__, no __dict__, defines __new__ but not __init__."
    - "threading.Event is a pure-Python class: no __slots__, has __weakref__ and __dict__, defines __init__ but not __new__."
    - "threading.Condition is a pure-Python class: no __slots__, has __weakref__ and __dict__, defines __init__ but not __new__."
    - "threading.Semaphore is a pure-Python class: no __slots__, has __weakref__ and __dict__, defines __init__ but not __new__."
    - "threading.BoundedSemaphore is a pure-Python subclass of Semaphore: no __slots__, no __weakref__ (inherited), no __dict__ (inherited), defines __init__."
    - "threading.Barrier is a pure-Python class: no __slots__, has __weakref__ and __dict__, defines __init__ but not __new__."
    - "threading.Timer is a pure-Python subclass of Thread: no __slots__, no __weakref__ (inherited), no __dict__ (inherited), defines __init__."
    - "threading.local is a C extension type: no __slots__, no __weakref__, no __dict__, defines __new__ but not __init__."
    - "threading._RLock is the pure-Python RLock implementation: no __slots__, has __weakref__ and __dict__, defines __init__ but not __new__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table threading_extra2236.thread_slot_protocol:
  description: "threading.Thread slot descriptor protocol — pure-Python class, no __slots__, has __weakref__ and __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2236

  columns: [id, function, args, expected]
  rows:
    - ["th2236001", "threading.Thread.__dict__.__contains__", ["__slots__"], false]
    - ["th2236002", "threading.Thread.__dict__.__contains__", ["__weakref__"], true]
    - ["th2236003", "threading.Thread.__dict__.__contains__", ["__dict__"], true]
    - ["th2236004", "threading.Thread.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th2236005", "threading.Thread.__dict__.__contains__", ["__init__"], true]
    - ["th2236006", "threading.Thread.__dict__.__contains__", ["__new__"], false]
    - ["th2236007", "threading.Thread.__dict__.__contains__", ["__subclasshook__"], false]

table threading_extra2236.lock_slot_protocol:
  description: "threading.Lock slot descriptor protocol — C extension type (_thread.lock), no __slots__, no __weakref__, no __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2236

  columns: [id, function, args, expected]
  rows:
    - ["th2236008", "threading.Lock.__dict__.__contains__", ["__slots__"], false]
    - ["th2236009", "threading.Lock.__dict__.__contains__", ["__weakref__"], false]
    - ["th2236010", "threading.Lock.__dict__.__contains__", ["__dict__"], false]
    - ["th2236011", "threading.Lock.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["th2236012", "threading.Lock.__dict__.__contains__", ["__init__"], false]
    - ["th2236013", "threading.Lock.__dict__.__contains__", ["__new__"], true]
    - ["th2236014", "threading.Lock.__dict__.__contains__", ["__subclasshook__"], false]

