spec: concurrent_futures_extra126
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers: wave 255 theme — concurrent.futures.ProcessPoolExecutor method code object co_varnames. NEW in extra126: ProcessPoolExecutor.submit.__code__.co_varnames[0]=='self'; ProcessPoolExecutor.submit.__code__.co_varnames[1]=='fn'; ProcessPoolExecutor.submit.__code__.co_argcount==2; ProcessPoolExecutor.shutdown.__code__.co_varnames[0]=='self'; ProcessPoolExecutor.shutdown.__code__.co_varnames[1]=='wait'; ProcessPoolExecutor.shutdown.__code__.co_argcount==2; ProcessPoolExecutor.__init__.__code__.co_argcount==5; ProcessPoolExecutor.__init__.__code__.co_varnames[0]=='self'; ProcessPoolExecutor.__init__.__code__.co_varnames[1]=='max_workers'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ProcessPoolExecutor.submit.__code__.co_argcount == 2. submit(self, fn, /, *args, **kwargs) has co_argcount==2 (self and fn are positional-only parameters; *args and **kwargs are not counted in co_argcount). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount == 5. __init__(self, max_workers, mp_context, initializer, initargs) has 5 positional parameters (plus 'max_tasks_per_child' and 'queue_size' as keyword-only, not counted in co_argcount). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3. PPE inherits from Executor (MRO=[ProcessPoolExecutor, Executor, object]), giving depth 3 — one deeper than concurrent.futures.Future (depth=2). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19. 'ProcessPoolExecutor' is 19 chars: 'Process'=7 + 'Pool'=4 + 'Executor'=8. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ProcessPoolExecutor.submit code object co_varnames — extra126
#
# Wave 255 theme: concurrent.futures.ProcessPoolExecutor method co_varnames.
#
# ProcessPoolExecutor.submit.__code__.co_varnames[0] == 'self'
# ProcessPoolExecutor.submit.__code__.co_varnames[1] == 'fn'
# ProcessPoolExecutor.submit.__code__.co_argcount    == 2
# ---------------------------------------------------------------------------

table concurrent_futures_extra126.cf_ppe_submit_covarnames:
  description: "concurrent.futures.ProcessPoolExecutor.submit code object co_varnames checks in cfppecovars126 namespace — wave 255 theme: ProcessPoolExecutor is defined in Lib/concurrent/futures/process.py (module='concurrent.futures.process'); submit(self, fn, /, *args, **kwargs) has co_argcount==2 because self and fn are positional-or-keyword parameters; *args and **kwargs are not counted in co_argcount but appear in co_varnames; submit.__code__.co_varnames[0].__eq__('self')==True (first parameter is always self for bound methods); submit.__code__.co_varnames[1].__eq__('fn')==True (fn is the callable to be executed in a process pool worker); submit.__code__.co_argcount.__eq__(2)==True (only self and fn are counted in co_argcount — the positional-or-keyword params before *args); the remaining co_varnames are ('args', 'kwargs', 'f', 'w') for the *args expansion, **kwargs, the submitted Future, and the work item; submit is defined directly in ProcessPoolExecutor (not inherited from Executor); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_identity
  id_prefix: cfppecovars126

  columns: [id, function, args, expected, description]
  rows:
    - [sub_var0,     "concurrent.futures.ProcessPoolExecutor.submit.__code__.co_varnames.__getitem__",  [0],     "self", "ProcessPoolExecutor.submit.__code__.co_varnames[0] == 'self'; verified with Python 3.14.3"]
    - [sub_var1,     "concurrent.futures.ProcessPoolExecutor.submit.__code__.co_varnames.__getitem__",  [1],     "fn",   "ProcessPoolExecutor.submit.__code__.co_varnames[1] == 'fn' (callable arg); verified with Python 3.14.3"]
    - [sub_argc,     "concurrent.futures.ProcessPoolExecutor.submit.__code__.co_argcount.__eq__",       [2],     true,   "ProcessPoolExecutor.submit.__code__.co_argcount == 2 (self + fn, positional-or-keyword only); verified with Python 3.14.3"]
    - [sub_argc_val, "concurrent.futures.ProcessPoolExecutor.submit.__code__.co_argcount.__eq__",       [2],     true,   "submit co_argcount==2: self and fn are the two positional-or-keyword params; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ProcessPoolExecutor.shutdown and __init__ code object co_varnames — extra126
#
# Wave 255 theme: shutdown and __init__ code object inspection.
#
# ProcessPoolExecutor.shutdown.__code__.co_varnames[0] == 'self'
# ProcessPoolExecutor.shutdown.__code__.co_varnames[1] == 'wait'
# ProcessPoolExecutor.shutdown.__code__.co_argcount    == 2
# ProcessPoolExecutor.__init__.__code__.co_argcount    == 5
# ProcessPoolExecutor.__init__.__code__.co_varnames[0] == 'self'
# ProcessPoolExecutor.__init__.__code__.co_varnames[1] == 'max_workers'
# ---------------------------------------------------------------------------

table concurrent_futures_extra126.cf_ppe_shutdown_init_covarnames:
  description: "concurrent.futures.ProcessPoolExecutor.shutdown and __init__ code object co_varnames checks in cfppecovars126 namespace — wave 255 theme: shutdown(self, wait=True, *, cancel_futures=False) has co_argcount==2 (self and wait are positional-or-keyword; cancel_futures is keyword-only and not counted in co_argcount); shutdown.__code__.co_varnames[0].__eq__('self')==True; shutdown.__code__.co_varnames[1].__eq__('wait')==True (the 'wait' parameter controls whether shutdown blocks until all futures complete); __init__(self, max_workers=None, mp_context=None, initializer=None, initargs=()) has co_argcount==5 (self, max_workers, mp_context, initializer, initargs are all positional-or-keyword); __init__.__code__.co_varnames[0].__eq__('self')==True; __init__.__code__.co_varnames[1].__eq__('max_workers')==True (max_workers is the first user-visible parameter, controlling maximum parallel processes); __init__.__code__.co_argcount.__eq__(5)==True; all inspections use the pure-Python code object (ProcessPoolExecutor is defined in process.py, not a C extension); verified with Python 3.14.3"
  kind: python_call_eq
  category: code_identity
  id_prefix: cfppecovars126a

  columns: [id, function, args, expected, description]
  rows:
    - [shut_var0,     "concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_varnames.__getitem__",    [0],  "self", "ProcessPoolExecutor.shutdown.__code__.co_varnames[0] == 'self'; verified with Python 3.14.3"]
    - [shut_var1,     "concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_varnames.__getitem__",    [1],  "wait", "ProcessPoolExecutor.shutdown.__code__.co_varnames[1] == 'wait'; verified with Python 3.14.3"]
    - [shut_argc,     "concurrent.futures.ProcessPoolExecutor.shutdown.__code__.co_argcount.__eq__",         [2],  true,   "ProcessPoolExecutor.shutdown.__code__.co_argcount == 2 (self + wait); verified with Python 3.14.3"]
    - [init_argc,     "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__",         [5],  true,   "ProcessPoolExecutor.__init__.__code__.co_argcount == 5 (self, max_workers, mp_context, initializer, initargs); verified with Python 3.14.3"]
    - [init_var0,     "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames.__getitem__",    [0],  "self",        "ProcessPoolExecutor.__init__.__code__.co_varnames[0] == 'self'; verified with Python 3.14.3"]
    - [init_var1,     "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_varnames.__getitem__",    [1],  "max_workers", "ProcessPoolExecutor.__init__.__code__.co_varnames[1] == 'max_workers'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# ProcessPoolExecutor class identity — extra126
#
# Wave 255 theme: ProcessPoolExecutor class-level identity checks.
#
# ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (len=19)
# ProcessPoolExecutor.__module__ == 'concurrent.futures.process'
# ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'
# ProcessPoolExecutor.__mro__.__len__() == 3
# ---------------------------------------------------------------------------

table concurrent_futures_extra126.cf_ppe_class_identity:
  description: "concurrent.futures.ProcessPoolExecutor class identity checks in cfppecovars126 namespace — wave 255 theme: ProcessPoolExecutor is a pure-Python class in Lib/concurrent/futures/process.py; ProcessPoolExecutor.__name__.__eq__('ProcessPoolExecutor')==True (len=19: 'Process'=7+'Pool'=4+'Executor'=8); ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process')==True (defined in the process submodule, distinct from _base.py where Future and Executor are defined); ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (inherits from Executor, the abstract base class for executor implementations in _base.py); ProcessPoolExecutor.__mro__.__len__()==3 (MRO=[ProcessPoolExecutor, Executor, object], depth-3 — one deeper than Future's depth-2 MRO); ProcessPoolExecutor.__class__.__name__.__eq__('type')==True; ProcessPoolExecutor.__name__.__len__()==19 (the longest class name in the concurrent.futures public API); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfppecovars126b

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_name,      "concurrent.futures.ProcessPoolExecutor.__name__.__eq__",              ["ProcessPoolExecutor"],          true, "ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (len=19); verified with Python 3.14.3"]
    - [ppe_namelen,   "concurrent.futures.ProcessPoolExecutor.__name__.__len__",             [],                               19,   "ProcessPoolExecutor.__name__.__len__() == 19 ('Process'=7+'Pool'=4+'Executor'=8); verified with Python 3.14.3"]
    - [ppe_module,    "concurrent.futures.ProcessPoolExecutor.__module__.__eq__",            ["concurrent.futures.process"],   true, "ProcessPoolExecutor.__module__ == 'concurrent.futures.process'; verified with Python 3.14.3"]
    - [ppe_base0,     "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"],                     true, "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'; verified with Python 3.14.3"]
    - [ppe_mro_len,   "concurrent.futures.ProcessPoolExecutor.__mro__.__len__",              [],                               3,    "ProcessPoolExecutor.__mro__.__len__() == 3 — [ProcessPoolExecutor, Executor, object]; verified with Python 3.14.3"]
    - [ppe_class_nm,  "concurrent.futures.ProcessPoolExecutor.__class__.__name__.__eq__",    ["type"],                         true, "ProcessPoolExecutor.__class__.__name__ == 'type' — genuine Python class; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra126
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra126.PPE_submit_var0_is_self:
  description: "concurrent.futures.ProcessPoolExecutor.submit.__code__.co_varnames[0] == 'self' — the first co_varname of ProcessPoolExecutor.submit is always 'self' (the instance parameter for bound methods); submit is a Python function defined in Lib/concurrent/futures/process.py with signature submit(self, fn, /, *args, **kwargs); the co_varnames tuple begins with ('self', 'fn', ...) — 'self' at index 0 and 'fn' at index 1; co_argcount is 2 (counting self and fn as positional-or-keyword params, not counting *args or **kwargs); ProcessPoolExecutor.submit overrides the abstract Executor.submit method; ProcessPoolExecutor.__module__ is 'concurrent.futures.process'; NEW in extra126: first standalone PPE submit co_varnames[0] invariant in cfppecovars126 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.submit.__code__.co_varnames.__getitem__"
  args: [0]
  expected: "self"

invariant concurrent_futures_extra126.PPE_submit_var1_is_fn:
  description: "concurrent.futures.ProcessPoolExecutor.submit.__code__.co_varnames[1] == 'fn' — the second co_varname of ProcessPoolExecutor.submit is 'fn', the callable to be executed in the process pool; submit(self, fn, /, *args, **kwargs) schedules fn to be executed and returns a Future object; 'fn' is positional-only (note the '/' in the signature) and is one of the two positional-or-keyword params contributing to co_argcount==2; the 'fn' naming convention is consistent with ThreadPoolExecutor.submit and the abstract Executor.submit API; the remaining co_varnames after 'fn' are local variables for *args expansion, **kwargs, the Future object, and the work item; ProcessPoolExecutor.submit.__code__.co_varnames[1]=='fn'; NEW in extra126: first standalone PPE submit co_varnames[1] invariant in cfppecovars126 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.submit.__code__.co_varnames.__getitem__"
  args: [1]
  expected: "fn"

invariant concurrent_futures_extra126.PPE_init_argc_is_5:
  description: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount == 5 — __init__(self, max_workers=None, mp_context=None, initializer=None, initargs=()) has 5 positional-or-keyword parameters: self, max_workers, mp_context, initializer, initargs; these 5 params are counted in co_argcount; any keyword-only parameters (like max_tasks_per_child and queue_size added in later Python versions) are not counted in co_argcount but do appear in co_varnames; ProcessPoolExecutor.__init__.__code__.co_varnames[0] is 'self' and co_varnames[1] is 'max_workers'; max_workers controls the maximum number of parallel worker processes; compare with submit's co_argcount==2 and shutdown's co_argcount==2, both having far fewer positional params; ProcessPoolExecutor.__module__ is 'concurrent.futures.process'; NEW in extra126: first standalone PPE __init__ co_argcount invariant in cfppecovars126 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__init__.__code__.co_argcount.__eq__"
  args: [5]
  expected: true

invariant concurrent_futures_extra126.PPE_module_is_process:
  description: "concurrent.futures.ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process') returns True — ProcessPoolExecutor is defined in Lib/concurrent/futures/process.py (module='concurrent.futures.process'); this is distinct from where Future and Executor are defined ('concurrent.futures._base', a private module with underscore prefix); the naming convention distinguishes public submodules (process, thread) from the private implementation module (_base); ProcessPoolExecutor.__name__ is 'ProcessPoolExecutor' (len=19: the longest class name in the concurrent.futures public API); ProcessPoolExecutor.__bases__[0].__name__ is 'Executor'; ProcessPoolExecutor.__mro__.__len__() is 3 ([ProcessPoolExecutor, Executor, object]); NEW in extra126: first standalone PPE module invariant in cfppecovars126 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__module__.__eq__"
  args: ["concurrent.futures.process"]
  expected: true

invariant concurrent_futures_extra126.PPE_mro_len_is_3:
  description: "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3 — ProcessPoolExecutor's MRO is [ProcessPoolExecutor, Executor, object] (length=3); this depth-3 chain is one deeper than concurrent.futures.Future (depth=2, MRO=[Future, object]) because ProcessPoolExecutor inherits from the abstract Executor base class; ProcessPoolExecutor.__bases__[0].__name__ is 'Executor'; the Executor abstract class (in 'concurrent.futures._base') defines the submit() and shutdown() interface; compare: concurrent.futures.Future.__mro__.__len__()==2 (depth=2); asyncio.TaskGroup.__mro__.__len__()==2 (depth=2); asyncio.BoundedSemaphore.__mro__.__len__()==5 (depth=5, deepest in asyncio locks); ProcessPoolExecutor.__module__ is 'concurrent.futures.process'; NEW in extra126: first standalone PPE MRO length invariant in cfppecovars126 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__mro__.__len__"
  args: []
  expected: 3
