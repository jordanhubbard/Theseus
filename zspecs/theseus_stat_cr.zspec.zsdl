spec: theseus_stat_cr
version: ">=3.8"
backend: python_cleanroom(theseus_stat_cr)
blocks: stat

docs: https://docs.python.org/3/library/stat.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/stat.html"
    - "POSIX.1-2017 file status constants"
  not_derived_from:
    - "CPython source: Lib/stat.py (internal implementation)"
  notes:
    - "Clean-room stat module. Do NOT import stat."
    - "S_ISREG(mode): True if mode is a regular file."
    - "S_ISDIR(mode): True if mode is a directory."
    - "S_ISLNK(mode): True if mode is a symbolic link."
    - "filemode(mode): return string like '-rwxr-xr-x' from numeric mode."
    - "Mode bit constants: S_IRUSR, S_IWUSR, S_IXUSR, S_IRGRP, etc."
    - "S_IFMT(mode): return the file type portion of a file mode."

error_model: python_exceptions

invariant theseus_stat_cr.stat2_isreg:
  description: "S_ISREG(os.stat(__file__).st_mode) is True for a regular file"
  category: S_ISREG
  kind: python_call_eq
  function: stat2_isreg
  args: []
  expected: true

invariant theseus_stat_cr.stat2_filemode:
  description: "filemode(0o100644) == '-rw-r--r--'"
  category: filemode
  kind: python_call_eq
  function: stat2_filemode
  args: []
  expected: "-rw-r--r--"

invariant theseus_stat_cr.stat2_constants:
  description: "S_IRUSR | S_IWUSR | S_IRGRP | S_IROTH == 0o644"
  category: constants
  kind: python_call_eq
  function: stat2_constants
  args: []
  expected: true
