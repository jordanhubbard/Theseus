spec: pluggy
version: ">=1.0"
backend: python_module(pluggy)

docs: https://pluggy.readthedocs.io/

provenance:
  derived_from:
    - "pluggy documentation — https://pluggy.readthedocs.io/"
    - "pluggy PyPI page — https://pypi.org/project/pluggy/"
    - "Test vectors verified with pluggy 1.6.0 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "pluggy source: src/pluggy/_manager.py"
    - "pluggy source: src/pluggy/_hooks.py"
    - "pluggy source: src/pluggy/_callers.py"
  notes:
    - "pluggy is pytest's plugin manager, also usable as a standalone library."
    - "PluginManager.get_plugins() returns a set (not a list); empty set on fresh manager."
    - "HookspecMarker and HookimplMarker are callable classes (instances are decorators)."
    - "is_registered(None) returns False — None is never a valid plugin."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — __version__ is a string containing a dot
# ---------------------------------------------------------------------------

invariant pluggy.version.is_string_with_dot:
  description: "__version__ contains a dot (e.g. '1.6.0')"
  category: version
  kind: python_call_eq
  function: __version__.__contains__
  args: ["."]
  expected: true

invariant pluggy.version.starts_with_digit:
  description: "__version__ starts with '1' (major version)"
  category: version
  kind: python_call_eq
  function: __version__.startswith
  args: ["1"]
  expected: true

# ---------------------------------------------------------------------------
# plugin_manager — PluginManager('myproject').project_name == 'myproject'
# ---------------------------------------------------------------------------

invariant pluggy.plugin_manager.project_name:
  description: "PluginManager('myproject').project_name == 'myproject'"
  category: plugin_manager
  kind: python_call_eq
  function: PluginManager
  args: ["myproject"]
  method: project_name
  expected: "myproject"

invariant pluggy.plugin_manager.class_name:
  description: "PluginManager.__name__ == 'PluginManager'"
  category: plugin_manager
  kind: python_call_eq
  function: PluginManager.__name__.__eq__
  args: ["PluginManager"]
  expected: true

# ---------------------------------------------------------------------------
# markers — HookspecMarker and HookimplMarker class names and callability
# ---------------------------------------------------------------------------

invariant pluggy.markers.hookspec_class_name:
  description: "HookspecMarker.__name__ == 'HookspecMarker'"
  category: markers
  kind: python_call_eq
  function: HookspecMarker.__name__.__eq__
  args: ["HookspecMarker"]
  expected: true

invariant pluggy.markers.hookimpl_class_name:
  description: "HookimplMarker.__name__ == 'HookimplMarker'"
  category: markers
  kind: python_call_eq
  function: HookimplMarker.__name__.__eq__
  args: ["HookimplMarker"]
  expected: true

invariant pluggy.markers.hookspec_instance_project_name:
  description: "HookspecMarker('myproject').project_name == 'myproject' — marker stores its project name"
  category: markers
  kind: python_call_eq
  function: HookspecMarker
  args: ["myproject"]
  method: project_name
  expected: "myproject"

invariant pluggy.markers.hookimpl_instance_project_name:
  description: "HookimplMarker('myproject').project_name == 'myproject' — marker stores its project name"
  category: markers
  kind: python_call_eq
  function: HookimplMarker
  args: ["myproject"]
  method: project_name
  expected: "myproject"

# ---------------------------------------------------------------------------
# pm_methods — get_plugins() returns empty set; is_registered(None) is False
# ---------------------------------------------------------------------------

invariant pluggy.pm_methods.get_plugins_is_empty:
  description: "PluginManager('x').get_plugins().__len__() == 0 — no plugins on fresh manager"
  category: pm_methods
  kind: python_call_eq
  function: PluginManager
  args: ["x"]
  method: get_plugins
  method_chain: __len__
  expected: 0

invariant pluggy.pm_methods.is_registered_none_is_false:
  description: "PluginManager('x').is_registered(None) == False"
  category: pm_methods
  kind: python_call_eq
  function: PluginManager
  args: ["x"]
  method: is_registered
  method_args: [~]
  expected: false

invariant pluggy.pm_methods.has_register:
  description: "PluginManager has 'register' attribute — hasattr check via __contains__"
  category: pm_methods
  kind: python_call_eq
  function: PluginManager.__dict__.__contains__
  args: ["register"]
  expected: true

invariant pluggy.pm_methods.has_unregister:
  description: "PluginManager has 'unregister' attribute"
  category: pm_methods
  kind: python_call_eq
  function: PluginManager.__dict__.__contains__
  args: ["unregister"]
  expected: true

invariant pluggy.pm_methods.has_get_plugins:
  description: "PluginManager has 'get_plugins' attribute"
  category: pm_methods
  kind: python_call_eq
  function: PluginManager.__dict__.__contains__
  args: ["get_plugins"]
  expected: true

