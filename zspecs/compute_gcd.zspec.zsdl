spec: compute_gcd
version: ">=1.2.1"
backend: node(compute-gcd)

docs: https://www.npmjs.com/package/compute-gcd

provenance:
  derived_from:
    - "compute-gcd README — https://www.npmjs.com/package/compute-gcd"
    - "Test vectors verified with compute-gcd via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "compute-gcd source"
  notes:
    - "compute-gcd is an npm package. Install: npm install compute-gcd"
    - "Returns the greatest common divisor of two integers."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table compute_gcd.gcd:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: gcd

  columns: [id, args, expected]
  rows:
    - [twelve_eight, [12, 8],  4]
    - [six_four,     [6, 4],   2]
    - [prime,        [7, 13],  1]
    - [same,         [6, 6],   6]
