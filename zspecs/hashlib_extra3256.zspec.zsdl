spec: hl3256
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 664 (hl3256): __rpow__, __rlshift__, __rrshift__ dict-presence checks for hashlib types."
    - "Theme: __rpow__/__rlshift__/__rrshift__ dict-presence (reflected power/shift)."
    - "All values False — hash objects do not define reflected power or bitwise-shift protocol."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __rpow__, __rlshift__, or __rrshift__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3256.rpow:
  description: "hashlib types __rpow__ dict-presence checks; wave 664"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3256
  columns: [id, function, args, expected]
  rows:
    - ["hl3256001", operator.contains, [type(hashlib.md5()).__dict__,        "__rpow__"], false]
    - ["hl3256002", operator.contains, [type(hashlib.sha1()).__dict__,       "__rpow__"], false]
    - ["hl3256003", operator.contains, [type(hashlib.sha256()).__dict__,     "__rpow__"], false]
    - ["hl3256004", operator.contains, [type(hashlib.sha512()).__dict__,     "__rpow__"], false]
    - ["hl3256005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__rpow__"], false]

