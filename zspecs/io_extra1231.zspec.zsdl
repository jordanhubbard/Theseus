spec: io_extra1231
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io.__dict__.__contains__ checks for module-level names: IOBase, RawIOBase, BufferedIOBase, TextIOBase, FileIO, BytesIO, StringIO, TextIOWrapper, BufferedReader, BufferedWriter, open, DEFAULT_BUFFER_SIZE, UnsupportedOperation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io.__dict__.__contains__ for module-level class and constant names exported by the io module; checks io.__dict__.__contains__ for names that should NOT be present (e.g. subprocess-owned names, unrelated builtins); checks io.TextIOBase.__dict__.__contains__ for methods TextIOBase defines on top of IOBase such as read, readline, write, seek, tell, encoding, newlines, errors; none of these io.__dict__.__contains__ or io.TextIOBase.__dict__.__contains__ membership checks were covered in _extra1201, _extra1216, or any prior io_extra spec"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1231.module_dict_contains_classes:
  description: "io.__dict__.__contains__ checks for module-level class names — IOBase, RawIOBase, BufferedIOBase, TextIOBase, FileIO, BytesIO, StringIO, TextIOWrapper, BufferedReader, BufferedWriter, UnsupportedOperation all present in io.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1231mc
  columns: [id, function, args, expected]
  rows:
    - [io1231mc001, io.__dict__.__contains__, ["IOBase"],              true]
    - [io1231mc002, io.__dict__.__contains__, ["RawIOBase"],           true]
    - [io1231mc003, io.__dict__.__contains__, ["BufferedIOBase"],      true]
    - [io1231mc004, io.__dict__.__contains__, ["TextIOBase"],          true]
    - [io1231mc005, io.__dict__.__contains__, ["FileIO"],              true]
    - [io1231mc006, io.__dict__.__contains__, ["BytesIO"],             true]
    - [io1231mc007, io.__dict__.__contains__, ["StringIO"],            true]
    - [io1231mc008, io.__dict__.__contains__, ["TextIOWrapper"],       true]
    - [io1231mc009, io.__dict__.__contains__, ["BufferedReader"],      true]
    - [io1231mc010, io.__dict__.__contains__, ["BufferedWriter"],      true]
    - [io1231mc011, io.__dict__.__contains__, ["UnsupportedOperation"], true]

table io_extra1231.module_dict_contains_other:
  description: "io.__dict__.__contains__ checks for module-level constants and functions — open and DEFAULT_BUFFER_SIZE present; names from unrelated modules absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1231mo
  columns: [id, function, args, expected]
  rows:
    - [io1231mo001, io.__dict__.__contains__, ["open"],                 true]
    - [io1231mo002, io.__dict__.__contains__, ["DEFAULT_BUFFER_SIZE"],  true]
    - [io1231mo003, io.__dict__.__contains__, ["SEEK_SET"],             true]
    - [io1231mo004, io.__dict__.__contains__, ["SEEK_CUR"],             true]
    - [io1231mo005, io.__dict__.__contains__, ["SEEK_END"],             true]
    - [io1231mo006, io.__dict__.__contains__, ["subprocess"],           false]
    - [io1231mo007, io.__dict__.__contains__, ["socket"],               false]
    - [io1231mo008, io.__dict__.__contains__, ["Path"],                 false]
    - [io1231mo009, io.__dict__.__contains__, ["Decimal"],              false]
    - [io1231mo010, io.__dict__.__contains__, ["BufferedRandom"],       true]

table io_extra1231.textiobase_dict_contains:
  description: "io.TextIOBase.__dict__.__contains__ checks for methods TextIOBase defines on top of IOBase — read, readline, write, seek, tell, encoding, newlines, errors present in TextIOBase.__dict__; BufferedIOBase-specific methods absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1231tb
  columns: [id, function, args, expected]
  rows:
    - [io1231tb001, io.TextIOBase.__dict__.__contains__, ["read"],      true]
    - [io1231tb002, io.TextIOBase.__dict__.__contains__, ["readline"],  true]
    - [io1231tb003, io.TextIOBase.__dict__.__contains__, ["write"],     true]
    - [io1231tb004, io.TextIOBase.__dict__.__contains__, ["seek"],      true]
    - [io1231tb005, io.TextIOBase.__dict__.__contains__, ["tell"],      true]
    - [io1231tb006, io.TextIOBase.__dict__.__contains__, ["encoding"],  true]
    - [io1231tb007, io.TextIOBase.__dict__.__contains__, ["newlines"],  true]
    - [io1231tb008, io.TextIOBase.__dict__.__contains__, ["errors"],    true]
    - [io1231tb009, io.TextIOBase.__dict__.__contains__, ["detach"],    true]
    - [io1231tb010, io.TextIOBase.__dict__.__contains__, ["read1"],     false]
    - [io1231tb011, io.TextIOBase.__dict__.__contains__, ["readinto"],  false]
    - [io1231tb012, io.TextIOBase.__dict__.__contains__, ["getvalue"],  false]
