spec: asyncio_extra2431
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio: Asynchronous I/O"
    - "https://docs.python.org/3/library/asyncio-stream.html — asyncio Streams"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "Theme: __aiter__ and __anext__ async iteration protocol dict-presence for asyncio classes."
    - "Only asyncio.StreamReader defines both __aiter__ and __anext__ in its __dict__."
    - "asyncio.StreamReader.__aiter__ and __anext__ support async-for iteration over lines."
    - "asyncio.Task.__iter__ and asyncio.Future.__iter__ exist (for yield-from) but NOT __aiter__."
    - "asyncio.Queue, Lock, Event, Semaphore, BoundedSemaphore, Condition, Barrier: no async iter protocol."
    - "asyncio.AbstractEventLoop, BaseEventLoop: no async iteration protocol."
    - "asyncio.TaskGroup, Timeout, StreamWriter: no async iteration protocol."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: StreamReader — the ONLY asyncio class with __aiter__ and __anext__
#
# asyncio.StreamReader.__dict__ defines __aiter__ == True
# asyncio.StreamReader.__dict__ defines __anext__ == True
# asyncio.StreamReader.__dict__ defines __iter__  == False (async, not sync iter)
# ---------------------------------------------------------------------------

table asyncio_extra2431.StreamReader_async_iter_protocol:
  description: "asyncio.StreamReader __aiter__ and __anext__ dict-presence checks — StreamReader is the only asyncio class that defines both async iteration dunder methods in its __dict__, enabling async-for iteration over lines read from the stream"
  kind: python_call_eq
  category: async_iter_protocol
  id_prefix: as2431

  columns: [id, function, args, expected]
  rows:
    - ["as2431001", asyncio.StreamReader.__dict__.__contains__, ["__aiter__"], true]
    - ["as2431002", asyncio.StreamReader.__dict__.__contains__, ["__anext__"], true]
    - ["as2431003", asyncio.StreamReader.__dict__.__contains__, ["__iter__"],  false]
    - ["as2431004", asyncio.StreamReader.__dict__.__contains__, ["__next__"],  false]

# ---------------------------------------------------------------------------
# Table 2: Task and Future — have __iter__ but NOT __aiter__
#
# asyncio.Task.__dict__   defines __iter__  == True  (yield-from support)
# asyncio.Task.__dict__   defines __aiter__ == False
# asyncio.Future.__dict__ defines __iter__  == True  (yield-from support)
# asyncio.Future.__dict__ defines __aiter__ == False
# ---------------------------------------------------------------------------

table asyncio_extra2431.Task_Future_async_iter_protocol:
  description: "asyncio.Task and asyncio.Future __aiter__ and __iter__ dict-presence checks — Task and Future define __iter__ for yield-from protocol but do NOT define __aiter__ or __anext__; they are awaitable but not async-iterable"
  kind: python_call_eq
  category: async_iter_protocol
  id_prefix: as2431

  columns: [id, function, args, expected]
  rows:
    - ["as2431005", asyncio.Task.__dict__.__contains__,   ["__aiter__"], false]
    - ["as2431006", asyncio.Task.__dict__.__contains__,   ["__anext__"], false]
    - ["as2431007", asyncio.Task.__dict__.__contains__,   ["__iter__"],  true]
    - ["as2431008", asyncio.Future.__dict__.__contains__,  ["__aiter__"], false]
    - ["as2431009", asyncio.Future.__dict__.__contains__,  ["__anext__"], false]
    - ["as2431010", asyncio.Future.__dict__.__contains__,  ["__iter__"],  true]

# ---------------------------------------------------------------------------
# Table 3: Queue, Lock, Event — no async or sync iteration protocol
#
# asyncio.Queue.__dict__  defines __aiter__ == False, __iter__ == False
# asyncio.Lock.__dict__   defines __aiter__ == False, __iter__ == False
# asyncio.Event.__dict__  defines __aiter__ == False, __iter__ == False
# ---------------------------------------------------------------------------

table asyncio_extra2431.Queue_Lock_Event_async_iter_protocol:
  description: "asyncio.Queue, asyncio.Lock, asyncio.Event __aiter__ dict-presence checks — none of these synchronization primitives define __aiter__ or __anext__ or __iter__ in their __dict__; they are not iterable in any form"
  kind: python_call_eq
  category: async_iter_protocol
  id_prefix: as2431

  columns: [id, function, args, expected]
  rows:
    - ["as2431011", asyncio.Queue.__dict__.__contains__, ["__aiter__"], false]
    - ["as2431012", asyncio.Queue.__dict__.__contains__, ["__anext__"], false]
    - ["as2431013", asyncio.Queue.__dict__.__contains__, ["__iter__"],  false]
    - ["as2431014", asyncio.Lock.__dict__.__contains__,  ["__aiter__"], false]
    - ["as2431015", asyncio.Lock.__dict__.__contains__,  ["__anext__"], false]
    - ["as2431016", asyncio.Lock.__dict__.__contains__,  ["__iter__"],  false]
    - ["as2431017", asyncio.Event.__dict__.__contains__, ["__aiter__"], false]
    - ["as2431018", asyncio.Event.__dict__.__contains__, ["__anext__"], false]
    - ["as2431019", asyncio.Event.__dict__.__contains__, ["__iter__"],  false]

# ---------------------------------------------------------------------------
# Table 4: Semaphore, BoundedSemaphore, Condition, Barrier — no async iter
#
# All False for __aiter__, __anext__, __iter__ in their own __dict__
# ---------------------------------------------------------------------------

table asyncio_extra2431.Semaphore_Condition_Barrier_async_iter_protocol:
  description: "asyncio.Semaphore, asyncio.BoundedSemaphore, asyncio.Condition, asyncio.Barrier __aiter__ dict-presence checks — synchronization primitives with no async iteration protocol defined in their own __dict__"
  kind: python_call_eq
  category: async_iter_protocol
  id_prefix: as2431

  columns: [id, function, args, expected]
  rows:
    - ["as2431020", asyncio.Semaphore.__dict__.__contains__,        ["__aiter__"], false]
    - ["as2431021", asyncio.Semaphore.__dict__.__contains__,        ["__anext__"], false]
    - ["as2431022", asyncio.BoundedSemaphore.__dict__.__contains__, ["__aiter__"], false]
    - ["as2431023", asyncio.BoundedSemaphore.__dict__.__contains__, ["__anext__"], false]
    - ["as2431024", asyncio.Condition.__dict__.__contains__,        ["__aiter__"], false]
    - ["as2431025", asyncio.Condition.__dict__.__contains__,        ["__anext__"], false]
    - ["as2431026", asyncio.Barrier.__dict__.__contains__,          ["__aiter__"], false]
    - ["as2431027", asyncio.Barrier.__dict__.__contains__,          ["__anext__"], false]

# ---------------------------------------------------------------------------
# Table 5: AbstractEventLoop, BaseEventLoop, TaskGroup, Timeout, StreamWriter
#
# None define __aiter__ or __anext__ in their __dict__
# ---------------------------------------------------------------------------

table asyncio_extra2431.EventLoop_TaskGroup_Timeout_async_iter_protocol:
  description: "asyncio.AbstractEventLoop, asyncio.BaseEventLoop, asyncio.TaskGroup, asyncio.Timeout, asyncio.StreamWriter __aiter__ dict-presence checks — none of these higher-level asyncio classes define async iteration protocol in their __dict__"
  kind: python_call_eq
  category: async_iter_protocol
  id_prefix: as2431

  columns: [id, function, args, expected]
  rows:
    - ["as2431028", asyncio.AbstractEventLoop.__dict__.__contains__, ["__aiter__"], false]
    - ["as2431029", asyncio.AbstractEventLoop.__dict__.__contains__, ["__anext__"], false]
    - ["as2431030", asyncio.AbstractEventLoop.__dict__.__contains__, ["__iter__"],  false]
    - ["as2431031", asyncio.BaseEventLoop.__dict__.__contains__,     ["__aiter__"], false]
    - ["as2431032", asyncio.BaseEventLoop.__dict__.__contains__,     ["__anext__"], false]
    - ["as2431033", asyncio.TaskGroup.__dict__.__contains__,         ["__aiter__"], false]
    - ["as2431034", asyncio.TaskGroup.__dict__.__contains__,         ["__anext__"], false]
    - ["as2431035", asyncio.Timeout.__dict__.__contains__,           ["__aiter__"], false]
