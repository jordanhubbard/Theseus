spec: sysconfig_extra9
version: ">=3.9"
backend: python_module(sysconfig)

docs: https://docs.python.org/3/library/sysconfig.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sysconfig.html — Python sysconfig documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sysconfig.py"
    - "sysconfig_extra3.zspec.zsdl — covers __qualname__ for get_python_version/get_platform/get_scheme_names/get_config_vars/get_path/get_paths/get_path_names/is_python_build/get_default_scheme."
    - "sysconfig_extra4.zspec.zsdl — covers __module__ for get_config_var/parse_config_h/get_path/get_paths."
    - "sysconfig_extra8.zspec.zsdl — covers __module__ for get_scheme_names/get_path/get_path_names; __qualname__ for get_scheme_names/get_path_names; get_scheme_names()/get_path_names() return tuple."
  notes:
    - "This spec extends sysconfig.zspec.zsdl through sysconfig_extra8.zspec.zsdl."
    - "Focus: __qualname__ for get_config_var and parse_config_h (not in any prior sysconfig spec); __module__ for get_config_vars/get_paths/is_python_build in a table; module-level __name__ and __package__."
    - "sysconfig.get_config_var.__qualname__ == 'get_config_var' — verified at runtime."
    - "sysconfig.parse_config_h.__qualname__ == 'parse_config_h' — verified at runtime."
    - "sysconfig.get_config_vars.__module__ == 'sysconfig' — verified at runtime."
    - "sysconfig.get_paths.__module__ == 'sysconfig' — verified at runtime."
    - "sysconfig.is_python_build.__module__ == 'sysconfig' — verified at runtime."
    - "sysconfig.__name__ == 'sysconfig' — verified at runtime."
    - "sysconfig.__package__ == 'sysconfig' — sysconfig is a top-level module whose __package__ is 'sysconfig'; verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# get_config_var, parse_config_h — __qualname__ table
#
# sysconfig_extra3 covers __qualname__ for 9 functions but does not include
# get_config_var or parse_config_h. This table covers both in the extra9
# namespace as a complementary qualname axis.
# ---------------------------------------------------------------------------

table sysconfig_extra9.remaining_qualnames:
  description: "__qualname__ for get_config_var and parse_config_h"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [get_config_var, get_config_var.__qualname__.__eq__, ["get_config_var"], true]
    - [parse_config_h, parse_config_h.__qualname__.__eq__, ["parse_config_h"], true]

# ---------------------------------------------------------------------------
# get_config_vars, get_paths, is_python_build — __module__ table
#
# sysconfig_extra3 covers __module__ for get_python_version and get_platform.
# sysconfig_extra4 covers __module__ for get_config_var, parse_config_h,
# get_path, and get_paths. sysconfig_extra8 covers __module__ for
# get_scheme_names, get_path, and get_path_names. get_config_vars and
# is_python_build __module__ have not been checked in any prior spec.
# This table covers get_config_vars, get_paths (re-anchor), and is_python_build.
# ---------------------------------------------------------------------------

table sysconfig_extra9.remaining_modules:
  description: "__module__ for get_config_vars, get_paths, is_python_build"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [get_config_vars, get_config_vars.__module__.__eq__, ["sysconfig"], true]
    - [get_paths,       get_paths.__module__.__eq__,       ["sysconfig"], true]
    - [is_python_build, is_python_build.__module__.__eq__, ["sysconfig"], true]

# ---------------------------------------------------------------------------
# sysconfig.__name__ — standalone
#
# No prior sysconfig spec checks sysconfig.__name__ via __eq__ chain as a
# standalone invariant. This anchors it in the extra9 namespace.
# ---------------------------------------------------------------------------

invariant sysconfig_extra9.module.name:
  description: "sysconfig.__name__ == 'sysconfig'"
  category: module_attrs
  kind: python_call_eq
  function: __name__.__eq__
  args: ["sysconfig"]
  expected: true

# ---------------------------------------------------------------------------
# sysconfig.__package__ — standalone
#
# sysconfig is a top-level module whose __package__ is 'sysconfig' (not '').
# No prior sysconfig spec checks __package__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant sysconfig_extra9.module.package:
  description: "sysconfig.__package__ == 'sysconfig'"
  category: module_attrs
  kind: python_call_eq
  function: __package__.__eq__
  args: ["sysconfig"]
  expected: true

# ---------------------------------------------------------------------------
# sysconfig.get_config_var — __qualname__ standalone
#
# The table above covers get_config_var.__qualname__ in a row. This invariant
# re-anchors it as a standalone in the extra9 namespace for explicit
# single-axis coverage.
# ---------------------------------------------------------------------------

invariant sysconfig_extra9.get_config_var.qualname:
  description: "sysconfig.get_config_var.__qualname__ == 'get_config_var'"
  category: function_attrs
  kind: python_call_eq
  function: get_config_var.__qualname__.__eq__
  args: ["get_config_var"]
  expected: true
