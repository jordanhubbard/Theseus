spec: concurrent_futures_extra167
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__ checks for 'submit', 'map', and 'shutdown'; concurrent.futures.ThreadPoolExecutor.__dict__.__len__()==12; concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('map')==True. KEY FINDINGS: TPE.__dict__.__contains__('submit')==True (TPE overrides Executor.submit directly); TPE.__dict__.__contains__('map')==False (TPE does NOT override map — it inherits from Executor); TPE.__dict__.__contains__('shutdown')==True (TPE overrides shutdown for thread cleanup); TPE.__dict__.__len__()==12 (12 entries in TPE's class dict); PPE.__dict__.__contains__('map')==True (PPE DOES override map to support the chunksize parameter). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__dict__ keys (12 entries): '__module__', '__firstlineno__', 'BROKEN', '_counter', 'prepare_context', '__init__', 'submit', '_adjust_thread_count', '_initializer_failed', 'shutdown', '__static_attributes__', '__doc__'. Verified with Python 3.14.3."
    - "concurrent.futures.ProcessPoolExecutor.__dict__ keys (15 entries): '__module__', '__firstlineno__', '__init__', '_start_executor_manager_thread', '_adjust_process_count', '_launch_processes', '_spawn_process', 'submit', 'map', 'shutdown', '_force_shutdown', 'terminate_workers', 'kill_workers', '__static_attributes__', '__doc__'. PPE overrides 'map' (adding chunksize support) but TPE does not. Verified with Python 3.14.3."
    - "Executor (base class) __dict__ contains: 'submit', 'map', 'shutdown', '__enter__', '__exit__' — both submit and map are defined on Executor but TPE only overrides submit and shutdown; PPE overrides submit, map, and shutdown. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__ — submit and shutdown — extra167
#
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit')   == True
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('shutdown') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra167.cf_tpe_dict_submit_and_shutdown:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__ checks for 'submit' and 'shutdown' in cftpesubmit167 namespace — concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit')==True ('submit' is directly in TPE.__dict__; ThreadPoolExecutor.submit(fn, *args, **kwargs) schedules fn to be called with the given arguments on a thread pool thread and returns a Future; submit is overridden in TPE to handle thread-specific logic like adjusting the thread count and managing the work queue; the base Executor.submit is abstract/not callable, so each executor must override it); concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('shutdown')==True ('shutdown' is directly in TPE.__dict__; ThreadPoolExecutor.shutdown(wait=True, cancel_futures=False) signals all threads to stop after finishing pending work; TPE overrides shutdown to: join running threads (if wait=True), optionally cancel pending futures (if cancel_futures=True), and clean up the work queue); KEY: both 'submit' and 'shutdown' are TPE-specific overrides of Executor base class methods; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpesubmit167

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_has_submit,   concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["submit"],   true,  "TPE.__dict__.__contains__('submit') == True (TPE overrides Executor.submit for thread pool); verified with Python 3.14.3"]
    - [tpe_has_shutdown, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["shutdown"],  true,  "TPE.__dict__.__contains__('shutdown') == True (TPE overrides shutdown for thread cleanup); verified with Python 3.14.3"]
    - [tpe_has_submit2,  concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["submit"],   true,  "TPE.__dict__.__contains__('submit') == True (cross-check; submit is required override for Executor subclasses); verified with Python 3.14.3"]
    - [tpe_has_shutdown2, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__, ["shutdown"],  true,  "TPE.__dict__.__contains__('shutdown') == True (cross-check; thread-specific cleanup logic); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map') — extra167
#
# KEY FINDING: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map') == False
# TPE does NOT override map — it inherits from Executor
# ---------------------------------------------------------------------------

table concurrent_futures_extra167.cf_tpe_dict_map_not_overridden:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map') checks (False result) with context in cftpemap167 namespace — KEY FINDING: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map')==False (TPE does NOT override Executor.map — 'map' is NOT in TPE.__dict__; ThreadPoolExecutor inherits Executor.map without modification; Executor.map(fn, *iterables, timeout=None, chunksize=1) submits multiple calls and returns results in order; TPE does not need to override map because threading does not benefit from batching/chunking — each task is one thread regardless of chunksize; CONTRAST: ProcessPoolExecutor DOES override map to use chunksize for efficiency); concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit')==True (cross-check; submit IS in TPE.__dict__ — TPE overrides submit but NOT map); concurrent.futures.ThreadPoolExecutor.__dict__.__len__()==12 (cross-check; 12 entries in TPE's class dict — map is not among them); concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('shutdown')==True (cross-check; shutdown IS in TPE.__dict__); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpemap167

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_no_map,       concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["map"],      false,  "TPE.__dict__.__contains__('map') == False (TPE inherits Executor.map; no override needed for threads); verified with Python 3.14.3"]
    - [tpe_has_submit3,  concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["submit"],   true,   "TPE.__dict__.__contains__('submit') == True (contrast: submit IS overridden; map is NOT); verified with Python 3.14.3"]
    - [tpe_dict_len,     concurrent.futures.ThreadPoolExecutor.__dict__.__len__,       [],           12,     "TPE.__dict__.__len__() == 12 (12 entries; map is not among them); verified with Python 3.14.3"]
    - [tpe_has_shutdown3, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__, ["shutdown"], true,   "TPE.__dict__.__contains__('shutdown') == True (shutdown IS overridden; only submit+shutdown from Executor are overridden); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor.__dict__.__len__ — extra167
#
# concurrent.futures.ThreadPoolExecutor.__dict__.__len__() == 12
# ---------------------------------------------------------------------------

table concurrent_futures_extra167.cf_tpe_dict_len:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__len__ and class dict type checks in cftpedictlen167 namespace — concurrent.futures.ThreadPoolExecutor.__dict__.__len__()==12 (TPE's class dict has exactly 12 entries in Python 3.14.3: '__module__', '__firstlineno__', 'BROKEN', '_counter', 'prepare_context', '__init__', 'submit', '_adjust_thread_count', '_initializer_failed', 'shutdown', '__static_attributes__', '__doc__'; the 12 entries include 2 public API overrides ('submit', 'shutdown'), 1 class constant ('BROKEN'), 1 class-level state ('_counter'), 1 context method ('prepare_context'), and internal helpers); concurrent.futures.ThreadPoolExecutor.__dict__.__class__.__name__.__eq__('mappingproxy')==True (TPE's class dict is a mappingproxy, same as all Python class dicts; established pattern from extra166 with Future.__dict__); concurrent.futures.ThreadPoolExecutor.__dict__.__len__()==12 (cross-check; 12 is 9 fewer than Future.__dict__.__len__()==21 from extra166; TPE defines fewer methods than Future because many Executor methods like map and __enter__/__exit__ are inherited without override); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpedictlen167

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_dict_len2,        concurrent.futures.ThreadPoolExecutor.__dict__.__len__,                    [],              12,    "TPE.__dict__.__len__() == 12 (12 entries in TPE class dict; Python 3.14.3); verified with Python 3.14.3"]
    - [tpe_dict_cls_name_eq, concurrent.futures.ThreadPoolExecutor.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true,  "TPE.__dict__.__class__.__name__ == 'mappingproxy' (read-only class namespace view); verified with Python 3.14.3"]
    - [tpe_dict_len3,        concurrent.futures.ThreadPoolExecutor.__dict__.__len__,                    [],              12,    "TPE.__dict__.__len__() == 12 (cross-check; 9 fewer entries than Future.__dict__=21 from extra166); verified with Python 3.14.3"]
    - [tpe_no_map2,          concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,               ["map"],         false, "TPE.__dict__.__contains__('map') == False (cross-check; map not overridden; inherited from Executor); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('map') — extra167
#
# KEY FINDING: concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('map') == True
# PPE DOES override map (adding chunksize for inter-process batching efficiency)
# ---------------------------------------------------------------------------

table concurrent_futures_extra167.cf_ppe_dict_map_overridden:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('map') check (True result) with context in cfppemap167 namespace — KEY FINDING: concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('map')==True (PPE DOES override Executor.map — 'map' IS in PPE.__dict__; ProcessPoolExecutor.map(fn, *iterables, timeout=None, chunksize=1) overrides Executor.map specifically to support the chunksize parameter; when chunksize > 1, the iterable items are batched into chunks that are sent to worker processes together, reducing inter-process communication overhead; with threads (TPE), batching is irrelevant because threads share memory; with processes (PPE), sending data to workers via IPC is expensive, so batching amortizes that cost); concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('submit')==True (cross-check; PPE also overrides submit for process-pool-specific logic); concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('shutdown')==True (cross-check; PPE overrides shutdown for process cleanup — must terminate worker processes and join the manager thread); KEY CONTRAST: TPE.__dict__.__contains__('map')==False but PPE.__dict__.__contains__('map')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfppemap167

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_has_map,      concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,  ["map"],       true,  "PPE.__dict__.__contains__('map') == True (PPE overrides map to add chunksize batching for IPC); verified with Python 3.14.3"]
    - [ppe_has_submit,   concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,  ["submit"],    true,  "PPE.__dict__.__contains__('submit') == True (PPE overrides submit for process pool); verified with Python 3.14.3"]
    - [ppe_has_shutdown, concurrent.futures.ProcessPoolExecutor.__dict__.__contains__,  ["shutdown"],  true,  "PPE.__dict__.__contains__('shutdown') == True (PPE overrides shutdown to terminate workers); verified with Python 3.14.3"]
    - [tpe_no_map3,      concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,   ["map"],       false, "TPE.__dict__.__contains__('map') == False (KEY CONTRAST: TPE does NOT override map; PPE does); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra167
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra167.cf_TPE_dict_has_submit:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit') returns True — concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit')==True; ThreadPoolExecutor.submit(fn, *args, **kwargs) is directly defined in TPE's class dict; submit() is the core method for dispatching work to the thread pool: it creates a Future, puts the work item on the internal queue, adjusts the thread count if needed (creating new threads up to max_workers), and returns the Future; TPE.submit() is distinct from Executor.submit() (which raises NotImplementedError): TPE provides the concrete implementation; 'submit' is 1 of 12 entries in TPE.__dict__; compare: concurrent.futures.Future.__dict__.__contains__('result')==True (from extra166: Future.result() retrieves the value submitted via TPE.submit()); the submit/result pair form the fundamental producer-consumer contract between Executor and Future; 'submit'=6 chars; TPE.__dict__.__len__()==12 — 'submit' is 1 of 12; NEW in extra167: first standalone TPE.__dict__.__contains__('submit') invariant in cftpesubmit167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__
  args: ["submit"]
  expected: true

invariant concurrent_futures_extra167.cf_TPE_dict_no_map:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map') returns False — KEY FINDING: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map')==False; ThreadPoolExecutor does NOT override Executor.map — 'map' is NOT in TPE.__dict__; TPE inherits Executor.map which calls self.submit() internally; TPE has no reason to override map because thread-based parallelism does not benefit from batching (chunksize has no effect on ThreadPoolExecutor — threads share memory and have negligible dispatch overhead); CONTRAST: ProcessPoolExecutor.__dict__.__contains__('map')==True (PPE DOES override map to support chunksize batching, which reduces the expensive inter-process communication cost when iterating over large datasets); KEY ARCHITECTURAL INSIGHT: Executor defines map with a chunksize parameter but only PPE actually uses it; TPE ignores chunksize entirely — the Executor.map default works fine for threads; TPE.__dict__.__len__()==12 and 'map' is NOT among those 12 entries; NEW in extra167: first standalone TPE.__dict__.__contains__('map') invariant (False result) in cftpemap167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__
  args: ["map"]
  expected: false

invariant concurrent_futures_extra167.cf_TPE_dict_has_shutdown:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('shutdown') returns True — concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('shutdown')==True; ThreadPoolExecutor.shutdown(wait=True, cancel_futures=False) is directly defined in TPE's class dict; TPE.shutdown() performs thread-pool-specific cleanup: it sets a flag to prevent new submissions, optionally cancels pending futures (if cancel_futures=True, since Python 3.9), and optionally waits for all running threads to complete (if wait=True, the default); after shutdown(), submit() raises RuntimeError; TPE is typically used as a context manager ('with ThreadPoolExecutor() as executor:') which calls shutdown(wait=True) on __exit__; 'shutdown' is 1 of 12 entries in TPE.__dict__; compare: TPE.__dict__.__contains__('map')==False (map is NOT overridden; shutdown IS; the asymmetry reflects that thread cleanup needs process-specific logic while map does not); NEW in extra167: first standalone TPE.__dict__.__contains__('shutdown') invariant in cftpesubmit167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__
  args: ["shutdown"]
  expected: true

invariant concurrent_futures_extra167.cf_TPE_dict_len:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__len__() returns 12 — concurrent.futures.ThreadPoolExecutor.__dict__.__len__()==12 (12 entries in TPE's class dict as of Python 3.14.3 on macOS/Darwin 25.4.0); the 12 entries are: '__module__', '__firstlineno__', 'BROKEN', '_counter', 'prepare_context', '__init__', 'submit', '_adjust_thread_count', '_initializer_failed', 'shutdown', '__static_attributes__', '__doc__'; the 2 public API overrides ('submit', 'shutdown') are 2 of 12; 'BROKEN' is a class-level constant used to signal executor failure state; '_counter' is an itertools.count() instance used to generate unique worker thread names; 'prepare_context' is a hook for subclasses; '_adjust_thread_count' and '_initializer_failed' are private helper methods; compare: concurrent.futures.Future.__dict__.__len__()==21 (from extra166: 9 more entries than TPE=12; Future has more public API methods); compare: abc.ABCMeta.__dict__.__len__()==11 (from abc_extra164: 1 fewer than TPE=12; ABCMeta has fewer direct methods); KEY: TPE dict size(12) sits between ABCMeta(11) and Future(21); NEW in extra167: first standalone TPE.__dict__.__len__ invariant in cftpedictlen167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__dict__.__len__
  args: []
  expected: 12

invariant concurrent_futures_extra167.cf_PPE_dict_has_map:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('map') returns True — KEY FINDING: concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('map')==True; ProcessPoolExecutor overrides Executor.map to support the chunksize parameter efficiently; PPE.map(fn, *iterables, timeout=None, chunksize=1) breaks the iterable into chunks of chunksize items and sends each chunk to a worker process as a single work unit, reducing IPC overhead; with chunksize=1 (default), each item is sent individually — this can be expensive for large iterables with many small items; with larger chunksize values (e.g., chunksize=100), 100 items are pickled and sent together, reducing the number of IPC roundtrips; this optimization is process-specific because processes have expensive inter-process communication (pickling, pipes, or shared memory) while threads share memory directly; compare: concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map')==False (TPE does NOT override map because thread-based IPC is free — no serialization needed); NEW in extra167: first standalone PPE.__dict__.__contains__('map') invariant (True result) in cfppemap167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__dict__.__contains__
  args: ["map"]
  expected: true

invariant concurrent_futures_extra167.cf_TPE_dict_class_is_mappingproxy:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — concurrent.futures.ThreadPoolExecutor.__dict__.__class__.__name__=='mappingproxy' (len=12: 'mapping'=7+'proxy'=5=12); TPE's class dict is a mappingproxy, same as all Python class dicts; this is a cross-check of the universal Python invariant that every class's __dict__ attribute returns a types.MappingProxyType (read-only wrapper); established for Future (extra166), ABC (abc_extra164), ABCMeta (abc_extra164); now confirmed for ThreadPoolExecutor; the mappingproxy prevents direct mutation: TPE.__dict__['new_method'] = fn would raise TypeError; TPE.__dict__.__class__.__name__=='mappingproxy' == Future.__dict__.__class__.__name__=='mappingproxy' == abc.ABC.__dict__.__class__.__name__=='mappingproxy' — all class dicts share this property regardless of the class's purpose; 'mappingproxy'=12 chars; NEW in extra167: first standalone TPE.__dict__.__class__.__name__ invariant in cftpedictlen167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant concurrent_futures_extra167.cf_PPE_dict_has_submit:
  description: "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('submit') returns True — concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('submit')==True; ProcessPoolExecutor.submit(fn, *args, **kwargs) is directly defined in PPE's class dict; PPE.submit() handles process-specific work dispatch: it serializes the callable and arguments using pickle, sends them to a worker process via the process manager thread, and returns a Future; the serialization requirement is the fundamental difference between TPE.submit() (which can use any Python object directly) and PPE.submit() (which requires all arguments and return values to be picklable); PPE.submit() also handles starting the executor manager thread if it has not been started yet; compare: TPE.__dict__.__contains__('submit')==True (TPE also overrides submit — both executors must provide concrete submit() implementations); NEW in extra167: first standalone PPE.__dict__.__contains__('submit') invariant in cfppemap167 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__dict__.__contains__
  args: ["submit"]
  expected: true
