spec: threading_extra157
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.RLock __name__ 'RLock', __module__ 'threading', __class__.__name__ 'function' (RLock is a factory function not a class); threading.BoundedSemaphore __name__ 'BoundedSemaphore', __module__ 'threading', __bases__[0].__name__ 'Semaphore'; threading.Lock __name__ 'lock', __module__ '_thread' (Lock is a C type alias); threading.Lock.__class__.__name__ 'type' (Wave 285)."
    - "threading.RLock.__name__ == 'RLock' — threading.RLock is a Python factory function in Lib/threading.py that returns a re-entrant lock object; __name__ is 'RLock'. Verified with Python 3.14.3."
    - "threading.RLock.__module__ == 'threading' — RLock factory function is defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.RLock.__class__.__name__ == 'function' — RLock is a Python function (not a class); it is a factory that creates _RLock instances; __class__.__name__ is 'function'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' — BoundedSemaphore is a Python class in Lib/threading.py; its __name__ is 'BoundedSemaphore'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__module__ == 'threading' — BoundedSemaphore is defined in Lib/threading.py; __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore inherits from Semaphore (not object); it adds an upper bound check to prevent release() from being called more times than acquire(). Verified with Python 3.14.3."
    - "threading.Lock.__name__ == 'lock' — threading.Lock is an alias for the C extension type '_thread.lock'; its __name__ is lowercase 'lock'. Verified with Python 3.14.3."
    - "threading.Lock.__module__ == '_thread' — Lock is defined in the C extension module _thread (Modules/_threadmodule.c); __module__ is '_thread'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.RLock identity (factory function not a class)
#
# Wave 285 theme: threading.RLock class identity — RLock is a factory function.
#
# threading.RLock.__name__ == 'RLock'
# threading.RLock.__module__ == 'threading'
# threading.RLock.__class__.__name__ == 'function'
#
# threading.RLock is a Python factory function in Lib/threading.py that returns
# a re-entrant lock object. Unlike most threading primitives (Semaphore, Event,
# Condition, etc.) which are classes, RLock is a function — specifically it
# returns a _RLock() instance. Its __class__.__name__ is 'function', not 'type'.
# New to extra157.
# ---------------------------------------------------------------------------

table threading_extra157.rlock_identity:
  description: "threading.RLock: __name__ 'RLock', __module__ 'threading', __class__.__name__ 'function' (RLock is a factory function not a class); wave 285; new to extra157"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingrlockid157

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_name_eq,
       "RLock.__name__.__eq__",
       ["RLock"],
       true,
       "threading.RLock.__name__.__eq__('RLock') == True — threading.RLock is a Python factory function in Lib/threading.py that returns re-entrant lock objects; its __name__ is 'RLock'; str.__eq__('RLock') returns True; new to extra157"]
    - [rlock_module_eq_threading,
       "RLock.__module__.__eq__",
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — RLock is defined as a factory function in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra157"]
    - [rlock_class_eq_function,
       "RLock.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — threading.RLock is a Python factory function, not a class; it returns a _RLock instance; its __class__.__name__ is 'function' (not 'type'); str.__eq__('function') returns True; new to extra157"]
    - [rlock_code_co_name_eq,
       "RLock.__code__.co_name.__eq__",
       ["RLock"],
       true,
       "threading.RLock.__code__.co_name.__eq__('RLock') == True — RLock is a Python function with a code object; its co_name is 'RLock'; str.__eq__('RLock') returns True; new to extra157"]

# ---------------------------------------------------------------------------
# Table 2: threading.BoundedSemaphore identity and threading.Lock C type identity
#
# Wave 285 theme: threading.BoundedSemaphore inherits from Semaphore; threading.Lock
# is a C type alias with lowercase __name__ 'lock'.
#
# threading.BoundedSemaphore.__name__ == 'BoundedSemaphore'
# threading.BoundedSemaphore.__module__ == 'threading'
# threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'
# threading.Lock.__name__ == 'lock'
# threading.Lock.__module__ == '_thread'
#
# BoundedSemaphore is a Python class in Lib/threading.py that extends Semaphore
# with an upper bound: release() raises ValueError if the count exceeds the
# initial value. Lock is an alias for the C extension type _thread.lock defined
# in Modules/_threadmodule.c; its __name__ is the lowercase 'lock' (the C type
# name) and its __module__ is '_thread'. New to extra157.
# ---------------------------------------------------------------------------

table threading_extra157.bounded_semaphore_and_lock_identity:
  description: "threading.BoundedSemaphore: __name__ 'BoundedSemaphore', __module__ 'threading', __bases__[0] 'Semaphore'; threading.Lock: __name__ 'lock' (C type), __module__ '_thread'; wave 285; new to extra157"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingbslockid157

  columns: [id, function, args, expected, description]
  rows:
    - [bounded_semaphore_name_eq,
       "BoundedSemaphore.__name__.__eq__",
       ["BoundedSemaphore"],
       true,
       "threading.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') == True — BoundedSemaphore is a Python class in Lib/threading.py extending Semaphore with an upper bound on release calls; its __name__ is 'BoundedSemaphore'; str.__eq__('BoundedSemaphore') returns True; new to extra157"]
    - [bounded_semaphore_module_eq_threading,
       "BoundedSemaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.BoundedSemaphore.__module__.__eq__('threading') == True — BoundedSemaphore is defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra157"]
    - ["bounded_semaphore_bases_0_name_eq_Semaphore",
       "BoundedSemaphore.__bases__[0].__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') == True — BoundedSemaphore inherits from Semaphore (not from object); it adds an upper bound check to prevent over-release; __bases__[0].__name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra157"]
    - [lock_name_eq_lock,
       "Lock.__name__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — threading.Lock is an alias for the C extension type _thread.lock defined in Modules/_threadmodule.c; the C type name is lowercase 'lock'; str.__eq__('lock') returns True; new to extra157"]
    - [lock_module_eq__thread,
       "Lock.__module__.__eq__",
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — Lock is the C extension type defined in _thread (Modules/_threadmodule.c); its __module__ is '_thread' (the private C module); threading.Lock is just an alias for _thread.lock; str.__eq__('_thread') returns True; new to extra157"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra157
# ---------------------------------------------------------------------------

invariant threading_extra157.rlock_name_eq:
  description: "threading.RLock.__name__ == 'RLock' — RLock is a Python factory function not a class; wave 285; new to extra157"
  kind: python_call_eq
  function: RLock.__name__.__eq__
  args: ["RLock"]
  expected: true

invariant threading_extra157.rlock_module_threading:
  description: "threading.RLock.__module__ == 'threading' — RLock factory function defined in Lib/threading.py; wave 285; new to extra157"
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra157.rlock_class_function:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a factory function not a class; its __class__.__name__ is 'function' not 'type'; wave 285; new to extra157"
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra157.bounded_semaphore_name_eq:
  description: "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' — semaphore with upper bound; wave 285; new to extra157"
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant threading_extra157.bounded_semaphore_module_threading:
  description: "threading.BoundedSemaphore.__module__ == 'threading' — BoundedSemaphore defined in Lib/threading.py; wave 285; new to extra157"
  kind: python_call_eq
  function: BoundedSemaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra157.bounded_semaphore_bases_Semaphore:
  description: "threading.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' — BoundedSemaphore inherits from Semaphore not object; wave 285; new to extra157"
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true

invariant threading_extra157.lock_name_lock_lowercase:
  description: "threading.Lock.__name__ == 'lock' — Lock is a C type alias; C type name is lowercase 'lock'; wave 285; new to extra157"
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra157.lock_module__thread:
  description: "threading.Lock.__module__ == '_thread' — Lock is defined in the C extension _thread module; wave 285; new to extra157"
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true
