spec: threading_extra2686
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 626 theme: __and__, __or__, and __xor__ dict-presence checks (bitwise AND, OR, XOR operators)."
    - "threading.Thread is a runnable object; it does not define bitwise operator protocols."
    - "threading.Lock (accessed as threading.Lock, actual type is _thread.lock) is a synchronization primitive; it defines acquire/release but not __and__, __or__, or __xor__."
    - "threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore are synchronization primitives; none define __and__, __or__, or __xor__."
    - "threading.Timer is a Thread subclass for deferred execution; it defines none of these bitwise protocols."
    - "threading.Barrier is a synchronization barrier; it does not define __and__, __or__, or __xor__."
    - "threading.local is a thread-local storage object; it does not define bitwise operator protocols."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __and__ dict-presence — absent from all threading synchronization types
# ---------------------------------------------------------------------------

table threading_extra2686.and_protocol:
  description: "__and__ is absent from all threading type __dict__s — synchronization primitives do not implement bitwise AND"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2686

  columns: [id, function, args, expected]
  rows:
    - ["th2686001", "threading.Thread.__dict__.__contains__",           ["__and__"], false]
    - ["th2686002", "threading.Lock.__dict__.__contains__",             ["__and__"], false]
    - ["th2686003", "threading.Event.__dict__.__contains__",            ["__and__"], false]
    - ["th2686004", "threading.Condition.__dict__.__contains__",        ["__and__"], false]
    - ["th2686005", "threading.Semaphore.__dict__.__contains__",        ["__and__"], false]
    - ["th2686006", "threading.BoundedSemaphore.__dict__.__contains__", ["__and__"], false]
    - ["th2686007", "threading.Timer.__dict__.__contains__",            ["__and__"], false]
    - ["th2686008", "threading.Barrier.__dict__.__contains__",          ["__and__"], false]
    - ["th2686009", "threading.local.__dict__.__contains__",            ["__and__"], false]

