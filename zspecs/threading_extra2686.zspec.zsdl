# ---------------------------------------------------------------------------
# Combined per-type view — Thread, Barrier, and Timer vs. all three protocols
# ---------------------------------------------------------------------------

table threading_extra2686.thread_barrier_combined:
  description: "threading.Thread, threading.Barrier, and threading.Timer define none of __and__, __or__, __xor__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2686

  columns: [id, function, args, expected]
  rows:
    - ["th2686028", "threading.Thread.__dict__.__contains__",  ["__and__"],  false]
    - ["th2686029", "threading.Thread.__dict__.__contains__",  ["__or__"],   false]
    - ["th2686030", "threading.Thread.__dict__.__contains__",  ["__xor__"],  false]
    - ["th2686031", "threading.Barrier.__dict__.__contains__", ["__and__"],  false]
    - ["th2686032", "threading.Barrier.__dict__.__contains__", ["__or__"],   false]
    - ["th2686033", "threading.Barrier.__dict__.__contains__", ["__xor__"],  false]
    - ["th2686034", "threading.Timer.__dict__.__contains__",   ["__and__"],  false]
    - ["th2686035", "threading.Timer.__dict__.__contains__",   ["__or__"],   false]
    - ["th2686036", "threading.Timer.__dict__.__contains__",   ["__xor__"],  false]
