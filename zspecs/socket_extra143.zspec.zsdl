spec: socket_extra143
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra142.zspec.zsdl — covers socket.AF_INET/AF_INET6/SOCK_STREAM/SOCK_DGRAM enum member .name values and lengths / AddressFamily/SocketKind class __name__ values and lengths and __bases__[0].__name__ == 'IntEnum' / socket.error/__name__/__len__()==7 / socket.timeout/__name__/__len__()==12 / timeout/__bases__[0].__name__=='OSError' (table + invariants)."
    - "socket_extra141.zspec.zsdl — covers socket.socket/__doc__/__len__()==58 / gethostname/__doc__/__len__()==54 / gethostbyname/__doc__/__len__()==106 / getaddrinfo/__doc__/__len__()==658 / setdefaulttimeout/__doc__/__len__()==224 / getdefaulttimeout/__doc__/__len__()==232 / __doc__.__class__.__name__ checks."
    - "socket_extra140.zspec.zsdl — covers socket.socket method_descriptor __doc__ lengths (recv/send/bind/connect/listen/setsockopt/getsockopt/sendall/recvfrom/accept) / socket.socket method __qualname__ lengths."
    - "socket_extra139.zspec.zsdl — covers socket.socket.__eq__/__hash__ qualnames / socket.socket.family and type as property descriptors / socket.socket class __name__/__module__/__mro__ / socket.getfqdn and create_connection __doc__ lengths."
    - "socket_extra138.zspec.zsdl — covers socket.socket.__doc__ identity / __spec__ and __loader__ attribute identity / herror and gaierror exception class identity / getfqdn and create_connection qualnames."
    - "socket_extra99.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__.__len__() / SocketIO class identity."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values."
    - "socket_extra97.zspec.zsdl — covers socket.socket.send/sendall/fileno __qualname__.__eq__ / socket.socket.__init__/accept/makefile/close __class__.__name__=='function'."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout __class__.__name__=='builtin_function_or_method'."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra142."
    - "Wave 301 theme: socket.socket method __qualname__ string equality for connect/bind/listen/accept/recv / __qualname__ length grouping (bind/recv=11, listen/accept=13, connect=14) / accept.__class__.__name__=='function' (Python-level) vs connect/bind/listen/send/recv __class__.__name__=='method_descriptor' (C-level)."
    - "socket.socket.connect.__qualname__ == 'socket.connect' (len 14). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__qualname__ == 'socket.bind' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__qualname__ == 'socket.listen' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__qualname__ == 'socket.accept' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__ == 'socket.recv' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.connect.__class__.__name__ == 'method_descriptor' (C-level). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.bind.__class__.__name__ == 'method_descriptor' (C-level). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__class__.__name__ == 'method_descriptor' (C-level). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__class__.__name__ == 'function' (Python-level in Lib/socket.py). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__class__.__name__ == 'method_descriptor' (C-level). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All socket.socket method qualnames follow the 'socket.<method>' pattern with the 7-char 'socket.' prefix (not 'socket.socket.'). This is because the C-level _socket.socket class (from socketmodule.c) uses the shorter prefix; the Python-level socket.socket class inherits these descriptors. The qualname does NOT include the class name 'socket.socket' — only the module's underlying 'socket' type name."
    - "Note: socket.socket.accept is a Python-level function (__class__.__name__ == 'function', __module__ == 'socket') defined in Lib/socket.py. It wraps the C-level accept() call to return a (conn, addr) tuple where conn is a socket.socket instance (not a raw _socket.socket). All other methods examined (connect/bind/listen/send/recv) are C-level method_descriptors from socketmodule.c."
    - "Note: The qualname length groups are: bind/recv (len 11 = 7 + 4), listen/accept (len 13 = 7 + 6), connect (len 14 = 7 + 7). extra98 anchors these lengths; this spec anchors the equality strings for connect/bind/listen/accept/recv (send was anchored in extra97)."
    - "Note: bind, recv, and send all have qualname length 11 (4-char method names), but their qualnames are NOT equal to each other: 'socket.bind' vs 'socket.recv' vs 'socket.send'. Similarly, listen (len 13) and accept (len 13) have the same length but different strings: 'socket.listen' vs 'socket.accept'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.connect.__qualname__.__eq__('socket.connect')
# socket.socket.bind.__qualname__.__eq__('socket.bind')
# socket.socket.listen.__qualname__.__eq__('socket.listen')
# socket.socket.accept.__qualname__.__eq__('socket.accept')
# socket.socket.recv.__qualname__.__eq__('socket.recv')
#
# Wave 301 theme: socket.socket method __qualname__ string equality.
#
# All five socket.socket methods follow the 'socket.<method>' qualname pattern
# with the 7-char 'socket.' prefix. extra98 anchors qualname lengths; extra97
# anchors send/sendall/fileno equality; no prior socket spec anchors
# connect/bind/listen/accept/recv qualname equality strings as a table under
# sockqn143. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra143.socket_method_qualname_equality:
  description: "socket.socket.connect/__qualname__.__eq__('socket.connect')==True / bind/__qualname__.__eq__('socket.bind')==True / listen/__qualname__.__eq__('socket.listen')==True / accept/__qualname__.__eq__('socket.accept')==True / recv/__qualname__.__eq__('socket.recv')==True — all five follow 'socket.<method>' pattern (7-char 'socket.' prefix); extra98 anchors lengths; extra97 anchors send; first sockqn143 anchor for connect/bind/listen/accept/recv equality strings"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: sockqn143

  columns: [id, function, args, expected, description]
  rows:
    - [connect_qualname_eq, socket.connect.__qualname__.__eq__, ["socket.connect"], true, "socket.socket.connect.__qualname__ == 'socket.connect' (14 chars = 7 + 7; C-level method_descriptor)"]
    - [bind_qualname_eq,    socket.bind.__qualname__.__eq__,    ["socket.bind"],    true, "socket.socket.bind.__qualname__ == 'socket.bind' (11 chars = 7 + 4; C-level method_descriptor)"]
    - [listen_qualname_eq,  socket.listen.__qualname__.__eq__,  ["socket.listen"],  true, "socket.socket.listen.__qualname__ == 'socket.listen' (13 chars = 7 + 6; C-level method_descriptor)"]
    - [accept_qualname_eq,  socket.accept.__qualname__.__eq__,  ["socket.accept"],  true, "socket.socket.accept.__qualname__ == 'socket.accept' (13 chars = 7 + 6; Python-level function in Lib/socket.py)"]
    - [recv_qualname_eq,    socket.recv.__qualname__.__eq__,    ["socket.recv"],    true, "socket.socket.recv.__qualname__ == 'socket.recv' (11 chars = 7 + 4; C-level method_descriptor)"]

# ---------------------------------------------------------------------------
# socket.socket.connect.__qualname__.__len__()==14
# socket.socket.listen.__qualname__.__len__()==13
# socket.socket.accept.__qualname__.__len__()==13
# socket.socket.bind.__qualname__.__len__()==11
# socket.socket.recv.__qualname__.__len__()==11
#
# Wave 301 theme: socket.socket method __qualname__ length grouping.
#
# Three length groups: bind/recv tie at 11 (4-char methods), listen/accept tie at
# 13 (6-char methods), connect is longest at 14 (7-char method). extra98 anchors
# these lengths; this table presents them grouped by equality to show the grouping
# structure under sockqn143. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra143.socket_method_qualname_length_groups:
  description: "socket.socket.connect/__qualname__/__len__()==14 / listen/__qualname__/__len__()==13 / accept/__qualname__/__len__()==13 / bind/__qualname__/__len__()==11 / recv/__qualname__/__len__()==11 — three length groups: bind/recv tie at 11 (4-char names), listen/accept tie at 13 (6-char names), connect is longest at 14 (7-char name); extra98 anchors these lengths; this table shows the grouping structure; first sockqn143 anchor for grouped length comparison"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: sockqn143

  columns: [id, function, args, expected, description]
  rows:
    - [connect_qualname_len, socket.connect.__qualname__.__len__, [], 14, "socket.socket.connect.__qualname__.__len__() is 14 ('socket.connect' = 7 + 7; longest of this group)"]
    - [listen_qualname_len,  socket.listen.__qualname__.__len__,  [], 13, "socket.socket.listen.__qualname__.__len__() is 13 ('socket.listen' = 7 + 6)"]
    - [accept_qualname_len,  socket.accept.__qualname__.__len__,  [], 13, "socket.socket.accept.__qualname__.__len__() is 13 ('socket.accept' = 7 + 6; ties with listen)"]
    - [bind_qualname_len,    socket.bind.__qualname__.__len__,    [], 11, "socket.socket.bind.__qualname__.__len__() is 11 ('socket.bind' = 7 + 4)"]
    - [recv_qualname_len,    socket.recv.__qualname__.__len__,    [], 11, "socket.socket.recv.__qualname__.__len__() is 11 ('socket.recv' = 7 + 4; ties with bind)"]

# ---------------------------------------------------------------------------
# socket.socket.accept.__class__.__name__.__eq__('function')
# socket.socket.connect.__class__.__name__.__eq__('method_descriptor')
# socket.socket.bind.__class__.__name__.__eq__('method_descriptor')
# socket.socket.listen.__class__.__name__.__eq__('method_descriptor')
# socket.socket.recv.__class__.__name__.__eq__('method_descriptor')
#
# Wave 301 theme: accept is Python-level (function) while connect/bind/listen/recv
# are C-level (method_descriptor).
#
# socket.socket.accept is the only Python-level method among the five examined
# here: it is defined in Lib/socket.py as a wrapper that upgrades the C-level
# accept() return to a socket.socket instance. extra97 anchors accept.__class__.__name__
# == 'function'; this table cross-checks it alongside the C-level methods under
# sockqn143. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra143.socket_method_class_names:
  description: "socket.socket.accept/__class__.__name__.__eq__('function')==True / connect/__class__.__name__.__eq__('method_descriptor')==True / bind/__class__.__name__.__eq__('method_descriptor')==True / listen/__class__.__name__.__eq__('method_descriptor')==True / recv/__class__.__name__.__eq__('method_descriptor')==True — accept is Python-level (function in Lib/socket.py); connect/bind/listen/recv are C-level (method_descriptor from socketmodule.c); extra97 anchors accept class name; first sockqn143 anchor for connect/bind/listen/recv class names"
  kind: python_call_eq
  category: identity
  id_prefix: sockqn143

  columns: [id, function, args, expected, description]
  rows:
    - [accept_class_function,  socket.accept.__class__.__name__.__eq__,  ["function"],         true, "socket.socket.accept.__class__.__name__ == 'function' (Python-level; wraps C accept() returning socket.socket)"]
    - [connect_class_method,   socket.connect.__class__.__name__.__eq__, ["method_descriptor"], true, "socket.socket.connect.__class__.__name__ == 'method_descriptor' (C-level from socketmodule.c)"]
    - [bind_class_method,      socket.bind.__class__.__name__.__eq__,    ["method_descriptor"], true, "socket.socket.bind.__class__.__name__ == 'method_descriptor' (C-level from socketmodule.c)"]
    - [listen_class_method,    socket.listen.__class__.__name__.__eq__,  ["method_descriptor"], true, "socket.socket.listen.__class__.__name__ == 'method_descriptor' (C-level from socketmodule.c)"]
    - [recv_class_method,      socket.recv.__class__.__name__.__eq__,    ["method_descriptor"], true, "socket.socket.recv.__class__.__name__ == 'method_descriptor' (C-level from socketmodule.c)"]

# ---------------------------------------------------------------------------
# socket.socket.connect.__qualname__.__eq__('socket.connect') — standalone
#
# socket.socket.connect.__qualname__ is 'socket.connect' (14 chars). The qualname
# prefix is 'socket.' (7 chars, using the underlying C type name) rather than
# 'socket.socket.' (14 chars, the Python class name). connect is the longest of
# the five method qualnames examined in this spec because 'connect' (7 chars) is
# the longest method name in the group. extra98 anchors connect.__qualname__.__len__();
# no prior socket spec anchors connect.__qualname__ == 'socket.connect' as a
# standalone under sockqn143. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra143.connect_qualname_socket_connect:
  description: "socket.socket.connect.__qualname__.__eq__('socket.connect') == True — 'socket.connect' (14 chars = 7-char 'socket.' prefix + 7-char 'connect'); longest qualname in this spec's group; prefix uses C type name ('socket') not Python class name ('socket.socket'); extra98 anchors the length; first standalone under sockqn143"
  category: qualname_identity
  kind: python_call_eq
  function: socket.connect.__qualname__.__eq__
  args: ["socket.connect"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.listen.__qualname__.__eq__('socket.listen') — standalone
#
# socket.socket.listen.__qualname__ is 'socket.listen' (13 chars). At 13 chars it
# ties with socket.socket.accept.__qualname__ ('socket.accept', also 13 chars) —
# both 'listen' and 'accept' are 6-char method names. listen is a C-level
# method_descriptor that calls the C listen() syscall, setting the maximum number
# of connections the OS will queue before rejecting new ones. No prior socket spec
# anchors listen.__qualname__ == 'socket.listen' as a standalone under sockqn143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra143.listen_qualname_socket_listen:
  description: "socket.socket.listen.__qualname__.__eq__('socket.listen') == True — 'socket.listen' (13 chars = 7-char prefix + 6-char 'listen'); ties with accept (also 13 chars, also 6-char name); C-level method_descriptor calling C listen() syscall; no prior socket spec anchors this as a standalone; first standalone under sockqn143"
  category: qualname_identity
  kind: python_call_eq
  function: socket.listen.__qualname__.__eq__
  args: ["socket.listen"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.accept.__qualname__.__eq__('socket.accept') — standalone
#
# socket.socket.accept.__qualname__ is 'socket.accept' (13 chars). Despite being
# a Python-level function (not a C method_descriptor), its qualname follows the
# same 'socket.<method>' pattern as the C-level methods. This is because socket.accept
# is defined as a method of the socket.socket class in Lib/socket.py, and Python's
# qualname mechanism for class methods uses the enclosing class name plus the method
# name — but the class here is socket, giving 'socket.accept'. No prior socket spec
# anchors accept.__qualname__ == 'socket.accept' as a standalone under sockqn143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra143.accept_qualname_socket_accept:
  description: "socket.socket.accept.__qualname__.__eq__('socket.accept') == True — 'socket.accept' (13 chars = 7-char prefix + 6-char 'accept'); Python-level function but qualname follows same 'socket.<method>' pattern as C methods; ties with listen (also 13 chars); no prior socket spec anchors this as a standalone; first standalone under sockqn143"
  category: qualname_identity
  kind: python_call_eq
  function: socket.accept.__qualname__.__eq__
  args: ["socket.accept"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.bind.__qualname__.__eq__('socket.bind') — standalone
#
# socket.socket.bind.__qualname__ is 'socket.bind' (11 chars). At 11 chars it
# ties with recv ('socket.recv', also 11 chars) and send ('socket.send', also
# 11 chars, anchored in extra97) because 'bind', 'recv', and 'send' are all 4-char
# method names. bind is the method that associates a socket with a local address
# and port. Despite the same qualname length, 'socket.bind' != 'socket.recv'.
# No prior socket spec anchors bind.__qualname__ == 'socket.bind' as a standalone
# under sockqn143. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra143.bind_qualname_socket_bind:
  description: "socket.socket.bind.__qualname__.__eq__('socket.bind') == True — 'socket.bind' (11 chars = 7-char prefix + 4-char 'bind'); ties with recv and send in qualname length (all 11 chars, all 4-char method names); 'socket.bind' != 'socket.recv' despite equal lengths; no prior socket spec anchors this as a standalone; first standalone under sockqn143"
  category: qualname_identity
  kind: python_call_eq
  function: socket.bind.__qualname__.__eq__
  args: ["socket.bind"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.recv.__qualname__.__eq__('socket.recv') — standalone
#
# socket.socket.recv.__qualname__ is 'socket.recv' (11 chars). recv is the
# fundamental method for receiving data from a connected socket. Its qualname
# 'socket.recv' (11 chars = 7 + 4) ties in length with bind ('socket.bind', 11)
# and send ('socket.send', 11, anchored in extra97). Despite the same length as
# bind, 'socket.recv' is distinct from 'socket.bind'. No prior socket spec anchors
# recv.__qualname__ == 'socket.recv' as a standalone under sockqn143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra143.recv_qualname_socket_recv:
  description: "socket.socket.recv.__qualname__.__eq__('socket.recv') == True — 'socket.recv' (11 chars = 7-char prefix + 4-char 'recv'); ties in length with bind (11) and send (11, extra97); 'socket.recv' != 'socket.bind' despite equal length; C-level method_descriptor for receiving data; no prior socket spec anchors this as a standalone; first standalone under sockqn143"
  category: qualname_identity
  kind: python_call_eq
  function: socket.recv.__qualname__.__eq__
  args: ["socket.recv"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.accept.__class__.__name__.__eq__('function') — standalone
#
# socket.socket.accept.__class__.__name__ == 'function'. accept is the only Python-
# level method among the five examined in this spec. It is defined in Lib/socket.py
# as a wrapper around the C-level accept() that upgrades the raw _socket.socket
# return value to a full socket.socket instance with the makefile() method available.
# extra97 anchors accept.__class__.__name__ == 'function'; this standalone cross-checks
# it alongside the new qualname theme under sockqn143.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra143.accept_class_function:
  description: "socket.socket.accept.__class__.__name__.__eq__('function') == True — Python-level function in Lib/socket.py; wraps C-level accept() to return socket.socket instances; the only Python-level method among connect/bind/listen/accept/recv; extra97 anchors this; cross-check standalone under sockqn143"
  category: identity
  kind: python_call_eq
  function: socket.accept.__class__.__name__.__eq__
  args: ["function"]
  expected: true
