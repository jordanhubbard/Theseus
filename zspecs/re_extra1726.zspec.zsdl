spec: re_extra1726
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "re.Pattern does not define ordering operators in its own __dict__."
    - "re.Pattern.__dict__.__contains__('__lt__') is False — Pattern objects are not orderable."
    - "re.Pattern.__dict__.__contains__('__le__') is False."
    - "re.Pattern.__dict__.__contains__('__gt__') is False."
    - "re.Pattern.__dict__.__contains__('__ge__') is False."
    - "re.Pattern.__dict__.__contains__('__eq__') is True — Pattern supports equality comparison."
    - "re.Pattern.__dict__.__contains__('__hash__') is True — Pattern objects are hashable."
    - "re.Match.__dict__.__contains__('__lt__') is False — Match objects are not orderable."
    - "re.Match.__dict__.__contains__('__eq__') is False — Match does not define __eq__ in its own dict."
    - "re.Match.__dict__.__contains__('__hash__') is False — Match objects are not hashable."
    - "re.error.__dict__.__contains__('__lt__') is False — error is an exception class with no ordering."
    - "re.error.__dict__.__contains__('__eq__') is False — error inherits equality from BaseException."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table re_extra1726.comparison_protocol:
  description: "re types comparison protocol dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1726

  columns: [id, function, args, expected]
  rows:
    - ["re1726001", "re.Pattern.__dict__.__contains__", ["__lt__"], false]
    - ["re1726002", "re.Pattern.__dict__.__contains__", ["__le__"], false]
    - ["re1726003", "re.Pattern.__dict__.__contains__", ["__gt__"], false]
    - ["re1726004", "re.Pattern.__dict__.__contains__", ["__ge__"], false]
    - ["re1726005", "re.Pattern.__dict__.__contains__", ["__ne__"], false]
    - ["re1726006", "re.Match.__dict__.__contains__",   ["__lt__"], false]
    - ["re1726007", "re.Match.__dict__.__contains__",   ["__le__"], false]
    - ["re1726008", "re.Match.__dict__.__contains__",   ["__gt__"], false]
    - ["re1726009", "re.Match.__dict__.__contains__",   ["__ge__"], false]
    - ["re1726010", "re.Match.__dict__.__contains__",   ["__ne__"], false]

table re_extra1726.eq_hash_protocol:
  description: "re types __eq__ and __hash__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1726

  columns: [id, function, args, expected]
  rows:
    - ["re1726011", "re.Pattern.__dict__.__contains__", ["__eq__"],   true ]
    - ["re1726012", "re.Pattern.__dict__.__contains__", ["__hash__"], true ]
    - ["re1726013", "re.Match.__dict__.__contains__",   ["__eq__"],   false]
    - ["re1726014", "re.Match.__dict__.__contains__",   ["__hash__"], false]

table re_extra1726.error_comparison_protocol:
  description: "re.error exception class comparison protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1726

  columns: [id, function, args, expected]
  rows:
    - ["re1726015", "re.error.__dict__.__contains__", ["__lt__"], false]
    - ["re1726016", "re.error.__dict__.__contains__", ["__le__"], false]
    - ["re1726017", "re.error.__dict__.__contains__", ["__gt__"], false]
    - ["re1726018", "re.error.__dict__.__contains__", ["__ge__"], false]
    - ["re1726019", "re.error.__dict__.__contains__", ["__ne__"], false]
    - ["re1726020", "re.error.__dict__.__contains__", ["__eq__"], false]
    - ["re1726021", "re.error.__dict__.__contains__", ["__hash__"], false]
