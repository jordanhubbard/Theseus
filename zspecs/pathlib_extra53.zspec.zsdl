spec: pathlib_extra53
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra52.zspec.zsdl — covers Path.walk.__qualname__.__len__()==9; PurePath.__truediv__.__qualname__.__len__()==20; Path.from_uri.__qualname__.__len__()==13."
    - "pathlib_extra50.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__len__()."
    - "pathlib_extra37.zspec.zsdl — covers Path.__dict__.__class__.__name__.__len__()==13; PurePath.__dict__.__class__.__name__.__len__()==13."
  notes:
    - "This spec extends pathlib_extra52.zspec.zsdl."
    - "Prior specs collectively covered: all six pathlib class __qualname__.__len__() and __qualname__.__eq__() (pathlib_extra50); all major PurePath and Path method __qualname__.__len__(); Path.__dict__.__class__.__name__.__len__() and PurePath.__dict__.__class__.__name__.__len__() (pathlib_extra37). NO prior pathlib spec covers Path.__class__.__name__.__eq__('type') or any of the six class __class__.__name__.__len__() length anchors. NO prior pathlib spec covers Path.cwd.__class__.__name__.__eq__('method') or Path.home.__class__.__name__.__eq__('method')."
    - "This spec covers: pathlib.Path.__class__.__name__.__eq__('type') (NOVEL — all six pathlib classes use 'type' as metaclass; no prior pathlib spec checks any class's __class__.__name__; novel equality anchor in pathlib_extra53 namespace); pathlib.Path.__class__.__name__.__len__()==4 (NOVEL — 'type' has 4 characters; no prior pathlib spec checks __class__.__name__.__len__() for any pathlib class; novel length anchor); pathlib.PurePath.__name__.__len__()==8 (NOVEL — pathlib_extra50 covers __qualname__.__len__(); no prior pathlib spec covers PurePath.__name__.__len__()); pathlib.Path.cwd.__class__.__name__.__eq__('method') (NOVEL — Path.cwd is a classmethod accessed as an unbound method descriptor; its __class__.__name__ is 'method'; no prior pathlib spec checks Path.cwd.__class__.__name__; novel)."
    - "pathlib.Path.__class__.__name__ == 'type'. Path is a regular Python class (not an abstract base class), so its metaclass is the standard 'type'. All six pathlib classes (Path, PurePath, PurePosixPath, PureWindowsPath, PosixPath, WindowsPath) return 'type'. 'type' has 4 characters. No prior pathlib spec checks any class's __class__.__name__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.cwd.__class__.__name__ == 'method'. When accessed as a class attribute, Path.cwd is a bound method wrapper. Its __class__.__name__ is 'method'. Same for Path.home. No prior pathlib spec checks Path.cwd.__class__.__name__ or Path.home.__class__.__name__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__name__.__len__() == 8. 'PurePath' has 8 characters. pathlib_extra50 covers PurePath.__qualname__.__len__()==8 (same value since __qualname__==__name__ for top-level classes); but no prior pathlib spec checks PurePath.__name__.__len__() explicitly via the __name__ path. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class __class__.__name__ equality
#
# All six pathlib classes are regular Python classes with the standard 'type'
# metaclass. Their __class__.__name__ is therefore 'type':
#
#   Path.__class__.__name__            == 'type'
#   PurePath.__class__.__name__        == 'type'
#   PurePosixPath.__class__.__name__   == 'type'
#   PureWindowsPath.__class__.__name__ == 'type'
#   PosixPath.__class__.__name__       == 'type'
#   WindowsPath.__class__.__name__     == 'type'
#
# No prior pathlib spec checks __class__.__name__ for any pathlib class.
# All six equality anchors are novel in the pathlib_extra53 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra53.class_metaclass_name_eq:
  description: "pathlib class __class__.__name__.__eq__('type') for Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath — all are regular Python classes with 'type' metaclass; no prior pathlib spec checks __class__.__name__ for any pathlib class; all six novel equality anchors in pathlib_extra53 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: plcmn53

  columns: [id, function, args, expected]
  rows:
    - [Path_class_name,            Path.__class__.__name__.__eq__,            ["type"], true]
    - [PurePath_class_name,        PurePath.__class__.__name__.__eq__,        ["type"], true]
    - [PurePosixPath_class_name,   PurePosixPath.__class__.__name__.__eq__,   ["type"], true]
    - [PureWindowsPath_class_name, PureWindowsPath.__class__.__name__.__eq__, ["type"], true]
    - [PosixPath_class_name,       PosixPath.__class__.__name__.__eq__,       ["type"], true]
    - [WindowsPath_class_name,     WindowsPath.__class__.__name__.__eq__,     ["type"], true]

# ---------------------------------------------------------------------------
# pathlib class __class__.__name__ length
#
# Since all six classes have __class__.__name__ == 'type', they all have
# the same length of 4:
#
#   Path.__class__.__name__.__len__()            == 4
#   PurePath.__class__.__name__.__len__()        == 4
#   PurePosixPath.__class__.__name__.__len__()   == 4
#   PureWindowsPath.__class__.__name__.__len__() == 4
#   PosixPath.__class__.__name__.__len__()       == 4
#   WindowsPath.__class__.__name__.__len__()     == 4
#
# Complementary length anchors to the equality checks above.
# All six are novel in the pathlib_extra53 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra53.class_metaclass_name_len:
  description: "pathlib class __class__.__name__.__len__()==4 for Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath — 'type' has 4 characters; complementary length anchors to the equality checks above; no prior pathlib spec checks __class__.__name__.__len__() for any class; all six novel length anchors in pathlib_extra53 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: plcmnl53

  columns: [id, function, args, expected]
  rows:
    - [Path_class_name_len,            Path.__class__.__name__.__len__,            [], 4]
    - [PurePath_class_name_len,        PurePath.__class__.__name__.__len__,        [], 4]
    - [PurePosixPath_class_name_len,   PurePosixPath.__class__.__name__.__len__,   [], 4]
    - [PureWindowsPath_class_name_len, PureWindowsPath.__class__.__name__.__len__, [], 4]
    - [PosixPath_class_name_len,       PosixPath.__class__.__name__.__len__,       [], 4]
    - [WindowsPath_class_name_len,     WindowsPath.__class__.__name__.__len__,     [], 4]

# ---------------------------------------------------------------------------
# pathlib.Path.cwd and Path.home __class__.__name__
#
# When accessed as class attributes (not called), Path.cwd and Path.home
# are bound method objects. Their __class__.__name__ is 'method':
#
#   Path.cwd.__class__.__name__  == 'method'
#   Path.home.__class__.__name__ == 'method'
#
# pathlib_extra50 covers Path.cwd.__qualname__.__len__()==8 and
# Path.home.__qualname__.__len__()==9. No prior pathlib spec checks
# Path.cwd.__class__.__name__ or Path.home.__class__.__name__.
# Both equality anchors are novel in the pathlib_extra53 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra53.Path_cwd_class_name_eq:
  description: "pathlib.Path.cwd.__class__.__name__ == 'method' — when accessed as a class attribute, Path.cwd is a bound method; its __class__.__name__ is 'method'; no prior pathlib spec checks Path.cwd.__class__.__name__; novel equality anchor in pathlib_extra53 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: Path.cwd.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant pathlib_extra53.Path_home_class_name_eq:
  description: "pathlib.Path.home.__class__.__name__ == 'method' — when accessed as a class attribute, Path.home is a bound method; its __class__.__name__ is 'method'; no prior pathlib spec checks Path.home.__class__.__name__; novel equality anchor in pathlib_extra53 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: Path.home.__class__.__name__.__eq__
  args: ["method"]
  expected: true
