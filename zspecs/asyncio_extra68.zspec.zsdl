spec: asyncio_extra68
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python function __kwdefaults__ documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra67.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__()==13, Task/Future __module__.__len__(), Queue/Lock method __qualname__.__len__() tables, InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__()==95, class __dict__.__class__.__name__/__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), Queue/Lock/Event/Semaphore/Condition method __name__.__len__() tables, Queue/Lock method qualname string equality, asyncio class __module__ string equality (extra52), Queue/Lock __doc__/__class__/__name__=='str' (extra50), asyncio.__all__.__class__.__name__=='list' (extra51), gather/sleep/__qualname__.__eq__ (extra3/extra22/extra26/extra28/extra43), Queue/__name__.__eq__ and Lock/__name__.__eq__ (extra/extra2/extra5), run/__qualname__.__eq__('run') (extra6/extra22/extra43), Condition/__name__/__qualname__/__len__() (extra53), BoundedSemaphore/__name__/__qualname__/__len__() (extra53), run/__name__.__eq__('run') (extra53), class __dict__.__class__.__name__/__qualname__ == 'mappingproxy' (extra54), class __class__.__module__.__eq__('builtins') (extra55), gather/sleep/wait __class__.__module__.__eq__('builtins') (extra55), Queue/Lock/Event/Semaphore/Condition __init__.__class__.__name__.__eq__('function') (extra55), class __repr__.__class__.__name__ (extra56), class __weakref__.__class__.__name__ (extra56), gather/sleep/wait function __repr__.__class__.__name__ (extra56), asyncio.__all__.__class__.__name__.__eq__('tuple') (extra57), class __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra57), class __subclasshook__.__class__.__name__ (extra57), asyncio.__all__.__contains__ membership checks (extra58), asyncio.__package__.__eq__('asyncio') (extra58), Queue/Lock __doc__.__class__.__name__.__eq__('str') (extra58), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra59), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra60), Queue/Lock __init__ and put/get/empty/full/qsize/acquire/release __qualname__.__eq__ (extra61), gather/sleep/Queue.__init__/Lock.__init__ __annotations__/__globals__ class identity, gather __globals__.__contains__('gather'), Queue.__doc__.__contains__('Queue') (extra62), gather/sleep/Queue.__init__/Lock.__init__ __defaults__/__code__/__class__.__name__ checks (extra63), gather/sleep/Queue.__init__/Lock.__init__ __code__.co_name equality and co_argcount values (extra64), gather/sleep/Queue.__init__ co_varnames/co_filename/co_flags attribute chains (extra65), gather/sleep/Queue.__init__ co_consts/co_nlocals/co_stacksize type identity (extra66), sleep/__defaults__.__class__.__name__=='tuple', sleep/__defaults__.__len__()==1, Queue.__init__/__defaults__.__class__.__name__=='tuple', gather/__defaults__.__class__.__name__=='NoneType', Lock.__init__/__defaults__.__class__.__name__=='NoneType', Event class identity, Semaphore class identity (extra67)."
    - "This spec covers (asynciokw68 namespace): wave 234 theme — __kwdefaults__ type identity for gather (keyword-only arg return_exceptions=False gives __kwdefaults__=={'return_exceptions': False}); NoneType identity for sleep/__kwdefaults__, Queue.__init__/__kwdefaults__, Lock.__init__/__kwdefaults__; and Condition/BoundedSemaphore class identity (__class__.__name__=='type', __module__=='asyncio.locks', __qualname__). NEW in extra68: gather.__kwdefaults__.__class__.__name__=='dict'; gather.__kwdefaults__.__len__()==1; sleep.__kwdefaults__.__class__.__name__=='NoneType'; Queue.__init__.__kwdefaults__.__class__.__name__=='NoneType'; Lock.__init__.__kwdefaults__.__class__.__name__=='NoneType'; Condition.__class__.__name__=='type'; Condition.__module__=='asyncio.locks'; Condition.__qualname__=='Condition'; BoundedSemaphore.__class__.__name__=='type'; BoundedSemaphore.__module__=='asyncio.locks'; BoundedSemaphore.__qualname__=='BoundedSemaphore'."
    - "asyncio.gather.__kwdefaults__.__class__.__name__ == 'dict'. gather(*coros_or_futures, return_exceptions=False) has one keyword-only parameter with a default (return_exceptions=False). __kwdefaults__ is {'return_exceptions': False}, a one-entry dict. __class__.__name__ is 'dict'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.gather.__kwdefaults__.__len__() == 1. gather.__kwdefaults__ is {'return_exceptions': False}, a one-entry dict. len({'return_exceptions': False}) == 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.sleep.__kwdefaults__ is None. sleep(delay, result=None) has no keyword-only parameters. __kwdefaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Queue.__init__.__kwdefaults__ is None. Queue.__init__(self, maxsize=0) has no keyword-only parameters. __kwdefaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__init__.__kwdefaults__ is None. Lock.__init__(self) has no keyword-only parameters. __kwdefaults__ is None. None.__class__.__name__ is 'NoneType'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Condition.__module__ == 'asyncio.locks'. Condition is defined in Lib/asyncio/locks.py which sets __name__ == 'asyncio.locks'. Condition.__module__ is 'asyncio.locks'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.BoundedSemaphore.__module__ == 'asyncio.locks'. BoundedSemaphore is defined in Lib/asyncio/locks.py which sets __name__ == 'asyncio.locks'. BoundedSemaphore.__module__ is 'asyncio.locks'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio gather __kwdefaults__ checks — extra68
#
# Wave 234 theme: __kwdefaults__ type identity and length.
#
# gather(*coros_or_futures, return_exceptions=False) has one keyword-only
# parameter with a default. __kwdefaults__ is {'return_exceptions': False},
# a one-entry dict. __class__.__name__ == 'dict' and __len__() == 1.
# ---------------------------------------------------------------------------

table asyncio_extra68.gather_kwdefaults:
  description: "asyncio gather/__kwdefaults__ type identity and length checks in asynciokw68 namespace — wave 234 theme: __kwdefaults__ type identity; gather(*coros_or_futures, return_exceptions=False) has one keyword-only parameter with a default; __kwdefaults__ is {'return_exceptions': False} a one-entry dict; __class__.__name__=='dict' and __len__()==1; NEW in extra68: first __kwdefaults__.__class__.__name__ and __len__() checks for gather in the asynciokw68 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: kwdefaults
  id_prefix: asynciokw68

  columns: [id, function, args, expected, description]
  rows:
    - [gather_kwdefaults_class, gather.__kwdefaults__.__class__.__name__.__eq__, ["dict"], true, "gather.__kwdefaults__.__class__.__name__ == 'dict' — gather(*coros_or_futures, return_exceptions=False) has one keyword-only parameter with a default (return_exceptions=False); __kwdefaults__ is {'return_exceptions': False} a one-entry dict; dict.__class__.__name__ is 'dict'; NEW in extra68: first __kwdefaults__.__class__.__name__.__eq__ check for gather in the asynciokw68 namespace; verified with Python 3.14.3"]
    - [gather_kwdefaults_len,   gather.__kwdefaults__.__len__,                   [],       1,    "gather.__kwdefaults__.__len__() == 1 — gather.__kwdefaults__ is {'return_exceptions': False} a one-entry dict; len({'return_exceptions': False}) == 1; NEW in extra68: first __kwdefaults__.__len__() check for gather in the asynciokw68 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio sleep / Queue.__init__ / Lock.__init__ __kwdefaults__ NoneType — extra68
#
# Wave 234 theme: __kwdefaults__ NoneType identity.
#
# sleep(delay, result=None) has no keyword-only parameters; __kwdefaults__ is None.
# Queue.__init__(self, maxsize=0) has no keyword-only parameters; __kwdefaults__ is None.
# Lock.__init__(self) has no keyword-only parameters; __kwdefaults__ is None.
# ---------------------------------------------------------------------------

table asyncio_extra68.none_kwdefaults:
  description: "asyncio sleep/__kwdefaults__ and Queue.__init__/__kwdefaults__ and Lock.__init__/__kwdefaults__ NoneType checks in asynciokw68 namespace — wave 234 theme: __kwdefaults__ NoneType identity; sleep/Queue.__init__/Lock.__init__ have no keyword-only parameters; __kwdefaults__ is None for all; None.__class__.__name__ is 'NoneType'; NEW in extra68: first __kwdefaults__.__class__.__name__.__eq__('NoneType') checks for sleep/Queue.__init__/Lock.__init__ in the asynciokw68 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: kwdefaults
  id_prefix: asynciokw68a

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_kwdefaults_class,     sleep.__kwdefaults__.__class__.__name__.__eq__,         ["NoneType"], true, "sleep.__kwdefaults__.__class__.__name__ == 'NoneType' — sleep(delay, result=None) has no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra68: first __kwdefaults__.__class__.__name__.__eq__ check for sleep in the asynciokw68 namespace; verified with Python 3.14.3"]
    - [queue_init_kwdefaults_class, Queue.__init__.__kwdefaults__.__class__.__name__.__eq__, ["NoneType"], true, "Queue.__init__.__kwdefaults__.__class__.__name__ == 'NoneType' — Queue.__init__(self, maxsize=0) has no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra68: first __kwdefaults__.__class__.__name__.__eq__ check for Queue.__init__ in the asynciokw68 namespace; verified with Python 3.14.3"]
    - [lock_init_kwdefaults_class,  Lock.__init__.__kwdefaults__.__class__.__name__.__eq__,  ["NoneType"], true, "Lock.__init__.__kwdefaults__.__class__.__name__ == 'NoneType' — Lock.__init__(self) has no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra68: first __kwdefaults__.__class__.__name__.__eq__ check for Lock.__init__ in the asynciokw68 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Condition class identity checks — extra68
#
# Wave 234 theme: Condition class identity.
#
# asyncio.Condition is a class defined in asyncio.locks. Its metaclass is
# 'type' (Condition.__class__.__name__ == 'type'), its __module__ is
# 'asyncio.locks', and its __qualname__ is 'Condition'.
# ---------------------------------------------------------------------------

table asyncio_extra68.Condition_identity:
  description: "asyncio Condition class identity checks in asynciokw68 namespace — wave 234 theme: Condition class identity; Condition.__class__.__name__=='type' (Condition is an ordinary class); Condition.__module__=='asyncio.locks' (defined in Lib/asyncio/locks.py); Condition.__qualname__=='Condition' (simple top-level class name); NEW in extra68: first __class__.__name__/__module__/__qualname__ equality checks for Condition in the asynciokw68 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciokw68b

  columns: [id, function, args, expected, description]
  rows:
    - [condition_class_name, Condition.__class__.__name__.__eq__,  ["type"],          true, "Condition.__class__.__name__ == 'type' — asyncio.Condition is an ordinary Python class; its metaclass is the built-in 'type'; Condition.__class__.__name__ is 'type'; NEW in extra68: first __class__.__name__.__eq__('type') check for Condition in the asynciokw68 namespace; verified with Python 3.14.3"]
    - [condition_module,     Condition.__module__.__eq__,          ["asyncio.locks"], true, "Condition.__module__ == 'asyncio.locks' — Condition is defined in Lib/asyncio/locks.py which sets __name__ == 'asyncio.locks'; Condition.__module__ is 'asyncio.locks'; NEW in extra68: first __module__.__eq__ check for Condition in the asynciokw68 namespace; verified with Python 3.14.3"]
    - [condition_qualname,   Condition.__qualname__.__eq__,        ["Condition"],     true, "Condition.__qualname__ == 'Condition' — Condition is a top-level class in asyncio.locks; its qualified name is simply 'Condition'; __qualname__.__eq__('Condition') returns True; NEW in extra68: first __qualname__.__eq__ check for Condition in the asynciokw68 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio BoundedSemaphore class identity checks — extra68
#
# Wave 234 theme: BoundedSemaphore class identity.
#
# asyncio.BoundedSemaphore is a class defined in asyncio.locks. Its metaclass
# is 'type', its __module__ is 'asyncio.locks', and its __qualname__ is
# 'BoundedSemaphore'.
# ---------------------------------------------------------------------------

table asyncio_extra68.BoundedSemaphore_identity:
  description: "asyncio BoundedSemaphore class identity checks in asynciokw68 namespace — wave 234 theme: BoundedSemaphore class identity; BoundedSemaphore.__class__.__name__=='type' (BoundedSemaphore is an ordinary class); BoundedSemaphore.__module__=='asyncio.locks' (defined in Lib/asyncio/locks.py); BoundedSemaphore.__qualname__=='BoundedSemaphore' (simple top-level class name); NEW in extra68: first __class__.__name__/__module__/__qualname__ equality checks for BoundedSemaphore in the asynciokw68 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciokw68c

  columns: [id, function, args, expected, description]
  rows:
    - [boundedsemaphore_class_name, BoundedSemaphore.__class__.__name__.__eq__,  ["type"],          true, "BoundedSemaphore.__class__.__name__ == 'type' — asyncio.BoundedSemaphore is an ordinary Python class; its metaclass is the built-in 'type'; BoundedSemaphore.__class__.__name__ is 'type'; NEW in extra68: first __class__.__name__.__eq__('type') check for BoundedSemaphore in the asynciokw68 namespace; verified with Python 3.14.3"]
    - [boundedsemaphore_module,     BoundedSemaphore.__module__.__eq__,          ["asyncio.locks"], true, "BoundedSemaphore.__module__ == 'asyncio.locks' — BoundedSemaphore is defined in Lib/asyncio/locks.py which sets __name__ == 'asyncio.locks'; BoundedSemaphore.__module__ is 'asyncio.locks'; NEW in extra68: first __module__.__eq__ check for BoundedSemaphore in the asynciokw68 namespace; verified with Python 3.14.3"]
    - [boundedsemaphore_qualname,   BoundedSemaphore.__qualname__.__eq__,        ["BoundedSemaphore"], true, "BoundedSemaphore.__qualname__ == 'BoundedSemaphore' — BoundedSemaphore is a top-level class in asyncio.locks; its qualified name is simply 'BoundedSemaphore'; __qualname__.__eq__('BoundedSemaphore') returns True; NEW in extra68: first __qualname__.__eq__ check for BoundedSemaphore in the asynciokw68 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra68
# ---------------------------------------------------------------------------

invariant asyncio_extra68.gather_kwdefaults_dict:
  description: "asyncio.gather.__kwdefaults__.__class__.__name__.__eq__('dict') returns True — gather(*coros_or_futures, return_exceptions=False) has one keyword-only parameter with a default (return_exceptions=False); __kwdefaults__ is {'return_exceptions': False} a one-entry dict; dict.__class__.__name__ is 'dict'; NEW in extra68: first standalone __kwdefaults__.__class__.__name__.__eq__('dict') invariant for gather in the asynciokw68 namespace; wave 234 first __kwdefaults__ type identity invariant for gather; verified with Python 3.14.3"
  category: kwdefaults
  kind: python_call_eq
  function: gather.__kwdefaults__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant asyncio_extra68.gather_kwdefaults_len_1:
  description: "asyncio.gather.__kwdefaults__.__len__() == 1 — gather.__kwdefaults__ is {'return_exceptions': False}, a one-entry dict; len({'return_exceptions': False}) == 1; __len__() returns 1; NEW in extra68: first standalone __kwdefaults__.__len__() invariant for gather in the asynciokw68 namespace; wave 234 first __kwdefaults__ length invariant for gather; verified with Python 3.14.3"
  category: kwdefaults
  kind: python_call_eq
  function: gather.__kwdefaults__.__len__
  args: []
  expected: 1

invariant asyncio_extra68.sleep_kwdefaults_NoneType:
  description: "asyncio.sleep.__kwdefaults__.__class__.__name__.__eq__('NoneType') returns True — sleep(delay, result=None) has no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ is 'NoneType'; NEW in extra68: first standalone __kwdefaults__.__class__.__name__.__eq__('NoneType') invariant for sleep in the asynciokw68 namespace; wave 234 first __kwdefaults__ NoneType identity invariant for sleep; verified with Python 3.14.3"
  category: kwdefaults
  kind: python_call_eq
  function: sleep.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant asyncio_extra68.Condition_module_asyncio_locks:
  description: "asyncio.Condition.__module__.__eq__('asyncio.locks') returns True — Condition is defined in Lib/asyncio/locks.py; the module sets its __name__ to 'asyncio.locks'; Condition.__module__ is 'asyncio.locks'; NEW in extra68: first standalone __module__.__eq__('asyncio.locks') invariant for Condition in the asynciokw68 namespace; wave 234 first __module__ identity invariant for Condition; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Condition.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra68.BoundedSemaphore_module_asyncio_locks:
  description: "asyncio.BoundedSemaphore.__module__.__eq__('asyncio.locks') returns True — BoundedSemaphore is defined in Lib/asyncio/locks.py; the module sets its __name__ to 'asyncio.locks'; BoundedSemaphore.__module__ is 'asyncio.locks'; NEW in extra68: first standalone __module__.__eq__('asyncio.locks') invariant for BoundedSemaphore in the asynciokw68 namespace; wave 234 first __module__ identity invariant for BoundedSemaphore; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: BoundedSemaphore.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true
