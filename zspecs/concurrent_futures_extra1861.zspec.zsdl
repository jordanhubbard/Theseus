spec: concurrent_futures_extra1861
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 571 theme: bitwise operators (__or__/__and__/__xor__/__invert__/__lshift__) and in-place operators (__iadd__/__imul__/__ior__/__isub__)."
    - "concurrent.futures.Future is a pure-Python class; no bitwise or in-place operator dunders in own __dict__."
    - "concurrent.futures.ThreadPoolExecutor, ProcessPoolExecutor, and Executor are pure-Python classes; no bitwise or in-place operator dunders."
    - "concurrent.futures module exports wait-condition constants: FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED."
    - "concurrent.futures module exports exception types: CancelledError, TimeoutError, BrokenExecutor, InvalidStateError, BrokenThreadPool, BrokenProcessPool."
    - "concurrent.futures.process submodule is accessible as 'process' in the module dict."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: bitwise operators absent from concurrent.futures class own __dict__
# ---------------------------------------------------------------------------

table concurrent_futures_extra1861.bitwise_operators:
  description: "Bitwise operator dunder methods absent from concurrent.futures class own __dict__"
  kind: python_call_eq
  category: bitwise_operators
  id_prefix: cf1861

  columns: [id, function, args, expected]
  rows:
    - ["cf1861001", concurrent.futures.Future.__dict__.__contains__,              ["__or__"],      false]
    - ["cf1861002", concurrent.futures.Future.__dict__.__contains__,              ["__and__"],     false]
    - ["cf1861003", concurrent.futures.Future.__dict__.__contains__,              ["__xor__"],     false]
    - ["cf1861004", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__or__"],      false]
    - ["cf1861005", concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__or__"],      false]
    - ["cf1861006", concurrent.futures.Executor.__dict__.__contains__,            ["__or__"],      false]
    - ["cf1861007", concurrent.futures.Future.__dict__.__contains__,              ["__invert__"],  false]
    - ["cf1861008", concurrent.futures.Future.__dict__.__contains__,              ["__lshift__"],  false]

# ---------------------------------------------------------------------------
# Table 2: in-place operators absent from concurrent.futures class own __dict__
# ---------------------------------------------------------------------------

table concurrent_futures_extra1861.inplace_operators:
  description: "In-place operator dunder methods absent from concurrent.futures class own __dict__"
  kind: python_call_eq
  category: inplace_operators
  id_prefix: cf1861

  columns: [id, function, args, expected]
  rows:
    - ["cf1861009", concurrent.futures.Future.__dict__.__contains__,              ["__iadd__"], false]
    - ["cf1861010", concurrent.futures.Future.__dict__.__contains__,              ["__ior__"],  false]
    - ["cf1861011", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__iadd__"], false]
    - ["cf1861012", concurrent.futures.ProcessPoolExecutor.__dict__.__contains__, ["__iadd__"], false]
    - ["cf1861013", concurrent.futures.Executor.__dict__.__contains__,            ["__iadd__"], false]
    - ["cf1861014", concurrent.futures.Future.__dict__.__contains__,              ["__imul__"], false]
    - ["cf1861015", concurrent.futures.Future.__dict__.__contains__,              ["__isub__"], false]
    - ["cf1861016", concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__ior__"],  false]

# ---------------------------------------------------------------------------
# Table 3: concurrent.futures module constants and submodule references
# ---------------------------------------------------------------------------

table concurrent_futures_extra1861.cf_state_constants:
  description: "concurrent.futures module exports wait constants, exception types, and submodule references"
  kind: python_call_eq
  category: module_contents
  id_prefix: cf1861

  columns: [id, function, args, expected]
  rows:
    - ["cf1861017", concurrent.futures.__dict__.__contains__, ["FIRST_COMPLETED"],  true]
    - ["cf1861018", concurrent.futures.__dict__.__contains__, ["FIRST_EXCEPTION"],  true]
    - ["cf1861019", concurrent.futures.__dict__.__contains__, ["ALL_COMPLETED"],    true]
    - ["cf1861020", concurrent.futures.__dict__.__contains__, ["CancelledError"],   true]
    - ["cf1861021", concurrent.futures.__dict__.__contains__, ["TimeoutError"],     true]
    - ["cf1861022", concurrent.futures.__dict__.__contains__, ["BrokenExecutor"],   true]
    - ["cf1861023", concurrent.futures.__dict__.__contains__, ["InvalidStateError"], true]
    - ["cf1861024", concurrent.futures.__dict__.__contains__, ["BrokenThreadPool"], true]
    - ["cf1861025", concurrent.futures.__dict__.__contains__, ["BrokenProcessPool"], true]
    - ["cf1861026", concurrent.futures.__dict__.__contains__, ["process"],          true]
