spec: is_base64
version: ">=1.1.0"
backend: node(is-base64)

docs: https://www.npmjs.com/package/is-base64

provenance:
  derived_from:
    - "is-base64 README — https://www.npmjs.com/package/is-base64"
    - "Test vectors verified with is-base64 via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-base64 source"
  notes:
    - "is-base64 is an npm package. Install: npm install is-base64"
    - "Returns true if the string is valid base64 encoding."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_base64.check:
  kind: node_module_call_eq
  function: isBase64
  category: validation
  id_prefix: isb64

  columns: [id, args, expected]
  rows:
    - [valid,    ["aGVsbG8="],  true]
    - [valid2,   ["SGVsbG8="],  true]
    - [invalid,  ["hello!"],    false]

