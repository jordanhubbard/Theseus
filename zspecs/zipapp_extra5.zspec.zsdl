spec: zipapp_extra5
version: ">=3.9"
backend: python_module(zipapp)

docs: https://docs.python.org/3/library/zipapp.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipapp.html — Python zipapp documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipapp.py"
  notes:
    - "This spec extends zipapp.zspec.zsdl through zipapp_extra4.zspec.zsdl."
    - "zipapp.zspec.zsdl covers: create_archive/__name__/type, get_interpreter/__name__/type, ZipAppError/__name__/__module__/base/type/issubclass."
    - "zipapp_extra.zspec.zsdl covers: create_archive/__name__/__qualname__/type, get_interpreter/__name__/__qualname__/type, ZipAppError/__name__/__module__/__qualname__/type/base."
    - "zipapp_extra2.zspec.zsdl covers: create_archive/__name__/__module__/__qualname__, get_interpreter/__name__/__module__/__qualname__, ZipAppError/__name__/__module__/base."
    - "zipapp_extra3.zspec.zsdl covers: create_archive/__doc__ class check (str), get_interpreter/__doc__ class check (NoneType per runtime), ZipAppError/__doc__ class check (str), ZipAppError.__bases__.__len__ == 1."
    - "zipapp_extra4.zspec.zsdl covers: create_archive/__qualname__ no dots, get_interpreter/__qualname__ no dots, ZipAppError/__qualname__ no dots, function_names table, ZipAppError.__bases__[0].__qualname__ == 'ValueError'."
    - "No prior spec covers: zipapp.ZipAppError.__mro__[1].__name__ == 'ValueError' — MRO depth 1."
    - "No prior spec covers: zipapp.ZipAppError.__mro__[2].__name__ == 'Exception' — MRO depth 2."
    - "No prior spec covers: zipapp.ZipAppError.__mro__[3].__name__ == 'BaseException' — MRO depth 3."
    - "No prior spec covers: zipapp.ZipAppError.__mro__[4].__name__ == 'object' — MRO terminal entry."
    - "No prior spec covers: zipapp.create_archive.__class__.__name__ == 'function' — create_archive is a plain function."
    - "No prior spec covers: zipapp.get_interpreter.__class__.__name__ == 'function' — get_interpreter is a plain function."
    - "zipapp.ZipAppError.__mro__: [ZipAppError, ValueError, Exception, BaseException, object] — full MRO, length 5."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ZipAppError.__mro__ — full MRO depth checks
# No prior zipapp spec checks __mro__[N].__name__ for any N.
# ZipAppError.__bases__[0].__name__ == 'ValueError' was covered (bases form).
# ZipAppError.__bases__[0].__qualname__ == 'ValueError' was covered (extra4).
# __mro__[N] form is a distinct axis for all four depth indices.
# ZipAppError.__mro__: [ZipAppError, ValueError, Exception, BaseException, object]
# ---------------------------------------------------------------------------

table zipapp_extra5.ZipAppError_mro:
  description: "ZipAppError.__mro__ depth checks: ValueError, Exception, BaseException, object"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mro5

  columns: [id, function, args, method, expected]
  rows:
    - [mro1, ZipAppError.__mro__.__getitem__, [1], __name__, "ValueError"]
    - [mro2, ZipAppError.__mro__.__getitem__, [2], __name__, "Exception"]
    - [mro3, ZipAppError.__mro__.__getitem__, [3], __name__, "BaseException"]
    - [mro4, ZipAppError.__mro__.__getitem__, [4], __name__, "object"]

# ---------------------------------------------------------------------------
# create_archive and get_interpreter __class__.__name__ == 'function'
# Prior specs check __name__, __qualname__, __module__, and __doc__ class name
# for create_archive and get_interpreter. No prior spec checks __class__.__name__
# directly for either function (type check form, not via issubclass).
# Both are plain module-level functions, so __class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

table zipapp_extra5.function_class_names:
  description: "create_archive and get_interpreter are plain functions (__class__.__name__ == 'function')"
  kind: python_call_eq
  category: functions
  id_prefix: fcls5

  columns: [id, function, args, expected]
  rows:
    - [create_archive,  create_archive.__class__.__name__.__eq__,  ["function"], true]
    - [get_interpreter, get_interpreter.__class__.__name__.__eq__, ["function"], true]
