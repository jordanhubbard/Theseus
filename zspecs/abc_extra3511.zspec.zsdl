spec: ab3511
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 681 (ab3511): __get__, __set__, __delete__ dict-presence checks for abc types."
    - "All values false — abc.ABC, abc.ABCMeta, and abc.abstractmethod do not implement the descriptor protocol."
    - "abc.abstractmethod is a decorator class but does not define __get__, __set__, or __delete__ in its own __dict__."
    - "abc.ABCMeta is a metaclass but does not define descriptor protocol slots in its own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
# ---------------------------------------------------------------------------

table ab3511.get:
  description: "abc types __get__ dict-presence checks; wave 681"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3511
  columns: [id, function, args, expected]
  rows:
    - ["ab3511001", operator.contains, [abc.ABC.__dict__,                                 "__get__"], false]
    - ["ab3511002", operator.contains, [abc.ABCMeta.__dict__,                             "__get__"], false]
    - ["ab3511003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__get__"], false]

