spec: json_extra20
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl and prior extras through json_extra19.zspec.zsdl."
    - "json_extra19 covers: JSONEncoder.__init__/__qualname__; JSONDecoder.__init__/__qualname__; JSONEncoder.__init__/__module__; JSONDecoder.__init__/__module__."
    - "json_extra18 covers: encode/iterencode/default __module__ for JSONEncoder; decode/raw_decode __module__ for JSONDecoder."
    - "json_extra17 covers: encode/iterencode/default __qualname__ for JSONEncoder; decode/raw_decode __qualname__ for JSONDecoder."
    - "json_extra16 covers: JSONEncoder/__qualname__; JSONDecoder/__qualname__; JSONDecodeError/__qualname__; __qualname__.__class__.__name__ type axis for those three classes."
    - "json_extra15 covers: JSONDecodeError/__module__; JSONEncoder/__module__ standalone; JSONDecoder/__module__ standalone; JSONEncoder/__bases__[0].__name__; JSONDecoder/__bases__[0].__name__."
    - "Focus: __bases__[0].__qualname__ for JSONEncoder, JSONDecoder, and JSONDecodeError; type-axis for method __module__ strings."
    - "No prior json spec checks JSONEncoder.__bases__[0].__qualname__."
    - "No prior json spec checks JSONDecoder.__bases__[0].__qualname__."
    - "No prior json spec checks JSONDecodeError.__bases__[0].__qualname__."
    - "No prior json spec checks JSONEncoder.encode.__module__.__class__.__name__."
    - "No prior json spec checks JSONDecoder.decode.__module__.__class__.__name__."
    - "json.JSONEncoder.__bases__[0].__qualname__ == 'object' — object's qualname equals its name."
    - "json.JSONDecoder.__bases__[0].__qualname__ == 'object' — object's qualname equals its name."
    - "json.JSONDecodeError.__bases__[0].__qualname__ == 'ValueError' — ValueError's qualname equals its name."
    - "json.JSONEncoder.encode.__module__.__class__.__name__ == 'str' — method __module__ is a string."
    - "json.JSONDecoder.decode.__module__.__class__.__name__ == 'str' — method __module__ is a string."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__qualname__ for JSONEncoder, JSONDecoder, and JSONDecodeError
#
# json_extra15 checks __bases__[0].__name__ for JSONEncoder and JSONDecoder.
# json_extra12 checks JSONDecodeError.__bases__[0].__name__ == 'ValueError'.
# No prior json spec checks the __qualname__ of any base class.  For built-in
# top-level classes (object, ValueError), __qualname__ equals __name__.
# ---------------------------------------------------------------------------

invariant json_extra20.JSONEncoder.base_qualname:
  description: "json.JSONEncoder.__bases__[0].__qualname__ == 'object' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "JSONEncoder.__bases__[0].__qualname__.__eq__"
  args: ["object"]
  expected: true

invariant json_extra20.JSONDecoder.base_qualname:
  description: "json.JSONDecoder.__bases__[0].__qualname__ == 'object' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "JSONDecoder.__bases__[0].__qualname__.__eq__"
  args: ["object"]
  expected: true

invariant json_extra20.JSONDecodeError.base_qualname:
  description: "json.JSONDecodeError.__bases__[0].__qualname__ == 'ValueError' — base class qualname equals name"
  category: class_attrs
  kind: python_call_eq
  function: "JSONDecodeError.__bases__[0].__qualname__.__eq__"
  args: ["ValueError"]
  expected: true

# ---------------------------------------------------------------------------
# Type axis for method __module__ strings
#
# json_extra18 checks the values of encode/iterencode/decode/raw_decode __module__.
# No prior json spec checks the type (__class__.__name__) of those __module__
# attributes.  A method's __module__ is always a str, so the class name is 'str'.
# ---------------------------------------------------------------------------

invariant json_extra20.encode.module.class_name:
  description: "json.JSONEncoder.encode.__module__.__class__.__name__ == 'str' — method __module__ is a string"
  category: method_attrs
  kind: python_call_eq
  function: "JSONEncoder.encode.__module__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

invariant json_extra20.decode.module.class_name:
  description: "json.JSONDecoder.decode.__module__.__class__.__name__ == 'str' — method __module__ is a string"
  category: method_attrs
  kind: python_call_eq
  function: "JSONDecoder.decode.__module__.__class__.__name__.__eq__"
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all five new invariants
#
# All five are first covered in this spec (json_extra20).
# ---------------------------------------------------------------------------

table json_extra20.base_qualnames_and_module_types:
  description: "json class base __qualname__ and method __module__ type axis"
  kind: python_call_eq
  category: class_attrs
  id_prefix: jbq20

  columns: [id, function, args, expected]
  rows:
    - [encoder_base_qn,       "JSONEncoder.__bases__[0].__qualname__.__eq__",              ["object"],    true]
    - [decoder_base_qn,       "JSONDecoder.__bases__[0].__qualname__.__eq__",              ["object"],    true]
    - [decodeerr_base_qn,     "JSONDecodeError.__bases__[0].__qualname__.__eq__",          ["ValueError"], true]
    - [encode_mod_type,       "JSONEncoder.encode.__module__.__class__.__name__.__eq__",   ["str"],       true]
    - [decode_mod_type,       "JSONDecoder.decode.__module__.__class__.__name__.__eq__",   ["str"],       true]
