spec: hashlib_extra1951
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/hashlib.html"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.HASH (the C-level hash type) does not define __contains__, __iter__, __next__, __aiter__, or __anext__ in its own __dict__."
    - "hashlib.algorithms_available and hashlib.algorithms_guaranteed are frozenset/set instances — they have __contains__ via the set type, not in the module __dict__ as a class."
    - "There is no async iteration support in any hashlib type — __aiter__ and __anext__ are absent from all class dicts."
    - "hashlib.new is a built-in function; its __dict__ (instance attribute dict) is empty — no dunder iteration methods present."
  created_at: "2026-04-12"
error_model: python_exceptions

table hashlib_extra1951.contains_protocol:
  description: "hashlib HASH type __contains__ dict-presence — HASH does not define __contains__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1951

  columns: [id, function, args, expected]
  rows:
    - ["hl1951001", "hashlib.md5.__class__.__dict__.__contains__",    ["__contains__"], false]
    - ["hl1951002", "hashlib.sha1.__class__.__dict__.__contains__",   ["__contains__"], false]
    - ["hl1951003", "hashlib.sha256.__class__.__dict__.__contains__", ["__contains__"], false]
    - ["hl1951004", "hashlib.sha512.__class__.__dict__.__contains__", ["__contains__"], false]
    - ["hl1951005", "hashlib.new.__class__.__dict__.__contains__",    ["__contains__"], false]

