table hashlib_extra1951.algorithms_sets:
  description: "hashlib.algorithms_available and algorithms_guaranteed are set instances — __contains__ is on type, not in instance dict"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1951

  columns: [id, function, args, expected]
  rows:
    - ["hl1951026", "hashlib.algorithms_available.__class__.__dict__.__contains__", ["__contains__"], true]
    - ["hl1951027", "hashlib.algorithms_guaranteed.__class__.__dict__.__contains__", ["__contains__"], true]
    - ["hl1951028", "hashlib.algorithms_available.__class__.__dict__.__contains__", ["__iter__"],    true]
    - ["hl1951029", "hashlib.algorithms_guaranteed.__class__.__dict__.__contains__", ["__iter__"],   true]
    - ["hl1951030", "hashlib.algorithms_available.__class__.__dict__.__contains__", ["__aiter__"],   false]
    - ["hl1951031", "hashlib.algorithms_guaranteed.__class__.__dict__.__contains__", ["__aiter__"],  false]
    - ["hl1951032", "hashlib.algorithms_available.__class__.__dict__.__contains__", ["__anext__"],   false]
    - ["hl1951033", "hashlib.algorithms_guaranteed.__class__.__dict__.__contains__", ["__anext__"],  false]
