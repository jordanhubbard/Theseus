spec: io_extra34
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra9.zspec.zsdl — covers BytesIO/StringIO __qualname__ in table rows; IOBase.__module__ in table"
    - "io_extra31.zspec.zsdl — covers IOBase/__qualname__/__module__; RawIOBase/__qualname__/__module__; BufferedIOBase/__qualname__/__module__; TextIOBase/__qualname__/__module__"
    - "io_extra32.zspec.zsdl — covers FileIO/BytesIO/StringIO/BufferedReader/BufferedWriter/TextIOWrapper __qualname__/__module__/__bases__[0].__name__"
    - "io_extra33.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase __qualname__ standalone; BytesIO/StringIO/FileIO/TextIOWrapper __qualname__ standalone; UnsupportedOperation/__qualname__/__module__/__bases__[0].__name__; io.open/__qualname__"
  notes:
    - "This spec extends io_extra33.zspec.zsdl."
    - "Prior specs covered: IOBase/RawIOBase/BufferedIOBase/TextIOBase __name__/__module__/__qualname__, BytesIO/StringIO/FileIO/TextIOWrapper __name__/__module__/__qualname__, UnsupportedOperation __name__/__module__/__qualname__/__bases__, io.open __name__/__qualname__, DEFAULT_BUFFER_SIZE value, various __bases__ checks."
    - "This spec covers: __module__.__len__() for IOBase/RawIOBase/BufferedIOBase/TextIOBase/BytesIO/StringIO; __name__.__len__() for IOBase/RawIOBase/BufferedIOBase/TextIOBase/BytesIO/StringIO."
    - "IMPORTANT: io abstract base classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase) have __module__ == 'io' (len 2). The concrete C-extension classes (BytesIO, StringIO) have __module__ == '_io' (len 3). This distinction is critical."
    - "io.IOBase.__module__ == 'io' (len 2) — abstract base class, registered under public 'io' module; verified Python 3.12."
    - "io.RawIOBase.__module__ == 'io' (len 2) — abstract base class; verified Python 3.12."
    - "io.BufferedIOBase.__module__ == 'io' (len 2) — abstract base class; verified Python 3.12."
    - "io.TextIOBase.__module__ == 'io' (len 2) — abstract base class; verified Python 3.12."
    - "io.BytesIO.__module__ == '_io' (len 3) — C-extension concrete class; verified Python 3.12."
    - "io.StringIO.__module__ == '_io' (len 3) — C-extension concrete class; verified Python 3.12."
    - "io.IOBase.__name__ == 'IOBase' (len 6) — verified Python 3.12."
    - "io.RawIOBase.__name__ == 'RawIOBase' (len 9) — verified Python 3.12."
    - "io.BufferedIOBase.__name__ == 'BufferedIOBase' (len 14) — verified Python 3.12."
    - "io.TextIOBase.__name__ == 'TextIOBase' (len 10) — verified Python 3.12."
    - "io.BytesIO.__name__ == 'BytesIO' (len 7) — verified Python 3.12."
    - "io.StringIO.__name__ == 'StringIO' (len 8) — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for abstract base classes: IOBase, RawIOBase,
# BufferedIOBase, TextIOBase
#
# These four abstract base classes have __module__ == 'io' (2 characters),
# NOT '_io'. Although they are implemented in C, they are registered under
# the public 'io' module namespace. Prior specs (io_extra31, io_extra33)
# establish the __module__ string equality; these invariants anchor the
# derived length value (2) in the extra34 namespace.
# ---------------------------------------------------------------------------

table io_extra34.abstract_base_module_lengths:
  description: "__module__.__len__() for IOBase, RawIOBase, BufferedIOBase, TextIOBase — all 2 (module name 'io')"
  kind: python_call_eq
  category: class_identity
  id_prefix: abml34

  columns: [id, function, args, expected]
  rows:
    - [IOBase,         IOBase.__module__.__len__,         [], 2]
    - [RawIOBase,      RawIOBase.__module__.__len__,      [], 2]
    - [BufferedIOBase, BufferedIOBase.__module__.__len__, [], 2]
    - [TextIOBase,     TextIOBase.__module__.__len__,     [], 2]

# ---------------------------------------------------------------------------
# __module__.__len__() for concrete classes: BytesIO, StringIO
#
# BytesIO and StringIO are C-extension concrete classes with __module__
# == '_io' (3 characters). This contrasts with the abstract base classes
# above (which have __module__ == 'io', len 2). Prior specs (io_extra32,
# io_extra33) establish the __module__ string equality for these classes;
# these invariants anchor the derived length value (3) in the extra34 namespace.
# ---------------------------------------------------------------------------

table io_extra34.concrete_class_module_lengths:
  description: "__module__.__len__() for BytesIO, StringIO — both 3 (module name '_io')"
  kind: python_call_eq
  category: class_identity
  id_prefix: ccml34

  columns: [id, function, args, expected]
  rows:
    - [BytesIO,  BytesIO.__module__.__len__,  [], 3]
    - [StringIO, StringIO.__module__.__len__, [], 3]

# ---------------------------------------------------------------------------
# __name__.__len__() for abstract base classes: IOBase, RawIOBase,
# BufferedIOBase, TextIOBase
#
# Each abstract base class name has a distinct length:
#   IOBase         -> 'IOBase'         -> 6
#   RawIOBase      -> 'RawIOBase'      -> 9
#   BufferedIOBase -> 'BufferedIOBase' -> 14
#   TextIOBase     -> 'TextIOBase'     -> 10
# Prior specs establish the __name__ string values; these invariants anchor
# the derived length values in the extra34 namespace.
# ---------------------------------------------------------------------------

table io_extra34.abstract_base_name_lengths:
  description: "__name__.__len__() for IOBase, RawIOBase, BufferedIOBase, TextIOBase"
  kind: python_call_eq
  category: class_identity
  id_prefix: abnl34

  columns: [id, function, args, expected]
  rows:
    - [IOBase,         IOBase.__name__.__len__,         [], 6]
    - [RawIOBase,      RawIOBase.__name__.__len__,      [], 9]
    - [BufferedIOBase, BufferedIOBase.__name__.__len__, [], 14]
    - [TextIOBase,     TextIOBase.__name__.__len__,     [], 10]

# ---------------------------------------------------------------------------
# __name__.__len__() for concrete classes: BytesIO, StringIO
# — standalone extra34-namespace invariants
#
# BytesIO.__name__ == 'BytesIO' (len 7) and StringIO.__name__ == 'StringIO'
# (len 8). These standalone invariants complement the table coverage above
# and establish the concrete-class name lengths as individually addressable
# extra34-namespace invariants.
# ---------------------------------------------------------------------------

invariant io_extra34.BytesIO.name_len:
  description: "io.BytesIO.__name__.__len__() == 7 — name 'BytesIO' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__name__.__len__
  args: []
  expected: 7

invariant io_extra34.StringIO.name_len:
  description: "io.StringIO.__name__.__len__() == 8 — name 'StringIO' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: StringIO.__name__.__len__
  args: []
  expected: 8
