spec: xml_extra6
version: ">=3.9"
backend: python_module(xml.etree.ElementTree)

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "Python xml.etree.ElementTree documentation — https://docs.python.org/3/library/xml.etree.elementtree.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xml/etree/ElementTree.py"
    - "xml_extra.zspec.zsdl — covers Element/ElementTree/SubElement/ParseError __name__, parse/fromstring/tostring __name__, ParseError base"
    - "xml_extra2.zspec.zsdl — covers fromstring tag/attrib, Element tag/attrib, tostring result class, ParseError name/base, VERSION/XML_VERSION class names, SubElement __name__"
    - "xml_extra3.zspec.zsdl — covers Element/__qualname__/ElementTree/__qualname__/XMLParser/__qualname__/ParseError/__qualname__, function __qualname__, Element/__module__/XMLParser/__module__, bases, type checks"
    - "xml_extra4.zspec.zsdl — covers Comment/ProcessingInstruction/register_namespace __qualname__/__module__/__class__.__name__; Element.text/tail is None; fromstring text content; tostring unicode encoding"
    - "xml_extra5.zspec.zsdl — covers Element/__name__/ElementTree/__name__/ParseError/__name__ standalone; ParseError.__bases__.__getitem__(0).__name__ via method chain; fromstring tag/attrib via method chain"
  notes:
    - "This spec extends all prior xml.etree.ElementTree specs through xml_extra5.zspec.zsdl."
    - "xml.etree.ElementTree.Element.__bases__[0].__name__ == 'object' — Element subclasses object; verified at runtime."
    - "xml.etree.ElementTree.ParseError.__bases__[0].__name__ == 'SyntaxError' — ParseError subclasses SyntaxError; verified at runtime."
    - "xml.etree.ElementTree.parse.__module__ == 'xml.etree.ElementTree' — parse lives in the ET module; verified at runtime."
    - "xml.etree.ElementTree.tostring.__module__ == 'xml.etree.ElementTree' — tostring lives in the ET module; verified at runtime."
    - "xml.etree.ElementTree.fromstring.__module__ == 'xml.etree.ElementTree' — fromstring lives in the ET module; verified at runtime."
    - "xml.etree.ElementTree.XMLParser.__module__ == 'xml.etree.ElementTree' — XMLParser lives in the ET module; verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class base hierarchy — Element and ParseError via __eq__ style
#
# xml_extra5 covers ParseError base via method chain (__bases__.__getitem__).
# xml_extra3 covers Element.__bases__[0].__name__ via a table row.
# These standalone invariants use the __bases__[0].__name__.__eq__ dotted
# chain style and carry distinct IDs in the extra6 namespace.
# ---------------------------------------------------------------------------

invariant xml_extra6.Element.base:
  description: "xml.etree.ElementTree.Element.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "Element.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant xml_extra6.ParseError.base:
  description: "xml.etree.ElementTree.ParseError.__bases__[0].__name__ == 'SyntaxError'"
  category: class_hierarchy
  kind: python_call_eq
  function: "ParseError.__bases__[0].__name__.__eq__"
  args: ["SyntaxError"]
  expected: true

# ---------------------------------------------------------------------------
# Function __module__ attributes — parse, tostring, fromstring
#
# All three public API functions are defined in xml.etree.ElementTree
# (the pure-Python layer). xml_extra3 checks Element.__module__ and
# XMLParser.__module__ for classes; no prior xml spec checks these function
# __module__ values as standalone invariants under the extra6 namespace.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant xml_extra6.parse.module:
  description: "xml.etree.ElementTree.parse.__module__ == 'xml.etree.ElementTree'"
  category: module_identity
  kind: python_call_eq
  function: parse.__module__.__eq__
  args: ["xml.etree.ElementTree"]
  expected: true

invariant xml_extra6.tostring.module:
  description: "xml.etree.ElementTree.tostring.__module__ == 'xml.etree.ElementTree'"
  category: module_identity
  kind: python_call_eq
  function: tostring.__module__.__eq__
  args: ["xml.etree.ElementTree"]
  expected: true

invariant xml_extra6.fromstring.module:
  description: "xml.etree.ElementTree.fromstring.__module__ == 'xml.etree.ElementTree'"
  category: module_identity
  kind: python_call_eq
  function: fromstring.__module__.__eq__
  args: ["xml.etree.ElementTree"]
  expected: true

# ---------------------------------------------------------------------------
# Class __module__ table — Element, XMLParser
#
# Consolidates class __module__ checks as a table for cross-referencing.
# xml_extra3 checks these as standalone invariants; this table re-anchors
# the same facts in the extra6 namespace with a distinct id_prefix.
# Verified at runtime.
# ---------------------------------------------------------------------------

table xml_extra6.class_modules:
  description: "__module__ for Element and XMLParser classes"
  kind: python_call_eq
  category: module_identity
  id_prefix: xmod6

  columns: [id, function, args, expected]
  rows:
    - [Element_module,    Element.__module__.__eq__,    ["xml.etree.ElementTree"], true]
    - [XMLParser_module,  XMLParser.__module__.__eq__,  ["xml.etree.ElementTree"], true]
