spec: io_extra1981
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/io.html"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "_io_extra.zspec.zsdl — covers _io C-module class metadata"
    - "io_extra1966.zspec.zsdl — covers __enter__/__exit__/__del__ dict-presence"
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "io.BytesIO defines __sizeof__ in its own __dict__ (True); all other public io classes do not."
    - "None of the io public classes define __length_hint__ — io streams are not length-hintable iterators."
    - "None of the io public classes define __floor__, __ceil__, or __trunc__ — io objects are not numeric."
    - "io.IOBase, RawIOBase, BufferedIOBase, TextIOBase are Python-level wrappers over _io C types."
    - "io.StringIO, io.FileIO do not override __sizeof__ at the Python level."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __sizeof__ dict-presence — io public classes
# io.BytesIO defines __sizeof__ to report its internal buffer size.
# All other public io classes inherit __sizeof__ from object (not overriding).
# ---------------------------------------------------------------------------

table io_extra1981.sizeof_protocol:
  description: "io public class __dict__.__contains__('__sizeof__') — BytesIO True, rest False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1981

  columns: [id, function, args, expected]
  rows:
    - ["io1981001", "io.IOBase.__dict__.__contains__",         ["__sizeof__"], false]
    - ["io1981002", "io.RawIOBase.__dict__.__contains__",      ["__sizeof__"], false]
    - ["io1981003", "io.BufferedIOBase.__dict__.__contains__", ["__sizeof__"], false]
    - ["io1981004", "io.TextIOBase.__dict__.__contains__",     ["__sizeof__"], false]
    - ["io1981005", "io.BytesIO.__dict__.__contains__",        ["__sizeof__"], true]
    - ["io1981006", "io.StringIO.__dict__.__contains__",       ["__sizeof__"], false]
    - ["io1981007", "io.FileIO.__dict__.__contains__",         ["__sizeof__"], false]

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — io public classes
# __length_hint__ is an iterator protocol method (PEP 424).
# io stream classes are not iterators in the length-hint sense; none define it.
# ---------------------------------------------------------------------------

table io_extra1981.length_hint_protocol:
  description: "io public class __dict__.__contains__('__length_hint__') — all False (not length-hintable iterators)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1981

  columns: [id, function, args, expected]
  rows:
    - ["io1981008",  "io.IOBase.__dict__.__contains__",         ["__length_hint__"], false]
    - ["io1981009",  "io.RawIOBase.__dict__.__contains__",      ["__length_hint__"], false]
    - ["io1981010", "io.BufferedIOBase.__dict__.__contains__", ["__length_hint__"], false]
    - ["io1981011", "io.TextIOBase.__dict__.__contains__",     ["__length_hint__"], false]
    - ["io1981012", "io.BytesIO.__dict__.__contains__",        ["__length_hint__"], false]
    - ["io1981013", "io.StringIO.__dict__.__contains__",       ["__length_hint__"], false]
    - ["io1981014", "io.FileIO.__dict__.__contains__",         ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# __floor__ dict-presence — io public classes
# io stream classes are not numeric types; no math rounding protocol applies.
# ---------------------------------------------------------------------------

table io_extra1981.floor_protocol:
  description: "io public class __dict__.__contains__('__floor__') — all False (non-numeric types)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io1981

  columns: [id, function, args, expected]
  rows:
    - ["io1981015", "io.IOBase.__dict__.__contains__",         ["__floor__"], false]
    - ["io1981016", "io.RawIOBase.__dict__.__contains__",      ["__floor__"], false]
    - ["io1981017", "io.BufferedIOBase.__dict__.__contains__", ["__floor__"], false]
    - ["io1981018", "io.TextIOBase.__dict__.__contains__",     ["__floor__"], false]
    - ["io1981019", "io.BytesIO.__dict__.__contains__",        ["__floor__"], false]
    - ["io1981020", "io.StringIO.__dict__.__contains__",       ["__floor__"], false]
    - ["io1981021", "io.FileIO.__dict__.__contains__",         ["__floor__"], false]

