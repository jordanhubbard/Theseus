spec: struct_extra210
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "verified with Python 3.14.3."
    - "struct.pack('!H', 1, 2) raises struct.error: pack expected 1 items for packing (got 2)."
    - "struct.pack('!B', 300) raises struct.error: 'B' format requires 0 <= number <= 255."
    - "struct.unpack('!H', b'x') raises struct.error: unpack requires a buffer of 2 bytes."
    - "struct.pack('!Z') raises struct.error: bad char in struct format (via calcsize)."
    - "struct.calcsize('!Z') raises struct.error: bad char in struct format."
    - "struct.error is a subclass of Exception; its __name__ is 'error'."
    - "All exception types verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack — raises struct.error on argument count mismatch
#
# struct.pack('!H', 1, 2) — format '!H' expects 1 value, got 2
# struct.pack('!B', 300) — 300 exceeds unsigned char range 0..255
# ---------------------------------------------------------------------------

table struct_extra210.pack_bad_args_raises:
  description: "struct.pack raises struct.error for argument count mismatch and out-of-range values in structerr210 namespace — wave 210 theme: struct.pack('!H', 1, 2) raises struct.error; struct.pack('!B', 300) raises struct.error; struct.pack enforces both count and value range constraints; verified with Python 3.14.3"
  kind: python_call_raises
  category: errors
  id_prefix: structerr210

  columns: [id, function, args, expected, description]
  rows:
    - [pack_too_many_args,    struct.pack, ["!H", 1, 2],  struct.error, "struct.pack('!H', 1, 2) raises struct.error — format '!H' expects 1 value but got 2"]
    - [pack_value_too_large,  struct.pack, ["!B", 300],   struct.error, "struct.pack('!B', 300) raises struct.error — 300 is out of range for unsigned char format 'B' (0..255)"]

# ---------------------------------------------------------------------------
# struct.unpack — raises struct.error on buffer size mismatch
# struct.calcsize — raises struct.error on invalid format character
# ---------------------------------------------------------------------------

table struct_extra210.unpack_and_calcsize_bad_args_raises:
  description: "struct.unpack raises struct.error for wrong buffer size and struct.calcsize raises struct.error for invalid format character in structerr210a namespace — wave 210 theme: struct.unpack('!H', b'x') raises struct.error; struct.calcsize('!Z') raises struct.error; format '!H' requires 2 bytes but b'x' is 1 byte; 'Z' is not a valid struct format character; verified with Python 3.14.3"
  kind: python_call_raises
  category: errors
  id_prefix: structerr210a

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_short_buffer,     struct.unpack,    ["!H", {type: bytes_ascii, value: "x"}],  struct.error, "struct.unpack('!H', b'x') raises struct.error — format '!H' requires 2 bytes but buffer has only 1"]
    - [calcsize_invalid_char,   struct.calcsize,  ["!Z"],                                   struct.error, "struct.calcsize('!Z') raises struct.error — 'Z' is not a valid struct format character"]

# ---------------------------------------------------------------------------
# struct.pack with invalid format character — standalone invariant
# ---------------------------------------------------------------------------

invariant struct_extra210.pack_invalid_format_char_raises:
  description: "struct.pack('!Z', 0) raises struct.error — 'Z' is not a recognized struct format character; struct.pack validates the format string before packing any values; invalid characters in the format string raise struct.error with 'bad char in struct format'; verified with Python 3.14.3"
  category: errors
  kind: python_call_raises
  function: struct.pack
  args: ["!Z", 0]
  expected_exception: struct.error

# ---------------------------------------------------------------------------
# struct.error class identity
# ---------------------------------------------------------------------------

table struct_extra210.struct_error_identity:
  description: "struct.error class name identity in structerr210b namespace — wave 210 theme: struct.error.__name__ == 'error'; struct.error is the exception class raised by all struct packing and unpacking errors; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: structerr210b

  columns: [id, function, args, expected, description]
  rows:
    - [struct_error_name,  struct.error.__name__.__eq__,  ["error"],  true, "struct.error.__name__ == 'error' — the struct exception class is named 'error'"]
