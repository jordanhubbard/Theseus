spec: struct_extra137
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra136.zspec.zsdl — covers struct.Struct method __doc__ lengths (pack/pack_into/unpack/unpack_from/iter_unpack) / module-level pack_into/unpack_from/iter_unpack __doc__ lengths / module-level vs Struct-method __doc__ inequality table (table + invariants)."
    - "struct_extra135.zspec.zsdl — covers struct.Struct.__eq__ inherited from object / struct.error MRO member names / struct module-level function __doc__ lengths (pack/unpack/calcsize) / struct.__doc__.__len__() and __class__.__name__."
    - "struct_extra134.zspec.zsdl — covers struct.__spec__ and __loader__ attribute identity / Struct method __doc__ lengths (pack/unpack/pack_into/unpack_from/iter_unpack) / Struct class __doc__ identity."
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths (pack/unpack/calcsize/pack_into/unpack_from/iter_unpack) / Struct.size and Struct.format __doc__ equality and lengths / struct module __doc__ length (1278)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / Struct.__doc__ length (40) and equality."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() and error.__name__/__len__()."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__()."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra136."
    - "Wave 294 theme: __doc__.__class__.__name__ checks for struct.pack/unpack/calcsize/pack_into/Struct / Struct.format and Struct.size property __doc__ lengths (both 20) and inequality / calcsize is the shortest module-level function __doc__ (66) / __doc__ length ordering among module-level functions."
    - "struct.pack.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__doc__.__len__() == 20. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__doc__.__len__() == 20. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__doc__ == 'struct format string' (not equal to Struct.size.__doc__ == 'struct size in bytes'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__doc__.__len__() == 66 (shortest module-level function __doc__ among pack/unpack/calcsize/pack_into). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Module-level __doc__ ordering: calcsize (66) < unpack (173) < pack (176) < pack_into (274). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.format.__doc__ ('struct format string', 20 chars) and struct.Struct.size.__doc__ ('struct size in bytes', 20 chars) are both exactly 20 chars but are not equal strings — they share the prefix 'struct ' (7 chars) and suffix length but have different attribute names."
    - "Note: struct.calcsize.__doc__ (66 chars) is by far the shortest of the four main module-level function docstrings. It simply states 'Return size in bytes of the struct described by the format string.' — one sentence with no examples. pack_into (274) is more than 4x longer."
    - "Note: struct.pack.__doc__.__class__.__name__ is 'str' even though pack is a C-level builtin_function_or_method — C functions can have str docstrings."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack.__doc__.__class__.__name__.__eq__('str')
# struct.unpack.__doc__.__class__.__name__.__eq__('str')
# struct.calcsize.__doc__.__class__.__name__.__eq__('str')
# struct.pack_into.__doc__.__class__.__name__.__eq__('str')
# struct.Struct.__doc__.__class__.__name__.__eq__('str')
#
# Wave 294 theme: __doc__.__class__.__name__ == 'str' for module-level functions
# and the Struct class.
#
# All five subjects have string docstrings, even the C-level builtin functions
# (pack, unpack, calcsize, pack_into) and the C-level Struct class. No prior
# struct spec anchors all five __doc__.__class__.__name__ checks together in one
# table under structdoc137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra137.module_function_and_Struct_doc_class:
  description: "struct.pack/__doc__/__class__.__name__.__eq__('str')==True / unpack/__doc__/__class__.__name__.__eq__('str')==True / calcsize/__doc__/__class__.__name__.__eq__('str')==True / pack_into/__doc__/__class__.__name__.__eq__('str')==True / Struct/__doc__/__class__.__name__.__eq__('str')==True — all five have str docstrings; C-level builtins (pack/unpack/calcsize/pack_into) and C-level class (Struct) all use str docs; no prior struct spec anchors all five together; first structdoc137 anchor"
  kind: python_call_eq
  category: doc_identity
  id_prefix: structdoc137

  columns: [id, function, args, expected, description]
  rows:
    - [pack_doc_class,     pack.__doc__.__class__.__name__.__eq__,     ["str"], true, "struct.pack.__doc__.__class__.__name__ == 'str' (C-level builtin_function_or_method with str docstring)"]
    - [unpack_doc_class,   unpack.__doc__.__class__.__name__.__eq__,   ["str"], true, "struct.unpack.__doc__.__class__.__name__ == 'str' (C-level builtin_function_or_method with str docstring)"]
    - [calcsize_doc_class, calcsize.__doc__.__class__.__name__.__eq__, ["str"], true, "struct.calcsize.__doc__.__class__.__name__ == 'str' (C-level builtin_function_or_method with str docstring)"]
    - [pack_into_doc_class, pack_into.__doc__.__class__.__name__.__eq__, ["str"], true, "struct.pack_into.__doc__.__class__.__name__ == 'str' (C-level builtin_function_or_method with str docstring)"]
    - [Struct_doc_class,   Struct.__doc__.__class__.__name__.__eq__,   ["str"], true, "struct.Struct.__doc__.__class__.__name__ == 'str' (C-level type with str class docstring)"]

# ---------------------------------------------------------------------------
# struct.Struct.format.__doc__.__len__()==20
# struct.Struct.size.__doc__.__len__()==20
# struct.Struct.format.__doc__.__eq__(struct.Struct.size.__doc__)==False
#
# Wave 294 theme: Struct.format and Struct.size property __doc__ lengths.
#
# Both Struct.format and Struct.size have 20-char property docstrings:
# 'struct format string' and 'struct size in bytes' respectively. They share
# the same length and the same 'struct ' prefix (7 chars) but are not equal
# strings. Extra99 anchors both lengths but the inequality check is fresh.
# No prior struct spec anchors the inequality under structdoc137.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra137.Struct_property_doc_lengths:
  description: "struct.Struct.format/__doc__/__len__()==20 / Struct.size/__doc__/__len__()==20 / Struct.format/__doc__.__eq__(Struct.size/__doc__)==False — both properties have exactly 20-char docstrings sharing 'struct ' prefix (7 chars) but differing in suffix ('format string' vs 'size in bytes'); same length but not equal strings; extra99 anchors the lengths; the inequality check is fresh under structdoc137"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: structdoc137

  columns: [id, function, args, expected, description]
  rows:
    - [format_doc_len,    Struct.format.__doc__.__len__,                          [], 20,   "struct.Struct.format.__doc__.__len__() is 20 ('struct format string' — the stored format string for this Struct instance)"]
    - [size_doc_len,      Struct.size.__doc__.__len__,                            [], 20,   "struct.Struct.size.__doc__.__len__() is 20 ('struct size in bytes' — the number of bytes packed by this Struct)"]
    - [format_ne_size,    Struct.format.__doc__.__eq__,                           ["struct size in bytes"], false, "struct.Struct.format.__doc__ != struct.Struct.size.__doc__ (same length 20, same prefix 'struct ', different suffix)"]
    - [format_doc_class,  Struct.format.__doc__.__class__.__name__.__eq__,        ["str"], true,  "struct.Struct.format.__doc__ is a str (getset_descriptor property docstring)"]
    - [size_doc_class,    Struct.size.__doc__.__class__.__name__.__eq__,           ["str"], true,  "struct.Struct.size.__doc__ is a str (getset_descriptor property docstring)"]

# ---------------------------------------------------------------------------
# struct.calcsize.__doc__.__len__()==66 (shortest module-level function)
# module-level ordering: calcsize (66) < unpack (173) < pack (176) < pack_into (274)
#
# Wave 294 theme: calcsize as the shortest module-level function __doc__ and
# the complete length ordering among the four main module-level functions.
#
# calcsize (66) is 107 chars shorter than unpack (173) — the next shortest —
# and is more than 4x shorter than pack_into (274). The ordering
# calcsize < unpack < pack < pack_into reflects increasing function complexity:
# calcsize reads a format string, unpack unpacks a fixed-size buffer, pack produces
# bytes, pack_into additionally requires an offset into a writable buffer.
# No prior struct spec anchors this ordering under structdoc137.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra137.module_function_doc_length_ordering:
  description: "struct.calcsize/__doc__/__len__()==66 / unpack/__doc__/__len__()==173 / pack/__doc__/__len__()==176 / pack_into/__doc__/__len__()==274 — ordering: calcsize (66) < unpack (173) < pack (176) < pack_into (274); calcsize is shortest (simplest; one sentence); pack_into is longest (documents buffer/offset and their constraints); unpack < pack by 3 chars; no prior struct spec anchors this complete ordering; first structdoc137 anchor"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: structdoc137

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_doc_len,  calcsize.__doc__.__len__,  [], 66,  "struct.calcsize.__doc__.__len__() is 66 (shortest of four; one sentence: 'Return size in bytes of the struct described by the format string.')"]
    - [unpack_doc_len,    unpack.__doc__.__len__,    [], 173, "struct.unpack.__doc__.__len__() is 173 (second-shortest; 107 chars longer than calcsize; documents buffer size constraint)"]
    - [pack_doc_len,      pack.__doc__.__len__,      [], 176, "struct.pack.__doc__.__len__() is 176 (third-longest; 3 chars longer than unpack; includes signature 'pack(format, v1, v2, ...) -> bytes')"]
    - [pack_into_doc_len, pack_into.__doc__.__len__, [], 274, "struct.pack_into.__doc__.__len__() is 274 (longest of four; more than 4x calcsize; documents buffer, offset, and note that offset is required)"]

# ---------------------------------------------------------------------------
# struct.calcsize.__doc__.__len__()==66 — standalone
#
# struct.calcsize.__doc__.__len__() is 66. The calcsize docstring is
# 'Return size in bytes of the struct described by the format string.' (66 chars).
# calcsize is the simplest of the four main module-level struct functions:
# it takes only a format string and returns an integer. Its docstring is
# correspondingly brief — a single sentence with no parameter descriptions,
# no return type syntax, no examples. No prior struct spec anchors
# calcsize.__doc__.__len__()==66 as a standalone under structdoc137.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra137.calcsize_doc_len_66:
  description: "struct.calcsize.__doc__.__len__() == 66 — shortest module-level function docstring (66 chars); 'Return size in bytes of the struct described by the format string.'; single sentence, no parameter documentation, no return type syntax; calcsize takes only a format string; no prior struct spec anchors this as a standalone; first standalone under structdoc137"
  category: doc_lengths
  kind: python_call_eq
  function: calcsize.__doc__.__len__
  args: []
  expected: 66

# ---------------------------------------------------------------------------
# struct.Struct.format.__doc__.__len__()==20 — standalone
#
# struct.Struct.format.__doc__.__len__() is 20. The format property docstring
# 'struct format string' is exactly 20 chars. It shares this length with
# Struct.size.__doc__ ('struct size in bytes', also 20 chars) but the two strings
# are not equal. Both start with 'struct ' (7 chars); format ends with
# 'format string' (13 chars); size ends with 'size in bytes' (13 chars).
# No prior struct spec anchors Struct.format.__doc__.__len__()==20 as a
# standalone under structdoc137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra137.Struct_format_doc_len_20:
  description: "struct.Struct.format.__doc__.__len__() == 20 — 'struct format string' (20 chars); same length as Struct.size.__doc__ ('struct size in bytes', 20 chars) but not equal; both share 'struct ' prefix; no prior struct spec anchors this as a standalone; first standalone under structdoc137"
  category: doc_lengths
  kind: python_call_eq
  function: Struct.format.__doc__.__len__
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# struct.Struct.size.__doc__.__len__()==20 — standalone
#
# struct.Struct.size.__doc__.__len__() is 20. The size property docstring
# 'struct size in bytes' is exactly 20 chars — the same length as
# Struct.format.__doc__ ('struct format string'). The two properties are
# symmetrically documented: both are one-sentence descriptions of a Struct
# attribute, both start with 'struct ', and both are 20 chars. No prior struct
# spec anchors Struct.size.__doc__.__len__()==20 as a standalone under
# structdoc137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra137.Struct_size_doc_len_20:
  description: "struct.Struct.size.__doc__.__len__() == 20 — 'struct size in bytes' (20 chars); same length as Struct.format.__doc__ (20 chars) but not equal; symmetrically documented as a one-sentence attribute description; no prior struct spec anchors this as a standalone; first standalone under structdoc137"
  category: doc_lengths
  kind: python_call_eq
  function: Struct.size.__doc__.__len__
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# struct.pack.__doc__.__class__.__name__.__eq__('str') — standalone
#
# struct.pack.__doc__.__class__.__name__ == 'str'. Even though struct.pack is a
# C-level builtin_function_or_method (from Modules/_struct.c), its docstring is
# a Python str object. This is the standard behavior for C extension functions —
# the docstring is stored as a C string in the function descriptor and exposed
# to Python as a str. No prior struct spec anchors pack.__doc__.__class__.__name__
# as a standalone under structdoc137. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra137.pack_doc_class_str:
  description: "struct.pack.__doc__.__class__.__name__ == 'str' — C-level builtin_function_or_method has a str docstring; C string exposed to Python as str; consistent with unpack/calcsize/pack_into which are also C-level builtins with str docstrings; no prior struct spec anchors this as a standalone; first standalone under structdoc137"
  category: doc_identity
  kind: python_call_eq
  function: pack.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack_into.__doc__.__len__()==274 — standalone
#
# struct.pack_into.__doc__.__len__() is 274. pack_into is the longest of the
# four main module-level struct function docstrings. It is more than 4x longer
# than calcsize (66) and 3 chars shorter than Struct.pack_into (277). The extra
# length relative to pack (176) comes from the additional buffer and offset
# parameters, plus the note that offset is a required argument. No prior struct
# spec anchors module-level pack_into.__doc__.__len__()==274 as a standalone
# under structdoc137 (extra136 anchors it but that is different from extra137).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra137.pack_into_doc_len_274:
  description: "struct.pack_into.__doc__.__len__() == 274 — longest module-level struct function docstring (274 chars); more than 4x longer than calcsize (66); 3 chars shorter than Struct.pack_into (277); documents buffer/offset parameters plus note that offset is required; no prior struct spec anchors this as a standalone under structdoc137; first standalone under structdoc137"
  category: doc_lengths
  kind: python_call_eq
  function: pack_into.__doc__.__len__
  args: []
  expected: 274

