spec: theseus_threading_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_threading_cr2)
blocks: threading

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html"
  notes:
    - "Clean-room synchronization primitives (no actual threads). Do NOT import threading."
    - "Event: manual-reset event with set/clear/is_set/wait."
    - "Barrier: n-party barrier; wait() blocks until n parties arrive."
    - "BoundedSemaphore(n): like Semaphore but raises if released more than n times."
    - "Condition: condition variable with wait/notify/notify_all."
    - "threading2_event(): Event; set(); is_set() == True."
    - "threading2_barrier(): Barrier(1); wait() returns immediately."
    - "threading2_bounded_semaphore(): BoundedSemaphore(1); acquire(); release() ok; extra release raises."
    - "Export: Event, Barrier, BoundedSemaphore, Condition."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_threading_cr2.event:
  description: "Event().set(); is_set() == True"
  category: event
  kind: python_call_eq
  function: threading2_event
  args: []
  expected: true

invariant theseus_threading_cr2.barrier:
  description: "Barrier(1).wait() returns 0 (party index)"
  category: barrier
  kind: python_call_eq
  function: threading2_barrier
  args: []
  expected: 0

invariant theseus_threading_cr2.bounded_semaphore:
  description: "BoundedSemaphore(1): acquire then release succeeds; second release raises ValueError"
  category: semaphore
  kind: python_call_eq
  function: threading2_bounded_semaphore
  args: []
  expected: true
