spec: struct_extra1591
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — descriptor protocol checks via __dict__.__contains__ for struct.Struct and struct module-level callables"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for descriptor protocol"
    - "struct.Struct is a C extension type for pre-compiled format strings; it does not implement the descriptor protocol (__get__, __set__, __delete__)."
    - "struct.Struct exposes format and size as read-only C-level attributes (getset_descriptor), not property objects."
    - "Module-level functions (struct.pack, struct.unpack, etc.) are built-in functions, not Python lambdas."
  created_at: "2026-04-12"
error_model: python_exceptions

table struct_extra1591.struct_class_no_descriptor:
  description: "struct.Struct does not define descriptor protocol methods in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1591nd

  columns: [id, function, args, expected]
  rows:
    - ["st1591nd001", "struct.Struct.__dict__.__contains__", ["__get__"],    false]
    - ["st1591nd002", "struct.Struct.__dict__.__contains__", ["__set__"],    false]
    - ["st1591nd003", "struct.Struct.__dict__.__contains__", ["__delete__"], false]
    - ["st1591nd004", "struct.Struct.__dict__.__contains__", ["__set_name__"], false]
    - ["st1591nd005", "struct.Struct.__dict__.__contains__", ["format"],     true]
    - ["st1591nd006", "struct.Struct.__dict__.__contains__", ["size"],       true]
    - ["st1591nd007", "struct.Struct.__dict__.__contains__", ["pack"],       true]
    - ["st1591nd008", "struct.Struct.__dict__.__contains__", ["unpack"],     true]
    - ["st1591nd009", "struct.Struct.__dict__.__contains__", ["pack_into"],  true]
    - ["st1591nd010", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st1591nd011", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st1591nd012", "struct.Struct.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["st1591nd013", "struct.Struct.__name__.__eq__",       ["Struct"],    true]
    - ["st1591nd014", "struct.Struct.__module__.__eq__",     ["_struct"],   true]
    - ["st1591nd015", "struct.Struct.__bases__.__len__",     [],            1]
    - ["st1591nd016", "struct.Struct.__mro__.__class__.__name__.__eq__", ["tuple"], true]
    - ["st1591nd017", "struct.Struct.__dict__.__contains__", ["__new__"],    true]
    - ["st1591nd018", "struct.Struct.__dict__.__contains__", ["__repr__"],   false]
    - ["st1591nd019", "struct.Struct.__dict__.__contains__", ["__init__"],   false]
    - ["st1591nd020", "struct.Struct.__dict__.__contains__", ["__weakref__"], false]
    - ["st1591nd021", "struct.Struct.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["st1591nd022", "struct.Struct.__dict__.__contains__", ["__doc__"],    true]

table struct_extra1591.struct_protocol_methods:
  description: "struct.Struct instances expose pack/unpack methods and read-only format/size attributes"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1591pm

  columns: [id, function, args, expected]
  rows:
    - ["st1591pm001", "struct.Struct.__dict__.__contains__", ["pack"],        true]
    - ["st1591pm002", "struct.Struct.__dict__.__contains__", ["unpack"],      true]
    - ["st1591pm003", "struct.Struct.__dict__.__contains__", ["pack_into"],   true]
    - ["st1591pm004", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st1591pm005", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st1591pm006", "struct.Struct.__dict__.__contains__", ["format"],      true]
    - ["st1591pm007", "struct.Struct.__dict__.__contains__", ["size"],        true]
    - ["st1591pm008", "struct.Struct.__dict__['format'].__class__.__name__.__eq__", ["getset_descriptor"], true]
    - ["st1591pm009", "struct.Struct.__dict__['size'].__class__.__name__.__eq__",   ["getset_descriptor"], true]
    - ["st1591pm010", "isinstance(struct.Struct.__dict__['format'], property).__eq__", [false], true]
    - ["st1591pm011", "isinstance(struct.Struct.__dict__['size'], property).__eq__",   [false], true]
    - ["st1591pm012", "struct.Struct.__dict__['format'].__class__.__mro__.__class__.__name__.__eq__", ["tuple"], true]
    - ["st1591pm013", "hasattr(struct.Struct.__dict__['format'], '__get__').__eq__",   [true],  true]
    - ["st1591pm014", "hasattr(struct.Struct.__dict__['size'], '__get__').__eq__",     [true],  true]
    - ["st1591pm015", "hasattr(struct.Struct.__dict__['format'], '__set__').__eq__",   [false], true]
    - ["st1591pm016", "hasattr(struct.Struct.__dict__['size'], '__set__').__eq__",     [false], true]
    - ["st1591pm017", "callable(struct.Struct.__dict__['pack']).__eq__",               [false], true]
    - ["st1591pm018", "struct.Struct.__dict__['pack'].__class__.__name__.__eq__",      ["method_descriptor"], true]
    - ["st1591pm019", "struct.Struct.__dict__['unpack'].__class__.__name__.__eq__",    ["method_descriptor"], true]
    - ["st1591pm020", "struct.Struct.__dict__['iter_unpack'].__class__.__name__.__eq__", ["method_descriptor"], true]
    - ["st1591pm021", "struct.Struct.__dict__.__contains__", ["__sizeof__"],  true]
    - ["st1591pm022", "struct.Struct.__dict__.__contains__", ["__class__"],   false]

table struct_extra1591.struct_module_callables:
  description: "struct module-level functions are built-in callables, not Python functions"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st1591mc

  columns: [id, function, args, expected]
  rows:
    - ["st1591mc001", "callable(struct.pack).__eq__",                               [true],  true]
    - ["st1591mc002", "callable(struct.unpack).__eq__",                             [true],  true]
    - ["st1591mc003", "callable(struct.calcsize).__eq__",                           [true],  true]
    - ["st1591mc004", "callable(struct.pack_into).__eq__",                          [true],  true]
    - ["st1591mc005", "callable(struct.unpack_from).__eq__",                        [true],  true]
    - ["st1591mc006", "callable(struct.iter_unpack).__eq__",                        [true],  true]
    - ["st1591mc007", "isinstance(struct.pack, type(lambda: None)).__eq__",         [false], true]
    - ["st1591mc008", "isinstance(struct.unpack, type(lambda: None)).__eq__",       [false], true]
    - ["st1591mc009", "isinstance(struct.calcsize, type(lambda: None)).__eq__",     [false], true]
    - ["st1591mc010", "struct.pack.__class__.__name__.__eq__",                      ["builtin_function_or_method"], true]
    - ["st1591mc011", "struct.unpack.__class__.__name__.__eq__",                    ["builtin_function_or_method"], true]
    - ["st1591mc012", "struct.calcsize.__class__.__name__.__eq__",                  ["builtin_function_or_method"], true]
    - ["st1591mc013", "struct.pack_into.__class__.__name__.__eq__",                 ["builtin_function_or_method"], true]
    - ["st1591mc014", "struct.unpack_from.__class__.__name__.__eq__",               ["builtin_function_or_method"], true]
    - ["st1591mc015", "struct.iter_unpack.__class__.__name__.__eq__",               ["builtin_function_or_method"], true]
    - ["st1591mc016", "hasattr(struct.pack, '__get__').__eq__",                     [true],  true]
    - ["st1591mc017", "hasattr(struct.pack, '__set__').__eq__",                     [false], true]
    - ["st1591mc018", "hasattr(struct.pack, '__delete__').__eq__",                  [false], true]
    - ["st1591mc019", "struct.pack.__module__.__eq__",                              ["_struct"], true]
    - ["st1591mc020", "struct.unpack.__module__.__eq__",                            ["_struct"], true]
    - ["st1591mc021", "struct.calcsize.__module__.__eq__",                          ["_struct"], true]
    - ["st1591mc022", "struct.error.__name__.__eq__",                               ["error"], true]
    - ["st1591mc023", "issubclass(struct.error, Exception).__eq__",                 [true],  true]
    - ["st1591mc024", "struct.error.__dict__.__contains__",                         ["__get__"], false]
    - ["st1591mc025", "struct.error.__dict__.__contains__",                         ["__set__"], false]
