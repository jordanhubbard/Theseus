spec: uuid_extra1306
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — UUID objects according to RFC 4122"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "Wave 534 (_extra1306): focuses on exception-raising behavior for bad inputs."
    - "uuid.UUID('not-a-uuid') raises ValueError: badly formed hexadecimal UUID string."
    - "uuid.UUID('') raises ValueError: badly formed hexadecimal UUID string."
    - "uuid.UUID('tooshort') raises ValueError: badly formed hexadecimal UUID string."
    - "uuid.UUID('{xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx}') raises ValueError (invalid literal for int() with base 16)."
    - "uuid.uuid3(42, 'name') raises AttributeError: 'int' object has no attribute 'bytes'."
    - "uuid.uuid5(42, 'name') raises AttributeError: 'int' object has no attribute 'bytes'."
    - "uuid.uuid3('bad', 'name') raises AttributeError: 'str' object has no attribute 'bytes'."
    - "uuid.uuid3(None, 'name') raises AttributeError: 'NoneType' object has no attribute 'bytes'."
    - "uuid.UUID(42) raises AttributeError because the hex parameter is treated as a string and 42 has no .replace()."
    - "uuid.UUID() (no args) raises TypeError: one of hex, bytes, bytes_le, fields, or int must be given."
    - "uuid.uuid4(42) raises TypeError: uuid4() takes 0 positional arguments but 1 was given."
    - "uuid.uuid3('name_only') raises TypeError: uuid3() missing 1 required positional argument: 'name'."
    - "In Python 3.14, UUID versions 1-8 are accepted; version 0 and negative raise ValueError."
    - "All exceptions verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table uuid_extra1306.constructor_bad_hex_errors:
  description: "uuid.UUID raises ValueError on malformed or invalid hex strings (first positional arg)"
  kind: python_call_raises
  category: value_errors
  id_prefix: uu1306cv
  columns: [id, function, args, exception]
  rows:
    - [uu1306cv001, uuid.UUID, ["not-a-uuid"],                                      "ValueError"]
    - [uu1306cv002, uuid.UUID, ["{xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx}"],           "ValueError"]
    - [uu1306cv003, uuid.UUID, ["zzzzzzzz-zzzz-zzzz-zzzz-zzzzzzzzzzzz"],            "ValueError"]
    - [uu1306cv004, uuid.UUID, ["tooshort"],                                         "ValueError"]
    - [uu1306cv005, uuid.UUID, ["12345678-1234-1234-1234-12345678901z"],             "ValueError"]
    - [uu1306cv006, uuid.UUID, [""],                                                 "ValueError"]

table uuid_extra1306.namespace_attr_errors:
  description: "uuid.uuid3 and uuid.uuid5 raise AttributeError when namespace argument is not a UUID"
  kind: python_call_raises
  category: attr_errors
  id_prefix: uu1306ns
  columns: [id, function, args, exception]
  rows:
    - [uu1306ns001, uuid.uuid3, [42,       "name"],    "AttributeError"]
    - [uu1306ns002, uuid.uuid5, [42,       "name"],    "AttributeError"]
    - [uu1306ns003, uuid.uuid3, ["bad",    "name"],    "AttributeError"]
    - [uu1306ns004, uuid.uuid5, ["bad",    "name"],    "AttributeError"]
    - [uu1306ns005, uuid.uuid3, [null,     "name"],    "AttributeError"]
    - [uu1306ns006, uuid.uuid5, [null,     "name"],    "AttributeError"]

table uuid_extra1306.misc_type_errors:
  description: "uuid functions raise TypeError or AttributeError when called with wrong argument counts or types"
  kind: python_call_raises
  category: type_errors
  id_prefix: uu1306te
  columns: [id, function, args, exception]
  rows:
    - [uu1306te001, uuid.UUID,  [],                 "TypeError"]
    - [uu1306te002, uuid.uuid3, ["name_only"],      "TypeError"]
    - [uu1306te003, uuid.uuid4, [42],               "TypeError"]
    - [uu1306te004, uuid.UUID,  [42],               "AttributeError"]
    - [uu1306te005, uuid.UUID,  [3.14],             "AttributeError"]
    - [uu1306te006, uuid.UUID,  [[]],               "AttributeError"]
