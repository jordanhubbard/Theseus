spec: abc_extra143
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers abc module-level identity attributes. abc.__spec__.name=='abc' (len=3). abc.__spec__.origin=='frozen' (abc is a frozen module in Python 3.14; origin is the string 'frozen' not a file path; has_location==False). abc.__loader__.__class__.__name__=='type' (the loader is FrozenImporter, a class whose metaclass is type). abc.__file__.__class__.__name__=='str' (the .py source file path is still accessible as a str even for frozen modules). abc.__package__.__eq__('')==True (len=0: abc is a top-level module, not in a sub-package, so __package__ is the empty string). abc.__spec__.origin.__len__()==6 ('frozen' is 6 chars). ABCMeta.__mro__.__len__()==3 ([ABCMeta, type, object]). ABC.__mro__.__len__()==2 ([ABC, object]). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc is a frozen module in Python 3.14 (abc.__spec__.origin=='frozen', abc.__spec__.has_location==False). abc.__loader__.__class__.__name__=='type' because FrozenImporter is itself a class (its metaclass is type). abc.__package__=='' (empty string, len=0) because abc is a top-level module. ABCMeta.__bases__[0].__name__=='type' (ABCMeta is a metaclass that subclasses type). ABC.__bases__[0].__name__=='object' (ABC is a simple helper class). abstractproperty.__bases__[0].__name__=='property' (abstractproperty subclasses property). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc module spec and loader attributes — extra143
#
# abc.__spec__.name.__eq__('abc')     == True   (len=3)
# abc.__spec__.origin.__eq__('frozen') == True  (len=6)
# abc.__spec__.origin.__class__.__name__.__eq__('str') == True
# abc.__loader__.__class__.__name__.__eq__('type') == True
# abc.__file__.__class__.__name__.__eq__('str')    == True
# abc.__package__.__eq__('')                       == True  (len=0)
# ---------------------------------------------------------------------------

table abc_extra143.abc_spec_and_loader:
  description: "abc module spec and loader attribute identity checks in abc_spec143 namespace — abc.__spec__.name.__eq__('abc')==True (len=3: the shortest module name among the batch; compare asyncio=7, multiprocessing=15, concurrent.futures=18); abc.__spec__.name.__len__()==3; abc.__spec__.origin.__eq__('frozen')==True (abc is a frozen module in Python 3.14; origin is the literal string 'frozen', not a file path); abc.__spec__.origin.__len__()==6 ('frozen' is 6 chars); abc.__spec__.origin.__class__.__name__.__eq__('str')==True (origin is a str); abc.__loader__.__class__.__name__.__eq__('type')==True (the loader for abc is FrozenImporter, which is itself a class; class of a class is type); abc.__file__.__class__.__name__.__eq__('str')==True (the source file path remains available as a str even though abc is frozen); abc.__package__.__eq__('')==True (abc is a top-level module, not in any sub-package, so __package__ is empty string, len=0); verified with Python 3.14.3"
  kind: python_call_eq
  category: module_identity
  id_prefix: abc_spec143

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,   abc.__spec__.name.__eq__,                       ["abc"],     true,  "abc.__spec__.name == 'abc' (len=3); verified with Python 3.14.3"]
    - [spec_name_len,  abc.__spec__.name.__len__,                       [],          3,     "abc.__spec__.name.__len__() == 3 (shortest in this batch); verified with Python 3.14.3"]
    - [spec_orig_eq,   abc.__spec__.origin.__eq__,                     ["frozen"],  true,  "abc.__spec__.origin == 'frozen' (abc is a frozen module in Python 3.14); verified with Python 3.14.3"]
    - [spec_orig_len,  abc.__spec__.origin.__len__,                     [],          6,     "abc.__spec__.origin.__len__() == 6 ('frozen'=6 chars); verified with Python 3.14.3"]
    - [spec_orig_cls,  abc.__spec__.origin.__class__.__name__.__eq__,  ["str"],     true,  "abc.__spec__.origin.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [ldr_cls,        abc.__loader__.__class__.__name__.__eq__,       ["type"],    true,  "abc.__loader__.__class__.__name__ == 'type' (FrozenImporter is a class, metaclass=type); verified with Python 3.14.3"]
    - [file_cls,       abc.__file__.__class__.__name__.__eq__,         ["str"],     true,  "abc.__file__.__class__.__name__ == 'str'; verified with Python 3.14.3"]
    - [pkg_eq,         abc.__package__.__eq__,                         [""],        true,  "abc.__package__ == '' (empty string, len=0, top-level module); verified with Python 3.14.3"]
    - [pkg_len,        abc.__package__.__len__,                         [],          0,     "abc.__package__.__len__() == 0 (empty string, not in a sub-package); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta and abc.ABC MRO checks — extra143
#
# abc.ABCMeta.__mro__.__len__()            == 3  ([ABCMeta, type, object])
# abc.ABCMeta.__bases__[0].__name__        == 'type'
# abc.ABCMeta.__name__.__len__()           == 7
# abc.ABCMeta.__module__.__eq__('abc')     == True
# abc.ABC.__mro__.__len__()                == 2  ([ABC, object])
# abc.ABC.__bases__[0].__name__.__eq__('object') == True
# abc.ABC.__name__.__len__()               == 3
# ---------------------------------------------------------------------------

table abc_extra143.abc_classes_mro:
  description: "abc.ABCMeta and abc.ABC MRO and identity checks in abc_spec143 namespace — abc.ABCMeta.__mro__.__len__()==3 (MRO is [ABCMeta, type, object]; ABCMeta subclasses type making it a metaclass, hence depth-3 chain: ABCMeta->type->object); abc.ABCMeta.__bases__[0].__name__.__eq__('type')==True (ABCMeta's direct base is type); abc.ABCMeta.__name__.__eq__('ABCMeta')==True (len=7: 'A'+'B'+'C'+'M'+'e'+'t'+'a'=7); abc.ABCMeta.__name__.__len__()==7; abc.ABCMeta.__module__.__eq__('abc')==True (defined in Lib/abc.py); abc.ABC.__mro__.__len__()==2 (MRO is [ABC, object]; ABC is a simple helper class that uses ABCMeta as its metaclass, it subclasses object directly); abc.ABC.__bases__[0].__name__.__eq__('object')==True (ABC's direct base is object); abc.ABC.__name__.__eq__('ABC')==True (len=3: 'A'+'B'+'C'=3); abc.ABC.__name__.__len__()==3; abc.ABC.__module__.__eq__('abc')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc_spec143a

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_mro_len,   abc.ABCMeta.__mro__.__len__,                       [],         3,     "abc.ABCMeta.__mro__.__len__() == 3 ([ABCMeta, type, object]); verified with Python 3.14.3"]
    - [abcmeta_base_eq,   "abc.ABCMeta.__bases__[0].__name__.__eq__",        ["type"],   true,  "abc.ABCMeta.__bases__[0].__name__ == 'type' (ABCMeta subclasses type); verified with Python 3.14.3"]
    - [abcmeta_name_eq,   abc.ABCMeta.__name__.__eq__,                       ["ABCMeta"], true,  "abc.ABCMeta.__name__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [abcmeta_name_len,  abc.ABCMeta.__name__.__len__,                       [],         7,     "abc.ABCMeta.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [abcmeta_mod_eq,    abc.ABCMeta.__module__.__eq__,                      ["abc"],   true,  "abc.ABCMeta.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [abc_mro_len,       abc.ABC.__mro__.__len__,                            [],         2,     "abc.ABC.__mro__.__len__() == 2 ([ABC, object]); verified with Python 3.14.3"]
    - [abc_base_eq,       "abc.ABC.__bases__[0].__name__.__eq__",            ["object"], true,  "abc.ABC.__bases__[0].__name__ == 'object' (ABC subclasses object directly); verified with Python 3.14.3"]
    - [abc_name_eq,       abc.ABC.__name__.__eq__,                           ["ABC"],    true,  "abc.ABC.__name__ == 'ABC' (len=3); verified with Python 3.14.3"]
    - [abc_name_len,      abc.ABC.__name__.__len__,                           [],         3,     "abc.ABC.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [abc_mod_eq,        abc.ABC.__module__.__eq__,                          ["abc"],   true,  "abc.ABC.__module__ == 'abc' (len=3); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.abstractproperty and abc.get_cache_token identity — extra143
#
# abc.abstractproperty.__name__.__len__()               == 16
# abc.abstractproperty.__bases__[0].__name__.__eq__('property') == True
# abc.abstractproperty.__mro__.__len__()                == 3
# abc.get_cache_token.__qualname__.__len__()            == 15
# abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method') == True
# ---------------------------------------------------------------------------

table abc_extra143.abc_abstractproperty_and_cache_token:
  description: "abc.abstractproperty and abc.get_cache_token identity checks in abc_spec143 namespace — abc.abstractproperty.__name__.__eq__('abstractproperty')==True (len=16: 'abstractproperty' is 16 chars; abstractproperty is deprecated since Python 3.3 but still present); abc.abstractproperty.__name__.__len__()==16; abc.abstractproperty.__bases__[0].__name__.__eq__('property')==True (abstractproperty subclasses the built-in property descriptor); abc.abstractproperty.__mro__.__len__()==3 ([abstractproperty, property, object]; depth-3 chain); abc.abstractproperty.__module__.__eq__('abc')==True; abc.get_cache_token.__qualname__.__eq__('get_cache_token')==True (len=15: 'get_cache_token' is 15 chars; get_cache_token is a C-level builtin function from _abc.c that returns an opaque token indicating the current version of the ABC cache); abc.get_cache_token.__qualname__.__len__()==15; abc.get_cache_token.__class__.__name__.__eq__('builtin_function_or_method')==True (C-level function); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc_spec143b

  columns: [id, function, args, expected, description]
  rows:
    - [ap_name_eq,   abc.abstractproperty.__name__.__eq__,                       ["abstractproperty"], true,  "abc.abstractproperty.__name__ == 'abstractproperty' (len=16); verified with Python 3.14.3"]
    - [ap_name_len,  abc.abstractproperty.__name__.__len__,                       [],                  16,    "abc.abstractproperty.__name__.__len__() == 16; verified with Python 3.14.3"]
    - [ap_base_eq,   "abc.abstractproperty.__bases__[0].__name__.__eq__",        ["property"],         true,  "abc.abstractproperty.__bases__[0].__name__ == 'property' (subclasses built-in property); verified with Python 3.14.3"]
    - [ap_mro_len,   abc.abstractproperty.__mro__.__len__,                        [],                  3,     "abc.abstractproperty.__mro__.__len__() == 3 ([abstractproperty, property, object]); verified with Python 3.14.3"]
    - [ap_mod_eq,    abc.abstractproperty.__module__.__eq__,                      ["abc"],             true,  "abc.abstractproperty.__module__ == 'abc'; verified with Python 3.14.3"]
    - [gct_qn_eq,    abc.get_cache_token.__qualname__.__eq__,                     ["get_cache_token"],  true,  "abc.get_cache_token.__qualname__ == 'get_cache_token' (len=15); verified with Python 3.14.3"]
    - [gct_qn_len,   abc.get_cache_token.__qualname__.__len__,                    [],                  15,    "abc.get_cache_token.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [gct_cls_eq,   abc.get_cache_token.__class__.__name__.__eq__,              ["builtin_function_or_method"], true, "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method' (C-level); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra143
# ---------------------------------------------------------------------------

invariant abc_extra143.abc_spec_name_len_3:
  description: "abc.__spec__.name.__len__() == 3 — abc.__spec__.name is 'abc' (3 chars: 'a'+'b'+'c'=3); this is the shortest module name in this batch: abc=3, asyncio=7, multiprocessing=15, concurrent.futures=18; abc.__name__.__len__()==3 also; abc.__package__.__len__()==0 (empty string, top-level module); abc.__spec__.name.__eq__('abc')==True; abc.__spec__.origin.__eq__('frozen')==True (abc is frozen in Python 3.14); NEW in extra143: first standalone abc.__spec__.name length invariant in abc_spec143 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: abc.__spec__.name.__len__
  args: []
  expected: 3

invariant abc_extra143.abc_spec_origin_is_frozen:
  description: "abc.__spec__.origin.__eq__('frozen') returns True — abc.__spec__.origin is 'frozen' (6 chars); in Python 3.14 (and several earlier versions), the abc module is compiled into the interpreter as a frozen module; abc.__spec__.has_location==False (no filesystem location); abc.__spec__.origin.__class__.__name__=='str' (origin is a plain string); abc.__loader__.__class__.__name__=='type' (the FrozenImporter is a class, not an instance of some loader class); abc.__file__ still exists as a str (the source .py file path is available for reference even though the module runs from the frozen bytecode); NEW in extra143: first standalone abc.__spec__.origin 'frozen' equality invariant in abc_spec143 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: abc.__spec__.origin.__eq__
  args: ["frozen"]
  expected: true

invariant abc_extra143.abc_package_is_empty_string:
  description: "abc.__package__.__eq__('') returns True — abc.__package__ is the empty string '' (len=0); abc is a top-level module, not part of any sub-package, so __package__ is '' (the empty string) rather than 'abc'; this contrasts with asyncio.__package__=='asyncio', multiprocessing.__package__=='multiprocessing', and concurrent.futures.__package__=='concurrent.futures' (all packages set __package__ to their own name); abc.__package__.__len__()==0; abc.__spec__.name=='abc' (len=3); NEW in extra143: first standalone abc.__package__ empty-string equality invariant in abc_spec143 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: module_identity
  kind: python_call_eq
  function: abc.__package__.__eq__
  args: [""]
  expected: true

invariant abc_extra143.ABCMeta_mro_len_3:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — ABCMeta's MRO is [ABCMeta, type, object] (length=3); ABCMeta subclasses type (type is the default metaclass in Python); being a subclass of type makes ABCMeta a metaclass; the chain ABCMeta->type->object gives depth 3; contrast with abc.ABC.__mro__.__len__()==2 ([ABC, object], depth 2, ABC is a plain class); ABCMeta.__bases__[0].__name__=='type'; ABCMeta.__name__=='ABCMeta' (len=7); ABCMeta.__module__=='abc' (len=3); NEW in extra143: first standalone ABCMeta MRO length invariant in abc_spec143 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra143.ABC_mro_len_2:
  description: "abc.ABC.__mro__.__len__() == 2 — ABC's MRO is [ABC, object] (length=2); ABC is a simple helper class that uses ABCMeta as its metaclass; it subclasses object directly, making the MRO depth-2; this is the minimal MRO depth for any non-trivial Python class; ABC.__bases__[0].__name__=='object'; ABC.__name__=='ABC' (len=3); ABC.__module__=='abc' (len=3); contrasts with ABCMeta.__mro__.__len__()==3 ([ABCMeta, type, object]) and abstractproperty.__mro__.__len__()==3 ([abstractproperty, property, object]); NEW in extra143: first standalone ABC MRO length invariant in abc_spec143 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__mro__.__len__
  args: []
  expected: 2

invariant abc_extra143.abstractproperty_base_is_property:
  description: "abc.abstractproperty.__bases__[0].__name__.__eq__('property') returns True — abc.abstractproperty subclasses the built-in 'property' descriptor; abstractproperty is a class (abc.abstractproperty.__class__.__name__=='type') that inherits from the built-in property; abc.abstractproperty.__mro__.__len__()==3 ([abstractproperty, property, object]); abstractproperty has been deprecated since Python 3.3 in favour of using abstractmethod with property, but it remains in the module; abc.abstractproperty.__name__=='abstractproperty' (len=16); abc.abstractproperty.__module__=='abc' (len=3); NEW in extra143: first standalone abc.abstractproperty base class name invariant in abc_spec143 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "abc.abstractproperty.__bases__[0].__name__.__eq__"
  args: ["property"]
  expected: true

invariant abc_extra143.get_cache_token_qualname_len_15:
  description: "abc.get_cache_token.__qualname__.__len__() == 15 — abc.get_cache_token.__qualname__ is 'get_cache_token' (15 chars: 'get_cache_token' = 'get'=3+'_'=1+'cache'=5+'_'=1+'token'=5=15); abc.get_cache_token is a C-level builtin function from Modules/_abc.c; abc.get_cache_token.__class__.__name__=='builtin_function_or_method'; get_cache_token() returns an opaque integer token that changes whenever the virtual subclass registry is changed; this token can be used to implement caching of subclass checks; abc.get_cache_token.__qualname__.__eq__('get_cache_token')==True; NEW in extra143: first standalone abc.get_cache_token qualname length invariant in abc_spec143 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.get_cache_token.__qualname__.__len__
  args: []
  expected: 15

