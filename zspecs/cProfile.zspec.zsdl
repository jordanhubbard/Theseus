spec: cProfile
version: ">=3.0"
backend: python_module(cProfile)

docs: https://docs.python.org/3/library/profile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from: []
  notes:
    - "cProfile.Profile is a C extension class wrapping _lsprof.Profiler."
    - "Method attributes checked via unbound method objects on the class (not instances), so __name__ is accessible directly."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Raises standard Python exceptions; invalid usage raises TypeError or ValueError."
  stderr: "null"
  stickiness: "N/A"
