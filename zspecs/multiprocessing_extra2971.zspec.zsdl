# ---------------------------------------------------------------------------
# combined — all three operators for a cross-class sample
#
# Spot-checks __floor__, __ceil__, __index__ absence across a representative
# selection of multiprocessing classes in a single table for concise coverage.
# ---------------------------------------------------------------------------

table mp2971.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_Process_flr",       operator.contains, [Process.__dict__,                              "__floor__"], false]
    - ["comb_Process_ceil",      operator.contains, [Process.__dict__,                              "__ceil__"],  false]
    - ["comb_Process_idx",       operator.contains, [Process.__dict__,                              "__index__"], false]
    - ["comb_Pool_flr",          operator.contains, [multiprocessing.pool.Pool.__dict__,            "__floor__"], false]
