spec: mp2971
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.shared_ctypes.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 645 — theme: __floor__, __ceil__, __index__ dict-presence (floor, ceiling, integer-index)."
    - "Tests operator.contains(SomeClass.__dict__, '__floor__') etc. for multiprocessing classes."
    - "Classes covered: Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.ListProxy, managers.SetProxy, managers.DictProxy."
    - "None of these classes define __floor__, __ceil__, or __index__ in their own __dict__."
    - "pool.Pool.__module__ == 'multiprocessing.pool'; managers.*.__module__ == 'multiprocessing.managers'."
    - "Process.__module__ == 'multiprocessing.context' on Python 3.12+."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __floor__ dict-presence — operator.contains(Cls.__dict__, '__floor__')
#
# None of the multiprocessing classes define __floor__; all results are false.
# ---------------------------------------------------------------------------

table mp2971.floor:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_floor
  id_prefix: flr

  columns: [id, function, args, expected]
  rows:
    - ["flr_Process",     operator.contains, [Process.__dict__,                              "__floor__"], false]
    - ["flr_Pool",        operator.contains, [multiprocessing.pool.Pool.__dict__,            "__floor__"], false]
    - ["flr_AsyncResult", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,     "__floor__"], false]
    - ["flr_MapResult",   operator.contains, [multiprocessing.pool.MapResult.__dict__,       "__floor__"], false]
    - ["flr_SyncManager", operator.contains, [multiprocessing.managers.SyncManager.__dict__, "__floor__"], false]
    - ["flr_ListProxy",   operator.contains, [multiprocessing.managers.ListProxy.__dict__,   "__floor__"], false]
    - ["flr_SetProxy",    operator.contains, [multiprocessing.managers.SetProxy.__dict__,    "__floor__"], false]
    - ["flr_DictProxy",   operator.contains, [multiprocessing.managers.DictProxy.__dict__,   "__floor__"], false]

