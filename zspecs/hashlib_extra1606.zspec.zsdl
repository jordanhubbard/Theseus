spec: hashlib_extra1606
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "hashlib hash objects are C extension instances of type HASH (from _hashlib); they have no __slots__ key in their type __dict__"
    - "md5, sha1, sha256, sha512 all share the same C type HASH from _hashlib module"
    - "sha3_256 and shake_128 are separate C types (HASH and HASHXOF) but also have no __slots__"
    - "blake2b has its own C type (blake2b) with no __slots__"
    - "C extension types expose read-only attributes (name, digest_size, block_size) as getset_descriptor, not member_descriptor"
    - "Methods (update, digest, hexdigest, copy) appear as method_descriptor in the HASH type __dict__"
    - "algorithms_guaranteed and algorithms_available are plain set objects in Python 3.14, not frozenset"
    - "All hash types from the same backend share a single C type object (md5 type is sha1 type is sha256 type)"
  created_at: "2026-04-12"
error_model: python_exceptions

table hashlib_extra1606.hash_type_no_slots:
  description: "HASH C extension type __dict__ does not contain __slots__ for any standard hash algorithm"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl1606hs

  columns: [id, function, args, expected]
  rows:
    - ["hl1606hs001", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__slots__"], false]
    - ["hl1606hs002", "type(hashlib.sha1(b'')).__dict__.__contains__",   ["__slots__"], false]
    - ["hl1606hs003", "type(hashlib.sha256(b'')).__dict__.__contains__", ["__slots__"], false]
    - ["hl1606hs004", "type(hashlib.sha512(b'')).__dict__.__contains__", ["__slots__"], false]
    - ["hl1606hs005", "type(hashlib.md5(b'')).__name__.__eq__",          ["HASH"],      true]
    - ["hl1606hs006", "type(hashlib.sha1(b'')).__name__.__eq__",         ["HASH"],      true]
    - ["hl1606hs007", "type(hashlib.sha256(b'')).__name__.__eq__",       ["HASH"],      true]
    - ["hl1606hs008", "type(hashlib.sha512(b'')).__name__.__eq__",       ["HASH"],      true]
    - ["hl1606hs009", "type(hashlib.md5(b'')).__module__.__eq__",        ["_hashlib"],  true]
    - ["hl1606hs010", "type(hashlib.sha1(b'')).__module__.__eq__",       ["_hashlib"],  true]
    - ["hl1606hs011", "type(hashlib.sha256(b'')).__module__.__eq__",     ["_hashlib"],  true]
    - ["hl1606hs012", "type(hashlib.sha512(b'')).__module__.__eq__",     ["_hashlib"],  true]
    - ["hl1606hs013", "type(hashlib.md5(b'')).__dict__.__contains__",    ["name"],         true]
    - ["hl1606hs014", "type(hashlib.md5(b'')).__dict__.__contains__",    ["digest_size"],  true]
    - ["hl1606hs015", "type(hashlib.md5(b'')).__dict__.__contains__",    ["block_size"],   true]
    - ["hl1606hs016", "type(hashlib.md5(b'')).__dict__.__contains__",    ["update"],       true]
    - ["hl1606hs017", "type(hashlib.md5(b'')).__dict__.__contains__",    ["digest"],       true]
    - ["hl1606hs018", "type(hashlib.md5(b'')).__dict__.__contains__",    ["hexdigest"],    true]
    - ["hl1606hs019", "type(hashlib.md5(b'')).__dict__.__contains__",    ["copy"],         true]
    - ["hl1606hs020", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__repr__"],     true]
    - ["hl1606hs021", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__new__"],      false]
    - ["hl1606hs022", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__init__"],     false]
    - ["hl1606hs023", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__reduce__"],   false]
    - ["hl1606hs024", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__doc__"],      true]
    - ["hl1606hs025", "type(hashlib.md5(b'')).__dict__.__contains__",    ["__module__"],   true]

table hashlib_extra1606.hash_attr_descriptor_types:
  description: "Attribute descriptor types in the HASH C extension type: name/digest_size/block_size are getset_descriptor; methods are method_descriptor"
  kind: python_call_eq
  category: descriptor_type
  id_prefix: hl1606dt

  columns: [id, function, args, expected]
  rows:
    - ["hl1606dt001", "type(type(hashlib.md5(b'')).__dict__['name']).__name__.__eq__",         ["getset_descriptor"],   true]
    - ["hl1606dt002", "type(type(hashlib.md5(b'')).__dict__['digest_size']).__name__.__eq__",  ["getset_descriptor"],   true]
    - ["hl1606dt003", "type(type(hashlib.md5(b'')).__dict__['block_size']).__name__.__eq__",   ["getset_descriptor"],   true]
    - ["hl1606dt004", "type(type(hashlib.md5(b'')).__dict__['update']).__name__.__eq__",       ["method_descriptor"],   true]
    - ["hl1606dt005", "type(type(hashlib.md5(b'')).__dict__['digest']).__name__.__eq__",       ["method_descriptor"],   true]
    - ["hl1606dt006", "type(type(hashlib.md5(b'')).__dict__['hexdigest']).__name__.__eq__",    ["method_descriptor"],   true]
    - ["hl1606dt007", "type(type(hashlib.md5(b'')).__dict__['copy']).__name__.__eq__",         ["method_descriptor"],   true]
    - ["hl1606dt008", "type(type(hashlib.md5(b'')).__dict__['__repr__']).__name__.__eq__",     ["wrapper_descriptor"],  true]
    - ["hl1606dt009", "type(hashlib.algorithms_guaranteed).__name__.__eq__",                   ["set"],                 true]
    - ["hl1606dt010", "type(hashlib.algorithms_available).__name__.__eq__",                    ["set"],                 true]
    - ["hl1606dt011", "len(hashlib.algorithms_guaranteed).__ge__",                             [6],                     true]
    - ["hl1606dt012", "hashlib.algorithms_guaranteed.__contains__",                            ["md5"],                 true]
    - ["hl1606dt013", "hashlib.algorithms_guaranteed.__contains__",                            ["sha1"],                true]
    - ["hl1606dt014", "hashlib.algorithms_guaranteed.__contains__",                            ["sha256"],              true]
    - ["hl1606dt015", "hashlib.algorithms_guaranteed.__contains__",                            ["sha512"],              true]
    - ["hl1606dt016", "hashlib.algorithms_guaranteed.__contains__",                            ["sha224"],              true]
    - ["hl1606dt017", "hashlib.algorithms_guaranteed.__contains__",                            ["sha384"],              true]
    - ["hl1606dt018", "type(hashlib.md5(b'')).__dict__.__class__.__name__.__eq__",            ["mappingproxy"],        true]
    - ["hl1606dt019", "hashlib.md5(b'').name.__eq__",                                         ["md5"],                 true]
    - ["hl1606dt020", "hashlib.sha256(b'').digest_size.__eq__",                               [32],                    true]
    - ["hl1606dt021", "hashlib.sha256(b'').block_size.__eq__",                                [64],                    true]
    - ["hl1606dt022", "hashlib.md5(b'').digest_size.__eq__",                                  [16],                    true]
    - ["hl1606dt023", "hashlib.md5(b'').block_size.__eq__",                                   [64],                    true]
    - ["hl1606dt024", "hashlib.sha512(b'').digest_size.__eq__",                               [64],                    true]
    - ["hl1606dt025", "hashlib.sha512(b'').block_size.__eq__",                                [128],                   true]
