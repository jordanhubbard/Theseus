spec: array_extra30
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array_extra29.zspec.zsdl — covers array.typecodes __class__.__name__ ('str') and __len__() (14); ArrayType.__name__/__module__ lengths (5); array.__reduce_ex__/__qualname__/__len__() (19); array.__class_getitem__/__qualname__/__len__() (23); __spec__.__class__.__name__ ('ModuleSpec')."
    - "array_extra28.zspec.zsdl — covers array.array method __qualname__.__len__() for append/extend/pop/insert/remove/reverse/tolist/frombytes/tobytes."
    - "array_extra27.zspec.zsdl — covers array.array class __module__/__name__/__qualname__ lengths (all 5); __name__.__len__() for core methods."
  notes:
    - "This spec extends array_extra29.zspec.zsdl."
    - "Prior specs covered: array.array class identity lengths; all core mutation/conversion method __name__ and __qualname__ lengths (append/extend/pop/insert/remove/reverse/tolist/frombytes/tobytes); typecodes identity; ArrayType identity; __reduce_ex__ and __class_getitem__ qualname lengths."
    - "This spec covers: array.array method __qualname__.__len__() for count/index/fromlist/fromfile/tofile/byteswap/buffer_info/fromunicode/tounicode — methods not covered by any prior array spec; array.array.__doc__.__class__.__name__.__len__() (3, 'str'); array.array.__mro__.__len__() (2); array.array.__bases__[0].__name__.__len__() (6, 'object'); array has no __all__ attribute."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "array has no __all__ attribute — confirmed with hasattr(array, '__all__') == False. Verified."
    - "array.array.count.__qualname__ == 'array.count', len == 11. Verified."
    - "array.array.index.__qualname__ == 'array.index', len == 11. Verified."
    - "array.array.fromlist.__qualname__ == 'array.fromlist', len == 14. Verified."
    - "array.array.fromfile.__qualname__ == 'array.fromfile', len == 14. Verified."
    - "array.array.tofile.__qualname__ == 'array.tofile', len == 12. Verified."
    - "array.array.byteswap.__qualname__ == 'array.byteswap', len == 14. Verified."
    - "array.array.buffer_info.__qualname__ == 'array.buffer_info', len == 17. Verified."
    - "array.array.fromunicode.__qualname__ == 'array.fromunicode', len == 17. Verified."
    - "array.array.tounicode.__qualname__ == 'array.tounicode', len == 15. Verified."
    - "array.array.__doc__.__class__.__name__ == 'str', len == 3. Verified."
    - "array.array.__mro__.__len__() == 2 — (array, object). Verified."
    - "array.array.__bases__[0].__name__ == 'object', len == 6. Verified."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for query and utility array.array methods
#
# Prior specs cover mutation/conversion methods (append/extend/pop/insert/remove/
# reverse/tolist/frombytes/tobytes). This table covers the remaining query and
# I/O methods: count(11), index(11), fromlist(14), fromfile(14), tofile(12),
# byteswap(14). All follow the 'array.METHOD' qualname pattern (6 + len(method)).
# No prior array spec covers any of these methods.
# Verified: count=11, index=11, fromlist=14, fromfile=14, tofile=12, byteswap=14.
# id_prefix mqlen30 is novel.
# ---------------------------------------------------------------------------

table array_extra30.method_qualname_lens_query_io:
  description: "array.array method __qualname__.__len__() for count/index/fromlist/fromfile/tofile/byteswap — lengths 11/11/14/14/12/14"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mqlen30

  columns: [id, function, args, expected]
  rows:
    - [count,     "array.count.__qualname__.__len__",     [], 11]
    - [index,     "array.index.__qualname__.__len__",     [], 11]
    - [fromlist,  "array.fromlist.__qualname__.__len__",  [], 14]
    - [fromfile,  "array.fromfile.__qualname__.__len__",  [], 14]
    - [tofile,    "array.tofile.__qualname__.__len__",    [], 12]
    - [byteswap,  "array.byteswap.__qualname__.__len__",  [], 14]

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for unicode I/O and buffer methods
#
# array.array.buffer_info and fromunicode/tounicode are methods not covered by
# any prior array spec. buffer_info: 'array.buffer_info' len 17.
# fromunicode: 'array.fromunicode' len 17. tounicode: 'array.tounicode' len 15.
# The unicode methods and buffer_info represent distinct functional categories.
# Verified: buffer_info=17, fromunicode=17, tounicode=15.
# id_prefix mqlen30u is novel.
# ---------------------------------------------------------------------------

table array_extra30.method_qualname_lens_unicode_buf:
  description: "array.array method __qualname__.__len__() for buffer_info/fromunicode/tounicode — lengths 17/17/15"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mqlen30u

  columns: [id, function, args, expected]
  rows:
    - [buffer_info,  "array.buffer_info.__qualname__.__len__",  [], 17]
    - [fromunicode,  "array.fromunicode.__qualname__.__len__",  [], 17]
    - [tounicode,    "array.tounicode.__qualname__.__len__",     [], 15]

# ---------------------------------------------------------------------------
# array.array.__mro__.__len__() == 2 — (array, object)
#
# array.array is a direct C extension type; its MRO is (array.array, object),
# so __mro__.__len__() == 2. No prior array spec covers __mro__.__len__().
# Mirrors the struct.Struct case (also 2). Verified.
# ---------------------------------------------------------------------------

invariant array_extra30.array_class.mro_len:
  description: "array.array.__mro__.__len__() == 2 — MRO is (array, object); direct C extension type"
  category: class_hierarchy
  kind: python_call_eq
  function: "array.__mro__.__len__"
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# array.array.__bases__[0].__name__.__len__() == 6 — len('object') == 6
#
# array.array's sole base class is object. 'object' has 6 characters. No prior
# array spec covers __bases__[0].__name__ or its length. Mirrors struct.Struct's
# analogous invariant from struct_extra27. Verified.
# ---------------------------------------------------------------------------

invariant array_extra30.array_class.base_name_len:
  description: "array.array.__bases__[0].__name__.__len__() == 6 — base class is 'object'; len('object') == 6"
  category: class_hierarchy
  kind: python_call_eq
  function: "array.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# array.array.__doc__.__class__.__name__.__len__() == 3 — len('str') == 3
#
# array.array.__doc__ is a string (the type docstring). Its class name 'str'
# has length 3. No prior array spec covers __doc__.__class__.__name__.__len__()
# for the array type (as opposed to the array module). Confirms the type-level
# docstring is a plain str. Verified.
# ---------------------------------------------------------------------------

invariant array_extra30.array_class.doc_class_name_len:
  description: "array.array.__doc__.__class__.__name__.__len__() == 3 — type docstring is a str; len('str') == 3"
  category: class_identity
  kind: python_call_eq
  function: "array.__doc__.__class__.__name__.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# array.array.buffer_info.__qualname__.__len__() == 17 — standalone anchor
#
# 'array.buffer_info' has 17 characters — tied with fromunicode for the
# longest method qualname checked in this spec. buffer_info returns the
# internal memory address and item count. Standalone invariant for this
# utility method. Verified: len('array.buffer_info') == 17.
# ---------------------------------------------------------------------------

invariant array_extra30.buffer_info.qualname_len:
  description: "array.array.buffer_info.__qualname__.__len__() == 17 — 'array.buffer_info' has 17 characters"
  category: method_qualnames
  kind: python_call_eq
  function: "array.buffer_info.__qualname__.__len__"
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# array.array.count.__qualname__.__len__() == 11 — standalone anchor
#
# 'array.count' has 11 characters — the shortest qualname among the newly
# covered methods (tied with index). Standalone invariant for the count method,
# which returns the number of occurrences of a value in the array.
# Verified: len('array.count') == 11.
# ---------------------------------------------------------------------------

invariant array_extra30.count.qualname_len:
  description: "array.array.count.__qualname__.__len__() == 11 — 'array.count' has 11 characters"
  category: method_qualnames
  kind: python_call_eq
  function: "array.count.__qualname__.__len__"
  args: []
  expected: 11
