spec: io3421
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 675 (io3421): __hash__, __eq__, __lt__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "Theme: __hash__/__eq__/__lt__ dict-presence (hash(x), x==y, x<y)."
    - "No io class defines __hash__ in its own __dict__: stream I/O classes are sequential I/O abstractions; hash() is not explicitly defined on any io class."
    - "No io class defines __eq__ in its own __dict__: io stream classes do not implement custom equality comparison in their own __dict__s."
    - "No io class defines __lt__ in its own __dict__: io stream classes do not implement ordering in their own __dict__s."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all hash/equality/ordering operators absent from io class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __hash__ dict-presence — operator.contains(Cls.__dict__, '__hash__')
#
# No io class defines __hash__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not hashable types,
# and do not implement the hash protocol (__hash__) in their own __dict__.
# ---------------------------------------------------------------------------

table io3421.hash:
  description: "io types __hash__ dict-presence checks; wave 675"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3421

  columns: [id, function, args, expected]
  rows:
    - ["io3421001", operator.contains, [io.RawIOBase.__dict__,       "__hash__"], false]
    - ["io3421002", operator.contains, [io.BufferedIOBase.__dict__,  "__hash__"], false]
    - ["io3421003", operator.contains, [io.TextIOBase.__dict__,      "__hash__"], false]
    - ["io3421004", operator.contains, [io.FileIO.__dict__,          "__hash__"], false]
    - ["io3421005", operator.contains, [io.BytesIO.__dict__,         "__hash__"], false]
    - ["io3421006", operator.contains, [io.StringIO.__dict__,        "__hash__"], false]
    - ["io3421007", operator.contains, [io.BufferedReader.__dict__,  "__hash__"], false]
    - ["io3421008", operator.contains, [io.BufferedWriter.__dict__,  "__hash__"], false]
    - ["io3421009", operator.contains, [io.BufferedRandom.__dict__,  "__hash__"], false]
    - ["io3421010", operator.contains, [io.BufferedRWPair.__dict__,  "__hash__"], false]
    - ["io3421011", operator.contains, [io.TextIOWrapper.__dict__,   "__hash__"], false]

# ---------------------------------------------------------------------------
# __eq__ dict-presence — operator.contains(Cls.__dict__, '__eq__')
#
# No io class defines __eq__ in its own __dict__; all false.
# io stream classes do not implement custom equality comparison;
# == falls back to identity-based comparison from object.
# ---------------------------------------------------------------------------

