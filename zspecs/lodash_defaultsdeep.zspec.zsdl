spec: lodash_defaultsdeep
version: ">=4.0.0"
backend: node(lodash.defaultsdeep)

docs: https://lodash.com/docs/#defaultsDeep

provenance:
  derived_from:
    - "lodash.defaultsdeep README — https://www.npmjs.com/package/lodash.defaultsdeep"
    - "Test vectors verified with lodash.defaultsdeep@4.6.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.defaultsdeep exports the _.defaultsDeep function directly as module.exports."
    - "defaultsDeep(object, ...sources) assigns defaults recursively for nested undefined slots."
    - "Unlike _.defaults, recurses into nested objects rather than replacing them."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns mutated object with deep defaults applied."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_defaultsdeep.defaultsdeep:
  kind: node_module_call_eq
  function: ~
  category: defaultsdeep
  id_prefix: ldd

  columns: [id, args, expected]
  rows:
    - [nested,  [{"a": {"x": 1}}, {"a": {"x": 99, "y": 2}}],
       {"a": {"x": 1, "y": 2}}]
    - [flat,    [{"a": 1}, {"a": 99, "b": 2}],
       {"a": 1, "b": 2}]
