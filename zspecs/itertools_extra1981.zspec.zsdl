spec: itertools_extra1981
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 579 (_extra1981): __sizeof__, __length_hint__, __floor__, __ceil__, __trunc__ dict-presence checks."
    - "itertools.product, itertools.combinations, and itertools.permutations define __sizeof__ for accurate memory reporting."
    - "itertools.count, itertools.cycle, itertools.chain, itertools.islice, itertools.zip_longest do NOT define __sizeof__."
    - "None of the itertools C types define __length_hint__ in their own dict."
    - "None of the itertools C types define __floor__, __ceil__, or __trunc__ — they are not numeric types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table itertools_extra1981.sizeof_protocol:
  description: "itertools types __sizeof__ dict-presence checks — product/combinations/permutations define it; others do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1981
  columns: [id, function, args, expected]
  rows:
    - ["it1981001", "itertools.count.__dict__.__contains__",        ["__sizeof__"], false]
    - ["it1981002", "itertools.cycle.__dict__.__contains__",        ["__sizeof__"], false]
    - ["it1981003", "itertools.chain.__dict__.__contains__",        ["__sizeof__"], false]
    - ["it1981004", "itertools.islice.__dict__.__contains__",       ["__sizeof__"], false]
    - ["it1981005", "itertools.zip_longest.__dict__.__contains__",  ["__sizeof__"], false]
    - ["it1981006", "itertools.product.__dict__.__contains__",      ["__sizeof__"], true]
    - ["it1981007", "itertools.combinations.__dict__.__contains__", ["__sizeof__"], true]
    - ["it1981008", "itertools.permutations.__dict__.__contains__", ["__sizeof__"], true]

