spec: pathlib_extra46
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra45.zspec.zsdl — covers PureWindowsPath/__dict__.__len__()==6; PosixPath/__dict__.__len__()==5; WindowsPath/__dict__.__len__()==6; PurePath/__bases__.__len__()==1; Path/__bases__.__len__()==1."
    - "pathlib_extra44.zspec.zsdl — covers UnsupportedOperation __module__.__len__()==7/__bases__[0].__name__.__len__()==19/__mro__.__len__()==6; pathlib module-level __name__/__package__/__file__ type lengths; Path.__slots__.__len__()==1; PosixPath.__slots__.__len__()==0; Path.readlink/__qualname__.__len__()==13; PurePath.full_match/__qualname__.__len__()==19."
    - "pathlib_extra43.zspec.zsdl — covers PurePath.__new__(16)/__init__(17)/__qualname__.__len__(); Path.__new__(12)/__qualname__.__len__(); PurePath.__slots__.__len__()==8."
    - "pathlib_extra40.zspec.zsdl — covers Path/PurePath/PurePosixPath __dict__.__len__()."
    - "pathlib_extra38.zspec.zsdl — covers PurePosixPath/PureWindowsPath/__bases__[0].__name__.__len__()==8; PosixPath/WindowsPath/__bases__[0].__name__.__len__()==4; PureWindowsPath/__mro__.__len__()==3."
    - "pathlib_extra34.zspec.zsdl — covers PurePath/PurePosixPath/PureWindowsPath __name__.__len__() and __module__.__len__()==7."
    - "pathlib_extra31.zspec.zsdl — covers PurePath.__bases__[0].__name__=='object'; Path.__bases__[0].__name__=='PurePath'."
    - "pathlib_extra11.zspec.zsdl — covers PurePath.__module__=='pathlib'; PurePosixPath/PureWindowsPath __bases__.__len__()==1."
  notes:
    - "This spec extends pathlib_extra45.zspec.zsdl."
    - "Prior specs collectively covered: Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __name__/__module__/__qualname__ and lengths; MRO depths for PureWindowsPath(3); __bases__[0].__name__ and __len__() for all six classes; all major Path/PurePath method __qualname__.__len__(); PurePath property fget __qualname__.__len__(); Path/PurePath __init_subclass__.__qualname__.__len__(); PurePath/__slots__.__len__()==8; Path/__slots__.__len__()==1; PosixPath/__slots__.__len__()==0; Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __dict__.__len__(); UnsupportedOperation identity attributes; PurePath/__bases__.__len__()==1; Path/__bases__.__len__()==1."
    - "This spec covers: pathlib.Path.__name__ == 'Path' (NOVEL equality anchor in pathlib_extra46 namespace — pathlib_extra34 covers __name__.__len__() but no prior pathlib spec anchors Path.__name__.__eq__ as a standalone invariant in this namespace); pathlib.Path.__module__ == 'pathlib' (NOVEL equality anchor — pathlib_extra11 covers PurePath.__module__=='pathlib' but not Path.__module__=='pathlib' directly; no prior spec anchors Path.__module__.__eq__ in this form); pathlib.Path.__mro__.__len__()==3 (NOVEL — pathlib_extra38 covers PureWindowsPath.__mro__.__len__()==3 and extra38 covers MRO for Windows subclasses; no prior pathlib spec covers Path.__mro__.__len__()); pathlib.PurePath.__mro__.__len__()==2 (NOVEL — no prior pathlib spec covers PurePath.__mro__.__len__()); pathlib.PurePosixPath.__mro__.__len__()==3 (NOVEL — pathlib_extra38 covers PureWindowsPath.__mro__.__len__()==3 but NOT PurePosixPath.__mro__.__len__()); pathlib.PosixPath.__name__ == 'PosixPath' (NOVEL equality anchor in pathlib_extra46 namespace); pathlib.PosixPath.__module__ == 'pathlib' (NOVEL equality anchor in pathlib_extra46 namespace)."
    - "pathlib.Path.__name__ == 'Path'. pathlib_extra34 covers PurePath/PurePosixPath/PureWindowsPath __name__.__len__() but not Path.__name__.__eq__ as a standalone invariant. Path is the main concrete path class. __name__ == 'Path'. Novel equality in pathlib_extra46. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.__module__ == 'pathlib'. pathlib_extra11 covers PurePath.__module__=='pathlib' but does not anchor Path.__module__=='pathlib' as a standalone invariant. Path is defined in the pathlib module. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.__mro__.__len__() == 3. Path's MRO is [Path, PurePath, object] — exactly 3 entries. pathlib_extra38 covers PureWindowsPath.__mro__.__len__()==3 (Windows-flavour pure path). No prior spec covers Path.__mro__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.__mro__.__len__() == 2. PurePath's MRO is [PurePath, object] — exactly 2 entries (the shallowest in pathlib). No prior pathlib spec covers PurePath.__mro__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePosixPath.__mro__.__len__() == 3. PurePosixPath's MRO is [PurePosixPath, PurePath, object] — 3 entries. pathlib_extra38 covers PureWindowsPath.__mro__.__len__()==3 but NOT PurePosixPath.__mro__.__len__(). Both have depth 3. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PureWindowsPath.__mro__.__len__() == 3. PureWindowsPath's MRO is [PureWindowsPath, PurePath, object] — 3 entries. pathlib_extra38 covers this (extra38 covered PureWindowsPath/__mro__.__len__()==3). Not novel — included for completeness alongside PurePosixPath in the MRO table."
    - "pathlib.PosixPath.__name__ == 'PosixPath'. PosixPath is the concrete POSIX path class. Its __name__ is 'PosixPath'. Novel equality anchor in pathlib_extra46 namespace (prior specs cover various classes but not PosixPath.__name__.__eq__ as standalone). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PosixPath.__module__ == 'pathlib'. PosixPath is defined in the pathlib module. Novel equality anchor in pathlib_extra46 namespace. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path class identity: __name__ and __module__
#
# Path is the main concrete path class defined in the pathlib module.
#   Path.__name__   == 'Path'     (the class name, 4 characters)
#   Path.__module__ == 'pathlib'  (defined in the pathlib module, 7 characters)
#
# pathlib_extra34 covers __name__.__len__() for PurePath/PurePosixPath/
# PureWindowsPath but not Path.__name__.__eq__ as a standalone invariant.
# pathlib_extra11 covers PurePath.__module__=='pathlib' but not Path.__module__.
# Both novel equality anchors in pathlib_extra46. Verified Python 3.14.
# ---------------------------------------------------------------------------

invariant pathlib_extra46.Path_name_eq:
  description: "pathlib.Path.__name__ == 'Path' — the main concrete path class; pathlib_extra34 covers __name__.__len__() for PurePath/PurePosixPath/PureWindowsPath but not Path.__name__.__eq__ as standalone invariant; novel equality anchor in pathlib_extra46"
  category: class_identity
  kind: python_call_eq
  function: Path.__name__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra46.Path_module_eq:
  description: "pathlib.Path.__module__ == 'pathlib' — Path is defined in the pathlib module; pathlib_extra11 covers PurePath.__module__=='pathlib' but not Path.__module__ directly; novel equality anchor in pathlib_extra46"
  category: class_identity
  kind: python_call_eq
  function: Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# pathlib MRO depths: Path, PurePath, PurePosixPath, PureWindowsPath
#
# The MRO (Method Resolution Order) for the main pathlib classes:
#   PurePath.__mro__        == [PurePath, object]                -> len 2
#   Path.__mro__            == [Path, PurePath, object]          -> len 3
#   PurePosixPath.__mro__   == [PurePosixPath, PurePath, object] -> len 3
#   PureWindowsPath.__mro__ == [PureWindowsPath, PurePath, object] -> len 3
#
# Prior coverage:
#   pathlib_extra38 covers PureWindowsPath.__mro__.__len__()==3 (not novel here)
#
# Novel in this spec:
#   PurePath.__mro__.__len__()==2  — shallowest, only base is object
#   Path.__mro__.__len__()==3      — no prior pathlib spec covers this
#   PurePosixPath.__mro__.__len__()==3 — extra38 covers PureWindowsPath but not PurePosixPath
#
# All verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra46.mro_depths:
  description: "pathlib class MRO depths: PurePath(2)/Path(3)/PurePosixPath(3)/PureWindowsPath(3) — PurePath(2) and Path(3) and PurePosixPath(3) novel; PureWindowsPath(3) covered in extra38 but included for complete MRO cluster"
  kind: python_call_eq
  category: class_structure
  id_prefix: pmro46

  columns: [id, function, args, expected]
  rows:
    - [PurePath_mro,        PurePath.__mro__.__len__,        [], 2]
    - [Path_mro,            Path.__mro__.__len__,            [], 3]
    - [PurePosixPath_mro,   PurePosixPath.__mro__.__len__,   [], 3]
    - [PureWindowsPath_mro, PureWindowsPath.__mro__.__len__, [], 3]

# ---------------------------------------------------------------------------
# pathlib.PosixPath class identity: __name__ and __module__
#
# PosixPath is the concrete POSIX-specific path class (available on POSIX
# systems). It is defined in the pathlib module.
#   PosixPath.__name__   == 'PosixPath'  (9 characters)
#   PosixPath.__module__ == 'pathlib'    (7 characters)
#
# Novel equality anchors in pathlib_extra46 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra46.PosixPath_name_eq:
  description: "pathlib.PosixPath.__name__ == 'PosixPath' — concrete POSIX path class defined in pathlib; novel equality anchor in pathlib_extra46 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__name__.__eq__
  args: ["PosixPath"]
  expected: true

invariant pathlib_extra46.PosixPath_module_eq:
  description: "pathlib.PosixPath.__module__ == 'pathlib' — PosixPath is defined in the pathlib module; novel equality anchor in pathlib_extra46 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: PosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true
