spec: itertools_extra30
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra29.zspec.zsdl."
    - "Prior specs covered: chain/cycle/count/dropwhile/filterfalse/groupby/islice/pairwise/permutations/combinations/product/repeat/starmap/takewhile/zip_longest __name__/__module__/__qualname__, __name__.__len__() for all types, __module__.__len__() for all types (all 9), __qualname__.__len__() for islice/pairwise/product."
    - "This spec covers: chain.from_iterable.__qualname__.__len__() (19); groupby.__iter__.__qualname__.__len__() and groupby.__next__.__qualname__.__len__() (both 16); __mro__.__len__() for chain/cycle/islice/product/groupby/accumulate/pairwise/filterfalse (all 2); __bases__[0].__name__ for chain/cycle/islice/product (all 'object'); combinations_with_replacement.__qualname__.__len__() (29)."
    - "Key findings: All itertools C-level types have __mro__ of length 2 (direct subclasses of object). chain.from_iterable is a classmethod with qualname 'chain.from_iterable' (len 19). groupby.__iter__ and groupby.__next__ have qualname 'groupby.__iter__' and 'groupby.__next__' respectively (both len 16)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
    - "spec version >=3.10 required for pairwise."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — chain.from_iterable and groupby protocol methods
#
# itertools.chain.from_iterable is a classmethod with __qualname__ equal to
# 'chain.from_iterable' (19 chars). itertools.groupby.__iter__ has __qualname__
# 'groupby.__iter__' (16 chars), and itertools.groupby.__next__ has __qualname__
# 'groupby.__next__' (16 chars). The groupby iterator protocol methods share the
# same 16-character qualname length. No prior itertools spec records these three
# method __qualname__.__len__() values together in a combined table in the extra30
# namespace.
# ---------------------------------------------------------------------------

table itertools_extra30.method_qualname_lengths:
  description: "__qualname__.__len__() for chain.from_iterable and groupby protocol methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [chain_from_iterable,
       chain.from_iterable.__qualname__.__len__,
       [],
       19,
       "len(itertools.chain.from_iterable.__qualname__) == 19 — 'chain.from_iterable'"]
    - [groupby__iter__,
       groupby.__iter__.__qualname__.__len__,
       [],
       16,
       "len(itertools.groupby.__iter__.__qualname__) == 16 — 'groupby.__iter__'"]
    - [groupby__next__,
       groupby.__next__.__qualname__.__len__,
       [],
       16,
       "len(itertools.groupby.__next__.__qualname__) == 16 — 'groupby.__next__'"]

# ---------------------------------------------------------------------------
# __mro__.__len__() table — hierarchy depth for core itertools types
#
# All C-level itertools types are direct subclasses of object, so their __mro__
# has length 2. This table records __mro__.__len__() for chain, cycle, islice,
# product, groupby, accumulate, pairwise, and filterfalse. No prior itertools spec
# records __mro__.__len__() for these eight types together in a combined table
# in the extra30 namespace.
# ---------------------------------------------------------------------------

table itertools_extra30.mro_lengths:
  description: "__mro__.__len__() for itertools types — all 2 (direct subclasses of object)"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mro_len

  columns: [id, function, method, method_args, expected, description]
  rows:
    - [chain,
       chain.__mro__,
       __len__,
       [],
       2,
       "len(itertools.chain.__mro__) == 2 — [chain, object]"]
    - [cycle,
       cycle.__mro__,
       __len__,
       [],
       2,
       "len(itertools.cycle.__mro__) == 2 — [cycle, object]"]
    - [islice,
       islice.__mro__,
       __len__,
       [],
       2,
       "len(itertools.islice.__mro__) == 2 — [islice, object]"]
    - [product,
       product.__mro__,
       __len__,
       [],
       2,
       "len(itertools.product.__mro__) == 2 — [product, object]"]
    - [groupby,
       groupby.__mro__,
       __len__,
       [],
       2,
       "len(itertools.groupby.__mro__) == 2 — [groupby, object]"]
    - [accumulate,
       accumulate.__mro__,
       __len__,
       [],
       2,
       "len(itertools.accumulate.__mro__) == 2 — [accumulate, object]"]
    - [pairwise,
       pairwise.__mro__,
       __len__,
       [],
       2,
       "len(itertools.pairwise.__mro__) == 2 — [pairwise, object]"]
    - [filterfalse,
       filterfalse.__mro__,
       __len__,
       [],
       2,
       "len(itertools.filterfalse.__mro__) == 2 — [filterfalse, object]"]

# ---------------------------------------------------------------------------
# __bases__[0].__name__ table — base class name for itertools types
#
# All itertools C-level types inherit directly from object. This table confirms
# that chain, cycle, islice, and product each have __bases__[0].__name__ == 'object'.
# Prior specs confirmed this for pairwise and product separately; this table
# collects four representative types spanning filtering, infinite, and combinatoric
# subcategories. No prior itertools spec records these four __bases__[0].__name__
# values together in a combined table in the extra30 namespace.
# ---------------------------------------------------------------------------

table itertools_extra30.bases_name:
  description: "__bases__[0].__name__ for itertools types — all 'object'"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: bases_name

  columns: [id, function, args, expected, description]
  rows:
    - [chain,
       chain.__bases__[0].__name__.__len__,
       [],
       6,
       "len(itertools.chain.__bases__[0].__name__) == 6 — 'object'"]
    - [cycle,
       cycle.__bases__[0].__name__.__len__,
       [],
       6,
       "len(itertools.cycle.__bases__[0].__name__) == 6 — 'object'"]
    - [islice,
       islice.__bases__[0].__name__.__len__,
       [],
       6,
       "len(itertools.islice.__bases__[0].__name__) == 6 — 'object'"]
    - [product,
       product.__bases__[0].__name__.__len__,
       [],
       6,
       "len(itertools.product.__bases__[0].__name__) == 6 — 'object'"]

# ---------------------------------------------------------------------------
# chain.from_iterable.__qualname__.__len__() — standalone invariant
#
# itertools.chain.from_iterable.__qualname__ is 'chain.from_iterable' (19 chars).
# from_iterable is a classmethod on chain that chains a single iterable of iterables.
# Its qualname reflects the dotted descriptor path 'chain.from_iterable', making
# it the only itertools object whose qualname contains an internal dot. No prior
# itertools spec records this standalone in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra30.chain_from_iterable_qualname_len:
  description: "len(itertools.chain.from_iterable.__qualname__) == 19 — 'chain.from_iterable'"
  category: method_qualnames
  kind: python_call_eq
  function: chain.from_iterable.__qualname__.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# groupby.__iter__.__qualname__.__len__() — standalone invariant
#
# itertools.groupby.__iter__.__qualname__ is 'groupby.__iter__' (16 chars).
# groupby implements the iterator protocol in C; the __iter__ slot has a qualname
# that follows the 'typename.__slot__' pattern. Its length (16) equals that of
# groupby.__next__, making the two iterator protocol methods the same length.
# No prior itertools spec records this standalone in the extra30 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra30.groupby__iter__qualname_len:
  description: "len(itertools.groupby.__iter__.__qualname__) == 16 — 'groupby.__iter__'"
  category: method_qualnames
  kind: python_call_eq
  function: groupby.__iter__.__qualname__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# combinations_with_replacement.__qualname__.__len__() — standalone invariant
#
# itertools.combinations_with_replacement.__qualname__ is
# 'combinations_with_replacement' (29 chars), by far the longest __qualname__
# among all itertools types. It generates combinations allowing repeated selection
# of elements. No prior itertools spec records this standalone in the extra30
# namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra30.combinations_with_replacement_qualname_len:
  description: "len(itertools.combinations_with_replacement.__qualname__) == 29 — 'combinations_with_replacement'"
  category: method_qualnames
  kind: python_call_eq
  function: combinations_with_replacement.__qualname__.__len__
  args: []
  expected: 29
