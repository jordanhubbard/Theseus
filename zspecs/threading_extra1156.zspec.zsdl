spec: threading_extra1156
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading.__package__.__class__.__name__, threading.__loader__.__class__.__name__, threading.__all__.__class__.__name__, threading.Thread/__module__, threading.Lock/__module__, threading.RLock/__module__, threading.Condition/__module__, threading.Event/__module__ — not covered in _extra1126/_extra1141"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1156.package_loader_all_class_names:
  description: "threading.__package__, __loader__, and __all__ class name identity"
  kind: python_call_eq
  category: package_loader_all_class_names
  id_prefix: th1156pl
  columns: [id, function, args, expected]
  rows:
    - [th1156pl001, threading.__package__.__class__.__name__.__eq__,                ["str"],                          true]
    - [th1156pl002, threading.__package__.__eq__,                                   ["threading"],                    true]
    - [th1156pl003, threading.__loader__.__class__.__name__.__eq__,                 ["SourceFileLoader"],              true]
    - [th1156pl004, threading.__all__.__class__.__name__.__eq__,                    ["list"],                         true]
    - [th1156pl005, threading.__all__.__contains__,                                 ["Thread"],                       true]
    - [th1156pl006, threading.__all__.__contains__,                                 ["Lock"],                         true]
    - [th1156pl007, threading.__all__.__contains__,                                 ["Event"],                        true]
    - [th1156pl008, threading.__all__.__contains__,                                 ["Condition"],                    true]

table threading_extra1156.thread_lock_rlock_modules:
  description: "threading.Thread, Lock, and RLock __module__ identity"
  kind: python_call_eq
  category: thread_lock_rlock_modules
  id_prefix: th1156tr
  columns: [id, function, args, expected]
  rows:
    - [th1156tr001, threading.Thread.__module__.__eq__,                             ["threading"],                    true]
    - [th1156tr002, threading.Thread.__qualname__.__eq__,                           ["Thread"],                       true]
    - [th1156tr003, threading.Thread.__class__.__name__.__eq__,                     ["type"],                         true]
    - [th1156tr004, threading.Lock.__module__.__eq__,                               ["_thread"],                      true]
    - [th1156tr005, threading.Lock.__qualname__.__eq__,                             ["lock"],                         true]
    - [th1156tr006, threading.Lock.__class__.__name__.__eq__,                       ["type"],                         true]
    - [th1156tr007, threading.RLock.__module__.__eq__,                              ["threading"],                    true]
    - [th1156tr008, threading.RLock.__qualname__.__eq__,                            ["RLock"],                        true]

table threading_extra1156.condition_event_modules:
  description: "threading.Condition and Event __module__ and class identity"
  kind: python_call_eq
  category: condition_event_modules
  id_prefix: th1156ce
  columns: [id, function, args, expected]
  rows:
    - [th1156ce001, threading.Condition.__module__.__eq__,                          ["threading"],                    true]
    - [th1156ce002, threading.Condition.__qualname__.__eq__,                        ["Condition"],                    true]
    - [th1156ce003, threading.Condition.__class__.__name__.__eq__,                  ["type"],                         true]
    - [th1156ce004, threading.Condition.__doc__.__class__.__name__.__eq__,          ["str"],                          true]
    - [th1156ce005, threading.Event.__module__.__eq__,                              ["threading"],                    true]
    - [th1156ce006, threading.Event.__qualname__.__eq__,                            ["Event"],                        true]
    - [th1156ce007, threading.Event.__class__.__name__.__eq__,                      ["type"],                         true]
    - [th1156ce008, threading.Event.__doc__.__class__.__name__.__eq__,              ["str"],                          true]
