# ---------------------------------------------------------------------------
# socket.create_connection co_varnames — class name and membership — extra207
#
# Wave 255 theme: co_varnames attributes for socket.create_connection.
#
# socket.create_connection.__code__.co_varnames.__class__.__name__    == 'tuple'
# socket.create_connection.__code__.co_varnames.__contains__('host')  == True
# ---------------------------------------------------------------------------

table socket_extra207.create_connection_co_varnames:
  description: "socket.create_connection.__code__.co_varnames class identity and membership checks in socketcovarnames207 namespace — wave 255 theme: socket.create_connection.__code__.co_varnames.__class__.__name__.__eq__('tuple')==True (co_varnames is always a tuple in CPython; create_connection co_varnames has 15 elements); socket.create_connection.__code__.co_varnames.__contains__('host')==True ('host' is an internal local variable in create_connection used when unpacking the address tuple: host, port = address; co_varnames includes 'host' even though it is not a parameter — it is the first local assigned inside the function body); socket.create_connection.__code__.co_varnames.__len__()==15 (4 params: address, timeout, source_address, all_errors + 11 locals: host, port, exceptions, res, af, socktype, proto, canonname, sa, sock, exc); socket.create_connection.__code__.co_argcount==3 (address, timeout, source_address; all_errors is keyword-only and not counted by co_argcount); co_varnames.__class__.__name__=='tuple' (len=5); verified with Python 3.14.3"
  kind: python_call_eq
  category: co_varnames
  id_prefix: socketcovarnames207

  columns: [id, function, args, expected, description]
  rows:
    - [cc_var_cls,   socket.create_connection.__code__.co_varnames.__class__.__name__.__eq__,  ["tuple"], true, "socket.create_connection.__code__.co_varnames.__class__.__name__ == 'tuple'; verified with Python 3.14.3"]
    - [cc_var_len,   socket.create_connection.__code__.co_varnames.__len__,                    [],        15,   "socket.create_connection.__code__.co_varnames.__len__() == 15 (address, timeout, source_address, all_errors + 11 locals); verified with Python 3.14.3"]
    - [cc_has_host,  socket.create_connection.__code__.co_varnames.__contains__,               ["host"],  true, "socket.create_connection.__code__.co_varnames.__contains__('host') == True; verified with Python 3.14.3"]
    - [cc_argc,      socket.create_connection.__code__.co_argcount.__eq__,                     [3],       true, "socket.create_connection.__code__.co_argcount == 3 (address, timeout, source_address); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.getfqdn co_varnames — membership and length — extra207
#
# Wave 255 theme: co_varnames attributes for socket.getfqdn.
#
# socket.getfqdn.__code__.co_varnames.__contains__('name')  == True
# ---------------------------------------------------------------------------

table socket_extra207.getfqdn_co_varnames:
  description: "socket.getfqdn.__code__.co_varnames membership and identity checks in socketcovarnames207 namespace — wave 255 theme: socket.getfqdn.__code__.co_varnames.__contains__('name')==True ('name' is the first positional parameter of getfqdn(name='') — the hostname to look up; defaults to empty string which triggers gethostname() lookup; co_varnames[0]=='name'); socket.getfqdn.__code__.co_varnames.__len__()==4 (1 param 'name' plus 3 locals: 'hostname', 'aliases', 'ipaddrs'); socket.getfqdn.__code__.co_argcount==1 (only 'name' is a positional parameter); socket.getfqdn.__code__.co_varnames.__class__.__name__=='tuple'; getfqdn is a pure-Python function in Lib/socket.py that resolves a fully-qualified domain name via gethostbyaddr; co_varnames are ('name', 'hostname', 'aliases', 'ipaddrs'); verified with Python 3.14.3"
  kind: python_call_eq
  category: co_varnames
  id_prefix: socketcovarnames207a

  columns: [id, function, args, expected, description]
  rows:
    - [fqdn_var_cls,   socket.getfqdn.__code__.co_varnames.__class__.__name__.__eq__,  ["tuple"], true, "socket.getfqdn.__code__.co_varnames.__class__.__name__ == 'tuple'; verified with Python 3.14.3"]
    - [fqdn_var_len,   socket.getfqdn.__code__.co_varnames.__len__,                    [],        4,    "socket.getfqdn.__code__.co_varnames.__len__() == 4 (name, hostname, aliases, ipaddrs); verified with Python 3.14.3"]
    - [fqdn_has_name,  socket.getfqdn.__code__.co_varnames.__contains__,               ["name"],  true, "socket.getfqdn.__code__.co_varnames.__contains__('name') == True; verified with Python 3.14.3"]
    - [fqdn_argc,      socket.getfqdn.__code__.co_argcount.__eq__,                     [1],       true, "socket.getfqdn.__code__.co_argcount == 1 (name only); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# socket.socket.__dict__ membership — accept, close, makefile — extra207
#
# Wave 255 theme: socket.socket.__dict__ contains Python-level methods.
#
# socket.socket.__dict__.__contains__('accept')   == True
# socket.socket.__dict__.__contains__('close')    == True
# socket.socket.__dict__.__contains__('makefile') == True
# ---------------------------------------------------------------------------

table socket_extra207.socket_socket_dict_membership:
  description: "socket.socket.__dict__ membership checks for Python-level methods in socketcovarnames207 namespace — wave 255 theme: socket.socket.__dict__.__contains__('accept')==True ('accept' is a Python-level method defined in Lib/socket.py on the socket class; accept() returns (socket_object, address) for a new connection on a bound/listening socket; it is defined in Python because it creates a new socket.socket instance wrapping the C-level _socket.socket.accept() result); socket.socket.__dict__.__contains__('close')==True ('close' is a Python-level method in Lib/socket.py; it properly releases the socket file descriptor and supports the context manager protocol); socket.socket.__dict__.__contains__('makefile')==True ('makefile' is a Python-level method in Lib/socket.py that returns a file-like wrapper around the socket; takes mode and buffering arguments); socket.socket.__dict__.__class__.__name__=='mappingproxy' (Python class __dict__ is always a mappingproxy); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: socketcovarnames207b

  columns: [id, function, args, expected, description]
  rows:
    - [sock_has_accept,   socket.socket.__dict__.__contains__,  ["accept"],   true, "socket.socket.__dict__.__contains__('accept') == True (Python-level method); verified with Python 3.14.3"]
    - [sock_has_close,    socket.socket.__dict__.__contains__,  ["close"],    true, "socket.socket.__dict__.__contains__('close') == True (Python-level method); verified with Python 3.14.3"]
    - [sock_has_makefile, socket.socket.__dict__.__contains__,  ["makefile"], true, "socket.socket.__dict__.__contains__('makefile') == True (Python-level method); verified with Python 3.14.3"]
    - [sock_dict_cls,     socket.socket.__dict__.__class__.__name__.__eq__,  ["mappingproxy"], true, "socket.socket.__dict__.__class__.__name__ == 'mappingproxy'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra207
# ---------------------------------------------------------------------------

invariant socket_extra207.create_connection_co_varnames_class_tuple:
  description: "socket.create_connection.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — socket.create_connection.__code__.co_varnames is a tuple (co_varnames is always a tuple of local variable name strings in CPython; create_connection co_varnames has 15 elements: ('address', 'timeout', 'source_address', 'all_errors', 'host', 'port', 'exceptions', 'res', 'af', 'socktype', 'proto', 'canonname', 'sa', 'sock', 'exc')); co_varnames.__class__.__name__=='tuple' (len=5); socket.create_connection is defined in Lib/socket.py; first standalone create_connection co_varnames class name invariant; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: co_varnames
  kind: python_call_eq
  function: socket.create_connection.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant socket_extra207.create_connection_co_varnames_contains_host:
  description: "socket.create_connection.__code__.co_varnames.__contains__('host') returns True — 'host' is present in socket.create_connection.__code__.co_varnames; 'host' is an internal local variable (not a parameter) that receives the first element when the address tuple is unpacked: host, port = address; this unpacking occurs inside the function body; socket.create_connection.__code__.co_varnames[0]=='address' (the first positional param); 'host' appears later in co_varnames after the parameter names; first standalone create_connection 'host' membership invariant in socketcovarnames207 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: co_varnames
  kind: python_call_eq
  function: socket.create_connection.__code__.co_varnames.__contains__
  args: ["host"]
  expected: true

invariant socket_extra207.getfqdn_co_varnames_contains_name:
  description: "socket.getfqdn.__code__.co_varnames.__contains__('name') returns True — 'name' is present in socket.getfqdn.__code__.co_varnames; socket.getfqdn(name='') takes 'name' as its only positional parameter — the hostname to resolve; if name=='' then gethostname() is called first; co_varnames[0]=='name' (positional params appear first); socket.getfqdn.__code__.co_argcount==1; co_varnames==('name', 'hostname', 'aliases', 'ipaddrs') (len=4); first standalone getfqdn 'name' membership invariant in socketcovarnames207 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: co_varnames
  kind: python_call_eq
  function: socket.getfqdn.__code__.co_varnames.__contains__
  args: ["name"]
  expected: true

invariant socket_extra207.socket_socket_dict_contains_accept:
  description: "socket.socket.__dict__.__contains__('accept') returns True — 'accept' is present in socket.socket.__dict__; socket.socket.accept() is a Python-level method defined in Lib/socket.py that wraps _socket.socket.accept() and returns a (socket, address) tuple where socket is a socket.socket instance (not _socket.socket); this wrapping is done in Python so that the returned socket gets all the socket.socket Python-level methods (accept, close, makefile, etc.); socket.socket.__dict__.__class__.__name__=='mappingproxy'; first standalone socket.socket.__dict__ 'accept' membership invariant in socketcovarnames207 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["accept"]
  expected: true

invariant socket_extra207.socket_socket_dict_contains_close:
  description: "socket.socket.__dict__.__contains__('close') returns True — 'close' is present in socket.socket.__dict__; socket.socket.close() is a Python-level method defined in Lib/socket.py that properly releases the socket file descriptor and handles the _closed flag; it also supports the context manager protocol (socket.socket implements __enter__ and __exit__); socket.socket.__dict__.__class__.__name__=='mappingproxy'; first standalone socket.socket.__dict__ 'close' membership invariant in socketcovarnames207 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["close"]
  expected: true

invariant socket_extra207.socket_socket_dict_contains_makefile:
  description: "socket.socket.__dict__.__contains__('makefile') returns True — 'makefile' is present in socket.socket.__dict__; socket.socket.makefile(mode='r', buffering=None, *, encoding=None, errors=None, newline=None) is a Python-level method in Lib/socket.py that returns a file-like wrapper (io.BufferedReader, io.BufferedWriter, or io.TextIOWrapper) around the socket; it is defined in Python (not C) so it can use the io module properly; first standalone socket.socket.__dict__ 'makefile' membership invariant in socketcovarnames207 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: socket.socket.__dict__.__contains__
  args: ["makefile"]
  expected: true

invariant socket_extra207.create_connection_co_varnames_len_15:
  description: "socket.create_connection.__code__.co_varnames.__len__() == 15 — co_varnames has 15 elements: parameters ('address', 'timeout', 'source_address', 'all_errors') plus locals ('host', 'port', 'exceptions', 'res', 'af', 'socktype', 'proto', 'canonname', 'sa', 'sock', 'exc'); socket.create_connection.__code__.co_argcount==3 (address, timeout, source_address — all_errors is keyword-only and not counted by co_argcount but appears in co_varnames); compare: getfqdn co_varnames len=4 << create_connection co_varnames len=15 (create_connection has many more locals due to its getaddrinfo loop); first standalone create_connection co_varnames length invariant in socketcovarnames207 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: co_varnames
  kind: python_call_eq
  function: socket.create_connection.__code__.co_varnames.__len__
  args: []
  expected: 15

invariant socket_extra207.getfqdn_co_varnames_len_4:
  description: "socket.getfqdn.__code__.co_varnames.__len__() == 4 — co_varnames==('name', 'hostname', 'aliases', 'ipaddrs') has 4 elements: 1 parameter 'name' plus 3 locals ('hostname' from gethostbyaddr, 'aliases' from gethostbyaddr, 'ipaddrs' from gethostbyaddr); socket.getfqdn.__code__.co_argcount==1 (only 'name' is a positional param); compare: getfqdn co_varnames len=4 << create_connection co_varnames len=15 (getfqdn is a simpler function that just calls gethostbyaddr); first standalone getfqdn co_varnames length invariant in socketcovarnames207 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: co_varnames
  kind: python_call_eq
  function: socket.getfqdn.__code__.co_varnames.__len__
  args: []
  expected: 4

