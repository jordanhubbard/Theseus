spec: click
version: ">=8.0"
backend: python_module(click)

docs: https://click.palletsprojects.com/en/stable/api/

provenance:
  derived_from:
    - "click documentation — https://click.palletsprojects.com/en/stable/api/"
    - "click changelog — https://click.palletsprojects.com/en/stable/changes/"
    - "Test vectors verified with click 8.3.1 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-08"
  not_derived_from:
    - "click source: src/click/__init__.py"
    - "click source: src/click/types.py"
    - "click source: src/click/core.py"
  notes:
    - "click.STRING, click.INT, click.FLOAT, click.BOOL are singleton instances, not classes."
    - "STRING.name == 'text', INT.name == 'integer', FLOAT.name == 'float', BOOL.name == 'boolean' (lowercase)."
    - "click.BaseCommand and click.MultiCommand are deprecated in click 8.x; their __name__ values are '_BaseCommand' and '_MultiCommand'."
    - "click.__version__ is deprecated in click 8.1+; use importlib.metadata instead."
    - "format_filename() returns ASCII paths unchanged; non-ASCII bytes are decoded with surrogateescape."
    - "click.echo, click.style, click.confirm are module-level functions (type 'function')."
    - "click.Path, click.Choice, click.File are ParamType subclasses (classes, not instances)."
  created_at: "2026-04-08T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — __version__ contains a dot and starts with a digit
# ---------------------------------------------------------------------------

invariant click.version.contains_dot:
  description: "__version__ contains '.' — version string is dotted (e.g. '8.3.1')"
  category: version
  kind: python_call_eq
  function: __version__.__contains__
  args: ["."]
  expected: true

invariant click.version.starts_with_digit:
  description: "__version__[0].isdigit() — version string starts with a digit"
  category: version
  kind: python_call_eq
  function: __version__.__getitem__
  args: [0]
  method: isdigit
  expected: true

# ---------------------------------------------------------------------------
# param_type_instances — singleton instances STRING, INT, FLOAT, BOOL
#
# These are instances of ParamType subclasses.  Their .name attributes
# are lowercase (verified empirically with click 8.3.1).
#
# STRING.name == "text"       (StringParamType)
# INT.name    == "integer"    (IntParamType)
# FLOAT.name  == "float"      (FloatParamType)
# BOOL.name   == "boolean"    (BoolParamType)
# ---------------------------------------------------------------------------

invariant click.param_types.string_name:
  description: "STRING.name == 'text' — singleton StringParamType instance reports name 'text'"
  category: param_types
  kind: python_call_eq
  function: STRING.name.__eq__
  args: ["text"]
  expected: true

invariant click.param_types.int_name:
  description: "INT.name == 'integer' — singleton IntParamType instance reports name 'integer'"
  category: param_types
  kind: python_call_eq
  function: INT.name.__eq__
  args: ["integer"]
  expected: true

invariant click.param_types.float_name:
  description: "FLOAT.name == 'float' — singleton FloatParamType instance reports name 'float'"
  category: param_types
  kind: python_call_eq
  function: FLOAT.name.__eq__
  args: ["float"]
  expected: true

invariant click.param_types.bool_name:
  description: "BOOL.name == 'boolean' — singleton BoolParamType instance reports name 'boolean'"
  category: param_types
  kind: python_call_eq
  function: BOOL.name.__eq__
  args: ["boolean"]
  expected: true

invariant click.param_types.string_class_name:
  description: "STRING.__class__.__name__ == 'StringParamType' — runtime class of STRING singleton"
  category: param_types
  kind: python_call_eq
  function: STRING.__class__.__name__.__eq__
  args: ["StringParamType"]
  expected: true

invariant click.param_types.int_class_name:
  description: "INT.__class__.__name__ == 'IntParamType' — runtime class of INT singleton"
  category: param_types
  kind: python_call_eq
  function: INT.__class__.__name__.__eq__
  args: ["IntParamType"]
  expected: true

# ---------------------------------------------------------------------------
# class_names — core Command hierarchy class name checks
#
# click.Command, Group, Option, Argument, Context, BaseCommand, MultiCommand,
# Path, Choice, File are all class objects (not instances).
# Access pattern: ClassName.__name__.__eq__("ClassName") → true.
# ---------------------------------------------------------------------------

invariant click.classes.Command_name:
  description: "Command.__name__ == 'Command'"
  category: classes
  kind: python_call_eq
  function: Command.__name__.__eq__
  args: ["Command"]
  expected: true

invariant click.classes.Group_name:
  description: "Group.__name__ == 'Group'"
  category: classes
  kind: python_call_eq
  function: Group.__name__.__eq__
  args: ["Group"]
  expected: true

invariant click.classes.Option_name:
  description: "Option.__name__ == 'Option'"
  category: classes
  kind: python_call_eq
  function: Option.__name__.__eq__
  args: ["Option"]
  expected: true

invariant click.classes.Argument_name:
  description: "Argument.__name__ == 'Argument'"
  category: classes
  kind: python_call_eq
  function: Argument.__name__.__eq__
  args: ["Argument"]
  expected: true

invariant click.classes.Context_name:
  description: "Context.__name__ == 'Context'"
  category: classes
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant click.classes.Path_name:
  description: "Path.__name__ == 'Path' — ParamType subclass for filesystem paths"
  category: classes
  kind: python_call_eq
  function: Path.__name__.__eq__
  args: ["Path"]
  expected: true

invariant click.classes.Choice_name:
  description: "Choice.__name__ == 'Choice' — ParamType subclass for enumerated choices"
  category: classes
  kind: python_call_eq
  function: Choice.__name__.__eq__
  args: ["Choice"]
  expected: true

invariant click.classes.File_name:
  description: "File.__name__ == 'File' — ParamType subclass for file arguments"
  category: classes
  kind: python_call_eq
  function: File.__name__.__eq__
  args: ["File"]
  expected: true

# ---------------------------------------------------------------------------
# format_filename — returns ASCII paths unchanged
#
# click.format_filename(s) decodes filesystem bytes; for ASCII strings it
# returns the input unchanged.
# ---------------------------------------------------------------------------

invariant click.format_filename.etc_hosts:
  description: "format_filename('/etc/hosts') == '/etc/hosts' — ASCII path returned unchanged"
  category: format_filename
  kind: python_call_eq
  function: format_filename
  args: ["/etc/hosts"]
  expected: "/etc/hosts"

invariant click.format_filename.tmp:
  description: "format_filename('/tmp') == '/tmp' — short ASCII path returned unchanged"
  category: format_filename
  kind: python_call_eq
  function: format_filename
  args: ["/tmp"]
  expected: "/tmp"

# ---------------------------------------------------------------------------
# callables — echo, style, confirm are module-level functions
# ---------------------------------------------------------------------------

invariant click.callables.echo_is_function:
  description: "echo.__class__.__name__ == 'function' — click.echo is a plain function"
  category: callables
  kind: python_call_eq
  function: echo.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant click.callables.style_is_function:
  description: "style.__class__.__name__ == 'function' — click.style is a plain function"
  category: callables
  kind: python_call_eq
  function: style.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant click.callables.confirm_is_function:
  description: "confirm.__class__.__name__ == 'function' — click.confirm is a plain function"
  category: callables
  kind: python_call_eq
  function: confirm.__class__.__name__.__eq__
  args: ["function"]
  expected: true

