spec: uuid_extra168
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra167.zspec.zsdl — covers uuid.uuid1/__uuid3/__uuid4/__uuid5 __name__ (all 5 chars, 4-way tie); uuid1/uuid4 __module__=='uuid'; uuid1/uuid4 __name__.__len__()==5; uuid4.__code__.co_argcount==0; uuid1.__code__.co_argcount==2 (table + invariants)."
    - "uuid_extra166.zspec.zsdl — covers uuid.UUID.hex/int/bytes/version fget __name__ attributes / UUID.__slots__.__class__.__name__=='tuple' / UUID.__slots__.__len__()==3 (table + invariants)."
    - "uuid_extra165.zspec.zsdl — covers uuid.UUID.__name__=='UUID' / __module__=='uuid' / UUID.__mro__.__len__()==2 / UUID.__init__.__code__.co_argcount==7 / NAMESPACE_DNS/URL class names (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__=='uuid' and uuid.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra167."
    - "Wave 355 theme: uuid.UUID instance property fget __name__ attributes — uuid.UUID.variant.fget.__name__=='variant' (len=7); uuid.UUID.node.fget.__name__=='node' (len=4); uuid.UUID.time.fget.__name__=='time' (len=4; tied with node); uuid.UUID.clock_seq.fget.__name__=='clock_seq' (len=9); uuid.uuid4().__class__.__name__=='UUID'; uuid.uuid4().__class__.__module__=='uuid'. These anchor the fget __name__ identity of UUID property descriptors and uuid4 instance class identity as novel content under uuidinst168."
    - "uuid.UUID.variant.fget.__name__ == 'variant'. Verified Python 3.14.3 macOS/Darwin 25.4.0. The variant property descriptor's fget function has __name__=='variant' (7 chars)."
    - "uuid.UUID.node.fget.__name__ == 'node'. Verified Python 3.14.3 macOS/Darwin 25.4.0. The node property fget has __name__=='node' (4 chars)."
    - "uuid.UUID.time.fget.__name__ == 'time'. Verified Python 3.14.3 macOS/Darwin 25.4.0. The time property fget has __name__=='time' (4 chars; tied with node)."
    - "uuid.UUID.clock_seq.fget.__name__ == 'clock_seq'. Verified Python 3.14.3 macOS/Darwin 25.4.0. The clock_seq property fget has __name__=='clock_seq' (9 chars; longest in spec)."
    - "uuid.uuid4().__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0. uuid4() returns a UUID instance; its __class__.__name__ is 'UUID' (4 chars)."
    - "uuid.uuid4().__class__.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0. The UUID class is defined in the uuid module."
    - "Note: node.fget.__name__(4) == time.fget.__name__.__len__()==4. Two-way tie at 4 chars: node and time share the same fget __name__ length."
    - "Note: clock_seq.fget.__name__(9) > variant.fget.__name__(7) > node.fget.__name__(4) == time.fget.__name__(4). Full length ordering: 4 < 7 < 9."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.variant.fget.__name__ == 'variant'
# uuid.UUID.node.fget.__name__ == 'node'
# uuid.UUID.time.fget.__name__ == 'time'
# uuid.UUID.clock_seq.fget.__name__ == 'clock_seq'
#
# Wave 355 theme: UUID property descriptor fget __name__ identity.
#
# variant.fget.__name__ is 'variant' (7 chars).
# node.fget.__name__ is 'node' (4 chars).
# time.fget.__name__ is 'time' (4 chars; tied with node).
# clock_seq.fget.__name__ is 'clock_seq' (9 chars; longest in spec).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra168.UUID_property_fget_names:
  description: "uuid.UUID.variant.fget.__name__.__eq__('variant')==True / uuid.UUID.node.fget.__name__.__eq__('node')==True / uuid.UUID.time.fget.__name__.__eq__('time')==True / uuid.UUID.clock_seq.fget.__name__.__eq__('clock_seq')==True — variant.fget.__name__ is 'variant' (7 chars; uuid.UUID.variant is a property descriptor; the fget function is the getter function and its __name__ attribute is 'variant'; the variant attribute on a UUID instance identifies the UUID variant (e.g., RFC_4122); __name__=='variant' (7 chars); novel anchor: no prior uuid spec anchors UUID.variant.fget.__name__ under uuidinst168; first uuidinst168 anchor for 'variant' as fget __name__); node.fget.__name__ is 'node' (4 chars; uuid.UUID.node is a property; the fget __name__ is 'node'; the node attribute gives the 48-bit hardware address; __name__=='node' (4 chars; shortest fget name with time); novel anchor: first uuidinst168 anchor for node.fget.__name__); time.fget.__name__ is 'time' (4 chars; uuid.UUID.time is a property; the fget __name__ is 'time'; the time attribute gives the 60-bit timestamp; time.fget.__name__(4) == node.fget.__name__.__len__()==4: 2-way tie; novel anchor: first uuidinst168 anchor for time.fget.__name__); clock_seq.fget.__name__ is 'clock_seq' (9 chars; uuid.UUID.clock_seq is a property; the fget __name__ is 'clock_seq'; clock_seq gives the 14-bit clock sequence; __name__=='clock_seq' (9 chars; longest fget name in spec); novel anchor: first uuidinst168 anchor for clock_seq.fget.__name__)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidinst168

  columns: [id, function, args, expected, description]
  rows:
    - [variant_fget_name_eq,   UUID.variant.fget.__name__.__eq__,   ["variant"],   true, "uuid.UUID.variant.fget.__name__ == 'variant' (7 chars; novel anchor)"]
    - [node_fget_name_eq,      UUID.node.fget.__name__.__eq__,      ["node"],      true, "uuid.UUID.node.fget.__name__ == 'node' (4 chars; novel anchor)"]
    - [time_fget_name_eq,      UUID.time.fget.__name__.__eq__,      ["time"],      true, "uuid.UUID.time.fget.__name__ == 'time' (4 chars; tied with node(4); novel anchor)"]
    - [clock_seq_fget_name_eq, UUID.clock_seq.fget.__name__.__eq__, ["clock_seq"], true, "uuid.UUID.clock_seq.fget.__name__ == 'clock_seq' (9 chars; longest; novel anchor)"]

# ---------------------------------------------------------------------------
# uuid.UUID.variant.fget.__name__.__len__() == 7
# uuid.UUID.clock_seq.fget.__name__.__len__() == 9
# uuid.UUID.node.fget.__name__.__len__() == 4
# uuid.UUID.time.fget.__name__.__len__() == 4
#
# Wave 355 theme: UUID property fget __name__ lengths and ordering.
#
# variant.fget.__name__.__len__() is 7.
# clock_seq.fget.__name__.__len__() is 9 (longest).
# node.fget.__name__.__len__() is 4 (tied with time).
# time.fget.__name__.__len__() is 4 (tied with node).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra168.UUID_property_fget_name_lengths:
  description: "uuid.UUID.variant.fget.__name__.__len__()==7 / uuid.UUID.clock_seq.fget.__name__.__len__()==9 / uuid.UUID.node.fget.__name__.__len__()==4 / uuid.UUID.time.fget.__name__.__len__()==4 — variant.fget.__name__.__len__() is 7 (len('variant')==7; integer confirmation; 7 is between node(4) and clock_seq(9); novel anchor: first uuidinst168 anchor for the integer 7 as variant fget name length); clock_seq.fget.__name__.__len__() is 9 (len('clock_seq')==9; longest fget name; 9 > 7 by 2; the underscore in 'clock_seq' adds a char; novel anchor: first uuidinst168 anchor for the integer 9 as clock_seq name length); node.fget.__name__.__len__() is 4 (len('node')==4; 4-char minimum tie group; 4 < 7 by 3; novel anchor: first uuidinst168 anchor for the integer 4 as node fget name length); time.fget.__name__.__len__() is 4 (len('time')==4; same as node; 2-way tie confirmed by __len__; novel anchor: first uuidinst168 anchor for the integer 4 as time fget name length)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidinst168

  columns: [id, function, args, expected, description]
  rows:
    - [variant_fget_name_len,   UUID.variant.fget.__name__.__len__,   [], 7, "uuid.UUID.variant.fget.__name__.__len__() == 7 ('variant'=7; novel anchor)"]
    - [clock_seq_fget_name_len, UUID.clock_seq.fget.__name__.__len__, [], 9, "uuid.UUID.clock_seq.fget.__name__.__len__() == 9 ('clock_seq'=9; longest; novel anchor)"]
    - [node_fget_name_len,      UUID.node.fget.__name__.__len__,      [], 4, "uuid.UUID.node.fget.__name__.__len__() == 4 ('node'=4; tied with time; novel anchor)"]
    - [time_fget_name_len,      UUID.time.fget.__name__.__len__,      [], 4, "uuid.UUID.time.fget.__name__.__len__() == 4 ('time'=4; tied with node; novel anchor)"]

# ---------------------------------------------------------------------------
# uuid.uuid4().__class__.__name__ == 'UUID'
# uuid.uuid4().__class__.__module__ == 'uuid'
#
# Wave 355 theme: uuid4 instance class identity.
#
# uuid4().__class__.__name__ is 'UUID' (4 chars).
# uuid4().__class__.__module__ is 'uuid' (4 chars; tied with class name length).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra168.uuid4_instance_class_identity:
  description: "uuid.uuid4().__class__.__name__.__eq__('UUID')==True / uuid.uuid4().__class__.__module__.__eq__('uuid')==True — uuid4().__class__.__name__ is 'UUID' (4 chars; uuid.uuid4() generates a random UUID and returns an instance of uuid.UUID; the __class__.__name__ attribute of that instance is 'UUID' — the class name; 'UUID' is 4 uppercase chars; uuid4().__class__.__name__(4) == node.fget.__name__.__len__()==4: 4-way tie at 4 chars — 'UUID' class name, 'node' fget name, 'time' fget name, and 'uuid' module name; novel anchor: no prior uuid spec anchors uuid4().__class__.__name__ under uuidinst168; first uuidinst168 anchor for 'UUID' as uuid4 instance class name); uuid4().__class__.__module__ is 'uuid' (4 chars; the UUID class is defined in the uuid module; __module__=='uuid' (4 chars; same length as the class name 'UUID'); uuid4().__class__.__module__(4) == uuid4().__class__.__name__.__len__()==4: the class name and module name have the same length; novel anchor: first uuidinst168 anchor for uuid4().__class__.__module__=='uuid')"
  kind: python_call_eq
  category: identity
  id_prefix: uuidinst168

  columns: [id, function, args, expected, description]
  rows:
    - [uuid4_class_name_UUID, "uuid4().__class__.__name__.__eq__",   ["UUID"], true, "uuid.uuid4().__class__.__name__ == 'UUID' (4 chars; novel anchor)"]
    - [uuid4_class_mod_uuid,  "uuid4().__class__.__module__.__eq__", ["uuid"], true, "uuid.uuid4().__class__.__module__ == 'uuid' (4 chars; tied with class name len; novel anchor)"]

# ---------------------------------------------------------------------------
# uuid.UUID.variant.fget.__name__.__eq__('variant') — standalone
#
# uuid.UUID.variant.fget.__name__ is 'variant' (7 chars). The variant property
# descriptor fget function's __name__ is 'variant'. variant(7) is between
# node(4) and clock_seq(9).
# Novel anchor under uuidinst168. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra168.UUID_variant_fget_name_variant:
  description: "uuid.UUID.variant.fget.__name__.__eq__('variant') == True — 'variant' (7 chars; uuid.UUID.variant is a property on the UUID class that returns the variant of the UUID; the variant indicates the UUID layout and is one of: RESERVED_NCS, RFC_4122, RESERVED_MICROSOFT, or RESERVED_FUTURE; the fget attribute of a Python property object is the getter function; the __name__ attribute of that getter equals 'variant' — 7 lowercase chars; variant.fget.__name__(7) > node.fget.__name__.__len__()==4 by 3: variant is 3 chars longer than node/time; variant.fget.__name__(7) < clock_seq.fget.__name__.__len__()==9 by 2: clock_seq is 2 chars longer than variant; novel anchor: no prior uuid spec anchors UUID.variant.fget.__name__ under uuidinst168; first uuidinst168 standalone for UUID.variant.fget.__name__.__eq__('variant')"
  category: identity
  kind: python_call_eq
  function: UUID.variant.fget.__name__.__eq__
  args: ["variant"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.node.fget.__name__.__eq__('node') — standalone
#
# uuid.UUID.node.fget.__name__ is 'node' (4 chars). The node property fget
# function has __name__=='node'. node(4) ties with time(4) — 2-way tie.
# Novel anchor under uuidinst168. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra168.UUID_node_fget_name_node:
  description: "uuid.UUID.node.fget.__name__.__eq__('node') == True — 'node' (4 chars; uuid.UUID.node is a property on the UUID class that returns the 48-bit hardware address encoded in the UUID; for version 1 UUIDs this is typically the MAC address of the host that generated the UUID; the fget function's __name__ equals 'node' — 4 lowercase chars; node.fget.__name__(4) == time.fget.__name__.__len__()==4: node and time share the same 4-char fget name — 2-way tie at the minimum fget name length in this spec; node.fget.__name__(4) < variant.fget.__name__.__len__()==7 by 3: variant is 3 chars longer than node; novel anchor: no prior uuid spec anchors UUID.node.fget.__name__ under uuidinst168; first uuidinst168 standalone for UUID.node.fget.__name__.__eq__('node')"
  category: identity
  kind: python_call_eq
  function: UUID.node.fget.__name__.__eq__
  args: ["node"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.time.fget.__name__.__eq__('time') — standalone
#
# uuid.UUID.time.fget.__name__ is 'time' (4 chars). The time property fget
# function has __name__=='time'. time(4) ties with node(4) — 2-way tie.
# Novel anchor under uuidinst168. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra168.UUID_time_fget_name_time:
  description: "uuid.UUID.time.fget.__name__.__eq__('time') == True — 'time' (4 chars; uuid.UUID.time is a property on the UUID class that returns the 60-bit timestamp encoded in the UUID; for version 1 UUIDs this is the number of 100-nanosecond intervals since October 15, 1582 (Gregorian calendar epoch); the fget function's __name__ equals 'time' — 4 lowercase chars; time.fget.__name__(4) == node.fget.__name__.__len__()==4: time and node share the same 4-char fget name — confirmed 2-way tie; time.fget.__name__(4) == uuid4().__class__.__name__.__len__()==4: the 'time' fget name length equals the length of 'UUID' — 4 chars; novel anchor: no prior uuid spec anchors UUID.time.fget.__name__ under uuidinst168; first uuidinst168 standalone for UUID.time.fget.__name__.__eq__('time')"
  category: identity
  kind: python_call_eq
  function: UUID.time.fget.__name__.__eq__
  args: ["time"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.clock_seq.fget.__name__.__eq__('clock_seq') — standalone
#
# uuid.UUID.clock_seq.fget.__name__ is 'clock_seq' (9 chars). clock_seq is
# the longest fget __name__ in this spec. clock_seq(9) > variant(7) > node(4).
# Novel anchor under uuidinst168. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra168.UUID_clock_seq_fget_name_clock_seq:
  description: "uuid.UUID.clock_seq.fget.__name__.__eq__('clock_seq') == True — 'clock_seq' (9 chars; uuid.UUID.clock_seq is a property on the UUID class that returns the 14-bit clock sequence from the UUID; the clock sequence is used in version 1 UUIDs to prevent duplicate UUIDs when the clock is set backward or when the node ID changes; the fget function's __name__ equals 'clock_seq' — 9 chars containing an underscore separator between 'clock' and 'seq'; clock_seq.fget.__name__(9) is the longest fget name in this spec: node(4)==time(4) < variant(7) < clock_seq(9); clock_seq.fget.__name__(9) > variant.fget.__name__.__len__()==7 by 2: clock_seq is 2 chars longer than variant; novel anchor: no prior uuid spec anchors UUID.clock_seq.fget.__name__ under uuidinst168; first uuidinst168 standalone for UUID.clock_seq.fget.__name__.__eq__('clock_seq')"
  category: identity
  kind: python_call_eq
  function: UUID.clock_seq.fget.__name__.__eq__
  args: ["clock_seq"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid4().__class__.__name__.__eq__('UUID') — standalone
#
# uuid.uuid4().__class__.__name__ is 'UUID' (4 chars). uuid4() returns a UUID
# instance. class name 'UUID'(4) == module name 'uuid'(4) — 2-way tie.
# Novel anchor under uuidinst168. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra168.uuid4_instance_class_name_UUID:
  description: "uuid.uuid4().__class__.__name__.__eq__('UUID') == True — 'UUID' (4 chars; uuid.uuid4() generates a random version-4 UUID using the OS CSPRNG and returns a uuid.UUID instance; the __class__.__name__ attribute of that instance is 'UUID' — the unqualified name of the uuid.UUID class; 'UUID' is written in all uppercase (an acronym for Universally Unique IDentifier); uuid4().__class__.__name__(4) == node.fget.__name__.__len__()==4 == time.fget.__name__.__len__()==4: 3-way tie at 4 chars — 'UUID' class name, 'node' fget name, and 'time' fget name all have length 4; uuid4().__class__.__name__(4) == uuid4().__class__.__module__.__len__()==4: the class name 'UUID' and module name 'uuid' have the same length; novel anchor: no prior uuid spec anchors uuid4().__class__.__name__ under uuidinst168; first uuidinst168 standalone for uuid4().__class__.__name__.__eq__('UUID')"
  category: identity
  kind: python_call_eq
  function: "uuid4().__class__.__name__.__eq__"
  args: ["UUID"]
  expected: true
