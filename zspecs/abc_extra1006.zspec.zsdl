spec: abc_extra1006
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.ABCMeta, abc.abstractmethod, abc.get_cache_token, and abc.update_abstractmethods doc class names"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra1006.abcmeta_doc_class:
  description: "abc.ABCMeta method __doc__ class name identity"
  kind: python_call_eq
  category: abcmeta_doc_class
  id_prefix: ab1006md
  columns: [id, function, args, expected]
  rows:
    - [ab1006md001, abc.ABCMeta.__new__.__doc__.__class__.__name__.__eq__,            ["str"], true]
    - [ab1006md002, abc.ABCMeta.register.__doc__.__class__.__name__.__eq__,           ["str"], true]
    - [ab1006md003, abc.ABCMeta.__instancecheck__.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [ab1006md004, abc.ABCMeta.__subclasscheck__.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [ab1006md005, abc.ABCMeta.__doc__.__class__.__name__.__eq__,                   ["str"], true]
    - [ab1006md006, abc.ABCMeta.__init__.__doc__.__class__.__name__.__eq__,           ["str"], true]

table abc_extra1006.abstractmethod_doc_class:
  description: "abc.abstractmethod __call__ and other method __doc__ class name identity"
  kind: python_call_eq
  category: abstractmethod_doc_class
  id_prefix: ab1006ad
  columns: [id, function, args, expected]
  rows:
    - [ab1006ad001, abc.abstractmethod.__call__.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab1006ad002, abc.abstractmethod.__doc__.__class__.__name__.__eq__,          ["str"], true]
    - [ab1006ad003, abc.abstractmethod.__init__.__doc__.__class__.__name__.__eq__, ["str"], true]

table abc_extra1006.module_func_doc_class:
  description: "abc module-level function __doc__ class name identity"
  kind: python_call_eq
  category: module_func_doc_class
  id_prefix: ab1006fd
  columns: [id, function, args, expected]
  rows:
    - [ab1006fd001, abc.get_cache_token.__doc__.__class__.__name__.__eq__,        ["str"], true]
    - [ab1006fd002, abc.update_abstractmethods.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ab1006fd003, abc.ABC.__doc__.__class__.__name__.__eq__,                    ["str"], true]
    - [ab1006fd004, abc.ABCMeta.__new__.__qualname__.__eq__,                      ["ABCMeta.__new__"], true]
    - [ab1006fd005, abc.ABCMeta.register.__qualname__.__eq__,                     ["ABCMeta.register"], true]
    - [ab1006fd006, abc.ABCMeta.__instancecheck__.__qualname__.__eq__,            ["ABCMeta.__instancecheck__"], true]
