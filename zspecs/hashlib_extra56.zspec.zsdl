spec: hashlib_extra56
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra55.zspec.zsdl — covers algorithms_guaranteed.__contains__ for sha224/sha384/blake2b/blake2s/sha3_256/sha3_512; algorithms_available/guaranteed __class__.__module__.__len__()==8; hashlib.__name__.__eq__('hashlib') and __name__.__len__()==7."
    - "hashlib_extra54.zspec.zsdl — covers algorithms_available/__guaranteed__ __class__.__name__/__qualname__/__module__.__eq__; algorithms_guaranteed.__contains__ for sha256/md5/sha1/sha512."
    - "hashlib_extra53.zspec.zsdl — covers sha256/md5/sha1/sha3_256/blake2b/new/pbkdf2_hmac __module__.__class__.__name__/__qualname__ and __module__.__len__()."
    - "hashlib_extra52.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __doc__.__class__.__name__/__qualname__.__eq__('str')."
    - "hashlib_extra51.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __name__.__class__.__name__.__eq__('str')."
    - "hashlib_extra18.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/new __name__/__qualname__ string values."
    - "hashlib_extra6.zspec.zsdl — covers sha256/md5/sha1/sha384/sha512/pbkdf2_hmac/sha3_256/blake2b/blake2s/scrypt __module__.__eq__ string values."
    - "hashlib_extra50.zspec.zsdl — covers sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s __class__.__qualname__/__module__ equality."
  notes:
    - "This spec extends hashlib through hashlib_extra55; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: No prior hashlib spec checks __dict__.__class__.__name__.__eq__('mappingproxy') for blake2b or blake2s. blake2b and blake2s are C extension types; their __dict__ is a mappingproxy. No prior spec checks the __name__ or __qualname__ of that mappingproxy type for these two classes. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__class__.__name__ == 'mappingproxy'. blake2b is a C extension type; its class namespace is a mappingproxy. No prior hashlib spec checks __dict__.__class__.__name__.__eq__('mappingproxy') for blake2b. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__dict__.__class__.__name__ == 'mappingproxy'. Same type identity as blake2b. No prior hashlib spec checks __dict__.__class__.__name__.__eq__('mappingproxy') for blake2s. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior hashlib spec checks __dict__.__class__.__qualname__ for blake2b or blake2s. __class__.__qualname__ is a distinct attribute chain from __class__.__name__. For non-nested C types, __qualname__ == __name__ == 'mappingproxy'. The __qualname__ access path is an independent regression vector. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__dict__.__class__.__qualname__ == 'mappingproxy'. The mappingproxy type's __qualname__ is 'mappingproxy'. No prior spec checks __dict__.__class__.__qualname__.__eq__ for blake2b. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior hashlib spec checks the hashlib module's own __dict__.__class__.__name__ or __qualname__. hashlib_extra55 checks the module __name__ attribute (hashlib.__name__.__eq__('hashlib')). But the module's __dict__ — the namespace mapping — is also a mappingproxy; its type's __name__ and __qualname__ have never been checked. Under python_module(hashlib), function: __dict__.__class__.__name__.__eq__ resolves to hashlib.__dict__.__class__.__name__.__eq__('mappingproxy'). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.__dict__.__class__.__name__ == 'mappingproxy'. The hashlib module's namespace dict is a mappingproxy. No prior hashlib spec checks __dict__.__class__.__name__.__eq__('mappingproxy') for the module itself. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.__dict__.__class__.__qualname__ == 'mappingproxy'. The mappingproxy type's __qualname__ equals its __name__ for non-nested C types. No prior hashlib spec checks __dict__.__class__.__qualname__.__eq__('mappingproxy') for the module. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 4: No prior hashlib spec checks __qualname__.__class__.__name__ == 'str' for any hashlib function. hashlib_extra51 checks __name__.__class__.__name__.__eq__('str') (the __name__ axis). But __qualname__ is a distinct attribute; its type is also str. This provides an independent regression vector on the __qualname__ type axis. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__qualname__.__class__.__name__ == 'str'. sha256 is a callable (builtin_function_or_method or similar); its __qualname__ is a str. No prior hashlib spec checks __qualname__.__class__.__name__.__eq__('str') for any hashlib function. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.md5.__qualname__.__class__.__name__ == 'str'. Same reasoning as sha256. No prior hashlib spec checks this for md5. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__.__class__.__name__ == 'str'. No prior hashlib spec checks this for sha1. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__.__class__.__name__ == 'str'. No prior hashlib spec checks this for pbkdf2_hmac. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__qualname__.__class__.__name__ == 'str'. No prior hashlib spec checks this for sha3_256. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__.__class__.__name__ == 'str'. No prior hashlib spec checks this for new. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.blake2b and hashlib.blake2s __dict__.__class__.__name__.__eq__
#
# No prior hashlib spec checks __dict__.__class__.__name__.__eq__('mappingproxy')
# for blake2b or blake2s. blake2b and blake2s are C extension types; their
# class namespace dict is always a mappingproxy in CPython. This is the
# string-value axis: if the mappingproxy type were renamed, this __eq__ check
# catches it regardless of whether the new name has the same length.
# ---------------------------------------------------------------------------

table hashlib_extra56.blake_dict_class_name_eq:
  description: "hashlib.blake2b/__dict__/__class__/__name__.__eq__('mappingproxy') and blake2s same — C extension class namespaces are mappingproxy; no prior hashlib spec checks __dict__.__class__.__name__.__eq__('mappingproxy') for blake2b or blake2s"
  kind: python_call_eq
  category: type_structure
  id_prefix: hashlibdict56

  columns: [id, function, args, expected]
  rows:
    - [blake2b_dict_class_name_eq, blake2b.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [blake2s_dict_class_name_eq, blake2s.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# hashlib.blake2b __dict__.__class__.__qualname__.__eq__
#
# No prior hashlib spec checks __dict__.__class__.__qualname__ for any class.
# For the mappingproxy C type, __qualname__ == __name__ == 'mappingproxy'.
# The __qualname__ access path is a distinct regression vector from __name__:
# if the type acquired a nested definition, __qualname__ would include a
# dotted prefix while __name__ would remain flat.
# ---------------------------------------------------------------------------

invariant hashlib_extra56.blake2b.dict_class_qualname_eq:
  description: "hashlib.blake2b.__dict__.__class__.__qualname__ == 'mappingproxy' — the mappingproxy type's __qualname__; distinct from __name__ chain; no prior hashlib spec checks __dict__.__class__.__qualname__.__eq__ for blake2b or any hashlib class"
  category: type_structure
  kind: python_call_eq
  function: blake2b.__dict__.__class__.__qualname__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib module __dict__.__class__.__name__ and __qualname__
#
# No prior hashlib spec checks the module's own __dict__.__class__.__name__
# or __qualname__. hashlib_extra55 checks hashlib.__name__.__eq__('hashlib')
# (the module's __name__ attribute), not its __dict__.__class__.__name__.
# Under python_module(hashlib), function: __dict__.__class__.__name__.__eq__
# resolves to hashlib.__dict__.__class__.__name__.__eq__('mappingproxy').
# Module namespaces are mappingproxy objects in CPython.
# ---------------------------------------------------------------------------

invariant hashlib_extra56.module.dict_class_name_eq:
  description: "hashlib.__dict__.__class__.__name__ == 'mappingproxy' — the hashlib module's namespace dict is a mappingproxy; distinct from blake2b/blake2s __dict__ (class dicts); no prior hashlib spec checks __dict__.__class__.__name__.__eq__ for the module itself"
  category: module_identity
  kind: python_call_eq
  function: __dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant hashlib_extra56.module.dict_class_qualname_eq:
  description: "hashlib.__dict__.__class__.__qualname__ == 'mappingproxy' — the mappingproxy type's __qualname__ for the module namespace; independent of __name__ axis; no prior hashlib spec checks __dict__.__class__.__qualname__.__eq__ for the hashlib module"
  category: module_identity
  kind: python_call_eq
  function: __dict__.__class__.__qualname__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib function __qualname__.__class__.__name__ == 'str'
#
# hashlib_extra51 checks __name__.__class__.__name__.__eq__('str') for
#   sha256/md5/sha1/pbkdf2_hmac/sha3_256/new/blake2b/blake2s (__name__ axis).
# No prior hashlib spec checks __qualname__.__class__.__name__.__eq__('str')
# for any hashlib function. For module-level callables, __qualname__ is a
# plain str object. This provides an independent regression vector on the
# __qualname__ type axis: if __qualname__ were somehow replaced by a non-str,
# only the __qualname__ chain would detect it.
# ---------------------------------------------------------------------------

table hashlib_extra56.function_qualname_class_name_eq:
  description: "hashlib.sha256/md5/sha1/pbkdf2_hmac/sha3_256/new __qualname__.__class__.__name__.__eq__('str') — function __qualname__ is a plain str; no prior hashlib spec checks __qualname__.__class__.__name__.__eq__('str') for any hashlib function; extra51 covers __name__.__class__.__name__.__eq__('str') (different chain via __name__)"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlibdict56

  columns: [id, function, args, expected]
  rows:
    - [sha256_qualname_class_name,    sha256.__qualname__.__class__.__name__.__eq__,    ["str"], true]
    - [md5_qualname_class_name,       md5.__qualname__.__class__.__name__.__eq__,       ["str"], true]
    - [sha1_qualname_class_name,      sha1.__qualname__.__class__.__name__.__eq__,      ["str"], true]
    - [pbkdf2_qualname_class_name,    pbkdf2_hmac.__qualname__.__class__.__name__.__eq__, ["str"], true]
    - [sha3_256_qualname_class_name,  sha3_256.__qualname__.__class__.__name__.__eq__,  ["str"], true]
    - [new_qualname_class_name,       new.__qualname__.__class__.__name__.__eq__,       ["str"], true]
