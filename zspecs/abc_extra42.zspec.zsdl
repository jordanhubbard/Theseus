spec: abc_extra42
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra41.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all five, abstractproperty lengths, ABCMeta.register qualname lengths, ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__(), various qualname length tables, ABCMeta MRO entries, ABC/__abstractmethods__/__class__/__name__=='frozenset', ABC/__abstractmethods__/__len__()==0, ABCMeta.__call__/__qualname__=='type.__call__', class qualname string equality, abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta', abstractproperty/__mro__.__len__()==3, abstractclassmethod/__mro__.__len__()==3, abstractstaticmethod/__mro__.__len__()==3, abstractproperty/__bases__[0].__name__.__len__()==8, abstractclassmethod/__bases__[0].__name__.__len__()==11, abstractstaticmethod/__bases__[0].__name__.__len__()==12 (extra40), __class__.__qualname__ string equality and __len__() for abstractproperty/ABC/ABCMeta/abstractmethod/get_cache_token, ABCMeta.__abstractmethods__ raises AttributeError (extra41)."
    - "This spec covers: abstractmethod/__class__.__module__=='builtins'; abstractproperty/__class__.__module__=='builtins'; ABC/__class__.__module__=='abc'; ABCMeta/__class__.__module__=='builtins'; get_cache_token/__class__.__module__=='builtins'; abstractclassmethod/__class__.__module__=='builtins'; abstractstaticmethod/__class__.__module__=='builtins'; __class__.__module__.__len__() == 8 for all except ABC (3)."
    - "abc.abstractmethod.__class__.__module__ == 'builtins'. abstractmethod is a plain Python function; its __class__ is the built-in 'function' type, whose __module__ is 'builtins'. len('builtins') == 8. Verified with Python 3.14.3."
    - "abc.abstractproperty.__class__.__module__ == 'builtins'. abstractproperty is a subclass of property; its metaclass is 'type', which is a built-in type with __module__ == 'builtins'. len('builtins') == 8. Verified with Python 3.14.3."
    - "abc.ABC.__class__.__module__ == 'abc'. ABC is an instance of ABCMeta; ABCMeta is defined in the abc module, so ABCMeta.__module__ == 'abc'. Therefore ABC.__class__.__module__ == 'abc'. len('abc') == 3. This is the only abc export whose __class__.__module__ is NOT 'builtins'. Verified with Python 3.14.3."
    - "abc.ABCMeta.__class__.__module__ == 'builtins'. ABCMeta is a class; its metaclass is the built-in 'type', whose __module__ is 'builtins'. len('builtins') == 8. Verified with Python 3.14.3."
    - "abc.get_cache_token.__class__.__module__ == 'builtins'. get_cache_token is a C-extension function from _abc; its __class__ is builtin_function_or_method, which has __module__ == 'builtins'. len('builtins') == 8. Verified with Python 3.14.3."
    - "abc.abstractclassmethod.__class__.__module__ == 'builtins'. abstractclassmethod is a subclass of classmethod; its metaclass is 'type' with __module__ == 'builtins'. len('builtins') == 8. Verified with Python 3.14.3."
    - "abc.abstractstaticmethod.__class__.__module__ == 'builtins'. abstractstaticmethod is a subclass of staticmethod; its metaclass is 'type' with __module__ == 'builtins'. len('builtins') == 8. Verified with Python 3.14.3."
    - "ABC.__class__.__module__ == 'abc' (3 chars) is distinct from all other abc exports whose __class__.__module__ == 'builtins' (8 chars). This is because ABC is an instance of the user-defined metaclass ABCMeta (which lives in abc), while all other exports are either plain Python functions (metaclass 'function' in 'builtins'), classes with metaclass 'type' (in 'builtins'), or C-extension callables (class in 'builtins'). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc object __class__.__module__ string equality — extra42
#
# Six of the seven abc exports have __class__.__module__ == 'builtins':
#   abstractmethod.__class__.__module__      == 'builtins'
#   abstractproperty.__class__.__module__    == 'builtins'
#   ABCMeta.__class__.__module__             == 'builtins'
#   get_cache_token.__class__.__module__     == 'builtins'
#   abstractclassmethod.__class__.__module__ == 'builtins'
#   abstractstaticmethod.__class__.__module__== 'builtins'
# The exception is ABC, whose metaclass (ABCMeta) lives in 'abc':
#   ABC.__class__.__module__                 == 'abc'
# Prior specs captured __class__.__name__ and __class__.__qualname__; extra42
# captures the __class__.__module__ dimension for the first time.
# ---------------------------------------------------------------------------

table abc_extra42.class_module_eq:
  description: "abc object __class__.__module__ string equality in extra42 namespace — six objects have 'builtins', ABC has 'abc'"
  kind: python_call_eq
  category: module_identity
  id_prefix: abcClsModEq42

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod,       abstractmethod.__class__.__module__.__eq__,       ["builtins"], true, "abstractmethod.__class__.__module__ == 'builtins' — function type is in builtins (8 chars)"]
    - [abstractproperty,     abstractproperty.__class__.__module__.__eq__,     ["builtins"], true, "abstractproperty.__class__.__module__ == 'builtins' — metaclass 'type' is in builtins (8 chars)"]
    - [ABCMeta,              ABCMeta.__class__.__module__.__eq__,              ["builtins"], true, "ABCMeta.__class__.__module__ == 'builtins' — metaclass 'type' is in builtins (8 chars)"]
    - [get_cache_token,      get_cache_token.__class__.__module__.__eq__,      ["builtins"], true, "get_cache_token.__class__.__module__ == 'builtins' — builtin_function_or_method is in builtins (8 chars)"]
    - [abstractclassmethod,  abstractclassmethod.__class__.__module__.__eq__,  ["builtins"], true, "abstractclassmethod.__class__.__module__ == 'builtins' — metaclass 'type' is in builtins (8 chars)"]
    - [abstractstaticmethod, abstractstaticmethod.__class__.__module__.__eq__, ["builtins"], true, "abstractstaticmethod.__class__.__module__ == 'builtins' — metaclass 'type' is in builtins (8 chars)"]
    - [ABC,                  ABC.__class__.__module__.__eq__,                  ["abc"],      true, "ABC.__class__.__module__ == 'abc' — metaclass ABCMeta is defined in the abc module (3 chars)"]

# ---------------------------------------------------------------------------
# abc object __class__.__module__.__len__() — extra42
#
# Six exports share __class__.__module__.__len__() == 8 ('builtins'):
#   abstractmethod/abstractproperty/ABCMeta/get_cache_token/abstractclassmethod/abstractstaticmethod
# ABC is the outlier with __class__.__module__.__len__() == 3 ('abc').
# ---------------------------------------------------------------------------

table abc_extra42.class_module_lengths:
  description: "abc object __class__.__module__.__len__() in extra42 namespace — six have 8 ('builtins'), ABC has 3 ('abc')"
  kind: python_call_eq
  category: module_identity
  id_prefix: abcClsModLen42

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod,       abstractmethod.__class__.__module__.__len__,       [], 8, "abstractmethod.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"]
    - [abstractproperty,     abstractproperty.__class__.__module__.__len__,     [], 8, "abstractproperty.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"]
    - [ABCMeta,              ABCMeta.__class__.__module__.__len__,              [], 8, "ABCMeta.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"]
    - [get_cache_token,      get_cache_token.__class__.__module__.__len__,      [], 8, "get_cache_token.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"]
    - [abstractclassmethod,  abstractclassmethod.__class__.__module__.__len__,  [], 8, "abstractclassmethod.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"]
    - [abstractstaticmethod, abstractstaticmethod.__class__.__module__.__len__, [], 8, "abstractstaticmethod.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"]
    - [ABC,                  ABC.__class__.__module__.__len__,                  [], 3, "ABC.__class__.__module__.__len__() == 3 — 'abc' has 3 characters; only non-builtins __class__.__module__ among abc exports"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra42
# ---------------------------------------------------------------------------

invariant abc_extra42.abstractmethod_class_module_eq:
  description: "abc.abstractmethod.__class__.__module__ == 'builtins' — abstractmethod is a plain Python function; function type lives in builtins (8 chars)"
  category: module_identity
  kind: python_call_eq
  function: abstractmethod.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant abc_extra42.abstractproperty_class_module_eq:
  description: "abc.abstractproperty.__class__.__module__ == 'builtins' — abstractproperty is a class; its metaclass 'type' lives in builtins (8 chars)"
  category: module_identity
  kind: python_call_eq
  function: abstractproperty.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant abc_extra42.ABC_class_module_eq:
  description: "abc.ABC.__class__.__module__ == 'abc' — ABC's metaclass is ABCMeta, which is defined in the abc module; the only non-builtins __class__.__module__ among abc exports (3 chars)"
  category: module_identity
  kind: python_call_eq
  function: ABC.__class__.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra42.ABCMeta_class_module_eq:
  description: "abc.ABCMeta.__class__.__module__ == 'builtins' — ABCMeta is a class; its metaclass 'type' lives in builtins (8 chars)"
  category: module_identity
  kind: python_call_eq
  function: ABCMeta.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant abc_extra42.get_cache_token_class_module_eq:
  description: "abc.get_cache_token.__class__.__module__ == 'builtins' — get_cache_token is a C-extension function; builtin_function_or_method lives in builtins (8 chars)"
  category: module_identity
  kind: python_call_eq
  function: get_cache_token.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant abc_extra42.abstractclassmethod_class_module_eq:
  description: "abc.abstractclassmethod.__class__.__module__ == 'builtins' — abstractclassmethod is a class; metaclass 'type' lives in builtins (8 chars)"
  category: module_identity
  kind: python_call_eq
  function: abstractclassmethod.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant abc_extra42.abstractstaticmethod_class_module_eq:
  description: "abc.abstractstaticmethod.__class__.__module__ == 'builtins' — abstractstaticmethod is a class; metaclass 'type' lives in builtins (8 chars)"
  category: module_identity
  kind: python_call_eq
  function: abstractstaticmethod.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant abc_extra42.abstractmethod_class_module_len:
  description: "abc.abstractmethod.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"
  category: module_identity
  kind: python_call_eq
  function: abstractmethod.__class__.__module__.__len__
  args: []
  expected: 8

invariant abc_extra42.ABC_class_module_len:
  description: "abc.ABC.__class__.__module__.__len__() == 3 — 'abc' has 3 characters; shortest __class__.__module__ among the seven abc exports"
  category: module_identity
  kind: python_call_eq
  function: ABC.__class__.__module__.__len__
  args: []
  expected: 3

invariant abc_extra42.ABCMeta_class_module_len:
  description: "abc.ABCMeta.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"
  category: module_identity
  kind: python_call_eq
  function: ABCMeta.__class__.__module__.__len__
  args: []
  expected: 8

invariant abc_extra42.get_cache_token_class_module_len:
  description: "abc.get_cache_token.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters"
  category: module_identity
  kind: python_call_eq
  function: get_cache_token.__class__.__module__.__len__
  args: []
  expected: 8
