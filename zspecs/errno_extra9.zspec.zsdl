spec: errno_extra9
version: ">=3.9"
backend: python_module(errno)

docs: https://docs.python.org/3/library/errno.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/errno.html — Python errno module documentation"
    - "POSIX.1-2017 — IEEE Std 1003.1, errno.h error codes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/errnomodule.c"
  notes:
    - "This spec extends errno.zspec.zsdl through errno_extra8.zspec.zsdl."
    - "errno_extra6 covers: EWOULDBLOCK.__class__.__name__=='int'; ECONNRESET.__class__.__name__=='int' (table); EWOULDBLOCK==35; errorcode[35]=='EAGAIN'; contains 35."
    - "errno_extra7 covers: ECONNREFUSED.__class__.__name__=='int'; ECONNREFUSED==61; errorcode reverse-lookups 13/17; positivity ECONNREFUSED/ETIMEDOUT."
    - "errno_extra8 covers: EDEADLK/ENODEV/ENOTTY/ESPIPE/EROFS/ENAMETOOLONG/ELOOP values; errorcode[1/11/19/25/29/30] lookups; contains 1."
    - "No prior spec verifies ENOTSOCK.__class__.__name__ or ENOTSOCK==38 as standalone invariants."
    - "No prior spec verifies ECONNRESET==54 as a standalone value invariant (errno_extra6 covers class name only, not value)."
    - "No prior spec verifies errorcode[38]=='ENOTSOCK', errorcode[54]=='ECONNRESET', or errorcode[61]=='ECONNREFUSED' as standalone invariants."
    - "No prior spec verifies 38 in errorcode, 54 in errorcode, or 61 in errorcode as standalone invariants."
    - "errno.ENOTSOCK == 38 on macOS/Darwin (socket operation on non-socket)."
    - "errno.ECONNRESET == 54 on macOS/Darwin (connection reset by peer)."
    - "errno.ECONNREFUSED == 61 on macOS/Darwin (connection refused) — value covered in extra7; errorcode[61] and contains 61 are new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ENOTSOCK — class name and value
#
# No prior spec verifies ENOTSOCK.__class__.__name__ or ENOTSOCK==38
# as standalone invariants. ENOTSOCK is 38 on macOS/Darwin.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra9.ENOTSOCK.class_name:
  description: "errno.ENOTSOCK.__class__.__name__ == 'int' — ENOTSOCK is a plain int"
  category: constants
  kind: python_call_eq
  function: ENOTSOCK.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant errno_extra9.ENOTSOCK.value:
  description: "errno.ENOTSOCK == 38 on macOS/Darwin (socket operation on non-socket)"
  category: constants
  kind: python_call_eq
  function: ENOTSOCK.__eq__
  args: [38]
  expected: true

# ---------------------------------------------------------------------------
# ECONNRESET value
#
# errno_extra6 covers ECONNRESET.__class__.__name__ == 'int' (in a table row).
# No prior spec verifies the integer value ECONNRESET==54 as a standalone
# invariant. ECONNRESET is 54 on macOS/Darwin.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant errno_extra9.ECONNRESET.value:
  description: "errno.ECONNRESET == 54 on macOS/Darwin (connection reset by peer)"
  category: constants
  kind: python_call_eq
  function: ECONNRESET.__eq__
  args: [54]
  expected: true

# ---------------------------------------------------------------------------
# errorcode reverse-lookups — keys 38, 54, 61
#
# No prior spec verifies errorcode[38], errorcode[54], or errorcode[61]
# as standalone reverse-lookup invariants.
# Verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant errno_extra9.errorcode.enotsock_lookup:
  description: "errno.errorcode[38] == 'ENOTSOCK' — reverse-lookup of errno 38 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [38]
  expected: "ENOTSOCK"

invariant errno_extra9.errorcode.econnreset_lookup:
  description: "errno.errorcode[54] == 'ECONNRESET' — reverse-lookup of errno 54 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [54]
  expected: "ECONNRESET"

invariant errno_extra9.errorcode.econnrefused_lookup:
  description: "errno.errorcode[61] == 'ECONNREFUSED' — reverse-lookup of errno 61 on macOS"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__getitem__
  args: [61]
  expected: "ECONNREFUSED"

# ---------------------------------------------------------------------------
# errorcode __contains__ — keys 38, 54, 61
#
# No prior spec verifies 38 in errorcode, 54 in errorcode, or 61 in errorcode
# as standalone __contains__ invariants.
# Verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant errno_extra9.errorcode.contains_enotsock_key:
  description: "38 in errno.errorcode — ENOTSOCK key is present on macOS/Darwin"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [38]
  expected: true

invariant errno_extra9.errorcode.contains_econnreset_key:
  description: "54 in errno.errorcode — ECONNRESET key is present on macOS/Darwin"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [54]
  expected: true

invariant errno_extra9.errorcode.contains_econnrefused_key:
  description: "61 in errno.errorcode — ECONNREFUSED key is present on macOS/Darwin"
  category: errorcode
  kind: python_call_eq
  function: errorcode.__contains__
  args: [61]
  expected: true

# ---------------------------------------------------------------------------
# Table: new constant integer values — ENOTSOCK and ECONNRESET
#
# Groups ENOTSOCK and ECONNRESET value checks in one indexed table.
# No prior table covers these two constants' values.
# All verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table errno_extra9.constant_values:
  description: "ENOTSOCK and ECONNRESET integer values on macOS/Darwin"
  kind: python_call_eq
  category: constants
  id_prefix: e9cv

  columns: [id, function, args, expected]
  rows:
    - [ENOTSOCK,   ENOTSOCK.__eq__,   [38], true]
    - [ECONNRESET, ECONNRESET.__eq__,  [54], true]

# ---------------------------------------------------------------------------
# Table: errorcode reverse-lookups for keys 38, 54, 61
#
# Groups the three new errorcode reverse-lookup checks in one indexed table.
# No prior table covers errorcode[38/54/61] lookups.
# All verified at runtime on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table errno_extra9.errorcode_lookups:
  description: "errno.errorcode reverse-lookups for ENOTSOCK/ECONNRESET/ECONNREFUSED"
  kind: python_call_eq
  category: errorcode
  id_prefix: e9el

  columns: [id, function, args, expected]
  rows:
    - [enotsock,    errorcode.__getitem__, [38], "ENOTSOCK"]
    - [econnreset,  errorcode.__getitem__, [54], "ECONNRESET"]
    - [econnrefused, errorcode.__getitem__, [61], "ECONNREFUSED"]
