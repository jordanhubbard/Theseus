spec: pwd
version: ">=3.x"
backend: python_module(pwd)

docs: https://docs.python.org/3/library/pwd.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/pwd.html"
    - "POSIX.1-2017 — IEEE Std 1003.1, passwd database access"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/pwdmodule.c"
  notes:
    - "pwd is a POSIX-only module; it is available on macOS and Linux but not on Windows."
    - "struct_passwd is a C-level struct-sequence type, not a namedtuple; it does not have _fields."
    - "struct_passwd.n_sequence_fields == 7 on all POSIX platforms."
    - "struct_passwd.n_fields == 7 on all POSIX platforms."
    - "The seven fields are pw_name, pw_passwd, pw_uid, pw_gid, pw_gecos, pw_dir, pw_shell."
    - "getpwuid(0) always returns an entry on POSIX systems; UID 0 is root."
    - "getpwuid, getpwnam, and getpwall are all builtin_function_or_method objects (C-level)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "getpwuid raises KeyError if the UID is not found; getpwnam raises KeyError if the username is not found."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Function name attributes
# ---------------------------------------------------------------------------

table pwd.func_names:
  kind: python_call_eq
  category: functions
  id_prefix: func_name

  columns: [id, function, args, expected]
  rows:
    - [getpwuid, "getpwuid.__name__.__eq__", ["getpwuid"], true]
    - [getpwnam, "getpwnam.__name__.__eq__", ["getpwnam"], true]
    - [getpwall, "getpwall.__name__.__eq__", ["getpwall"], true]

# ---------------------------------------------------------------------------
# Functions are C-level builtins
# ---------------------------------------------------------------------------

table pwd.func_types:
  kind: python_call_eq
  category: types
  id_prefix: func_type

  columns: [id, function, args, expected]
  rows:
    - [getpwuid, "getpwuid.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - [getpwnam, "getpwnam.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - [getpwall, "getpwall.__class__.__name__.__eq__", ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# struct_passwd class identity
# ---------------------------------------------------------------------------

invariant pwd.struct_passwd.class_name:
  description: "pwd.struct_passwd.__name__ == 'struct_passwd'"
  category: classnames
  kind: python_call_eq
  function: "struct_passwd.__name__.__eq__"
  args: ["struct_passwd"]
  expected: true

invariant pwd.struct_passwd.module:
  description: "pwd.struct_passwd.__module__ == 'pwd'"
  category: classnames
  kind: python_call_eq
  function: "struct_passwd.__module__.__eq__"
  args: ["pwd"]
  expected: true

# ---------------------------------------------------------------------------
# struct_passwd field count (n_sequence_fields)
# ---------------------------------------------------------------------------

invariant pwd.struct_passwd.n_sequence_fields:
  description: "pwd.struct_passwd.n_sequence_fields == 7 — seven positional fields"
  category: struct
  kind: python_call_eq
  function: "struct_passwd.n_sequence_fields.__eq__"
  args: [7]
  expected: true

invariant pwd.struct_passwd.n_fields:
  description: "pwd.struct_passwd.n_fields == 7 — total number of fields"
  category: struct
  kind: python_call_eq
  function: "struct_passwd.n_fields.__eq__"
  args: [7]
  expected: true

# ---------------------------------------------------------------------------
# getpwall returns a list
# ---------------------------------------------------------------------------

invariant pwd.getpwall.returns_list:
  description: "getpwall().__class__.__name__ == 'list' — getpwall returns a plain list"
  category: behavior
  kind: python_call_eq
  function: getpwall
  args: []
  method: __class__
  method_chain: __name__
  expected: "list"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: infeasible
  model: claude-cli
  attempted_at: 2026-04-15T11:29:32Z
  iterations: 1
  pass_count: 0
  fail_count: 0
  total_invariants: 11
