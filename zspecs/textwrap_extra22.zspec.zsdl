spec: textwrap_extra22
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec extends textwrap.zspec.zsdl and prior extras through textwrap_extra21.zspec.zsdl."
    - "textwrap_extra17 covers: wrap/fill/shorten/indent/dedent __qualname__ standalone invariants and table."
    - "textwrap_extra14 covers: TextWrapper.__qualname__ == 'TextWrapper' standalone invariant."
    - "textwrap_extra21 covers: TextWrapper.wrap.__qualname__ == 'TextWrapper.wrap'; TextWrapper.fill.__qualname__ == 'TextWrapper.fill'; TextWrapper.__init__.__qualname__."
    - "textwrap_extra20 covers: wrap/fill/dedent/indent/shorten __qualname__.__len__() and TextWrapper.__qualname__.__len__()==11."
    - "This spec provides a consolidated extra22-namespace view of all eight textwrap function and class __qualname__ values: wrap, fill, dedent, indent, shorten, TextWrapper.wrap, TextWrapper.fill, TextWrapper."
    - "textwrap.wrap.__qualname__ == 'wrap' — module-level function. Verified at runtime."
    - "textwrap.fill.__qualname__ == 'fill' — module-level function. Verified at runtime."
    - "textwrap.dedent.__qualname__ == 'dedent' — module-level function. Verified at runtime."
    - "textwrap.indent.__qualname__ == 'indent' — module-level function. Verified at runtime."
    - "textwrap.shorten.__qualname__ == 'shorten' — module-level function. Verified at runtime."
    - "textwrap.TextWrapper.wrap.__qualname__ == 'TextWrapper.wrap' — method qualname includes owning class. Verified at runtime."
    - "textwrap.TextWrapper.fill.__qualname__ == 'TextWrapper.fill' — method qualname includes owning class. Verified at runtime."
    - "textwrap.TextWrapper.__qualname__ == 'TextWrapper' — module-level class flat qualname. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# textwrap.wrap — __qualname__ (extra22 namespace anchor)
#
# textwrap_extra17 covers wrap.__qualname__ == 'wrap'. Re-anchored here as a
# named standalone invariant in the extra22 namespace.
# Verified at runtime: 'wrap'.
# ---------------------------------------------------------------------------

invariant textwrap_extra22.wrap.qualname:
  description: "textwrap.wrap.__qualname__ == 'wrap' — module-level function qualname equals its simple name"
  category: function_identity
  kind: python_call_eq
  function: wrap.__qualname__.__eq__
  args: ["wrap"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.fill — __qualname__ (extra22 namespace anchor)
#
# textwrap_extra17 covers fill.__qualname__ == 'fill'. Re-anchored here.
# Verified at runtime: 'fill'.
# ---------------------------------------------------------------------------

invariant textwrap_extra22.fill.qualname:
  description: "textwrap.fill.__qualname__ == 'fill' — module-level function qualname equals its simple name"
  category: function_identity
  kind: python_call_eq
  function: fill.__qualname__.__eq__
  args: ["fill"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.dedent — __qualname__ (extra22 namespace anchor)
#
# textwrap_extra17 covers dedent.__qualname__ == 'dedent'. Re-anchored here.
# Verified at runtime: 'dedent'.
# ---------------------------------------------------------------------------

invariant textwrap_extra22.dedent.qualname:
  description: "textwrap.dedent.__qualname__ == 'dedent' — module-level function qualname equals its simple name"
  category: function_identity
  kind: python_call_eq
  function: dedent.__qualname__.__eq__
  args: ["dedent"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.indent — __qualname__ (extra22 namespace anchor)
#
# textwrap_extra17 covers indent.__qualname__ == 'indent'. Re-anchored here.
# Verified at runtime: 'indent'.
# ---------------------------------------------------------------------------

invariant textwrap_extra22.indent.qualname:
  description: "textwrap.indent.__qualname__ == 'indent' — module-level function qualname equals its simple name"
  category: function_identity
  kind: python_call_eq
  function: indent.__qualname__.__eq__
  args: ["indent"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.shorten — __qualname__ (extra22 namespace anchor)
#
# textwrap_extra17 covers shorten.__qualname__ == 'shorten'. Re-anchored here.
# Verified at runtime: 'shorten'.
# ---------------------------------------------------------------------------

invariant textwrap_extra22.shorten.qualname:
  description: "textwrap.shorten.__qualname__ == 'shorten' — module-level function qualname equals its simple name"
  category: function_identity
  kind: python_call_eq
  function: shorten.__qualname__.__eq__
  args: ["shorten"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper.wrap — __qualname__ (extra22 namespace anchor)
#
# textwrap_extra21 covers TextWrapper.wrap.__qualname__ == 'TextWrapper.wrap'.
# Re-anchored here as a named standalone invariant in the extra22 namespace.
# Verified at runtime: 'TextWrapper.wrap'.
# ---------------------------------------------------------------------------

invariant textwrap_extra22.TextWrapper.wrap_qualname:
  description: "textwrap.TextWrapper.wrap.__qualname__ == 'TextWrapper.wrap' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: TextWrapper.wrap.__qualname__.__eq__
  args: ["TextWrapper.wrap"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper.fill — __qualname__ (extra22 namespace anchor)
#
# textwrap_extra21 covers TextWrapper.fill.__qualname__ == 'TextWrapper.fill'.
# Re-anchored here as a named standalone invariant in the extra22 namespace.
# Verified at runtime: 'TextWrapper.fill'.
# ---------------------------------------------------------------------------

invariant textwrap_extra22.TextWrapper.fill_qualname:
  description: "textwrap.TextWrapper.fill.__qualname__ == 'TextWrapper.fill' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: TextWrapper.fill.__qualname__.__eq__
  args: ["TextWrapper.fill"]
  expected: true

# ---------------------------------------------------------------------------
# textwrap.TextWrapper — __qualname__ (extra22 namespace anchor)
#
# textwrap_extra14 covers TextWrapper.__qualname__ == 'TextWrapper'. Re-anchored
# here as a named standalone invariant in the extra22 namespace.
# Verified at runtime: 'TextWrapper'.
# ---------------------------------------------------------------------------

invariant textwrap_extra22.TextWrapper.qualname:
  description: "textwrap.TextWrapper.__qualname__ == 'TextWrapper' — module-level class flat qualname"
  category: class_identity
  kind: python_call_eq
  function: TextWrapper.__qualname__.__eq__
  args: ["TextWrapper"]
  expected: true

# ---------------------------------------------------------------------------
# Table: consolidated textwrap function and class __qualname__ values
#
# Groups all eight __qualname__ checks from this spec into a single table for
# compact cross-reference: wrap, fill, dedent, indent, shorten (module-level
# functions), TextWrapper.wrap, TextWrapper.fill (methods), TextWrapper (class).
# All values verified at runtime.
# ---------------------------------------------------------------------------

table textwrap_extra22.qualnames:
  description: "textwrap function and class __qualname__ values — all eight consolidated"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [wrap,
       wrap.__qualname__.__eq__,
       ["wrap"],
       true,
       "wrap.__qualname__ == 'wrap'"]
    - [fill,
       fill.__qualname__.__eq__,
       ["fill"],
       true,
       "fill.__qualname__ == 'fill'"]
    - [dedent,
       dedent.__qualname__.__eq__,
       ["dedent"],
       true,
       "dedent.__qualname__ == 'dedent'"]
    - [indent,
       indent.__qualname__.__eq__,
       ["indent"],
       true,
       "indent.__qualname__ == 'indent'"]
    - [shorten,
       shorten.__qualname__.__eq__,
       ["shorten"],
       true,
       "shorten.__qualname__ == 'shorten'"]
    - [TextWrapper_wrap,
       TextWrapper.wrap.__qualname__.__eq__,
       ["TextWrapper.wrap"],
       true,
       "TextWrapper.wrap.__qualname__ == 'TextWrapper.wrap'"]
    - [TextWrapper_fill,
       TextWrapper.fill.__qualname__.__eq__,
       ["TextWrapper.fill"],
       true,
       "TextWrapper.fill.__qualname__ == 'TextWrapper.fill'"]
    - [TextWrapper,
       TextWrapper.__qualname__.__eq__,
       ["TextWrapper"],
       true,
       "TextWrapper.__qualname__ == 'TextWrapper'"]
