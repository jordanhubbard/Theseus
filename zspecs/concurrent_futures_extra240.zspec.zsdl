spec: concurrent_futures_extra240
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers concurrent.futures.BrokenExecutor and concurrent.futures.InvalidStateError exception identity."
    - "BrokenExecutor.__name__ == 'BrokenExecutor' — 14 characters."
    - "BrokenExecutor.__module__ == 'concurrent.futures._base' — 24 characters."
    - "BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' — inherits from RuntimeError."
    - "BrokenExecutor.__qualname__ == 'BrokenExecutor' — matches __name__ (14 chars)."
    - "InvalidStateError.__name__ == 'InvalidStateError' — 17 characters."
    - "InvalidStateError.__module__ == 'concurrent.futures._base' — 24 characters."
    - "InvalidStateError.__bases__[0].__name__ == 'Error' — inherits from concurrent.futures._base.Error."
    - "InvalidStateError.__qualname__ == 'InvalidStateError' — matches __name__ (17 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: BrokenExecutor class identity contracts
#
# BrokenExecutor.__name__, __module__, __qualname__ and string lengths.
# ---------------------------------------------------------------------------

table concurrent_futures_extra240.broken_executor_identity:
  description: "concurrent.futures.BrokenExecutor class identity: name, module, qualname; new to extra240"
  kind: python_call_eq
  category: exception_identity
  id_prefix: cf240exc

  columns: [id, function, args, expected, description]
  rows:
    - [broken_name_eq,
       BrokenExecutor.__name__.__eq__,
       ["BrokenExecutor"],
       true,
       "concurrent.futures.BrokenExecutor.__name__.__eq__('BrokenExecutor') == True — 14 characters; new to extra240"]
    - [broken_module_eq,
       BrokenExecutor.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.BrokenExecutor.__module__.__eq__('concurrent.futures._base') == True — 24 characters; new to extra240"]
    - [broken_qualname_eq,
       BrokenExecutor.__qualname__.__eq__,
       ["BrokenExecutor"],
       true,
       "concurrent.futures.BrokenExecutor.__qualname__.__eq__('BrokenExecutor') == True — qualname matches __name__ for top-level class; new to extra240"]
    - [broken_name_len_14,
       BrokenExecutor.__name__.__len__,
       [],
       14,
       "concurrent.futures.BrokenExecutor.__name__.__len__() == 14 — 'BrokenExecutor' has 14 characters; new to extra240"]
    - [broken_module_len_24,
       BrokenExecutor.__module__.__len__,
       [],
       24,
       "concurrent.futures.BrokenExecutor.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters; new to extra240"]

# ---------------------------------------------------------------------------
# Table 2: BrokenExecutor base class contract
#
# BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'.
# The function path contains '[' so must be double-quoted.
# ---------------------------------------------------------------------------

table concurrent_futures_extra240.broken_executor_base:
  description: "concurrent.futures.BrokenExecutor base class identity; new to extra240"
  kind: python_call_eq
  category: exception_identity
  id_prefix: cf240exc

  columns: [id, function, args, expected, description]
  rows:
    - [broken_base_name_eq,
       "BrokenExecutor.__bases__[0].__name__.__eq__",
       ["RuntimeError"],
       true,
       "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError') == True — BrokenExecutor inherits from RuntimeError; new to extra240"]

# ---------------------------------------------------------------------------
# Table 3: InvalidStateError class identity contracts
#
# InvalidStateError.__name__, __module__, __qualname__ and string lengths.
# ---------------------------------------------------------------------------

table concurrent_futures_extra240.invalid_state_error_identity:
  description: "concurrent.futures.InvalidStateError class identity: name, module, qualname; new to extra240"
  kind: python_call_eq
  category: exception_identity
  id_prefix: cf240exc

  columns: [id, function, args, expected, description]
  rows:
    - [ise_name_eq,
       InvalidStateError.__name__.__eq__,
       ["InvalidStateError"],
       true,
       "concurrent.futures.InvalidStateError.__name__.__eq__('InvalidStateError') == True — 17 characters; new to extra240"]
    - [ise_module_eq,
       InvalidStateError.__module__.__eq__,
       ["concurrent.futures._base"],
       true,
       "concurrent.futures.InvalidStateError.__module__.__eq__('concurrent.futures._base') == True — 24 characters; new to extra240"]
    - [ise_qualname_eq,
       InvalidStateError.__qualname__.__eq__,
       ["InvalidStateError"],
       true,
       "concurrent.futures.InvalidStateError.__qualname__.__eq__('InvalidStateError') == True — qualname matches __name__ for top-level class; new to extra240"]
    - [ise_name_len_17,
       InvalidStateError.__name__.__len__,
       [],
       17,
       "concurrent.futures.InvalidStateError.__name__.__len__() == 17 — 'InvalidStateError' has 17 characters; new to extra240"]
    - [ise_module_len_24,
       InvalidStateError.__module__.__len__,
       [],
       24,
       "concurrent.futures.InvalidStateError.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters; new to extra240"]

# ---------------------------------------------------------------------------
# Table 4: InvalidStateError base class contract
#
# InvalidStateError.__bases__[0].__name__ == 'Error'.
# The function path contains '[' so must be double-quoted.
# ---------------------------------------------------------------------------

table concurrent_futures_extra240.invalid_state_error_base:
  description: "concurrent.futures.InvalidStateError base class identity; new to extra240"
  kind: python_call_eq
  category: exception_identity
  id_prefix: cf240exc

  columns: [id, function, args, expected, description]
  rows:
    - [ise_base_name_eq,
       "InvalidStateError.__bases__[0].__name__.__eq__",
       ["Error"],
       true,
       "concurrent.futures.InvalidStateError.__bases__[0].__name__.__eq__('Error') == True — InvalidStateError inherits from concurrent.futures._base.Error; new to extra240"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra240
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra240.BrokenExecutor.name:
  description: "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor'; new to extra240"
  category: exception_identity
  kind: python_call_eq
  function: BrokenExecutor.__name__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra240.BrokenExecutor.module:
  description: "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base'; new to extra240"
  category: exception_identity
  kind: python_call_eq
  function: BrokenExecutor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra240.BrokenExecutor.qualname:
  description: "concurrent.futures.BrokenExecutor.__qualname__ == 'BrokenExecutor'; new to extra240"
  category: exception_identity
  kind: python_call_eq
  function: BrokenExecutor.__qualname__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures_extra240.BrokenExecutor.name_len:
  description: "concurrent.futures.BrokenExecutor.__name__.__len__() == 14 — 'BrokenExecutor' has 14 characters; new to extra240"
  category: exception_identity
  kind: python_call_eq
  function: BrokenExecutor.__name__.__len__
  args: []
  expected: 14

invariant concurrent_futures_extra240.BrokenExecutor.base_name:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' — inherits from RuntimeError; new to extra240"
  category: exception_identity
  kind: python_call_eq
  function: "BrokenExecutor.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true

invariant concurrent_futures_extra240.InvalidStateError.name:
  description: "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError'; new to extra240"
  category: exception_identity
  kind: python_call_eq
  function: InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant concurrent_futures_extra240.InvalidStateError.module:
  description: "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base'; new to extra240"
  category: exception_identity
  kind: python_call_eq
  function: InvalidStateError.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra240.InvalidStateError.qualname:
  description: "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError'; new to extra240"
  category: exception_identity
  kind: python_call_eq
  function: InvalidStateError.__qualname__.__eq__
  args: ["InvalidStateError"]
  expected: true

invariant concurrent_futures_extra240.InvalidStateError.name_len:
  description: "concurrent.futures.InvalidStateError.__name__.__len__() == 17 — 'InvalidStateError' has 17 characters; new to extra240"
  category: exception_identity
  kind: python_call_eq
  function: InvalidStateError.__name__.__len__
  args: []
  expected: 17

invariant concurrent_futures_extra240.InvalidStateError.base_name:
  description: "concurrent.futures.InvalidStateError.__bases__[0].__name__ == 'Error' — inherits from concurrent.futures._base.Error; new to extra240"
  category: exception_identity
  kind: python_call_eq
  function: "InvalidStateError.__bases__[0].__name__.__eq__"
  args: ["Error"]
  expected: true
