    - ["dc3286001", operator.contains, [decimal.Decimal.__dict__,          "__iadd__"], false]
    - ["dc3286002", operator.contains, [decimal.Context.__dict__,           "__iadd__"], false]
    - ["dc3286003", operator.contains, [decimal.DecimalException.__dict__,  "__iadd__"], false]
    - ["dc3286004", operator.contains, [decimal.InvalidOperation.__dict__,  "__iadd__"], false]
    - ["dc3286005", operator.contains, [decimal.Overflow.__dict__,          "__iadd__"], false]
    - ["dc3286006", operator.contains, [decimal.Underflow.__dict__,         "__iadd__"], false]

