spec: abc_extra1531
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 549 theme: comparison operator dict-presence checks — __lt__, __le__, __gt__, __ge__, __ne__, __eq__, __hash__ in class __dict__."
    - "abc.ABCMeta is a metaclass — its own __dict__ contains __instancecheck__, __subclasscheck__, register, and metaclass-level hooks; no comparison operators."
    - "abc.ABC is a simple helper class whose __dict__ contains __slots__, __abstractmethods__, and _abc_impl — no comparison operators."
    - "abc.abstractmethod is a function/decorator whose __dict__ is essentially empty at the module level — no comparison operators."
    - "ABCMeta does not define __eq__ or __hash__ in its own __dict__ — as a metaclass it inherits type's identity-based equality and hashing."
    - "ABC does not define __eq__ or __hash__ in its own __dict__ — ABC is a thin helper class; subclasses are expected to define equality semantics appropriate to their domain."
    - "Anchor 'true' rows confirm that ABCMeta.__instancecheck__ and ABCMeta.__subclasscheck__ and ABCMeta.register are present in ABCMeta.__dict__, and that ABC.__abstractmethods__ is present in ABC.__dict__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc.ABCMeta comparison operator __dict__ absence
#
# abc.ABCMeta.__dict__.__contains__('__lt__')             == False
# abc.ABCMeta.__dict__.__contains__('__le__')             == False
# abc.ABCMeta.__dict__.__contains__('__gt__')             == False
# abc.ABCMeta.__dict__.__contains__('__ge__')             == False
# abc.ABCMeta.__dict__.__contains__('__ne__')             == False
# abc.ABCMeta.__dict__.__contains__('__eq__')             == False
# abc.ABCMeta.__dict__.__contains__('__hash__')           == False
# abc.ABCMeta.__dict__.__contains__('__instancecheck__')  == True
# abc.ABCMeta.__dict__.__contains__('__subclasscheck__')  == True
# abc.ABCMeta.__dict__.__contains__('register')           == True
# ---------------------------------------------------------------------------

table abc_extra1531.abcmeta_no_cmp_ops:
  description: "abc.ABCMeta has no comparison operator methods in its own __dict__ — ab1531am namespace. abc.ABCMeta.__dict__.__contains__('__lt__')==False (ABCMeta is a metaclass controlling abstract base class registration and virtual subclass checking; ordering between metaclasses is not defined; no __lt__ in ABCMeta.__dict__); abc.ABCMeta.__dict__.__contains__('__le__')==False (no less-than-or-equal on ABCMeta); abc.ABCMeta.__dict__.__contains__('__gt__')==False (no greater-than on ABCMeta); abc.ABCMeta.__dict__.__contains__('__ge__')==False (no greater-than-or-equal on ABCMeta); abc.ABCMeta.__dict__.__contains__('__ne__')==False (ABCMeta does not override __ne__); abc.ABCMeta.__dict__.__contains__('__eq__')==False (ABCMeta does not override __eq__ in its own __dict__; as a metaclass it inherits type's identity equality); abc.ABCMeta.__dict__.__contains__('__hash__')==False (ABCMeta does not override __hash__); abc.ABCMeta.__dict__.__contains__('__instancecheck__')==True (ABCMeta.__instancecheck__ IS defined in ABCMeta.__dict__ — overrides isinstance() to consult the ABC virtual-subclass registry); abc.ABCMeta.__dict__.__contains__('__subclasscheck__')==True (ABCMeta.__subclasscheck__ IS defined in ABCMeta.__dict__ — overrides issubclass()); abc.ABCMeta.__dict__.__contains__('register')==True (ABCMeta.register() IS defined in ABCMeta.__dict__ — registers a class as a virtual subclass of the ABC); verified with Python 3.14.4"
  kind: python_call_eq
  category: comparison_protocol
  id_prefix: ab1531am

  columns: [id, function, args, expected, description]
  rows:
    - [ab1531am001, abc.ABCMeta.__dict__.__contains__, ["__lt__"],            false, "abc.ABCMeta.__dict__.__contains__('__lt__')==False — ABCMeta is a metaclass; no ordering operators; verified with Python 3.14.4"]
    - [ab1531am002, abc.ABCMeta.__dict__.__contains__, ["__le__"],            false, "abc.ABCMeta.__dict__.__contains__('__le__')==False — no less-than-or-equal on ABCMeta; verified with Python 3.14.4"]
    - [ab1531am003, abc.ABCMeta.__dict__.__contains__, ["__gt__"],            false, "abc.ABCMeta.__dict__.__contains__('__gt__')==False — no greater-than on ABCMeta; verified with Python 3.14.4"]
    - [ab1531am004, abc.ABCMeta.__dict__.__contains__, ["__ge__"],            false, "abc.ABCMeta.__dict__.__contains__('__ge__')==False — no greater-than-or-equal on ABCMeta; verified with Python 3.14.4"]
    - [ab1531am005, abc.ABCMeta.__dict__.__contains__, ["__ne__"],            false, "abc.ABCMeta.__dict__.__contains__('__ne__')==False — ABCMeta does not override __ne__; verified with Python 3.14.4"]
    - [ab1531am006, abc.ABCMeta.__dict__.__contains__, ["__eq__"],            false, "abc.ABCMeta.__dict__.__contains__('__eq__')==False — ABCMeta does not override __eq__; inherits type's identity equality; verified with Python 3.14.4"]
    - [ab1531am007, abc.ABCMeta.__dict__.__contains__, ["__hash__"],          false, "abc.ABCMeta.__dict__.__contains__('__hash__')==False — ABCMeta does not override __hash__; verified with Python 3.14.4"]
    - [ab1531am008, abc.ABCMeta.__dict__.__contains__, ["__instancecheck__"], true,  "abc.ABCMeta.__dict__.__contains__('__instancecheck__')==True — ABCMeta.__instancecheck__ IS in ABCMeta.__dict__; overrides isinstance() with ABC registry lookup; verified with Python 3.14.4"]
    - [ab1531am009, abc.ABCMeta.__dict__.__contains__, ["__subclasscheck__"], true,  "abc.ABCMeta.__dict__.__contains__('__subclasscheck__')==True — ABCMeta.__subclasscheck__ IS in ABCMeta.__dict__; overrides issubclass(); verified with Python 3.14.4"]
    - [ab1531am010, abc.ABCMeta.__dict__.__contains__, ["register"],          true,  "abc.ABCMeta.__dict__.__contains__('register')==True — ABCMeta.register() IS in ABCMeta.__dict__; registers virtual subclasses of the ABC; verified with Python 3.14.4"]

