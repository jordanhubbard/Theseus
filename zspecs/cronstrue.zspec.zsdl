spec: cronstrue
version: ">=2.0.0"
backend: node(cronstrue)

docs: https://github.com/bradymholt/cRonstrue#readme

provenance:
  derived_from:
    - "cRonstrue README — https://github.com/bradymholt/cRonstrue#readme"
    - "Test vectors verified with cronstrue via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "cronstrue source"
  notes:
    - "cronstrue translates cron expressions into human-readable English."
    - "Install: npm install cronstrue"
    - "toString(expr) returns the description; pure function with deterministic output."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; throws on invalid cron expressions."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table cronstrue.toString:
  kind: node_module_call_eq
  category: toString
  function: toString
  id_prefix: cron

  columns: [id, args, expected]
  rows:
    - [every_minute,        ["* * * * *"],         "Every minute"]
    - [midnight,            ["0 0 * * *"],         "At 12:00 AM"]
    - [every_5_minutes,     ["*/5 * * * *"],       "Every 5 minutes"]
    - [every_15_minutes,    ["*/15 * * * *"],      "Every 15 minutes"]
    - [hourly,              ["0 * * * *"],         "Every hour"]
    - [noon,                ["0 12 * * *"],        "At 12:00 PM"]
    - [weekly_sunday,       ["0 0 * * 0"],         "At 12:00 AM, only on Sunday"]
    - [weekly_monday,       ["0 0 * * 1"],         "At 12:00 AM, only on Monday"]
    - [first_of_month,      ["0 0 1 * *"],         "At 12:00 AM, on day 1 of the month"]
