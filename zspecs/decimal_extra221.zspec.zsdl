spec: decimal_extra221
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification, Version 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec covers: decimal module and class __doc__ string contains checks, and ROUND_HALF_EVEN type and value."
    - "decimal.__doc__.__contains__('decimal') == True — module doc starts 'Decimal fixed-point and floating-point arithmetic.'; 'decimal' appears in 'Decimal' (lowercase variant checked via 'decimal'); verified with Python 3.14.3."
    - "decimal.Decimal.__doc__.__contains__('Decimal') == True — Decimal doc starts 'Construct a new Decimal object.'; 'Decimal' appears immediately; verified with Python 3.14.3."
    - "decimal.Context.__doc__.__contains__('context') == True — Context doc starts 'The context affects almost all operations'; 'context' appears in 'context' further in doc; verified with Python 3.14.3."
    - "decimal.InvalidOperation.__doc__ is None — InvalidOperation is an exception subclass with no docstring; __doc__ is None; we do not assert __contains__ on None; instead we assert __doc__.__class__.__name__ == 'NoneType'; verified with Python 3.14.3."
    - "decimal.getcontext.__doc__.__contains__('context') == True — getcontext doc is 'Get the current default context.'; 'context' appears; verified with Python 3.14.3."
    - "decimal.setcontext.__doc__.__contains__('context') == True — setcontext doc is 'Set a new default context.'; 'context' appears; verified with Python 3.14.3."
    - "decimal.Decimal.quantize.__doc__.__contains__('quantize') == True — quantize doc starts 'Return a value equal to the first operand after rounding and having the exponent of the second operand.'; example uses Decimal.quantize; verified with Python 3.14.3."
    - "decimal.Decimal.sqrt.__doc__.__contains__('square root') == True — sqrt doc starts 'Return the square root of the argument to full precision.'; 'sqrt' is NOT present but 'square root' is; verified with Python 3.14.3."
    - "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str' — ROUND_HALF_EVEN is a plain Python str constant; verified with Python 3.14.3."
    - "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True — the value is the string 'ROUND_HALF_EVEN'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal module-level __doc__ contains check
# decimal.__doc__ contains 'decimal' (lowercase appears in the doc text)
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table decimal_extra221.module_doc_contains:
  description: "decimal.__doc__ contains 'decimal'; verified with Python 3.14.3"
  kind: python_call_eq
  category: docstring
  id_prefix: decdoccontains221a

  columns: [id, function, args, expected]
  rows:
    - [decimal_module_doc_decimal, "__doc__.__contains__", ["decimal"], true]

# ---------------------------------------------------------------------------
# decimal class __doc__ contains checks
# Decimal->Decimal, Context->context, getcontext->context, setcontext->context
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table decimal_extra221.class_doc_contains:
  description: "decimal class and function __doc__ string contains checks for Decimal, Context, getcontext, setcontext; verified with Python 3.14.3"
  kind: python_call_eq
  category: docstring
  id_prefix: decdoccontains221b

  columns: [id, function, args, expected]
  rows:
    - [decimal_doc_Decimal,         "Decimal.__doc__.__contains__",     ["Decimal"],  true]
    - [context_doc_context,         "Context.__doc__.__contains__",     ["context"],  true]
    - [getcontext_doc_context,      "getcontext.__doc__.__contains__",  ["context"],  true]
    - [setcontext_doc_context,      "setcontext.__doc__.__contains__",  ["context"],  true]

# ---------------------------------------------------------------------------
# decimal.Decimal method __doc__ contains checks
# quantize->quantize, sqrt->'square root'
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table decimal_extra221.decimal_method_doc_contains:
  description: "decimal.Decimal method __doc__ string contains checks for quantize and sqrt; verified with Python 3.14.3"
  kind: python_call_eq
  category: docstring
  id_prefix: decdoccontains221c

  columns: [id, function, args, expected]
  rows:
    - [quantize_doc_quantize,    "Decimal.quantize.__doc__.__contains__",  ["quantize"],    true]
    - [sqrt_doc_square_root,     "Decimal.sqrt.__doc__.__contains__",      ["square root"], true]

# ---------------------------------------------------------------------------
# decimal.InvalidOperation __doc__ type check
# InvalidOperation.__doc__ is None (exception subclass with no docstring).
# We check __doc__.__class__.__name__ == 'NoneType' instead of __contains__.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table decimal_extra221.invalid_operation_doc_type:
  description: "decimal.InvalidOperation.__doc__ is None; __doc__.__class__.__name__ == 'NoneType'; verified with Python 3.14.3"
  kind: python_call_eq
  category: docstring
  id_prefix: decdoccontains221d

  columns: [id, function, args, expected]
  rows:
    - [invalid_op_doc_nonetype, InvalidOperation.__doc__.__class__.__name__.__eq__, ["NoneType"], true]

# ---------------------------------------------------------------------------
# decimal.ROUND_HALF_EVEN type and value
# ROUND_HALF_EVEN is a str constant with value 'ROUND_HALF_EVEN'.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table decimal_extra221.round_half_even:
  description: "decimal.ROUND_HALF_EVEN type is 'str' and value is 'ROUND_HALF_EVEN'; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: decroundhe221

  columns: [id, function, args, expected]
  rows:
    - [round_half_even_classname, ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"],              true]
    - [round_half_even_value,     ROUND_HALF_EVEN.__eq__,                    ["ROUND_HALF_EVEN"],  true]

# ---------------------------------------------------------------------------
# Standalone invariants
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant decimal_extra221.module_doc_contains_decimal:
  description: "decimal.__doc__.__contains__('decimal') == True — module docstring starts 'Decimal fixed-point and floating-point arithmetic.'; 'decimal' appears later in the text; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: __doc__.__contains__
  args: ["decimal"]
  expected: true

invariant decimal_extra221.Decimal.doc_contains_Decimal:
  description: "decimal.Decimal.__doc__.__contains__('Decimal') == True — Decimal docstring starts 'Construct a new Decimal object.'; 'Decimal' appears immediately; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: Decimal.__doc__.__contains__
  args: ["Decimal"]
  expected: true

invariant decimal_extra221.Context.doc_contains_context:
  description: "decimal.Context.__doc__.__contains__('context') == True — Context docstring mentions 'context' in 'A new context can be constructed as follows:'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: Context.__doc__.__contains__
  args: ["context"]
  expected: true

invariant decimal_extra221.InvalidOperation.doc_is_none:
  description: "decimal.InvalidOperation.__doc__.__class__.__name__ == 'NoneType' — InvalidOperation is an exception subclass with no docstring; __doc__ is None; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: InvalidOperation.__doc__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant decimal_extra221.getcontext.doc_contains_context:
  description: "decimal.getcontext.__doc__.__contains__('context') == True — getcontext docstring is 'Get the current default context.'; 'context' appears at the end; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: getcontext.__doc__.__contains__
  args: ["context"]
  expected: true

invariant decimal_extra221.setcontext.doc_contains_context:
  description: "decimal.setcontext.__doc__.__contains__('context') == True — setcontext docstring is 'Set a new default context.'; 'context' appears at the end; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: setcontext.__doc__.__contains__
  args: ["context"]
  expected: true

invariant decimal_extra221.Decimal.quantize_doc_contains_quantize:
  description: "decimal.Decimal.quantize.__doc__.__contains__('quantize') == True — quantize docstring includes 'quantize' in the doctest example 'Decimal(\"1.41421356\").quantize(...)'; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: Decimal.quantize.__doc__.__contains__
  args: ["quantize"]
  expected: true

invariant decimal_extra221.Decimal.sqrt_doc_contains_square_root:
  description: "decimal.Decimal.sqrt.__doc__.__contains__('square root') == True — sqrt docstring starts 'Return the square root of the argument to full precision.'; 'sqrt' is NOT present but 'square root' is the phrase used; verified with Python 3.14.3"
  category: docstring
  kind: python_call_eq
  function: Decimal.sqrt.__doc__.__contains__
  args: ["square root"]
  expected: true

invariant decimal_extra221.ROUND_HALF_EVEN.class_name:
  description: "decimal.ROUND_HALF_EVEN.__class__.__name__ == 'str' — ROUND_HALF_EVEN is a plain Python str rounding mode constant; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant decimal_extra221.ROUND_HALF_EVEN.value:
  description: "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') == True — the value of the constant is the string 'ROUND_HALF_EVEN'; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true
