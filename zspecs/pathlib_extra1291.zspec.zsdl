spec: pathlib_extra1291
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 533 _extra1291: checks __init__/__new__ qualname and __dict__.__contains__ for pathlib.PurePath, pathlib.Path, pathlib.PurePosixPath."
    - "pathlib.PurePath defines both __init__ and __new__ directly; both are pure-Python functions (__class__.__name__ == 'function')."
    - "pathlib.Path defines __new__ directly (qualname 'Path.__new__') but NOT __init__; MRO resolves __init__ to PurePath.__init__."
    - "pathlib.PurePosixPath defines neither __init__ nor __new__ directly; both resolve via MRO to PurePath."
    - "pathlib.PureWindowsPath similarly does not define __init__ or __new__ directly."
    - "pathlib.PurePath.__init__.__class__.__name__ == 'function' — pure-Python implementation, not a C wrapper."
    - "pathlib.PurePath.__new__.__class__.__name__ == 'function' — pure-Python __new__."
    - "pathlib.Path.__new__.__class__.__name__ == 'function' — pure-Python __new__ override."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1291.purepath_init_new:
  description: "pathlib.PurePath __init__ and __new__ qualname and class name checks"
  kind: python_call_eq
  category: purepath_init_new
  id_prefix: pl1291pi
  columns: [id, function, args, expected]
  rows:
    - [pl1291pi001, pathlib.PurePath.__init__.__qualname__.__eq__,      ["PurePath.__init__"], true]
    - [pl1291pi002, pathlib.PurePath.__init__.__class__.__name__.__eq__, ["function"],          true]
    - [pl1291pi003, pathlib.PurePath.__new__.__qualname__.__eq__,       ["PurePath.__new__"],  true]
    - [pl1291pi004, pathlib.PurePath.__new__.__class__.__name__.__eq__,  ["function"],          true]
    - [pl1291pi005, pathlib.PurePath.__dict__.__contains__,             ["__init__"],           true]
    - [pl1291pi006, pathlib.PurePath.__dict__.__contains__,             ["__new__"],            true]

table pathlib_extra1291.path_init_new:
  description: "pathlib.Path __init__ and __new__ presence and qualname checks"
  kind: python_call_eq
  category: path_init_new
  id_prefix: pl1291pa
  columns: [id, function, args, expected]
  rows:
    - [pl1291pa001, pathlib.Path.__dict__.__contains__,             ["__new__"],           true]
    - [pl1291pa002, pathlib.Path.__dict__.__contains__,             ["__init__"],          false]
    - [pl1291pa003, pathlib.Path.__new__.__qualname__.__eq__,       ["Path.__new__"],      true]
    - [pl1291pa004, pathlib.Path.__new__.__class__.__name__.__eq__,  ["function"],          true]
    - [pl1291pa005, pathlib.Path.__init__.__qualname__.__eq__,      ["PurePath.__init__"], true]
    - [pl1291pa006, pathlib.Path.__init__.__class__.__name__.__eq__, ["function"],          true]

table pathlib_extra1291.subclass_dict_contains:
  description: "pathlib.PurePosixPath and pathlib.PureWindowsPath __dict__.__contains__ for __init__ and __new__"
  kind: python_call_eq
  category: subclass_dict_contains
  id_prefix: pl1291sc
  columns: [id, function, args, expected]
  rows:
    - [pl1291sc001, pathlib.PurePosixPath.__dict__.__contains__,    ["__init__"],          false]
    - [pl1291sc002, pathlib.PurePosixPath.__dict__.__contains__,    ["__new__"],           false]
    - [pl1291sc003, pathlib.PurePosixPath.__init__.__qualname__.__eq__, ["PurePath.__init__"], true]
    - [pl1291sc004, pathlib.PurePosixPath.__new__.__qualname__.__eq__,  ["PurePath.__new__"],  true]
    - [pl1291sc005, pathlib.PureWindowsPath.__dict__.__contains__,  ["__init__"],          false]
    - [pl1291sc006, pathlib.PureWindowsPath.__dict__.__contains__,  ["__new__"],           false]
    - [pl1291sc007, pathlib.PureWindowsPath.__init__.__qualname__.__eq__, ["PurePath.__init__"], true]
    - [pl1291sc008, pathlib.PureWindowsPath.__new__.__qualname__.__eq__,  ["PurePath.__new__"],  true]
