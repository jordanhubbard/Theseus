spec: cf3466
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 678 (cf3466): __iter__, __next__, __len__ dict-presence (iter(x), next(x), len(x)) for concurrent.futures types."
    - "Theme: __iter__/__next__/__len__ dict-presence (iter(x), next(x), len(x))."
    - "All values False — these types do not implement the iterator or sizing protocol in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Key finding (__iter__): all 3 concurrent.futures classes return false for __iter__. iter(x) calls __iter__ when defined in the class's own __dict__. concurrent.futures.Future: a state-machine result handle (PENDING/RUNNING/CANCELLED/FINISHED) that does NOT define __iter__ in its own __dict__. Results are retrieved via result()/exception() method calls, not iteration. ThreadPoolExecutor/ProcessPoolExecutor: worker-pool lifecycle managers with no __iter__ in their own __dict__."
    - "Key finding (__next__): all 3 concurrent.futures classes return false for __next__. next(x) delegates to __next__ when defined in the class's own __dict__. concurrent.futures.Future: does NOT define __next__ in its own Future.__dict__. Future results are retrieved via result(); iterator advancement is not part of the Future API. ThreadPoolExecutor/ProcessPoolExecutor: no __next__ defined in their own __dict__."
    - "Key finding (__len__): all 3 concurrent.futures classes return false for __len__. len(x) delegates to __len__ when defined in the class's own __dict__. concurrent.futures types define no sizing protocol in their own __dict__. Future objects hold a single result slot; __len__ is absent from Future.__dict__. ThreadPoolExecutor/ProcessPoolExecutor: executor types with no __len__ in their own __dict__."
    - "All 9 values in this wave are false. concurrent.futures is a high-level parallel execution API operating entirely through method calls — submit(), map(), result(), cancel(), add_done_callback(), shutdown() — with no iterator or sizing protocol overrides in any class __dict__."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (cf3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (cf3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (cf3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (cf3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (cf3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (cf3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (cf3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (cf3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (cf3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (cf3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
    - "  Wave 669 (cf3331): __iand__/__ior__/__ixor__ — all false for all 3."
    - "  Wave 670 (cf3346): __neg__/__pos__/__abs__ — all false for all 3."
    - "  Wave 671 (cf3361): __invert__/__floor__/__ceil__ — all false for all 3."
    - "  Wave 672 (cf3376): __trunc__/__round__/__index__ — all false for all 3."
    - "  Wave 673 (cf3391): __int__/__float__/__complex__ — all false for all 3."
    - "  Wave 674 (cf3406): __bool__/__str__/__repr__ — all false for all 3."
    - "  Wave 675 (cf3421): __hash__/__eq__/__lt__ — all false for all 3."
    - "  Wave 676 (cf3436): __le__/__gt__/__ge__ — all false for all 3."
    - "  Wave 677 (cf3451): __getitem__/__setitem__/__delitem__ — all false for all 3."
    - "  Wave 678 (cf3466): __iter__/__next__/__len__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iter__ dict-presence — operator.contains(Cls.__dict__, '__iter__')
#
# All 3 concurrent.futures classes return false for __iter__.
# iter(x) calls __iter__ when defined in the class's own __dict__.
# concurrent.futures.Future: a state-machine result handle that does not
#   define __iter__ in its own __dict__. Results are retrieved via
#   result()/exception(); iteration is not part of the Future API.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool lifecycle managers
#   with no __iter__ in their own __dict__. Pool contents are not iterable
#   via the iterator protocol.
# ---------------------------------------------------------------------------

table cf3466.iter:
  description: "concurrent.futures types __iter__ dict-presence checks; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3466

  columns: [id, function, args, expected]
  rows:
    - ["cf3466001", operator.contains, [concurrent.futures.Future.__dict__,              "__iter__"], false]
    - ["cf3466002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__iter__"], false]
    - ["cf3466003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__iter__"], false]

# ---------------------------------------------------------------------------
# __next__ dict-presence — operator.contains(Cls.__dict__, '__next__')
#
# All 3 concurrent.futures classes return false for __next__.
# next(x) delegates to __next__ when defined in the class's own __dict__.
# concurrent.futures.Future: does NOT define __next__ in its own Future.__dict__.
#   Future results are retrieved via result(); iterator advancement is not part
#   of the public API.
# ThreadPoolExecutor/ProcessPoolExecutor: executor types with no __next__
#   defined in their own __dict__. Pool state is managed via submit()/shutdown().
# ---------------------------------------------------------------------------

table cf3466.next:
  description: "concurrent.futures types __next__ dict-presence checks; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3466

  columns: [id, function, args, expected]
  rows:
    - ["cf3466004", operator.contains, [concurrent.futures.Future.__dict__,              "__next__"], false]
    - ["cf3466005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__next__"], false]
    - ["cf3466006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__next__"], false]

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# All 3 concurrent.futures classes return false for __len__.
# len(x) delegates to __len__ when defined in the class's own __dict__.
# concurrent.futures types define no sizing protocol in their own __dict__.
# concurrent.futures.Future: holds a single result slot in a state-machine;
#   no __len__ is defined in Future.__dict__. Futures are not sized containers.
# ThreadPoolExecutor/ProcessPoolExecutor: executor types with no __len__
#   defined in their own __dict__. Pool instances do not expose a length.
# ---------------------------------------------------------------------------

table cf3466.len:
  description: "concurrent.futures types __len__ dict-presence checks; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3466

  columns: [id, function, args, expected]
  rows:
    - ["cf3466007", operator.contains, [concurrent.futures.Future.__dict__,              "__len__"], false]
    - ["cf3466008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__len__"], false]
    - ["cf3466009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__len__"], false]

# ---------------------------------------------------------------------------
# combined — __iter__, __next__, __len__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __iter__: false for all 3 — iter(x) protocol not in own __dict__.
# __next__: false for all 3 — next(x) protocol not in own __dict__.
# __len__:  false for all 3 — len(x) protocol not in own __dict__.
# All 9 values are false.
# concurrent.futures is a high-level parallel execution API. Its entire
#   public surface is method-based: submit(), map(), result(), cancel(),
#   done(), running(), cancelled(), add_done_callback(), shutdown(). Waves
#   658–677 established that no arithmetic, bitwise, reflected, in-place
#   augmented assignment, unary numeric, rounding, numeric conversion,
#   display, hash/eq/lt, ordering, or container/mapping protocol dunder
#   appears in the concurrent.futures type hierarchy. The iterator and
#   sizing protocol dunders tested here follow the same pattern.
# concurrent.futures.Future note: despite the name and its state-machine
#   design, Future does not define __iter__, __next__, or __len__ in its own
#   __dict__. These iterator/sizing dunders are not meaningful for a result
#   handle whose states are PENDING/RUNNING/CANCELLED/FINISHED — only entries
#   directly defined on the class appear in its __dict__.
# ThreadPoolExecutor/ProcessPoolExecutor note: executor types encapsulate a
#   pool of worker threads or processes; they expose only lifecycle and dispatch
#   methods. No iterator or sizing protocol overloads are defined in their __dict__.
# ---------------------------------------------------------------------------

table cf3466.combined:
  description: "concurrent.futures types combined __iter__/__next__/__len__; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3466

  columns: [id, function, args, expected]
  rows:
    - ["cf3466010", operator.contains, [concurrent.futures.Future.__dict__,              "__iter__"],  false]
    - ["cf3466011", operator.contains, [concurrent.futures.Future.__dict__,              "__next__"],  false]
    - ["cf3466012", operator.contains, [concurrent.futures.Future.__dict__,              "__len__"],   false]
    - ["cf3466013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__iter__"],  false]
    - ["cf3466014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__next__"],  false]
    - ["cf3466015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__len__"],   false]
    - ["cf3466016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__iter__"],  false]
    - ["cf3466017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__next__"],  false]
    - ["cf3466018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__len__"],   false]
