spec: inspect_extra352
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "inspect.classify_class_attrs.__name__ == 'classify_class_attrs' — verified with Python 3.14.3."
    - "inspect.classify_class_attrs.__module__ == 'inspect' — verified with Python 3.14.3."
    - "inspect.getmembers.__name__ == 'getmembers' — verified with Python 3.14.3."
    - "inspect.getmembers.__module__ == 'inspect' — verified with Python 3.14.3."
    - "inspect.getmembers_static.__name__ == 'getmembers_static' — added in Python 3.11; verified with Python 3.14.3."
    - "inspect.getmembers_static.__module__ == 'inspect' — verified with Python 3.14.3."
    - "inspect.getattr_static.__name__ == 'getattr_static' — verified with Python 3.14.3."
    - "inspect.getattr_static.__module__ == 'inspect' — verified with Python 3.14.3."
    - "inspect.findsource.__name__ == 'findsource' — verified with Python 3.14.3."
    - "inspect.findsource.__module__ == 'inspect' — verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.classify_class_attrs and inspect.getmembers identity
#
# inspect.classify_class_attrs.__name__ == 'classify_class_attrs'
# inspect.classify_class_attrs.__module__ == 'inspect'
# inspect.getmembers.__name__ == 'getmembers'
# inspect.getmembers.__module__ == 'inspect'
#
# Both are pure-Python functions defined in Lib/inspect.py.
# classify_class_attrs returns a list of Attribute named tuples describing
# each member of a class. getmembers returns all members of an object.
# ---------------------------------------------------------------------------

table inspect_extra352.classify_getmembers_identity:
  description: "inspect.classify_class_attrs and inspect.getmembers function __name__ and __module__ identity; both defined in Lib/inspect.py; new to extra352"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectmembers352

  columns: [id, function, args, expected, description]
  rows:
    - [classify_class_attrs_name_eq,
       "classify_class_attrs.__name__.__eq__",
       ["classify_class_attrs"],
       true,
       "inspect.classify_class_attrs.__name__.__eq__('classify_class_attrs') == True — classify_class_attrs is a pure-Python function in Lib/inspect.py that returns a list of Attribute named tuples for each class member; its __name__ is 'classify_class_attrs'; str.__eq__('classify_class_attrs') returns True; new to extra352"]
    - [classify_class_attrs_module_eq,
       "classify_class_attrs.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.classify_class_attrs.__module__.__eq__('inspect') == True — classify_class_attrs is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra352"]
    - [getmembers_name_eq,
       "getmembers.__name__.__eq__",
       ["getmembers"],
       true,
       "inspect.getmembers.__name__.__eq__('getmembers') == True — getmembers is a pure-Python function in Lib/inspect.py that returns all the members of an object as (name, value) pairs; its __name__ is 'getmembers'; str.__eq__('getmembers') returns True; new to extra352"]
    - [getmembers_module_eq,
       "getmembers.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — getmembers is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra352"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getmembers_static and inspect.getattr_static identity
#
# inspect.getmembers_static.__name__ == 'getmembers_static'
# inspect.getmembers_static.__module__ == 'inspect'
# inspect.getattr_static.__name__ == 'getattr_static'
# inspect.getattr_static.__module__ == 'inspect'
#
# getmembers_static was added in Python 3.11 and does not invoke descriptors.
# getattr_static retrieves attributes without triggering dynamic lookup
# (descriptors, __getattr__, __getattribute__). Both are defined in Lib/inspect.py.
# ---------------------------------------------------------------------------

table inspect_extra352.static_getmembers_identity:
  description: "inspect.getmembers_static (Python 3.11+) and inspect.getattr_static function __name__ and __module__ identity; both avoid descriptor invocation; new to extra352"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectmembers352

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_static_name_eq,
       "getmembers_static.__name__.__eq__",
       ["getmembers_static"],
       true,
       "inspect.getmembers_static.__name__.__eq__('getmembers_static') == True — getmembers_static was added in Python 3.11 as a variant of getmembers that does not invoke descriptors; its __name__ is 'getmembers_static'; str.__eq__('getmembers_static') returns True; new to extra352"]
    - [getmembers_static_module_eq,
       "getmembers_static.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmembers_static.__module__.__eq__('inspect') == True — getmembers_static is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra352"]
    - [getattr_static_name_eq,
       "getattr_static.__name__.__eq__",
       ["getattr_static"],
       true,
       "inspect.getattr_static.__name__.__eq__('getattr_static') == True — getattr_static is a pure-Python function in Lib/inspect.py that retrieves attributes without triggering dynamic lookup via descriptors or __getattr__; its __name__ is 'getattr_static'; str.__eq__('getattr_static') returns True; new to extra352"]
    - [getattr_static_module_eq,
       "getattr_static.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getattr_static.__module__.__eq__('inspect') == True — getattr_static is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra352"]

# ---------------------------------------------------------------------------
# Table 3: inspect.findsource identity
#
# inspect.findsource.__name__ == 'findsource'
# inspect.findsource.__module__ == 'inspect'
#
# findsource is an internal helper in Lib/inspect.py that returns the source
# lines and starting line index for an object. It is used by getsource and
# related functions.
# ---------------------------------------------------------------------------

table inspect_extra352.findsource_identity:
  description: "inspect.findsource function __name__ and __module__ identity; internal helper used by getsource; new to extra352"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectmembers352

  columns: [id, function, args, expected, description]
  rows:
    - [findsource_name_eq,
       "findsource.__name__.__eq__",
       ["findsource"],
       true,
       "inspect.findsource.__name__.__eq__('findsource') == True — findsource is an internal pure-Python function in Lib/inspect.py; it is used by getsource/getsourcelines to locate source code; its __name__ is 'findsource'; str.__eq__('findsource') returns True; new to extra352"]
    - [findsource_module_eq,
       "findsource.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.findsource.__module__.__eq__('inspect') == True — findsource is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra352"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra352
# ---------------------------------------------------------------------------

invariant inspect_extra352.classify_class_attrs_name:
  description: "inspect.classify_class_attrs.__name__ == 'classify_class_attrs' — pure-Python function in Lib/inspect.py; new to extra352"
  kind: python_call_eq
  function: classify_class_attrs.__name__.__eq__
  args: ["classify_class_attrs"]
  expected: true

invariant inspect_extra352.classify_class_attrs_module:
  description: "inspect.classify_class_attrs.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra352"
  kind: python_call_eq
  function: classify_class_attrs.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra352.getmembers_name:
  description: "inspect.getmembers.__name__ == 'getmembers' — pure-Python function in Lib/inspect.py; new to extra352"
  kind: python_call_eq
