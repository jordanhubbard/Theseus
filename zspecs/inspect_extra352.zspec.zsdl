  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra352.getmembers_static_name:
  description: "inspect.getmembers_static.__name__ == 'getmembers_static' — added in Python 3.11; defined in Lib/inspect.py; new to extra352"
  kind: python_call_eq
  function: getmembers_static.__name__.__eq__
  args: ["getmembers_static"]
  expected: true

invariant inspect_extra352.getmembers_static_module:
  description: "inspect.getmembers_static.__module__ == 'inspect' — Python 3.11+ function; defined in Lib/inspect.py; new to extra352"
  kind: python_call_eq
  function: getmembers_static.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra352.getattr_static_name:
  description: "inspect.getattr_static.__name__ == 'getattr_static' — retrieves attributes without invoking descriptors; defined in Lib/inspect.py; new to extra352"
  kind: python_call_eq
  function: getattr_static.__name__.__eq__
  args: ["getattr_static"]
  expected: true

invariant inspect_extra352.getattr_static_module:
  description: "inspect.getattr_static.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra352"
  kind: python_call_eq
  function: getattr_static.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra352.findsource_name:
  description: "inspect.findsource.__name__ == 'findsource' — internal helper function in Lib/inspect.py; new to extra352"
  kind: python_call_eq
  function: findsource.__name__.__eq__
  args: ["findsource"]
  expected: true

invariant inspect_extra352.findsource_module:
  description: "inspect.findsource.__module__ == 'inspect' — defined in Lib/inspect.py; new to extra352"
  kind: python_call_eq
  function: findsource.__module__.__eq__
  args: ["inspect"]
  expected: true
