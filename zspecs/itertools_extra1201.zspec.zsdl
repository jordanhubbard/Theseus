spec: itertools_extra1201
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks itertools.count.__bases__.__len__() == 1, itertools.cycle.__bases__.__len__() == 1, itertools.repeat.__bases__.__len__() == 1, itertools.accumulate.__bases__.__len__() == 1, itertools.combinations.__bases__.__len__() == 1, itertools.product.__bases__.__len__() == 1, itertools.groupby.__bases__.__len__() == 1 — not covered in _extra1171/_extra1186 (1171 only checked chain/zip_longest/product __bases__.__len__)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra1201.count_cycle_repeat_bases_len:
  description: "itertools.count, cycle, and repeat __bases__.__len__() == 1 identity"
  kind: python_call_eq
  category: count_cycle_repeat_bases_len
  id_prefix: it1201cc
  columns: [id, function, args, expected]
  rows:
    - [it1201cc001, itertools.count.__bases__.__len__,                  [],   1]
    - [it1201cc002, itertools.count.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [it1201cc003, itertools.cycle.__bases__.__len__,                  [],   1]
    - [it1201cc004, itertools.cycle.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [it1201cc005, itertools.repeat.__bases__.__len__,                 [],   1]
    - [it1201cc006, itertools.repeat.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [it1201cc007, itertools.count.__module__.__eq__,                  ["itertools"], true]
    - [it1201cc008, itertools.cycle.__module__.__eq__,                  ["itertools"], true]

