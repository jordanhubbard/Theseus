spec: multiprocessing_extra1351
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Process-based parallelism"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks at the class __dict__ level."
    - "multiprocessing.Process does not define __slots__, __weakref__, or __dict__ in its own __dict__."
    - "multiprocessing.Manager, Value, and Array also define none of these attributes in their own __dict__."
    - "multiprocessing.pool.Pool defines __weakref__ and __dict__ in its own __dict__ (top-level class in pool module)."
    - "multiprocessing.pool.AsyncResult and ApplyResult similarly define __weakref__ and __dict__ in their own __dict__."
    - "None of the multiprocessing classes use __slots__: all use standard instance __dict__ memory layout."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra1351.Process_slots_weakref_dict:
  description: "multiprocessing.Process, Manager, Value, Array __slots__, __weakref__, __dict__ checks: none define these in their own __dict__"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: mp1351pr
  columns: [id, function, args, expected]
  rows:
    - [mp1351pr001, multiprocessing.Process.__dict__.__contains__, ["__slots__"],   false]
    - [mp1351pr002, multiprocessing.Process.__dict__.__contains__, ["__weakref__"], false]
    - [mp1351pr003, multiprocessing.Process.__dict__.__contains__, ["__dict__"],    false]
    - [mp1351pr004, multiprocessing.Manager.__dict__.__contains__, ["__slots__"],   false]
    - [mp1351pr005, multiprocessing.Manager.__dict__.__contains__, ["__weakref__"], false]
    - [mp1351pr006, multiprocessing.Manager.__dict__.__contains__, ["__dict__"],    false]

table multiprocessing_extra1351.Value_Array_slots_weakref_dict:
  description: "multiprocessing.Value and Array do not define __slots__, __weakref__, or __dict__ in their own __dict__"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: mp1351va
  columns: [id, function, args, expected]
  rows:
    - [mp1351va001, multiprocessing.Value.__dict__.__contains__, ["__slots__"],   false]
    - [mp1351va002, multiprocessing.Value.__dict__.__contains__, ["__weakref__"], false]
    - [mp1351va003, multiprocessing.Value.__dict__.__contains__, ["__dict__"],    false]
    - [mp1351va004, multiprocessing.Array.__dict__.__contains__, ["__slots__"],   false]
    - [mp1351va005, multiprocessing.Array.__dict__.__contains__, ["__weakref__"], false]
    - [mp1351va006, multiprocessing.Array.__dict__.__contains__, ["__dict__"],    false]

table multiprocessing_extra1351.Pool_AsyncResult_slots_weakref_dict:
  description: "multiprocessing.pool.Pool and AsyncResult define __weakref__ and __dict__ in their own __dict__ (top-level classes in pool module)"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: mp1351po
  columns: [id, function, args, expected]
  rows:
    - [mp1351po001, multiprocessing.pool.Pool.__dict__.__contains__,        ["__slots__"],   false]
    - [mp1351po002, multiprocessing.pool.Pool.__dict__.__contains__,        ["__weakref__"], true]
    - [mp1351po003, multiprocessing.pool.Pool.__dict__.__contains__,        ["__dict__"],    true]
    - [mp1351po004, multiprocessing.pool.AsyncResult.__dict__.__contains__, ["__slots__"],   false]
    - [mp1351po005, multiprocessing.pool.AsyncResult.__dict__.__contains__, ["__weakref__"], true]
    - [mp1351po006, multiprocessing.pool.AsyncResult.__dict__.__contains__, ["__dict__"],    true]
