spec: is_anagram
version: ">=1.0.3"
backend: node(is-anagram)

docs: https://www.npmjs.com/package/is-anagram

provenance:
  derived_from:
    - "is-anagram README — https://www.npmjs.com/package/is-anagram"
    - "Test vectors verified with is-anagram via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-anagram source"
  notes:
    - "is-anagram is an npm package. Install: npm install is-anagram"
    - "Returns true if two strings are anagrams of each other."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_anagram.check:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: isanag

  columns: [id, args, expected]
  rows:
    - [yes,       ["listen", "silent"],  true]
    - [no,        ["hello", "world"],    false]
    - [triangle,  ["triangle", "integral"],  true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:23:04Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
