spec: socket_extra
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 791 — Internet Protocol"
  - "RFC 1700 — Assigned Numbers (network byte order)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 791 — Internet Protocol, DARPA, September 1981"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "socket source: internal BSD socket implementation"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "This spec extends socket.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket.zspec.zsdl covers: AF_INET/AF_INET6/AF_UNIX constants; SOCK_STREAM/SOCK_DGRAM/SOCK_RAW; IPPROTO_IP/TCP/UDP; SOL_SOCKET; SHUT_RD/WR/RDWR; socket/herror/gaierror class names; gethostname/getdefaulttimeout/inet_aton/inet_ntoa/htonl/ntohl function names; getdefaulttimeout()==None; inet_aton('127.0.0.1')/('0.0.0.0'); htonl(0)==0."
    - "socket.create_connection was added in Python 3.0; socket.create_server was added in Python 3.8."
    - "create_connection and create_server are module-level functions, not socket methods."
    - "setdefaulttimeout/getdefaulttimeout are symmetric; setdefaulttimeout(None) restores the no-timeout default."
    - "inet_aton('255.255.255.255').hex() == 'ffffffff' — broadcast address."
    - "inet_ntoa(b'\\x7f\\x00\\x00\\x01') == '127.0.0.1' — inverse of inet_aton."
    - "inet_ntoa(b'\\xff\\xff\\xff\\xff') == '255.255.255.255' — broadcast address inverse."
    - "htons(0) == 0 and ntohs(0) == 0 because zero is byte-order invariant."
    - "ntohl(0) == 0 — already tested in socket.zspec.zsdl for htonl; ntohl is the symmetric inverse."
    - "htonl(1) on a little-endian (x86/ARM) host returns 0x01000000 = 16777216."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "socket raises OSError (and subclasses herror, gaierror, timeout) for I/O failures. inet_aton raises OSError for invalid IP strings. inet_ntoa raises OSError for wrong-length bytes."
  stderr: "null"
  stickiness: "N/A — all tested invariants are pure-computation functions or name checks."
  codes: {}

# ---------------------------------------------------------------------------
# create_connection and create_server — function name checks
# (added in 3.0 and 3.8 respectively; no connection is opened)
# ---------------------------------------------------------------------------

table socket_extra.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fnname

  columns: [id, function, args, expected]
  rows:
    - [create_connection, create_connection.__name__.__eq__, ["create_connection"], true]
    - [create_server,     create_server.__name__.__eq__,     ["create_server"],     true]
    - [setdefaulttimeout, setdefaulttimeout.__name__.__eq__, ["setdefaulttimeout"], true]
    - [htons,             htons.__name__.__eq__,             ["htons"],             true]
    - [ntohs,             ntohs.__name__.__eq__,             ["ntohs"],             true]

# ---------------------------------------------------------------------------
# setdefaulttimeout / getdefaulttimeout — round-trip through a non-None value
# After calling setdefaulttimeout(0.0), getdefaulttimeout() returns 0.0.
# We restore None afterward to avoid polluting later invariants; however, since
# each invariant is evaluated independently we express only the setter name
# and the getter identity here (getter==None already in socket.zspec.zsdl).
# ---------------------------------------------------------------------------

invariant socket_extra.setdefaulttimeout.return_is_none:
  description: "socket.setdefaulttimeout(None) returns None (always returns None)"
  category: functions
  kind: python_call_eq
  function: setdefaulttimeout
  args: [~]
  expected: ~

# ---------------------------------------------------------------------------
# inet_aton — additional address vectors beyond socket.zspec.zsdl
# socket.zspec.zsdl already tests '127.0.0.1' -> '7f000001' and '0.0.0.0' -> '00000000'.
# ---------------------------------------------------------------------------

invariant socket_extra.inet_aton.broadcast:
  description: "socket.inet_aton('255.255.255.255').hex() == 'ffffffff' (broadcast address)"
  category: functions
  kind: python_call_eq
  function: inet_aton
  args: ["255.255.255.255"]
  method: hex
  method_args: []
  expected: "ffffffff"

invariant socket_extra.inet_aton.len_always_4:
  description: "len(socket.inet_aton('1.2.3.4')) == 4 (always exactly 4 bytes)"
  category: functions
  kind: python_call_eq
  function: inet_aton
  args: ["1.2.3.4"]
  method: __len__
  method_args: []
  expected: 4

# ---------------------------------------------------------------------------
# inet_ntoa — inverse of inet_aton (not tested in socket.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant socket_extra.inet_ntoa.loopback:
  description: "socket.inet_ntoa(b'\\x7f\\x00\\x00\\x01') == '127.0.0.1'"
  category: functions
  kind: python_call_eq
  function: inet_ntoa
  args: [!hex 7f000001]
  expected: "127.0.0.1"

invariant socket_extra.inet_ntoa.broadcast:
  description: "socket.inet_ntoa(b'\\xff\\xff\\xff\\xff') == '255.255.255.255'"
  category: functions
  kind: python_call_eq
  function: inet_ntoa
  args: [!hex ffffffff]
  expected: "255.255.255.255"

invariant socket_extra.inet_ntoa.zero:
  description: "socket.inet_ntoa(b'\\x00\\x00\\x00\\x00') == '0.0.0.0'"
  category: functions
  kind: python_call_eq
  function: inet_ntoa
  args: [!hex 00000000]
  expected: "0.0.0.0"

# ---------------------------------------------------------------------------
# htons / ntohs — zero is byte-order invariant on all platforms
# (htonl(0)==0 is already in socket.zspec.zsdl; ntohl(0) and htons(0)/ntohs(0) are new)
# ---------------------------------------------------------------------------

invariant socket_extra.htons.zero:
  description: "socket.htons(0) == 0 (zero is invariant across byte orders)"
  category: functions
  kind: python_call_eq
  function: htons
  args: [0]
  expected: 0

invariant socket_extra.ntohs.zero:
  description: "socket.ntohs(0) == 0 (zero is invariant across byte orders)"
  category: functions
  kind: python_call_eq
  function: ntohs
  args: [0]
  expected: 0

invariant socket_extra.ntohl.zero:
  description: "socket.ntohl(0) == 0 (zero is invariant across byte orders)"
  category: functions
  kind: python_call_eq
  function: ntohl
  args: [0]
  expected: 0

# ---------------------------------------------------------------------------
# htonl on a little-endian host (macOS/Darwin on x86_64 or arm64)
# htonl converts a 32-bit int from host byte order to network (big-endian) order.
# On little-endian hosts: htonl(1) == 0x01000000 == 16777216.
# ---------------------------------------------------------------------------

invariant socket_extra.htonl.one_little_endian:
  description: "socket.htonl(1) == 16777216 on little-endian (x86_64/arm64) macOS/Darwin"
  category: functions
  kind: python_call_eq
  function: htonl
  args: [1]
  expected: 16777216
