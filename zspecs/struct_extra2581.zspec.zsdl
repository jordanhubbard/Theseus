spec: struct_extra2581
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 2581 theme: __call__ dict-presence — checking whether struct.Struct defines __call__ in its class __dict__ (making Struct objects callable functors)."
    - "struct.Struct is a compiled struct format object. It caches the format string and provides pack/unpack methods, but it is not a callable functor."
    - "struct.Struct.__dict__.__contains__('__call__') == False — Struct instances cannot be invoked with (); they are not functors. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Attempting to call a Struct instance raises TypeError: '_struct.Struct' object is not callable."
    - "struct.Struct.__dict__.__contains__('pack') == True — pack() encodes values into bytes."
    - "struct.Struct.__dict__.__contains__('unpack') == True — unpack() decodes bytes into values."
    - "struct.Struct.__dict__.__contains__('pack_into') == True — pack_into() writes into a buffer at an offset."
    - "struct.Struct.__dict__.__contains__('unpack_from') == True — unpack_from() reads from a buffer at an offset."
    - "struct.Struct.__dict__.__contains__('iter_unpack') == True — iter_unpack() iterates over repeated structs in a buffer."
    - "struct.Struct.__dict__.__contains__('size') == True — size is the computed byte size of the struct format."
    - "struct.Struct.__dict__.__contains__('format') == True — format is the format string attribute."
    - "struct.Struct.__dict__.__contains__('__sizeof__') == True — __sizeof__ is defined for memory accounting."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __call__ absence — struct.Struct is not a callable functor
#
# struct.Struct objects are compiled format descriptors. They expose a
# pack/unpack API but are not callable with (). __call__ is absent from
# struct.Struct.__dict__.
# ---------------------------------------------------------------------------

table struct_extra2581.call_absent:
  description: "__call__ is absent from struct.Struct.__dict__ — Struct objects are not callable functors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2581

  columns: [id, function, args, expected]
  rows:
    - ["st2581001", "struct.Struct.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# Pack/unpack API presence — methods present in struct.Struct.__dict__
#
# The struct.Struct class defines its entire binary encoding API directly
# in its own __dict__. These True entries contrast with the __call__ absence.
# ---------------------------------------------------------------------------

table struct_extra2581.pack_unpack_api_present:
  description: "Binary encoding/decoding methods are present in struct.Struct.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2581

  columns: [id, function, args, expected]
  rows:
    - ["st2581002", "struct.Struct.__dict__.__contains__", ["pack"],        true]
    - ["st2581003", "struct.Struct.__dict__.__contains__", ["unpack"],      true]
    - ["st2581004", "struct.Struct.__dict__.__contains__", ["pack_into"],   true]
    - ["st2581005", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st2581006", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]

# ---------------------------------------------------------------------------
# Format and size descriptors present in struct.Struct.__dict__
#
# struct.Struct exposes 'format' (the format string) and 'size' (the
# computed byte count) as descriptors in its own __dict__.
# ---------------------------------------------------------------------------

table struct_extra2581.format_size_present:
  description: "format and size descriptors are present in struct.Struct.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2581

  columns: [id, function, args, expected]
  rows:
    - ["st2581007", "struct.Struct.__dict__.__contains__", ["format"], true]
    - ["st2581008", "struct.Struct.__dict__.__contains__", ["size"],   true]

# ---------------------------------------------------------------------------
# Lifecycle and memory dunders present in struct.Struct.__dict__
#
# struct.Struct is a C extension type that defines __init__, __new__,
# __repr__, __doc__, and __sizeof__ in its own __dict__.
# ---------------------------------------------------------------------------

table struct_extra2581.lifecycle_dunders_present:
  description: "Lifecycle and memory management dunders are present in struct.Struct.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2581

  columns: [id, function, args, expected]
  rows:
    - ["st2581009", "struct.Struct.__dict__.__contains__", ["__init__"],    true]
    - ["st2581010", "struct.Struct.__dict__.__contains__", ["__new__"],     true]
    - ["st2581011", "struct.Struct.__dict__.__contains__", ["__repr__"],    true]
    - ["st2581012", "struct.Struct.__dict__.__contains__", ["__doc__"],     true]
    - ["st2581013", "struct.Struct.__dict__.__contains__", ["__sizeof__"],  true]

# ---------------------------------------------------------------------------
# Absent call-related dunders — confirming non-functor nature
#
# Besides __call__, other call-related attributes like __get__ (descriptor)
# and __wrapped__ (decorator) are also absent from struct.Struct.__dict__.
# ---------------------------------------------------------------------------

table struct_extra2581.call_adjacent_absent:
  description: "Call-adjacent dunders are also absent from struct.Struct.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2581

  columns: [id, function, args, expected]
  rows:
    - ["st2581014", "struct.Struct.__dict__.__contains__", ["__call__"],   false]
    - ["st2581015", "struct.Struct.__dict__.__contains__", ["__get__"],    false]
    - ["st2581016", "struct.Struct.__dict__.__contains__", ["__wrapped__"], false]
