table deep_get_set.get:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: dgs

  columns: [id, args, expected]
  rows:
    - [two_level,   [{"a": {"b": 1}}, "a.b"],       1]
    - [three_level, [{"x": {"y": {"z": 42}}}, "x.y.z"],  42]
    - [top_level,   [{"a": 1}, "a"],               1]

