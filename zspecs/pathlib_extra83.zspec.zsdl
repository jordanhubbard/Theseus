spec: pathlib_extra83
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra82."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes for open/read_text/write_text/iterdir/mkdir/exists/unlink/stat/rename/read_bytes/write_bytes/touch/rmdir/resolve/glob/rglob/is_dir/is_file/absolute; PurePath/__dict__ membership; Path/__dict__ membership."
    - "pathlib_extra82 covers Path.glob/rglob/is_dir/is_file/absolute __code__.co_name and co_argcount."
    - "This spec covers: Path.symlink_to/__code__.co_name and co_argcount; Path.hardlink_to/__code__.co_name and co_argcount; Path.lstat/__code__.co_name and co_argcount; Path.expanduser/__code__.co_name and co_argcount; Path.parent/__class__.__name__; Path.name/__class__.__name__; Path.suffix/__class__.__name__."
    - "pathlib.Path.symlink_to.__code__.co_name == 'symlink_to' — verified by code object attribute."
    - "pathlib.Path.symlink_to.__code__.co_argcount == 3 — symlink_to(self, target, target_is_directory=False): self + target + target_is_directory; target_is_directory is a regular positional-or-keyword arg with a default."
    - "pathlib.Path.hardlink_to.__code__.co_name == 'hardlink_to' — verified by code object attribute."
    - "pathlib.Path.hardlink_to.__code__.co_argcount == 2 — hardlink_to(self, target): self + target only."
    - "pathlib.Path.lstat.__code__.co_name == 'lstat' — verified by code object attribute."
    - "pathlib.Path.lstat.__code__.co_argcount == 1 — lstat(self): only self."
    - "pathlib.Path.expanduser.__code__.co_name == 'expanduser' — verified by code object attribute."
    - "pathlib.Path.expanduser.__code__.co_argcount == 1 — expanduser(self): only self."
    - "pathlib.Path.parent.__class__.__name__ == 'property' — Path.parent is a Python property descriptor."
    - "pathlib.Path.name.__class__.__name__ == 'property' — Path.name is a Python property descriptor."
    - "pathlib.Path.suffix.__class__.__name__ == 'property' — Path.suffix is a Python property descriptor."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.symlink_to and Path.hardlink_to __code__ attributes
# symlink_to(self, target, target_is_directory=False): co_argcount == 3.
# hardlink_to(self, target): co_argcount == 2.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra83.symlink_hardlink_code:
  description: "Path.symlink_to and Path.hardlink_to __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore83

  columns: [id, function, args, expected]
  rows:
    - [symlink_co_name,   Path.symlink_to.__code__.co_name.__eq__,     ["symlink_to"],  true]
    - [symlink_co_argc,   Path.symlink_to.__code__.co_argcount.__eq__,  [3],            true]
    - [hardlink_co_name,  Path.hardlink_to.__code__.co_name.__eq__,    ["hardlink_to"], true]
    - [hardlink_co_argc,  Path.hardlink_to.__code__.co_argcount.__eq__, [2],            true]

# ---------------------------------------------------------------------------
# Path.lstat and Path.expanduser __code__ attributes
# lstat(self): co_argcount == 1; no parameters beyond self.
# expanduser(self): co_argcount == 1; no parameters beyond self.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra83.lstat_expanduser_code:
  description: "Path.lstat and Path.expanduser __code__ co_name and co_argcount"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore83

  columns: [id, function, args, expected]
  rows:
    - [lstat_co_name,      Path.lstat.__code__.co_name.__eq__,      ["lstat"],      true]
    - [lstat_co_argc,      Path.lstat.__code__.co_argcount.__eq__,   [1],           true]
    - [expanduser_co_name, Path.expanduser.__code__.co_name.__eq__, ["expanduser"], true]
    - [expanduser_co_argc, Path.expanduser.__code__.co_argcount.__eq__, [1],        true]

# ---------------------------------------------------------------------------
# Path.parent, Path.name, Path.suffix are property descriptors
# All three are Python property objects on the Path class.
# __class__.__name__ == 'property' for each.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra83.property_descriptors:
  description: "Path.parent, Path.name, Path.suffix are property descriptors"
  kind: python_call_eq
  category: class_properties
  id_prefix: pathlibmore83

  columns: [id, function, args, expected]
  rows:
    - [parent_cls, Path.parent.__class__.__name__.__eq__, ["property"], true]
    - [name_cls,   Path.name.__class__.__name__.__eq__,   ["property"], true]
    - [suffix_cls, Path.suffix.__class__.__name__.__eq__, ["property"], true]

# ---------------------------------------------------------------------------
# Combined co_name identity for symlink_to/hardlink_to/lstat/expanduser
# Confirms all four method code objects carry the correct co_name.
# Not covered in any prior pathlib spec.
# ---------------------------------------------------------------------------

table pathlib_extra83.method_code_names:
  description: "Path method __code__.co_name values match their method names"
  kind: python_call_eq
  category: code_attrs
  id_prefix: pathlibmore83

  columns: [id, function, args, expected]
  rows:
    - [symlink_name,    Path.symlink_to.__code__.co_name.__eq__,  ["symlink_to"],  true]
    - [hardlink_name,   Path.hardlink_to.__code__.co_name.__eq__, ["hardlink_to"], true]
    - [lstat_name,      Path.lstat.__code__.co_name.__eq__,       ["lstat"],       true]
    - [expanduser_name, Path.expanduser.__code__.co_name.__eq__,  ["expanduser"],  true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra83.symlink_to_code.co_name:
  description: "pathlib.Path.symlink_to.__code__.co_name == 'symlink_to'"
  category: code_attrs
  kind: python_call_eq
  function: Path.symlink_to.__code__.co_name.__eq__
  args: ["symlink_to"]
  expected: true

invariant pathlib_extra83.symlink_to_code.co_argcount:
  description: "pathlib.Path.symlink_to.__code__.co_argcount == 3 (self + target + target_is_directory)"
  category: code_attrs
  kind: python_call_eq
  function: Path.symlink_to.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant pathlib_extra83.hardlink_to_code.co_argcount:
  description: "pathlib.Path.hardlink_to.__code__.co_argcount == 2 (self + target)"
  category: code_attrs
  kind: python_call_eq
  function: Path.hardlink_to.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant pathlib_extra83.parent.is_property:
  description: "pathlib.Path.parent.__class__.__name__ == 'property'"
  category: class_properties
  kind: python_call_eq
  function: Path.parent.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant pathlib_extra83.suffix.is_property:
  description: "pathlib.Path.suffix.__class__.__name__ == 'property'"
  category: class_properties
  kind: python_call_eq
  function: Path.suffix.__class__.__name__.__eq__
  args: ["property"]
  expected: true
