spec: zipfile
version: ">=3.9"
backend: python_module(zipfile)

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/zipfile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "zipfile source: zipfile/__init__.py (PSF; source inspection permitted)"
  not_derived_from:
    - "zipfile source: internal implementation details"
  notes:
    - "zipfile.ZipFile is the main class for reading and writing ZIP archives."
    - "zipfile.ZipInfo stores metadata for a single archive member."
    - "ZIP_STORED=0 (no compression), ZIP_DEFLATED=8 (zlib), ZIP_BZIP2=12, ZIP_LZMA=14."
    - "ZIP64_LIMIT=2147483647 is the max size (in bytes) of a single file without ZIP64 extension."
    - "ZIP_FILECOUNT_LIMIT=65535 is the max number of files in a ZIP without ZIP64 extension."
    - "ZIP_MAX_COMMENT=65535 is the maximum length of the archive comment field."
    - "BadZipFile is raised when opening an invalid or corrupt ZIP archive; subclass of Exception."
    - "LargeZipFile is raised when a file exceeds ZIP64_LIMIT and allowZip64=False; subclass of Exception."
    - "is_zipfile(file) returns True if the file/bytes-like object appears to be a valid ZIP archive."
    - "ZipInfo('name') constructs a member info object with compress_type=ZIP_STORED (0) by default."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "zipfile.ZipFile raises BadZipFile when opening invalid data in read mode."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Compression method constants
# ---------------------------------------------------------------------------

invariant zipfile.ZIP_STORED.value:
  description: "zipfile.ZIP_STORED == 0 — no compression"
  category: constants
  kind: python_call_eq
  function: ZIP_STORED.__eq__
  args: [0]
  expected: true

invariant zipfile.ZIP_DEFLATED.value:
  description: "zipfile.ZIP_DEFLATED == 8 — zlib deflate compression"
  category: constants
  kind: python_call_eq
  function: ZIP_DEFLATED.__eq__
  args: [8]
  expected: true

invariant zipfile.ZIP_BZIP2.value:
  description: "zipfile.ZIP_BZIP2 == 12 — bzip2 compression"
  category: constants
  kind: python_call_eq
  function: ZIP_BZIP2.__eq__
  args: [12]
  expected: true

invariant zipfile.ZIP_LZMA.value:
  description: "zipfile.ZIP_LZMA == 14 — LZMA compression"
  category: constants
  kind: python_call_eq
  function: ZIP_LZMA.__eq__
  args: [14]
  expected: true

invariant zipfile.ZIP64_LIMIT.value:
  description: "zipfile.ZIP64_LIMIT == 2147483647 — max file size without ZIP64"
  category: constants
  kind: python_call_eq
  function: ZIP64_LIMIT.__eq__
  args: [2147483647]
  expected: true

invariant zipfile.ZIP_FILECOUNT_LIMIT.value:
  description: "zipfile.ZIP_FILECOUNT_LIMIT == 65535 — max file count without ZIP64"
  category: constants
  kind: python_call_eq
  function: ZIP_FILECOUNT_LIMIT.__eq__
  args: [65535]
  expected: true

invariant zipfile.ZIP_MAX_COMMENT.value:
  description: "zipfile.ZIP_MAX_COMMENT == 65535 — maximum archive comment length"
  category: constants
  kind: python_call_eq
  function: ZIP_MAX_COMMENT.__eq__
  args: [65535]
  expected: true

# ---------------------------------------------------------------------------
# Class identity — ZipFile, ZipInfo, BadZipFile, LargeZipFile, Path
# ---------------------------------------------------------------------------

invariant zipfile.ZipFile.class_name:
  description: "zipfile.ZipFile.__name__ == 'ZipFile'"
  category: class_metadata
  kind: python_call_eq
  function: ZipFile.__name__.__eq__
  args: ["ZipFile"]
  expected: true

invariant zipfile.ZipInfo.class_name:
  description: "zipfile.ZipInfo.__name__ == 'ZipInfo'"
  category: class_metadata
  kind: python_call_eq
  function: ZipInfo.__name__.__eq__
  args: ["ZipInfo"]
  expected: true

invariant zipfile.BadZipFile.class_name:
  description: "zipfile.BadZipFile.__name__ == 'BadZipFile'"
  category: class_metadata
  kind: python_call_eq
  function: BadZipFile.__name__.__eq__
  args: ["BadZipFile"]
  expected: true

invariant zipfile.LargeZipFile.class_name:
  description: "zipfile.LargeZipFile.__name__ == 'LargeZipFile'"
  category: class_metadata
  kind: python_call_eq
  function: LargeZipFile.__name__.__eq__
  args: ["LargeZipFile"]
  expected: true

invariant zipfile.Path.class_name:
  description: "zipfile.Path.__name__ == 'Path'"
  category: class_metadata
  kind: python_call_eq
  function: Path.__name__.__eq__
  args: ["Path"]
  expected: true

# ---------------------------------------------------------------------------
# Exception hierarchy
# ---------------------------------------------------------------------------

invariant zipfile.BadZipFile.base_is_Exception:
  description: "zipfile.BadZipFile.__bases__[0].__name__ == 'Exception'"
  category: class_metadata
  kind: python_call_eq
  function: BadZipFile.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

invariant zipfile.LargeZipFile.base_is_Exception:
  description: "zipfile.LargeZipFile.__bases__[0].__name__ == 'Exception'"
  category: class_metadata
  kind: python_call_eq
  function: LargeZipFile.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# ZipInfo construction — filename and default compress_type
# ---------------------------------------------------------------------------

invariant zipfile.ZipInfo.filename:
  description: "zipfile.ZipInfo('hello.txt').filename == 'hello.txt'"
  category: zipinfo
  kind: python_call_eq
  function: ZipInfo
  args: ["hello.txt"]
  method: filename
  expected: "hello.txt"

invariant zipfile.ZipInfo.compress_type_default:
  description: "zipfile.ZipInfo('hello.txt').compress_type == 0 (ZIP_STORED by default)"
  category: zipinfo
  kind: python_call_eq
  function: ZipInfo
  args: ["hello.txt"]
  method: compress_type.__eq__
  method_args: [0]
  expected: true

invariant zipfile.ZipInfo.file_size_default:
  description: "zipfile.ZipInfo('hello.txt').file_size == 0 — default file size is zero"
  category: zipinfo
  kind: python_call_eq
  function: ZipInfo
  args: ["hello.txt"]
  method: file_size.__eq__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# is_zipfile — non-ZIP bytes return False
# ---------------------------------------------------------------------------

invariant zipfile.is_zipfile.false_on_ascii:
  description: "zipfile.is_zipfile(b'not a zip') == False — non-ZIP bytes are rejected"
  category: is_zipfile
  kind: python_call_eq
  function: is_zipfile
  args: [{type: bytes_ascii, value: "not a zip"}]
  expected: false

invariant zipfile.is_zipfile.false_on_empty:
  description: "zipfile.is_zipfile(b'') == False — empty bytes are not a ZIP file"
  category: is_zipfile
  kind: python_call_eq
  function: is_zipfile
  args: [{type: bytes_ascii, value: ""}]
  expected: false

# ---------------------------------------------------------------------------
# Error — BadZipFile raised on invalid data
# ---------------------------------------------------------------------------

invariant zipfile.ZipFile.raises_BadZipFile_on_invalid:
  description: "zipfile.ZipFile(BytesIO(b'bad data'), 'r') raises BadZipFile"
  category: error
  kind: python_call_raises
  function: ZipFile
  args: [{type: bytes_ascii, value: "bad data"}, "r"]
  expected_exception: BadZipFile
