spec: is_docker
version: ">=3.0.0"
backend: node(is-docker)

docs: https://github.com/sindresorhus/is-docker#readme

provenance:
  derived_from:
    - "is-docker README — https://github.com/sindresorhus/is-docker#readme"
    - "Test vectors verified with is-docker via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "is-docker source"
  notes:
    - "Detect if the current process runs inside a Docker container — checks /.dockerenv and cgroup."
    - "Install: npm install is-docker"
    - "v4 ESM only; default export is the function (returns boolean each call)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "Detection result cached."
  codes: {}

invariant is_docker.default_is_function:
  description: "Default export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.constructor.name"}
  expected: "Function"

invariant is_docker.returns_boolean:
  description: "isDocker() returns a Boolean"
  category: usage
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "Boolean"

invariant is_docker.macos_value_is_false:
  description: "On macOS host (the test runner), isDocker() is false"
  category: usage
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: []
  chain: []
  expected: false

invariant is_docker.factory_arity_zero:
  description: "isDocker takes no args — function.length 0"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "default.length"}
  expected: 0

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:24:48Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
