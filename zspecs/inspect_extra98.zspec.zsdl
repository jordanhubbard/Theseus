spec: inspect_extra98
version: ">=3.9"
backend: python_module(inspect)
extends: inspect_extra97

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra97.zspec.zsdl."
    - "This spec covers: inspect module function __module__ attribute; parameter introspection via co_argcount; inspect function __qualname__ lengths; inspect.Parameter class identity (Wave 255)."
    - "inspect.getmembers.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.signature.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isfunction.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isclass.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.ismethod.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.isabstract.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.ismodule.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.getmembers.__code__.co_argcount == 2. Verified with Python 3.14.3."
    - "inspect.signature.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isfunction.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isclass.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.ismethod.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.iscoroutinefunction.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.isabstract.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "inspect.Parameter.__class__.__name__ == 'type'. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "inspect.Parameter.__qualname__ == 'Parameter'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect function __module__ attributes (all 'inspect')
#
# Wave 255 theme: inspect module function __module__ attribute.
#
# inspect.getmembers.__module__ == 'inspect'
# inspect.signature.__module__ == 'inspect'
# inspect.isfunction.__module__ == 'inspect'
# inspect.isclass.__module__ == 'inspect'
# inspect.ismethod.__module__ == 'inspect'
# inspect.iscoroutinefunction.__module__ == 'inspect'
# inspect.isbuiltin.__module__ == 'inspect'
# inspect.isabstract.__module__ == 'inspect'
#
# All public inspect functions are defined in Lib/inspect.py; their __module__
# attribute is 'inspect'. New to extra98.
# ---------------------------------------------------------------------------

table inspect_extra98.function_module_attrs:
  description: "inspect.getmembers/signature/isfunction/isclass/ismethod/iscoroutinefunction/isbuiltin/isabstract __module__ == 'inspect'; all defined in Lib/inspect.py; wave 255; new to extra98"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectmodule98

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_module_eq_inspect,
       "getmembers.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — getmembers is a pure-Python function defined in Lib/inspect.py; its __module__ attribute reflects the module where it was defined; str.__eq__('inspect') returns True; new to extra98"]
    - [signature_module_eq_inspect,
       "signature.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.signature.__module__.__eq__('inspect') == True — signature is a pure-Python function defined in Lib/inspect.py; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra98"]
    - [isfunction_module_eq_inspect,
       "isfunction.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isfunction.__module__.__eq__('inspect') == True — isfunction is a plain Python function defined in Lib/inspect.py that checks isinstance against types.FunctionType; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra98"]
    - [isclass_module_eq_inspect,
       "isclass.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isclass.__module__.__eq__('inspect') == True — isclass is defined in Lib/inspect.py; checks isinstance(object, type); __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra98"]
    - [ismethod_module_eq_inspect,
       "ismethod.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.ismethod.__module__.__eq__('inspect') == True — ismethod is defined in Lib/inspect.py; it checks isinstance(object, types.MethodType); __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra98"]
    - [iscoroutinefunction_module_eq_inspect,
       "iscoroutinefunction.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.iscoroutinefunction.__module__.__eq__('inspect') == True — iscoroutinefunction is defined in Lib/inspect.py; it detects async def functions; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra98"]
    - [isbuiltin_module_eq_inspect,
       "isbuiltin.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isbuiltin.__module__.__eq__('inspect') == True — isbuiltin is defined in Lib/inspect.py; checks isinstance(object, types.BuiltinFunctionType); __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra98"]
    - [isabstract_module_eq_inspect,
       "isabstract.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.isabstract.__module__.__eq__('inspect') == True — isabstract is defined in Lib/inspect.py; checks __abstractmethods__; __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra98"]

# ---------------------------------------------------------------------------
# Table 2: inspect function co_argcount values
#
# Wave 255 theme: inspect function parameter introspection via co_argcount.
#
# inspect.getmembers.__code__.co_argcount == 2
# inspect.signature.__code__.co_argcount == 1
# inspect.isfunction.__code__.co_argcount == 1
# inspect.isclass.__code__.co_argcount == 1
# inspect.ismethod.__code__.co_argcount == 1
# inspect.iscoroutinefunction.__code__.co_argcount == 1
# inspect.isbuiltin.__code__.co_argcount == 1
# inspect.isabstract.__code__.co_argcount == 1
#
# getmembers(object, predicate=None) takes two positional args.
# All is*/signature functions take a single positional arg.
# New to extra98.
# ---------------------------------------------------------------------------

table inspect_extra98.function_co_argcount:
  description: "inspect function co_argcount: getmembers==2; signature/isfunction/isclass/ismethod/iscoroutinefunction/isbuiltin/isabstract==1; wave 255; new to extra98"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectmodule98

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_co_argcount_eq_2,
       "getmembers.__code__.co_argcount.__eq__",
       [2],
       true,
       "inspect.getmembers.__code__.co_argcount.__eq__(2) == True — getmembers(object, predicate=None) takes two positional parameters; co_argcount counts all positional args including those with defaults; int.__eq__(2) returns True; new to extra98"]
    - [signature_co_argcount_eq_1,
       "signature.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.signature.__code__.co_argcount.__eq__(1) == True — inspect.signature(obj) takes one positional argument (the callable to inspect); co_argcount is 1; int.__eq__(1) returns True; new to extra98"]
    - [isfunction_co_argcount_eq_1,
       "isfunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isfunction.__code__.co_argcount.__eq__(1) == True — isfunction(object) takes one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra98"]
    - [isclass_co_argcount_eq_1,
       "isclass.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isclass.__code__.co_argcount.__eq__(1) == True — isclass(object) takes one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra98"]
    - [ismethod_co_argcount_eq_1,
       "ismethod.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.ismethod.__code__.co_argcount.__eq__(1) == True — ismethod(object) takes one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra98"]
    - [iscoroutinefunction_co_argcount_eq_1,
       "iscoroutinefunction.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.iscoroutinefunction.__code__.co_argcount.__eq__(1) == True — iscoroutinefunction(object) takes one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra98"]
    - [isbuiltin_co_argcount_eq_1,
       "isbuiltin.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isbuiltin.__code__.co_argcount.__eq__(1) == True — isbuiltin(object) takes one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra98"]
    - [isabstract_co_argcount_eq_1,
       "isabstract.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.isabstract.__code__.co_argcount.__eq__(1) == True — isabstract(object) takes one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra98"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Parameter class identity and ismodule __module__
#
# Wave 255 theme: inspect.Parameter class identity and ismodule attrs.
#
# inspect.Parameter.__class__.__name__ == 'type'
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.__qualname__ == 'Parameter'
# inspect.ismodule.__module__ == 'inspect'
# inspect.ismodule.__code__.co_argcount == 1
#
# inspect.Parameter is a Python class used to represent callable parameters.
# ismodule is a plain Python function taking one arg. New to extra98.
# ---------------------------------------------------------------------------

table inspect_extra98.parameter_class_and_ismodule:
  description: "inspect.Parameter class identity (__class__.__name__/__module__/__qualname__); inspect.ismodule __module__/co_argcount; wave 255; new to extra98"
  kind: python_call_eq
  category: string_identity
  id_prefix: inspectmodule98

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_class_name_eq_type,
       "Parameter.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.__class__.__name__.__eq__('type') == True — inspect.Parameter is a Python class defined with 'class Parameter:' in Lib/inspect.py; its metaclass is the built-in <class 'type'>; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra98"]
    - [parameter_module_eq_inspect,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — Parameter is defined in Lib/inspect.py; its __module__ attribute is 'inspect'; str.__eq__('inspect') returns True; new to extra98"]
    - [parameter_qualname_eq,
       "Parameter.__qualname__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter is defined at module scope in Lib/inspect.py; its __qualname__ is the simple class name 'Parameter'; str.__eq__('Parameter') returns True; new to extra98"]
    - [ismodule_module_eq_inspect,
       "ismodule.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.ismodule.__module__.__eq__('inspect') == True — ismodule is a plain Python function defined in Lib/inspect.py; it checks isinstance(object, types.ModuleType); __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra98"]
    - [ismodule_co_argcount_eq_1,
       "ismodule.__code__.co_argcount.__eq__",
       [1],
       true,
       "inspect.ismodule.__code__.co_argcount.__eq__(1) == True — ismodule(object) takes one positional argument; co_argcount is 1; int.__eq__(1) returns True; new to extra98"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra98
# ---------------------------------------------------------------------------

invariant inspect_extra98.getmembers_module:
  description: "inspect.getmembers.__module__ == 'inspect' — pure-Python function defined in Lib/inspect.py; wave 255; new to extra98"
  kind: python_call_eq
  function: getmembers.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra98.getmembers_co_argcount:
  description: "inspect.getmembers.__code__.co_argcount == 2 — getmembers(object, predicate=None) takes two positional parameters; wave 255; new to extra98"
  kind: python_call_eq
  function: getmembers.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant inspect_extra98.iscoroutinefunction_module:
  description: "inspect.iscoroutinefunction.__module__ == 'inspect' — async detection function defined in Lib/inspect.py; wave 255; new to extra98"
  kind: python_call_eq
  function: iscoroutinefunction.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra98.parameter_class_name:
  description: "inspect.Parameter.__class__.__name__ == 'type' — Parameter is a Python class with type as metaclass; wave 255; new to extra98"
  kind: python_call_eq
  function: Parameter.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra98.isbuiltin_co_argcount:
  description: "inspect.isbuiltin.__code__.co_argcount == 1 — isbuiltin(object) takes a single positional argument; wave 255; new to extra98"
  kind: python_call_eq
  function: isbuiltin.__code__.co_argcount.__eq__
  args: [1]
  expected: true
