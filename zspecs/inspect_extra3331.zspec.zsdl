spec: in3331
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 669 (in3331): __iand__, __ior__, __ixor__ dict-presence checks for inspect types."
    - "Theme: __iand__/__ior__/__ixor__ in-place bitwise logical dict-presence."
    - "In-place augmented assignment operators (&=, |=, ^=) fall back to __and__/__or__/__xor__ if not defined."
    - "All values False — callable/iterator/inspection/synchronization types have no in-place bitwise logical operators."
    - "No inspect type defines __iand__, __ior__, or __ixor__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "None of these types implement in-place bitwise logical protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3331.iand:
  description: "inspect types __iand__ dict-presence checks; wave 669"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3331
  columns: [id, function, args, expected]
  rows:
    - ["in3331001", operator.contains, [inspect.Parameter.__dict__,           "__iand__"], false]
    - ["in3331002", operator.contains, [inspect.Signature.__dict__,           "__iand__"], false]
    - ["in3331003", operator.contains, [inspect.BoundArguments.__dict__,      "__iand__"], false]
    - ["in3331004", operator.contains, [inspect.FrameInfo.__dict__,           "__iand__"], false]
    - ["in3331005", operator.contains, [inspect.ArgInfo.__dict__,             "__iand__"], false]
    - ["in3331006", operator.contains, [inspect.FullArgSpec.__dict__,         "__iand__"], false]
    - ["in3331007", operator.contains, [inspect.Attribute.__dict__,           "__iand__"], false]
    - ["in3331008", operator.contains, [inspect.ClassFoundException.__dict__, "__iand__"], false]
    - ["in3331009", operator.contains, [inspect.EndOfBlock.__dict__,          "__iand__"], false]

