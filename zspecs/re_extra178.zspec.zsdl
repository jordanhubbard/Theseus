spec: re_extra178
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.error class identity — __name__, __module__, __qualname__, __mro__ length, and base class."
    - "re.error.__name__ == 'error' (len=5; all lowercase — unlike most exception classes which use CamelCase)."
    - "re.error.__module__ == 're' (len=2)."
    - "re.error.__qualname__ == 'error' (len=5; same as __name__)."
    - "re.error.__bases__[0].__name__ == 'Exception' — the direct base class is Exception."
    - "re.error.__mro__.__len__() == 4 — MRO is: error > Exception > BaseException > object."
    - "re.PatternError is an alias for re.error in Python 3.13+: re.PatternError.__name__ == 'error' (it IS re.error, not a subclass)."
    - "re.error.__name__ (5) == re.error.__qualname__ (5): __name__ and __qualname__ are equal for a top-level class."
    - "re.error.__module__ (2) < re.error.__name__ (5): the module name is shorter than the class name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.error class name, module, and qualname
# error.__name__ == 'error' (len=5; lowercase)
# error.__module__ == 're' (len=2)
# error.__qualname__ == 'error' (len=5; same as __name__)
# ---------------------------------------------------------------------------

table re_extra178.error_name_and_module:
  description: "re.error class metadata: __name__=='error' (len=5; lowercase); __module__=='re' (len=2); __qualname__=='error' (len=5; equals __name__); module (2) < name=qualname (5) in length"
  kind: python_call_eq
  category: identity
  id_prefix: reerror178

  columns: [id, function, args, expected, description]
  rows:
    - [error_name,      error.__name__.__eq__,      ["error"], true, "re.error.__name__ == 'error' — 'error' has 5 characters; the class name is all lowercase unlike most Python exception classes which use CamelCase (e.g., ValueError, TypeError); error (5) > re module name 're' (2) by 3; error (5) == error.__qualname__ (5): __name__ and __qualname__ match for a top-level class; confirmed Python 3.14.3 macOS"]
    - [error_name_len,  error.__name__.__len__,     [],        5,    "re.error.__name__.__len__() == 5 — 'error' has 5 characters: e(1)r(2)r(3)o(4)r(5); error (5) > '__module__' value 're' (2) by 3; error (5) == qualname (5): the two length-5 string attributes of re.error; error.__name__ (5) < 'Exception' (9): the base class name is longer; confirmed Python 3.14.3 macOS"]
    - [error_module,    error.__module__.__eq__,    ["re"],    true, "re.error.__module__ == 're' — 're' has 2 characters; error.__module__ (2) < error.__name__ (5) by 3; all public re module objects share __module__ == 're'; confirmed Python 3.14.3 macOS"]
    - [error_module_len,error.__module__.__len__,   [],        2,    "re.error.__module__.__len__() == 2 — 're' has 2 characters; module name (2) < class name (5) by 3; module name (2) < qualname (5) by 3; the module name 're' is the shortest string attribute among those checked for re.error; confirmed Python 3.14.3 macOS"]
    - [error_qualname,  error.__qualname__.__eq__,  ["error"], true, "re.error.__qualname__ == 'error' — 'error' has 5 characters; __qualname__ == __name__ for a top-level class (no enclosing class or function); error.__qualname__ (5) == error.__name__ (5): the two attributes hold identical strings for re.error; confirmed Python 3.14.3 macOS"]
    - [error_qual_len,  error.__qualname__.__len__, [],        5,    "re.error.__qualname__.__len__() == 5 — 'error' has 5 characters; qualname (5) == __name__ (5): equal for a top-level class; qualname (5) > __module__ (2) by 3; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.error base class and MRO
# error.__bases__[0].__name__ == 'Exception'
# error.__mro__.__len__() == 4 (error > Exception > BaseException > object)
# ---------------------------------------------------------------------------

table re_extra178.error_mro:
  description: "re.error MRO: __bases__[0].__name__=='Exception'; __mro__.__len__()==4 (error > Exception > BaseException > object); MRO has 4 elements"
  kind: python_call_eq
  category: identity
  id_prefix: reerror178

  columns: [id, function, args, expected, description]
  rows:
    - [error_base,     "error.__bases__[0].__name__.__eq__", ["Exception"], true, "re.error.__bases__[0].__name__ == 'Exception' — the direct base class of re.error is Exception; re.error.__bases__ is a 1-tuple containing Exception; 'Exception' has 9 characters: Exception (9) > error (5) by 4; the MRO therefore is: error > Exception > BaseException > object (4 elements); confirmed Python 3.14.3 macOS"]
    - [mro_len,        "error.__mro__.__len__",              [],            4,    "re.error.__mro__.__len__() == 4 — the MRO of re.error has 4 classes: error (0) > Exception (1) > BaseException (2) > object (3); MRO len 4 is typical for a single-inheritance exception class that inherits directly from Exception; confirmed Python 3.14.3 macOS"]
    - [mro_0_name,     "error.__mro__[0].__name__.__eq__",  ["error"],     true, "re.error.__mro__[0].__name__ == 'error' — the first element of the MRO is re.error itself; __mro__[0] is always the class itself; confirmed Python 3.14.3 macOS"]
    - [mro_1_name,     "error.__mro__[1].__name__.__eq__",  ["Exception"], true, "re.error.__mro__[1].__name__ == 'Exception' — the second element of the MRO is Exception; __mro__[1] is the direct base class; 'Exception' has 9 characters; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# re.PatternError alias (Python 3.13+) and re.error class object identity
# re.PatternError.__name__ == 'error' — PatternError IS re.error (not a subclass)
# re.error.__class__.__name__ == 'type'
# ---------------------------------------------------------------------------

table re_extra178.error_alias_and_type:
  description: "re.PatternError is an alias for re.error in Python 3.13+: PatternError.__name__=='error'; re.error.__class__.__name__=='type' (it is a class object); error is a class not an instance"
  kind: python_call_eq
  category: identity
  id_prefix: reerror178

  columns: [id, function, args, expected, description]
  rows:
    - [pattern_error_name, PatternError.__name__.__eq__,       ["error"], true, "re.PatternError.__name__ == 'error' — PatternError is an alias introduced in Python 3.13 for re.error; because PatternError IS re.error (not a subclass), its __name__ is 'error' not 'PatternError'; PatternError.__name__ == error.__name__: both are 'error'; confirmed Python 3.14.3 macOS"]
    - [error_is_type,      error.__class__.__name__.__eq__,    ["type"],  true, "re.error.__class__.__name__ == 'type' — re.error is a class object; its metaclass is the built-in 'type'; this distinguishes the class object from an instance of re.error; confirmed Python 3.14.3 macOS"]
    - [error_name_eq_qual, error.__name__.__eq__,              ["error"], true, "re.error.__name__ == 'error' (standalone confirmation) — the class name is the 5-character lowercase string 'error'; error.__name__ (5) == error.__qualname__ (5): equal for a top-level class definition; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra178.error_name_is_error:
  description: "re.error.__name__ == 'error' — the class name is all-lowercase 'error' with 5 characters; this is unusual for Python exceptions which normally use CamelCase; error.__name__ (5) == error.__qualname__ (5); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant re_extra178.error_module_is_re:
  description: "re.error.__module__ == 're' — 're' has 2 characters; error.__module__ (2) < error.__name__ (5) by 3; the module name 're' is shared by all public re module objects; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra178.error_qualname_is_error:
  description: "re.error.__qualname__ == 'error' — 'error' has 5 characters; __qualname__ == __name__ for a top-level class with no enclosing scope; both are the 5-character string 'error'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["error"]
  expected: true

invariant re_extra178.error_base_is_Exception:
  description: "re.error.__bases__[0].__name__ == 'Exception' — the first (and only) direct base class of re.error is Exception; this places re.error in the standard exception hierarchy: error > Exception > BaseException > object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant re_extra178.error_mro_len_4:
  description: "re.error.__mro__.__len__() == 4 — the MRO has 4 entries: error, Exception, BaseException, object; MRO length 4 is standard for a single-inheritance exception that directly extends Exception; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "error.__mro__.__len__"
  args: []
  expected: 4

invariant re_extra178.PatternError_name_is_error:
  description: "re.PatternError.__name__ == 'error' — PatternError is a Python 3.13+ alias for re.error; because it IS re.error (not a subclass), its __name__ is 'error' not 'PatternError'; PatternError.__name__ == error.__name__; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: PatternError.__name__.__eq__
  args: ["error"]
  expected: true

invariant re_extra178.error_name_len_5:
  description: "re.error.__name__.__len__() == 5 — 'error' has 5 characters: e-r-r-o-r; error (5) > module 're' (2) by 3; error (5) == qualname (5); error (5) < base class 'Exception' (9) by 4; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: error.__name__.__len__
  args: []
  expected: 5

