spec: filecmp_extra5
version: ">=3.9"
backend: python_module(filecmp)

docs: https://docs.python.org/3/library/filecmp.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/filecmp.html — Python filecmp module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/filecmp.py"
  notes:
    - "This spec extends filecmp.zspec.zsdl and all prior filecmp_extra specs."
    - "filecmp.zspec.zsdl covers: cmp/cmpfiles/clear_cache __name__ table; dircmp.__name__; cmp.__module__; dircmp method names table; DEFAULT_IGNORES type and .git membership; clear_cache() return value."
    - "filecmp_extra.zspec.zsdl covers: dircmp.__bases__[0].__name__; dircmp.__module__/__class__.__name__; DEFAULT_IGNORES VCS entries table and length; cmpfiles/clear_cache module; dircmp.hide type; cmpfiles/cmp __class__.__name__."
    - "filecmp_extra2.zspec.zsdl covers: cmp/__name__; cmpfiles/__name__; dircmp/__name__; DEFAULT_IGNORES/__class__.__name__; dircmp/__module__/__bases__[0]/__name__."
    - "filecmp_extra3.zspec.zsdl covers: clear_cache/__name__/__module__; function_names table; dircmp/__qualname__; DEFAULT_BUFSIZE class name and minimum value; cmpfiles/__module__; cmp/__name__/__module__; dircmp/__name__/__module__/__bases__."
    - "filecmp_extra4.zspec.zsdl covers: function_qualnames table (cmp/cmpfiles/clear_cache); dircmp_method_qualnames table (report/report_full_closure/report_partial_closure); DEFAULT_IGNORES is_list and minimum_length; dircmp.report/__report_full_closure module."
    - "This spec adds new axes: __name__ length checks for cmp, cmpfiles, dircmp, and clear_cache; __name__ first-character checks; __name__ is-str checks; dircmp.__name__.__len__ and clear_cache.__name__.__len__."
    - "filecmp.cmp.__name__ has length 3 ('cmp')."
    - "filecmp.cmpfiles.__name__ has length 8 ('cmpfiles')."
    - "filecmp.dircmp.__name__ has length 6 ('dircmp')."
    - "filecmp.clear_cache.__name__ has length 11 ('clear_cache')."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ length checks — cmp, cmpfiles, dircmp, clear_cache
# All prior specs verify __name__ via equality; none verify the length of
# the __name__ string. This is a genuinely new axis.
# ---------------------------------------------------------------------------

table filecmp_extra5.name_lengths:
  description: "__name__ attribute lengths for cmp, cmpfiles, dircmp, and clear_cache"
  kind: python_call_eq
  category: name_lengths
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [cmp,         cmp.__name__.__len__,         [], 3]
    - [cmpfiles,    cmpfiles.__name__.__len__,     [], 8]
    - [dircmp,      dircmp.__name__.__len__,       [], 6]
    - [clear_cache, clear_cache.__name__.__len__,  [], 11]

# ---------------------------------------------------------------------------
# __name__ is-str checks — cmp, cmpfiles, dircmp, clear_cache
# No prior filecmp spec verifies that __name__ is a str object.
# ---------------------------------------------------------------------------

table filecmp_extra5.name_is_str:
  description: "__name__ attributes are str objects for filecmp public symbols"
  kind: python_call_eq
  category: name_types
  id_prefix: namestr

  columns: [id, function, args, expected]
  rows:
    - [cmp,         cmp.__name__.__class__.__name__.__eq__,         ["str"], true]
    - [cmpfiles,    cmpfiles.__name__.__class__.__name__.__eq__,    ["str"], true]
    - [dircmp,      dircmp.__name__.__class__.__name__.__eq__,      ["str"], true]
    - [clear_cache, clear_cache.__name__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# __name__ first-character checks
# Distinct axis: verifies the first character of each __name__ string.
# cmp -> 'c', cmpfiles -> 'c', dircmp -> 'd', clear_cache -> 'c'.
# Not covered in any prior filecmp spec.
# ---------------------------------------------------------------------------

invariant filecmp_extra5.cmp.name_starts_c:
  description: "filecmp.cmp.__name__[0] == 'c' — 'cmp' begins with 'c'"
  category: name_prefix
  kind: python_call_eq
  function: cmp.__name__.__getitem__
  args: [0]
  expected: "c"

invariant filecmp_extra5.cmpfiles.name_starts_c:
  description: "filecmp.cmpfiles.__name__[0] == 'c' — 'cmpfiles' begins with 'c'"
  category: name_prefix
  kind: python_call_eq
  function: cmpfiles.__name__.__getitem__
  args: [0]
  expected: "c"

invariant filecmp_extra5.dircmp.name_starts_d:
  description: "filecmp.dircmp.__name__[0] == 'd' — 'dircmp' begins with 'd'"
  category: name_prefix
  kind: python_call_eq
  function: dircmp.__name__.__getitem__
  args: [0]
  expected: "d"

invariant filecmp_extra5.clear_cache.name_starts_c:
  description: "filecmp.clear_cache.__name__[0] == 'c' — 'clear_cache' begins with 'c'"
  category: name_prefix
  kind: python_call_eq
  function: clear_cache.__name__.__getitem__
  args: [0]
  expected: "c"
