spec: contextlib_extra11
version: ">=3.10"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra10.zspec.zsdl and contextlib_suppress.zspec.zsdl."
    - "contextlib_extra10 covers: MRO lengths for suppress/closing/ExitStack/AsyncExitStack/ContextDecorator; AsyncExitStack.__abstractmethods__.__len__ == 0; aclosing name/module/base; AsyncContextDecorator name/module/base."
    - "NOT yet covered: MRO lengths for nullcontext, aclosing, redirect_stdout, redirect_stderr, AsyncContextDecorator."
    - "NOT yet covered: suppress/closing/nullcontext/aclosing/redirect_stdout/redirect_stderr __abstractmethods__.__len__ == 0."
    - "NOT yet covered: redirect_stdout.__name__ and redirect_stderr.__name__."
    - "NOT yet covered: redirect_stdout.__qualname__ and redirect_stderr.__qualname__."
    - "contextlib.nullcontext.__mro__.__len__() == 5 — [nullcontext, AbstractContextManager, AbstractAsyncContextManager, ABC, object]."
    - "contextlib.aclosing.__mro__.__len__() == 4 — [aclosing, AbstractAsyncContextManager, ABC, object]."
    - "contextlib.redirect_stdout.__mro__.__len__() == 5 — [redirect_stdout, _RedirectStream, AbstractContextManager, ABC, object]."
    - "contextlib.redirect_stderr.__mro__.__len__() == 5 — [redirect_stderr, _RedirectStream, AbstractContextManager, ABC, object]."
    - "contextlib.AsyncContextDecorator.__mro__.__len__() == 2 — [AsyncContextDecorator, object]."
    - "contextlib.suppress.__abstractmethods__.__len__() == 0 — suppress is fully concrete."
    - "contextlib.closing.__abstractmethods__.__len__() == 0 — closing is fully concrete."
    - "contextlib.nullcontext.__abstractmethods__.__len__() == 0 — nullcontext is fully concrete."
    - "contextlib.aclosing.__abstractmethods__.__len__() == 0 — aclosing is fully concrete."
    - "contextlib.redirect_stdout.__qualname__ == 'redirect_stdout'."
    - "contextlib.redirect_stderr.__qualname__ == 'redirect_stderr'."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# MRO length — nullcontext, aclosing, redirect_stdout, redirect_stderr,
# AsyncContextDecorator
#
# contextlib_extra10 verified MRO lengths for suppress/closing/ExitStack/
# AsyncExitStack/ContextDecorator. These five classes remain uncovered.
# nullcontext: [nullcontext, AbstractContextManager, AbstractAsyncContextManager, ABC, object] = 5
# aclosing: [aclosing, AbstractAsyncContextManager, ABC, object] = 4
# redirect_stdout/_stderr: [cls, _RedirectStream, AbstractContextManager, ABC, object] = 5
# AsyncContextDecorator: [AsyncContextDecorator, object] = 2
# ---------------------------------------------------------------------------

invariant contextlib_extra11.nullcontext.mro_len:
  description: "contextlib.nullcontext.__mro__.__len__() == 5 — [nullcontext, AbstractContextManager, AbstractAsyncContextManager, ABC, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: nullcontext.__mro__.__len__
  args: []
  expected: 5

invariant contextlib_extra11.aclosing.mro_len:
  description: "contextlib.aclosing.__mro__.__len__() == 4 — [aclosing, AbstractAsyncContextManager, ABC, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: aclosing.__mro__.__len__
  args: []
  expected: 4

invariant contextlib_extra11.redirect_stdout.mro_len:
  description: "contextlib.redirect_stdout.__mro__.__len__() == 5 — [redirect_stdout, _RedirectStream, AbstractContextManager, ABC, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: redirect_stdout.__mro__.__len__
  args: []
  expected: 5

invariant contextlib_extra11.redirect_stderr.mro_len:
  description: "contextlib.redirect_stderr.__mro__.__len__() == 5 — [redirect_stderr, _RedirectStream, AbstractContextManager, ABC, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: redirect_stderr.__mro__.__len__
  args: []
  expected: 5

invariant contextlib_extra11.AsyncContextDecorator.mro_len:
  description: "contextlib.AsyncContextDecorator.__mro__.__len__() == 2 — [AsyncContextDecorator, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: AsyncContextDecorator.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# __abstractmethods__.__len__ == 0 for fully concrete classes
#
# contextlib_extra9 covers AbstractContextManager/AbstractAsyncContextManager
# (both 1) and ExitStack (0). contextlib_extra10 adds AsyncExitStack (0).
# Not yet covered: suppress, closing, nullcontext, aclosing, redirect_stdout,
# redirect_stderr — all fully concrete with no abstract methods.
# ---------------------------------------------------------------------------

table contextlib_extra11.abstractmethods_empty:
  kind: python_call_eq
  category: abstract_methods
  id_prefix: absmeth

  columns: [id, function, args, expected]
  rows:
    - [suppress,         suppress.__abstractmethods__.__len__,         [], 0]
    - [closing,          closing.__abstractmethods__.__len__,          [], 0]
    - [nullcontext,      nullcontext.__abstractmethods__.__len__,      [], 0]
    - [aclosing,         aclosing.__abstractmethods__.__len__,         [], 0]
    - [redirect_stdout,  redirect_stdout.__abstractmethods__.__len__,  [], 0]
    - [redirect_stderr,  redirect_stderr.__abstractmethods__.__len__,  [], 0]

# ---------------------------------------------------------------------------
# redirect_stdout and redirect_stderr — __qualname__ and __name__
#
# contextlib_extra8 covers redirect_stdout/__module__ and redirect_stderr/__module__
# as well as base class qualname. No prior spec checks __qualname__ or __name__
# for redirect_stdout or redirect_stderr directly.
# ---------------------------------------------------------------------------

invariant contextlib_extra11.redirect_stdout.qualname:
  description: "contextlib.redirect_stdout.__qualname__ == 'redirect_stdout'"
  category: qualnames
  kind: python_call_eq
  function: redirect_stdout.__qualname__.__eq__
  args: ["redirect_stdout"]
  expected: true

invariant contextlib_extra11.redirect_stderr.qualname:
  description: "contextlib.redirect_stderr.__qualname__ == 'redirect_stderr'"
  category: qualnames
  kind: python_call_eq
  function: redirect_stderr.__qualname__.__eq__
  args: ["redirect_stderr"]
  expected: true

invariant contextlib_extra11.redirect_stdout.name:
  description: "contextlib.redirect_stdout.__name__ == 'redirect_stdout'"
  category: class_names
  kind: python_call_eq
  function: redirect_stdout.__name__.__eq__
  args: ["redirect_stdout"]
  expected: true

invariant contextlib_extra11.redirect_stderr.name:
  description: "contextlib.redirect_stderr.__name__ == 'redirect_stderr'"
  category: class_names
  kind: python_call_eq
  function: redirect_stderr.__name__.__eq__
  args: ["redirect_stderr"]
  expected: true
