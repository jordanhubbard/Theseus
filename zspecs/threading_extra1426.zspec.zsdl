spec: threading_extra1426
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 542 (_extra1426): focuses on __format__ and __dir__ method type and dict-presence checks for threading module classes."
    - "threading.Thread, threading.Semaphore, threading.Barrier, threading.Condition, threading.Event are pure Python classes in Lib/threading.py."
    - "threading.Lock is a class alias for _thread.lock (a C extension type from _threadmodule.c)."
    - "threading.Thread.__format__.__class__.__name__ == 'method_descriptor' — inherits __format__ from object. Verified Python 3.14.3."
    - "threading.Lock.__format__.__class__.__name__ == 'method_descriptor' — _thread.lock inherits __format__ from object. Verified Python 3.14.3."
    - "threading.Event.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "threading.Semaphore.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "threading.Barrier.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "threading.Condition.__format__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3."
    - "None of Thread, Lock, Event, Semaphore, Barrier, Condition define '__format__' or '__dir__' in their own __dict__. Verified Python 3.14.3."
    - "All __format__.__doc__ and __dir__.__doc__ values are str objects for these classes. Verified Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading class __format__ method type checks
#
# Wave 542 theme: __format__.__class__.__name__ checks for threading classes.
# Thread, Lock, Event, Semaphore, Barrier, Condition all yield 'method_descriptor'
# for __format__ (inherited from object through the class hierarchy).
# ---------------------------------------------------------------------------

table threading_extra1426.format_class_name:
  description: "threading classes: __format__.__class__.__name__ == 'method_descriptor' for Thread, Lock, Event, Semaphore, Barrier, Condition; wave 542; new to extra1426"
  kind: python_call_eq
  category: format_class_name
  id_prefix: th1426fc

  columns: [id, function, args, expected, description]
  rows:
    - [th1426fc001,
       "threading.Thread.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Thread.__format__.__class__.__name__.__eq__('method_descriptor') == True — Thread is a Python class; __format__ inherited from object as method_descriptor; new to extra1426"]
    - [th1426fc002,
       "threading.Lock.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.__format__.__class__.__name__.__eq__('method_descriptor') == True — Lock is _thread.lock C extension type; __format__ inherited from object as method_descriptor; new to extra1426"]
    - [th1426fc003,
       "threading.Event.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Event.__format__.__class__.__name__.__eq__('method_descriptor') == True — Event is a Python class; __format__ inherited from object as method_descriptor; new to extra1426"]
    - [th1426fc004,
       "threading.Semaphore.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Semaphore.__format__.__class__.__name__.__eq__('method_descriptor') == True — Semaphore is a Python class; __format__ inherited from object as method_descriptor; new to extra1426"]
    - [th1426fc005,
       "threading.Barrier.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Barrier.__format__.__class__.__name__.__eq__('method_descriptor') == True — Barrier is a Python class; __format__ inherited from object as method_descriptor; new to extra1426"]
    - [th1426fc006,
       "threading.Condition.__format__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Condition.__format__.__class__.__name__.__eq__('method_descriptor') == True — Condition is a Python class; __format__ inherited from object as method_descriptor; new to extra1426"]
    - [th1426fc007,
       "threading.Thread.__format__.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.Thread.__format__.__doc__.__class__.__name__.__eq__('str') == True — __format__ docstring is a str object; new to extra1426"]
    - [th1426fc008,
       "threading.Lock.__format__.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.Lock.__format__.__doc__.__class__.__name__.__eq__('str') == True — __format__ docstring is a str object; new to extra1426"]

# ---------------------------------------------------------------------------
# Table 2: threading class __format__ and __dir__ absence from own __dict__
#
# Wave 542 theme: '__format__' and '__dir__' not in own __dict__ for threading
# classes. Thread, Lock, Event, Semaphore, Barrier, Condition all inherit both
# methods from object without overriding them.
# ---------------------------------------------------------------------------

table threading_extra1426.format_dir_dict_membership:
  description: "threading classes: '__format__' and '__dir__' not in own __dict__ for Thread, Lock, Event, Semaphore, Barrier, Condition; wave 542; new to extra1426"
  kind: python_call_eq
  category: format_dir_dict_membership
  id_prefix: th1426dm

  columns: [id, function, args, expected, description]
  rows:
    - [th1426dm001,
       "threading.Thread.__dict__.__contains__",
       ["__format__"],
       false,
       "threading.Thread.__dict__.__contains__('__format__') == False — Thread does not define __format__ in its own class __dict__; inherited from object; new to extra1426"]
    - [th1426dm002,
       "threading.Lock.__dict__.__contains__",
       ["__format__"],
       false,
       "threading.Lock.__dict__.__contains__('__format__') == False — Lock (_thread.lock) does not define __format__ in its own class __dict__; inherited from object; new to extra1426"]
    - [th1426dm003,
       "threading.Event.__dict__.__contains__",
       ["__format__"],
       false,
       "threading.Event.__dict__.__contains__('__format__') == False — Event does not define __format__ in its own class __dict__; inherited from object; new to extra1426"]
    - [th1426dm004,
       "threading.Semaphore.__dict__.__contains__",
       ["__format__"],
       false,
       "threading.Semaphore.__dict__.__contains__('__format__') == False — Semaphore does not define __format__ in its own class __dict__; inherited from object; new to extra1426"]
    - [th1426dm005,
       "threading.Thread.__dict__.__contains__",
       ["__dir__"],
       false,
       "threading.Thread.__dict__.__contains__('__dir__') == False — Thread does not define __dir__ in its own class __dict__; inherited from object; new to extra1426"]
    - [th1426dm006,
       "threading.Lock.__dict__.__contains__",
       ["__dir__"],
       false,
       "threading.Lock.__dict__.__contains__('__dir__') == False — Lock does not define __dir__ in its own class __dict__; inherited from object; new to extra1426"]
    - [th1426dm007,
       "threading.Barrier.__dict__.__contains__",
       ["__dir__"],
       false,
       "threading.Barrier.__dict__.__contains__('__dir__') == False — Barrier does not define __dir__ in its own class __dict__; inherited from object; new to extra1426"]
    - [th1426dm008,
       "threading.Condition.__dict__.__contains__",
       ["__dir__"],
       false,
       "threading.Condition.__dict__.__contains__('__dir__') == False — Condition does not define __dir__ in its own class __dict__; inherited from object; new to extra1426"]

# ---------------------------------------------------------------------------
# Table 3: threading class __dir__ method type checks and doc type
#
# Wave 542 theme: __dir__.__class__.__name__ == 'method_descriptor' for all
# threading classes; __dir__.__doc__.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

table threading_extra1426.dir_class_name:
  description: "threading classes: __dir__.__class__.__name__ == 'method_descriptor' and __dir__.__doc__.__class__.__name__ == 'str' for Thread, Lock, Event, Semaphore, Barrier, Condition; wave 542; new to extra1426"
  kind: python_call_eq
  category: dir_class_name
  id_prefix: th1426dc

  columns: [id, function, args, expected, description]
  rows:
    - [th1426dc001,
       "threading.Thread.__dir__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Thread.__dir__.__class__.__name__.__eq__('method_descriptor') == True — Thread inherits __dir__ from object as method_descriptor; new to extra1426"]
    - [th1426dc002,
       "threading.Lock.__dir__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.__dir__.__class__.__name__.__eq__('method_descriptor') == True — Lock inherits __dir__ from object as method_descriptor; new to extra1426"]
    - [th1426dc003,
       "threading.Event.__dir__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Event.__dir__.__class__.__name__.__eq__('method_descriptor') == True — Event inherits __dir__ from object as method_descriptor; new to extra1426"]
    - [th1426dc004,
       "threading.Semaphore.__dir__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Semaphore.__dir__.__class__.__name__.__eq__('method_descriptor') == True — Semaphore inherits __dir__ from object as method_descriptor; new to extra1426"]
    - [th1426dc005,
       "threading.Barrier.__dir__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Barrier.__dir__.__class__.__name__.__eq__('method_descriptor') == True — Barrier inherits __dir__ from object as method_descriptor; new to extra1426"]
    - [th1426dc006,
       "threading.Condition.__dir__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Condition.__dir__.__class__.__name__.__eq__('method_descriptor') == True — Condition inherits __dir__ from object as method_descriptor; new to extra1426"]
    - [th1426dc007,
       "threading.Barrier.__dir__.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.Barrier.__dir__.__doc__.__class__.__name__.__eq__('str') == True — __dir__ docstring is a str object; new to extra1426"]
    - [th1426dc008,
       "threading.Condition.__dir__.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "threading.Condition.__dir__.__doc__.__class__.__name__.__eq__('str') == True — __dir__ docstring is a str object; new to extra1426"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1426
# ---------------------------------------------------------------------------

invariant threading_extra1426.Thread_format_is_method_descriptor:
  description: "threading.Thread.__format__.__class__.__name__ == 'method_descriptor' — __format__ inherited from object; wave 542; new to extra1426"
  kind: python_call_eq
  function: threading.Thread.__format__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant threading_extra1426.Thread_format_not_in_dict:
  description: "'__format__' not in threading.Thread.__dict__ — Thread does not override __format__; wave 542; new to extra1426"
  kind: python_call_eq
  function: threading.Thread.__dict__.__contains__
  args: ["__format__"]
  expected: false

invariant threading_extra1426.Lock_dir_is_method_descriptor:
  description: "threading.Lock.__dir__.__class__.__name__ == 'method_descriptor' — __dir__ inherited from object; wave 542; new to extra1426"
  kind: python_call_eq
  function: threading.Lock.__dir__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant threading_extra1426.Semaphore_dir_not_in_dict:
  description: "'__dir__' not in threading.Semaphore.__dict__ — Semaphore does not override __dir__; wave 542; new to extra1426"
  kind: python_call_eq
  function: threading.Semaphore.__dict__.__contains__
  args: ["__dir__"]
  expected: false
