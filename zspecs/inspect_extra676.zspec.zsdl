spec: inspect_extra676
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from: ["CPython source code"]
  notes: ["Covers Traceback, FrameInfo, ModuleInfo namedtuple identity and related inspect types"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra676.traceback_identity:
  description: "Identity checks on inspect.Traceback namedtuple type"
  kind: python_call_eq
  category: namedtuple_identity
  id_prefix: in676tr
  columns: [id, function, args, expected]
  rows:
    - [in676tr001, inspect.Traceback.__class__.__name__.__eq__, ["type"], true]
    - [in676tr002, inspect.Traceback.__qualname__.__eq__, ["Traceback"], true]
    - [in676tr003, inspect.Traceback.__module__.__eq__, ["inspect"], true]

table inspect_extra676.frameinfo_identity:
  description: "Identity checks on inspect.FrameInfo namedtuple type"
  kind: python_call_eq
  category: namedtuple_identity
  id_prefix: in676fi
  columns: [id, function, args, expected]
  rows:
    - [in676fi001, inspect.FrameInfo.__class__.__name__.__eq__, ["type"], true]
    - [in676fi002, inspect.FrameInfo.__qualname__.__eq__, ["FrameInfo"], true]
    - [in676fi003, inspect.FrameInfo.__module__.__eq__, ["inspect"], true]

table inspect_extra676.misc_type_identity:
  description: "Identity checks on miscellaneous inspect types and exceptions"
  kind: python_call_eq
  category: type_identity
  id_prefix: in676mi
  columns: [id, function, args, expected]
  rows:
    - [in676mi001, inspect.ModuleInfo.__class__.__name__.__eq__, ["type"], true]
    - [in676mi002, inspect.ModuleInfo.__qualname__.__eq__, ["ModuleInfo"], true]
    - [in676mi003, inspect.ClassFoundException.__qualname__.__eq__, ["ClassFoundException"], true]
    - [in676mi004, inspect.EndOfBlock.__qualname__.__eq__, ["EndOfBlock"], true]
    - [in676mi005, inspect.Attribute.__qualname__.__eq__, ["Attribute"], true]
    - [in676mi006, inspect.BlockFinder.__qualname__.__eq__, ["BlockFinder"], true]
