  columns: [id, function, args, expected]
  rows:
    - ["it3556001", operator.contains, [itertools.chain.__dict__,                         "__reduce__"], false]
    - ["it3556002", operator.contains, [itertools.cycle.__dict__,                         "__reduce__"], false]
