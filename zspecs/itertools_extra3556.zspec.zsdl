  notes:
    - "Wave 684 (it3556): __reduce__, __reduce_ex__, __getstate__ dict-presence checks for itertools types."
    - "All values false — itertools iterator types do not define __reduce__, __reduce_ex__, or __getstate__ in their own __dict__."
    - "itertools.pairwise requires Python >= 3.10."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __reduce__ dict-presence — operator.contains(Cls.__dict__, '__reduce__')
# ---------------------------------------------------------------------------

table it3556.reduce:
  description: "itertools types __reduce__ dict-presence checks; wave 684"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
