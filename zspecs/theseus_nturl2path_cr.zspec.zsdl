spec: theseus_nturl2path_cr
version: ">=3.0"
backend: python_cleanroom(theseus_nturl2path_cr)
blocks: nturl2path

docs: https://docs.python.org/3/library/urllib.request.html

provenance:
  derived_from:
    - "CPython docs"
  not_derived_from:
    - "CPython source: Lib/nturl2path.py"
  notes:
    - "Clean-room nturl2path module. Do NOT import nturl2path."

error_model: python_exceptions

invariant theseus_nturl2path_cr.nturl2_url2pathname:
  description: "url2pathname() converts URL path to NT path"
  category: behavior
  kind: python_call_eq
  function: nturl2_url2pathname
  args: []
  expected: true

invariant theseus_nturl2path_cr.nturl2_pathname2url:
  description: "pathname2url() converts NT path to URL"
  category: behavior
  kind: python_call_eq
  function: nturl2_pathname2url
  args: []
  expected: true

invariant theseus_nturl2path_cr.nturl2_roundtrip:
  description: "pathname2url and url2pathname are inverses"
  category: behavior
  kind: python_call_eq
  function: nturl2_roundtrip
  args: []
  expected: true
