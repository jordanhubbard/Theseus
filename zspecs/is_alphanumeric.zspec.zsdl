spec: is_alphanumeric
version: ">=1.0.0"
backend: node(is-alphanumeric)

docs: https://www.npmjs.com/package/is-alphanumeric

provenance:
  derived_from:
    - "is-alphanumeric README — https://www.npmjs.com/package/is-alphanumeric"
    - "Test vectors verified with is-alphanumeric via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "is-alphanumeric source"
  notes:
    - "is-alphanumeric is an npm package. Install: npm install is-alphanumeric"
    - "Returns true if all characters in the string are alphanumeric (a-z, A-Z, 0-9)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_alphanumeric.check:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: isalnum

  columns: [id, args, expected]
  rows:
    - [letters,  ["abc"],         true]
    - [mixed,    ["az5"],         true]
    - [spaces,   ["hello world"], false]
    - [special,  ["!"],           false]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:22:50Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
