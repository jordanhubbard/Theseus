spec: concurrent_futures_extra247
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#module-functions — as_completed and wait functions"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.wait — wait condition constants"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py (internal implementation)"
  notes:
    - "concurrent.futures.as_completed.__name__ == 'as_completed' (len=12); __module__ == 'concurrent.futures._base' (len=24); __class__.__name__ == 'function' (len=8)."
    - "concurrent.futures.wait.__name__ == 'wait' (len=4); __module__ == 'concurrent.futures._base' (len=24); __class__.__name__ == 'function' (len=8)."
    - "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED' (len=15); it is a plain str, not an enum — type(FIRST_COMPLETED).__name__ == 'str'."
    - "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION' (len=15); same length as FIRST_COMPLETED."
    - "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED' (len=13); two characters shorter than FIRST_COMPLETED and FIRST_EXCEPTION."
    - "FIRST_COMPLETED.__class__.__module__ == 'builtins' (len=8) — str is a built-in type."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures module-level function identity — as_completed
#
# as_completed.__name__ == 'as_completed' (len=12)
# as_completed.__module__ == 'concurrent.futures._base' (len=24)
# as_completed.__class__.__name__ == 'function' (len=8)
# ---------------------------------------------------------------------------

table concurrent_futures_extra247.as_completed_identity:
  description: "concurrent.futures.as_completed function identity — as_completed.__name__.__eq__('as_completed')==True (len=12); as_completed.__module__.__eq__('concurrent.futures._base')==True (len=24; the function is defined in the private _base submodule and re-exported from the package); as_completed.__class__.__name__.__eq__('function')==True (len=8; it is a plain Python function, not a builtin or generator); all verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cf247ac

  columns: [id, function, args, expected, description]
  rows:
    - [ac_name_eq,   as_completed.__name__.__eq__,                ["as_completed"],               true, "concurrent.futures.as_completed.__name__ == 'as_completed'; verified with Python 3.14.3"]
    - [ac_name_len,  as_completed.__name__.__len__,               [],                             12,   "concurrent.futures.as_completed.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [ac_mod_eq,    as_completed.__module__.__eq__,              ["concurrent.futures._base"],   true, "concurrent.futures.as_completed.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [ac_mod_len,   as_completed.__module__.__len__,             [],                             24,   "concurrent.futures.as_completed.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [ac_cls_eq,    as_completed.__class__.__name__.__eq__,      ["function"],                   true, "concurrent.futures.as_completed.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [ac_cls_len,   as_completed.__class__.__name__.__len__,     [],                             8,    "concurrent.futures.as_completed.__class__.__name__.__len__() == 8; verified with Python 3.14.3"]

