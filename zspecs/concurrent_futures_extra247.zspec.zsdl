    - [wt_name_len,  wait.__name__.__len__,              [],                              4,    "concurrent.futures.wait.__name__.__len__() == 4; verified with Python 3.14.3"]
    - [wt_mod_eq,    wait.__module__.__eq__,             ["concurrent.futures._base"],    true, "concurrent.futures.wait.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
