spec: uuid_by_string
version: ">=4.0.0"
backend: node(uuid-by-string)

docs: https://www.npmjs.com/package/uuid-by-string

provenance:
  derived_from:
    - "uuid-by-string README — https://www.npmjs.com/package/uuid-by-string"
    - "Test vectors verified with uuid-by-string via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "uuid-by-string source"
  notes:
    - "uuid-by-string is an npm package. Install: npm install uuid-by-string"
    - "uuidByString(str) deterministically derives a UUID v5 from the input string."
    - "The same input always produces the same UUID."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns deterministic UUID v5 string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table uuid_by_string.uuidByString:
  kind: node_module_call_eq
  function: ~
  category: generate
  id_prefix: ubs

  columns: [id, args, expected]
  rows:
    - [hello, ["hello"], "aaf4c61d-dcc5-58a2-9abe-de0f3b482cd9"]
    - [world, ["world"], "7c211433-f020-5159-b741-e6ff5a8ea347"]
    - [test,  ["test"],  "a94a8fe5-ccb1-5ba6-9c4c-0873d391e987"]
