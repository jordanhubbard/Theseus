spec: re_extra12
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra11.zspec.zsdl."
    - "re_extra11 covers: compile.groupindex empty/named; compile.groups==2; match.string, match.pos, match.endpos, match.re class name; search.lastindex None; sub count=1; split maxsplit=2."
    - "re_extra10 covers: RegexFlag.LOCALE/UNICODE values; LOCALE/UNICODE class names; purge/escape/subn qualnames; escape('a.b'); compile default flags==32; findall digit length 3; subn count 3."
    - "re_extra8 covers: fullmatch/match/search/sub/split/findall/finditer/compile __qualname__."
    - "re_extra3 covers: re.fullmatch('a+', 'aaa') returns a Match object."
    - "re_patterns covers: fullmatch(r'\\d{3}', '123') group(0)=='123'; fullmatch(r'\\d{3}', '1234')==None."
    - "No prior spec covers re.fullmatch(r'\\d+', '123') returning a non-None result (not None)."
    - "No prior spec covers re.fullmatch(r'\\d+', '12x') returning None (partial digit string fails full match)."
    - "No prior spec covers re.escape('hello') == 'hello' (a plain word with no metacharacters is unchanged)."
    - "No prior spec covers re.IGNORECASE | re.MULTILINE combined value (2 | 8 == 10) as an integer."
    - "No prior spec covers re.search(r'(?P<name>\\w+)', 'hello').group('name') == 'hello' (named-group extraction by name)."
    - "No prior spec covers re.search(r'(\\d+)', 'abc123').group(1) == '123' (numbered capture group in search)."
    - "No prior spec covers re.sub(r'\\s+', ' ', 'a  b  c') == 'a b c' (collapsing whitespace runs)."
    - "No prior spec covers re.split(r'\\s+', 'a b c') == ['a', 'b', 'c'] with single-space separators."
    - "re.fullmatch(r'\\d+', '123') is not None — the whole string consists of digits."
    - "re.fullmatch(r'\\d+', '12x') is None — the trailing 'x' prevents a full match."
    - "re.escape('hello') == 'hello' — alphanumeric strings are returned unchanged."
    - "re.IGNORECASE | re.MULTILINE == 10 — the combined flag integer value."
    - "re.search(r'(?P<name>\\w+)', 'hello').group('name') == 'hello'."
    - "re.search(r'(\\d+)', 'abc123').group(1) == '123'."
    - "re.sub(r'\\s+', ' ', 'a  b  c') == 'a b c'."
    - "re.split(r'\\s+', 'a b c') == ['a', 'b', 'c'] — splits on single spaces."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.fullmatch — new pattern and subject variants
#
# re_patterns covers fullmatch(r'\d{3}', '123') and fullmatch(r'\d{3}', '1234').
# re_extra3 covers fullmatch('a+', 'aaa') returning a Match.
# No prior spec uses the pattern r'\d+' (greedy digit match) for fullmatch.
# This tests fullmatch with a different pattern on a purely numeric string
# (matches) and on a mixed string (fails).
# ---------------------------------------------------------------------------

invariant re_extra12.fullmatch.digits_match_class:
  description: "re.fullmatch(r'\\d+', '123').__class__.__name__ == 'Match' — whole digit string fully matches"
  category: fullmatch
  kind: python_call_eq
  function: fullmatch
  args: ["\\d+", "123"]
  method: __class__.__name__.__eq__
  method_args: ["Match"]
  expected: true

invariant re_extra12.fullmatch.mixed_string_is_none:
  description: "re.fullmatch(r'\\d+', '12x') is None — trailing non-digit prevents full match"
  category: fullmatch
  kind: python_call_eq
  function: fullmatch
  args: ["\\d+", "12x"]
  method: __eq__
  method_args: [null]
  expected: true

# ---------------------------------------------------------------------------
# re.escape — plain word leaves string unchanged
#
# re_extra2 covers escape('a.b+c') == 'a\\.b\\+c'.
# re_extra10 covers escape('a.b') == 'a\\.b'.
# No prior spec checks that escape('hello') == 'hello' (no metacharacters).
# Since Python 3.7, re.escape only escapes characters that have regex meaning.
# ---------------------------------------------------------------------------

invariant re_extra12.escape.plain_word:
  description: "re.escape('hello') == 'hello' — a plain alphanumeric word is unchanged by escape"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["hello"]
  expected: "hello"

# ---------------------------------------------------------------------------
# re.IGNORECASE | re.MULTILINE — combined flag integer value
#
# re_extra7 covers the individual .value attributes (IGNORECASE==2, MULTILINE==8).
# No prior spec checks the bitwise-OR of two flags.
# IGNORECASE (2) | MULTILINE (8) == 10; the result is a RegexFlag integer.
# We test the combined value using the __or__ method and check the result
# against the expected integer 10.
# ---------------------------------------------------------------------------

invariant re_extra12.flags.ignorecase_or_multiline_value:
  description: "re.IGNORECASE | re.MULTILINE == 10 — combined flag integer value (2 | 8)"
  category: flags
  kind: python_call_eq
  function: IGNORECASE.__or__
  args: [8]
  expected: 10

# ---------------------------------------------------------------------------
# re.search — named group extraction
#
# re.zspec covers named groups via re.sub backreferences only.
# re_patterns notes that named groups work via .group('name') but never
# tests it as an actual invariant.
# No prior spec tests re.search(r'(?P<name>\w+)', 'hello').group('name').
# ---------------------------------------------------------------------------

invariant re_extra12.search.named_group:
  description: "re.search(r'(?P<name>\\w+)', 'hello').group('name') == 'hello'"
  category: search
  kind: python_call_eq
  function: search
  args: ["(?P<name>\\w+)", "hello"]
  method: group
  method_args: ["name"]
  expected: "hello"

# ---------------------------------------------------------------------------
# re.search — numbered capture group
#
# re_patterns covers match().group(1) and match().group(2) via re.match.
# re_extra covers search().group(0).
# No prior spec covers search().group(1) for a numbered capture group.
# ---------------------------------------------------------------------------

invariant re_extra12.search.capture_group_one:
  description: "re.search(r'(\\d+)', 'abc123').group(1) == '123' — first capture group"
  category: search
  kind: python_call_eq
  function: search
  args: ["(\\d+)", "abc123"]
  method: group
  method_args: [1]
  expected: "123"

# ---------------------------------------------------------------------------
# re.sub — whitespace collapsing
#
# re.zspec and re_extra5 cover sub() with character-level patterns.
# re_extra11 covers sub(r'a', 'b', 'aaa', 1) with count argument.
# No prior spec covers sub(r'\s+', ' ', ...) (collapsing whitespace runs).
# re.sub(r'\s+', ' ', 'a  b  c') == 'a b c'.
# ---------------------------------------------------------------------------

invariant re_extra12.sub.collapse_whitespace:
  description: "re.sub(r'\\s+', ' ', 'a  b  c') == 'a b c' — runs of whitespace collapsed to one space"
  category: sub
  kind: python_call_eq
  function: sub
  args: ["\\s+", " ", "a  b  c"]
  expected: "a b c"

# ---------------------------------------------------------------------------
# re.split — whitespace separator, single spaces
#
# re_extra covers split(r'\s+', 'a b  c') == ['a', 'b', 'c'] (double space).
# re_extra11 covers split(r',', 'a,b,c,d', 2).
# re_extra5 covers split(',', 'a,b,c') with a literal comma.
# No prior spec covers split(r'\s+', 'a b c') with single spaces only
# (distinct subject string from re_extra).
# ---------------------------------------------------------------------------

invariant re_extra12.split.single_spaces:
  description: "re.split(r'\\s+', 'a b c') == ['a', 'b', 'c'] — split on single whitespace chars"
  category: split
  kind: python_call_eq
  function: split
  args: ["\\s+", "a b c"]
  expected: ["a", "b", "c"]

# ---------------------------------------------------------------------------
# re.fullmatch — return-value class for failing match
#
# No prior spec checks __class__.__name__ for a None result from fullmatch
# (re_patterns uses __eq__(null) for that). This tests the truthiness of a
# successful fullmatch result via __bool__.
# ---------------------------------------------------------------------------

invariant re_extra12.fullmatch.match_is_truthy:
  description: "bool(re.fullmatch(r'\\d+', '123')) == True — a successful fullmatch is truthy"
  category: fullmatch
  kind: python_call_eq
  function: fullmatch
  args: ["\\d+", "123"]
  method: __bool__
  expected: true

# ---------------------------------------------------------------------------
# re.search — named group: lastindex is set for a capture group
#
# re_extra11 covers search(r'\d+', 'abc123').lastindex is None (no capture groups).
# No prior spec covers lastindex when there IS a capture group.
# search(r'(\d+)', 'abc123').lastindex == 1 after matching one capture group.
# ---------------------------------------------------------------------------

invariant re_extra12.search.lastindex_one:
  description: "re.search(r'(\\d+)', 'abc123').lastindex == 1 — one capture group sets lastindex to 1"
  category: search
  kind: python_call_eq
  function: search
  args: ["(\\d+)", "abc123"]
  method: lastindex.__eq__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# re.sub — return type
#
# No prior spec explicitly checks that re.sub() returns a str.
# re.sub(r'\s+', ' ', 'a  b  c').__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

invariant re_extra12.sub.return_type:
  description: "re.sub(r'\\s+', ' ', 'a  b  c').__class__.__name__ == 'str' — sub always returns a str"
  category: sub
  kind: python_call_eq
  function: sub
  args: ["\\s+", " ", "a  b  c"]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# re.split — return type and length
#
# No prior spec checks that re.split() returns a list (__class__.__name__).
# re.split(r'\s+', 'a b c') returns a 3-element list.
# ---------------------------------------------------------------------------

invariant re_extra12.split.returns_list:
  description: "re.split(r'\\s+', 'a b c').__class__.__name__ == 'list' — split always returns a list"
  category: split
  kind: python_call_eq
  function: split
  args: ["\\s+", "a b c"]
  method: __class__.__name__.__eq__
  method_args: ["list"]
  expected: true

invariant re_extra12.split.length_three:
  description: "len(re.split(r'\\s+', 'a b c')) == 3 — splitting 'a b c' on whitespace yields 3 parts"
  category: split
  kind: python_call_eq
  function: split
  args: ["\\s+", "a b c"]
  method: __len__
  expected: 3
