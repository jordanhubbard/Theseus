spec: asyncio_extra1561
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio tasks and coroutines"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Wave 551 (_extra1561): numeric type conversion protocol dict-presence checks for asyncio classes."
    - "asyncio classes (Queue, Task, Future, Lock, Event, Semaphore, Barrier, TaskGroup) are concurrency primitives, not numeric types."
    - "None of these classes define __bool__, __int__, __float__, __complex__, __index__, __trunc__, __floor__, __ceil__, or __round__ in their own __dict__."
    - "asyncio.Queue.__module__=='asyncio.queues'; asyncio.Task.__module__=='_asyncio'; asyncio.Future.__module__=='_asyncio'."
    - "asyncio.Lock.__module__=='asyncio.locks'; asyncio.Event.__module__=='asyncio.locks'; asyncio.Semaphore.__module__=='asyncio.locks'."
    - "asyncio.Barrier.__module__=='asyncio.locks'; asyncio.TaskGroup.__module__=='asyncio.taskgroups'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue — numeric type conversion protocol dict-presence (all False)
# ---------------------------------------------------------------------------

table asyncio_extra1561.queue_numeric_protocol:
  description: "asyncio.Queue.__dict__ does not contain any numeric type conversion protocol dunder"
  kind: python_call_eq
  category: numeric_presence
  id_prefix: as1561qu

  columns: [id, function, args, expected]
  rows:
    - [as1561qu001, asyncio.Queue.__dict__.__contains__, ["__bool__"],    false]
    - [as1561qu002, asyncio.Queue.__dict__.__contains__, ["__int__"],     false]
    - [as1561qu003, asyncio.Queue.__dict__.__contains__, ["__float__"],   false]
    - [as1561qu004, asyncio.Queue.__dict__.__contains__, ["__complex__"], false]
    - [as1561qu005, asyncio.Queue.__dict__.__contains__, ["__index__"],   false]
    - [as1561qu006, asyncio.Queue.__dict__.__contains__, ["__trunc__"],   false]
    - [as1561qu007, asyncio.Queue.__dict__.__contains__, ["__floor__"],   false]
    - [as1561qu008, asyncio.Queue.__dict__.__contains__, ["__ceil__"],    false]
    - [as1561qu009, asyncio.Queue.__dict__.__contains__, ["__round__"],   false]

