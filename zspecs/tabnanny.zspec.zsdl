spec: tabnanny
version: ">=3.0"
backend: python_module(tabnanny)

docs: https://docs.python.org/3/library/tabnanny.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tabnanny.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "tabnanny source: Lib/tabnanny.py (PSF; source inspection permitted)"
  not_derived_from:
    - "tabnanny source: internal tokenizer integration details"
  notes:
    - "tabnanny detects ambiguous whitespace (mixed tabs and spaces) in Python source files."
    - "tabnanny.check() accepts a file or directory path and reports NannyNag exceptions for violations."
    - "tabnanny.process_tokens() is the low-level token scanner; it raises NannyNag on ambiguous indentation."
    - "tabnanny.NannyNag is an Exception subclass raised to report ambiguous whitespace; it carries lineno, line, and msg."
    - "tabnanny.verbose is an int (default 0); set to 1 to enable verbose output."
    - "tabnanny.filename_only is an int (default 0); set to 1 to report only filenames, not line details."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "tabnanny.process_tokens() raises NannyNag on ambiguous indentation. tabnanny.check() catches NannyNag internally and prints a warning."
  stderr: "null"
  stickiness: "N/A — stateless per call."
  codes: {}

# ---------------------------------------------------------------------------
# Function name attributes
# ---------------------------------------------------------------------------

invariant tabnanny.names.check:
  description: "tabnanny.check.__name__ == 'check'"
  category: names
  kind: python_call_eq
  function: check.__name__.__eq__
  args: ["check"]
  expected: true

invariant tabnanny.names.process_tokens:
  description: "tabnanny.process_tokens.__name__ == 'process_tokens'"
  category: names
  kind: python_call_eq
  function: process_tokens.__name__.__eq__
  args: ["process_tokens"]
  expected: true

# ---------------------------------------------------------------------------
# Class name
# ---------------------------------------------------------------------------

invariant tabnanny.names.NannyNag:
  description: "tabnanny.NannyNag.__name__ == 'NannyNag'"
  category: names
  kind: python_call_eq
  function: NannyNag.__name__.__eq__
  args: ["NannyNag"]
  expected: true

# ---------------------------------------------------------------------------
# Module membership
# ---------------------------------------------------------------------------

invariant tabnanny.modules.NannyNag:
  description: "tabnanny.NannyNag.__module__ == 'tabnanny'"
  category: modules
  kind: python_call_eq
  function: NannyNag.__module__.__eq__
  args: ["tabnanny"]
  expected: true

# ---------------------------------------------------------------------------
# NannyNag inheritance — base class is Exception
# ---------------------------------------------------------------------------

invariant tabnanny.hierarchy.NannyNag_base:
  description: "tabnanny.NannyNag.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: NannyNag.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# NannyNag method names
# ---------------------------------------------------------------------------

invariant tabnanny.method_names.get_lineno:
  description: "tabnanny.NannyNag.get_lineno.__name__ == 'get_lineno'"
  category: method_names
  kind: python_call_eq
  function: NannyNag.get_lineno.__name__.__eq__
  args: ["get_lineno"]
  expected: true

invariant tabnanny.method_names.get_line:
  description: "tabnanny.NannyNag.get_line.__name__ == 'get_line'"
  category: method_names
  kind: python_call_eq
  function: NannyNag.get_line.__name__.__eq__
  args: ["get_line"]
  expected: true

invariant tabnanny.method_names.get_msg:
  description: "tabnanny.NannyNag.get_msg.__name__ == 'get_msg'"
  category: method_names
  kind: python_call_eq
  function: NannyNag.get_msg.__name__.__eq__
  args: ["get_msg"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level constants — verbose and filename_only are ints
# ---------------------------------------------------------------------------

invariant tabnanny.constants.verbose_is_int:
  description: "tabnanny.verbose.__class__.__name__ == 'int' — verbose flag is an integer"
  category: constants
  kind: python_call_eq
  function: verbose.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tabnanny.constants.filename_only_is_int:
  description: "tabnanny.filename_only.__class__.__name__ == 'int' — filename_only flag is an integer"
  category: constants
  kind: python_call_eq
  function: filename_only.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level constants — default values
# ---------------------------------------------------------------------------

invariant tabnanny.constants.verbose_default:
  description: "tabnanny.verbose == 0 — default verbose is 0 (off)"
  category: constants
  kind: python_call_eq
  function: verbose.__eq__
  args: [0]
  expected: true

invariant tabnanny.constants.filename_only_default:
  description: "tabnanny.filename_only == 0 — default filename_only is 0 (off)"
  category: constants
  kind: python_call_eq
  function: filename_only.__eq__
  args: [0]
  expected: true

