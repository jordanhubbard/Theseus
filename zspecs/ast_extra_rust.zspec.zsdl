spec: ast_extra_rust
version: ">=3.9"
backend: rust_module(ast_extra_rust)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — ast stdlib"
  notes:
    - "ast parses Python source code to an AST."
    - "ast.parse('x=1') returns a Module."
    - "ast.dump(ast.parse('x=1')) is a non-empty string."
    - "ast.literal_eval('42') == 42."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant ast_extra_rust.literal_eval_42:
  description: "ast.literal_eval('42') == 42"
  category: literal_eval
  kind: python_call_eq
  function: ast_extra_literal_eval_42
  args: []
  expected: 42

invariant ast_extra_rust.parse_returns_module:
  description: "type(ast.parse('x=1')).__name__ == 'Module'"
  category: parse
  kind: python_call_eq
  function: ast_extra_parse_type_name
  args: []
  expected: "Module"

invariant ast_extra_rust.dump_nonempty:
  description: "ast.dump(ast.parse('x=1')) is non-empty"
  category: dump
  kind: python_call_eq
  function: ast_extra_dump_nonempty
  args: []
  expected: true

