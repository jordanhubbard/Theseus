spec: asyncio_extra159
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-future.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-future.html — Python asyncio Future and Task documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec covers: asyncio.Future and asyncio.Task class identity. asyncio.Future.__name__=='Future' (len=6: 'F'+'u'+'t'+'u'+'r'+'e'=6); asyncio.Future.__module__=='_asyncio' (len=8: '_'+'a'+'s'+'y'+'n'+'c'+'i'+'o'=8; NOT 'asyncio.futures' — the C-accelerated Future class lives in the _asyncio extension module, not the asyncio.futures Python module); asyncio.Future.__bases__[0].__name__=='object' (Future inherits directly from object in the C implementation); asyncio.Task.__name__=='Task' (len=4); asyncio.Task.__module__=='_asyncio' (same C extension module as Future); asyncio.Task.__bases__[0].__name__=='Future' (Task inherits from Future — Task is a Future that wraps a coroutine). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Future.__module__=='_asyncio' (NOT 'asyncio.futures') — in CPython, asyncio.Future is the C-accelerated implementation defined in Modules/_asynciomodule.c and exposed as _asyncio.Future; the Python module asyncio.futures re-exports it but the class's own __module__ attribute reflects its defining module '_asyncio' (len=8: '_'=1+'asyncio'=7=8); this is a key difference from Python-pure asyncio classes like asyncio.Lock (__module__=='asyncio.locks') — the C-level asyncio classes report '_asyncio' as their module; asyncio.Task is similarly C-accelerated and reports __module__=='_asyncio'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Task.__bases__[0].__name__=='Future' — asyncio.Task inherits from asyncio.Future; Task wraps a coroutine and schedules it on the event loop; Task is a special subclass of Future that represents a running coroutine; because Task.__bases__[0].__name__=='Future' (not 'object'), Task adds coroutine scheduling on top of Future's state machine (pending, running, cancelled, finished); Future.__bases__[0].__name__=='object' (Future is the root — it does NOT inherit from any asyncio class). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Future class identity — extra159
#
# asyncio.Future.__name__.__eq__('Future')                         == True
# asyncio.Future.__module__.__eq__('_asyncio')                     == True
# asyncio.Future.__bases__[0].__name__.__eq__('object')            == True
# ---------------------------------------------------------------------------

table asyncio_extra159.asyncio_future_identity:
  description: "asyncio.Future class identity checks in asynciofut159 namespace — asyncio.Future.__name__=='Future' (len=6: 'F'+'u'+'t'+'u'+'r'+'e'=6; the asyncio C-accelerated future class representing the result of an async operation; supports add_done_callback(), result(), exception(), cancel(), cancelled(), done()); asyncio.Future.__module__=='_asyncio' (len=8: '_'=1+'asyncio'=7=8; NOT 'asyncio.futures' — Future is the C extension class in _asyncio, not the Python module asyncio.futures; this contrasts with asyncio.Lock.__module__=='asyncio.locks' which is Python-defined); asyncio.Future.__bases__[0].__name__=='object' (len=6; Future inherits directly from object in the C implementation — it is the root asyncio future class); Future.__name__.__len__()==6; compare: asyncio.Task.__name__.__len__()==4 (2 shorter than Future); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciofut159

  columns: [id, function, args, expected, description]
  rows:
    - [future_name_eq,   asyncio.Future.__name__.__eq__,                ["Future"],    true,  "asyncio.Future.__name__ == 'Future' (len=6; C-accelerated asyncio future class); verified with Python 3.14.3"]
    - [future_mod_eq,    asyncio.Future.__module__.__eq__,               ["_asyncio"],  true,  "asyncio.Future.__module__ == '_asyncio' (len=8; C extension module, NOT asyncio.futures); verified with Python 3.14.3"]
    - [future_base_eq,   "asyncio.Future.__bases__[0].__name__.__eq__",  ["object"],    true,  "asyncio.Future.__bases__[0].__name__ == 'object' (Future inherits from object in C impl); verified with Python 3.14.3"]
    - [future_name_len,  asyncio.Future.__name__.__len__,                [],            6,     "asyncio.Future.__name__.__len__() == 6 ('Future'; compare Task=4); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Task class identity — extra159
#
# asyncio.Task.__name__.__eq__('Task')                             == True
# asyncio.Task.__module__.__eq__('_asyncio')                       == True
# asyncio.Task.__bases__[0].__name__.__eq__('Future')              == True
# ---------------------------------------------------------------------------

table asyncio_extra159.asyncio_task_identity:
  description: "asyncio.Task class identity checks in asynciotask159 namespace — asyncio.Task.__name__=='Task' (len=4: 'T'+'a'+'s'+'k'=4; the asyncio C-accelerated Task class that wraps a coroutine and schedules it on the event loop; Task is the primary way to run coroutines concurrently); asyncio.Task.__module__=='_asyncio' (len=8; same C extension module as Future — '_asyncio'; NOT 'asyncio.tasks'; Task is defined in Modules/_asynciomodule.c alongside Future); asyncio.Task.__bases__[0].__name__=='Future' (len=6; Task inherits from Future — Task IS-A Future; this means Task exposes all Future methods (result, exception, cancel, add_done_callback) plus coroutine scheduling via the event loop); Task.__name__.__len__()==4; compare: Future.__name__.__len__()==6 (2 longer than Task); both Task and Future report __module__=='_asyncio'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotask159

  columns: [id, function, args, expected, description]
  rows:
    - [task_name_eq,   asyncio.Task.__name__.__eq__,                ["Task"],      true,  "asyncio.Task.__name__ == 'Task' (len=4; C-accelerated asyncio task class); verified with Python 3.14.3"]
    - [task_mod_eq,    asyncio.Task.__module__.__eq__,               ["_asyncio"],  true,  "asyncio.Task.__module__ == '_asyncio' (len=8; same C extension as Future, NOT asyncio.tasks); verified with Python 3.14.3"]
    - [task_base_eq,   "asyncio.Task.__bases__[0].__name__.__eq__",  ["Future"],    true,  "asyncio.Task.__bases__[0].__name__ == 'Future' (Task inherits from Future, not object); verified with Python 3.14.3"]
    - [task_name_len,  asyncio.Task.__name__.__len__,                [],            4,     "asyncio.Task.__name__.__len__() == 4 ('Task'; 2 shorter than Future=6); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Cross-comparison: Future and Task shared module identity — extra159
#
# asyncio.Future.__module__.__eq__(asyncio.Task.__module__) — both '_asyncio'
# asyncio.Future.__module__.__len__() == 8
# asyncio.Task.__module__.__len__() == 8
# ---------------------------------------------------------------------------

table asyncio_extra159.asyncio_future_task_module_comparison:
  description: "asyncio.Future and asyncio.Task shared module identity cross-checks in asyncioftmod159 namespace — both asyncio.Future and asyncio.Task are C-accelerated and share __module__=='_asyncio' (len=8: '_'=1+'asyncio'=7=8); asyncio.Future.__module__.__len__()==8 and asyncio.Task.__module__.__len__()==8 (same length because they are in the same module); this is in contrast to Python-defined asyncio classes: asyncio.Lock.__module__=='asyncio.locks' (len=13) and asyncio.StreamReader.__module__=='asyncio.streams' (len=15) — all longer than '_asyncio'=8; the C module name '_asyncio' begins with an underscore indicating it is a private C extension (the public API is re-exported through the asyncio package); Future.__name__.__len__()==6 > Task.__name__.__len__()==4; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioftmod159

  columns: [id, function, args, expected, description]
  rows:
    - [future_mod_len,  asyncio.Future.__module__.__len__,  [],            8,     "asyncio.Future.__module__.__len__() == 8 ('_asyncio'; starts with underscore — private C ext); verified with Python 3.14.3"]
    - [task_mod_len,    asyncio.Task.__module__.__len__,    [],            8,     "asyncio.Task.__module__.__len__() == 8 ('_asyncio'; same module as Future); verified with Python 3.14.3"]
    - [future_mod_eq2,  asyncio.Future.__module__.__eq__,   ["_asyncio"],  true,  "asyncio.Future.__module__ == '_asyncio' (cross-reference: both Future and Task in _asyncio); verified with Python 3.14.3"]
    - [task_base_len,   "asyncio.Task.__bases__[0].__name__.__len__",   [], 6,     "asyncio.Task.__bases__[0].__name__.__len__() == 6 ('Future'; Task inherits from Future); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra159
# ---------------------------------------------------------------------------

invariant asyncio_extra159.asyncio_Future_name_eq:
  description: "asyncio.Future.__name__.__eq__('Future') returns True — asyncio.Future is the C-accelerated future class in the asyncio library; Future.__name__=='Future' (len=6: 'F'+'u'+'t'+'u'+'r'+'e'=6); a Future represents the eventual result of an asynchronous operation; callers can await a Future, add callbacks with add_done_callback(), check completion with done(), retrieve the result with result(), or retrieve any exception with exception(); Future.__module__=='_asyncio' (len=8; the C extension module — NOT 'asyncio.futures' which is the Python compatibility wrapper); Future.__bases__[0].__name__=='object' (inherits from object in the C implementation); compare: asyncio.Task.__name__=='Task' (len=4; 2 shorter than Future=6); NEW in extra159: first standalone asyncio.Future.__name__ identity invariant in asynciofut159 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Future.__name__.__eq__
  args: ["Future"]
  expected: true

invariant asyncio_extra159.asyncio_Future_module_eq:
  description: "asyncio.Future.__module__.__eq__('_asyncio') returns True — asyncio.Future is the C-accelerated implementation; its __module__ is '_asyncio' (len=8: '_'=1+'asyncio'=7=8); '_asyncio' is the private C extension module in CPython (Modules/_asynciomodule.c) that provides fast implementations of Future and Task; the Python module asyncio.futures re-exports Future from _asyncio but Future.__module__ reflects its actual defining module '_asyncio'; this is DIFFERENT from asyncio.Lock.__module__=='asyncio.locks' (len=13; a Python-implemented class); '_asyncio' (len=8) is shorter than all Python asyncio submodule names (locks=13, streams=15, events=14); NEW in extra159: first standalone asyncio.Future.__module__ identity invariant in asynciofut159 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Future.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra159.asyncio_Task_module_eq:
  description: "asyncio.Task.__module__.__eq__('_asyncio') returns True — asyncio.Task is the C-accelerated task class; its __module__ is '_asyncio' (len=8; same C extension module as asyncio.Future); Task.__module__=='_asyncio' NOT 'asyncio.tasks'; like Future, Task is implemented in Modules/_asynciomodule.c in CPython; the Python module asyncio.tasks re-exports Task from _asyncio; both asyncio.Future and asyncio.Task share __module__=='_asyncio', distinguishing them from Python-implemented asyncio classes that show their respective submodule names; NEW in extra159: first standalone asyncio.Task.__module__ identity invariant in asynciotask159 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.__module__.__eq__
  args: ["_asyncio"]
  expected: true

invariant asyncio_extra159.asyncio_Task_base_is_Future:
  description: "asyncio.Task.__bases__[0].__name__.__eq__('Future') returns True — asyncio.Task inherits from asyncio.Future; Task.__bases__[0].__name__=='Future' (len=6); this means Task IS-A Future: every Task is also a Future with the additional capability of wrapping and scheduling a coroutine on the event loop; Task adds a coroutine stepper that calls Future's set_result() or set_exception() when the coroutine completes; compare: asyncio.Future.__bases__[0].__name__=='object' (Future inherits from object, the root — no asyncio base) vs asyncio.Task.__bases__[0].__name__=='Future' (Task inherits from Future — one level deeper); this inheritance means awaiting a Task works because Task is a Future; NEW in extra159: first standalone asyncio.Task.__bases__[0].__name__ identity invariant in asynciotask159 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Task.__bases__[0].__name__.__eq__"
  args: ["Future"]
  expected: true

invariant asyncio_extra159.asyncio_Future_base_is_object:
  description: "asyncio.Future.__bases__[0].__name__.__eq__('object') returns True — asyncio.Future inherits directly from object in the C implementation; Future.__bases__[0].__name__=='object' (len=6); Future is the root asyncio future class — it does NOT inherit from any asyncio class; compare: asyncio.Task.__bases__[0].__name__=='Future' (Task inherits from Future — one level of asyncio inheritance) vs asyncio.Future.__bases__[0].__name__=='object' (Future is the root); asyncio.BoundedSemaphore.__bases__[0].__name__=='Semaphore' (also one level of asyncio inheritance from a sibling class); among asyncio C-extension classes, Future is the root (inheriting from object) while Task inherits from Future; NEW in extra159: first standalone asyncio.Future.__bases__[0].__name__ identity invariant in asynciofut159 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Future.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

