spec: concurrent_futures_extra402
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "concurrent.futures.Executor.__enter__.__name__ == '__enter__'"
    - "concurrent.futures.Executor.__exit__.__name__ == '__exit__'"
    - "concurrent.futures.Executor.map.__name__ == 'map'"
    - "concurrent.futures.Executor.shutdown.__name__ == 'shutdown'"
    - "concurrent.futures.Error is not present in Python 3.14; the module has CancelledError, BrokenExecutor, InvalidStateError"
    - "concurrent.futures.CancelledError.__doc__.__class__.__name__ == 'str'"
    - "concurrent.futures.BrokenExecutor.__doc__.__class__.__name__ == 'str'"
    - "concurrent.futures.InvalidStateError.__doc__.__class__.__name__ == 'str'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra402.executor_method_names:
  description: "Verify __name__ attribute of concurrent.futures.Executor methods"
  kind: python_call_eq
  category: identity
  id_prefix: cf402e

  columns: [id, function, args, expected]
  rows:
    - [cf402e001, concurrent.futures.Executor.__enter__.__name__.__eq__, ["__enter__"], true]
    - [cf402e002, concurrent.futures.Executor.__exit__.__name__.__eq__, ["__exit__"], true]
    - [cf402e003, concurrent.futures.Executor.map.__name__.__eq__, ["map"], true]
    - [cf402e004, concurrent.futures.Executor.shutdown.__name__.__eq__, ["shutdown"], true]

table concurrent_futures_extra402.error_doc_class_names:
  description: "Verify __doc__.__class__.__name__ for concurrent.futures exception classes (all docstrings are str)"
  kind: python_call_eq
  category: identity
  id_prefix: cf402dc

  columns: [id, function, args, expected]
  rows:
    - [cf402dc001, concurrent.futures.CancelledError.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf402dc002, concurrent.futures.BrokenExecutor.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf402dc003, concurrent.futures.InvalidStateError.__doc__.__class__.__name__.__eq__, ["str"], true]
