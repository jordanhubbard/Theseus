spec: io_extra162
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.TextIOWrapper and io.BufferedWriter class identity (__name__, __module__, __bases__[0].__name__), plus io.BufferedRandom and io.IncrementalNewlineDecoder identity."
    - "io.TextIOWrapper.__module__ == '_io' (confirmed in io_extra161); TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — TextIOWrapper inherits from the private C ABC _TextIOBase, same as io.StringIO."
    - "io.BufferedWriter.__module__ == '_io'; BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — BufferedWriter inherits from the private C ABC _BufferedIOBase, consistent with BufferedReader (established in io_extra159/io_extra161)."
    - "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — BufferedRandom also inherits from _BufferedIOBase, the same C ABC as BufferedWriter and BufferedReader. This confirms that ALL four concrete buffered classes (BufferedReader, BufferedWriter, BufferedRandom, BytesIO) share the same C ABC parent."
    - "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder'; __module__ == '_io' — IncrementalNewlineDecoder is also a C extension class with __module__ == '_io'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOWrapper and io.BufferedWriter class identity
# TextIOWrapper.__name__ == 'TextIOWrapper', __module__ == '_io'
# TextIOWrapper.__bases__[0].__name__ == '_TextIOBase'
# BufferedWriter.__name__ == 'BufferedWriter', __module__ == '_io'
# BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase'
# All are C extension classes with __module__ == '_io' and private C ABC parents.
# ---------------------------------------------------------------------------

table io_extra162.TextIOWrapper_BufferedWriter_identity:
  description: "io.TextIOWrapper and io.BufferedWriter class identity: both have __module__=='_io'; TextIOWrapper inherits '_TextIOBase', BufferedWriter inherits '_BufferedIOBase' — all private C ABCs"
  kind: python_call_eq
  category: identity
  id_prefix: ioconcid162

  columns: [id, function, args, expected, description]
  rows:
    - [twr_name_eq,      TextIOWrapper.__name__.__eq__,                       ["TextIOWrapper"],   true, "io.TextIOWrapper.__name__ == 'TextIOWrapper' (the concrete text stream class that wraps a binary buffered stream with a codec for encoding/decoding; TextIOWrapper is returned by open() in text mode; __name__ equals the bare class name 'TextIOWrapper' without any module prefix; 'TextIOWrapper' has 14 characters)"]
    - [twr_module_eq,    TextIOWrapper.__module__.__eq__,                     ["_io"],             true, "io.TextIOWrapper.__module__ == '_io' (TextIOWrapper is a C extension class implemented in the _io module; like all concrete io classes, its __module__ is '_io' rather than 'io'; this was also established in io_extra161; TextIOWrapper is the most commonly used io class in practice — it is returned by open() in text mode)"]
    - [twr_base_eq,      "TextIOWrapper.__bases__[0].__name__.__eq__",        ["_TextIOBase"],     true, "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (TextIOWrapper inherits from the private C ABC _TextIOBase, not the public Python wrapper io.TextIOBase; this follows the same pattern as io.StringIO (also inherits _TextIOBase); both concrete text stream classes skip the public Python ABC wrapper and inherit the private C ABC directly)"]
    - [bwr_name_eq,      BufferedWriter.__name__.__eq__,                      ["BufferedWriter"],  true, "io.BufferedWriter.__name__ == 'BufferedWriter' (the concrete buffered binary write stream class; BufferedWriter wraps a RawIOBase object and buffers write operations for efficiency; __name__ is the bare class name 'BufferedWriter'; 'BufferedWriter' has 14 characters, same length as 'TextIOWrapper')"]
    - [bwr_module_eq,    BufferedWriter.__module__.__eq__,                    ["_io"],             true, "io.BufferedWriter.__module__ == '_io' (BufferedWriter is a C extension class with __module__ == '_io'; consistent with all other concrete io classes: StringIO, BytesIO, FileIO, BufferedReader, TextIOWrapper — all have __module__ == '_io' while the public ABC wrappers have __module__ == 'io')"]
    - [bwr_base_eq,      "BufferedWriter.__bases__[0].__name__.__eq__",       ["_BufferedIOBase"], true, "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' (BufferedWriter inherits from the private C ABC _BufferedIOBase; this matches BufferedReader and BytesIO, which also inherit _BufferedIOBase; all three concrete buffered binary classes share the same C ABC parent; the full four-way pattern: BufferedReader, BufferedWriter, BufferedRandom, BytesIO all inherit _BufferedIOBase)"]

# ---------------------------------------------------------------------------
# io.BufferedRandom and io.IncrementalNewlineDecoder class identity
# BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase'
# IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder'
# IncrementalNewlineDecoder.__module__ == '_io'
# ---------------------------------------------------------------------------

table io_extra162.BufferedRandom_IncrementalNewlineDecoder_identity:
  description: "io.BufferedRandom and io.IncrementalNewlineDecoder class identity: BufferedRandom inherits '_BufferedIOBase'; IncrementalNewlineDecoder has __module__=='_io'"
  kind: python_call_eq
  category: identity
  id_prefix: ioconcid162

  columns: [id, function, args, expected, description]
  rows:
    - [bran_base_eq,     "BufferedRandom.__bases__[0].__name__.__eq__",       ["_BufferedIOBase"], true, "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' (BufferedRandom supports both reading and writing on a seekable stream; it inherits from the same C ABC _BufferedIOBase as BufferedReader, BufferedWriter, and BytesIO; this completes the four-way pattern: ALL four concrete buffered binary classes inherit _BufferedIOBase directly)"]
    - [ind_name_eq,      IncrementalNewlineDecoder.__name__.__eq__,           ["IncrementalNewlineDecoder"], true, "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' (IncrementalNewlineDecoder is a helper class that decodes universal newlines incrementally; it is used internally by TextIOWrapper for newline translation; __name__ is the bare class name 'IncrementalNewlineDecoder'; 'IncrementalNewlineDecoder' has 26 characters — the longest class name in the io module)"]
    - [ind_module_eq,    IncrementalNewlineDecoder.__module__.__eq__,         ["_io"],             true, "io.IncrementalNewlineDecoder.__module__ == '_io' (IncrementalNewlineDecoder is a C extension class with __module__ == '_io'; it wraps another incremental decoder and performs universal newline translation (converting \\r\\n and \\r to \\n); being a C extension class, its __module__ is '_io' rather than the public 'io' module)"]
    - [bran_name_eq,     BufferedRandom.__name__.__eq__,                      ["BufferedRandom"],  true, "io.BufferedRandom.__name__ == 'BufferedRandom' (the concrete buffered random-access binary stream class supporting both read and write; __name__ is the bare class name 'BufferedRandom'; 'BufferedRandom' has 14 characters; unlike BufferedReader (read-only) and BufferedWriter (write-only), BufferedRandom supports both operations on a seekable underlying stream)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra162.TextIOWrapper_base_is_private_TextIOBase:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — TextIOWrapper's direct base class is the private C ABC _TextIOBase; this is the same base as io.StringIO (also inherits _TextIOBase); both concrete text stream classes (TextIOWrapper for file-based text I/O and StringIO for in-memory text I/O) share _TextIOBase as their parent; the public Python wrapper io.TextIOBase exists alongside _TextIOBase but concrete classes skip it; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "TextIOWrapper.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra162.BufferedWriter_base_is_private_BufferedIOBase:
  description: "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — BufferedWriter inherits from the private C ABC _BufferedIOBase; the complete four-way pattern for buffered binary concrete classes: BufferedReader->_BufferedIOBase, BufferedWriter->_BufferedIOBase, BufferedRandom->_BufferedIOBase, BytesIO->_BufferedIOBase; all four share the same C ABC parent; none inherit from the public Python wrapper io.BufferedIOBase; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "BufferedWriter.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra162.BufferedRandom_base_is_private_BufferedIOBase:
  description: "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — BufferedRandom inherits from the same C ABC _BufferedIOBase as BufferedReader, BufferedWriter, and BytesIO; BufferedRandom is the read-write seekable buffered stream, requiring that the underlying raw stream also be seekable (supports seek() and tell()); this confirms ALL four concrete buffered binary classes share _BufferedIOBase as their immediate parent class"
  category: identity
  kind: python_call_eq
  function: "BufferedRandom.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra162.IncrementalNewlineDecoder_module_is_private_io:
  description: "io.IncrementalNewlineDecoder.__module__ == '_io' — IncrementalNewlineDecoder is a C extension class with __module__ == '_io'; it is an internal helper class for TextIOWrapper's universal newline translation; its presence in the _io C extension (rather than pure Python) means it can perform high-performance incremental newline decoding; IncrementalNewlineDecoder converts \\r\\n and standalone \\r to \\n when universal newline mode is enabled"
  category: identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra162.BufferedWriter_module_is_private_io:
  description: "io.BufferedWriter.__module__ == '_io' — BufferedWriter is a C extension class with __module__ == '_io'; together with BufferedReader, BufferedRandom, BytesIO, FileIO, StringIO, TextIOWrapper, and IncrementalNewlineDecoder, BufferedWriter completes the set of concrete io classes that all have __module__ == '_io'; in contrast, the abstract base classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase) have __module__ == 'io'"
  category: identity
  kind: python_call_eq
  function: BufferedWriter.__module__.__eq__
  args: ["_io"]
  expected: true

