spec: cf3121
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 655 (cf3121): __ge__, __repr__, __str__ dict-presence for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor, concurrent.futures.Executor."
    - "Key finding (__ge__): all 4 concurrent.futures classes return false for __ge__. Consistent with wave 654 (cf3106) which showed all false for __lt__/__le__/__gt__ as well. No ordering operators are defined anywhere in the concurrent.futures class hierarchy."
    - "Key finding (__repr__): concurrent.futures.Future defines __repr__ in its own __dict__ (true). ThreadPoolExecutor, ProcessPoolExecutor, and Executor do not (false). Future.__repr__ provides a state-aware string including the future's status (PENDING, RUNNING, CANCELLED, FINISHED) and result or exception if available."
    - "Key finding (__str__): all 4 concurrent.futures classes return false for __str__. None define a custom string representation; str() on these objects falls back to __repr__ via object.__str__."
    - "concurrent.futures.Executor is an abstract base class; it defines no __repr__, leaving concrete subclasses free to do so (but neither ThreadPoolExecutor nor ProcessPoolExecutor does)."
    - "The absence of __repr__ on ThreadPoolExecutor and ProcessPoolExecutor means executor objects display their default object representation (memory address) when printed."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __ge__ dict-presence — operator.contains(Cls.__dict__, '__ge__')
#
# All 4 concurrent.futures classes return false for __ge__.
# No ordering operators are defined in the concurrent.futures hierarchy.
# Futures and executors are managed by identity and state, not by value ordering.
# This is consistent with wave 654 (cf3106): all false for __lt__/__le__/__gt__.
# ---------------------------------------------------------------------------

table cf3121.ge:
  description: "concurrent.futures types __ge__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3121

  columns: [id, function, args, expected]
  rows:
    - ["cf3121001", operator.contains, [concurrent.futures.Future.__dict__,              "__ge__"], false]
    - ["cf3121002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ge__"], false]
    - ["cf3121003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ge__"], false]
    - ["cf3121004", operator.contains, [concurrent.futures.Executor.__dict__,            "__ge__"], false]

# ---------------------------------------------------------------------------
# __repr__ dict-presence — operator.contains(Cls.__dict__, '__repr__')
#
# concurrent.futures.Future: TRUE — defines __repr__ to expose the future's
#   internal state (PENDING, RUNNING, CANCELLED, FINISHED) along with the
#   result or exception, making it informative for debugging and logging.
# ThreadPoolExecutor, ProcessPoolExecutor, Executor: false — none define
#   __repr__ in their own __dict__. Executor is abstract and leaves this to
#   subclasses; the concrete executors do not bother, relying on object's default.
# ---------------------------------------------------------------------------

table cf3121.repr:
  description: "concurrent.futures types __repr__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3121

  columns: [id, function, args, expected]
  rows:
    - ["cf3121005", operator.contains, [concurrent.futures.Future.__dict__,              "__repr__"], true]
    - ["cf3121006", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__repr__"], false]
    - ["cf3121007", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__repr__"], false]
    - ["cf3121008", operator.contains, [concurrent.futures.Executor.__dict__,            "__repr__"], false]

# ---------------------------------------------------------------------------
# __str__ dict-presence — operator.contains(Cls.__dict__, '__str__')
#
# All 4 concurrent.futures classes return false for __str__.
# None define a dedicated __str__; str() falls back to __repr__ via
# object.__str__ for all four classes.
# ---------------------------------------------------------------------------

table cf3121.str:
  description: "concurrent.futures types __str__ dict-presence checks; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3121

  columns: [id, function, args, expected]
  rows:
    - ["cf3121009",  operator.contains, [concurrent.futures.Future.__dict__,              "__str__"], false]
    - ["cf3121010", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__str__"], false]
    - ["cf3121011", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__str__"], false]
    - ["cf3121012", operator.contains, [concurrent.futures.Executor.__dict__,            "__str__"], false]

# ---------------------------------------------------------------------------
# combined — __ge__, __repr__, __str__ across all 4 concurrent.futures subjects
#
# Covers the full matrix: 4 classes x 3 methods = 12 rows.
# __ge__:   false for all 4 — no ordering defined anywhere in the hierarchy.
# __repr__: true only for concurrent.futures.Future; false for all others.
# __str__:  false for all 4 — no custom string conversion defined.
# The only non-false value in this entire matrix is Future.__repr__ (true).
# concurrent.futures.Future is the only class that cares about its own
# printed representation; executors are opaque resource managers by design.
# Cross-wave summary for cf subjects:
#   Wave 652 (cf3076): __get__/__set__/__delete__ — all false for all 4.
#   Wave 653 (cf3091): __hash__/__eq__/__bool__ — all false for all 4.
#   Wave 654 (cf3106): __lt__/__le__/__gt__ — all false for all 4.
#   Wave 655 (cf3121): __ge__ false for all 4; __repr__ true only for Future.
# ---------------------------------------------------------------------------

table cf3121.combined:
  description: "concurrent.futures types combined __ge__/__repr__/__str__; wave 655"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3121

  columns: [id, function, args, expected]
  rows:
