    - ["cf3121014", operator.contains, [concurrent.futures.Future.__dict__,              "__repr__"], true]
    - ["cf3121015", operator.contains, [concurrent.futures.Future.__dict__,              "__str__"],  false]
    - ["cf3121016", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__ge__"],   false]
    - ["cf3121017", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__repr__"], false]
    - ["cf3121018", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__str__"],  false]
    - ["cf3121019", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__ge__"],   false]
    - ["cf3121020", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__repr__"], false]
    - ["cf3121021", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__str__"],  false]
    - ["cf3121022", operator.contains, [concurrent.futures.Executor.__dict__,            "__ge__"],   false]
    - ["cf3121023", operator.contains, [concurrent.futures.Executor.__dict__,            "__repr__"], false]
    - ["cf3121024", operator.contains, [concurrent.futures.Executor.__dict__,            "__str__"],  false]
