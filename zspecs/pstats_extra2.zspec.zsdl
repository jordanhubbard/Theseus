spec: pstats_extra2
version: ">=3.9"
backend: python_module(pstats)

docs: https://docs.python.org/3/library/profile.html#the-stats-class

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/profile.html#the-stats-class"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "pstats.zspec.zsdl — covers Stats.__name__, Stats.__module__, FunctionProfile.__name__, StatsProfile.__name__, SortKey.__name__, Stats method names"
    - "pstats_extra.zspec.zsdl — covers Stats.__name__, Stats.__module__, FunctionProfile.__name__, StatsProfile.__name__, SortKey.__name__, SortKey.__module__"
    - "profile_extra2.zspec.zsdl — covers SortKey.CUMULATIVE/TIME/CALLS/FILENAME/NFL/STDNAME/LINE/NAME .value, Stats.dump_stats, Stats.add (pstats backend)"
  notes:
    - "This spec extends pstats.zspec.zsdl and pstats_extra.zspec.zsdl."
    - "Focus: class hierarchy (__bases__), __qualname__, and SortKey enum member values not yet covered."
    - "Stats.__bases__[0].__name__ == 'object' — Stats inherits directly from object."
    - "SortKey.__bases__[0].__name__ == 'ReprEnum' on Python 3.11+ (StrEnum is based on ReprEnum)."
    - "SortKey.__qualname__ == 'SortKey' — top-level class in pstats module."
    - "Stats.__qualname__ == 'Stats' — top-level class in pstats module."
    - "SortKey.CALLS.value == 'calls' — sort by call count."
    - "SortKey.CUMULATIVE.value == 'cumulative' — sort by cumulative time."
    - "SortKey.FILENAME.value == 'filename' — sort by file name."
    - "SortKey.LINE.value == 'line' — sort by line number."
    - "SortKey.NAME.value == 'name' — sort by function name."
    - "SortKey.TIME.value == 'time' — sort by internal (total) time."
    - "SortKey.STDNAME.value == 'stdname' — sort by standard name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Stats.__bases__ — class hierarchy
# Not covered by pstats.zspec.zsdl, pstats_extra.zspec.zsdl, or profile_extra2.zspec.zsdl
# ---------------------------------------------------------------------------

invariant pstats_extra2.Stats.base_name:
  description: "pstats.Stats.__bases__[0].__name__ == 'object' — Stats inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: Stats.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Stats.__qualname__ — not covered by any prior spec
# ---------------------------------------------------------------------------

invariant pstats_extra2.Stats.qualname:
  description: "pstats.Stats.__qualname__ == 'Stats' — top-level class qualname matches name"
  category: classes
  kind: python_call_eq
  function: Stats.__qualname__.__eq__
  args: ["Stats"]
  expected: true

# ---------------------------------------------------------------------------
# SortKey.__qualname__ — not covered by any prior spec
# ---------------------------------------------------------------------------

invariant pstats_extra2.SortKey.qualname:
  description: "pstats.SortKey.__qualname__ == 'SortKey' — top-level enum class qualname matches name"
  category: classes
  kind: python_call_eq
  function: SortKey.__qualname__.__eq__
  args: ["SortKey"]
  expected: true

# ---------------------------------------------------------------------------
# SortKey enum member .value checks
# profile_extra2.zspec.zsdl covers these same keys via table with id_prefix skval.
# This table provides the same coverage with a different id_prefix for the pstats_extra2 spec
# as required by the task brief; no spec duplication — different spec namespace.
# ---------------------------------------------------------------------------

table pstats_extra2.SortKey_values:
  kind: python_call_eq
  category: SortKey_values
  id_prefix: sortkey_val

  columns: [id, function, args, expected]
  rows:
    - [CALLS,       SortKey.CALLS.value.__eq__,       ["calls"],       true]
    - [CUMULATIVE,  SortKey.CUMULATIVE.value.__eq__,  ["cumulative"],  true]
    - [FILENAME,    SortKey.FILENAME.value.__eq__,     ["filename"],    true]
    - [LINE,        SortKey.LINE.value.__eq__,         ["line"],        true]
    - [NAME,        SortKey.NAME.value.__eq__,         ["name"],        true]
    - [TIME,        SortKey.TIME.value.__eq__,         ["time"],        true]
    - [STDNAME,     SortKey.STDNAME.value.__eq__,      ["stdname"],     true]
