spec: inspect_extra2701
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/inspect.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 627 theme: __lshift__, __rshift__, and __invert__ dict-presence checks (bit-shift left/right and bitwise NOT)."
    - "inspect.Parameter is an introspection value object; it does not implement bit-shift or bitwise NOT protocols."
    - "inspect.BoundArguments wraps a signature binding; it exposes .args and .kwargs but does not define __lshift__, __rshift__, or __invert__ itself."
    - "inspect.Signature is a callable signature descriptor; it defines __eq__ and __hash__ but not __lshift__, __rshift__, or __invert__."
    - "inspect.FullArgSpec is a namedtuple subclass; namedtuples inherit tuple methods but do not define __lshift__, __rshift__, or __invert__ in their own __dict__."
    - "None of these four inspect types define __lshift__, __rshift__, or __invert__ in their own class __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __lshift__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2701.lshift_protocol:
  description: "__lshift__ is absent from all inspect type __dict__s — none define bit-shift left directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2701

  columns: [id, function, args, expected]
  rows:
    - ["in2701001", "inspect.Parameter.__dict__.__contains__",       ["__lshift__"], false]
    - ["in2701002", "inspect.BoundArguments.__dict__.__contains__",  ["__lshift__"], false]
    - ["in2701003", "inspect.Signature.__dict__.__contains__",       ["__lshift__"], false]
    - ["in2701004", "inspect.FullArgSpec.__dict__.__contains__",     ["__lshift__"], false]

# ---------------------------------------------------------------------------
# __rshift__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2701.rshift_protocol:
  description: "__rshift__ is absent from all inspect type __dict__s — none define bit-shift right directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2701

  columns: [id, function, args, expected]
  rows:
    - ["in2701005", "inspect.Parameter.__dict__.__contains__",       ["__rshift__"], false]
    - ["in2701006", "inspect.BoundArguments.__dict__.__contains__",  ["__rshift__"], false]
    - ["in2701007", "inspect.Signature.__dict__.__contains__",       ["__rshift__"], false]
    - ["in2701008", "inspect.FullArgSpec.__dict__.__contains__",     ["__rshift__"], false]

# ---------------------------------------------------------------------------
# __invert__ dict-presence — absent from all four inspect types
# ---------------------------------------------------------------------------

table inspect_extra2701.invert_protocol:
  description: "__invert__ is absent from all inspect type __dict__s — none define bitwise NOT directly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2701

  columns: [id, function, args, expected]
  rows:
    - ["in2701009",  "inspect.Parameter.__dict__.__contains__",       ["__invert__"], false]
    - ["in2701010",  "inspect.BoundArguments.__dict__.__contains__",  ["__invert__"], false]
    - ["in2701011",  "inspect.Signature.__dict__.__contains__",       ["__invert__"], false]
    - ["in2701012",  "inspect.FullArgSpec.__dict__.__contains__",     ["__invert__"], false]

# ---------------------------------------------------------------------------
# Combined per-type view — all four inspect types vs. all three protocols
# ---------------------------------------------------------------------------

table inspect_extra2701.signature_combined:
  description: "inspect.Parameter, inspect.Signature, inspect.BoundArguments, and inspect.FullArgSpec define none of __lshift__, __rshift__, __invert__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2701

  columns: [id, function, args, expected]
  rows:
    - ["in2701013", "inspect.Parameter.__dict__.__contains__",       ["__lshift__"],  false]
    - ["in2701014", "inspect.Parameter.__dict__.__contains__",       ["__rshift__"],  false]
    - ["in2701015", "inspect.Parameter.__dict__.__contains__",       ["__invert__"],  false]
    - ["in2701016", "inspect.Signature.__dict__.__contains__",       ["__lshift__"],  false]
    - ["in2701017", "inspect.Signature.__dict__.__contains__",       ["__rshift__"],  false]
    - ["in2701018", "inspect.Signature.__dict__.__contains__",       ["__invert__"],  false]
    - ["in2701019", "inspect.BoundArguments.__dict__.__contains__",  ["__lshift__"],  false]
    - ["in2701020", "inspect.BoundArguments.__dict__.__contains__",  ["__rshift__"],  false]
    - ["in2701021", "inspect.BoundArguments.__dict__.__contains__",  ["__invert__"],  false]
    - ["in2701022", "inspect.FullArgSpec.__dict__.__contains__",     ["__lshift__"],  false]
    - ["in2701023", "inspect.FullArgSpec.__dict__.__contains__",     ["__rshift__"],  false]
    - ["in2701024", "inspect.FullArgSpec.__dict__.__contains__",     ["__invert__"],  false]
