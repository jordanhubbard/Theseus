spec: io_extra386
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "io.BufferedReader methods read, read1, peek, readline, readlines each report __name__ matching their Python-level name"
    - "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' and __module__ == 'io'"
    - "io.UnsupportedOperation inherits from both OSError and ValueError (MRO order: OSError first)"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedReader method __name__ identity
# ---------------------------------------------------------------------------

table io_extra386.buffered_reader_method_names:
  description: "io.BufferedReader method __name__ identity — read, read1, peek, readline, readlines; each method's __name__ matches its Python-level name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iobr386

  columns: [id, function, args, expected]
  rows:
    - [read_name,      io.BufferedReader.read.__name__.__eq__,      ["read"],      true]
    - [read1_name,     io.BufferedReader.read1.__name__.__eq__,     ["read1"],     true]
    - [peek_name,      io.BufferedReader.peek.__name__.__eq__,      ["peek"],      true]
    - [readline_name,  io.BufferedReader.readline.__name__.__eq__,  ["readline"],  true]
    - [readlines_name, io.BufferedReader.readlines.__name__.__eq__, ["readlines"], true]

# ---------------------------------------------------------------------------
# io.UnsupportedOperation class identity — __name__ and __module__
# ---------------------------------------------------------------------------

table io_extra386.unsupported_operation_identity:
  description: "io.UnsupportedOperation class identity — __name__ == 'UnsupportedOperation', __module__ == 'io'; UnsupportedOperation is raised when an unsupported operation is attempted on a stream; it inherits from both OSError and ValueError; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iounsupp386

  columns: [id, function, args, expected]
  rows:
    - [name_val,   io.UnsupportedOperation.__name__.__eq__,   ["UnsupportedOperation"], true]
    - [module_val, io.UnsupportedOperation.__module__.__eq__, ["io"],                   true]
