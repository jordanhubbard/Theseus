spec: struct_extra64
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra63.zspec.zsdl — covers pack/unpack/calcsize __qualname__.__eq__ / pack/unpack/calcsize __module__.__eq__('struct') / Struct.unpack_from/__qualname__.__eq__('Struct.unpack_from') / Struct.iter_unpack/__qualname__.__eq__('Struct.iter_unpack') / pack/unpack/calcsize __class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "struct_extra62.zspec.zsdl — covers Struct.pack/__qualname__/__len__()==11 / Struct.unpack/__qualname__/__len__()==13 / Struct.pack_into/__qualname__/__len__()==16 / Struct.unpack_from/__qualname__/__len__()==18 / Struct.iter_unpack/__qualname__/__len__()==18 / Struct.pack/__qualname__.__eq__('Struct.pack') / Struct.unpack/__qualname__.__eq__('Struct.unpack') / Struct.pack_into/__qualname__.__eq__('Struct.pack_into') / Struct.pack/__class__.__name__=='method_descriptor' / Struct.unpack/__class__.__name__=='method_descriptor' (table + invariants)."
    - "struct_extra8.zspec.zsdl — covers function __module__ (all '_struct' except error 'struct')."
    - "struct.zspec — covers struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra63; it does NOT duplicate invariants present in those files."
    - "Wave 235 theme: struct module-level C function (pack_into/unpack_from/iter_unpack) qualname/module/class identity + Struct.pack_into/__class__/__name__ and Struct.unpack_from/__class__/__name__ method_descriptor identity."
    - "struct.pack_into.__qualname__ == 'pack_into' — struct.pack_into is a module-level C builtin function; in Python 3.3+ module-level C builtins have __qualname__ equal to __name__; __qualname__ is 'pack_into'. No prior struct spec checks pack_into.__qualname__.__eq__('pack_into'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__ == 'unpack_from' — same reasoning as pack_into; __qualname__ is 'unpack_from'. No prior struct spec checks unpack_from.__qualname__.__eq__('unpack_from'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__ == 'iter_unpack' — same reasoning as pack_into; __qualname__ is 'iter_unpack'. No prior struct spec checks iter_unpack.__qualname__.__eq__('iter_unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__module__ == 'struct' — struct.pack_into is exposed in the struct module namespace; __module__ is 'struct'. struct_extra8 covers __module__ on the attribute-read axis; this spec adds the call form. No prior struct spec checks pack_into.__module__.__eq__('struct') in call form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__module__ == 'struct' — same reasoning; __module__ is 'struct'. No prior struct spec checks unpack_from.__module__.__eq__('struct') in call form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__module__ == 'struct' — same reasoning; __module__ is 'struct'. No prior struct spec checks iter_unpack.__module__.__eq__('struct') in call form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__class__.__name__ == 'builtin_function_or_method' — pack_into is a C builtin function at module level; __class__.__name__ is 'builtin_function_or_method'. No prior struct spec checks pack_into.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__class__.__name__ == 'builtin_function_or_method' — same reasoning; unpack_from is a C builtin at module level. No prior struct spec checks unpack_from.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__class__.__name__ == 'builtin_function_or_method' — same reasoning. No prior struct spec checks iter_unpack.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__class__.__name__ == 'method_descriptor' — Struct.pack_into is an unbound C method descriptor on the Struct C extension type; struct_extra62 covers method_descriptor for Struct.pack and Struct.unpack; this spec adds Struct.pack_into and Struct.unpack_from (new). No prior struct spec checks Struct.pack_into.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__class__.__name__ == 'method_descriptor' — same reasoning as pack_into. No prior struct spec checks Struct.unpack_from.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module-level C function pack_into / unpack_from / iter_unpack __qualname__
#
# Wave 235 theme: pack_into/unpack_from/iter_unpack __qualname__ equality.
#
# struct.pack_into, struct.unpack_from, and struct.iter_unpack are C builtin
# functions at module level. In Python 3.3+ module-level C builtins have
# __qualname__ equal to __name__. struct_extra63 covers pack/unpack/calcsize
# qualnames; this spec extends to pack_into/unpack_from/iter_unpack.
# No prior struct spec checks __qualname__.__eq__ for these three.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra64.module_func_qualnames_ext:
  description: "struct.pack_into/__qualname__.__eq__('pack_into')==True / struct.unpack_from/__qualname__.__eq__('unpack_from')==True / struct.iter_unpack/__qualname__.__eq__('iter_unpack')==True — pack_into/unpack_from/iter_unpack are C builtin functions at module level; in Python 3.3+ __qualname__==__name__ for module-level C builtins; struct_extra63 covers pack/unpack/calcsize qualnames; no prior struct spec checks __qualname__.__eq__ for pack_into/unpack_from/iter_unpack; first qualname equality anchor for these three functions"
  kind: python_call_eq
  category: qualnames
  id_prefix: structext64

  columns: [id, function, args, expected]
  rows:
    - [pack_into_qualname_eq_pack_into,     pack_into.__qualname__.__eq__,    ["pack_into"],    true]
    - [unpack_from_qualname_eq_unpack_from, unpack_from.__qualname__.__eq__,  ["unpack_from"],  true]
    - [iter_unpack_qualname_eq_iter_unpack, iter_unpack.__qualname__.__eq__,  ["iter_unpack"],  true]

# ---------------------------------------------------------------------------
# struct module-level C function pack_into / unpack_from / iter_unpack __module__
#
# Wave 235 theme: pack_into/unpack_from/iter_unpack __module__ == 'struct'.
#
# struct.pack_into, unpack_from, and iter_unpack are exposed in the struct
# module namespace. Their __module__ is 'struct'. struct_extra8 covers __module__
# on the attribute-read axis; this spec adds the call form for these three.
# No prior struct spec checks __module__.__eq__('struct') for pack_into,
# unpack_from, or iter_unpack in call form. Verified Python 3.14.3 macOS.
# ---------------------------------------------------------------------------

table struct_extra64.module_func_modules_ext:
  description: "struct.pack_into/__module__.__eq__('struct')==True / struct.unpack_from/__module__.__eq__('struct')==True / struct.iter_unpack/__module__.__eq__('struct')==True — pack_into/unpack_from/iter_unpack are exposed in the struct namespace; __module__ is 'struct'; struct_extra8 covers __module__ on attribute-read axis; struct_extra63 adds call form for pack/unpack/calcsize; this spec extends to pack_into/unpack_from/iter_unpack; no prior struct spec checks __module__.__eq__ in call form for these three; first __module__ call-form anchor for pack_into/unpack_from/iter_unpack"
  kind: python_call_eq
  category: module_identity
  id_prefix: structext64

  columns: [id, function, args, expected]
  rows:
    - [pack_into_module_eq_struct,    pack_into.__module__.__eq__,    ["struct"], true]
    - [unpack_from_module_eq_struct,  unpack_from.__module__.__eq__,  ["struct"], true]
    - [iter_unpack_module_eq_struct,  iter_unpack.__module__.__eq__,  ["struct"], true]

# ---------------------------------------------------------------------------
# struct module-level C function pack_into / unpack_from / iter_unpack __class__.__name__
#
# Wave 235 theme: pack_into/unpack_from/iter_unpack are C builtins.
#
# struct.pack_into, unpack_from, and iter_unpack are module-level C builtin
# functions. __class__.__name__ is 'builtin_function_or_method' for each.
# struct_extra63 covers pack/unpack/calcsize class names; this spec extends
# to pack_into/unpack_from/iter_unpack. No prior struct spec checks
# __class__.__name__ for these three. Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

table struct_extra64.module_func_classes_ext:
  description: "struct.pack_into/__class__/__name__=='builtin_function_or_method' / struct.unpack_from/__class__/__name__=='builtin_function_or_method' / struct.iter_unpack/__class__/__name__=='builtin_function_or_method' — pack_into/unpack_from/iter_unpack are module-level C builtin functions; struct_extra63 covers pack/unpack/calcsize class names; this spec extends to pack_into/unpack_from/iter_unpack; no prior struct spec checks __class__/__name__ for these three; first C builtin class identity anchor for pack_into/unpack_from/iter_unpack"
  kind: python_call_eq
  category: class_identity
  id_prefix: structext64

  columns: [id, function, args, expected]
  rows:
    - [pack_into_class_builtin_function,    pack_into.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [unpack_from_class_builtin_function,  unpack_from.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [iter_unpack_class_builtin_function,  iter_unpack.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# struct.Struct.pack_into and Struct.unpack_from __class__.__name__ == 'method_descriptor'
#
# Wave 235 theme: Struct.pack_into and Struct.unpack_from C method descriptor class.
#
# struct_extra62 covers method_descriptor for Struct.pack and Struct.unpack.
# This spec extends to Struct.pack_into and Struct.unpack_from — both are
# unbound C method descriptors on the Struct C extension type.
# No prior struct spec checks __class__.__name__ for Struct.pack_into or
# Struct.unpack_from. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra64.Struct_method_class_ext:
  description: "struct.Struct.pack_into/__class__/__name__=='method_descriptor' / struct.Struct.unpack_from/__class__/__name__=='method_descriptor' — Struct.pack_into and Struct.unpack_from are unbound C method descriptors on the Struct type; struct_extra62 covers method_descriptor for Struct.pack and Struct.unpack; this spec adds Struct.pack_into and Struct.unpack_from; no prior struct spec checks __class__/__name__ for Struct.pack_into or Struct.unpack_from; first method_descriptor class identity anchor for these two Struct methods"
  kind: python_call_eq
  category: class_identity
  id_prefix: structext64

  columns: [id, function, args, expected]
  rows:
    - [Struct_pack_into_class_method_descriptor,   Struct.pack_into.__class__.__name__.__eq__,   ["method_descriptor"], true]
    - [Struct_unpack_from_class_method_descriptor, Struct.unpack_from.__class__.__name__.__eq__, ["method_descriptor"], true]

# ---------------------------------------------------------------------------
# struct.pack_into.__qualname__.__eq__('pack_into') — standalone
#
# struct.pack_into is a C builtin function at module level. __qualname__ is
# 'pack_into'. struct_extra63 covers pack/unpack/calcsize qualnames. No prior
# struct spec checks pack_into.__qualname__.__eq__. First qualname equality
# standalone for struct.pack_into.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra64.pack_into_qualname:
  description: "struct.pack_into.__qualname__.__eq__('pack_into') == True — pack_into is a module-level C builtin; __qualname__=='pack_into' (equals __name__); struct_extra63 covers pack/unpack/calcsize qualnames; no prior struct spec checks pack_into.__qualname__.__eq__; first qualname equality standalone for struct.pack_into"
  category: qualnames
  kind: python_call_eq
  function: pack_into.__qualname__.__eq__
  args: ["pack_into"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack_from.__qualname__.__eq__('unpack_from') — standalone
#
# struct.unpack_from is a C builtin function at module level. __qualname__ is
# 'unpack_from'. No prior struct spec checks unpack_from.__qualname__.__eq__.
# First qualname equality standalone for struct.unpack_from.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra64.unpack_from_qualname:
  description: "struct.unpack_from.__qualname__.__eq__('unpack_from') == True — unpack_from is a module-level C builtin; __qualname__=='unpack_from'; no prior struct spec checks unpack_from.__qualname__.__eq__; first qualname equality standalone for struct.unpack_from"
  category: qualnames
  kind: python_call_eq
  function: unpack_from.__qualname__.__eq__
  args: ["unpack_from"]
  expected: true

# ---------------------------------------------------------------------------
# struct.iter_unpack.__qualname__.__eq__('iter_unpack') — standalone
#
# struct.iter_unpack is a C builtin function at module level. __qualname__ is
# 'iter_unpack'. No prior struct spec checks iter_unpack.__qualname__.__eq__.
# First qualname equality standalone for struct.iter_unpack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra64.iter_unpack_qualname:
  description: "struct.iter_unpack.__qualname__.__eq__('iter_unpack') == True — iter_unpack is a module-level C builtin; __qualname__=='iter_unpack'; no prior struct spec checks iter_unpack.__qualname__.__eq__; first qualname equality standalone for struct.iter_unpack"
  category: qualnames
  kind: python_call_eq
  function: iter_unpack.__qualname__.__eq__
  args: ["iter_unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack_into.__module__.__eq__('struct') — standalone
#
# struct.pack_into is exposed in the struct module namespace. __module__ is
# 'struct'. struct_extra8 covers __module__ on attribute-read axis; struct_extra63
# adds call form for pack/unpack/calcsize. No prior struct spec checks
# pack_into.__module__.__eq__. First __module__ call-form standalone for
# struct.pack_into. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra64.pack_into_module_struct:
  description: "struct.pack_into.__module__.__eq__('struct') == True — pack_into is exposed in the struct namespace; __module__ is 'struct'; struct_extra8 covers attribute-read axis; struct_extra63 adds call form for pack/unpack/calcsize; no prior struct spec checks pack_into.__module__.__eq__; first __module__ call-form standalone for struct.pack_into"
  category: module_identity
  kind: python_call_eq
  function: pack_into.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__class__.__name__.__eq__('method_descriptor') — standalone
#
# struct.Struct.unpack_from is a C method descriptor on the Struct type.
# Its __class__.__name__ is 'method_descriptor'. struct_extra62 covers
# method_descriptor for Struct.pack and Struct.unpack. No prior struct spec
# checks Struct.unpack_from.__class__.__name__. First method_descriptor class
# identity standalone for struct.Struct.unpack_from.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra64.Struct_unpack_from_qualname_eq:
  description: "struct.Struct.unpack_from.__class__.__name__.__eq__('method_descriptor') == True — Struct.unpack_from is a C method descriptor on the Struct type; __class__.__name__ is 'method_descriptor'; struct_extra62 covers method_descriptor for Struct.pack and Struct.unpack; no prior struct spec checks Struct.unpack_from.__class__.__name__; first method_descriptor class identity standalone for struct.Struct.unpack_from"
  category: class_identity
  kind: python_call_eq
  function: Struct.unpack_from.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true
