spec: zipfile_extra5
version: ">=3.9"
backend: python_module(zipfile)

docs: https://docs.python.org/3/library/zipfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipfile.html — Python zipfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipfile/__init__.py"
    - "zipfile.zspec.zsdl — covers core ZipFile open/read/write/namelist behaviors and BadZipFile raises"
    - "zipfile_extra.zspec.zsdl — covers ZipFile.__name__, ZipInfo.__name__, BadZipFile.__name__, LargeZipFile.__name__, Path.__name__, ZipFile.__module__, BadZipFile.__bases__[0].__name__, is_zipfile.__name__, all ZIP_* class names, all ZIP_* values"
    - "zipfile_extra2.zspec.zsdl — covers table-form class names, constant type checks"
    - "zipfile_extra3.zspec.zsdl — covers ZipFile.__module__, ZipInfo.__module__, BadZipFile.__module__, ZIP_STORED/ZIP_DEFLATED class names and values, ZipFile/ZipInfo type identity"
    - "zipfile_extra4.zspec.zsdl — covers ZIP_STORED/ZIP_DEFLATED/ZIP_BZIP2/ZIP_LZMA equality, class __name__ table, is_zipfile.__name__, ZipFile.__module__ invariant, BadZipFile/LargeZipFile bases, ZipInfo instance class, ZipInfo filename attr, ZIP_STORED class name"
  notes:
    - "This spec covers __qualname__ attributes for zipfile classes and functions — not covered in prior zipfile specs."
    - "zipfile.ZipFile.__qualname__ == 'ZipFile' — qualname equals name for top-level class."
    - "zipfile.ZipInfo.__qualname__ == 'ZipInfo' — qualname equals name for top-level class."
    - "zipfile.Path.__qualname__ == 'Path' — qualname equals name for top-level class."
    - "zipfile.BadZipFile.__qualname__ == 'BadZipFile' — qualname equals name for top-level exception class."
    - "zipfile.LargeZipFile.__qualname__ == 'LargeZipFile' — qualname equals name for top-level exception class."
    - "zipfile.is_zipfile.__qualname__ == 'is_zipfile' — qualname equals name for top-level function."
    - "zipfile.is_zipfile.__module__ == 'zipfile' — function is defined in zipfile module."
    - "zipfile.ZIP_BZIP2.__class__.__name__ == 'int' — not yet checked in prior specs."
    - "zipfile.ZIP_LZMA.__class__.__name__ == 'int' — not yet checked in prior specs."
    - "zipfile.LargeZipFile.__module__ == 'zipfile' — exception class module identity."
    - "zipfile.Path.__module__ == 'zipfile' — Path class module identity."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for top-level zipfile classes
# Not covered in any prior zipfile spec (prior specs only used __name__)
# ---------------------------------------------------------------------------

table zipfile_extra5.class_qualnames:
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: cqname

  columns: [id, function, args, expected]
  rows:
    - [ZipFile,      ZipFile.__qualname__.__eq__,      ["ZipFile"],      true]
    - [ZipInfo,      ZipInfo.__qualname__.__eq__,      ["ZipInfo"],      true]
    - [Path,         Path.__qualname__.__eq__,         ["Path"],         true]
    - [BadZipFile,   BadZipFile.__qualname__.__eq__,   ["BadZipFile"],   true]
    - [LargeZipFile, LargeZipFile.__qualname__.__eq__, ["LargeZipFile"], true]

# ---------------------------------------------------------------------------
# __qualname__ check for is_zipfile function
# ---------------------------------------------------------------------------

table zipfile_extra5.function_qualnames:
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [is_zipfile, is_zipfile.__qualname__.__eq__, ["is_zipfile"], true]

# ---------------------------------------------------------------------------
# __module__ checks not covered in prior specs
# zipfile_extra3 covers ZipFile, ZipInfo, BadZipFile __module__
# zipfile_extra4 covers ZipFile.__module__ (invariant form)
# New: LargeZipFile, Path, is_zipfile modules
# ---------------------------------------------------------------------------

table zipfile_extra5.extra_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [LargeZipFile, LargeZipFile.__module__.__eq__, ["zipfile"], true]
    - [Path,         Path.__module__.__eq__,         ["zipfile"], true]
    - [is_zipfile,   is_zipfile.__module__.__eq__,   ["zipfile"], true]

# ---------------------------------------------------------------------------
# ZIP_BZIP2 and ZIP_LZMA class name checks
# zipfile_extra3 only checked ZIP_STORED and ZIP_DEFLATED class names
# zipfile_extra4 only checked ZIP_STORED class name
# New: ZIP_BZIP2 and ZIP_LZMA class names
# ---------------------------------------------------------------------------

table zipfile_extra5.extra_constant_class_names:
  kind: python_call_eq
  category: constants
  id_prefix: consttype

  columns: [id, function, args, expected]
  rows:
    - [ZIP_BZIP2, ZIP_BZIP2.__class__.__name__.__eq__, ["int"], true]
    - [ZIP_LZMA,  ZIP_LZMA.__class__.__name__.__eq__,  ["int"], true]
