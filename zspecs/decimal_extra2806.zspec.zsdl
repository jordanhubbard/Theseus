spec: decimal_extra2806
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2791.zspec.zsdl — covers __iand__/__ior__/__ixor__ dict-presence"
    - "decimal_extra2776.zspec.zsdl — covers __isub__/__imul__/__itruediv__ dict-presence"
    - "decimal_extra2761.zspec.zsdl — covers __matmul__/__truediv__/__iadd__ dict-presence"
    - "decimal_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "decimal_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
  notes:
    - "Wave 634 (decimal_extra2806) theme: __ilshift__, __irshift__, and __ipow__ dict-presence checks."
    - "decimal.Decimal does NOT define __ilshift__, __irshift__, or __ipow__ in its own __dict__."
    - "Although decimal.Decimal defines arithmetic operators such as __add__, __sub__, and __pow__, it is an immutable decimal floating-point type and does not implement in-place shift operator hooks."
    - "decimal.Context and decimal.DecimalException also do NOT define __ilshift__, __irshift__, or __ipow__ in their own __dict__."
    - "__ilshift__ supports the <<= operator; Decimal is a decimal floating-point type and has no bitwise left-shift semantics."
    - "__irshift__ supports the >>= operator; Decimal does not implement in-place right-shift semantics."
    - "__ipow__ supports the **= operator; Decimal defines __pow__ for exponentiation but not the in-place __ipow__ variant."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __ilshift__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2806.no_ilshift_in_decimal_classes:
  description: "__ilshift__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal is a decimal floating-point type with no bitwise left-shift semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2806

  columns: [id, function, args, expected]
  rows:
    - ["dc2806001", "decimal.Decimal.__dict__.__contains__",          ["__ilshift__"], false]
    - ["dc2806002", "decimal.Context.__dict__.__contains__",          ["__ilshift__"], false]
    - ["dc2806003", "decimal.DecimalException.__dict__.__contains__", ["__ilshift__"], false]

# ---------------------------------------------------------------------------
# __irshift__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2806.no_irshift_in_decimal_classes:
  description: "__irshift__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal does not implement >>= in-place right-shift"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2806

  columns: [id, function, args, expected]
  rows:
    - ["dc2806004", "decimal.Decimal.__dict__.__contains__",          ["__irshift__"], false]
    - ["dc2806005", "decimal.Context.__dict__.__contains__",          ["__irshift__"], false]
    - ["dc2806006", "decimal.DecimalException.__dict__.__contains__", ["__irshift__"], false]

# ---------------------------------------------------------------------------
# __ipow__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2806.no_ipow_in_decimal_classes:
  description: "__ipow__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s — Decimal defines __pow__ but not the in-place __ipow__ variant"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2806

  columns: [id, function, args, expected]
  rows:
    - ["dc2806007", "decimal.Decimal.__dict__.__contains__",          ["__ipow__"], false]
    - ["dc2806008", "decimal.Context.__dict__.__contains__",          ["__ipow__"], false]
    - ["dc2806009", "decimal.DecimalException.__dict__.__contains__", ["__ipow__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal defines binary arithmetic hooks but none of the in-place shift variants
# Contrasts Decimal's __pow__/__add__/__mul__ presence with absent __ilshift__/__irshift__/__ipow__
# ---------------------------------------------------------------------------

table decimal_extra2806.decimal_has_binary_ops_but_not_inplace_shift_pow_variants:
  description: "decimal.Decimal defines __pow__/__add__/__mul__ but NOT __ilshift__/__irshift__/__ipow__; decimal.Context has sqrt/exp/ln but none of the in-place shift or exponentiation hooks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2806

  columns: [id, function, args, expected]
  rows:
    - ["dc2806010", "decimal.Decimal.__dict__.__contains__", ["__pow__"],     true]
    - ["dc2806011", "decimal.Decimal.__dict__.__contains__", ["__add__"],     true]
    - ["dc2806012", "decimal.Decimal.__dict__.__contains__", ["__mul__"],     true]
    - ["dc2806013", "decimal.Decimal.__dict__.__contains__", ["__ilshift__"], false]
    - ["dc2806014", "decimal.Decimal.__dict__.__contains__", ["__irshift__"], false]
    - ["dc2806015", "decimal.Decimal.__dict__.__contains__", ["__ipow__"],    false]
    - ["dc2806016", "decimal.Context.__dict__.__contains__", ["sqrt"],        true]
    - ["dc2806017", "decimal.Context.__dict__.__contains__", ["exp"],         true]
    - ["dc2806018", "decimal.Context.__dict__.__contains__", ["ln"],          true]
    - ["dc2806019", "decimal.Context.__dict__.__contains__", ["__ilshift__"], false]
    - ["dc2806020", "decimal.Context.__dict__.__contains__", ["__irshift__"], false]
    - ["dc2806021", "decimal.Context.__dict__.__contains__", ["__ipow__"],    false]
