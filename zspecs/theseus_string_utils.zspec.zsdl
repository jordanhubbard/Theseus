spec: theseus_string_utils
version: ">=3.9"
backend: python_cleanroom(theseus_string_utils)
blocks: string

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html"
  notes:
    - "Clean-room string template and capwords utilities. Do NOT import string."
    - "capwords(s) capitalizes each word: capwords('hello world') == 'Hello World'."
    - "ascii_letters: string of all ASCII letters a-z and A-Z (52 chars total)."
    - "digits: string '0123456789'."
    - "Template(tmpl).substitute(mapping) replaces $key or ${key} with mapping values."
    - "Export: capwords(s: str, sep=None) -> str, ascii_letters: str, digits: str."
    - "Template class with substitute(mapping) method."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_string_utils.capwords:
  description: "capwords('hello world') == 'Hello World'"
  category: capwords
  kind: python_call_eq
  function: string_capwords
  args: []
  expected: "Hello World"

invariant theseus_string_utils.digits:
  description: "digits == '0123456789'"
  category: constants
  kind: python_call_eq
  function: string_digits
  args: []
  expected: "0123456789"

invariant theseus_string_utils.ascii_letters_len:
  description: "len(ascii_letters) == 52"
  category: constants
  kind: python_call_eq
  function: string_ascii_letters_len
  args: []
  expected: 52
