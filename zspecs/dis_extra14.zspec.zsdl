spec: dis_extra14
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis_extra4.zspec.zsdl — covers opmap.__contains__ for several opcodes; opname.__len__ >= 100"
    - "dis_extra11.zspec.zsdl — covers opmap.__len__==154; opcode list lengths"
    - "dis_extra12.zspec.zsdl — covers cmp_op.__class__.__name__=='tuple'; cmp_op[0]=='<'; hasjump class and len; deoptmap class"
    - "dis_extra13.zspec.zsdl — covers opname.len_256; opmap.class; HAVE_ARGUMENT class/ge_one; cmp_op.len_ge_6; function_names table; dis.__module__"
  notes:
    - "This spec extends dis_extra13.zspec.zsdl."
    - "dis.opmap.__contains__ checks for LOAD_CONST/LOAD_FAST/STORE_FAST/POP_TOP/JUMP_FORWARD — dis_extra4 covers a subset in a table; this table adds JUMP_FORWARD and assembles all five in the dis_extra14 namespace."
    - "dis.opmap.__len__() >= 50 — dis_extra11 verifies exact count of 154; this records a version-stable lower bound in the dis_extra14 namespace."
    - "dis.Instruction.__name__ == 'Instruction' — dis_extra4/dis_extra11 cover __qualname__; no prior spec checks __name__ standalone in the dis_extra14 namespace."
    - "dis.Bytecode.__name__ == 'Bytecode' — dis_extra5/dis_extra11 cover __qualname__; no prior spec checks __name__ standalone in the dis_extra14 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# opmap — __contains__ checks for always-present opcodes
#
# dis_extra4 covers a subset of opmap __contains__ rows. This table records
# LOAD_CONST, LOAD_FAST, STORE_FAST, POP_TOP, and JUMP_FORWARD as distinct
# invariant IDs in the dis_extra14 namespace. These opcodes exist across all
# supported CPython versions (3.9+).
# ---------------------------------------------------------------------------

table dis_extra14.opmap_contains:
  kind: python_call_eq
  category: opmap
  id_prefix: contains

  columns: [id, function, args, expected]
  rows:
    - [LOAD_CONST,    opmap.__contains__,  ["LOAD_CONST"],    true]
    - [LOAD_FAST,     opmap.__contains__,  ["LOAD_FAST"],     true]
    - [STORE_FAST,    opmap.__contains__,  ["STORE_FAST"],    true]
    - [POP_TOP,       opmap.__contains__,  ["POP_TOP"],       true]
    - [JUMP_FORWARD,  opmap.__contains__,  ["JUMP_FORWARD"],  true]

# ---------------------------------------------------------------------------
# opmap — lower-bound length
#
# dis_extra11 verifies opmap.__len__() == 154 for Python 3.12. This records a
# version-stable lower bound of 50 in the dis_extra14 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra14.opmap.len_ge_50:
  description: "dis.opmap.__len__() >= 50 — opmap has at least 50 named opcodes across all supported versions"
  category: opmap
  kind: python_call_eq
  function: opmap.__len__().__ge__
  args: [50]
  expected: true

# ---------------------------------------------------------------------------
# Instruction and Bytecode — __name__ checks (dis_extra14 namespace)
#
# dis_extra4 and dis_extra11 verify __qualname__ for Instruction/Bytecode.
# No prior dis spec checks __name__ for either class as a standalone invariant
# in the dis_extra14 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra14.Instruction.name:
  description: "dis.Instruction.__name__ == 'Instruction' — the named tuple class for disassembled instructions"
  category: class_names
  kind: python_call_eq
  function: Instruction.__name__.__eq__
  args: ["Instruction"]
  expected: true

invariant dis_extra14.Bytecode.name:
  description: "dis.Bytecode.__name__ == 'Bytecode' — the iterator class for bytecode disassembly"
  category: class_names
  kind: python_call_eq
  function: Bytecode.__name__.__eq__
  args: ["Bytecode"]
  expected: true

# ---------------------------------------------------------------------------
# Instruction and Bytecode — __module__ checks (dis_extra14 namespace)
#
# dis_extra8 covers __module__ for major dis public names. Instruction and
# Bytecode __module__ have not been verified as standalone invariants in the
# dis_extra14 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra14.Instruction.module:
  description: "dis.Instruction.__module__ == 'dis' — Instruction is defined in the dis module"
  category: module_attrs
  kind: python_call_eq
  function: Instruction.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra14.Bytecode.module:
  description: "dis.Bytecode.__module__ == 'dis' — Bytecode is defined in the dis module"
  category: module_attrs
  kind: python_call_eq
  function: Bytecode.__module__.__eq__
  args: ["dis"]
  expected: true

# ---------------------------------------------------------------------------
# stack_effect and get_instructions — __module__ (dis_extra14 namespace)
#
# dis_extra3 and dis_extra8 cover __module__ for these functions in prior
# namespaces. These are distinct standalone IDs in the dis_extra14 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra14.stack_effect.module:
  description: "dis.stack_effect.__module__ == 'dis' — stack_effect is defined in the dis module"
  category: module_attrs
  kind: python_call_eq
  function: stack_effect.__module__.__eq__
  args: ["dis"]
  expected: true

invariant dis_extra14.get_instructions.module:
  description: "dis.get_instructions.__module__ == 'dis' — get_instructions is defined in the dis module"
  category: module_attrs
  kind: python_call_eq
  function: get_instructions.__module__.__eq__
  args: ["dis"]
  expected: true
