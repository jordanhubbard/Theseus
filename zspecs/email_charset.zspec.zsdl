spec: email_charset
version: ">=3.3"
backend: python_module(email.charset)

docs: https://docs.python.org/3/library/email.charset.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/email.charset.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "email.charset source: Lib/email/charset.py (PSF; source inspection permitted)"
  not_derived_from:
    - "email.charset source: codec registry internals"
  notes:
    - "email.charset provides the Charset class and three module-level registration functions."
    - "Charset encapsulates a character set name and its email encoding/decoding rules."
    - "add_alias(alias, canonical) registers a charset alias in the internal alias map."
    - "add_charset(name, ...) registers a new charset with header and body encoding preferences."
    - "add_codec(name, codec) maps a charset name to a Python codec name."
    - "Charset('utf-8').get_output_charset() returns 'utf-8' — utf-8 maps to itself."
    - "Charset.__bases__[0].__name__ == 'object' — Charset has no non-trivial base class."
    - "All expected values verified by running Python 3.12 email.charset module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name and module checks
# ---------------------------------------------------------------------------

table email_charset.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: classname

  columns: [id, function, args, expected]
  rows:
    - [Charset, Charset.__name__.__eq__, ["Charset"], true]

table email_charset.module_checks:
  kind: python_call_eq
  category: module_checks
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Charset, Charset.__module__.__eq__, ["email.charset"], true]

# ---------------------------------------------------------------------------
# Inheritance
# ---------------------------------------------------------------------------

invariant email_charset.Charset_base:
  description: "Charset.__bases__[0].__name__ == 'object' — Charset has no non-trivial base class"
  category: inheritance
  kind: python_call_eq
  function: Charset.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

table email_charset.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [add_alias,   add_alias.__name__.__eq__,   ["add_alias"],   true]
    - [add_charset, add_charset.__name__.__eq__,  ["add_charset"], true]
    - [add_codec,   add_codec.__name__.__eq__,    ["add_codec"],   true]

# ---------------------------------------------------------------------------
# Instantiation
# ---------------------------------------------------------------------------

invariant email_charset.Charset_instantiable:
  description: "Charset('utf-8').__class__.__name__ == 'Charset' — Charset can be instantiated with a charset name"
  category: instantiation
  kind: python_call_eq
  function: Charset
  args: ["utf-8"]
  method: __class__.__name__.__eq__
  method_args: ["Charset"]
  expected: true

# ---------------------------------------------------------------------------
# Charset behaviour
# ---------------------------------------------------------------------------

invariant email_charset.Charset_get_output_charset:
  description: "Charset('utf-8').get_output_charset() == 'utf-8' — utf-8 maps to itself as the output charset"
  category: behaviour
  kind: python_call_eq
  function: Charset
  args: ["utf-8"]
  method: get_output_charset
  method_args: []
  expected: "utf-8"

