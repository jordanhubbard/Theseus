spec: socket_extra283
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 791 — Internet Protocol"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 791 — Internet Protocol, DARPA, September 1981"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "This spec extends socket.zspec.zsdl through socket_extra282.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "socket_extra282.zspec.zsdl covers: socket.socket context manager (__enter__/__exit__/close __qualname__ and __class__.__name__); socket.socket.__name__ == 'socket'; socket.socket.__module__ == 'socket'; __enter__ returns self; enter/exit co_argcount."
    - "This spec focuses on: socket.create_connection module; socket.getaddrinfo module; socket.error name/module/base; socket.timeout name/base; socket.AF_INET integer value via __eq__; socket.SOCK_STREAM integer value via __eq__; socket.create_server module."
    - "socket.create_connection.__module__ == 'socket' — pure-Python function in socket module. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.getaddrinfo.__module__ is a str — the module attribute exists; value is platform-dependent ('socket' or '_socket'). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.error.__name__ == 'OSError' — socket.error is an alias for OSError since Python 3.3. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.error.__module__ == 'builtins' — OSError lives in builtins. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.timeout.__name__ == 'TimeoutError' — socket.timeout is an alias for TimeoutError since Python 3.3. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.timeout.__bases__[0].__name__ == 'OSError' — TimeoutError inherits from OSError. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.AF_INET == 2 — universally stable POSIX constant (POSIX.1-2017). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.SOCK_STREAM == 1 — universally stable POSIX constant (POSIX.1-2017). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.create_server was added in Python 3.8; __module__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "socket raises OSError (and subclasses herror, gaierror, timeout) for I/O failures. Class and module attribute checks are stateless and never raise."
  stderr: "null"
  stickiness: "N/A — all tested invariants are class name, module name, or constant value checks."
  codes: {}

# ---------------------------------------------------------------------------
# socket.error — alias for OSError since Python 3.3
# socket.error.__name__ == 'OSError' — it picks up the aliased class name.
# socket.error.__module__ == 'builtins' — OSError is defined in builtins.
# socket.error.__bases__[0].__name__ == 'Exception' — OSError inherits from Exception.
# ---------------------------------------------------------------------------

invariant socket_extra283.error.name:
  description: "socket.error.__name__ == 'OSError' — socket.error is an alias for OSError; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: exceptions
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

invariant socket_extra283.error.module:
  description: "socket.error.__module__ == 'builtins' — OSError is defined in the builtins module; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: exceptions
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant socket_extra283.error.base_class:
  description: "socket.error.__bases__[0].__name__ == 'Exception' — OSError inherits from Exception; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: exceptions
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# socket.timeout — alias for TimeoutError since Python 3.3
# socket.timeout.__name__ == 'TimeoutError'.
# socket.timeout.__bases__[0].__name__ == 'OSError' — TimeoutError inherits from OSError.
# ---------------------------------------------------------------------------

invariant socket_extra283.timeout.name:
  description: "socket.timeout.__name__ == 'TimeoutError' — socket.timeout is an alias for TimeoutError; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: exceptions
  kind: python_call_eq
  function: timeout.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant socket_extra283.timeout.base_class:
  description: "socket.timeout.__bases__[0].__name__ == 'OSError' — TimeoutError inherits from OSError; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: exceptions
  kind: python_call_eq
  function: timeout.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "OSError"

# ---------------------------------------------------------------------------
# socket.create_connection and socket.create_server — module identity
# Both are pure-Python functions defined in the socket module (not the C _socket ext).
# create_connection was added in Python 3.0; create_server was added in Python 3.8.
# ---------------------------------------------------------------------------

table socket_extra283.function_modules:
  description: "socket.create_connection and socket.create_server __module__ == 'socket'; verified with Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: function_identity
  id_prefix: fnmod283

  columns: [id, function, args, expected, description]
  rows:
    - [create_connection_module, "create_connection.__module__.__eq__", ["socket"], true, "create_connection is a pure-Python function in the socket module"]
    - [create_server_module,     "create_server.__module__.__eq__",     ["socket"], true, "create_server is a pure-Python function in the socket module (Python 3.8+)"]

# ---------------------------------------------------------------------------
# socket.AF_INET and socket.SOCK_STREAM — integer value checks
# AF_INET == 2 and SOCK_STREAM == 1 are universally stable POSIX constants.
# These are the same checks as socket_extra2 but using the __eq__ attribute
# idiom for consistency with later specs in this series.
# ---------------------------------------------------------------------------

invariant socket_extra283.constants.AF_INET:
  description: "socket.AF_INET == 2 — universally stable POSIX constant; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: constants
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

invariant socket_extra283.constants.SOCK_STREAM:
  description: "socket.SOCK_STREAM == 1 — universally stable POSIX constant; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_INET and socket.SOCK_STREAM — enum class name checks
# AF_INET is an IntEnum member of AddressFamily; SOCK_STREAM is a SocketKind member.
# ---------------------------------------------------------------------------

invariant socket_extra283.constants.AF_INET_class:
  description: "socket.AF_INET.__class__.__name__ == 'AddressFamily' — AF_INET is an IntEnum value; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: constants
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__eq__
  args: ["AddressFamily"]
  expected: true

invariant socket_extra283.constants.SOCK_STREAM_class:
  description: "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' — SOCK_STREAM is an IntEnum value; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__eq__
  args: ["SocketKind"]
  expected: true
