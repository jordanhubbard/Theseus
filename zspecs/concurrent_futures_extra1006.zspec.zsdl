spec: concurrent_futures_extra1006
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures.ProcessPoolExecutor, Executor, and Future method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1006.processpoolexecutor_qualnames:
  description: "concurrent.futures.ProcessPoolExecutor method __qualname__ identity"
  kind: python_call_eq
  category: processpoolexecutor_qualnames
  id_prefix: cf1006pp
  columns: [id, function, args, expected]
  rows:
    - [cf1006pp001, concurrent.futures.ProcessPoolExecutor.__init__.__qualname__.__eq__,     ["ProcessPoolExecutor.__init__"],     true]
    - [cf1006pp002, concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__eq__,       ["ProcessPoolExecutor.submit"],       true]
    - [cf1006pp003, concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__,          ["ProcessPoolExecutor.map"],          true]
    - [cf1006pp004, concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__eq__,     ["ProcessPoolExecutor.shutdown"],     true]
    - [cf1006pp005, concurrent.futures.ProcessPoolExecutor.__name__.__eq__,                  ["ProcessPoolExecutor"],              true]
    - [cf1006pp006, concurrent.futures.ProcessPoolExecutor.__module__.__eq__,                ["concurrent.futures.process"],      true]

table concurrent_futures_extra1006.executor_qualnames:
  description: "concurrent.futures.Executor method __qualname__ identity"
  kind: python_call_eq
  category: executor_qualnames
  id_prefix: cf1006ex
  columns: [id, function, args, expected]
  rows:
    - [cf1006ex001, concurrent.futures.Executor.__enter__.__qualname__.__eq__, ["Executor.__enter__"], true]
    - [cf1006ex002, concurrent.futures.Executor.__exit__.__qualname__.__eq__,  ["Executor.__exit__"],  true]
    - [cf1006ex003, concurrent.futures.Executor.__name__.__eq__,               ["Executor"],           true]
    - [cf1006ex004, concurrent.futures.Executor.__module__.__eq__,             ["concurrent.futures"], true]

table concurrent_futures_extra1006.future_qualnames:
  description: "concurrent.futures.Future method __qualname__ identity"
  kind: python_call_eq
  category: future_qualnames
  id_prefix: cf1006fu
  columns: [id, function, args, expected]
  rows:
    - [cf1006fu001, concurrent.futures.Future.__repr__.__qualname__.__eq__, ["Future.__repr__"], true]
    - [cf1006fu002, concurrent.futures.Future.__str__.__qualname__.__eq__,  ["Future.__str__"],  true]
    - [cf1006fu003, concurrent.futures.Future.__name__.__eq__,              ["Future"],          true]
    - [cf1006fu004, concurrent.futures.Future.__module__.__eq__,            ["concurrent.futures"], true]
    - [cf1006fu005, concurrent.futures.Future.__qualname__.__eq__,          ["Future"],          true]
