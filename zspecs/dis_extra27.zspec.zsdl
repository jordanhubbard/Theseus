spec: dis_extra27
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "dis_extra26.zspec.zsdl — covers dis/disassemble/code_info/show_code/get_instructions/Instruction __module__.__len__() and __name__.__len__() (table + standalone)."
    - "dis_extra25.zspec.zsdl — covers dis/disassemble/code_info/show_code/get_instructions/findlinestarts/findlabels __qualname__ standalone; Instruction/__qualname__ standalone."
    - "dis_extra24.zspec.zsdl — covers Instruction._fields/__len__() and _fields[0]/_fields[1]; Bytecode.__init__.__qualname__/__module__."
    - "dis_extra21.zspec.zsdl — covers dis/disassemble/get_instructions/findlinestarts/findlabels __qualname__.__eq__ (table); Instruction/__qualname__.__eq__ standalone."
  notes:
    - "This spec extends dis_extra26.zspec.zsdl."
    - "Prior specs covered: all dis/__name__/__module__/__qualname__ for top-level functions and Instruction class; __name__/__module__ length checks; Instruction._fields/__len__() and field values."
    - "This spec covers: dis.Bytecode class __module__/__name__/__qualname__ lengths; dis.Bytecode.info and Bytecode.from_traceback __qualname__/__name__ lengths; dis module-level function __qualname__.__len__() for dis/disassemble/distb/findlinestarts/get_instructions/code_info/show_code; dis.Instruction.__qualname__.__len__()."
    - "dis.Bytecode.__module__.__len__() == 3. Verified."
    - "dis.Bytecode.__name__.__len__() == 8. Verified."
    - "dis.Bytecode.__qualname__.__len__() == 8. Verified."
    - "dis.Bytecode.info.__qualname__ == 'Bytecode.info', __qualname__.__len__() == 13. Verified."
    - "dis.Bytecode.info.__name__ == 'info', __name__.__len__() == 4. Verified."
    - "dis.Bytecode.from_traceback.__qualname__ == 'Bytecode.from_traceback', __qualname__.__len__() == 23. Verified."
    - "dis.Bytecode.from_traceback.__name__ == 'from_traceback', __name__.__len__() == 14. Verified."
    - "dis.dis.__qualname__.__len__() == 3. dis.disassemble.__qualname__.__len__() == 11. dis.distb.__qualname__.__len__() == 5. dis.findlinestarts.__qualname__.__len__() == 14. dis.get_instructions.__qualname__.__len__() == 16. dis.code_info.__qualname__.__len__() == 9. dis.show_code.__qualname__.__len__() == 9. Verified."
    - "dis.Instruction.__qualname__.__len__() == 11. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: dis.Bytecode class __module__/__name__/__qualname__ lengths
#
# No prior dis spec covers __len__() on Bytecode's class-level identity
# attributes. Bytecode.__module__ == 'dis' (3), __name__ == 'Bytecode' (8),
# __qualname__ == 'Bytecode' (8).
# Verified: module_len=3, name_len=8, qualname_len=8.
# ---------------------------------------------------------------------------

table dis_extra27.Bytecode_class_attr_lengths:
  description: "dis.Bytecode class __module__/__name__/__qualname__ lengths — 3/8/8"
  kind: python_call_eq
  category: class_identity
  id_prefix: bcal27

  columns: [id, function, args, expected]
  rows:
    - [module_len,   Bytecode.__module__.__len__,   [], 3]
    - [name_len,     Bytecode.__name__.__len__,     [], 8]
    - [qualname_len, Bytecode.__qualname__.__len__, [], 8]

# ---------------------------------------------------------------------------
# Table: dis.Bytecode method __qualname__/__name__ lengths
#
# dis_extra24 covers Bytecode.__init__.__qualname__/__module__. No prior dis
# spec covers __qualname__.__len__() or __name__.__len__() for Bytecode.info
# or Bytecode.from_traceback.
# Verified: info qualname_len=13, info name_len=4;
# from_traceback qualname_len=23, from_traceback name_len=14.
# ---------------------------------------------------------------------------

table dis_extra27.Bytecode_method_lengths:
  description: "dis.Bytecode method __qualname__/__name__ lengths — info and from_traceback"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: bcmlen27

  columns: [id, function, method, method_args, expected]
  rows:
    - [info_qualname_len,        Bytecode.info,          __qualname__.__len__, [], 13]
    - [info_name_len,            Bytecode.info,          __name__.__len__,     [], 4]
    - [from_traceback_qlen,      Bytecode.from_traceback, __qualname__.__len__, [], 23]
    - [from_traceback_nlen,      Bytecode.from_traceback, __name__.__len__,     [], 14]

# ---------------------------------------------------------------------------
# Standalone: dis.Bytecode.__name__.__len__() == 8
#
# 'Bytecode' has 8 characters. No prior dis spec covers __name__.__len__() for
# Bytecode as a standalone invariant.
# Verified: dis.Bytecode.__name__ == 'Bytecode', len=8.
# ---------------------------------------------------------------------------

invariant dis_extra27.Bytecode.name_len:
  description: "dis.Bytecode.__name__.__len__() == 8 — 'Bytecode' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: Bytecode.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Standalone: dis.Bytecode.from_traceback.__qualname__.__len__() == 23
#
# 'Bytecode.from_traceback' has 23 characters. No prior dis spec covers
# __qualname__.__len__() for Bytecode.from_traceback.
# Verified: dis.Bytecode.from_traceback.__qualname__ == 'Bytecode.from_traceback', len=23.
# ---------------------------------------------------------------------------

invariant dis_extra27.Bytecode_from_traceback.qualname_len:
  description: "dis.Bytecode.from_traceback.__qualname__.__len__() == 23 — 'Bytecode.from_traceback' has 23 characters"
  category: method_qualnames
  kind: python_call_eq
  function: Bytecode.from_traceback.__qualname__.__len__
  args: []
  expected: 23

# ---------------------------------------------------------------------------
# Table: dis module-level function __qualname__.__len__()
#
# For module-level functions, __qualname__ == __name__ (no class prefix).
# dis_extra25 covers these as __qualname__.__eq__ checks. No prior dis spec
# covers __qualname__.__len__() for any of these functions.
# Verified: dis=3, disassemble=11, distb=5, findlinestarts=14,
# get_instructions=16, code_info=9, show_code=9.
# ---------------------------------------------------------------------------

table dis_extra27.function_qualname_lengths:
  description: "__qualname__.__len__() for dis module-level functions — seven functions"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: fqlen27

  columns: [id, function, args, expected]
  rows:
    - [dis_func,         dis.__qualname__.__len__,              [], 3]
    - [disassemble,      disassemble.__qualname__.__len__,      [], 11]
    - [distb,            distb.__qualname__.__len__,            [], 5]
    - [findlinestarts,   findlinestarts.__qualname__.__len__,   [], 14]
    - [get_instructions, get_instructions.__qualname__.__len__, [], 16]
    - [code_info,        code_info.__qualname__.__len__,        [], 9]
    - [show_code,        show_code.__qualname__.__len__,        [], 9]

# ---------------------------------------------------------------------------
# Standalone: dis.Instruction.__qualname__.__len__() == 11
#
# 'Instruction' has 11 characters. dis_extra25 covers Instruction.__qualname__
# as a standalone __eq__ invariant. No prior dis spec covers __qualname__.__len__()
# for Instruction as a standalone invariant.
# Verified: dis.Instruction.__qualname__ == 'Instruction', len=11.
# ---------------------------------------------------------------------------

invariant dis_extra27.Instruction.qualname_len:
  description: "dis.Instruction.__qualname__.__len__() == 11 — 'Instruction' has 11 characters"
  category: string_lengths
  kind: python_call_eq
  function: Instruction.__qualname__.__len__
  args: []
  expected: 11
