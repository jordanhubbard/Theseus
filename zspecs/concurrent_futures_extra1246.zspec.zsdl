spec: concurrent_futures_extra1246
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures __doc__ class checks for module, Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor, wait, as_completed"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks that concurrent.futures module, Future, Executor, wait, and as_completed have str __doc__; ThreadPoolExecutor and ProcessPoolExecutor have NoneType __doc__; distinct from extra1231 (__dict__.__contains__), extra1201 (__bases__.__len__), extra1216 (__mro__.__len__)"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1246.module_and_core_class_doc_class:
  description: "concurrent.futures module __doc__ and core classes Future, Executor, wait, as_completed have str __doc__"
  kind: python_call_eq
  category: doc_class
  id_prefix: cf1246mc
  columns: [id, function, args, expected]
  rows:
    - [cf1246mc001, concurrent.futures.__doc__.__class__.__name__.__eq__,              ["str"], true]
    - [cf1246mc002, concurrent.futures.Future.__doc__.__class__.__name__.__eq__,       ["str"], true]
    - [cf1246mc003, concurrent.futures.Executor.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [cf1246mc004, concurrent.futures.wait.__doc__.__class__.__name__.__eq__,         ["str"], true]
    - [cf1246mc005, concurrent.futures.as_completed.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [cf1246mc006, concurrent.futures.__doc__.__class__.__name__.__eq__,              ["NoneType"], false]
    - [cf1246mc007, concurrent.futures.Future.__doc__.__class__.__name__.__eq__,       ["NoneType"], false]
    - [cf1246mc008, concurrent.futures.Executor.__doc__.__class__.__name__.__eq__,     ["NoneType"], false]
    - [cf1246mc009, concurrent.futures.wait.__doc__.__class__.__name__.__eq__,         ["NoneType"], false]
    - [cf1246mc010, concurrent.futures.as_completed.__doc__.__class__.__name__.__eq__, ["NoneType"], false]

table concurrent_futures_extra1246.executor_subclass_doc_is_nonetype:
  description: "concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor have NoneType __doc__ (no docstring on the class itself)"
  kind: python_call_eq
  category: doc_class
  id_prefix: cf1246en
  columns: [id, function, args, expected]
  rows:
    - [cf1246en001, concurrent.futures.ThreadPoolExecutor.__doc__.__class__.__name__.__eq__,  ["NoneType"], true]
    - [cf1246en002, concurrent.futures.ProcessPoolExecutor.__doc__.__class__.__name__.__eq__, ["NoneType"], true]
    - [cf1246en003, concurrent.futures.ThreadPoolExecutor.__doc__.__class__.__name__.__eq__,  ["str"],      false]
    - [cf1246en004, concurrent.futures.ProcessPoolExecutor.__doc__.__class__.__name__.__eq__, ["str"],      false]
    - [cf1246en005, concurrent.futures.ThreadPoolExecutor.__doc__.__class__.__name__.__eq__,  ["int"],      false]
    - [cf1246en006, concurrent.futures.ProcessPoolExecutor.__doc__.__class__.__name__.__eq__, ["int"],      false]

table concurrent_futures_extra1246.doc_class_not_int_or_float:
  description: "concurrent.futures module and key class __doc__ class name is not int, float, or list"
  kind: python_call_eq
  category: doc_class
  id_prefix: cf1246nf
  columns: [id, function, args, expected]
  rows:
    - [cf1246nf001, concurrent.futures.__doc__.__class__.__name__.__eq__,              ["int"],   false]
    - [cf1246nf002, concurrent.futures.__doc__.__class__.__name__.__eq__,              ["float"], false]
    - [cf1246nf003, concurrent.futures.__doc__.__class__.__name__.__eq__,              ["list"],  false]
    - [cf1246nf004, concurrent.futures.Future.__doc__.__class__.__name__.__eq__,       ["int"],   false]
    - [cf1246nf005, concurrent.futures.Future.__doc__.__class__.__name__.__eq__,       ["float"], false]
    - [cf1246nf006, concurrent.futures.Executor.__doc__.__class__.__name__.__eq__,     ["int"],   false]
    - [cf1246nf007, concurrent.futures.Executor.__doc__.__class__.__name__.__eq__,     ["float"], false]
    - [cf1246nf008, concurrent.futures.wait.__doc__.__class__.__name__.__eq__,         ["int"],   false]
    - [cf1246nf009, concurrent.futures.wait.__doc__.__class__.__name__.__eq__,         ["float"], false]
    - [cf1246nf010, concurrent.futures.as_completed.__doc__.__class__.__name__.__eq__, ["int"],   false]
