spec: secrets_extra2
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
  notes:
    - "This spec extends secrets.zspec.zsdl and secrets_extra.zspec.zsdl."
    - "secrets.zspec.zsdl covers: token_bytes/token_hex/token_urlsafe return-type class checks and length checks."
    - "secrets_extra.zspec.zsdl covers: token_bytes/__name__/__module__, token_hex/__name__, token_urlsafe/__name__, choice/__name__, randbelow/__name__, randbits/__name__, SystemRandom/__name__, and return-type checks."
    - "This spec adds: SystemRandom.__module__, choice/__module__, randbits/__module__, token_bytes return-value length at 32 bytes, token_hex str length at 2*n, token_urlsafe str isinstance check, and SystemRandom class inheritance."
    - "secrets.SystemRandom is re-exported from the random module; its __module__ is 'random'."
    - "secrets.choice and secrets.randbits are bound methods on a module-level SystemRandom instance; their __module__ reflects 'random'."
    - "token_hex(n) returns a hex string of exactly 2*n characters (each byte encodes as two hex digits)."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks
# (secrets_extra covers these; retained here as anchors for the extra2 family)
# ---------------------------------------------------------------------------

table secrets_extra2.function_names:
  description: "secrets module functions have __name__ equal to their identifier"
  kind: python_call_eq
  category: functions
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [token_bytes,    token_bytes.__name__.__eq__,    ["token_bytes"],    true]
    - [token_hex,      token_hex.__name__.__eq__,      ["token_hex"],      true]
    - [token_urlsafe,  token_urlsafe.__name__.__eq__,  ["token_urlsafe"],  true]
    - [choice,         choice.__name__.__eq__,         ["choice"],         true]
    - [randbits,       randbits.__name__.__eq__,       ["randbits"],       true]

# ---------------------------------------------------------------------------
# Function __module__ checks
# ---------------------------------------------------------------------------

invariant secrets_extra2.token_bytes.module:
  description: "secrets.token_bytes.__module__ == 'secrets'"
  category: modules
  kind: python_call_eq
  function: token_bytes.__module__.__eq__
  args: ["secrets"]
  expected: true

invariant secrets_extra2.token_hex.module:
  description: "secrets.token_hex.__module__ == 'secrets'"
  category: modules
  kind: python_call_eq
  function: token_hex.__module__.__eq__
  args: ["secrets"]
  expected: true

invariant secrets_extra2.token_urlsafe.module:
  description: "secrets.token_urlsafe.__module__ == 'secrets'"
  category: modules
  kind: python_call_eq
  function: token_urlsafe.__module__.__eq__
  args: ["secrets"]
  expected: true

# ---------------------------------------------------------------------------
# SystemRandom class — name and module
# ---------------------------------------------------------------------------

invariant secrets_extra2.SystemRandom.name:
  description: "secrets.SystemRandom.__name__ == 'SystemRandom' — re-exported from random"
  category: classes
  kind: python_call_eq
  function: SystemRandom.__name__.__eq__
  args: ["SystemRandom"]
  expected: true

invariant secrets_extra2.SystemRandom.module:
  description: "secrets.SystemRandom.__module__ == 'random' — SystemRandom is defined in random"
  category: classes
  kind: python_call_eq
  function: SystemRandom.__module__.__eq__
  args: ["random"]
  expected: true

invariant secrets_extra2.SystemRandom.base_is_Random:
  description: "secrets.SystemRandom.__bases__[0].__name__ == 'Random' — SystemRandom extends Random"
  category: classes
  kind: python_call_eq
  function: SystemRandom.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Random"

# ---------------------------------------------------------------------------
# Return type and size invariants
# ---------------------------------------------------------------------------

invariant secrets_extra2.token_bytes.len32:
  description: "len(secrets.token_bytes(32)) == 32 — returns exactly 32 bytes"
  category: return_types
  kind: python_call_eq
  function: token_bytes
  args: [32]
  method: __len__
  method_args: []
  expected: 32

invariant secrets_extra2.token_hex.len_is_twice_n:
  description: "len(secrets.token_hex(8)) == 16 — hex string is 2*n characters"
  category: return_types
  kind: python_call_eq
  function: token_hex
  args: [8]
  method: __len__
  method_args: []
  expected: 16

invariant secrets_extra2.token_bytes.class_is_bytes:
  description: "secrets.token_bytes(16).__class__.__name__ == 'bytes'"
  category: return_types
  kind: python_call_eq
  function: token_bytes
  args: [16]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant secrets_extra2.token_hex.class_is_str:
  description: "secrets.token_hex(8).__class__.__name__ == 'str'"
  category: return_types
  kind: python_call_eq
  function: token_hex
  args: [8]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant secrets_extra2.token_urlsafe.class_is_str:
  description: "secrets.token_urlsafe(8).__class__.__name__ == 'str'"
  category: return_types
  kind: python_call_eq
  function: token_urlsafe
  args: [8]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true
