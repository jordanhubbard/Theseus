spec: itertools_extra144
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.filterfalse (C type), itertools.takewhile (C type), itertools.dropwhile (C type), itertools.compress (C type), itertools.combinations_with_replacement (C type) — __name__ len, __qualname__ len, __module__, __doc__ len, MRO len (Wave 272)."
    - "itertools.filterfalse: __name__ == 'filterfalse' (len 11); __qualname__ == 'filterfalse' (len 11); __module__ == 'itertools'; __doc__ len == 120; MRO len == 2. Verified with Python 3.14.3."
    - "itertools.takewhile: __name__ == 'takewhile' (len 9); __qualname__ == 'takewhile' (len 9); __module__ == 'itertools'; __doc__ len == 101; MRO len == 2. Verified with Python 3.14.3."
    - "itertools.dropwhile: __name__ == 'dropwhile' (len 9); __qualname__ == 'dropwhile' (len 9); __module__ == 'itertools'; __doc__ len == 126; MRO len == 2. Verified with Python 3.14.3."
    - "itertools.compress: __name__ == 'compress' (len 8); __qualname__ == 'compress' (len 8); __module__ == 'itertools'; __doc__ len == 164; MRO len == 2. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement: __name__ == 'combinations_with_replacement' (len 29); __qualname__ == 'combinations_with_replacement' (len 29); __module__ == 'itertools'; __doc__ len == 234; MRO len == 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.filterfalse and itertools.takewhile — C type attrs
#
# Wave 272 theme: filtering C types in itertoolsmodule.c.
#
# itertools.filterfalse.__class__.__name__ == 'type'
# itertools.filterfalse.__name__ == 'filterfalse' (len 11)
# itertools.filterfalse.__qualname__ == 'filterfalse' (len 11)
# itertools.filterfalse.__module__ == 'itertools' (len 9)
# len(itertools.filterfalse.__doc__) == 120
# len(itertools.filterfalse.__mro__) == 2
# itertools.takewhile.__class__.__name__ == 'type'
# itertools.takewhile.__name__ == 'takewhile' (len 9)
# itertools.takewhile.__qualname__ == 'takewhile' (len 9)
# itertools.takewhile.__module__ == 'itertools' (len 9)
# len(itertools.takewhile.__doc__) == 101
# len(itertools.takewhile.__mro__) == 2
#
# filterfalse(predicate, iterable) yields elements where predicate is False;
# takewhile(predicate, iterable) yields while predicate is True. New to extra144.
# ---------------------------------------------------------------------------

table itertools_extra144.filterfalse_takewhile_attrs:
  description: "itertools.filterfalse (__name__ len 11, __doc__ len 120, MRO len 2) and takewhile (__name__ len 9, __doc__ len 101, MRO len 2); C types; wave 272; new to extra144"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsfilttake144

  columns: [id, function, args, expected, description]
  rows:
    - [filterfalse_class_eq_type,
       "filterfalse.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.filterfalse.__class__.__name__.__eq__('type') == True — filterfalse is a C extension type; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra144"]
    - [filterfalse_name_eq,
       "filterfalse.__name__.__eq__",
       ["filterfalse"],
       true,
       "itertools.filterfalse.__name__.__eq__('filterfalse') == True — the C type's __name__ is 'filterfalse'; str.__eq__('filterfalse') returns True; new to extra144"]
    - [filterfalse_name_len_eq_11,
       "filterfalse.__name__.__len__",
       [],
       11,
       "itertools.filterfalse.__name__.__len__() == 11 — __name__ is 'filterfalse' which has 11 characters; len('filterfalse') == 11; new to extra144"]
    - [filterfalse_qualname_eq,
       "filterfalse.__qualname__.__eq__",
       ["filterfalse"],
       true,
       "itertools.filterfalse.__qualname__.__eq__('filterfalse') == True — the C type's __qualname__ is 'filterfalse'; str.__eq__('filterfalse') returns True; new to extra144"]
    - [filterfalse_module_eq_itertools,
       "filterfalse.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.filterfalse.__module__.__eq__('itertools') == True — filterfalse is defined in itertoolsmodule.c; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra144"]
    - [filterfalse_doc_len_eq_120,
       "filterfalse.__doc__.__len__",
       [],
       120,
       "itertools.filterfalse.__doc__.__len__() == 120 — the filterfalse docstring has 120 characters; len(__doc__) == 120; verified with Python 3.14.3; new to extra144"]
    - [filterfalse_mro_len_eq_2,
       "filterfalse.__mro__.__len__",
       [],
       2,
       "itertools.filterfalse.__mro__.__len__() == 2 — filterfalse's MRO is [filterfalse, object]; len(__mro__) is 2; new to extra144"]
    - [takewhile_class_eq_type,
       "takewhile.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.takewhile.__class__.__name__.__eq__('type') == True — takewhile is a C extension type; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra144"]
    - [takewhile_name_eq,
       "takewhile.__name__.__eq__",
       ["takewhile"],
       true,
       "itertools.takewhile.__name__.__eq__('takewhile') == True — the C type's __name__ is 'takewhile'; str.__eq__('takewhile') returns True; new to extra144"]
    - [takewhile_name_len_eq_9,
       "takewhile.__name__.__len__",
       [],
       9,
       "itertools.takewhile.__name__.__len__() == 9 — __name__ is 'takewhile' which has 9 characters; len('takewhile') == 9; new to extra144"]
    - [takewhile_module_eq_itertools,
       "takewhile.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.takewhile.__module__.__eq__('itertools') == True — takewhile is defined in itertoolsmodule.c; __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra144"]
    - [takewhile_doc_len_eq_101,
       "takewhile.__doc__.__len__",
       [],
       101,
       "itertools.takewhile.__doc__.__len__() == 101 — the takewhile docstring has 101 characters; len(__doc__) == 101; verified with Python 3.14.3; new to extra144"]
    - [takewhile_mro_len_eq_2,
       "takewhile.__mro__.__len__",
       [],
       2,
       "itertools.takewhile.__mro__.__len__() == 2 — takewhile's MRO is [takewhile, object]; len(__mro__) is 2; new to extra144"]

# ---------------------------------------------------------------------------
# Table 2: itertools.dropwhile and itertools.compress — C type attrs
#
# Wave 272 theme: dropwhile and compress — filtering C extension types.
#
# itertools.dropwhile.__class__.__name__ == 'type'
# itertools.dropwhile.__name__ == 'dropwhile' (len 9)
# itertools.dropwhile.__qualname__ == 'dropwhile' (len 9)
# itertools.dropwhile.__module__ == 'itertools' (len 9)
# len(itertools.dropwhile.__doc__) == 126
# len(itertools.dropwhile.__mro__) == 2
# itertools.compress.__class__.__name__ == 'type'
# itertools.compress.__name__ == 'compress' (len 8)
# itertools.compress.__qualname__ == 'compress' (len 8)
# itertools.compress.__module__ == 'itertools' (len 9)
# len(itertools.compress.__doc__) == 164
# len(itertools.compress.__mro__) == 2
#
# dropwhile(predicate, iterable) drops while predicate is True then yields all;
# compress(data, selectors) returns elements where selectors are truthy.
# New to extra144.
# ---------------------------------------------------------------------------

