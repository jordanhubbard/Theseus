# len(itertools.combinations_with_replacement.__doc__) == 234
# len(itertools.combinations_with_replacement.__mro__) == 2
#
# combinations_with_replacement(iterable, r) yields r-length combinations
# allowing individual elements to be repeated. New to extra144.
# ---------------------------------------------------------------------------

