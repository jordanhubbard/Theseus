spec: socket_extra2611
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 621 theme: __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks."
    - "socket.socket does NOT define __init_subclass__ in its own __dict__ — inherits from object."
    - "socket.socket does NOT define __subclasshook__ in its own __dict__ — not an ABC; hook not defined."
    - "socket.socket does NOT define __class_getitem__ in its own __dict__ — no PEP 585 generic alias support."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses with EnumType metaclass; they also do NOT define any of the three dunder methods in their own __dict__."
    - "socket.SocketIO has ABCMeta as its metaclass but likewise does NOT define __init_subclass__, __subclasshook__, or __class_getitem__ in its own __dict__."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# socket.socket — __init_subclass__, __subclasshook__, __class_getitem__
# ---------------------------------------------------------------------------

table socket_extra2611.socket_class_init_subclass:
  description: "__init_subclass__ is absent from socket.socket.__dict__ — inherited from object, not defined on socket itself"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2611

  columns: [id, function, args, expected]
  rows:
    - ["sk2611001", "socket.socket.__dict__.__contains__", ["__init_subclass__"], false]

table socket_extra2611.socket_class_subclasshook:
  description: "__subclasshook__ is absent from socket.socket.__dict__ — socket.socket is not an ABC; hook not defined"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2611

  columns: [id, function, args, expected]
  rows:
    - ["sk2611002", "socket.socket.__dict__.__contains__", ["__subclasshook__"], false]

table socket_extra2611.socket_class_class_getitem:
  description: "__class_getitem__ is absent from socket.socket.__dict__ — no PEP 585 generic alias support on socket.socket"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2611

  columns: [id, function, args, expected]
  rows:
    - ["sk2611003", "socket.socket.__dict__.__contains__", ["__class_getitem__"], false]

table socket_extra2611.enum_types_dict_presence:
  description: "socket.AddressFamily and socket.SocketKind (IntEnum subclasses) do not define __init_subclass__, __subclasshook__, or __class_getitem__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2611

  columns: [id, function, args, expected]
  rows:
    - ["sk2611004", "socket.AddressFamily.__dict__.__contains__", ["__init_subclass__"],  false]
    - ["sk2611005", "socket.AddressFamily.__dict__.__contains__", ["__subclasshook__"],   false]
    - ["sk2611006", "socket.AddressFamily.__dict__.__contains__", ["__class_getitem__"],  false]
    - ["sk2611007", "socket.SocketKind.__dict__.__contains__",    ["__init_subclass__"],  false]
    - ["sk2611008", "socket.SocketKind.__dict__.__contains__",    ["__subclasshook__"],   false]
    - ["sk2611009", "socket.SocketKind.__dict__.__contains__",    ["__class_getitem__"],  false]
