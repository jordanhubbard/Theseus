invariant asyncio_extra124.Task_add_done_callback_qualname_len_22:
  description: "asyncio.Task.add_done_callback.__qualname__.__len__() == 22 — Task.add_done_callback.__qualname__ is 'Task.add_done_callback' (22 chars: 'Task.'=5 + 'add_done_callback'=17); this is the longest Task method qualname in this spec; compare Task method qualname lengths: cancel=11, done=9, result=11, get_name=13, set_name=13, get_coro=13, add_done_callback=22; the 'add_done_callback' suffix is 17 chars (a compound snake_case identifier with two underscores); Task.add_done_callback.__class__.__name__ is 'method_descriptor' (C-level); add_done_callback adds a callback to be called when the task is done; NEW in extra124: first standalone Task.add_done_callback qualname length invariant in asynciotaskqn124 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.add_done_callback.__qualname__.__len__
  args: []
  expected: 22

invariant asyncio_extra124.Future_add_done_callback_qualname_len_24:
  description: "asyncio.Future.add_done_callback.__qualname__.__len__() == 24 — Future.add_done_callback.__qualname__ is 'Future.add_done_callback' (24 chars: 'Future.'=7 + 'add_done_callback'=17); this is the longest Future method qualname in this spec and the longest overall; compare with Task.add_done_callback.__qualname__.__len__()==22 — the two-character difference arises because 'Future.'=7 chars vs 'Task.'=5 chars (6-4=2 letters in the class name + the dot stays 1); Future.add_done_callback registers a callback to be called when the Future transitions to done state; Future.add_done_callback.__class__.__name__ is 'method_descriptor' (C-level); NEW in extra124: first standalone Future.add_done_callback qualname length invariant in asynciotaskqn124 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Future.add_done_callback.__qualname__.__len__
  args: []
  expected: 24

invariant asyncio_extra124.Future_set_exception_qualname_len_20:
  description: "asyncio.Future.set_exception.__qualname__.__len__() == 20 — Future.set_exception.__qualname__ is 'Future.set_exception' (20 chars: 'Future.'=7 + 'set_exception'=13); compare Future write-side method qualname lengths: set_result=17 (10-char suffix), set_exception=20 (13-char suffix); compare with Task.add_done_callback=22 and Future.add_done_callback=24; set_exception sets the exception on the Future, transitioning it to done state; calling set_exception on an already-done Future raises InvalidStateError; Future.set_exception.__class__.__name__ is 'method_descriptor' (C-level); NEW in extra124: first standalone Future.set_exception qualname length invariant in asynciotaskqn124 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Future.set_exception.__qualname__.__len__
  args: []
  expected: 20

invariant asyncio_extra124.Task_get_coro_qualname_len_13:
  description: "asyncio.Task.get_coro.__qualname__.__len__() == 13 — Task.get_coro.__qualname__ is 'Task.get_coro' (13 chars: 'Task.'=5 + 'get_coro'=8); this is tied with Task.get_name and Task.set_name at len=13; Task.get_coro returns the coroutine object wrapped by the Task; Task.get_coro.__class__.__name__ is 'method_descriptor' (C-level); get_name, set_name, and get_coro are all Task-specific methods not present on Future — they manage the task's name and the wrapped coroutine; compare: Task.cancel=11, Task.done=9, Task.result=11 are shorter (6-char or 4-char suffixes vs get_coro's 8-char suffix); NEW in extra124: first standalone Task.get_coro qualname length invariant in asynciotaskqn124 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Task.get_coro.__qualname__.__len__
  args: []
  expected: 13

invariant asyncio_extra124.Future_set_result_qualname_len_17:
  description: "asyncio.Future.set_result.__qualname__.__len__() == 17 — Future.set_result.__qualname__ is 'Future.set_result' (17 chars: 'Future.'=7 + 'set_result'=10); Future.set_result.__class__.__name__ is 'method_descriptor' (C-level); set_result is the primary write-side method for a Future, marking it done with a result value; compare Future method qualname lengths: done=11 < cancel=13 < result=13 < exception=16 < set_result=17 < set_exception=20 < add_done_callback=24; calling set_result on an already-done Future raises InvalidStateError; compare with concurrent.futures.Future.set_result which has qualname 'Future.set_result' and same length but is Python-defined in Lib/concurrent/futures/_base.py (not C extension); NEW in extra124: first standalone Future.set_result qualname length invariant in asynciotaskqn124 namespace; wave 255; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Future.set_result.__qualname__.__len__
  args: []
  expected: 17

