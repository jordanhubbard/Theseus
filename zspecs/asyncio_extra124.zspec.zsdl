spec: asyncio_extra124
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec covers: wave 255 theme — asyncio Task and Future additional method qualnames. NEW in extra124: asyncio.Task.add_done_callback.__qualname__=='Task.add_done_callback' (len=22, longest Task method qualname covered); asyncio.Task.get_name.__qualname__=='Task.get_name' (len=13); asyncio.Task.set_name.__qualname__=='Task.set_name' (len=13); asyncio.Task.get_coro.__qualname__=='Task.get_coro' (len=13); asyncio.Task.result.__qualname__.__len__()==11; asyncio.Future.set_result.__qualname__=='Future.set_result' (len=17); asyncio.Future.set_exception.__qualname__=='Future.set_exception' (len=20); asyncio.Future.add_done_callback.__qualname__=='Future.add_done_callback' (len=24, longest Future method qualname); asyncio.Future.exception.__qualname__=='Future.exception' (len=16). All methods are C-level method_descriptors. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Task.add_done_callback.__qualname__.__len__() == 22. 'Task.add_done_callback' is 22 chars: 'Task.'=5 + 'add_done_callback'=17. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Future.add_done_callback.__qualname__.__len__() == 24. 'Future.add_done_callback' is 24 chars: 'Future.'=7 + 'add_done_callback'=17. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Future.set_exception.__qualname__.__len__() == 20. 'Future.set_exception' is 20 chars: 'Future.'=7 + 'set_exception'=13. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Task.get_name, set_name, get_coro all have qualname length 13 — same as Task.result (len=11) is shorter because 'result'=6 chars vs 'get_name'=8 chars. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Task additional method qualnames — extra124
#
# Wave 255 theme: asyncio Task additional method qualnames (C extension).
#
# asyncio.Task.add_done_callback.__qualname__ == 'Task.add_done_callback' (len=22)
# asyncio.Task.get_name.__qualname__          == 'Task.get_name'          (len=13)
# asyncio.Task.set_name.__qualname__          == 'Task.set_name'          (len=13)
# asyncio.Task.get_coro.__qualname__          == 'Task.get_coro'          (len=13)
# asyncio.Task.result.__qualname__.__len__()  == 11
# All Task methods have class 'method_descriptor' (C extension).
# ---------------------------------------------------------------------------

table asyncio_extra124.asyncio_task_extra_qualnames:
  description: "asyncio.Task additional method __qualname__ checks in asynciotaskqn124 namespace — wave 255 theme: Task methods are C-level method_descriptors; Task.add_done_callback.__qualname__.__eq__('Task.add_done_callback')==True (len=22: 'Task.'=5 + 'add_done_callback'=17, longest Task method qualname in this spec); Task.add_done_callback.__qualname__.__len__()==22; Task.get_name.__qualname__.__eq__('Task.get_name')==True (len=13: 'Task.'=5 + 'get_name'=8); Task.set_name.__qualname__.__eq__('Task.set_name')==True (len=13: same pattern as get_name); Task.get_coro.__qualname__.__eq__('Task.get_coro')==True (len=13: 'Task.'=5 + 'get_coro'=8); Task.result.__qualname__.__len__()==11 ('Task.'=5+'result'=6); Task.add_done_callback.__class__.__name__.__eq__('method_descriptor')==True (all Task methods are C-level); get_name, set_name, and get_coro are Task-specific methods for managing task names and coroutines; add_done_callback schedules a callback to be called when the task finishes; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotaskqn124

  columns: [id, function, args, expected, description]
  rows:
    - [task_adc_qeq,   asyncio.Task.add_done_callback.__qualname__.__eq__,  ["Task.add_done_callback"], true, "Task.add_done_callback.__qualname__ == 'Task.add_done_callback' (len=22, longest Task method qualname); verified with Python 3.14.3"]
    - [task_adc_qlen,  asyncio.Task.add_done_callback.__qualname__.__len__,  [],                         22,   "Task.add_done_callback.__qualname__.__len__() == 22 ('Task.'=5+'add_done_callback'=17); verified with Python 3.14.3"]
    - [task_adc_cls,   asyncio.Task.add_done_callback.__class__.__name__.__eq__, ["method_descriptor"],  true, "Task.add_done_callback.__class__.__name__ == 'method_descriptor' (C-level method); verified with Python 3.14.3"]
    - [task_gn_qeq,    asyncio.Task.get_name.__qualname__.__eq__,            ["Task.get_name"],          true, "Task.get_name.__qualname__ == 'Task.get_name' (len=13); verified with Python 3.14.3"]
    - [task_gn_qlen,   asyncio.Task.get_name.__qualname__.__len__,           [],                         13,   "Task.get_name.__qualname__.__len__() == 13 ('Task.'=5+'get_name'=8); verified with Python 3.14.3"]
    - [task_sn_qeq,    asyncio.Task.set_name.__qualname__.__eq__,            ["Task.set_name"],          true, "Task.set_name.__qualname__ == 'Task.set_name' (len=13, same as get_name); verified with Python 3.14.3"]
    - [task_gc_qeq,    asyncio.Task.get_coro.__qualname__.__eq__,            ["Task.get_coro"],          true, "Task.get_coro.__qualname__ == 'Task.get_coro' (len=13, same as get_name and set_name); verified with Python 3.14.3"]
    - [task_res_qlen,  asyncio.Task.result.__qualname__.__len__,             [],                         11,   "Task.result.__qualname__.__len__() == 11 ('Task.'=5+'result'=6, shorter than get_name/set_name/get_coro at 13); verified with Python 3.14.3"]

