spec: re_extra126
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Pattern and re.Match method __qualname__ values and lengths."
    - "re.Pattern and re.Match are C extension types from the _sre module."
    - "type(re.compile('')).__name__ == 'Pattern'."
    - "type(re.compile('').match('')).__name__ == 'Match'."
    - "re.Pattern.__qualname__ = 'Pattern', re.Match.__qualname__ = 'Match'."
    - "re.Pattern.match.__qualname__ = 'Pattern.match' (length 13)."
    - "re.Pattern.search.__qualname__ = 'Pattern.search' (length 14)."
    - "re.Pattern.findall.__qualname__ = 'Pattern.findall' (length 15)."
    - "re.Pattern.finditer.__qualname__ = 'Pattern.finditer' (length 16)."
    - "re.Pattern.sub.__qualname__ = 'Pattern.sub' (length 11)."
    - "re.Pattern.subn.__qualname__ = 'Pattern.subn' (length 12)."
    - "re.Pattern.split.__qualname__ = 'Pattern.split' (length 13)."
    - "re.Pattern.fullmatch.__qualname__ = 'Pattern.fullmatch' (length 17)."
    - "re.Match.group.__qualname__ = 'Match.group' (length 11)."
    - "re.Match.groups.__qualname__ = 'Match.groups' (length 12)."
    - "re.Match.groupdict.__qualname__ = 'Match.groupdict' (length 15)."
    - "re.Match.start.__qualname__ = 'Match.start' (length 11)."
    - "re.Match.end.__qualname__ = 'Match.end' (length 9)."
    - "re.Match.span.__qualname__ = 'Match.span' (length 10)."
    - "re.Match.expand.__qualname__ = 'Match.expand' (length 12)."
    - "re.Pattern.__module__ = 're', re.Match.__module__ = 're'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern method __qualname__ values
# Pattern is a C extension type. Method qualnames follow 'Pattern.<method>'.
# match=13, search=14, findall=15, finditer=16, sub=11, subn=12,
# split=13, fullmatch=17.
# ---------------------------------------------------------------------------

table re_extra126.Pattern_method_qualnames:
  description: "re.Pattern method __qualname__ values and lengths: match, search, findall, finditer, sub, subn, split, fullmatch"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: repattern126

  columns: [id, function, args, expected, description]
  rows:
    - [pat_match_qname_eq,     Pattern.match.__qualname__.__eq__,     ["Pattern.match"],     true,  "Pattern.match.__qualname__ == 'Pattern.match'"]
    - [pat_match_qname_len,    Pattern.match.__qualname__.__len__,    [],                    13,    "Pattern.match.__qualname__ has 13 characters"]
    - [pat_search_qname_eq,    Pattern.search.__qualname__.__eq__,    ["Pattern.search"],    true,  "Pattern.search.__qualname__ == 'Pattern.search'"]
    - [pat_search_qname_len,   Pattern.search.__qualname__.__len__,   [],                    14,    "Pattern.search.__qualname__ has 14 characters"]
    - [pat_findall_qname_eq,   Pattern.findall.__qualname__.__eq__,   ["Pattern.findall"],   true,  "Pattern.findall.__qualname__ == 'Pattern.findall'"]
    - [pat_findall_qname_len,  Pattern.findall.__qualname__.__len__,  [],                    15,    "Pattern.findall.__qualname__ has 15 characters"]
    - [pat_finditer_qname_eq,  Pattern.finditer.__qualname__.__eq__,  ["Pattern.finditer"],  true,  "Pattern.finditer.__qualname__ == 'Pattern.finditer'"]
    - [pat_finditer_qname_len, Pattern.finditer.__qualname__.__len__, [],                    16,    "Pattern.finditer.__qualname__ has 16 characters"]
    - [pat_sub_qname_eq,       Pattern.sub.__qualname__.__eq__,       ["Pattern.sub"],       true,  "Pattern.sub.__qualname__ == 'Pattern.sub'"]
    - [pat_sub_qname_len,      Pattern.sub.__qualname__.__len__,      [],                    11,    "Pattern.sub.__qualname__ has 11 characters"]

# ---------------------------------------------------------------------------
# re.Pattern additional method qualnames and re.Match method qualnames
# subn=12, split=13, fullmatch=17.
# Match method qualnames: group=11, groups=12, groupdict=15.
# ---------------------------------------------------------------------------

table re_extra126.Pattern_more_and_Match_qualnames:
  description: "re.Pattern subn/split/fullmatch qualnames and re.Match group/groups/groupdict qualnames"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: repattern126

  columns: [id, function, args, expected, description]
  rows:
    - [pat_subn_qname_eq,      Pattern.subn.__qualname__.__eq__,      ["Pattern.subn"],      true,  "Pattern.subn.__qualname__ == 'Pattern.subn'"]
    - [pat_subn_qname_len,     Pattern.subn.__qualname__.__len__,     [],                    12,    "Pattern.subn.__qualname__ has 12 characters"]
    - [pat_split_qname_eq,     Pattern.split.__qualname__.__eq__,     ["Pattern.split"],     true,  "Pattern.split.__qualname__ == 'Pattern.split'"]
    - [pat_split_qname_len,    Pattern.split.__qualname__.__len__,    [],                    13,    "Pattern.split.__qualname__ has 13 characters"]
    - [pat_fullmatch_qname_eq, Pattern.fullmatch.__qualname__.__eq__, ["Pattern.fullmatch"], true,  "Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch'"]
    - [pat_fullmatch_qname_len,Pattern.fullmatch.__qualname__.__len__,[],                    17,    "Pattern.fullmatch.__qualname__ has 17 characters"]
    - [mat_group_qname_eq,     Match.group.__qualname__.__eq__,       ["Match.group"],       true,  "Match.group.__qualname__ == 'Match.group'"]
    - [mat_group_qname_len,    Match.group.__qualname__.__len__,      [],                    11,    "Match.group.__qualname__ has 11 characters"]
    - [mat_groups_qname_eq,    Match.groups.__qualname__.__eq__,      ["Match.groups"],      true,  "Match.groups.__qualname__ == 'Match.groups'"]
    - [mat_groups_qname_len,   Match.groups.__qualname__.__len__,     [],                    12,    "Match.groups.__qualname__ has 12 characters"]
    - [mat_groupdict_qname_eq, Match.groupdict.__qualname__.__eq__,   ["Match.groupdict"],   true,  "Match.groupdict.__qualname__ == 'Match.groupdict'"]
    - [mat_groupdict_qname_len,Match.groupdict.__qualname__.__len__,  [],                    15,    "Match.groupdict.__qualname__ has 15 characters"]

# ---------------------------------------------------------------------------
# re.Match additional method qualnames and type qualnames
# start=11, end=9, span=10, expand=12.
# Pattern.__qualname__='Pattern', Match.__qualname__='Match'.
# Pattern.__module__='re', Match.__module__='re'.
# ---------------------------------------------------------------------------

table re_extra126.Match_more_and_type_qualnames:
  description: "re.Match start/end/span/expand qualnames and re.Pattern/re.Match type __qualname__ and __module__"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: repattern126

  columns: [id, function, args, expected, description]
  rows:
    - [mat_start_qname_eq,  Match.start.__qualname__.__eq__,   ["Match.start"],  true,  "Match.start.__qualname__ == 'Match.start'"]
    - [mat_start_qname_len, Match.start.__qualname__.__len__,  [],               11,    "Match.start.__qualname__ has 11 characters"]
    - [mat_end_qname_eq,    Match.end.__qualname__.__eq__,     ["Match.end"],    true,  "Match.end.__qualname__ == 'Match.end'"]
    - [mat_end_qname_len,   Match.end.__qualname__.__len__,    [],               9,     "Match.end.__qualname__ has 9 characters"]
    - [mat_span_qname_eq,   Match.span.__qualname__.__eq__,    ["Match.span"],   true,  "Match.span.__qualname__ == 'Match.span'"]
    - [mat_span_qname_len,  Match.span.__qualname__.__len__,   [],               10,    "Match.span.__qualname__ has 10 characters"]
    - [mat_expand_qname_eq, Match.expand.__qualname__.__eq__,  ["Match.expand"], true,  "Match.expand.__qualname__ == 'Match.expand'"]
    - [mat_expand_qname_len,Match.expand.__qualname__.__len__, [],               12,    "Match.expand.__qualname__ has 12 characters"]
    - [pattern_type_qname,  Pattern.__qualname__.__eq__,       ["Pattern"],      true,  "re.Pattern.__qualname__ == 'Pattern'"]
    - [match_type_qname,    Match.__qualname__.__eq__,         ["Match"],        true,  "re.Match.__qualname__ == 'Match'"]
    - [pattern_module_eq,   Pattern.__module__.__eq__,         ["re"],           true,  "re.Pattern.__module__ == 're'"]
    - [match_module_eq,     Match.__module__.__eq__,           ["re"],           true,  "re.Match.__module__ == 're'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra126.Pattern.match_qualname:
  description: "re.Pattern.match.__qualname__ == 'Pattern.match' (length 13; C extension method qualname follows 'TypeName.method' pattern)"
  category: method_qualnames
  kind: python_call_eq
  function: Pattern.match.__qualname__.__eq__
  args: ["Pattern.match"]
  expected: true

invariant re_extra126.Pattern.fullmatch_qualname_len:
  description: "re.Pattern.fullmatch.__qualname__.__len__() == 17 ('Pattern.fullmatch' has 17 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: Pattern.fullmatch.__qualname__.__len__
  args: []
  expected: 17

invariant re_extra126.Match.group_qualname:
  description: "re.Match.group.__qualname__ == 'Match.group' (length 11)"
  category: method_qualnames
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true

invariant re_extra126.Match.end_qualname_len:
  description: "re.Match.end.__qualname__.__len__() == 9 ('Match.end' has 9 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: Match.end.__qualname__.__len__
  args: []
  expected: 9

invariant re_extra126.Pattern.module_is_re:
  description: "re.Pattern.__module__ == 're' (even though Pattern is a C type from _sre, its __module__ is set to 're')"
  category: method_qualnames
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

