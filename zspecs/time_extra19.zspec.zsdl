spec: time_extra19
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time_extra10.zspec.zsdl — covers __module__ table for core timing functions"
    - "time_extra15.zspec.zsdl — covers __module__ standalone invariants for sleep/time/monotonic/perf_counter/process_time/gmtime/localtime/mktime/strftime"
    - "time_extra16.zspec.zsdl — covers __qualname__ for core timing and conversion functions; monotonic_ns/__name__"
    - "time_extra17.zspec.zsdl — covers __module__.__len__() and __name__.__len__() for time/sleep/monotonic/perf_counter/process_time/struct_time"
    - "time_extra18.zspec.zsdl — covers __qualname__.__len__() for time/sleep/monotonic/perf_counter/process_time/gmtime/localtime; __name__.__len__() for gmtime through perf_counter_ns; __module__.__len__() for gmtime through perf_counter_ns"
  notes:
    - "This spec extends time_extra18.zspec.zsdl."
    - "Prior specs covered: time/sleep/monotonic/perf_counter/process_time/localtime/gmtime/mktime/strftime/strptime/ctime/struct_time __name__/__module__/__qualname__ and lengths, timezone/altzone/daylight __class__.__name__, monotonic_ns/__name__, qualname lengths for seven timing functions, name lengths for nine extended functions, module lengths for seven functions."
    - "This spec covers: time.tzname.__len__() (always 2); time.struct_time.__mro__.__len__() (3); time.struct_time.__bases__[0].__name__.__len__() (5); time.struct_time.__name__.__len__() (11); time.struct_time.__dict__.__class__.__name__.__len__() (12); time.struct_time.n_sequence_fields (9); time.struct_time.n_fields (11); __qualname__.__len__() and __name__.__len__() for process_time_ns/thread_time/thread_time_ns/get_clock_info."
    - "No prior time spec checks time.tzname.__len__()."
    - "No prior time spec checks time.struct_time.__mro__.__len__()."
    - "No prior time spec checks time.struct_time.__bases__[0].__name__.__len__()."
    - "No prior time spec checks time.struct_time.__name__.__len__()."
    - "No prior time spec checks time.struct_time.__dict__.__class__.__name__.__len__()."
    - "No prior time spec checks time.struct_time.n_sequence_fields."
    - "No prior time spec checks time.struct_time.n_fields."
    - "No prior time spec checks time.process_time_ns.__qualname__.__len__()."
    - "No prior time spec checks time.thread_time.__qualname__.__len__()."
    - "No prior time spec checks time.thread_time_ns.__qualname__.__len__()."
    - "No prior time spec checks time.get_clock_info.__qualname__.__len__()."
    - "time.tzname is a tuple of 2 timezone name strings (e.g. ('PST', 'PDT')); len is always 2."
    - "time.struct_time.__mro__ == [struct_time, tuple, object] — len 3 (struct_time extends named tuple)."
    - "time.struct_time.__bases__[0].__name__ == 'tuple' — len 5."
    - "time.struct_time.__name__ == 'struct_time' — len 11."
    - "time.struct_time.__dict__.__class__.__name__ == 'mappingproxy' — len 12."
    - "time.struct_time.n_sequence_fields == 9 (tm_year through tm_isdst)."
    - "time.struct_time.n_fields == 11 (9 sequence fields + tm_gmtoff + tm_zone)."
    - "time.process_time_ns.__qualname__ == 'process_time_ns' — len 15 (C builtin, flat qualname)."
    - "time.thread_time.__qualname__ == 'thread_time' — len 11 (C builtin, flat qualname)."
    - "time.thread_time_ns.__qualname__ == 'thread_time_ns' — len 14 (C builtin, flat qualname)."
    - "time.get_clock_info.__qualname__ == 'get_clock_info' — len 14 (C builtin, flat qualname)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# time.tzname — tuple of timezone name strings
#
# time.tzname is always a tuple with exactly 2 elements: the standard and
# daylight saving timezone abbreviations (e.g. ('PST', 'PDT') on US Pacific).
# Its __class__.__name__ is 'tuple'. No prior time spec checks tzname.__len__().
# ---------------------------------------------------------------------------

invariant time_extra19.tzname_len:
  description: "time.tzname.__len__() == 2 — tzname always has exactly 2 elements: standard and DST timezone names"
  category: module_constants
  kind: python_call_eq
  function: tzname.__len__
  args: []
  expected: 2

invariant time_extra19.tzname_class_name_len:
  description: "time.tzname.__class__.__name__.__len__() == 5 — tzname is a 'tuple' (5 chars)"
  category: module_constants
  kind: python_call_eq
  function: tzname.__class__.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# time.struct_time class introspection
#
# struct_time is a named-tuple subclass residing in the time C extension.
# Its MRO is [struct_time, tuple, object] (len 3). The first base is 'tuple'
# (len 5). The class name 'struct_time' has 11 characters. Its __dict__ is
# a mappingproxy (len 12) like all Python class __dict__ objects.
# No prior time spec checks any of these struct_time properties.
# ---------------------------------------------------------------------------

invariant time_extra19.struct_time.mro_len:
  description: "time.struct_time.__mro__.__len__() == 3 — MRO: struct_time, tuple, object (named-tuple subclass)"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_time.__mro__.__len__
  args: []
  expected: 3

invariant time_extra19.struct_time.bases0_name_len:
  description: "time.struct_time.__bases__[0].__name__.__len__() == 5 — first base is 'tuple' (5 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "struct_time.__bases__[0].__name__.__len__"
  args: []
  expected: 5

invariant time_extra19.struct_time.name_len:
  description: "time.struct_time.__name__.__len__() == 11 — 'struct_time' has 11 characters"
  category: string_lengths
  kind: python_call_eq
  function: struct_time.__name__.__len__
  args: []
  expected: 11

invariant time_extra19.struct_time.dict_class_name_len:
  description: "time.struct_time.__dict__.__class__.__name__.__len__() == 12 — class __dict__ is 'mappingproxy' (12 chars)"
  category: class_introspection
  kind: python_call_eq
  function: struct_time.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# time.struct_time named-tuple field counts
#
# struct_time exposes three class-level integer attributes describing its
# field layout:
#   n_sequence_fields == 9  (tm_year, tm_mon, tm_mday, tm_hour, tm_min,
#                             tm_sec, tm_wday, tm_yday, tm_isdst)
#   n_unnamed_fields  == 0  (no unnamed positional fields)
#   n_fields          == 11 (9 sequence fields + tm_gmtoff + tm_zone)
# No prior time spec checks any of these constants.
# ---------------------------------------------------------------------------

table time_extra19.struct_time_field_counts:
  description: "time.struct_time field-count constants: n_sequence_fields (9), n_unnamed_fields (0), n_fields (11)"
  kind: python_call_eq
  category: module_constants
  id_prefix: stfc19

  columns: [id, function, args, expected]
  rows:
    - [n_sequence_fields, struct_time.n_sequence_fields.__eq__, [9],  true]
    - [n_unnamed_fields,  struct_time.n_unnamed_fields.__eq__,  [0],  true]
    - [n_fields,          struct_time.n_fields.__eq__,          [11], true]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for process_time_ns, thread_time, thread_time_ns,
# get_clock_info
#
# These four functions extend time_extra18's coverage of qualname lengths.
# All are C builtins; __qualname__ == __name__ (flat, no enclosing class).
#   process_time_ns  -> 'process_time_ns'  -> 15
#   thread_time      -> 'thread_time'      -> 11
#   thread_time_ns   -> 'thread_time_ns'   -> 14
#   get_clock_info   -> 'get_clock_info'   -> 14
# No prior time spec checks any of these qualname lengths.
# ---------------------------------------------------------------------------

table time_extra19.extended_qualname_lengths:
  description: "__qualname__.__len__() for process_time_ns (15), thread_time (11), thread_time_ns (14), get_clock_info (14)"
  kind: python_call_eq
  category: function_identity
  id_prefix: eql19

  columns: [id, function, args, expected]
  rows:
    - [process_time_ns, process_time_ns.__qualname__.__len__, [], 15]
    - [thread_time,     thread_time.__qualname__.__len__,     [], 11]
    - [thread_time_ns,  thread_time_ns.__qualname__.__len__,  [], 14]
    - [get_clock_info,  get_clock_info.__qualname__.__len__,  [], 14]
