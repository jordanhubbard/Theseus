spec: th3301
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 667 (th3301): __itruediv__, __ifloordiv__, __imod__ dict-presence checks for threading types."
    - "Theme: __itruediv__/__ifloordiv__/__imod__ in-place division/modulo dict-presence."
    - "In-place augmented assignment operators (/=, //=, %=) fall back to __truediv__/__floordiv__/__mod__ if not defined."
    - "All values False — callable/iterator/inspection/synchronization types have no in-place division/modulo operators."
    - "None of the threading types define __itruediv__, __ifloordiv__, or __imod__ in their own __dict__."
    - "threading.Thread, threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore, threading.Timer, threading.Barrier, and threading.local are Python-level classes."
    - "threading.Lock() returns a _thread.lock instance; type(threading.Lock()) is used to access its __dict__."
    - "threading.RLock() returns a _thread.RLock instance; type(threading.RLock()) is used to access its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table th3301.itruediv:
  description: "threading types __itruediv__ dict-presence checks; wave 667"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: th3301
  columns: [id, function, args, expected]
  rows:
    - ["th3301001", operator.contains, [threading.Thread.__dict__,           "__itruediv__"], false]
    - ["th3301002", operator.contains, [threading.Event.__dict__,            "__itruediv__"], false]
    - ["th3301003", operator.contains, [threading.Condition.__dict__,        "__itruediv__"], false]
    - ["th3301004", operator.contains, [threading.Semaphore.__dict__,        "__itruediv__"], false]
    - ["th3301005", operator.contains, [threading.BoundedSemaphore.__dict__, "__itruediv__"], false]
    - ["th3301006", operator.contains, [threading.Timer.__dict__,            "__itruediv__"], false]
    - ["th3301007", operator.contains, [threading.Barrier.__dict__,          "__itruediv__"], false]
    - ["th3301008", operator.contains, [threading.local.__dict__,            "__itruediv__"], false]
    - ["th3301009", operator.contains, [type(threading.Lock()).__dict__,     "__itruediv__"], false]
    - ["th3301010", operator.contains, [type(threading.RLock()).__dict__,    "__itruediv__"], false]

