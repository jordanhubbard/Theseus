spec: contextlib_extra18
version: ">=3.10"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra17.zspec.zsdl."
    - "contextlib_extra17 covers: closing MRO[0..3]; ExitStack MRO[4]; aclosing MRO[0] and [3]; AsyncExitStack MRO[4]; suppress MRO[0] and [3]."
    - "contextlib_extra16 covers: suppress/closing/ExitStack __qualname__ via standalone invariants; suppress MRO[1]/[2]; nullcontext MRO[3]/[4]; redirect_stderr.__module__."
    - "contextlib_extra12 covers: standalone __name__ for contextmanager/asynccontextmanager/closing/nullcontext/suppress/ExitStack/AsyncExitStack."
    - "NOT yet covered as __qualname__ invariants: contextmanager/asynccontextmanager/nullcontext/AsyncExitStack/redirect_stdout/redirect_stderr/aclosing."
    - "contextlib.contextmanager.__qualname__ == 'contextmanager' — decorator function defined at module level."
    - "contextlib.asynccontextmanager.__qualname__ == 'asynccontextmanager' — async variant."
    - "contextlib.nullcontext.__qualname__ == 'nullcontext' — class defined at module level."
    - "contextlib.AsyncExitStack.__qualname__ == 'AsyncExitStack' — class defined at module level."
    - "contextlib.redirect_stdout.__qualname__ == 'redirect_stdout' — class defined at module level."
    - "contextlib.redirect_stderr.__qualname__ == 'redirect_stderr' — class defined at module level."
    - "contextlib.aclosing.__qualname__ == 'aclosing' — class defined at module level."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for contextmanager and asynccontextmanager
#
# contextlib_extra12 records __name__ for contextmanager and asynccontextmanager.
# No prior spec records their __qualname__ as standalone boolean __eq__ invariants.
# Both are pure-Python decorator functions at module scope, so __qualname__ == __name__.
# ---------------------------------------------------------------------------

invariant contextlib_extra18.contextmanager.qualname:
  description: "contextlib.contextmanager.__qualname__ == 'contextmanager'"
  category: function_qualnames
  kind: python_call_eq
  function: contextmanager.__qualname__.__eq__
  args: ["contextmanager"]
  expected: true

invariant contextlib_extra18.asynccontextmanager.qualname:
  description: "contextlib.asynccontextmanager.__qualname__ == 'asynccontextmanager'"
  category: function_qualnames
  kind: python_call_eq
  function: asynccontextmanager.__qualname__.__eq__
  args: ["asynccontextmanager"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for nullcontext and AsyncExitStack
#
# contextlib_extra16 records __qualname__ for suppress, closing, and ExitStack.
# No prior spec records __qualname__ for nullcontext or AsyncExitStack as
# standalone boolean __eq__ invariants.
# ---------------------------------------------------------------------------

invariant contextlib_extra18.nullcontext.qualname:
  description: "contextlib.nullcontext.__qualname__ == 'nullcontext'"
  category: class_qualnames
  kind: python_call_eq
  function: nullcontext.__qualname__.__eq__
  args: ["nullcontext"]
  expected: true

invariant contextlib_extra18.AsyncExitStack.qualname:
  description: "contextlib.AsyncExitStack.__qualname__ == 'AsyncExitStack'"
  category: class_qualnames
  kind: python_call_eq
  function: AsyncExitStack.__qualname__.__eq__
  args: ["AsyncExitStack"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for redirect_stdout and redirect_stderr
#
# contextlib_extra14 records redirect_stdout.__module__ and redirect_stderr.__module__.
# contextlib_extra15 and extra16 cover their MRO entries. No prior spec records
# __qualname__ for redirect_stdout or redirect_stderr as standalone invariants.
# ---------------------------------------------------------------------------

invariant contextlib_extra18.redirect_stdout.qualname:
  description: "contextlib.redirect_stdout.__qualname__ == 'redirect_stdout'"
  category: class_qualnames
  kind: python_call_eq
  function: redirect_stdout.__qualname__.__eq__
  args: ["redirect_stdout"]
  expected: true

invariant contextlib_extra18.redirect_stderr.qualname:
  description: "contextlib.redirect_stderr.__qualname__ == 'redirect_stderr'"
  category: class_qualnames
  kind: python_call_eq
  function: redirect_stderr.__qualname__.__eq__
  args: ["redirect_stderr"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for aclosing
#
# contextlib_extra14 records aclosing.__mro__.__len__() and MRO[1].
# contextlib_extra15 records aclosing MRO[2]. contextlib_extra17 records
# aclosing MRO[0] and MRO[3]. No prior spec records aclosing.__qualname__
# as a standalone boolean __eq__ invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra18.aclosing.qualname:
  description: "contextlib.aclosing.__qualname__ == 'aclosing'"
  category: class_qualnames
  kind: python_call_eq
  function: aclosing.__qualname__.__eq__
  args: ["aclosing"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for closing and suppress — confirm against __name__ checks
#
# contextlib_extra16 records closing.__qualname__ and suppress.__qualname__
# using the dotted-chain form. These invariants use the same pattern for
# completeness of the __qualname__ axis; they are NEW standalone boolean
# __eq__ forms if the prior ones used a different predicate form.
# contextlib_extra12 covers __name__ for closing and suppress.
# contextlib_extra16 covers __qualname__ for closing and suppress via
# standalone invariants — skip to avoid duplication; add ExitStack instead.
# ExitStack.__qualname__ was also covered in contextlib_extra16 — skip.
# Add redirect_stdout and redirect_stderr __module__ consistency checks instead.
# ---------------------------------------------------------------------------

invariant contextlib_extra18.redirect_stdout.module:
  description: "contextlib.redirect_stdout.__module__ == 'contextlib'"
  category: class_modules
  kind: python_call_eq
  function: redirect_stdout.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra18.AsyncExitStack.module:
  description: "contextlib.AsyncExitStack.__module__ == 'contextlib'"
  category: class_modules
  kind: python_call_eq
  function: AsyncExitStack.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra18.nullcontext.module:
  description: "contextlib.nullcontext.__module__ == 'contextlib'"
  category: class_modules
  kind: python_call_eq
  function: nullcontext.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra18.aclosing.module:
  description: "contextlib.aclosing.__module__ == 'contextlib'"
  category: class_modules
  kind: python_call_eq
  function: aclosing.__module__.__eq__
  args: ["contextlib"]
  expected: true
