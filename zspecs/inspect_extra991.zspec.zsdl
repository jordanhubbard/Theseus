spec: inspect_extra991
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks inspect.Parameter, Signature, and BoundArguments method __qualname__ identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra991.parameter_qualnames:
  description: "inspect.Parameter method __qualname__ identity"
  kind: python_call_eq
  category: parameter_qualnames
  id_prefix: ip991pa
  columns: [id, function, args, expected]
  rows:
    - [ip991pa001, inspect.Parameter.__qualname__.__eq__,                          ["Parameter"],                        true]
    - [ip991pa002, inspect.Parameter.__init__.__qualname__.__eq__,                 ["Parameter.__init__"],               true]
    - [ip991pa003, inspect.Parameter.replace.__qualname__.__eq__,                  ["Parameter.replace"],                true]
    - [ip991pa004, inspect.Parameter.__repr__.__qualname__.__eq__,                 ["Parameter.__repr__"],               true]
    - [ip991pa005, inspect.Parameter.__hash__.__qualname__.__eq__,                 ["Parameter.__hash__"],               true]
    - [ip991pa006, inspect.Parameter.__eq__.__qualname__.__eq__,                   ["Parameter.__eq__"],                 true]
    - [ip991pa007, inspect.Parameter.__module__.__eq__,                            ["inspect"],                          true]

table inspect_extra991.signature_qualnames:
  description: "inspect.Signature method __qualname__ identity"
  kind: python_call_eq
  category: signature_qualnames
  id_prefix: ip991si
  columns: [id, function, args, expected]
  rows:
    - [ip991si001, inspect.Signature.__qualname__.__eq__,                          ["Signature"],                        true]
    - [ip991si002, inspect.Signature.__init__.__qualname__.__eq__,                 ["Signature.__init__"],               true]
    - [ip991si003, inspect.Signature.replace.__qualname__.__eq__,                  ["Signature.replace"],                true]
    - [ip991si004, inspect.Signature.bind.__qualname__.__eq__,                     ["Signature.bind"],                   true]
    - [ip991si005, inspect.Signature.bind_partial.__qualname__.__eq__,             ["Signature.bind_partial"],           true]
    - [ip991si006, inspect.Signature.__module__.__eq__,                            ["inspect"],                          true]

table inspect_extra991.boundarguments_and_module_qualnames:
  description: "inspect.BoundArguments method __qualname__ identity and module identity"
  kind: python_call_eq
  category: boundarguments_qualnames
  id_prefix: ip991ba
  columns: [id, function, args, expected]
  rows:
    - [ip991ba001, inspect.BoundArguments.__qualname__.__eq__,                     ["BoundArguments"],                   true]
    - [ip991ba002, inspect.BoundArguments.__init__.__qualname__.__eq__,            ["BoundArguments.__init__"],          true]
    - [ip991ba003, inspect.BoundArguments.__repr__.__qualname__.__eq__,            ["BoundArguments.__repr__"],          true]
    - [ip991ba004, inspect.BoundArguments.__module__.__eq__,                       ["inspect"],                          true]
    - [ip991ba005, inspect.__spec__.name.__eq__,                                   ["inspect"],                          true]
    - [ip991ba006, inspect.__name__.__eq__,                                        ["inspect"],                          true]
    - [ip991ba007, inspect.Parameter.__doc__.__class__.__name__.__eq__,            ["str"],                              true]
