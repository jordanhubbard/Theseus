spec: re_extra901
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module function documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __module__ attributes of re module functions"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra901.search_function_modules:
  description: "re search and match function __module__ identity"
  kind: python_call_eq
  category: search_function_modules
  id_prefix: re901s
  columns: [id, function, args, expected]
  rows:
    - [re901s001, re.compile.__module__.__eq__,   ["re"], true]
    - [re901s002, re.match.__module__.__eq__,     ["re"], true]
    - [re901s003, re.search.__module__.__eq__,    ["re"], true]
    - [re901s004, re.fullmatch.__module__.__eq__, ["re"], true]
    - [re901s005, re.compile.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [re901s006, re.match.__class__.__name__.__eq__,     ["builtin_function_or_method"], true]

table re_extra901.find_function_modules:
  description: "re find and iter function __module__ identity"
  kind: python_call_eq
  category: find_function_modules
  id_prefix: re901f
  columns: [id, function, args, expected]
  rows:
    - [re901f001, re.findall.__module__.__eq__,  ["re"], true]
    - [re901f002, re.finditer.__module__.__eq__, ["re"], true]
    - [re901f003, re.findall.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [re901f004, re.finditer.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [re901f005, re.findall.__qualname__.__eq__, ["findall"],  true]
    - [re901f006, re.finditer.__qualname__.__eq__, ["finditer"], true]

table re_extra901.transform_function_modules:
  description: "re sub and split function __module__ identity"
  kind: python_call_eq
  category: transform_function_modules
  id_prefix: re901t
  columns: [id, function, args, expected]
  rows:
    - [re901t001, re.sub.__module__.__eq__,     ["re"], true]
    - [re901t002, re.split.__module__.__eq__,   ["re"], true]
    - [re901t003, re.sub.__qualname__.__eq__,   ["sub"],   true]
    - [re901t004, re.split.__qualname__.__eq__, ["split"], true]
    - [re901t005, re.sub.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]
    - [re901t006, re.split.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [re901t007, re.__name__.__eq__,           ["re"],    true]
