spec: pathlib_extra394
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pathlib.Path methods glob, rglob, iterdir, resolve, rename, replace, absolute each report __name__ matching their Python-level name"
    - "pathlib.Path.absolute is an instance method returning the absolute path without resolving symlinks"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path method __name__ identity — filesystem traversal methods
# ---------------------------------------------------------------------------

table pathlib_extra394.path_traversal_method_names:
  description: "pathlib.Path method __name__ identity — glob, rglob, iterdir; each method's __name__ matches its Python-level name; glob and rglob yield matching paths, iterdir yields directory contents; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: plptraversal394

  columns: [id, function, args, expected]
  rows:
    - [glob_name,    pathlib.Path.glob.__name__.__eq__,    ["glob"],    true]
    - [rglob_name,   pathlib.Path.rglob.__name__.__eq__,   ["rglob"],   true]
    - [iterdir_name, pathlib.Path.iterdir.__name__.__eq__, ["iterdir"], true]

# ---------------------------------------------------------------------------
# pathlib.Path method __name__ identity — resolution and mutation methods
# ---------------------------------------------------------------------------

table pathlib_extra394.path_resolution_method_names:
  description: "pathlib.Path method __name__ identity — resolve, absolute, rename, replace; each method's __name__ matches its Python-level name; resolve follows symlinks, absolute does not; rename and replace move/rename files atomically; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: plpresolution394

  columns: [id, function, args, expected]
  rows:
    - [resolve_name,  pathlib.Path.resolve.__name__.__eq__,  ["resolve"],  true]
    - [absolute_name, pathlib.Path.absolute.__name__.__eq__, ["absolute"], true]
    - [rename_name,   pathlib.Path.rename.__name__.__eq__,   ["rename"],   true]
    - [replace_name,  pathlib.Path.replace.__name__.__eq__,  ["replace"],  true]
