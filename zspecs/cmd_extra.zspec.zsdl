spec: cmd_extra
version: ">=3.9"
backend: python_module(cmd)

docs: https://docs.python.org/3/library/cmd.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmd.html — Python cmd module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/cmd.py"
  notes:
    - "Extends cmd.zspec.zsdl with method name invariants and IDENTCHARS type check."
    - "cmd.Cmd.__name__ == 'Cmd' and __module__ == 'cmd' — the command-interpreter base class."
    - "cmd.Cmd.cmdloop.__name__ == 'cmdloop' — the main read-eval-print loop method."
    - "cmd.Cmd.onecmd.__name__ == 'onecmd' — interprets a single command string."
    - "cmd.Cmd.default.__name__ == 'default' — called when a command prefix is not recognized."
    - "cmd.Cmd.do_help.__name__ == 'do_help' — built-in help command handler."
    - "cmd.Cmd.emptyline.__name__ == 'emptyline' — called when an empty line is entered."
    - "cmd.Cmd.precmd.__name__ == 'precmd' — hook executed just before a command is dispatched."
    - "cmd.Cmd.postcmd.__name__ == 'postcmd' — hook executed just after a command finishes."
    - "cmd.IDENTCHARS is a str containing ASCII letters, digits, and underscore."
    - "cmd.IDENTCHARS.__class__.__name__ == 'str' — IDENTCHARS is a plain string constant."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Cmd — class name and module affiliation
# ---------------------------------------------------------------------------

invariant cmd_extra.Cmd.name:
  description: "cmd.Cmd.__name__ == 'Cmd'"
  category: class_names
  kind: python_call_eq
  function: Cmd.__name__.__eq__
  args: ["Cmd"]
  expected: true

invariant cmd_extra.Cmd.module:
  description: "cmd.Cmd.__module__ == 'cmd'"
  category: class_modules
  kind: python_call_eq
  function: Cmd.__module__.__eq__
  args: ["cmd"]
  expected: true

# ---------------------------------------------------------------------------
# Cmd method names — core command-loop API
# ---------------------------------------------------------------------------

invariant cmd_extra.Cmd.cmdloop_name:
  description: "cmd.Cmd.cmdloop.__name__ == 'cmdloop'"
  category: methods
  kind: python_call_eq
  function: Cmd.cmdloop.__name__.__eq__
  args: ["cmdloop"]
  expected: true

invariant cmd_extra.Cmd.onecmd_name:
  description: "cmd.Cmd.onecmd.__name__ == 'onecmd'"
  category: methods
  kind: python_call_eq
  function: Cmd.onecmd.__name__.__eq__
  args: ["onecmd"]
  expected: true

invariant cmd_extra.Cmd.default_name:
  description: "cmd.Cmd.default.__name__ == 'default'"
  category: methods
  kind: python_call_eq
  function: Cmd.default.__name__.__eq__
  args: ["default"]
  expected: true

invariant cmd_extra.Cmd.do_help_name:
  description: "cmd.Cmd.do_help.__name__ == 'do_help'"
  category: methods
  kind: python_call_eq
  function: Cmd.do_help.__name__.__eq__
  args: ["do_help"]
  expected: true

invariant cmd_extra.Cmd.emptyline_name:
  description: "cmd.Cmd.emptyline.__name__ == 'emptyline'"
  category: methods
  kind: python_call_eq
  function: Cmd.emptyline.__name__.__eq__
  args: ["emptyline"]
  expected: true

invariant cmd_extra.Cmd.precmd_name:
  description: "cmd.Cmd.precmd.__name__ == 'precmd'"
  category: methods
  kind: python_call_eq
  function: Cmd.precmd.__name__.__eq__
  args: ["precmd"]
  expected: true

invariant cmd_extra.Cmd.postcmd_name:
  description: "cmd.Cmd.postcmd.__name__ == 'postcmd'"
  category: methods
  kind: python_call_eq
  function: Cmd.postcmd.__name__.__eq__
  args: ["postcmd"]
  expected: true

invariant cmd_extra.Cmd.parseline_name:
  description: "cmd.Cmd.parseline.__name__ == 'parseline'"
  category: methods
  kind: python_call_eq
  function: Cmd.parseline.__name__.__eq__
  args: ["parseline"]
  expected: true

# ---------------------------------------------------------------------------
# Cmd method name table — compact form for all remaining public methods
# ---------------------------------------------------------------------------

table cmd_extra.cmd_method_names:
  kind: python_call_eq
  category: methods
  id_prefix: method
  columns: [id, function, args, expected]
  rows:
    - [cmdloop,   Cmd.cmdloop.__name__.__eq__,   ["cmdloop"],   true]
    - [onecmd,    Cmd.onecmd.__name__.__eq__,    ["onecmd"],    true]
    - [default,   Cmd.default.__name__.__eq__,   ["default"],   true]
    - [do_help,   Cmd.do_help.__name__.__eq__,   ["do_help"],   true]
    - [emptyline, Cmd.emptyline.__name__.__eq__,  ["emptyline"], true]
    - [precmd,    Cmd.precmd.__name__.__eq__,    ["precmd"],    true]
    - [postcmd,   Cmd.postcmd.__name__.__eq__,   ["postcmd"],   true]
    - [parseline, Cmd.parseline.__name__.__eq__,  ["parseline"], true]

# ---------------------------------------------------------------------------
# IDENTCHARS — module-level string constant type check
# ---------------------------------------------------------------------------

invariant cmd_extra.IDENTCHARS.is_str:
  description: "cmd.IDENTCHARS.__class__.__name__ == 'str' — IDENTCHARS is a string constant"
  category: module_constants
  kind: python_call_eq
  function: IDENTCHARS.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant cmd_extra.IDENTCHARS.nonempty:
  description: "len(cmd.IDENTCHARS) > 0 — IDENTCHARS is not empty"
  category: module_constants
  kind: python_call_eq
  function: IDENTCHARS.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

invariant cmd_extra.IDENTCHARS.contains_underscore:
  description: "cmd.IDENTCHARS contains '_' — underscore is a valid identifier char"
  category: module_constants
  kind: python_call_eq
  function: IDENTCHARS.__contains__
  args: ["_"]
  expected: true

invariant cmd_extra.IDENTCHARS.contains_alpha:
  description: "cmd.IDENTCHARS contains 'a' — lowercase letters are valid identifier chars"
  category: module_constants
  kind: python_call_eq
  function: IDENTCHARS.__contains__
  args: ["a"]
  expected: true
