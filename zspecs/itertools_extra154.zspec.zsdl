  args: ["accumulate"]
  expected: true

invariant itertools_extra154.groupby_qualname_eq:
  description: "itertools.groupby.__qualname__ == 'groupby' — top-level C type qualname equals name; wave 283; new to extra154"
  kind: python_call_eq
