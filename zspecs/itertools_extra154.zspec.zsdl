spec: itertools_extra154
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools C-type __qualname__ values for cycle, repeat, count, zip_longest, accumulate, groupby — for top-level C types, __qualname__ equals __name__; itertools.count.__mro__.__len__() == 2 confirming single-level inheritance from object (Wave 283)."
    - "itertools.cycle.__qualname__ == 'cycle' — cycle is a top-level C extension type in itertoolsmodule.c; for top-level C types __qualname__ equals __name__. Verified with Python 3.14.3."
    - "itertools.repeat.__qualname__ == 'repeat' — repeat is a top-level C extension type; __qualname__ equals __name__. Verified with Python 3.14.3."
    - "itertools.count.__qualname__ == 'count' — count is a top-level C extension type; __qualname__ equals __name__. Verified with Python 3.14.3."
    - "itertools.zip_longest.__qualname__ == 'zip_longest' — zip_longest is a top-level C extension type; __qualname__ equals __name__. Verified with Python 3.14.3."
    - "itertools.accumulate.__qualname__ == 'accumulate' — accumulate is a top-level C extension type; __qualname__ equals __name__. Verified with Python 3.14.3."
    - "itertools.groupby.__qualname__ == 'groupby' — groupby is a top-level C extension type; __qualname__ equals __name__. Verified with Python 3.14.3."
    - "itertools.count.__mro__.__len__() == 2 — count inherits directly from object; MRO is [count, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools __qualname__ values — cycle, repeat, count, zip_longest
#
# Wave 283 theme: itertools module-level C type __qualname__ values.
#
# itertools.cycle.__qualname__ == 'cycle'
# itertools.repeat.__qualname__ == 'repeat'
# itertools.count.__qualname__ == 'count'
# itertools.zip_longest.__qualname__ == 'zip_longest'
#
# For C extension types defined at module scope (not nested in another class),
# __qualname__ equals __name__. All itertools types are top-level C types,
# so their qualnames equal their simple names. New to extra154.
# ---------------------------------------------------------------------------

table itertools_extra154.cycle_repeat_count_zip_longest_qualname:
  description: "itertools cycle/repeat/count/zip_longest: __qualname__ equals __name__; C types at module scope have qualname == name; wave 283; new to extra154"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolscrcq154

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_qualname_eq_cycle,
       "cycle.__qualname__.__eq__",
       ["cycle"],
       true,
       "itertools.cycle.__qualname__.__eq__('cycle') == True — cycle is a C extension type defined at module scope in itertoolsmodule.c; for top-level C types __qualname__ equals __name__; __qualname__ is 'cycle'; str.__eq__('cycle') returns True; new to extra154"]
    - [repeat_qualname_eq_repeat,
       "repeat.__qualname__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat.__qualname__.__eq__('repeat') == True — repeat is a C extension type defined at module scope; for top-level C types __qualname__ equals __name__; __qualname__ is 'repeat'; str.__eq__('repeat') returns True; new to extra154"]
    - [count_qualname_eq_count,
       "count.__qualname__.__eq__",
       ["count"],
       true,
       "itertools.count.__qualname__.__eq__('count') == True — count is a C extension type defined at module scope; __qualname__ equals __name__ 'count' for top-level C types; str.__eq__('count') returns True; new to extra154"]
    - [zip_longest_qualname_eq_zip_longest,
       "zip_longest.__qualname__.__eq__",
       ["zip_longest"],
       true,
       "itertools.zip_longest.__qualname__.__eq__('zip_longest') == True — zip_longest is a C extension type aggregating iterables with fill values; __qualname__ equals __name__ 'zip_longest' for top-level C types; str.__eq__('zip_longest') returns True; new to extra154"]

# ---------------------------------------------------------------------------
# Table 2: itertools __qualname__ values — accumulate, groupby; count MRO len
#
# Wave 283 theme: more itertools C type __qualname__ values and count MRO.
#
# itertools.accumulate.__qualname__ == 'accumulate'
# itertools.groupby.__qualname__ == 'groupby'
# itertools.count.__mro__.__len__() == 2
#
# accumulate and groupby are both top-level C extension types in
# itertoolsmodule.c. count's MRO is [count, object] (length 2).
# New to extra154.
# ---------------------------------------------------------------------------

table itertools_extra154.accumulate_groupby_qualname_and_count_mro:
  description: "itertools accumulate/groupby: __qualname__ equals __name__; count.__mro__.__len__() 2; wave 283; new to extra154"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsagcm154

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_qualname_eq_accumulate,
       "accumulate.__qualname__.__eq__",
       ["accumulate"],
       true,
       "itertools.accumulate.__qualname__.__eq__('accumulate') == True — accumulate is a C extension type computing running totals; __qualname__ equals __name__ 'accumulate' for top-level C types; str.__eq__('accumulate') returns True; new to extra154"]
    - [groupby_qualname_eq_groupby,
       "groupby.__qualname__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__qualname__.__eq__('groupby') == True — groupby is a C extension type grouping consecutive elements sharing a key; __qualname__ equals __name__ 'groupby' for top-level C types; str.__eq__('groupby') returns True; new to extra154"]
    - [count_mro_len_eq_2,
       "count.__mro__.__len__",
       [],
       2,
       "itertools.count.__mro__.__len__() == 2 — count is a C extension type inheriting directly from object; MRO is [count, object]; len(__mro__) == 2; new to extra154"]
    - [cycle_mro_len_eq_2,
       "cycle.__mro__.__len__",
       [],
       2,
       "itertools.cycle.__mro__.__len__() == 2 — cycle is a C extension type inheriting directly from object; MRO is [cycle, object]; len(__mro__) == 2; new to extra154"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra154
# ---------------------------------------------------------------------------

invariant itertools_extra154.cycle_qualname_eq_cycle:
  description: "itertools.cycle.__qualname__ == 'cycle' — top-level C type qualname equals name; wave 283; new to extra154"
  kind: python_call_eq
  function: cycle.__qualname__.__eq__
  args: ["cycle"]
  expected: true

invariant itertools_extra154.repeat_qualname_eq_repeat:
  description: "itertools.repeat.__qualname__ == 'repeat' — top-level C type qualname equals name; wave 283; new to extra154"
  kind: python_call_eq
  function: repeat.__qualname__.__eq__
  args: ["repeat"]
  expected: true

invariant itertools_extra154.count_qualname_eq_count:
  description: "itertools.count.__qualname__ == 'count' — top-level C type qualname equals name; wave 283; new to extra154"
  kind: python_call_eq
  function: count.__qualname__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra154.zip_longest_qualname_eq:
  description: "itertools.zip_longest.__qualname__ == 'zip_longest' — top-level C type qualname equals name; wave 283; new to extra154"
  kind: python_call_eq
  function: zip_longest.__qualname__.__eq__
  args: ["zip_longest"]
