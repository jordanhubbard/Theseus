  args: ["groupby"]
  expected: true

invariant itertools_extra154.count_mro_len_2:
  description: "itertools.count.__mro__.__len__() == 2 — count inherits from object only; MRO is [count, object]; wave 283; new to extra154"
  kind: python_call_eq
  function: count.__mro__.__len__
  args: []
  expected: 2
