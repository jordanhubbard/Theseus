spec: socket_extra136
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra135.zspec.zsdl — covers socket.socket.recvfrom/sendto/shutdown/settimeout/gettimeout/setblocking qualname and class name / close __class__.__name__=='function' and __module__=='socket' (table + invariants)."
    - "socket_extra132.zspec.zsdl — covers socket.socket.bind/connect/listen qualname equality / socket.socket.send/recv qualname equality / bind/connect/listen/send/recv __class__.__name__=='method_descriptor' / socket.socket.__init__ and accept qualname equality (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module function __qualname__.__len__() / SocketIO class identity (table + invariants)."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values (table + invariants)."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__ (table + invariants)."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC __class__.__name__=='AddressFamily' / gethostname/gethostbyname as C builtins / getaddrinfo/create_connection as Python functions (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior socket spec files."
    - "Wave 360 theme: socket.socket.setsockopt/getsockopt/getsockname/getpeername/fileno qualname, __name__, __class__.__name__, and __objclass__ identity."
    - "socket.socket.setsockopt.__qualname__ == 'socket.setsockopt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__qualname__ == 'socket.getsockopt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockname.__qualname__ == 'socket.getsockname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getpeername.__qualname__ == 'socket.getpeername'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.fileno.__qualname__ == 'socket.fileno'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockname.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getpeername.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.fileno.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__name__ == 'setsockopt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__name__ == 'getsockopt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockname.__name__ == 'getsockname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getpeername.__name__ == 'getpeername'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.fileno.__name__ == 'fileno'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__objclass__.__name__ == 'socket'. __objclass__ is the C-level class named 'socket' (from _socket), not the Python-level 'socket.socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__objclass__.__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.fileno.__objclass__.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket_extra97 anchors socket.socket.fileno.__qualname__.__eq__ at table level. socket_extra135 covers setblocking/settimeout/gettimeout. socket_extra132 covers bind/connect/listen/send/recv. This spec is the first to anchor setsockopt/getsockopt/getsockname/getpeername qualname, __name__, __class__.__name__, and __objclass__ via __eq__ calls under socksockopt136."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.setsockopt.__qualname__.__eq__('socket.setsockopt')
# socket.socket.getsockopt.__qualname__.__eq__('socket.getsockopt')
# socket.socket.getsockname.__qualname__.__eq__('socket.getsockname')
# socket.socket.setsockopt.__class__.__name__.__eq__('method_descriptor')
# socket.socket.getsockopt.__class__.__name__.__eq__('method_descriptor')
#
# Wave 360 theme: socket option and name methods qualname and class.
#
# socket.socket.setsockopt, getsockopt, getsockname, and getpeername are
# method_descriptor objects inherited from _socket.socket (the C extension).
# Their qualnames use the C-level class name 'socket.' prefix (not 'socket.socket.')
# — the same pattern as bind/connect/listen (anchored in extra132) and
# recvfrom/sendto (anchored in extra135). socket_extra97 anchors fileno.__qualname__
# at table level via __len__; this spec anchors setsockopt/getsockopt/getsockname
# qualname via __eq__ for the first time under socksockopt136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra136.setsockopt_getsockopt_getsockname_qualnames:
  description: "socket.socket/setsockopt/__qualname__.__eq__('socket.setsockopt')==True / getsockopt/__qualname__.__eq__('socket.getsockopt')==True / getsockname/__qualname__.__eq__('socket.getsockname')==True / setsockopt/__class__/__name__.__eq__('method_descriptor')==True / getsockopt/__class__/__name__.__eq__('method_descriptor')==True — setsockopt/getsockopt/getsockname are method_descriptor from _socket.socket; qualnames use C-level 'socket.' prefix; extra132 covers bind/connect/listen; first socksockopt136 anchor for setsockopt/getsockopt/getsockname qualname"
  kind: python_call_eq
  category: type_identity
  id_prefix: socksockopt136

  columns: [id, function, args, expected, description]
  rows:
    - [setsockopt_qual,   socket.setsockopt.__qualname__.__eq__,             ["socket.setsockopt"],  true, "socket.setsockopt.__qualname__ is 'socket.setsockopt' (sets socket option at given level)"]
    - [getsockopt_qual,   socket.getsockopt.__qualname__.__eq__,             ["socket.getsockopt"],  true, "socket.getsockopt.__qualname__ is 'socket.getsockopt' (retrieves socket option value)"]
    - [getsockname_qual,  socket.getsockname.__qualname__.__eq__,            ["socket.getsockname"], true, "socket.getsockname.__qualname__ is 'socket.getsockname' (returns local address of socket)"]
    - [setsockopt_cls,    socket.setsockopt.__class__.__name__.__eq__,       ["method_descriptor"],  true, "socket.setsockopt.__class__.__name__ is 'method_descriptor' (C-level method from _socket.socket)"]
    - [getsockopt_cls,    socket.getsockopt.__class__.__name__.__eq__,       ["method_descriptor"],  true, "socket.getsockopt.__class__.__name__ is 'method_descriptor' (C-level method from _socket.socket)"]

# ---------------------------------------------------------------------------
# socket.socket.getpeername.__qualname__.__eq__('socket.getpeername')
# socket.socket.fileno.__qualname__.__eq__('socket.fileno')
# socket.socket.getsockname.__class__.__name__.__eq__('method_descriptor')
# socket.socket.getpeername.__class__.__name__.__eq__('method_descriptor')
# socket.socket.fileno.__class__.__name__.__eq__('method_descriptor')
#
# Wave 360 theme: getpeername and fileno qualname and class.
#
# socket.socket.getpeername returns the remote address of a connected socket
# (raises OSError if the socket is not connected). socket.socket.fileno returns
# the underlying OS file descriptor integer. Both are method_descriptor objects
# from _socket.socket. socket_extra97 anchors fileno via __qualname__.__eq__ in
# a table row (and __len__()); this spec anchors fileno and getpeername qualname
# and class name via __eq__ as cross-checks under socksockopt136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra136.getpeername_fileno_qualname_and_class:
  description: "socket.socket/getpeername/__qualname__.__eq__('socket.getpeername')==True / fileno/__qualname__.__eq__('socket.fileno')==True / getsockname/__class__/__name__.__eq__('method_descriptor')==True / getpeername/__class__/__name__.__eq__('method_descriptor')==True / fileno/__class__/__name__.__eq__('method_descriptor')==True — getpeername returns remote address; fileno returns OS file descriptor; all three are method_descriptor; extra97 anchors fileno via __len__; first socksockopt136 anchor for getpeername qualname and class and fileno class"
  kind: python_call_eq
  category: type_identity
  id_prefix: socksockopt136

  columns: [id, function, args, expected, description]
  rows:
    - [getpeername_qual,  socket.getpeername.__qualname__.__eq__,             ["socket.getpeername"], true, "socket.getpeername.__qualname__ is 'socket.getpeername' (returns remote address of connected socket)"]
    - [fileno_qual,       socket.fileno.__qualname__.__eq__,                  ["socket.fileno"],      true, "socket.fileno.__qualname__ is 'socket.fileno' (returns underlying OS file descriptor integer)"]
    - [getsockname_cls,   socket.getsockname.__class__.__name__.__eq__,       ["method_descriptor"],  true, "socket.getsockname.__class__.__name__ is 'method_descriptor' (C-level method from _socket.socket)"]
    - [getpeername_cls,   socket.getpeername.__class__.__name__.__eq__,       ["method_descriptor"],  true, "socket.getpeername.__class__.__name__ is 'method_descriptor' (C-level method from _socket.socket)"]
    - [fileno_cls,        socket.fileno.__class__.__name__.__eq__,            ["method_descriptor"],  true, "socket.fileno.__class__.__name__ is 'method_descriptor' (C-level method from _socket.socket)"]

# ---------------------------------------------------------------------------
# socket.socket.setsockopt.__name__.__eq__('setsockopt')
# socket.socket.getsockopt.__name__.__eq__('getsockopt')
# socket.socket.getsockname.__name__.__eq__('getsockname')
# socket.socket.getpeername.__name__.__eq__('getpeername')
# socket.socket.setsockopt.__objclass__.__name__.__eq__('socket')
#
# Wave 360 theme: socket option method __name__ and __objclass__ identity.
#
# The __name__ attribute of a method_descriptor is the short method name without
# the class prefix. setsockopt.__name__ == 'setsockopt' (not 'socket.setsockopt').
# The __objclass__ of these methods is the C-level class named 'socket' (from
# _socket) — not the Python-level 'socket.socket'. The C-level class is named
# 'socket', which explains why all qualnames use the 'socket.' prefix rather than
# 'socket.socket.'. No prior socket spec anchors setsockopt/getsockopt/getsockname/
# getpeername __name__ or setsockopt __objclass__.__name__ under socksockopt136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra136.sockopt_names_and_objclass:
  description: "socket.socket/setsockopt/__name__.__eq__('setsockopt')==True / getsockopt/__name__.__eq__('getsockopt')==True / getsockname/__name__.__eq__('getsockname')==True / getpeername/__name__.__eq__('getpeername')==True / setsockopt/__objclass__/__name__.__eq__('socket')==True — __name__ is short form without 'socket.' prefix; __objclass__.__name__ is 'socket' (C-level class, not Python-level 'socket.socket'); first socksockopt136 anchor for setsockopt/getsockopt/getsockname/getpeername __name__ and setsockopt __objclass__"
  kind: python_call_eq
  category: type_identity
  id_prefix: socksockopt136

  columns: [id, function, args, expected, description]
  rows:
    - [setsockopt_name,    socket.setsockopt.__name__.__eq__,             ["setsockopt"],  true, "socket.setsockopt.__name__ is 'setsockopt' (short form; set socket option e.g. SO_REUSEADDR)"]
    - [getsockopt_name,    socket.getsockopt.__name__.__eq__,             ["getsockopt"],  true, "socket.getsockopt.__name__ is 'getsockopt' (short form; retrieve socket option value)"]
    - [getsockname_name,   socket.getsockname.__name__.__eq__,            ["getsockname"], true, "socket.getsockname.__name__ is 'getsockname' (short form; returns local (host, port) tuple)"]
    - [getpeername_name,   socket.getpeername.__name__.__eq__,            ["getpeername"], true, "socket.getpeername.__name__ is 'getpeername' (short form; returns remote (host, port) tuple)"]
    - [setsockopt_obj,     socket.setsockopt.__objclass__.__name__.__eq__, ["socket"],     true, "socket.setsockopt.__objclass__.__name__ is 'socket' (C-level class from _socket; not Python 'socket.socket')"]

# ---------------------------------------------------------------------------
# socket.socket.setsockopt.__qualname__.__eq__('socket.setsockopt') — standalone
#
# socket.socket.setsockopt.__qualname__ is 'socket.setsockopt'. setsockopt sets
# a socket option at a given level (e.g., socket.SOL_SOCKET) with a given option
# name (e.g., socket.SO_REUSEADDR). It is a method_descriptor inherited from the
# C extension _socket.socket. The qualname 'socket.setsockopt' uses the C-level
# class name 'socket' (not the Python-level 'socket.socket') — the same pattern
# seen across all _socket.socket method_descriptors. No prior socket spec anchors
# setsockopt.__qualname__ via __eq__ as a standalone under socksockopt136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra136.setsockopt_qualname:
  description: "socket.socket.setsockopt.__qualname__.__eq__('socket.setsockopt') == True — setsockopt is a C method_descriptor from _socket.socket; sets socket options (e.g., SO_REUSEADDR at SOL_SOCKET level); qualname uses C-level 'socket.' prefix; first standalone for setsockopt.__qualname__.__eq__ under socksockopt136"
  category: type_identity
  kind: python_call_eq
  function: socket.setsockopt.__qualname__.__eq__
  args: ["socket.setsockopt"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.getsockopt.__qualname__.__eq__('socket.getsockopt') — standalone
#
# socket.socket.getsockopt.__qualname__ is 'socket.getsockopt'. getsockopt is
# the complement to setsockopt: it retrieves the current value of a socket option.
# It takes the same level/option arguments as setsockopt and an optional buflen
# for options that return a buffer. It is a method_descriptor from _socket.socket.
# No prior socket spec anchors getsockopt.__qualname__ via __eq__ as a standalone
# under socksockopt136. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra136.getsockopt_qualname:
  description: "socket.socket.getsockopt.__qualname__.__eq__('socket.getsockopt') == True — getsockopt is a C method_descriptor from _socket.socket; retrieves current socket option value; complement to setsockopt; qualname uses C-level 'socket.' prefix; first standalone for getsockopt.__qualname__.__eq__ under socksockopt136"
  category: type_identity
  kind: python_call_eq
  function: socket.getsockopt.__qualname__.__eq__
  args: ["socket.getsockopt"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.getsockname.__qualname__.__eq__('socket.getsockname') — standalone
#
# socket.socket.getsockname.__qualname__ is 'socket.getsockname'. getsockname
# returns the local address to which the socket is bound. For AF_INET sockets
# this is a (host, port) tuple; for AF_UNIX sockets it is a path string. It is
# particularly useful to find the port assigned by the OS when bind() was called
# with port 0 (ephemeral port). It is a method_descriptor from _socket.socket.
# No prior socket spec anchors getsockname.__qualname__ via __eq__ as a standalone
# under socksockopt136. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra136.getsockname_qualname:
  description: "socket.socket.getsockname.__qualname__.__eq__('socket.getsockname') == True — getsockname returns local (host, port) address; useful for finding OS-assigned ephemeral ports (after bind with port 0); C method_descriptor from _socket.socket; first standalone for getsockname.__qualname__.__eq__ under socksockopt136"
  category: type_identity
  kind: python_call_eq
  function: socket.getsockname.__qualname__.__eq__
  args: ["socket.getsockname"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.getpeername.__qualname__.__eq__('socket.getpeername') — standalone
#
# socket.socket.getpeername.__qualname__ is 'socket.getpeername'. getpeername
# returns the remote address of a connected socket (raises OSError if not
# connected). It is the counterpart to getsockname: getsockname returns the
# local address, getpeername returns the remote address. For AF_INET sockets
# this is a (host, port) tuple identifying the peer. It is a method_descriptor
# from _socket.socket. No prior socket spec anchors getpeername.__qualname__ via
# __eq__ as a standalone under socksockopt136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra136.getpeername_qualname:
  description: "socket.socket.getpeername.__qualname__.__eq__('socket.getpeername') == True — getpeername returns remote (host, port) address (complement to getsockname which returns local address); raises OSError if not connected; C method_descriptor from _socket.socket; first standalone for getpeername.__qualname__.__eq__ under socksockopt136"
  category: type_identity
  kind: python_call_eq
  function: socket.getpeername.__qualname__.__eq__
  args: ["socket.getpeername"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.setsockopt.__objclass__.__name__.__eq__('socket') — standalone
#
# socket.socket.setsockopt.__objclass__.__name__ is 'socket'. The __objclass__
# of a method_descriptor reveals the class that defines it. For all _socket.socket
# method_descriptors (setsockopt, getsockopt, getsockname, getpeername, fileno,
# recv, send, bind, connect, etc.), __objclass__.__name__ is 'socket' — the name
# of the C-level class, not the Python-level class 'socket.socket'. The Python-
# level socket.socket (from Lib/socket.py) inherits from _socket.socket and adds
# Python-level methods (close, accept, makefile). No prior socket spec anchors
# setsockopt.__objclass__.__name__ via __eq__ as a standalone under socksockopt136.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra136.setsockopt_objclass_name:
  description: "socket.socket.setsockopt.__objclass__.__name__.__eq__('socket') == True — __objclass__.__name__ is 'socket' (C-level class name from _socket, not the Python-level 'socket.socket'); all _socket.socket method_descriptors share this __objclass__; first standalone for setsockopt.__objclass__.__name__.__eq__ under socksockopt136"
  category: type_identity
  kind: python_call_eq
  function: socket.setsockopt.__objclass__.__name__.__eq__
  args: ["socket"]
  expected: true

