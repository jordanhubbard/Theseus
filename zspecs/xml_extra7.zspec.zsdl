spec: xml_extra7
version: ">=3.9"
backend: python_module(xml.etree.ElementTree)

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xml.etree.elementtree.html — Python xml.etree.ElementTree module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xml/etree/ElementTree.py"
    - "xml_extra.zspec.zsdl — covers Element/ElementTree/SubElement/ParseError __name__, parse/fromstring/tostring __name__, ParseError base"
    - "xml_extra2.zspec.zsdl — covers fromstring tag/attrib, Element tag/attrib, tostring result class, ParseError name/base, VERSION/XML_VERSION class names, SubElement __name__"
    - "xml_extra3.zspec.zsdl — covers Element/__qualname__/ElementTree/__qualname__/XMLParser/__qualname__/ParseError/__qualname__, function __qualname__ (tostring/indent/iterparse/parse), Element/__module__/XMLParser/__module__, bases, function type checks, ParseError/Element is_type"
    - "xml_extra4.zspec.zsdl — covers Comment/ProcessingInstruction/register_namespace __qualname__/__module__/__class__.__name__; Element.text/tail is None; fromstring text content; tostring unicode encoding"
    - "xml_extra5.zspec.zsdl — covers Element/__name__/ElementTree/__name__/ParseError/__name__ standalone; ParseError.__bases__.__getitem__(0).__name__ via method chain; fromstring tag/attrib via method chain"
    - "xml_extra6.zspec.zsdl — covers Element/ParseError __bases__[0].__name__ via __eq__ chain; parse/tostring/fromstring __module__ standalone; Element/XMLParser __module__ table"
    - "xml_etree_extra2.zspec.zsdl — covers SubElement/__qualname__, fromstring/__qualname__, function __module__ table (SubElement/fromstring/tostring/parse/indent/iterparse), ParseError.__module__, SubElement callable"
  notes:
    - "This spec extends all prior xml.etree.ElementTree specs through xml_extra6.zspec.zsdl."
    - "Focus: __qualname__ for ElementTree instance methods — a new axis not in any prior xml spec."
    - "ElementTree.parse.__qualname__ == 'ElementTree.parse' — method qualname includes the class name."
    - "ElementTree.write.__qualname__ == 'ElementTree.write' — method qualname includes the class name."
    - "ElementTree.find.__qualname__ == 'ElementTree.find' — method qualname includes the class name."
    - "ElementTree.getroot.__qualname__ == 'ElementTree.getroot' — method qualname includes the class name."
    - "ElementTree.__class__.__name__ == 'type' — ElementTree is a class object (a type)."
    - "ElementTree.__bases__[0].__name__ == 'object' — ElementTree inherits directly from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ElementTree method __qualname__ — class.method pattern
#
# No prior xml spec checks the __qualname__ of ElementTree instance methods.
# For methods defined inside a class, __qualname__ == 'ClassName.method_name'.
# Verified at runtime with Python 3.12.
# ---------------------------------------------------------------------------

table xml_extra7.ElementTree_method_qualnames:
  description: "__qualname__ for ElementTree instance methods"
  kind: python_call_eq
  category: qualnames
  id_prefix: etmq

  columns: [id, function, args, expected]
  rows:
    - [parse,    ElementTree.parse.__qualname__.__eq__,    ["ElementTree.parse"],    true]
    - [write,    ElementTree.write.__qualname__.__eq__,    ["ElementTree.write"],    true]
    - [find,     ElementTree.find.__qualname__.__eq__,     ["ElementTree.find"],     true]
    - [getroot,  ElementTree.getroot.__qualname__.__eq__,  ["ElementTree.getroot"],  true]

# ---------------------------------------------------------------------------
# ElementTree class identity
#
# xml_extra3.Element.is_type checks Element.__class__.__name__ == 'type'.
# No prior spec checks ElementTree.__class__.__name__.
# Verified at runtime: ElementTree is a plain class (type).
# ---------------------------------------------------------------------------

invariant xml_extra7.ElementTree.is_type:
  description: "xml.etree.ElementTree.ElementTree.__class__.__name__ == 'type'"
  category: class_type
  kind: python_call_eq
  function: ElementTree.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# ElementTree base class
#
# xml_extra3 checks XMLParser.__bases__[0] and Element.__bases__[0].
# xml_extra6 re-checks Element base via __eq__ chain.
# No prior spec checks ElementTree.__bases__[0].__name__ as a standalone
# invariant in the xml_extra namespace.
# Verified at runtime: ElementTree.__bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant xml_extra7.ElementTree.base_is_object:
  description: "xml.etree.ElementTree.ElementTree.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "ElementTree.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
