spec: xml_extra3
version: ">=3.9"
backend: python_module(xml.etree.ElementTree)

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xml.etree.elementtree.html — Python xml.etree.ElementTree documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xml/etree/ElementTree.py"
  notes:
    - "This spec extends xml_extra.zspec.zsdl, xml_extra2.zspec.zsdl, xml_etree_extra.zspec.zsdl, xml_parse.zspec.zsdl, xml_dom.zspec.zsdl, xml_sax.zspec.zsdl, and xml_minidom.zspec.zsdl."
    - "xml_parse.zspec.zsdl covers ElementTree/XMLParser/ParseError __module__ (exact value 'xml.etree.ElementTree'), ParseError base, ElementTree.__bases__[0].__name__=='object', XMLParser feed+close."
    - "xml_etree_extra.zspec.zsdl covers Element.__name__, SubElement.__name__, parse/fromstring/tostring/indent/iterparse/register_namespace __name__, Comment/ProcessingInstruction __name__, ParseError name/base, fromstring result class, Element.__module__ class name check (== 'str')."
    - "xml_extra.zspec.zsdl covers class/function __name__ table (Element, ElementTree, SubElement, ParseError, parse, fromstring, tostring), ParseError base."
    - "xml_extra2.zspec.zsdl covers fromstring tag/attrib behavior, Element tag/attrib, tostring result class, ParseError class_name, VERSION/XML_VERSION constants, SubElement.__name__, ParseError base."
    - "This spec adds: Element.__module__ exact value check, XMLParser.__qualname__, Element/__qualname__, ElementTree/__qualname__, function __qualname__ checks for indent/iterparse/tostring/parse/SubElement, XMLParser.__module__, Element.__bases__[0].__name__=='object'."
    - "xml.etree.ElementTree.Element.__module__ == 'xml.etree.ElementTree' — verified on CPython 3.12."
    - "xml.etree.ElementTree.XMLParser.__qualname__ == 'XMLParser' — not a nested class."
    - "xml.etree.ElementTree.indent.__qualname__ == 'indent' — top-level function added in 3.9."
    - "xml.etree.ElementTree.Element.__bases__[0].__name__ == 'object' — Element has no special base class."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module membership — exact value checks for symbols not yet checked
# (xml_parse covers ElementTree/XMLParser/ParseError module;
#  xml_etree_extra checks Element.__module__.__class__.__name__ == 'str' only)
# ---------------------------------------------------------------------------

invariant xml_extra3.Element.module:
  description: "xml.etree.ElementTree.Element.__module__ == 'xml.etree.ElementTree'"
  category: modules
  kind: python_call_eq
  function: Element.__module__.__eq__
  args: ["xml.etree.ElementTree"]
  expected: true

invariant xml_extra3.XMLParser.module:
  description: "xml.etree.ElementTree.XMLParser.__module__ == 'xml.etree.ElementTree'"
  category: modules
  kind: python_call_eq
  function: XMLParser.__module__.__eq__
  args: ["xml.etree.ElementTree"]
  expected: true

# ---------------------------------------------------------------------------
# Qualified name checks — top-level classes have __qualname__ == __name__
# (not covered in any prior xml spec)
# ---------------------------------------------------------------------------

table xml_extra3.class_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Element,     Element.__qualname__.__eq__,     ["Element"],     true]
    - [ElementTree, ElementTree.__qualname__.__eq__, ["ElementTree"], true]
    - [XMLParser,   XMLParser.__qualname__.__eq__,   ["XMLParser"],   true]
    - [ParseError,  ParseError.__qualname__.__eq__,  ["ParseError"],  true]

# ---------------------------------------------------------------------------
# Function qualified name checks — module-level functions
# (not covered in any prior xml spec)
# ---------------------------------------------------------------------------

table xml_extra3.function_qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: fnqualname

  columns: [id, function, args, expected]
  rows:
    - [tostring,   tostring.__qualname__.__eq__,   ["tostring"],   true]
    - [indent,     indent.__qualname__.__eq__,     ["indent"],     true]
    - [iterparse,  iterparse.__qualname__.__eq__,  ["iterparse"],  true]
    - [parse,      parse.__qualname__.__eq__,      ["parse"],      true]

# ---------------------------------------------------------------------------
# Element — base class is object
# (not covered in prior specs; xml_parse checks ElementTree.__bases__[0] only)
# ---------------------------------------------------------------------------

invariant xml_extra3.Element.base_is_object:
  description: "xml.etree.ElementTree.Element.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: Element.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# XMLParser — base class is object
# ---------------------------------------------------------------------------

invariant xml_extra3.XMLParser.base_is_object:
  description: "xml.etree.ElementTree.XMLParser.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: XMLParser.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Function type checks — module-level functions are Python functions
# (not covered in prior specs which focus on __name__ only)
# ---------------------------------------------------------------------------

table xml_extra3.function_type_checks:
  kind: python_call_eq
  category: types
  id_prefix: typecheck

  columns: [id, function, args, expected]
  rows:
    - [indent,    indent.__class__.__name__.__eq__,    ["function"], true]
    - [iterparse, iterparse.__class__.__name__.__eq__, ["function"], true]
    - [parse,     parse.__class__.__name__.__eq__,     ["function"], true]
    - [tostring,  tostring.__class__.__name__.__eq__,  ["function"], true]

# ---------------------------------------------------------------------------
# ParseError — is_type check (class is an instance of type)
# (not tested in prior specs as a standalone invariant)
# ---------------------------------------------------------------------------

invariant xml_extra3.ParseError.is_type:
  description: "xml.etree.ElementTree.ParseError.__class__.__name__ == 'type'"
  category: class_type
  kind: python_call_eq
  function: ParseError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Element — is_type check
# ---------------------------------------------------------------------------

invariant xml_extra3.Element.is_type:
  description: "xml.etree.ElementTree.Element.__class__.__name__ == 'type'"
  category: class_type
  kind: python_call_eq
  function: Element.__class__.__name__.__eq__
  args: ["type"]
  expected: true
