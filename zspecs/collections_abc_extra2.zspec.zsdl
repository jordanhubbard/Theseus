spec: collections_abc_extra2
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — Python collections.abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "This spec extends collections_abc_extra.zspec.zsdl with __module__ checks for additional ABCs and __bases__[0].__name__ hierarchy checks."
    - "collections_abc_extra.zspec.zsdl covers: __name__ and __module__ for Callable, Iterable, Iterator, Generator, Sequence, MutableSequence, Mapping, MutableMapping, Set, MutableSet; hierarchy checks for Iterator->Iterable, Generator->Iterator, MutableSequence->Sequence, MutableMapping->Mapping."
    - "This spec adds: __module__ checks for Awaitable, Coroutine, AsyncIterable, AsyncIterator, AsyncGenerator (all == 'collections.abc')."
    - "Also adds __bases__[0].__name__ hierarchy checks for Coroutine, AsyncIterator, AsyncGenerator, MutableSet, Set."
    - "collections.abc.Awaitable.__module__ == 'collections.abc'."
    - "collections.abc.Coroutine.__bases__[0].__name__ == 'Awaitable' — Coroutine inherits from Awaitable."
    - "collections.abc.AsyncIterator.__bases__[0].__name__ == 'AsyncIterable' — AsyncIterator inherits from AsyncIterable."
    - "collections.abc.AsyncGenerator.__bases__[0].__name__ == 'AsyncIterator' — AsyncGenerator inherits from AsyncIterator."
    - "collections.abc.MutableSet.__bases__[0].__name__ == 'Set' — MutableSet inherits from Set."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — Awaitable, Coroutine, AsyncIterable, AsyncIterator,
# AsyncGenerator (all must report 'collections.abc')
# ---------------------------------------------------------------------------

invariant collections_abc_extra2.Awaitable.module:
  description: "collections.abc.Awaitable.__module__ == 'collections.abc'"
  category: module_checks
  kind: python_call_eq
  function: Awaitable.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant collections_abc_extra2.Coroutine.module:
  description: "collections.abc.Coroutine.__module__ == 'collections.abc'"
  category: module_checks
  kind: python_call_eq
  function: Coroutine.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant collections_abc_extra2.AsyncIterable.module:
  description: "collections.abc.AsyncIterable.__module__ == 'collections.abc'"
  category: module_checks
  kind: python_call_eq
  function: AsyncIterable.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant collections_abc_extra2.AsyncIterator.module:
  description: "collections.abc.AsyncIterator.__module__ == 'collections.abc'"
  category: module_checks
  kind: python_call_eq
  function: AsyncIterator.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant collections_abc_extra2.AsyncGenerator.module:
  description: "collections.abc.AsyncGenerator.__module__ == 'collections.abc'"
  category: module_checks
  kind: python_call_eq
  function: AsyncGenerator.__module__.__eq__
  args: ["collections.abc"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ table — Sequence, Mapping, MutableSequence, MutableMapping,
# Set, MutableSet, Iterable, Iterator, Generator, Callable (comprehensive
# table form for cross-reference completeness)
# ---------------------------------------------------------------------------

table collections_abc_extra2.module_checks:
  kind: python_call_eq
  category: module_checks
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [Sequence,         Sequence.__module__.__eq__,         ["collections.abc"], true]
    - [Mapping,          Mapping.__module__.__eq__,          ["collections.abc"], true]
    - [MutableSequence,  MutableSequence.__module__.__eq__,  ["collections.abc"], true]
    - [MutableMapping,   MutableMapping.__module__.__eq__,   ["collections.abc"], true]
    - [Set,              Set.__module__.__eq__,              ["collections.abc"], true]
    - [MutableSet,       MutableSet.__module__.__eq__,       ["collections.abc"], true]
    - [Iterable,         Iterable.__module__.__eq__,         ["collections.abc"], true]
    - [Iterator,         Iterator.__module__.__eq__,         ["collections.abc"], true]
    - [Generator,        Generator.__module__.__eq__,        ["collections.abc"], true]
    - [Callable,         Callable.__module__.__eq__,         ["collections.abc"], true]

# ---------------------------------------------------------------------------
# Class hierarchy — __bases__[0].__name__ checks
#
# Coroutine  -> Awaitable
# AsyncIterator -> AsyncIterable
# AsyncGenerator -> AsyncIterator
# MutableSet -> Set
# Set -> (Hashable, Iterable, Container) — first base is Hashable
# ---------------------------------------------------------------------------

invariant collections_abc_extra2.Coroutine.base_is_Awaitable:
  description: "collections.abc.Coroutine.__bases__[0].__name__ == 'Awaitable' — Coroutine directly inherits from Awaitable"
  category: class_hierarchy
  kind: python_call_eq
  function: Coroutine.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Awaitable"

invariant collections_abc_extra2.AsyncIterator.base_is_AsyncIterable:
  description: "collections.abc.AsyncIterator.__bases__[0].__name__ == 'AsyncIterable' — AsyncIterator directly inherits from AsyncIterable"
  category: class_hierarchy
  kind: python_call_eq
  function: AsyncIterator.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "AsyncIterable"

invariant collections_abc_extra2.AsyncGenerator.base_is_AsyncIterator:
  description: "collections.abc.AsyncGenerator.__bases__[0].__name__ == 'AsyncIterator' — AsyncGenerator directly inherits from AsyncIterator"
  category: class_hierarchy
  kind: python_call_eq
  function: AsyncGenerator.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "AsyncIterator"

invariant collections_abc_extra2.MutableSet.base_is_Set:
  description: "collections.abc.MutableSet.__bases__[0].__name__ == 'Set' — MutableSet directly inherits from Set"
  category: class_hierarchy
  kind: python_call_eq
  function: MutableSet.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Set"
