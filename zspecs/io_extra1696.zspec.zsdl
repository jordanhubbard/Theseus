spec: io_extra1696
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/*.c"
    - "io.zspec.zsdl — covers core io type attributes and read/write interface"
  notes:
    - "Wave 560 (_extra1696): pickling protocol — which stdlib types define __reduce__, __getstate__, __setstate__, __getnewargs__, __getnewargs_ex__ in their own __dict__."
    - "io.BytesIO defines __getstate__ and __setstate__ in its __dict__ to support pickling (saves/restores buffer and position)."
    - "io.StringIO defines __getstate__ and __setstate__ in its __dict__ (same pattern as BytesIO)."
    - "io.FileIO defines __getstate__ (but NOT __setstate__) — this reflects that FileIO records state but cannot round-trip a file descriptor."
    - "io.BufferedReader, io.BufferedWriter, io.BufferedRandom each define __getstate__ (no __setstate__)."
    - "io.BufferedRWPair does NOT define any pickling methods in its __dict__."
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase define none of the five pickling protocol methods."
    - "io.TextIOWrapper defines __getstate__ (no __setstate__)."
    - "No io type defines __reduce__, __getnewargs__, __getnewargs_ex__, __copy__, or __deepcopy__ in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: pickling_protocol
#
# Records whether each io type defines __reduce__, __getstate__, __setstate__,
# __getnewargs__, or __getnewargs_ex__ directly in its own __dict__.
#
# BytesIO and StringIO: __getstate__ + __setstate__ → True; rest → False.
# FileIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper:
#   __getstate__ → True; __setstate__ and all others → False.
# Base classes and BufferedRWPair: all five → False.
# ---------------------------------------------------------------------------

table io_extra1696.pickling_protocol:
  description: "io types pickling protocol dict-presence checks"
  kind: python_call_eq
  category: pickling_protocol
  id_prefix: io1696

  columns: [id, function, args, expected]
  rows:
    - ["io1696001", "io.BytesIO.__dict__.__contains__",         ["__getstate__"],     true]
    - ["io1696002", "io.BytesIO.__dict__.__contains__",         ["__setstate__"],     true]
    - ["io1696003", "io.BytesIO.__dict__.__contains__",         ["__reduce__"],       false]
    - ["io1696004", "io.BytesIO.__dict__.__contains__",         ["__getnewargs__"],   false]
    - ["io1696005", "io.BytesIO.__dict__.__contains__",         ["__getnewargs_ex__"], false]
    - ["io1696006", "io.StringIO.__dict__.__contains__",        ["__getstate__"],     true]
    - ["io1696007", "io.StringIO.__dict__.__contains__",        ["__setstate__"],     true]
    - ["io1696008", "io.StringIO.__dict__.__contains__",        ["__reduce__"],       false]
    - ["io1696009", "io.StringIO.__dict__.__contains__",        ["__getnewargs__"],   false]
    - ["io1696010", "io.StringIO.__dict__.__contains__",        ["__getnewargs_ex__"], false]
    - ["io1696011", "io.FileIO.__dict__.__contains__",          ["__getstate__"],     true]
    - ["io1696012", "io.FileIO.__dict__.__contains__",          ["__setstate__"],     false]
    - ["io1696013", "io.FileIO.__dict__.__contains__",          ["__reduce__"],       false]
    - ["io1696014", "io.FileIO.__dict__.__contains__",          ["__getnewargs__"],   false]
    - ["io1696015", "io.BufferedReader.__dict__.__contains__",  ["__getstate__"],     true]
    - ["io1696016", "io.BufferedReader.__dict__.__contains__",  ["__setstate__"],     false]
    - ["io1696017", "io.BufferedReader.__dict__.__contains__",  ["__reduce__"],       false]
    - ["io1696018", "io.BufferedWriter.__dict__.__contains__",  ["__getstate__"],     true]
    - ["io1696019", "io.BufferedWriter.__dict__.__contains__",  ["__setstate__"],     false]
    - ["io1696020", "io.BufferedWriter.__dict__.__contains__",  ["__reduce__"],       false]
    - ["io1696021", "io.BufferedRandom.__dict__.__contains__",  ["__getstate__"],     true]
    - ["io1696022", "io.BufferedRandom.__dict__.__contains__",  ["__setstate__"],     false]
    - ["io1696023", "io.BufferedRandom.__dict__.__contains__",  ["__reduce__"],       false]
    - ["io1696024", "io.TextIOWrapper.__dict__.__contains__",   ["__getstate__"],     true]
    - ["io1696025", "io.TextIOWrapper.__dict__.__contains__",   ["__setstate__"],     false]
    - ["io1696026", "io.TextIOWrapper.__dict__.__contains__",   ["__reduce__"],       false]
    - ["io1696027", "io.IOBase.__dict__.__contains__",          ["__reduce__"],       false]
    - ["io1696028", "io.IOBase.__dict__.__contains__",          ["__getstate__"],     false]
    - ["io1696029", "io.IOBase.__dict__.__contains__",          ["__setstate__"],     false]
    - ["io1696030", "io.RawIOBase.__dict__.__contains__",       ["__reduce__"],       false]
    - ["io1696031", "io.RawIOBase.__dict__.__contains__",       ["__getstate__"],     false]
    - ["io1696032", "io.BufferedIOBase.__dict__.__contains__",  ["__reduce__"],       false]
    - ["io1696033", "io.BufferedIOBase.__dict__.__contains__",  ["__getstate__"],     false]
    - ["io1696034", "io.TextIOBase.__dict__.__contains__",      ["__reduce__"],       false]
    - ["io1696035", "io.TextIOBase.__dict__.__contains__",      ["__getstate__"],     false]
    - ["io1696036", "io.BufferedRWPair.__dict__.__contains__",  ["__getstate__"],     false]
    - ["io1696037", "io.BufferedRWPair.__dict__.__contains__",  ["__reduce__"],       false]

# ---------------------------------------------------------------------------
# Table 2: copy_protocol
#
# Checks whether io types define __copy__ or __deepcopy__ in their own
# __dict__.  No io type defines either — io objects holding file descriptors
# are not copyable via the copy protocol.
# ---------------------------------------------------------------------------

table io_extra1696.copy_protocol:
  description: "io types copy protocol (__copy__, __deepcopy__) dict-presence checks"
  kind: python_call_eq
  category: copy_protocol
  id_prefix: io1696

  columns: [id, function, args, expected]
  rows:
    - ["io1696040", "io.IOBase.__dict__.__contains__",          ["__copy__"],     false]
    - ["io1696041", "io.IOBase.__dict__.__contains__",          ["__deepcopy__"], false]
    - ["io1696042", "io.BytesIO.__dict__.__contains__",         ["__copy__"],     false]
    - ["io1696043", "io.BytesIO.__dict__.__contains__",         ["__deepcopy__"], false]
    - ["io1696044", "io.StringIO.__dict__.__contains__",        ["__copy__"],     false]
    - ["io1696045", "io.StringIO.__dict__.__contains__",        ["__deepcopy__"], false]
    - ["io1696046", "io.FileIO.__dict__.__contains__",          ["__copy__"],     false]
    - ["io1696047", "io.FileIO.__dict__.__contains__",          ["__deepcopy__"], false]
    - ["io1696048", "io.BufferedReader.__dict__.__contains__",  ["__copy__"],     false]
    - ["io1696049", "io.BufferedReader.__dict__.__contains__",  ["__deepcopy__"], false]
    - ["io1696050", "io.TextIOWrapper.__dict__.__contains__",   ["__copy__"],     false]
    - ["io1696051", "io.TextIOWrapper.__dict__.__contains__",   ["__deepcopy__"], false]

# ---------------------------------------------------------------------------
# Table 3: pickable_subset_contrast
#
# Contrasts the two fully-picklable io types (BytesIO, StringIO, which have
# both __getstate__ and __setstate__) against the partially-defined types
# (FileIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper,
# which have __getstate__ only) and the base classes (none of either).
# ---------------------------------------------------------------------------

table io_extra1696.pickable_subset_contrast:
  description: "Contrast fully-picklable (getstate+setstate) vs partial vs none"
  kind: python_call_eq
  category: pickable_subset_contrast
  id_prefix: io1696

  columns: [id, function, args, expected]
  rows:
    - ["io1696060", "io.BytesIO.__dict__.__contains__",                ["__getstate__"], true]
    - ["io1696061", "io.BytesIO.__dict__.__contains__",                ["__setstate__"], true]
    - ["io1696062", "io.StringIO.__dict__.__contains__",               ["__getstate__"], true]
    - ["io1696063", "io.StringIO.__dict__.__contains__",               ["__setstate__"], true]
    - ["io1696064", "io.FileIO.__dict__.__contains__",                 ["__getstate__"], true]
    - ["io1696065", "io.FileIO.__dict__.__contains__",                 ["__setstate__"], false]
    - ["io1696066", "io.BufferedReader.__dict__.__contains__",         ["__getstate__"], true]
    - ["io1696067", "io.BufferedReader.__dict__.__contains__",         ["__setstate__"], false]
    - ["io1696068", "io.BufferedWriter.__dict__.__contains__",         ["__getstate__"], true]
    - ["io1696069", "io.BufferedWriter.__dict__.__contains__",         ["__setstate__"], false]
    - ["io1696070", "io.BufferedRandom.__dict__.__contains__",         ["__getstate__"], true]
    - ["io1696071", "io.BufferedRandom.__dict__.__contains__",         ["__setstate__"], false]
    - ["io1696072", "io.TextIOWrapper.__dict__.__contains__",          ["__getstate__"], true]
    - ["io1696073", "io.TextIOWrapper.__dict__.__contains__",          ["__setstate__"], false]
    - ["io1696074", "io.IOBase.__dict__.__contains__",                 ["__getstate__"], false]
    - ["io1696075", "io.IOBase.__dict__.__contains__",                 ["__setstate__"], false]
    - ["io1696076", "io.BufferedRWPair.__dict__.__contains__",         ["__getstate__"], false]
    - ["io1696077", "io.BufferedRWPair.__dict__.__contains__",         ["__setstate__"], false]
    - ["io1696078", "io.IncrementalNewlineDecoder.__dict__.__contains__", ["__getstate__"], false]
    - ["io1696079", "io.IncrementalNewlineDecoder.__dict__.__contains__", ["__reduce__"],   false]
