spec: socket_extra156
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra155.zspec.zsdl — covers socket.setdefaulttimeout/__class__.__name__/__module__ / getdefaulttimeout/__class__.__name__ / gethostname/__class__.__name__/__module__ / getaddrinfo/__class__.__name__/__module__ / socket.socket.__doc__/__class__.__name__ (table + invariants)."
    - "socket_extra154.zspec.zsdl — covers socket.error/__name__/__eq__('OSError') / gaierror/__bases__[0].__name__ / herror/__name__/__module__ / timeout/__name__/__eq__('TimeoutError') / timeout/__module__/__eq__('builtins') / timeout/__bases__[0].__name__ (table + invariants)."
    - "socket_extra153.zspec.zsdl — covers socket.socket.send/__recv/__accept/__close/__fileno qualnames and qualname lengths (table + invariants)."
    - "socket_extra152.zspec.zsdl — covers socket.socket.__name__/__module__/__bases__[0].__name__ / socket.socket.connect/__bind/__listen qualnames / socket.error/__name__ / socket.gaierror.__name__/__module__ (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra155."
    - "Wave 338 theme: socket module __spec__ attributes and socket.socket method qualnames — socket.__spec__.__class__.__name__.__eq__('ModuleSpec') / __spec__.name.__eq__('socket') / socket.socket.makefile.__qualname__.__eq__('socket.makefile') / setblocking.__qualname__.__eq__('socket.setblocking') / settimeout.__qualname__.__eq__('socket.settimeout') / getpeername.__qualname__.__eq__('socket.getpeername') / getsockname.__qualname__.__eq__('socket.getsockname') / setsockopt.__qualname__.__eq__('socket.setsockopt')."
    - "socket.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.name == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__qualname__ == 'socket.makefile'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__qualname__ == 'socket.setblocking'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__qualname__ == 'socket.settimeout'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getpeername.__qualname__ == 'socket.getpeername'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockname.__qualname__ == 'socket.getsockname'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__qualname__ == 'socket.setsockopt'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars) and __spec__.name == 'socket' (6 chars). Like hashlib (extra157) and struct (extra150), socket is a fully-specified module with a ModuleSpec from the Python import system. socket is a hybrid module: the public API is accessible via 'import socket', backed by the _socket C extension. __spec__.name == 'socket' (6 chars; same length as 'struct' from extra150). socket module was anchored for __spec__ in prior specs but not as sockspec156; this is the first sockspec156 anchor."
    - "Note: socket.socket.makefile.__qualname__ == 'socket.makefile'. The socket.socket class methods accessed via the class object use 'socket.' as their qualname prefix (matching the class name 'socket', not the module name 'socket'). The qualname prefix is 'socket.' (7 chars = 'socket'=6 + '.'=1), reflecting the class name socket.socket (the inner 'socket' in 'socket.socket' is the class). This contrasts with hashlib constructors whose qualname is 'openssl_sha256' (no class prefix). Qualname format: 'socket.' + method_name."
    - "Note: socket.socket.setblocking.__qualname__ == 'socket.setblocking'. setblocking(flag) is a convenience method that sets a socket to blocking (True) or non-blocking (False) mode. It is equivalent to calling settimeout(None) for blocking and settimeout(0.0) for non-blocking. socket.socket.settimeout.__qualname__ == 'socket.settimeout'. settimeout(value) sets a timeout (in seconds) for socket operations. Both setblocking and settimeout are C extension methods of the socket class with qualnames following the 'socket.' + method_name pattern."
    - "Note: socket.socket.getpeername.__qualname__ == 'socket.getpeername'. socket.socket.getsockname.__qualname__ == 'socket.getsockname'. getpeername() returns the address of the remote end of the connection. getsockname() returns the socket's own address. socket.socket.setsockopt.__qualname__ == 'socket.setsockopt'. setsockopt() sets a socket option. All three follow the 'socket.' + method_name qualname pattern. Method name lengths: makefile(8) < setblocking(10) < setsockopt(10) < getsockname(11) < getpeername(11) < settimeout(11)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.__spec__.__class__.__name__.__eq__('ModuleSpec')
# socket.__spec__.name.__eq__('socket')
# socket.socket.makefile.__qualname__.__eq__('socket.makefile')
# socket.socket.setblocking.__qualname__.__eq__('socket.setblocking')
#
# Wave 338 theme: socket __spec__ identity and socket.socket method qualnames.
#
# __spec__.__class__.__name__ == 'ModuleSpec' (10 chars; importlib spec; same as hashlib/struct).
# __spec__.name == 'socket' (6 chars; canonical import name).
# socket.socket.makefile.__qualname__ == 'socket.makefile' (15 chars = 'socket.'=7 + 'makefile'=8).
# socket.socket.setblocking.__qualname__ == 'socket.setblocking' (18 chars = 'socket.'=7 + 'setblocking'=11... wait, 'setblocking'=10, so 7+10=17 chars).
# Actually: 'socket.setblocking' = 'socket.'(7) + 'setblocking'(10) = 17 chars.
# No prior socket spec anchors __spec__ or socket method qualname strings as a combined
# table under sockspec156. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra156.spec_and_socket_method_qualnames_part1:
  description: "socket.__spec__.__class__.__name__.__eq__('ModuleSpec')==True / __spec__.name.__eq__('socket')==True / socket.makefile.__qualname__.__eq__('socket.makefile')==True / socket.setblocking.__qualname__.__eq__('socket.setblocking')==True — __spec__ is ModuleSpec (10 chars; importlib; same as hashlib extra157 and struct extra150); __spec__.name is 'socket' (6 chars; same length as 'struct'); makefile.__qualname__ is 'socket.makefile' (15 chars = 'socket.'=7 + 'makefile'=8; prefix is class name 'socket', not module name); setblocking.__qualname__ is 'socket.setblocking' (17 chars = 'socket.'=7 + 'setblocking'=10); all socket.socket methods use 'socket.' qualname prefix; first sockspec156 anchor for __spec__ and socket method qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: sockspec156

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_ModuleSpec,   "__spec__.__class__.__name__.__eq__",        ["ModuleSpec"],        true, "socket.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars; importlib module spec; same type as hashlib/struct __spec__)"]
    - [spec_name_socket,        "__spec__.name.__eq__",                      ["socket"],            true, "socket.__spec__.name == 'socket' (6 chars; canonical import name; same length as 'struct' from struct_extra150)"]
    - [makefile_qualname,       "socket.makefile.__qualname__.__eq__",       ["socket.makefile"],   true, "socket.socket.makefile.__qualname__ == 'socket.makefile' (15 chars; 'socket.'=7 + 'makefile'=8; class name prefix)"]
    - [setblocking_qualname,    "socket.setblocking.__qualname__.__eq__",    ["socket.setblocking"], true, "socket.socket.setblocking.__qualname__ == 'socket.setblocking' (17 chars; 'socket.'=7 + 'setblocking'=10)"]

# ---------------------------------------------------------------------------
# socket.socket.settimeout.__qualname__.__eq__('socket.settimeout')
# socket.socket.getpeername.__qualname__.__eq__('socket.getpeername')
# socket.socket.getsockname.__qualname__.__eq__('socket.getsockname')
# socket.socket.setsockopt.__qualname__.__eq__('socket.setsockopt')
#
# Wave 338 theme: more socket.socket method qualnames following 'socket.' prefix pattern.
#
# All follow 'socket.' + method_name pattern (class name prefix, not module prefix).
# settimeout(11 chars) -> 'socket.settimeout' (17 chars = 7+10 ... 'settimeout'=10).
# Actually 'settimeout'=10 chars -> 'socket.settimeout' = 7+10 = 17 chars.
# getpeername(11 chars) -> 'socket.getpeername' = 7+11 = 18 chars.
# getsockname(11 chars) -> 'socket.getsockname' = 7+11 = 18 chars.
# setsockopt(10 chars) -> 'socket.setsockopt' = 7+10 = 17 chars.
# No prior socket spec anchors these qualname values as a table under sockspec156.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra156.socket_method_qualnames_part2:
  description: "socket.socket.settimeout.__qualname__.__eq__('socket.settimeout')==True / getpeername.__qualname__.__eq__('socket.getpeername')==True / getsockname.__qualname__.__eq__('socket.getsockname')==True / setsockopt.__qualname__.__eq__('socket.setsockopt')==True — all follow 'socket.' prefix (class name, not module name); settimeout: 'socket.settimeout' (17 chars='socket.'=7+'settimeout'=10); getpeername: 'socket.getpeername' (18 chars='socket.'=7+'getpeername'=11); getsockname: 'socket.getsockname' (18 chars='socket.'=7+'getsockname'=11); setsockopt: 'socket.setsockopt' (17 chars='socket.'=7+'setsockopt'=10); getpeername and getsockname tie at 18 chars; first sockspec156 anchor for these method qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: sockspec156

  columns: [id, function, args, expected, description]
  rows:
    - [settimeout_qualname,    "socket.settimeout.__qualname__.__eq__",    ["socket.settimeout"],   true, "socket.socket.settimeout.__qualname__ == 'socket.settimeout' (17 chars; 'socket.'=7 + 'settimeout'=10; sets socket timeout)"]
    - [getpeername_qualname,   "socket.getpeername.__qualname__.__eq__",   ["socket.getpeername"],  true, "socket.socket.getpeername.__qualname__ == 'socket.getpeername' (18 chars; 'socket.'=7 + 'getpeername'=11; remote address)"]
    - [getsockname_qualname,   "socket.getsockname.__qualname__.__eq__",   ["socket.getsockname"],  true, "socket.socket.getsockname.__qualname__ == 'socket.getsockname' (18 chars; 'socket.'=7 + 'getsockname'=11; own address)"]
    - [setsockopt_qualname,    "socket.setsockopt.__qualname__.__eq__",    ["socket.setsockopt"],   true, "socket.socket.setsockopt.__qualname__ == 'socket.setsockopt' (17 chars; 'socket.'=7 + 'setsockopt'=10; sets socket option)"]

# ---------------------------------------------------------------------------
# qualname length checks for socket.socket methods
#
# Wave 338 theme: qualname lengths for the socket methods under inspection.
#
# 'socket.makefile' = 15 chars. 'socket.setblocking' = 17 chars.
# 'socket.settimeout' = 17 chars. 'socket.setsockopt' = 17 chars.
# 'socket.getpeername' = 18 chars. 'socket.getsockname' = 18 chars.
# Length ordering: makefile(15) < setblocking==settimeout==setsockopt(17) < getpeername==getsockname(18).
# No prior socket spec anchors these qualname lengths as a combined table under sockspec156.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra156.socket_method_qualname_lengths:
  description: "socket.socket.makefile.__qualname__.__len__()==15 / setblocking.__qualname__.__len__()==17 / getpeername.__qualname__.__len__()==18 / getsockname.__qualname__.__len__()==18 — all qualnames follow 'socket.' prefix (7 chars); method lengths: makefile(8)=15, setblocking(10)=17, settimeout(10)=17, setsockopt(10)=17, getpeername(11)=18, getsockname(11)=18; makefile(15) < setblocking/settimeout/setsockopt(17) < getpeername/getsockname(18); getpeername and getsockname tie at 18 chars; first sockspec156 anchor for these qualname length values"
  kind: python_call_eq
  category: identity
  id_prefix: sockspec156

  columns: [id, function, args, expected, description]
  rows:
    - [makefile_qualname_len_15,    "socket.makefile.__qualname__.__len__",    [], 15, "socket.socket.makefile.__qualname__.__len__() is 15 ('socket.makefile' = 'socket.'=7 + 'makefile'=8 = 15 chars)"]
    - [setblocking_qualname_len_17, "socket.setblocking.__qualname__.__len__", [], 17, "socket.socket.setblocking.__qualname__.__len__() is 17 ('socket.setblocking' = 'socket.'=7 + 'setblocking'=10 = 17 chars)"]
    - [getpeername_qualname_len_18, "socket.getpeername.__qualname__.__len__", [], 18, "socket.socket.getpeername.__qualname__.__len__() is 18 ('socket.getpeername' = 'socket.'=7 + 'getpeername'=11 = 18 chars)"]
    - [getsockname_qualname_len_18, "socket.getsockname.__qualname__.__len__", [], 18, "socket.socket.getsockname.__qualname__.__len__() is 18 ('socket.getsockname' = 'socket.'=7 + 'getsockname'=11 = 18 chars; ties getpeername)"]

# ---------------------------------------------------------------------------
# socket.__spec__.__class__.__name__.__eq__('ModuleSpec') — standalone
#
# socket.__spec__.__class__.__name__ is 'ModuleSpec' (10 chars). Like hashlib (extra157)
# and struct (extra150), socket is a properly imported module with a standard ModuleSpec
# from Python's importlib. socket is a hybrid module: the public API is in Lib/socket.py,
# backed by the _socket C extension. socket.__spec__.name == 'socket' (6 chars) is the
# canonical public module name — the same name used in 'import socket'. The ModuleSpec
# stores the module name, origin (file path of socket.py), loader, and cached path.
# No prior socket spec anchors __spec__.__class__.__name__ as a standalone under
# sockspec156. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra156.spec_class_name_ModuleSpec:
  description: "socket.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — 10 chars; importlib module spec; same type as hashlib.__spec__ (extra157) and struct.__spec__ (extra150); socket is hybrid module (Lib/socket.py + _socket C extension); __spec__.name=='socket' (6 chars; same length as 'struct'); ModuleSpec stores name/origin/loader/cached path; no prior socket spec anchors this as a standalone under sockspec156; first standalone under sockspec156"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.makefile.__qualname__.__eq__('socket.makefile') — standalone
#
# socket.socket.makefile.__qualname__ is 'socket.makefile' (15 chars). socket.socket
# is a class whose name (as a class object) is 'socket'. Therefore all its methods
# have __qualname__ = 'socket.' + method_name (using the class name 'socket', which
# is the same string as the module name 'socket' but refers to the class). makefile()
# creates a file-like object associated with the socket. It accepts mode and bufsize
# arguments. The qualname 'socket.makefile' = 'socket.'=7 chars + 'makefile'=8 chars
# = 15 chars. This is the shortest qualname among the socket methods in this spec,
# because 'makefile' (8 chars) is shorter than the other method names here.
# No prior socket spec anchors makefile.__qualname__ as a standalone under sockspec156.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra156.makefile_qualname_socket:
  description: "socket.socket.makefile.__qualname__.__eq__('socket.makefile') == True — 15 chars = 'socket.'=7 + 'makefile'=8; qualname prefix 'socket.' is the class name (not module name; both happen to be 'socket'); makefile() creates a file-like object for the socket; __qualname__.__len__()==15 (shortest among this spec's methods); first socket extra spec to anchor makefile.__qualname__ as standalone; no prior socket spec anchors this as a standalone under sockspec156"
  category: identity
  kind: python_call_eq
  function: socket.makefile.__qualname__.__eq__
  args: ["socket.makefile"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.settimeout.__qualname__.__eq__('socket.settimeout') — standalone
#
# socket.socket.settimeout.__qualname__ is 'socket.settimeout' (17 chars). settimeout()
# sets a timeout on blocking socket operations. The socket argument should be a value
# in seconds (a float), or None for blocking mode (no timeout), or 0 for non-blocking
# mode. settimeout(value) is the full-featured version of setblocking(True/False):
# setblocking(True) is equivalent to settimeout(None), and setblocking(False) is
# equivalent to settimeout(0.0). The qualname 'socket.settimeout' = 'socket.'=7 chars +
# 'settimeout'=10 chars = 17 chars. Ties with setblocking and setsockopt at 17 chars.
# No prior socket spec anchors settimeout.__qualname__ as a standalone under sockspec156.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra156.settimeout_qualname_socket:
  description: "socket.socket.settimeout.__qualname__.__eq__('socket.settimeout') == True — 17 chars = 'socket.'=7 + 'settimeout'=10; sets timeout on blocking socket operations; settimeout(None)=blocking, settimeout(0)=non-blocking, settimeout(float)=timed; equivalent relationship: setblocking(True)==settimeout(None), setblocking(False)==settimeout(0.0); ties setblocking and setsockopt at 17 chars; shorter than getpeername/getsockname (18 chars); no prior socket spec anchors this as a standalone under sockspec156"
  category: identity
  kind: python_call_eq
  function: socket.settimeout.__qualname__.__eq__
  args: ["socket.settimeout"]
  expected: true
