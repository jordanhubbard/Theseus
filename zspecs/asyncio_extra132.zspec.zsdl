spec: asyncio_extra132
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "This spec covers: wave 254 theme — asyncio Queue class hierarchy identity. NEW in extra132: asyncio.Queue.__name__=='Queue' (len=5); asyncio.Queue.__module__=='asyncio.queues'; asyncio.Queue.__bases__[0].__name__=='_LoopBoundMixin'; asyncio.Queue.__mro__.__len__()==3 ([Queue, _LoopBoundMixin, object]); asyncio.QueueEmpty.__name__=='QueueEmpty' (len=10); asyncio.QueueEmpty.__bases__[0].__name__=='Exception'; asyncio.QueueEmpty.__mro__.__len__()==4; asyncio.QueueFull.__name__=='QueueFull' (len=9); asyncio.QueueFull.__bases__[0].__name__=='Exception'; asyncio.QueueFull.__mro__.__len__()==4; asyncio.LifoQueue.__bases__[0].__name__=='Queue'; asyncio.LifoQueue.__mro__.__len__()==4; asyncio.PriorityQueue.__bases__[0].__name__=='Queue'; asyncio.PriorityQueue.__mro__.__len__()==4. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.__module__ == 'asyncio.queues'. Queue, LifoQueue, PriorityQueue, QueueEmpty, and QueueFull are all defined in Lib/asyncio/queues.py and re-exported through asyncio/__init__.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Queue.__mro__.__len__() == 3. Queue's MRO is [Queue, _LoopBoundMixin, object] — same depth as asyncio.Event (also 3). LifoQueue and PriorityQueue extend Queue, giving MRO length 4. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.QueueEmpty.__bases__[0].__name__ == 'Exception'. QueueEmpty and QueueFull are exception classes, not Queue subclasses; their MRO is [QueueEmpty, Exception, BaseException, object] (length=4). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Queue base class identity — extra132
#
# Wave 254 theme: asyncio Queue class hierarchy identity.
#
# asyncio.Queue.__name__              == 'Queue'          (len=5)
# asyncio.Queue.__module__            == 'asyncio.queues'
# asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin'
# asyncio.Queue.__mro__.__len__()     == 3   [Queue, _LoopBoundMixin, object]
# asyncio.Queue.__class__.__name__    == 'type'
# asyncio.Queue.__qualname__          == 'Queue' (len=5)
# ---------------------------------------------------------------------------

table asyncio_extra132.asyncio_queue_base_identity:
  description: "asyncio.Queue base class identity checks in asyncioqueueident132 namespace — wave 254 theme: asyncio Queue hierarchy; asyncio.Queue is a pure-Python class defined in Lib/asyncio/queues.py; Queue.__name__.__eq__('Queue')==True (len=5); Queue.__module__.__eq__('asyncio.queues')==True (defined in queues submodule, not asyncio/__init__.py); Queue.__module__.__len__()==14 ('asyncio.queues'=14); Queue.__bases__[0].__name__.__eq__('_LoopBoundMixin')==True (Queue uses the same base mixin as asyncio.Event); Queue.__mro__.__len__()==3 (MRO is [Queue, _LoopBoundMixin, object], same depth as asyncio.Event); Queue.__class__.__name__.__eq__('type')==True (Queue is a class, metaclass is type); Queue.__qualname__.__eq__('Queue')==True (len=5, module-level class so qualname equals name); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqueueident132

  columns: [id, function, args, expected, description]
  rows:
    - [queue_name_eq,    asyncio.Queue.__name__.__eq__,                      ["Queue"],            true, "asyncio.Queue.__name__ == 'Queue' (len=5); verified with Python 3.14.3"]
    - [queue_name_len,   asyncio.Queue.__name__.__len__,                     [],                   5,    "asyncio.Queue.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [queue_module,     asyncio.Queue.__module__.__eq__,                    ["asyncio.queues"],   true, "asyncio.Queue.__module__ == 'asyncio.queues' (defined in queues submodule); verified with Python 3.14.3"]
    - [queue_module_len, asyncio.Queue.__module__.__len__,                   [],                   14,   "asyncio.Queue.__module__.__len__() == 14 ('asyncio.queues'); verified with Python 3.14.3"]
    - [queue_base0,      "asyncio.Queue.__bases__[0].__name__.__eq__",       ["_LoopBoundMixin"],  true, "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' (same mixin as asyncio.Event); verified with Python 3.14.3"]
    - [queue_mro_len,    asyncio.Queue.__mro__.__len__,                      [],                   3,    "asyncio.Queue.__mro__.__len__() == 3 — MRO is [Queue, _LoopBoundMixin, object]; verified with Python 3.14.3"]
    - [queue_class_nm,   asyncio.Queue.__class__.__name__.__eq__,            ["type"],             true, "asyncio.Queue.__class__.__name__ == 'type' — Queue is a class, metaclass is type; verified with Python 3.14.3"]

