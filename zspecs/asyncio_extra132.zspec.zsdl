table asyncio_extra132.asyncio_queue_subclass_identity:
  description: "asyncio.LifoQueue and PriorityQueue subclass identity checks in asyncioqueueident132 namespace — wave 254 theme: asyncio Queue subclasses; LifoQueue and PriorityQueue are Queue subclasses (unlike QueueEmpty/QueueFull which are Exception subclasses); LifoQueue.__name__.__eq__('LifoQueue')==True (len=9: 'Lifo'=4+'Queue'=5); LifoQueue.__bases__[0].__name__.__eq__('Queue')==True (direct subclass of Queue); LifoQueue.__mro__.__len__()==4 (MRO is [LifoQueue, Queue, _LoopBoundMixin, object], one deeper than Queue's 3-element MRO); PriorityQueue.__name__.__eq__('PriorityQueue')==True (len=13: 'Priority'=8+'Queue'=5, longest name of all queue classes); PriorityQueue.__bases__[0].__name__.__eq__('Queue')==True (direct subclass of Queue just like LifoQueue); PriorityQueue.__mro__.__len__()==4 (same depth as LifoQueue); PriorityQueue.__module__.__eq__('asyncio.queues')==True (all queue classes share the same module); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqueueident132b

  columns: [id, function, args, expected, description]
  rows:
    - [lifo_name_eq,     asyncio.LifoQueue.__name__.__eq__,                      ["LifoQueue"],        true, "asyncio.LifoQueue.__name__ == 'LifoQueue' (len=9); verified with Python 3.14.3"]
    - [lifo_name_len,    asyncio.LifoQueue.__name__.__len__,                     [],                   9,    "asyncio.LifoQueue.__name__.__len__() == 9 ('Lifo'=4+'Queue'=5); verified with Python 3.14.3"]
    - [lifo_base0,       "asyncio.LifoQueue.__bases__[0].__name__.__eq__",       ["Queue"],            true, "asyncio.LifoQueue.__bases__[0].__name__ == 'Queue' (direct Queue subclass); verified with Python 3.14.3"]
    - [lifo_mro_len,     asyncio.LifoQueue.__mro__.__len__,                      [],                   4,    "asyncio.LifoQueue.__mro__.__len__() == 4 — [LifoQueue, Queue, _LoopBoundMixin, object]; verified with Python 3.14.3"]
    - [pq_name_eq,       asyncio.PriorityQueue.__name__.__eq__,                  ["PriorityQueue"],    true, "asyncio.PriorityQueue.__name__ == 'PriorityQueue' (len=13, longest queue class name); verified with Python 3.14.3"]
    - [pq_name_len,      asyncio.PriorityQueue.__name__.__len__,                 [],                   13,   "asyncio.PriorityQueue.__name__.__len__() == 13 ('Priority'=8+'Queue'=5); verified with Python 3.14.3"]
    - [pq_base0,         "asyncio.PriorityQueue.__bases__[0].__name__.__eq__",   ["Queue"],            true, "asyncio.PriorityQueue.__bases__[0].__name__ == 'Queue' (direct Queue subclass); verified with Python 3.14.3"]
    - [pq_mro_len,       asyncio.PriorityQueue.__mro__.__len__,                  [],                   4,    "asyncio.PriorityQueue.__mro__.__len__() == 4 — same depth as LifoQueue; verified with Python 3.14.3"]
    - [pq_module,        asyncio.PriorityQueue.__module__.__eq__,                ["asyncio.queues"],   true, "asyncio.PriorityQueue.__module__ == 'asyncio.queues'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra132
# ---------------------------------------------------------------------------

invariant asyncio_extra132.Queue_base_is_LoopBoundMixin:
  description: "asyncio.Queue.__bases__[0].__name__.__eq__('_LoopBoundMixin') returns True — asyncio.Queue inherits from _LoopBoundMixin as its sole direct base class; this is the same _LoopBoundMixin base used by asyncio.Event (whose MRO is [Event, _LoopBoundMixin, object] length=3, the same depth as Queue); _LoopBoundMixin provides the event loop binding mechanism; LifoQueue and PriorityQueue extend Queue, adding a 4th level to their MRO; QueueEmpty and QueueFull are exception classes inheriting from Exception (not from Queue or _LoopBoundMixin); Queue.__module__ is 'asyncio.queues' (defined in Lib/asyncio/queues.py, re-exported via asyncio/__init__.py); NEW in extra132: first standalone Queue base class invariant in asyncioqueueident132 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "asyncio.Queue.__bases__[0].__name__.__eq__"
  args: ["_LoopBoundMixin"]
  expected: true

invariant asyncio_extra132.Queue_mro_len_is_3:
  description: "asyncio.Queue.__mro__.__len__() == 3 — asyncio.Queue's MRO is [Queue, _LoopBoundMixin, object] (length=3); this 3-element depth matches asyncio.Event.__mro__.__len__()==3 — both classes use _LoopBoundMixin as their single intermediate base; LifoQueue and PriorityQueue (Queue subclasses) have MRO length 4; QueueEmpty and QueueFull (Exception subclasses) also have MRO length 4 ([QueueEmpty, Exception, BaseException, object]); Queue is a FIFO queue; LifoQueue is LIFO (stack); PriorityQueue delivers items lowest-value first; NEW in extra132: first standalone Queue MRO length invariant in asyncioqueueident132 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.__mro__.__len__
  args: []
  expected: 3

invariant asyncio_extra132.QueueEmpty_base_is_Exception:
  description: "asyncio.QueueEmpty.__bases__[0].__name__.__eq__('Exception') returns True — QueueEmpty is an exception class, not a Queue subclass; it inherits from Exception (standard exception base), giving the 4-element MRO [QueueEmpty, Exception, BaseException, object]; QueueFull shares the same inheritance structure with the same MRO depth of 4; QueueEmpty is raised by Queue.get_nowait() when the queue is empty; QueueFull is raised by Queue.put_nowait() when the queue is full; both exception classes are defined in Lib/asyncio/queues.py alongside Queue, LifoQueue, and PriorityQueue; NEW in extra132: first standalone QueueEmpty base class invariant in asyncioqueueident132 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "asyncio.QueueEmpty.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant asyncio_extra132.LifoQueue_base_is_Queue:
  description: "asyncio.LifoQueue.__bases__[0].__name__.__eq__('Queue') returns True — asyncio.LifoQueue inherits from Queue as its sole direct base class; this gives LifoQueue a 4-element MRO [LifoQueue, Queue, _LoopBoundMixin, object]; PriorityQueue also inherits directly from Queue with the same 4-element MRO depth; LifoQueue overrides _get and _put to implement LIFO (last-in, first-out / stack) semantics; LifoQueue.__name__ is 'LifoQueue' (len=9: 'Lifo'=4 + 'Queue'=5); LifoQueue.__module__ is 'asyncio.queues'; NEW in extra132: first standalone LifoQueue base class invariant in asyncioqueueident132 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "asyncio.LifoQueue.__bases__[0].__name__.__eq__"
  args: ["Queue"]
  expected: true

invariant asyncio_extra132.PriorityQueue_name_len_13:
  description: "asyncio.PriorityQueue.__name__.__len__() == 13 — PriorityQueue.__name__ is 'PriorityQueue' (13 chars: 'Priority'=8 + 'Queue'=5); this is the longest name among the asyncio queue classes: Queue=5, LifoQueue=9, QueueFull=9, QueueEmpty=10, PriorityQueue=13; PriorityQueue.__bases__[0].__name__ is 'Queue' (direct Queue subclass); PriorityQueue.__mro__.__len__() is 4 (same as LifoQueue: [PriorityQueue, Queue, _LoopBoundMixin, object]); PriorityQueue delivers items in priority order using a heapq internally; PriorityQueue.__module__ is 'asyncio.queues'; NEW in extra132: first standalone PriorityQueue name length invariant in asyncioqueueident132 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: asyncio.PriorityQueue.__name__.__len__
  args: []
  expected: 13

