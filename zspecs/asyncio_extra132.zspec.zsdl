# asyncio.QueueFull.__mro__.__len__()      == 4
# asyncio.QueueFull.__module__             == 'asyncio.queues'
# ---------------------------------------------------------------------------

table asyncio_extra132.asyncio_queue_exception_identity:
  description: "asyncio.QueueEmpty and QueueFull exception class identity checks in asyncioqueueident132 namespace — wave 254 theme: asyncio queue exception classes; QueueEmpty and QueueFull are exception classes (not Queue subclasses) defined in Lib/asyncio/queues.py; QueueEmpty.__name__.__eq__('QueueEmpty')==True (len=10: 'Queue'=5 + 'Empty'=5); QueueEmpty.__bases__[0].__name__.__eq__('Exception')==True (not Queue! these are proper exceptions inheriting from Exception); QueueEmpty.__mro__.__len__()==4 (MRO is [QueueEmpty, Exception, BaseException, object]); QueueFull.__name__.__eq__('QueueFull')==True (len=9: 'Queue'=5 + 'Full'=4); QueueFull.__bases__[0].__name__.__eq__('Exception')==True (same base as QueueEmpty); QueueFull.__mro__.__len__()==4 (same depth as QueueEmpty); QueueFull.__module__.__eq__('asyncio.queues')==True; both share the same 4-element MRO structure via the standard Exception hierarchy; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioqueueident132a

  columns: [id, function, args, expected, description]
  rows:
    - [qempty_name_eq,    asyncio.QueueEmpty.__name__.__eq__,                     ["QueueEmpty"],       true, "asyncio.QueueEmpty.__name__ == 'QueueEmpty' (len=10); verified with Python 3.14.3"]
    - [qempty_name_len,   asyncio.QueueEmpty.__name__.__len__,                    [],                   10,   "asyncio.QueueEmpty.__name__.__len__() == 10 ('Queue'=5+'Empty'=5); verified with Python 3.14.3"]
    - [qempty_base0,      "asyncio.QueueEmpty.__bases__[0].__name__.__eq__",      ["Exception"],        true, "asyncio.QueueEmpty.__bases__[0].__name__ == 'Exception' (not Queue; QueueEmpty is an exception); verified with Python 3.14.3"]
    - [qempty_mro_len,    asyncio.QueueEmpty.__mro__.__len__,                     [],                   4,    "asyncio.QueueEmpty.__mro__.__len__() == 4 — [QueueEmpty, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [qfull_name_eq,     asyncio.QueueFull.__name__.__eq__,                      ["QueueFull"],        true, "asyncio.QueueFull.__name__ == 'QueueFull' (len=9); verified with Python 3.14.3"]
    - [qfull_name_len,    asyncio.QueueFull.__name__.__len__,                     [],                   9,    "asyncio.QueueFull.__name__.__len__() == 9 ('Queue'=5+'Full'=4); verified with Python 3.14.3"]
    - [qfull_base0,       "asyncio.QueueFull.__bases__[0].__name__.__eq__",       ["Exception"],        true, "asyncio.QueueFull.__bases__[0].__name__ == 'Exception' (same as QueueEmpty); verified with Python 3.14.3"]
    - [qfull_mro_len,     asyncio.QueueFull.__mro__.__len__,                      [],                   4,    "asyncio.QueueFull.__mro__.__len__() == 4 — same depth as QueueEmpty; verified with Python 3.14.3"]
    - [qfull_module,      asyncio.QueueFull.__module__.__eq__,                    ["asyncio.queues"],   true, "asyncio.QueueFull.__module__ == 'asyncio.queues'; verified with Python 3.14.3"]

