spec: multiprocessing_extra164
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec covers: multiprocessing.pool.Pool class name and module identity; multiprocessing.pool.AsyncResult class name, module, and base class identity. KEY FINDING: multiprocessing.pool.AsyncResult.__name__=='ApplyResult' (NOT 'AsyncResult'); AsyncResult is an alias: in Lib/multiprocessing/pool.py, the class is defined as 'class ApplyResult' and then 'AsyncResult = ApplyResult' is added as an alias for backward compatibility; __name__ always returns the original class definition name, not the alias name; so AsyncResult.__name__=='ApplyResult' (len=11: 'Apply'=5+'Result'=6=11), NOT 'AsyncResult' (len=11: 'Async'=5+'Result'=6=11). Both names happen to be 11 chars. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.pool.Pool.__name__=='Pool' (len=4: 'P'+'o'+'o'+'l'=4; established in extra162); multiprocessing.pool.Pool.__module__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20; established in extra162); NEW in extra164: Pool identity cross-checked and extended with name/module length comparisons against AsyncResult; multiprocessing.pool.AsyncResult is the alias for ApplyResult — the async result type returned by Pool.apply_async() and Pool.map_async() when callback=None; AsyncResult.__name__=='ApplyResult' (len=11: 'Apply'=5+'Result'=6=11) NOT 'AsyncResult'; AsyncResult.__module__=='multiprocessing.pool' (len=20: same module as Pool); AsyncResult.__bases__[0].__name__=='object' (ApplyResult/AsyncResult inherits from object directly). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Length analysis: Pool.__name__.__len__()==4; Pool.__module__.__len__()==20; AsyncResult.__name__.__len__()==11 ('ApplyResult'=11: 'Apply'=5+'Result'=6=11); AsyncResult.__module__.__len__()==20 (same as Pool module); AsyncResult.__bases__[0].__name__.__len__()==6 ('object'=6); compare: Pool(4) < AsyncResult_canonical_name(11) in class name length; Pool module(20) == AsyncResult module(20) — both in multiprocessing.pool; 'multiprocessing.pool'=20: 'multiprocessing'=15+'.'=1+'pool'=4=20. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.pool.Pool class identity — extra164
#
# multiprocessing.pool.Pool.__name__.__eq__('Pool')              == True
# multiprocessing.pool.Pool.__name__.__len__()                   == 4
# multiprocessing.pool.Pool.__module__.__eq__('multiprocessing.pool') == True
# multiprocessing.pool.Pool.__module__.__len__()                 == 20
# ---------------------------------------------------------------------------

table multiprocessing_extra164.mp_pool_identity:
  description: "multiprocessing.pool.Pool class name and module identity checks in mppool164 namespace — multiprocessing.pool.Pool.__name__.__eq__('Pool')==True (Pool.__name__=='Pool' (len=4: 'P'+'o'+'o'+'l'=4; established in extra162 via the identity table; confirmed again here with new id_prefix); multiprocessing.pool.Pool is the process pool class for parallel execution using multiple worker processes; Pool manages a pool of worker processes and dispatches work items to them via apply/map/starmap and their async/iterator variants); multiprocessing.pool.Pool.__name__.__len__()==4 ('Pool'=4; the shortest class name in this spec; Pool(4) < AsyncResult canonical name ApplyResult(11) by 7 chars); multiprocessing.pool.Pool.__module__.__eq__('multiprocessing.pool')==True (__module__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20)); multiprocessing.pool.Pool.__module__.__len__()==20 ('multiprocessing.pool'=20; compare: concurrent.futures._base=24 is 4 chars longer; multiprocessing.pool=20 < concurrent.futures._base=24 by 4); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppool164

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name_eq,  multiprocessing.pool.Pool.__name__.__eq__,    ["Pool"],                   true,  "Pool.__name__ == 'Pool' (len=4; established in extra162; confirmed in extra164); verified with Python 3.14.3"]
    - [pool_name_len, multiprocessing.pool.Pool.__name__.__len__,   [],                         4,     "Pool.__name__.__len__() == 4 ('Pool'=4; shorter than ApplyResult=11 by 7); verified with Python 3.14.3"]
    - [pool_mod_eq,   multiprocessing.pool.Pool.__module__.__eq__,  ["multiprocessing.pool"],  true,  "Pool.__module__ == 'multiprocessing.pool' (len=20; 'multiprocessing'=15+'.'=1+'pool'=4=20); verified with Python 3.14.3"]
    - [pool_mod_len,  multiprocessing.pool.Pool.__module__.__len__, [],                         20,    "Pool.__module__.__len__() == 20 ('multiprocessing.pool'=20; same as AsyncResult module=20); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.AsyncResult (ApplyResult) class identity — extra164
#
# multiprocessing.pool.AsyncResult.__name__.__eq__('ApplyResult')        == True
# multiprocessing.pool.AsyncResult.__module__.__eq__('multiprocessing.pool') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra164.mp_asyncresult_identity:
  description: "multiprocessing.pool.AsyncResult class name and module identity checks in mpasyncres164 namespace — multiprocessing.pool.AsyncResult.__name__.__eq__('ApplyResult')==True (KEY FINDING: AsyncResult.__name__=='ApplyResult' NOT 'AsyncResult'; in Lib/multiprocessing/pool.py the class is defined as 'class ApplyResult(object):' and then 'AsyncResult = ApplyResult' is added as a backward-compatibility alias; Python's __name__ attribute always reflects the original class definition name, not any alias assigned to it; so the canonical __name__ is 'ApplyResult' (len=11: 'Apply'=5+'Result'=6=11); AsyncResult is an alias pointing to the same class object); multiprocessing.pool.AsyncResult.__name__.__len__()==11 ('ApplyResult'=11: 'Apply'=5+'Result'=6=11; coincidentally the alias name 'AsyncResult'=11: 'Async'=5+'Result'=6=11 has the same length — both 'Apply' and 'Async' are 5 chars, so both names are 11 chars; but the canonical __name__ is 'ApplyResult'); multiprocessing.pool.AsyncResult.__module__.__eq__('multiprocessing.pool')==True (__module__=='multiprocessing.pool' (len=20; same module as Pool)); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpasyncres164

  columns: [id, function, args, expected, description]
  rows:
    - [ar_name_eq,  multiprocessing.pool.AsyncResult.__name__.__eq__,    ["ApplyResult"],           true,  "AsyncResult.__name__ == 'ApplyResult' (canonical name; AsyncResult is an alias for ApplyResult); verified with Python 3.14.3"]
    - [ar_name_len, multiprocessing.pool.AsyncResult.__name__.__len__,   [],                        11,    "AsyncResult.__name__.__len__() == 11 ('ApplyResult'=11: 'Apply'=5+'Result'=6=11); verified with Python 3.14.3"]
    - [ar_mod_eq,   multiprocessing.pool.AsyncResult.__module__.__eq__,  ["multiprocessing.pool"],  true,  "AsyncResult.__module__ == 'multiprocessing.pool' (len=20; same module as Pool); verified with Python 3.14.3"]
    - [ar_mod_len,  multiprocessing.pool.AsyncResult.__module__.__len__, [],                        20,    "AsyncResult.__module__.__len__() == 20 ('multiprocessing.pool'=20; same as Pool module=20); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.pool.AsyncResult base class — extra164
#
# multiprocessing.pool.AsyncResult.__bases__[0].__name__.__eq__('object') == True
# multiprocessing.pool.AsyncResult.__bases__[0].__name__.__len__()        == 6
# ---------------------------------------------------------------------------

table multiprocessing_extra164.mp_asyncresult_base_class:
  description: "multiprocessing.pool.AsyncResult (ApplyResult) base class checks in mparbase164 namespace — multiprocessing.pool.AsyncResult.__bases__[0].__name__.__eq__('object')==True (AsyncResult/ApplyResult inherits from object directly; __bases__ == (<class 'object'>,); __bases__[0].__name__=='object' (len=6: 'o'+'b'+'j'+'e'+'c'+'t'=6)); multiprocessing.pool.AsyncResult.__bases__[0].__name__.__len__()==6 ('object'=6; same length as asyncio.Future.__name__='Future'=6 — base class name length equals asyncio.Future's class name length); Pool.__name__.__len__()==4 (cross-check; Pool(4) is the shortest name; Pool.__name__ != AsyncResult.__name__ in length: Pool=4 < ApplyResult=11); Pool.__module__.__len__()==20 (cross-check; Pool and AsyncResult share the same module length=20); KEY: AsyncResult.__bases__[0].__name__=='object' means AsyncResult is NOT a subclass of any Pool-related abstract class; it is a standalone result-holder class that provides get(), ready(), successful(), and wait() methods for retrieving async results; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mparbase164

  columns: [id, function, args, expected, description]
  rows:
    - [ar_base_name_eq,  "multiprocessing.pool.AsyncResult.__bases__[0].__name__.__eq__",  ["object"],  true,  "AsyncResult.__bases__[0].__name__ == 'object' (inherits from object directly; no abstract base); verified with Python 3.14.3"]
    - [ar_base_name_len, "multiprocessing.pool.AsyncResult.__bases__[0].__name__.__len__", [],          6,     "AsyncResult.__bases__[0].__name__.__len__() == 6 ('object'=6; same len as asyncio.Future name=6); verified with Python 3.14.3"]
    - [pool_name_len2,   multiprocessing.pool.Pool.__name__.__len__,                       [],          4,     "Pool.__name__.__len__() == 4 (cross-check; Pool=4 < ApplyResult=11 by 7); verified with Python 3.14.3"]
    - [pool_mod_len2,    multiprocessing.pool.Pool.__module__.__len__,                     [],          20,    "Pool.__module__.__len__() == 20 (cross-check; same as AsyncResult module len=20); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Pool vs AsyncResult name length cross-comparison — extra164
#
# Pool.__name__.__len__()           == 4
# AsyncResult.__name__.__len__()    == 11   (canonical name is 'ApplyResult')
# Pool.__module__.__len__()         == 20
# AsyncResult.__module__.__len__()  == 20
# ---------------------------------------------------------------------------

table multiprocessing_extra164.mp_pool_asyncresult_comparison:
  description: "multiprocessing.pool.Pool vs AsyncResult name and module length cross-comparison in mppoolarcmp164 namespace — Pool.__name__.__len__()==4 ('Pool'=4) vs AsyncResult.__name__.__len__()==11 ('ApplyResult'=11); Pool(4) < ApplyResult(11) by 7 chars — the result class name is much longer than the pool class name; Pool.__module__.__len__()==20 == AsyncResult.__module__.__len__()==20 — both classes share the same module 'multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20); Pool.__name__.__eq__('Pool')==True (pool has the short, simple 4-char name); AsyncResult.__name__.__eq__('ApplyResult')==True (the canonical name is ApplyResult=11; the alias AsyncResult also has 11 chars: 'Async'=5+'Result'=6=11 == 'Apply'=5+'Result'=6=11; both the alias and canonical name have the same length because 'Async'=5=='Apply'=5); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolarcmp164

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name_len3,  multiprocessing.pool.Pool.__name__.__len__,        [],               4,     "Pool.__name__.__len__() == 4 (Pool=4; shortest in spec); verified with Python 3.14.3"]
    - [ar_name_len2,    multiprocessing.pool.AsyncResult.__name__.__len__, [],               11,    "AsyncResult.__name__.__len__() == 11 ('ApplyResult'=11; Pool=4 < ApplyResult=11 by 7); verified with Python 3.14.3"]
    - [pool_mod_len3,   multiprocessing.pool.Pool.__module__.__len__,      [],               20,    "Pool.__module__.__len__() == 20 (same as AsyncResult module=20); verified with Python 3.14.3"]
    - [ar_mod_len2,     multiprocessing.pool.AsyncResult.__module__.__len__,  [],            20,    "AsyncResult.__module__.__len__() == 20 (same as Pool module=20); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra164
# ---------------------------------------------------------------------------

invariant multiprocessing_extra164.mp_Pool_name_eq:
  description: "multiprocessing.pool.Pool.__name__.__eq__('Pool') returns True — multiprocessing.pool.Pool.__name__=='Pool' (len=4: 'P'+'o'+'o'+'l'=4; established in extra162 table mp_pool_identity_and_dict_cross and confirmed here in extra164); Pool is the multiprocessing process pool class; Pool manages a collection of worker processes; work is distributed to them using apply(), map(), starmap(), apply_async(), map_async(), starmap_async(), imap(), imap_unordered() — all established in prior specs; Pool.__module__=='multiprocessing.pool' (len=20); Pool.__name__.__len__()==4 is the shortest class name in this spec — shorter than AsyncResult's canonical name 'ApplyResult'=11 by 7 chars; compare: multiprocessing.pool.AsyncResult.__name__=='ApplyResult' (not 'AsyncResult'; established in this spec's tables); NEW in extra164: extended Pool.__name__ invariant in mppool164 namespace with new cross-module context vs AsyncResult; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__name__.__eq__
  args: ["Pool"]
  expected: true

invariant multiprocessing_extra164.mp_Pool_module_eq:
  description: "multiprocessing.pool.Pool.__module__.__eq__('multiprocessing.pool') returns True — multiprocessing.pool.Pool.__module__=='multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20; established in extra162 table mp_pool_identity_and_dict_cross); the 'multiprocessing.pool' module (len=20) is shorter than 'concurrent.futures._base' (len=24) by 4 chars and shorter than 'concurrent.futures.thread' (len=25) by 5; 'multiprocessing.pool'=20: 'multiprocessing'=15 is the longest component (compare: 'concurrent'=10+'.'=1+'futures'=7=18 for the cf prefix — multiprocessing module starts longer but has a shorter suffix 'pool'=4 vs '_base'=5+'thread'=6/'process'=7); Pool.__module__ == AsyncResult.__module__ == 'multiprocessing.pool' — both Pool and AsyncResult (ApplyResult) are defined in the same pool module; NEW in extra164: Pool.__module__ invariant in mppool164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra164.mp_AsyncResult_name_eq:
  description: "multiprocessing.pool.AsyncResult.__name__.__eq__('ApplyResult') returns True — KEY FINDING: multiprocessing.pool.AsyncResult.__name__ is 'ApplyResult' NOT 'AsyncResult'; in Lib/multiprocessing/pool.py the class is defined as 'class ApplyResult(object):' and then 'AsyncResult = ApplyResult' creates an alias; Python's __name__ attribute captures the name at class DEFINITION time, not any alias names; therefore AsyncResult.__name__=='ApplyResult' (len=11: 'Apply'=5+'Result'=6=11); multiprocessing.pool.AsyncResult is the class returned by Pool.apply_async() when callback=None; it provides: get(timeout=None) — block until result is available and return it; ready() — True if the call completed; successful() — True if completed without exception; wait(timeout=None) — wait for result without retrieving it; compare: the alias 'AsyncResult' and canonical 'ApplyResult' both have len=11 ('Async'=5=='Apply'=5 and 'Result'=6 is shared); NEW in extra164: first standalone AsyncResult.__name__ invariant in mpasyncres164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.AsyncResult.__name__.__eq__
  args: ["ApplyResult"]
  expected: true

invariant multiprocessing_extra164.mp_AsyncResult_module_eq:
  description: "multiprocessing.pool.AsyncResult.__module__.__eq__('multiprocessing.pool') returns True — AsyncResult (ApplyResult) is defined in the same module as Pool: 'multiprocessing.pool' (len=20: 'multiprocessing'=15+'.'=1+'pool'=4=20); Pool and AsyncResult share the same module path because ApplyResult is defined immediately after Pool in Lib/multiprocessing/pool.py; Pool.apply_async() returns an ApplyResult instance; Pool.map_async() returns a MapResult instance (a subclass of ApplyResult); Pool.__module__ == AsyncResult.__module__ == 'multiprocessing.pool' — module equality; AsyncResult.__module__.__len__()==20 == Pool.__module__.__len__()==20; compare: concurrent.futures.Future.__module__=='concurrent.futures._base' (len=24; cf.Future and its executor classes are in a larger module path); NEW in extra164: first standalone AsyncResult.__module__ identity invariant in mpasyncres164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.AsyncResult.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra164.mp_AsyncResult_base_is_object:
  description: "multiprocessing.pool.AsyncResult.__bases__[0].__name__.__eq__('object') returns True — AsyncResult (ApplyResult) inherits from object directly; __bases__[0].__name__=='object' (len=6: 'o'+'b'+'j'+'e'+'c'+'t'=6); ApplyResult is a standalone result class with no abstract base class — it is a concrete class that wraps multiprocessing event/condition synchronization to deliver results from worker processes; the inheritance chain is simply ApplyResult -> object; compare: concurrent.futures.Future.__bases__[0].__name__=='object' (cf.Future also inherits from object directly — established in extra163); multiprocessing.pool.Pool.__bases__[0].__name__=='object' (Pool also inherits from object — established in extra162 table mp_pool_identity_and_dict_cross); all three major classes in multiprocessing.pool and concurrent.futures inherit directly from object; 'object'=6 chars; NEW in extra164: first standalone AsyncResult.__bases__[0].__name__ invariant in mparbase164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.pool.AsyncResult.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant multiprocessing_extra164.mp_AsyncResult_name_len:
  description: "multiprocessing.pool.AsyncResult.__name__.__len__() returns 11 — AsyncResult.__name__ is 'ApplyResult' (the canonical class definition name); 'ApplyResult'.__len__()==11 ('Apply'=5+'Result'=6=11); note: the alias name 'AsyncResult' also has length 11 ('Async'=5+'Result'=6=11) — both the canonical name and the alias have the same length because 'Apply'=5=='Async'=5 (both are 5-char prefixes) and they share the 'Result'=6 suffix; AsyncResult.__name__.__len__()==11 > Pool.__name__.__len__()==4 by 7 chars — ApplyResult(11) is much longer than Pool(4); compare: concurrent.futures.Future.__name__.__len__()==6 ('Future'=6) < ApplyResult(11) by 5 chars; concurrent.futures.Executor.__name__.__len__()==8 ('Executor'=8) < ApplyResult(11) by 3 chars; NEW in extra164: first standalone AsyncResult.__name__.__len__ invariant in mpasyncres164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.AsyncResult.__name__.__len__
  args: []
  expected: 11
