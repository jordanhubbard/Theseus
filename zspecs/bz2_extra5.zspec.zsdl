spec: bz2_extra5
version: ">=3.9"
backend: python_module(bz2)

docs: https://docs.python.org/3/library/bz2.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bz2.html — Python bz2 documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/bz2.py"
  notes:
    - "This spec extends bz2.zspec.zsdl and prior extras."
    - "bz2.BZ2File.__name__ == 'BZ2File' — table form with new id_prefix cn5."
    - "bz2.BZ2Compressor.__name__ == 'BZ2Compressor' — in table form."
    - "bz2.BZ2Decompressor.__name__ == 'BZ2Decompressor' — in table form."
    - "bz2.BZ2File.__module__ == 'bz2' — checked via class_module_check table."
    - "bz2.BZ2File.__qualname__ == 'BZ2File' — qualname string equality."
    - "bz2.open.__name__ == 'open' — standalone invariant form."
    - "bz2.BZ2File.__bases__[0].__name__ == 'BaseStream' — checked via __eq__ returning bool (new form vs prior __name__ string form in bz2_extra2)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ checks — table form with new id_prefix cn5
# bz2_extra and bz2_extra3 used prefixes classname/cname; this is cn5.
# ---------------------------------------------------------------------------

table bz2_extra5.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cn5

  columns: [id, function, args, expected]
  rows:
    - [BZ2File,         BZ2File.__name__.__eq__,         ["BZ2File"],         true]
    - [BZ2Compressor,   BZ2Compressor.__name__.__eq__,   ["BZ2Compressor"],   true]
    - [BZ2Decompressor, BZ2Decompressor.__name__.__eq__, ["BZ2Decompressor"], true]

# ---------------------------------------------------------------------------
# BZ2File module check — table form
# Prior specs use standalone invariants for BZ2File.__module__;
# this is the first table form grouping BZ2File __module__.
# ---------------------------------------------------------------------------

table bz2_extra5.class_modules:
  kind: python_call_eq
  category: module
  id_prefix: cmod5

  columns: [id, function, args, expected]
  rows:
    - [BZ2File, BZ2File.__module__.__eq__, ["bz2"], true]

# ---------------------------------------------------------------------------
# BZ2File.__qualname__ — string equality check
# bz2_extra4 uses __qualname__.__eq__ in a table row returning bool.
# This is a standalone invariant form for cross-check.
# ---------------------------------------------------------------------------

invariant bz2_extra5.BZ2File.qualname_eq:
  description: "bz2.BZ2File.__qualname__ == 'BZ2File' — top-level class qualname equals its name"
  category: qualnames
  kind: python_call_eq
  function: BZ2File.__qualname__.__eq__
  args: ["BZ2File"]
  expected: true

# ---------------------------------------------------------------------------
# open.__name__ — standalone invariant (bz2_extra/bz2_extra3 cover this in tables)
# ---------------------------------------------------------------------------

invariant bz2_extra5.open.name_eq:
  description: "bz2.open.__name__ == 'open' — module-level open function name attribute"
  category: function_names
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

# ---------------------------------------------------------------------------
# BZ2File base class — bool form via __eq__
# bz2_extra2 checks this as: function: BZ2File.__bases__.__getitem__, args: [0],
#   method: __name__, expected: "BaseStream"  (returns the string).
# This is a distinct form: method: __name__.__eq__, method_args: ["BaseStream"],
#   expected: true  (returns bool).
# ---------------------------------------------------------------------------

invariant bz2_extra5.BZ2File.base_name_bool:
  description: "bz2.BZ2File.__bases__[0].__name__ == 'BaseStream' — BZ2File does NOT inherit from io.BufferedIOBase"
  category: hierarchy
  kind: python_call_eq
  function: BZ2File.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["BaseStream"]
  expected: true
