spec: pathlib_extra2041
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rlshift__, __ilshift__, __rshift__, __rrshift__, __irshift__, __and__, __rand__, __iand__, __or__, __ror__, __ior__, __xor__, __rxor__, __ixor__, __invert__ dict-presence checks."
    - "pathlib.Path, pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath are filesystem path types; none defines any bitwise operator."
    - "pathlib.PurePath defines __truediv__ and __rtruediv__ for path joining (/) but no bitwise shift, AND, OR, XOR, or NOT operators."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __lshift__ / __rlshift__ / __ilshift__ — left shift dict-presence
# ---------------------------------------------------------------------------

table pathlib_extra2041.lshift_protocol:
  description: "pathlib types __lshift__/__rlshift__/__ilshift__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2041

  columns: [id, function, args, expected]
  rows:
    - ["pl2041001", "pathlib.PurePath.__dict__.__contains__",        ["__lshift__"],  false]
    - ["pl2041002", "pathlib.PurePath.__dict__.__contains__",        ["__rlshift__"], false]
    - ["pl2041003", "pathlib.PurePath.__dict__.__contains__",        ["__ilshift__"], false]
    - ["pl2041004", "pathlib.PurePosixPath.__dict__.__contains__",   ["__lshift__"],  false]
    - ["pl2041005", "pathlib.PurePosixPath.__dict__.__contains__",   ["__rlshift__"], false]
    - ["pl2041006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__ilshift__"], false]
    - ["pl2041007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__lshift__"],  false]
    - ["pl2041008", "pathlib.PureWindowsPath.__dict__.__contains__", ["__rlshift__"], false]
    - ["pl2041009", "pathlib.PureWindowsPath.__dict__.__contains__", ["__ilshift__"], false]
    - ["pl2041010", "pathlib.Path.__dict__.__contains__",            ["__lshift__"],  false]
    - ["pl2041011", "pathlib.Path.__dict__.__contains__",            ["__rlshift__"], false]
    - ["pl2041012", "pathlib.Path.__dict__.__contains__",            ["__ilshift__"], false]

