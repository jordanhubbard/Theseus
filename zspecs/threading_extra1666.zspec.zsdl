spec: threading_extra1666
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "Python threading documentation — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading.zspec.zsdl — covers class __name__ checks (Barrier, BoundedSemaphore, Condition), function names, TIMEOUT_MAX, active_count, Lock, Event, Semaphore, current_thread.is_alive"
    - "threading_extra.zspec.zsdl — covers class_modules table, threading.local name/module, current_thread class name, get_ident, TIMEOUT_MAX type, stack_size"
    - "threading_sync.zspec.zsdl — covers Barrier parties/n_waiting/broken, BoundedSemaphore, RLock, Condition, Semaphore defaults"
    - "threading_timer.zspec.zsdl — covers Timer/ThreadError bases, main_thread, current_thread, enumerate, active_count return type"
  notes:
    - "Theme: __new__ — object construction protocol."
    - "threading.Thread, Event, Condition, Semaphore, BoundedSemaphore, Barrier, Timer, _RLock — all Python classes that define __init__ but NOT __new__."
    - "threading.Lock is actually _thread.lock, a C extension type; it defines __new__ but NOT __init__."
    - "threading.local is _thread.local, a C extension type; it defines __new__ but NOT __init__."
    - "threading._CRLock is a C extension type (from _thread); defines __new__, no __init__."
    - "threading.RLock is a Python function (factory) that returns a _CRLock or _RLock depending on availability; it is not a type, so __dict__ queries for __new__/__init__ are not applicable."
    - "threading.Lock.__module__ == '_thread'; threading.local.__module__ == '_thread'."
    - "threading.Lock.__name__ == 'lock' (lowercase) — the C class name exposed by _thread."
    - "All expected values verified by running Python 3.14 on macOS Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: no_custom_new
#
# Confirms that the pure-Python threading classes (Thread, Event, Condition,
# Semaphore, BoundedSemaphore, Barrier, Timer, _RLock) do NOT define __new__
# in their own __dict__.  These classes rely on object.__new__ inherited from
# the default MRO; all construction logic lives in __init__.
# ---------------------------------------------------------------------------

table threading_extra1666.no_custom_new:
  kind: python_call_eq
  category: no_custom_new
  id_prefix: th1666

  columns: [id, function, args, expected]
  rows:
    - ["thread_no_new",              Thread.__dict__.__contains__,            ["__new__"],  false]
    - ["event_no_new",               Event.__dict__.__contains__,             ["__new__"],  false]
    - ["condition_no_new",           Condition.__dict__.__contains__,         ["__new__"],  false]
    - ["semaphore_no_new",           Semaphore.__dict__.__contains__,         ["__new__"],  false]
    - ["boundedsemaphore_no_new",    BoundedSemaphore.__dict__.__contains__,  ["__new__"],  false]
    - ["barrier_no_new",             Barrier.__dict__.__contains__,           ["__new__"],  false]
    - ["timer_no_new",               Timer.__dict__.__contains__,             ["__new__"],  false]
    - ["rlock_impl_no_new",          _RLock.__dict__.__contains__,            ["__new__"],  false]
    - ["thread_is_type",             Thread.__class__.__name__.__eq__,        ["type"],     true]
    - ["event_is_type",              Event.__class__.__name__.__eq__,         ["type"],     true]
    - ["condition_is_type",          Condition.__class__.__name__.__eq__,     ["type"],     true]
    - ["semaphore_is_type",          Semaphore.__class__.__name__.__eq__,     ["type"],     true]
    - ["boundedsemaphore_is_type",   BoundedSemaphore.__class__.__name__.__eq__, ["type"],  true]
    - ["barrier_is_type",            Barrier.__class__.__name__.__eq__,       ["type"],     true]
    - ["timer_is_type",              Timer.__class__.__name__.__eq__,         ["type"],     true]
    - ["rlock_impl_is_type",         _RLock.__class__.__name__.__eq__,        ["type"],     true]
    - ["thread_module",              Thread.__module__.__eq__,                ["threading"], true]
    - ["event_module",               Event.__module__.__eq__,                 ["threading"], true]
    - ["condition_module",           Condition.__module__.__eq__,             ["threading"], true]
    - ["semaphore_module",           Semaphore.__module__.__eq__,             ["threading"], true]
    - ["boundedsemaphore_module",    BoundedSemaphore.__module__.__eq__,      ["threading"], true]
    - ["barrier_module",             Barrier.__module__.__eq__,               ["threading"], true]
    - ["timer_module",               Timer.__module__.__eq__,                 ["threading"], true]
    - ["rlock_impl_module",          _RLock.__module__.__eq__,                ["threading"], true]

# ---------------------------------------------------------------------------
# Table 2: init_present
#
# Confirms that the same pure-Python threading classes all define __init__
# in their own __dict__.  This is the standard pattern: no custom __new__,
# all construction logic in __init__.
# ---------------------------------------------------------------------------

table threading_extra1666.init_present:
  kind: python_call_eq
  category: init_present
  id_prefix: th1666

  columns: [id, function, args, expected]
  rows:
    - ["thread_has_init",            Thread.__dict__.__contains__,            ["__init__"], true]
    - ["event_has_init",             Event.__dict__.__contains__,             ["__init__"], true]
    - ["condition_has_init",         Condition.__dict__.__contains__,         ["__init__"], true]
    - ["semaphore_has_init",         Semaphore.__dict__.__contains__,         ["__init__"], true]
    - ["boundedsemaphore_has_init",  BoundedSemaphore.__dict__.__contains__,  ["__init__"], true]
    - ["barrier_has_init",           Barrier.__dict__.__contains__,           ["__init__"], true]
    - ["timer_has_init",             Timer.__dict__.__contains__,             ["__init__"], true]
    - ["rlock_impl_has_init",        _RLock.__dict__.__contains__,            ["__init__"], true]
    - ["thread_has_run",             Thread.__dict__.__contains__,            ["run"],      true]
    - ["thread_has_start",           Thread.__dict__.__contains__,            ["start"],    true]
    - ["thread_has_join",            Thread.__dict__.__contains__,            ["join"],     true]
    - ["event_has_set",              Event.__dict__.__contains__,             ["set"],      true]
    - ["event_has_clear",            Event.__dict__.__contains__,             ["clear"],    true]
    - ["event_has_wait",             Event.__dict__.__contains__,             ["wait"],     true]
    - ["event_has_is_set",           Event.__dict__.__contains__,             ["is_set"],   true]
    - ["condition_has_acquire",      Condition.__dict__.__contains__,         ["acquire"],  true]
    - ["condition_has_release",      Condition.__dict__.__contains__,         ["release"],  true]
    - ["condition_has_wait",         Condition.__dict__.__contains__,         ["wait"],     true]
    - ["condition_has_notify",       Condition.__dict__.__contains__,         ["notify"],   true]
    - ["semaphore_has_acquire",      Semaphore.__dict__.__contains__,         ["acquire"],  true]
    - ["semaphore_has_release",      Semaphore.__dict__.__contains__,         ["release"],  true]
    - ["barrier_has_wait",           Barrier.__dict__.__contains__,           ["wait"],     true]
    - ["barrier_has_reset",          Barrier.__dict__.__contains__,           ["reset"],    true]
    - ["barrier_has_abort",          Barrier.__dict__.__contains__,           ["abort"],    true]

# ---------------------------------------------------------------------------
# Table 3: c_type_new_init
#
# C extension types from the _thread module exposed through threading.
# threading.Lock (_thread.lock) and threading.local (_thread.local) define
# __new__ but NOT __init__ — the opposite pattern from the pure-Python classes.
# threading._CRLock is the C-level RLock implementation with the same pattern.
# ---------------------------------------------------------------------------

table threading_extra1666.c_type_new_init:
  kind: python_call_eq
  category: c_type_new_init
  id_prefix: th1666

  columns: [id, function, args, expected]
  rows:
    - ["lock_has_new",               Lock.__dict__.__contains__,    ["__new__"],   true]
    - ["lock_no_init",               Lock.__dict__.__contains__,    ["__init__"],  false]
    - ["local_has_new",              local.__dict__.__contains__,   ["__new__"],   true]
    - ["local_no_init",              local.__dict__.__contains__,   ["__init__"],  false]
    - ["crlock_has_new",             _CRLock.__dict__.__contains__,  ["__new__"],   true]
    - ["crlock_no_init",             _CRLock.__dict__.__contains__,  ["__init__"],  false]
    - ["lock_module_is_thread",      Lock.__module__.__eq__,        ["_thread"],   true]
    - ["local_module_is_thread",     local.__module__.__eq__,       ["_thread"],   true]
    - ["crlock_module_is_thread",    _CRLock.__module__.__eq__,      ["_thread"],   true]
    - ["lock_name_is_lock",          Lock.__name__.__eq__,          ["lock"],      true]
    - ["local_name_is_local",        local.__name__.__eq__,         ["local"],     true]
    - ["lock_is_type",               Lock.__class__.__name__.__eq__, ["type"],     true]
    - ["local_is_type",              local.__class__.__name__.__eq__, ["type"],    true]
    - ["crlock_is_type",             _CRLock.__class__.__name__.__eq__, ["type"],  true]
    - ["lock_has_acquire",           Lock.__dict__.__contains__,    ["acquire"],   true]
    - ["lock_has_release",           Lock.__dict__.__contains__,    ["release"],   true]
    - ["lock_has_locked",            Lock.__dict__.__contains__,    ["locked"],    true]
    - ["lock_has_enter",             Lock.__dict__.__contains__,    ["__enter__"], true]
    - ["lock_has_exit",              Lock.__dict__.__contains__,    ["__exit__"],  true]
    - ["lock_has_repr",              Lock.__dict__.__contains__,    ["__repr__"],  true]
