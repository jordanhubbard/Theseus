spec: uuid_extra2116
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html"
    - "CPython source: Lib/uuid.py"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave _extra2116: __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks."
    - "uuid.UUID is a pure-Python class with __slots__; it defines comparison and hash operators but not set/dict merge operators."
    - "uuid.SafeUUID is an Enum subclass (not IntEnum); its MRO is [SafeUUID, Enum, object]. Enum does not define __or__/__and__/__xor__ in its own __dict__."
    - "Neither uuid.UUID nor uuid.SafeUUID define __or__, __ror__, or __ior__ in their own __dict__."
    - "Neither uuid.UUID nor uuid.SafeUUID define __and__, __rand__, or __iand__ in their own __dict__."
    - "Neither uuid.UUID nor uuid.SafeUUID define __xor__, __rxor__, or __ixor__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __or__ / __ror__ / __ior__ — dict-merge / set-union dict-presence
# uuid.UUID and uuid.SafeUUID do not define these operators
# ---------------------------------------------------------------------------

table uuid_extra2116.or_protocol:
  description: "uuid types __or__/__ror__/__ior__ dict-presence"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2116

  columns: [id, function, args, expected]
  rows:
    - ["uu2116001", "uuid.UUID.__dict__.__contains__",     ["__or__"],  false]
    - ["uu2116002", "uuid.UUID.__dict__.__contains__",     ["__ror__"], false]
    - ["uu2116003", "uuid.UUID.__dict__.__contains__",     ["__ior__"], false]
    - ["uu2116004", "uuid.SafeUUID.__dict__.__contains__", ["__or__"],  false]
    - ["uu2116005", "uuid.SafeUUID.__dict__.__contains__", ["__ror__"], false]
    - ["uu2116006", "uuid.SafeUUID.__dict__.__contains__", ["__ior__"], false]

