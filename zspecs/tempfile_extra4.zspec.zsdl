spec: tempfile_extra4
version: ">=3.9"
backend: python_module(tempfile)

docs: https://docs.python.org/3/library/tempfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tempfile.html — Python tempfile module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tempfile.py"
    - "tempfile.zspec.zsdl — covers core NamedTemporaryFile/TemporaryDirectory/mkstemp behaviors"
    - "tempfile_extra.zspec.zsdl — covers initial __name__ and __module__ checks"
    - "tempfile_extra2.zspec.zsdl — covers additional attribute checks"
    - "tempfile_extra3.zspec.zsdl — covers __name__ for NamedTemporaryFile/SpooledTemporaryFile/TemporaryDirectory/TemporaryFile/mkstemp/mkdtemp/gettempdir/gettempprefix/mktemp, __module__ for NamedTemporaryFile/SpooledTemporaryFile/TemporaryDirectory, gettempdir() returns str, gettempprefix() == 'tmp', TemporaryDirectory/SpooledTemporaryFile instance class names"
  notes:
    - "This spec covers __qualname__ attributes for tempfile functions and classes — not covered in prior tempfile specs."
    - "tempfile.NamedTemporaryFile.__qualname__ == 'NamedTemporaryFile' — qualname equals name for top-level class."
    - "tempfile.TemporaryFile.__qualname__ == 'TemporaryFile' — qualname equals name for top-level class."
    - "tempfile.TemporaryDirectory.__qualname__ == 'TemporaryDirectory' — qualname equals name for top-level class."
    - "tempfile.SpooledTemporaryFile.__qualname__ == 'SpooledTemporaryFile' — qualname equals name for top-level class."
    - "tempfile.mkstemp.__qualname__ == 'mkstemp' — qualname equals name for top-level function."
    - "tempfile.mkdtemp.__qualname__ == 'mkdtemp' — qualname equals name for top-level function."
    - "tempfile.gettempdir.__qualname__ == 'gettempdir' — qualname equals name for top-level function."
    - "tempfile.gettempprefix.__qualname__ == 'gettempprefix' — qualname equals name for top-level function."
    - "tempfile.NamedTemporaryFile.__module__ == 'tempfile' — already in tempfile_extra3; not duplicated here."
    - "tempfile.gettempdir.__module__ == 'tempfile' — function is defined in the tempfile module."
    - "tempfile.gettempprefix.__module__ == 'tempfile' — function is defined in the tempfile module."
    - "tempfile.TemporaryFile.__module__ == 'tempfile' — class is defined in the tempfile module."
    - "tempfile.gettempprefix().__class__.__name__ == 'str' — return type is str."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks for top-level tempfile classes
# Not covered in any prior tempfile spec (prior specs only used __name__)
# ---------------------------------------------------------------------------

table tempfile_extra4.class_qualnames:
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: cqname

  columns: [id, function, args, expected]
  rows:
    - [NamedTemporaryFile,   NamedTemporaryFile.__qualname__.__eq__,   ["NamedTemporaryFile"],   true]
    - [TemporaryFile,        TemporaryFile.__qualname__.__eq__,        ["TemporaryFile"],        true]
    - [TemporaryDirectory,   TemporaryDirectory.__qualname__.__eq__,   ["TemporaryDirectory"],   true]
    - [SpooledTemporaryFile, SpooledTemporaryFile.__qualname__.__eq__, ["SpooledTemporaryFile"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks for top-level tempfile functions
# ---------------------------------------------------------------------------

table tempfile_extra4.function_qualnames:
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: fqname

  columns: [id, function, args, expected]
  rows:
    - [mkstemp,       mkstemp.__qualname__.__eq__,       ["mkstemp"],       true]
    - [mkdtemp,       mkdtemp.__qualname__.__eq__,       ["mkdtemp"],       true]
    - [gettempdir,    gettempdir.__qualname__.__eq__,    ["gettempdir"],    true]
    - [gettempprefix, gettempprefix.__qualname__.__eq__, ["gettempprefix"], true]

# ---------------------------------------------------------------------------
# __module__ checks not yet covered by tempfile_extra3
# tempfile_extra3 covers: NamedTemporaryFile, SpooledTemporaryFile, TemporaryDirectory
# New: TemporaryFile, gettempdir, gettempprefix, mkstemp, mkdtemp
# ---------------------------------------------------------------------------

table tempfile_extra4.extra_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [TemporaryFile, TemporaryFile.__module__.__eq__, ["tempfile"], true]
    - [gettempdir,    gettempdir.__module__.__eq__,    ["tempfile"], true]
    - [gettempprefix, gettempprefix.__module__.__eq__, ["tempfile"], true]
    - [mkstemp,       mkstemp.__module__.__eq__,       ["tempfile"], true]
    - [mkdtemp,       mkdtemp.__module__.__eq__,       ["tempfile"], true]

# ---------------------------------------------------------------------------
# gettempprefix() return type — not yet covered (tempfile_extra3 checks value == 'tmp')
# ---------------------------------------------------------------------------

invariant tempfile_extra4.gettempprefix.returns_str:
  description: "tempfile.gettempprefix().__class__.__name__ == 'str'"
  category: gettempprefix
  kind: python_call_eq
  function: gettempprefix
  args: []
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true
