spec: struct_extra1126
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.pack/unpack/calcsize __doc__.__class__.__name__, struct.Struct.size/format __class__.__name__ (member_descriptor), struct.Struct.size/format __qualname__"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1126.module_function_doc_class_names:
  description: "struct.pack, unpack, calcsize __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: module_function_doc_classnames
  id_prefix: st1126fd
  columns: [id, function, args, expected]
  rows:
    - [st1126fd001, struct.pack.__doc__.__class__.__name__.__eq__,              ["str"],      true]
    - [st1126fd002, struct.unpack.__doc__.__class__.__name__.__eq__,            ["str"],      true]
    - [st1126fd003, struct.calcsize.__doc__.__class__.__name__.__eq__,          ["str"],      true]
    - [st1126fd004, struct.pack.__doc__.__class__.__qualname__.__eq__,          ["str"],      true]
    - [st1126fd005, struct.unpack.__doc__.__class__.__qualname__.__eq__,        ["str"],      true]
    - [st1126fd006, struct.calcsize.__doc__.__class__.__qualname__.__eq__,      ["str"],      true]
    - [st1126fd007, struct.pack.__doc__.__class__.__module__.__eq__,            ["builtins"], true]
    - [st1126fd008, struct.unpack.__doc__.__class__.__module__.__eq__,          ["builtins"], true]
    - [st1126fd009, struct.calcsize.__doc__.__class__.__module__.__eq__,        ["builtins"], true]
    - [st1126fd010, struct.pack_into.__doc__.__class__.__name__.__eq__,         ["str"],      true]

