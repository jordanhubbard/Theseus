spec: countries_and_timezones
version: ">=3.0.0"
backend: node(countries-and-timezones)

docs: https://www.npmjs.com/package/countries-and-timezones

provenance:
  derived_from:
    - "countries-and-timezones README — https://www.npmjs.com/package/countries-and-timezones"
    - "Test vectors verified with countries-and-timezones via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "countries-and-timezones source"
  notes:
    - "countries-and-timezones is an npm package. Install: npm install countries-and-timezones"
    - "getTimezone(name) returns timezone metadata including UTC/DST offsets."
    - "utcOffset and dstOffset are in minutes."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns timezone object or undefined."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table countries_and_timezones.getTimezone:
  kind: node_module_call_eq
  function: getTimezone
  category: timezone
  id_prefix: cat

  columns: [id, args, expected]
  rows:
    - [new_york, ["America/New_York"],
       {"name": "America/New_York", "countries": ["US"],
        "utcOffset": -300, "utcOffsetStr": "-05:00",
        "dstOffset": -240, "dstOffsetStr": "-04:00", "aliasOf": null}]
    - [london, ["Europe/London"],
       {"name": "Europe/London", "countries": ["GB", "GG", "IM", "JE"],
        "utcOffset": 0, "utcOffsetStr": "+00:00",
        "dstOffset": 60, "dstOffsetStr": "+01:00", "aliasOf": null}]
