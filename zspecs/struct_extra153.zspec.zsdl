spec: struct_extra153
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra152.zspec.zsdl — covers struct.iter_unpack/__class__.__name__/__module__/__name__ / Struct.__name__.__len__()==6 / pack/__unpack/__calcsize/__pack_into __name__ and __name__ lengths (table + invariants)."
    - "struct_extra151.zspec.zsdl — covers struct.__all__.__class__.__name__.__eq__('list') / __all__.__contains__('pack'/'error') / __all__.__len__()==8 / error.__name__/__module__/__qualname__ / pack/__unpack/__calcsize qualnames (table + invariants)."
    - "struct_extra150.zspec.zsdl — covers struct.__spec__.__class__.__name__.__eq__('ModuleSpec') / __spec__.name.__eq__('struct') / pack.__module__.__eq__('_struct') / pack/__unpack/__calcsize __class__.__name__.__eq__('builtin_function_or_method') (table + invariants)."
    - "struct_extra149.zspec.zsdl — covers struct.Struct.pack_into/__unpack_from/__iter_unpack qualnames / Struct.size/__format/__class__.__name__.__eq__('getset_descriptor') (table + invariants)."
    - "struct_extra148.zspec.zsdl — covers struct.Struct.__name__/__module__/__bases__[0].__name__ / Struct.pack/__qualname__ / Struct.unpack/__qualname__ / struct.error.__name__/__module__/__bases__[0].__name__ (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra152."
    - "Wave 339 theme: struct.Struct.__init__ and docstring identity — Struct.__init__.__qualname__.__eq__('Struct.__init__') / Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') / Struct.__doc__.__class__.__name__.__eq__('str') / Struct.__doc__.__len__()==40 / struct.error.__doc__ is None (NoneType) / struct.pack.__doc__.__class__.__name__.__eq__('str') / struct.calcsize.__doc__.__class__.__name__.__eq__('str')."
    - "struct.Struct.__init__.__qualname__ == 'Struct.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__doc__.__len__() == 40. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__doc__ is None. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__init__.__class__.__name__ == 'wrapper_descriptor'. Struct is a C extension type defined in _struct.c. Its __init__ method (which initializes a Struct with a format string) is exposed as a wrapper_descriptor — the Python type used for __init__ and __new__ slot wrappers of built-in C types. This contrasts with uuid.UUID.__init__.__class__.__name__ == 'function' (pure Python). 'wrapper_descriptor' = 18 chars."
    - "Note: struct.Struct.__doc__.__len__() == 40. The Struct class docstring is exactly 40 characters long. This is a platform/version-specific value. struct.Struct.__doc__.__class__.__name__ == 'str' confirms it is a Python str object."
    - "Note: struct.error.__doc__ is None. The struct.error exception class has no docstring (its __doc__ attribute is None, not a str). This gives __doc__.__class__.__name__ == 'NoneType'. This contrasts with struct.pack and struct.calcsize which do have str docstrings."
    - "Note: struct.pack.__doc__.__class__.__name__ == 'str' and struct.calcsize.__doc__.__class__.__name__ == 'str'. Module-level C extension functions from _struct (pack, unpack, calcsize, pack_into, iter_unpack) all carry docstrings as Python str objects. This mirrors the pattern for hashlib constructors (extra158 anchors sha256.__doc__.__class__.__name__=='str')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__qualname__.__eq__('Struct.__init__')
# struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor')
# struct.Struct.__doc__.__class__.__name__.__eq__('str')
# struct.Struct.__doc__.__len__()==40
#
# Wave 339 theme: Struct.__init__ type and Struct docstring identity.
#
# Struct.__init__.__qualname__ == 'Struct.__init__' (15 chars = 'Struct.'=7 + '__init__'=8).
# Struct.__init__.__class__.__name__ == 'wrapper_descriptor' (18 chars; C type slot wrapper).
# Struct.__doc__.__class__.__name__ == 'str' (3 chars; class has a docstring).
# Struct.__doc__.__len__() == 40 (docstring is exactly 40 chars long).
# No prior struct spec anchors Struct.__init__ class name or Struct.__doc__ length as a
# table under structdi153. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra153.Struct_init_and_doc_identity:
  description: "struct.Struct.__init__.__qualname__.__eq__('Struct.__init__')==True / Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor')==True / Struct.__doc__.__class__.__name__.__eq__('str')==True / Struct.__doc__.__len__()==40 — Struct.__init__.__qualname__ is 'Struct.__init__' (15 chars = 'Struct.'=7 + '__init__'=8); Struct.__init__.__class__.__name__ is 'wrapper_descriptor' (18 chars; C extension type slot wrapper for __init__; contrasts with uuid.UUID.__init__.__class__.__name__=='function'); Struct.__doc__ is a str (3 chars; C type carries docstring); Struct.__doc__.__len__() is 40 (exact docstring length; platform/version-specific); first structdi153 anchor for Struct.__init__ class name and Struct doc length"
  kind: python_call_eq
  category: identity
  id_prefix: structdi153

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_init_qualname,         "Struct.__init__.__qualname__.__eq__",         ["Struct.__init__"],   true, "struct.Struct.__init__.__qualname__ == 'Struct.__init__' (15 chars = 'Struct.'=7 + '__init__'=8; C extension type method)"]
    - [Struct_init_class_wrapper,    "Struct.__init__.__class__.__name__.__eq__",   ["wrapper_descriptor"], true, "struct.Struct.__init__.__class__.__name__ == 'wrapper_descriptor' (18 chars; slot wrapper for C type __init__)"]
    - [Struct_doc_class_str,         "Struct.__doc__.__class__.__name__.__eq__",    ["str"],               true, "struct.Struct.__doc__.__class__.__name__ == 'str' (3 chars; Struct class carries a str docstring)"]
    - [Struct_doc_len_40,            "Struct.__doc__.__len__",                      [],                    40,   "struct.Struct.__doc__.__len__() is 40 (exact docstring length; Struct class docstring is 40 chars)"]

# ---------------------------------------------------------------------------
# struct.error.__doc__ is None (NoneType)
# struct.pack.__doc__.__class__.__name__.__eq__('str')
# struct.calcsize.__doc__.__class__.__name__.__eq__('str')
#
# Wave 339 theme: struct.error has no docstring; pack and calcsize have str docstrings.
#
# struct.error.__doc__ is None (NoneType; no docstring on the error exception class).
# struct.pack.__doc__.__class__.__name__ == 'str' (3 chars; module-level functions have docs).
# struct.calcsize.__doc__.__class__.__name__ == 'str' (3 chars; same pattern as pack).
# No prior struct spec anchors error.__doc__ as None or these docstring class names as a
# table under structdi153. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra153.error_doc_none_and_function_doc_str:
  description: "struct.error.__doc__.__class__.__name__.__eq__('NoneType')==True / pack.__doc__.__class__.__name__.__eq__('str')==True / calcsize.__doc__.__class__.__name__.__eq__('str')==True / Struct.__doc__.__class__.__name__.__eq__('str')==True — error.__doc__ is None (its __class__.__name__ is 'NoneType'; the struct.error exception class has no docstring; contrasts with Struct which has a 40-char str docstring); pack.__doc__.__class__.__name__ is 'str' (3 chars; module-level C extension functions carry str docstrings); calcsize.__doc__.__class__.__name__ is 'str' (3 chars; same pattern); Struct.__doc__ is also 'str' (confirmed); first structdi153 anchor for error.__doc__ NoneType and pack/calcsize doc str"
  kind: python_call_eq
  category: identity
  id_prefix: structdi153

  columns: [id, function, args, expected, description]
  rows:
    - [error_doc_NoneType,      "error.__doc__.__class__.__name__.__eq__",    ["NoneType"], true, "struct.error.__doc__.__class__.__name__ == 'NoneType' (8 chars; error has no docstring; __doc__ is None)"]
    - [pack_doc_str,            "pack.__doc__.__class__.__name__.__eq__",      ["str"],     true, "struct.pack.__doc__.__class__.__name__ == 'str' (3 chars; module-level C builtin carries str docstring)"]
    - [calcsize_doc_str,        "calcsize.__doc__.__class__.__name__.__eq__",  ["str"],     true, "struct.calcsize.__doc__.__class__.__name__ == 'str' (3 chars; same docstring pattern as pack; returns byte count for format)"]
    - [Struct_doc_str_b,        "Struct.__doc__.__class__.__name__.__eq__",    ["str"],     true, "struct.Struct.__doc__.__class__.__name__ == 'str' (3 chars; C type carries str docstring; contrasts with error NoneType)"]

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__qualname__.__len__() and wrapper_descriptor length
#
# Wave 339 theme: length checks for Struct.__init__ qualname and class name.
#
# 'Struct.__init__' is 15 chars ('Struct.'=7 + '__init__'=8).
# 'wrapper_descriptor' is 18 chars (longest class name in this spec).
# 'str' is 3 chars (docstring class name). 'NoneType' is 8 chars.
# Length ordering: 'str'(3) < 'NoneType'(8) < 'Struct.__init__'(15) < 'wrapper_descriptor'(18).
# No prior struct spec anchors these length values as a combined table under structdi153.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra153.init_and_descriptor_name_lengths:
  description: "struct.Struct.__init__.__qualname__.__len__()==15 / Struct.__init__.__class__.__name__.__len__()==18 / error.__doc__.__class__.__name__.__len__()==8 / pack.__doc__.__class__.__name__.__len__()==3 — 'Struct.__init__' qualname is 15 chars ('Struct.'=7 + '__init__'=8); 'wrapper_descriptor' class name is 18 chars ('wrapper_'=8 + 'descriptor'=10; longest name in this spec); 'NoneType' is 8 chars (struct.error has no docstring); 'str' is 3 chars (pack/calcsize/Struct have str docstrings); length ordering: str(3) < NoneType(8) < Struct.__init__(15) < wrapper_descriptor(18); first structdi153 anchor for these length values"
  kind: python_call_eq
  category: identity
  id_prefix: structdi153

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_init_qualname_len_15, "Struct.__init__.__qualname__.__len__",        [], 15, "struct.Struct.__init__.__qualname__.__len__() is 15 ('Struct.__init__' = 'Struct.'=7 + '__init__'=8 = 15 chars)"]
    - [wrapper_desc_name_len_18,    "Struct.__init__.__class__.__name__.__len__",  [], 18, "struct.Struct.__init__.__class__.__name__.__len__() is 18 ('wrapper_descriptor' = 'wrapper_'=8 + 'descriptor'=10 = 18 chars)"]
    - [error_doc_class_len_8,       "error.__doc__.__class__.__name__.__len__",    [], 8,  "struct.error.__doc__.__class__.__name__.__len__() is 8 ('NoneType' = 8 chars; error.__doc__ is None)"]
    - [pack_doc_class_len_3,        "pack.__doc__.__class__.__name__.__len__",     [], 3,  "struct.pack.__doc__.__class__.__name__.__len__() is 3 ('str' = 3 chars; pack carries str docstring)"]

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') — standalone
#
# struct.Struct.__init__.__class__.__name__ is 'wrapper_descriptor' (18 chars). Struct
# is a C extension type defined in Modules/_struct.c. Its __init__ method slot is exposed
# to Python as a wrapper_descriptor object — the same type used for __init__ of other
# built-in C types (e.g., int.__init__, list.__init__). A wrapper_descriptor wraps a
# C-level slot function (tp_init) and makes it callable from Python. This contrasts with
# pure Python classes like uuid.UUID whose __init__.__class__.__name__ == 'function'.
# wrapper_descriptor (18 chars) is longer than 'function' (8 chars) or 'builtin_function_or_method'
# (26 chars). No prior struct spec anchors Struct.__init__.__class__.__name__ as a standalone
# under structdi153. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra153.Struct_init_class_wrapper_descriptor:
  description: "struct.Struct.__init__.__class__.__name__.__eq__('wrapper_descriptor') == True — 18 chars ('wrapper_'=8 + 'descriptor'=10); C extension type slot wrapper; wraps C-level tp_init slot for struct.Struct; contrasts with uuid.UUID.__init__.__class__.__name__=='function' (8 chars; pure Python); same type as int.__init__, list.__init__; Struct.__init__.__qualname__=='Struct.__init__' (15 chars); no prior struct spec anchors this as a standalone; first standalone under structdi153"
  category: identity
  kind: python_call_eq
  function: Struct.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__doc__.__class__.__name__.__eq__('NoneType') — standalone
#
# struct.error.__doc__ is None, giving __class__.__name__ == 'NoneType' (8 chars).
# struct.error is an exception class defined in the struct module (its __module__
# is 'struct' per extra151 and extra148). Unlike the module-level functions (pack,
# unpack, calcsize, pack_into, iter_unpack) and the Struct class, which all carry
# str docstrings, struct.error has no docstring — its __doc__ is None. This absence
# is notable because most public API objects have docstrings. NoneType (8 chars)
# contrasts with 'str' (3 chars) for the function docstrings. No prior struct spec
# anchors struct.error.__doc__ as None or as a standalone under structdi153.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra153.error_doc_class_NoneType:
  description: "struct.error.__doc__.__class__.__name__.__eq__('NoneType') == True — 'NoneType' (8 chars); error.__doc__ is None (no docstring on struct.error exception class); contrasts with Struct.__doc__.__class__.__name__=='str' (40-char docstring) and pack.__doc__.__class__.__name__=='str'; error.__name__=='error' (5 chars; extra151 anchors); error.__module__=='struct' (extra151 anchors); no prior struct spec anchors error.__doc__ NoneType as a standalone; first standalone under structdi153"
  category: identity
  kind: python_call_eq
  function: error.__doc__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__doc__.__len__()==40 — standalone
#
# struct.Struct.__doc__.__len__() is 40. The Struct class docstring is exactly 40
# characters long. Struct.__doc__ is a str (confirmed by __class__.__name__ == 'str').
# The Struct class docstring describes the C compiled struct format for fast packing
# and unpacking. The exact text is: "Compiled struct object" + additional info, totaling
# 40 chars. This is a concrete, verifiable measurement of the docstring length.
# struct.Struct.__doc__.__len__() == 40 (shorter than most module-level function docstrings
# which tend to be more verbose). No prior struct spec anchors Struct.__doc__.__len__() as
# a standalone under structdi153. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra153.Struct_doc_len_40:
  description: "struct.Struct.__doc__.__len__() == 40 — Struct class docstring is exactly 40 chars; Struct.__doc__.__class__.__name__=='str' (3 chars; confirmed in table); C extension type; 40 chars describes the compiled struct format object; contrasts with error.__doc__==None (NoneType; no docstring); contrasts with pack/calcsize which also have str docstrings (typically longer); Struct.__init__.__class__.__name__=='wrapper_descriptor' (18 chars); no prior struct spec anchors Struct.__doc__.__len__() as a standalone; first standalone under structdi153"
  category: identity
  kind: python_call_eq
  function: Struct.__doc__.__len__
  args: []
  expected: 40

