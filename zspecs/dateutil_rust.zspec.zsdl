spec: dateutil_rust
version: ">=3.9"
backend: rust_module(dateutil_rust)

docs: https://dateutil.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://dateutil.readthedocs.io/en/stable/ — python-dateutil documentation"
  not_derived_from:
    - "dateutil source: dateutil/__init__.py"
  notes:
    - "python-dateutil extends Python's datetime module."
    - "dateutil.parser.parse('2024-01-15').year == 2024."
    - "dateutil.parser.parse('2024-01-15').month == 1."
    - "dateutil.parser.parse('2024-01-15').day == 15."
    - "dateutil.relativedelta.relativedelta(months=1).months == 1."
    - "Expose dateutil_parse_year(s) -> int: dateutil.parser.parse(s).year."
    - "Expose dateutil_parse_month(s) -> int: dateutil.parser.parse(s).month."
    - "Expose dateutil_parse_day(s) -> int: dateutil.parser.parse(s).day."
    - "All test vectors verified against python-dateutil 2.9.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# dateutil_parse_year — parsed year
table dateutil_rust.parse.year:
  kind: python_call_eq
  category: year
  id_prefix: du_y
  function: dateutil_parse_year

  columns: [id, args, expected]
  rows:
    - [y2024, ["2024-01-15"], 2024]
    - [y2000, ["2000-06-01"], 2000]

# dateutil_parse_month — parsed month
table dateutil_rust.parse.month:
  kind: python_call_eq
  category: month
  id_prefix: du_m
  function: dateutil_parse_month

  columns: [id, args, expected]
  rows:
    - [jan,  ["2024-01-15"], 1]
    - [june, ["2000-06-01"], 6]

# dateutil_parse_day — parsed day
table dateutil_rust.parse.day:
  kind: python_call_eq
  category: day
  id_prefix: du_d
  function: dateutil_parse_day

  columns: [id, args, expected]
  rows:
    - [fifteen, ["2024-01-15"], 15]
    - [first,   ["2000-06-01"],  1]

