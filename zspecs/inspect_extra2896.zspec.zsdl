spec: in2896
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 640 (in2896): __itruediv__, __ifloordiv__, __imod__ dict-presence checks for inspect types."
    - "inspect types are introspection helpers — none define in-place true-divide, floor-divide, or modulo operators."
    - "Verified types: inspect.Parameter, inspect.BoundArguments, inspect.Signature, inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, inspect.ClosureVars."
    - "inspect.FullArgSpec, inspect.FrameInfo, inspect.ArgInfo, inspect.Traceback, and inspect.ClosureVars are namedtuple subclasses."
    - "inspect.Parameter, inspect.BoundArguments, and inspect.Signature are pure Python classes."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in2896.itruediv:
  description: "inspect types __itruediv__ dict-presence checks; wave 640"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2896
  columns: [id, function, args, expected]
  rows:
    - ["in2896001", operator.contains, [inspect.Parameter.__dict__,       "__itruediv__"], false]
    - ["in2896002", operator.contains, [inspect.BoundArguments.__dict__,  "__itruediv__"], false]
    - ["in2896003", operator.contains, [inspect.Signature.__dict__,       "__itruediv__"], false]
