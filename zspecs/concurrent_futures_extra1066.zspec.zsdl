spec: concurrent_futures_extra1066
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures Future, Executor, and wait documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks concurrent.futures.Future add_done_callback/set_result/set_exception qualnames, Executor class module identity, wait/as_completed function module — behaviors not covered by extra1036 or extra1051"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra1066.future_mutation_qualnames:
  description: "concurrent.futures.Future add_done_callback, set_result, set_exception __qualname__ identity"
  kind: python_call_eq
  category: future_method_qualnames
  id_prefix: cf1066fm
  columns: [id, function, args, expected]
  rows:
    - [cf1066fm001, concurrent.futures.Future.add_done_callback.__qualname__.__eq__, ["Future.add_done_callback"], true]
    - [cf1066fm002, concurrent.futures.Future.set_result.__qualname__.__eq__,        ["Future.set_result"],        true]
    - [cf1066fm003, concurrent.futures.Future.set_exception.__qualname__.__eq__,     ["Future.set_exception"],     true]
    - [cf1066fm004, concurrent.futures.Future.set_running_or_notify_cancel.__qualname__.__eq__, ["Future.set_running_or_notify_cancel"], true]
    - [cf1066fm005, concurrent.futures.Future.__init__.__qualname__.__eq__,          ["Future.__init__"],          true]
    - [cf1066fm006, concurrent.futures.Future.add_done_callback.__class__.__name__.__eq__, ["function"],           true]
    - [cf1066fm007, concurrent.futures.Future.set_result.__class__.__name__.__eq__,  ["function"],                 true]

table concurrent_futures_extra1066.executor_class_module:
  description: "concurrent.futures Executor base class module and qualname identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: cf1066ec
  columns: [id, function, args, expected]
  rows:
    - [cf1066ec001, concurrent.futures.Executor.__module__.__eq__,                      ["concurrent.futures._base"], true]
    - [cf1066ec002, concurrent.futures.Executor.__qualname__.__eq__,                    ["Executor"],                 true]
    - [cf1066ec003, concurrent.futures.Executor.__name__.__eq__,                        ["Executor"],                 true]
    - [cf1066ec004, concurrent.futures.Executor.submit.__qualname__.__eq__,             ["Executor.submit"],          true]
    - [cf1066ec005, concurrent.futures.Executor.map.__qualname__.__eq__,                ["Executor.map"],             true]
    - [cf1066ec006, concurrent.futures.Executor.shutdown.__qualname__.__eq__,           ["Executor.shutdown"],        true]
    - [cf1066ec007, concurrent.futures.ProcessPoolExecutor.__module__.__eq__,           ["concurrent.futures.process"], true]

table concurrent_futures_extra1066.wait_and_as_completed_identity:
  description: "concurrent.futures.wait and as_completed function module and class identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: cf1066wc
  columns: [id, function, args, expected]
  rows:
    - [cf1066wc001, concurrent.futures.wait.__module__.__eq__,             ["concurrent.futures._base"], true]
    - [cf1066wc002, concurrent.futures.wait.__qualname__.__eq__,           ["wait"],                     true]
    - [cf1066wc003, concurrent.futures.wait.__class__.__name__.__eq__,     ["function"],                 true]
    - [cf1066wc004, concurrent.futures.as_completed.__module__.__eq__,     ["concurrent.futures._base"], true]
    - [cf1066wc005, concurrent.futures.as_completed.__qualname__.__eq__,   ["as_completed"],             true]
    - [cf1066wc006, concurrent.futures.as_completed.__class__.__name__.__eq__, ["function"],             true]
    - [cf1066wc007, concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__, ["str"],               true]
