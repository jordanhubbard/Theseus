spec: pytest_extra_rust
version: ">=3.9"
backend: rust_module(pytest_extra_rust)

docs: https://docs.pytest.org/en/stable/reference/

provenance:
  derived_from:
    - "https://docs.pytest.org/en/stable/reference/ — pytest reference"
  not_derived_from:
    - "pytest source: src/_pytest/__init__.py"
  notes:
    - "pytest is the Python testing framework."
    - "pytest.__version__ is a non-empty string."
    - "pytest.raises is available."
    - "pytest.approx(0.1 + 0.2) == 0.3 — approximate equality."
    - "pytest.approx(1.0) == 1.0."
    - "Expose pytest_approx_eq(a, b) -> bool: pytest.approx(a) == b."
    - "Expose pytest_version_nonempty() -> bool: len(pytest.__version__) > 0."
    - "Expose pytest_has_raises() -> bool: hasattr(pytest, 'raises')."
    - "All test vectors verified against pytest 8.3.5."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# pytest_approx_eq — approximate equality
table pytest_extra_rust.approx.equal:
  kind: python_call_eq
  category: approx
  id_prefix: pt_ap
  function: pytest_approx_eq

  columns: [id, args, expected]
  rows:
    - [one,     [1.0, 1.0],    true]
    - [pi,      [3.14, 3.14],  true]
    - [differ,  [1.0, 2.0],    false]

# pytest_version_nonempty — version non-empty
invariant pytest_extra_rust.version.nonempty:
  description: "pytest.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pytest_version_nonempty
  args: []
  expected: true

# pytest_has_raises — raises present
invariant pytest_extra_rust.module.has_raises:
  description: "pytest.raises is available"
  category: module
  kind: python_call_eq
  function: pytest_has_raises
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:09:51Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
