spec: itertools_extra217
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools class __name__ length checks and __doc__ word presence checks (wave 383)."
    - "combinations_with_replacement.__name__ == 'combinations_with_replacement', len == 29. Verified with Python 3.14.3."
    - "combinations.__name__ len == 12; permutations.__name__ len == 12; filterfalse.__name__ len == 11; zip_longest.__name__ len == 11. Verified with Python 3.14.3."
    - "accumulate doc contains 'accumulated', 'sums', 'binary'. Verified with Python 3.14.3."
    - "starmap doc contains 'argument', 'tuple'. Verified with Python 3.14.3."
    - "dropwhile doc contains 'Drop', 'predicate'. Verified with Python 3.14.3."
    - "pairwise doc contains 'overlapping', 'pairs'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools class __name__ length checks
#
# itertools types are C-implemented classes; their __name__ attribute is
# the same as their name in the module namespace. The lengths are fixed and
# form meaningful invariants about the API surface.
#
# Verified with Python 3.14.3:
#   combinations_with_replacement.__name__ len == 29
#   combinations.__name__ len == 12
#   permutations.__name__ len == 12
#   filterfalse.__name__ len == 11
#   zip_longest.__name__ len == 11
#   accumulate.__name__ len == 10
#   dropwhile.__name__ len == 9
#   takewhile.__name__ len == 9
#   pairwise.__name__ len == 8
# ---------------------------------------------------------------------------

table itertools_extra217.name_lengths:
  description: "itertools class __name__ length checks; wave 383; new to extra217"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra217namelen

  columns: [id, function, args, expected, description]
  rows:
    - [combinations_with_replacement_name_len_29,
       "combinations_with_replacement.__name__.__len__",
       [],
       29,
       "itertools.combinations_with_replacement.__name__.__len__() == 29 — 'combinations_with_replacement' is the longest name in itertools at 29 characters; str.__len__() returns 29; new to extra217"]
    - [combinations_name_len_12,
       combinations.__name__.__len__,
       [],
       12,
       "itertools.combinations.__name__.__len__() == 12 — 'combinations' has 12 characters; str.__len__() returns 12; new to extra217"]
    - [permutations_name_len_12,
       permutations.__name__.__len__,
       [],
       12,
       "itertools.permutations.__name__.__len__() == 12 — 'permutations' has 12 characters matching the length of 'combinations'; str.__len__() returns 12; new to extra217"]
    - [filterfalse_name_len_11,
       filterfalse.__name__.__len__,
       [],
       11,
       "itertools.filterfalse.__name__.__len__() == 11 — 'filterfalse' has 11 characters; str.__len__() returns 11; new to extra217"]
    - [zip_longest_name_len_11,
       zip_longest.__name__.__len__,
       [],
       11,
       "itertools.zip_longest.__name__.__len__() == 11 — 'zip_longest' has 11 characters matching the length of 'filterfalse'; str.__len__() returns 11; new to extra217"]
    - [accumulate_name_len_10,
       accumulate.__name__.__len__,
       [],
       10,
       "itertools.accumulate.__name__.__len__() == 10 — 'accumulate' has 10 characters; str.__len__() returns 10; new to extra217"]
    - [dropwhile_name_len_9,
       dropwhile.__name__.__len__,
       [],
       9,
       "itertools.dropwhile.__name__.__len__() == 9 — 'dropwhile' has 9 characters; str.__len__() returns 9; new to extra217"]
    - [takewhile_name_len_9,
       takewhile.__name__.__len__,
       [],
       9,
       "itertools.takewhile.__name__.__len__() == 9 — 'takewhile' has 9 characters matching the length of 'dropwhile'; both are predicate-based filtering iterators; str.__len__() returns 9; new to extra217"]
    - [pairwise_name_len_8,
       pairwise.__name__.__len__,
       [],
       8,
       "itertools.pairwise.__name__.__len__() == 8 — 'pairwise' has 8 characters; str.__len__() returns 8; new to extra217"]

# ---------------------------------------------------------------------------
# Table 2: itertools.accumulate __doc__ word presence
#
# itertools.accumulate.__doc__ starts with:
#   "Return series of accumulated sums (or other binary function results)."
#
# Verified with Python 3.14.3:
#   doc.__contains__('Return') == True
#   doc.__contains__('accumulated') == True
#   doc.__contains__('sums') == True
#   doc.__contains__('binary') == True
# ---------------------------------------------------------------------------

table itertools_extra217.accumulate_doc_words:
  description: "itertools.accumulate.__doc__ contains 'Return', 'accumulated', 'sums', 'binary'; wave 383; new to extra217"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra217accumdoc

  columns: [id, function, args, expected, description]
  rows:
    - [accumulate_doc_contains_Return,
       accumulate.__doc__.__contains__,
       ["Return"],
       true,
       "itertools.accumulate.__doc__.__contains__('Return') == True — the docstring begins with 'Return series of accumulated sums'; 'Return' is the first word; str.__contains__ returns True; new to extra217"]
    - [accumulate_doc_contains_accumulated,
       accumulate.__doc__.__contains__,
       ["accumulated"],
       true,
       "itertools.accumulate.__doc__.__contains__('accumulated') == True — the word 'accumulated' appears in 'Return series of accumulated sums'; it directly describes what the function computes; str.__contains__ returns True; new to extra217"]
    - [accumulate_doc_contains_sums,
       accumulate.__doc__.__contains__,
       ["sums"],
       true,
       "itertools.accumulate.__doc__.__contains__('sums') == True — 'sums' appears in the docstring describing the default operation (addition); str.__contains__ returns True; new to extra217"]
    - [accumulate_doc_contains_binary,
       accumulate.__doc__.__contains__,
       ["binary"],
       true,
       "itertools.accumulate.__doc__.__contains__('binary') == True — 'binary' appears in '(or other binary function results)' indicating the general two-argument function support; str.__contains__ returns True; new to extra217"]

# ---------------------------------------------------------------------------
# Table 3: itertools.starmap __doc__ word presence
#
# itertools.starmap.__doc__ starts with:
#   "Return an iterator whose values are returned from the function evaluated
#    with an argument tuple taken from the given sequence."
#
# Verified with Python 3.14.3:
#   doc.__contains__('Return') == True
#   doc.__contains__('argument') == True
#   doc.__contains__('tuple') == True
# ---------------------------------------------------------------------------

table itertools_extra217.starmap_doc_words:
  description: "itertools.starmap.__doc__ contains 'Return', 'argument', 'tuple'; wave 383; new to extra217"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra217starmapdoc

  columns: [id, function, args, expected, description]
  rows:
    - [starmap_doc_contains_Return,
       starmap.__doc__.__contains__,
       ["Return"],
       true,
       "itertools.starmap.__doc__.__contains__('Return') == True — the docstring begins with 'Return an iterator'; 'Return' is the first word; str.__contains__ returns True; new to extra217"]
    - [starmap_doc_contains_argument,
       starmap.__doc__.__contains__,
       ["argument"],
       true,
       "itertools.starmap.__doc__.__contains__('argument') == True — 'argument' appears in 'evaluated with an argument tuple'; this distinguishes starmap from map (it unpacks tuple args); str.__contains__ returns True; new to extra217"]
    - [starmap_doc_contains_tuple,
       starmap.__doc__.__contains__,
       ["tuple"],
       true,
       "itertools.starmap.__doc__.__contains__('tuple') == True — 'tuple' appears in 'argument tuple taken from the given sequence'; starmap applies a function to each tuple of arguments in the iterable; str.__contains__ returns True; new to extra217"]

# ---------------------------------------------------------------------------
# Table 4: itertools.dropwhile and itertools.pairwise __doc__ word presence
#
# itertools.dropwhile.__doc__ starts with:
#   "Drop items from the iterable while predicate(item) is true."
# itertools.pairwise.__doc__ starts with:
#   "Return an iterator of overlapping pairs taken from the input iterator."
#
# Verified with Python 3.14.3:
#   dropwhile doc.__contains__('Drop') == True
#   dropwhile doc.__contains__('predicate') == True
#   pairwise doc.__contains__('overlapping') == True
#   pairwise doc.__contains__('pairs') == True
# ---------------------------------------------------------------------------

table itertools_extra217.dropwhile_pairwise_doc_words:
  description: "itertools.dropwhile doc contains 'Drop','predicate'; pairwise doc contains 'overlapping','pairs'; wave 383; new to extra217"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra217docwords

  columns: [id, function, args, expected, description]
  rows:
    - [dropwhile_doc_contains_Drop,
       dropwhile.__doc__.__contains__,
       ["Drop"],
       true,
       "itertools.dropwhile.__doc__.__contains__('Drop') == True — the docstring begins with 'Drop items from the iterable while predicate(item) is true'; 'Drop' is the first word describing the skip-until behavior; str.__contains__ returns True; new to extra217"]
    - [dropwhile_doc_contains_predicate,
       dropwhile.__doc__.__contains__,
       ["predicate"],
       true,
       "itertools.dropwhile.__doc__.__contains__('predicate') == True — 'predicate' appears in 'while predicate(item) is true'; the predicate controls which leading items are dropped; str.__contains__ returns True; new to extra217"]
    - [pairwise_doc_contains_overlapping,
       pairwise.__doc__.__contains__,
       ["overlapping"],
       true,
       "itertools.pairwise.__doc__.__contains__('overlapping') == True — the docstring reads 'Return an iterator of overlapping pairs'; 'overlapping' precisely describes how consecutive elements share a common element (s0,s1),(s1,s2); str.__contains__ returns True; new to extra217"]
    - [pairwise_doc_contains_pairs,
       pairwise.__doc__.__contains__,
       ["pairs"],
       true,
       "itertools.pairwise.__doc__.__contains__('pairs') == True — 'pairs' appears in 'Return an iterator of overlapping pairs'; it directly names the output type; str.__contains__ returns True; new to extra217"]

