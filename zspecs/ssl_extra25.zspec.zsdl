spec: ssl_extra25
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "ssl_extra24.zspec.zsdl — covers SSLContext.verify_mode class type; SSLError.__bases__[0].__name__; CertificateError.__qualname__; SSLWantReadError/WriteError/Object qualnames."
    - "ssl_extra23.zspec.zsdl — covers SSLContext.wrap_socket/load_cert_chain/set_ciphers __qualname__; SSLSocket.read.__qualname__; SSLError.__module__; PROTOCOL_TLS_CLIENT class name."
    - "ssl_extra22.zspec.zsdl — covers VerifyMode enum member __class__.__qualname__; PROTOCOL_TLS_CLIENT.__class__.__qualname__; VerifyMode.__qualname__.__len__; SSLCertVerificationError.__qualname__ standalone."
    - "ssl_extra9.zspec.zsdl — covers SSLWantReadError/__qualname__; SSLWantWriteError/__qualname__; SSLObject/__qualname__."
    - "ssl_extra8.zspec.zsdl — covers SSLContext/SSLSocket/SSLError/create_default_context __qualname__ table; SSLCertVerificationError/__qualname__; SSLZeroReturnError/__qualname__."
    - "ssl.zspec.zsdl — covers SSLError.__bases__[0].__name__ == 'OSError'; SSLError/__module__; class names."
  notes:
    - "This spec extends ssl through ssl_extra24; it does NOT duplicate invariants present in those files."
    - "Focus: ssl.Purpose/__qualname__/__module__; ssl.AlertDescription/__qualname__/__module__; Purpose/__class__.__name__; AlertDescription/__class__.__name__; VerifyMode/__class__.__name__; SSLCertVerificationError/__bases__[0].__name__; CertificateError/__bases__[0].__name__."
    - "ssl.Purpose.__qualname__ == 'Purpose': ssl_extra22 covers VerifyMode.__qualname__.__len__; ssl_extra8 covers SSLContext/SSLSocket/SSLError class qualnames. No prior spec covers Purpose.__qualname__.__eq__ as a standalone invariant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.AlertDescription.__qualname__ == 'AlertDescription': No prior spec covers AlertDescription.__qualname__.__eq__. ssl_extra8 covers SSLError/SSLContext/SSLSocket qualnames but not AlertDescription. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.Purpose.__module__ == 'ssl' and ssl.AlertDescription.__module__ == 'ssl': No prior spec checks __module__ for Purpose or AlertDescription. ssl_extra23 covers SSLError.__module__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.Purpose.__class__.__name__ == 'EnumType': Purpose is an enum metaclass. No prior spec checks __class__.__name__ for Purpose (only VerifyMode member's __class__.__qualname__ in extra22). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.AlertDescription.__class__.__name__ == 'EnumType': AlertDescription is an enum. No prior spec checks its metaclass __name__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.VerifyMode.__class__.__name__ == 'EnumType': ssl_extra22 covers VerifyMode member __class__.__qualname__; no prior spec checks VerifyMode's own __class__.__name__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLCertVerificationError.__bases__[0].__name__ == 'SSLError': SSLCertVerificationError inherits from SSLError. ssl.zspec covers SSLError.__bases__[0].__name__ == 'OSError'; no prior spec covers SSLCertVerificationError.__bases__[0].__name__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.CertificateError.__bases__[0].__name__ == 'SSLError': CertificateError is an alias for SSLCertVerificationError; shares the same base. ssl_extra24 covers CertificateError.__qualname__; no prior spec covers CertificateError.__bases__[0].__name__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ssl.Purpose.__qualname__ and __module__
#
# ssl_extra22 covers VerifyMode.__qualname__.__len__; no prior spec covers
# Purpose.__qualname__.__eq__ as a standalone invariant.
# ssl.Purpose.__qualname__ == 'Purpose'; ssl.Purpose.__module__ == 'ssl'.
# ---------------------------------------------------------------------------

invariant ssl_extra25.Purpose.qualname:
  description: "ssl.Purpose.__qualname__ == 'Purpose' — TLS purpose enum qualname"
  category: function_qualnames
  kind: python_call_eq
  function: Purpose.__qualname__.__eq__
  args: ["Purpose"]
  expected: true

invariant ssl_extra25.Purpose.module:
  description: "ssl.Purpose.__module__ == 'ssl' — TLS purpose enum defined in ssl module"
  category: module_metadata
  kind: python_call_eq
  function: Purpose.__module__.__eq__
  args: ["ssl"]
  expected: true

# ---------------------------------------------------------------------------
# ssl.AlertDescription.__qualname__ and __module__
#
# No prior spec covers AlertDescription.__qualname__ or __module__.
# ssl.AlertDescription.__qualname__ == 'AlertDescription';
# ssl.AlertDescription.__module__ == 'ssl'.
# ---------------------------------------------------------------------------

invariant ssl_extra25.AlertDescription.qualname:
  description: "ssl.AlertDescription.__qualname__ == 'AlertDescription' — TLS alert description enum qualname"
  category: function_qualnames
  kind: python_call_eq
  function: AlertDescription.__qualname__.__eq__
  args: ["AlertDescription"]
  expected: true

invariant ssl_extra25.AlertDescription.module:
  description: "ssl.AlertDescription.__module__ == 'ssl' — alert description enum defined in ssl module"
  category: module_metadata
  kind: python_call_eq
  function: AlertDescription.__module__.__eq__
  args: ["ssl"]
  expected: true

# ---------------------------------------------------------------------------
# Enum metaclass __class__.__name__ — Purpose, AlertDescription, VerifyMode
#
# ssl_extra22 covers VerifyMode member (enum instance) __class__.__qualname__.
# No prior spec checks the __class__.__name__ of the enum classes themselves.
# On Python 3.12, all three use EnumType as their metaclass.
# ---------------------------------------------------------------------------

table ssl_extra25.enum_class_metaclass_names:
  description: "ssl enum classes have __class__.__name__ == 'EnumType'"
  kind: python_call_eq
  category: type_metadata
  id_prefix: sslecmn25

  columns: [id, function, args, expected]
  rows:
    - [Purpose,           Purpose.__class__.__name__.__eq__,          ["EnumType"], true]
    - [AlertDescription,  AlertDescription.__class__.__name__.__eq__,  ["EnumType"], true]
    - [VerifyMode,        VerifyMode.__class__.__name__.__eq__,        ["EnumType"], true]

# ---------------------------------------------------------------------------
# SSLCertVerificationError and CertificateError base class name
#
# ssl.zspec covers SSLError.__bases__[0].__name__ == 'OSError'.
# ssl_extra24 covers CertificateError.__qualname__ (alias identity).
# No prior spec checks __bases__[0].__name__ for SSLCertVerificationError
# or CertificateError. Both inherit from SSLError.
# ---------------------------------------------------------------------------

invariant ssl_extra25.SSLCertVerificationError.base_name:
  description: "ssl.SSLCertVerificationError.__bases__[0].__name__ == 'SSLError' — inherits from SSLError"
  category: type_metadata
  kind: python_call_eq
  function: "SSLCertVerificationError.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["SSLError"]
  expected: true

invariant ssl_extra25.CertificateError.base_name:
  description: "ssl.CertificateError.__bases__[0].__name__ == 'SSLError' — alias also inherits from SSLError"
  category: type_metadata
  kind: python_call_eq
  function: "CertificateError.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["SSLError"]
  expected: true
