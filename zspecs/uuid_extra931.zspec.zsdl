spec: uuid_extra931
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks __doc__.__class__.__name__ for uuid functions and classes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra931.uuid_class_doc_class:
  description: "uuid.UUID and uuid.SafeUUID __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: doc_class_name
  id_prefix: uu931c
  columns: [id, function, args, expected]
  rows:
    - [uu931c001, uuid.UUID.__doc__.__class__.__name__.__eq__,     ["str"], true]
    - [uu931c002, uuid.SafeUUID.__doc__.__class__.__name__.__eq__, ["str"], true]

table uuid_extra931.uuid_functions_doc_class:
  description: "uuid factory function __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: doc_class_name
  id_prefix: uu931f
  columns: [id, function, args, expected]
  rows:
    - [uu931f001, uuid.uuid1.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu931f002, uuid.uuid3.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu931f003, uuid.uuid4.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [uu931f004, uuid.uuid5.__doc__.__class__.__name__.__eq__, ["str"], true]

table uuid_extra931.uuid_module_attrs_doc_class:
  description: "uuid module-level namespace attributes doc class"
  kind: python_call_eq
  category: doc_class_name
  id_prefix: uu931a
  columns: [id, function, args, expected]
  rows:
    - [uu931a001, uuid.NAMESPACE_DNS.__class__.__name__.__eq__,  ["UUID"], true]
    - [uu931a002, uuid.NAMESPACE_URL.__class__.__name__.__eq__,  ["UUID"], true]
    - [uu931a003, uuid.NAMESPACE_OID.__class__.__name__.__eq__,  ["UUID"], true]
    - [uu931a004, uuid.NAMESPACE_X500.__class__.__name__.__eq__, ["UUID"], true]

table uuid_extra931.uuid_doc_nonempty:
  description: "uuid __doc__ strings are non-empty"
  kind: python_call_eq
  category: doc_nonempty
  id_prefix: uu931n
  columns: [id, function, args, expected]
  rows:
    - [uu931n001, uuid.UUID.__doc__.__len__.__gt__,     [0], true]
    - [uu931n002, uuid.uuid1.__doc__.__len__.__gt__,    [0], true]
    - [uu931n003, uuid.uuid3.__doc__.__len__.__gt__,    [0], true]
    - [uu931n004, uuid.uuid4.__doc__.__len__.__gt__,    [0], true]
    - [uu931n005, uuid.uuid5.__doc__.__len__.__gt__,    [0], true]
    - [uu931n006, uuid.SafeUUID.__doc__.__len__.__gt__, [0], true]
