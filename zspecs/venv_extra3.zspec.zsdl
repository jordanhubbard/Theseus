spec: venv_extra3
version: ">=3.9"
backend: python_module(venv)

docs: https://docs.python.org/3/library/venv.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/venv.html — Python venv module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/venv/__init__.py"
  notes:
    - "This spec extends venv.zspec.zsdl, venv_extra.zspec.zsdl, and venv_extra2.zspec.zsdl."
    - "venv_extra covered: EnvBuilder.__name__, EnvBuilder.__module__, EnvBuilder.__bases__[0].__name__, create.__name__, EnvBuilder.__qualname__, create.__qualname__, and EnvBuilder method __name__ table."
    - "venv_extra2 covered: EnvBuilder method __name__ invariants (create, setup_scripts, setup_python, post_setup, install_scripts, clear_directory), EnvBuilder.__init__.__module__, method type table, method qualname table."
    - "This spec adds: create.__module__ == 'venv' (not in any prior spec), EnvBuilder.__init__.__qualname__ == 'EnvBuilder.__init__' (not in any prior spec), a class_names table (EnvBuilder), and a method_modules table for key EnvBuilder methods."
    - "venv.create is a module-level convenience function: create.__module__ == 'venv'."
    - "EnvBuilder.__init__.__qualname__ == 'EnvBuilder.__init__' — dotted qualname for a method defined inside a class body."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# create — __module__ attribute (not covered in venv_extra or venv_extra2)
# ---------------------------------------------------------------------------

invariant venv_extra3.create.module:
  description: "venv.create.__module__ == 'venv' — the convenience function is defined in the venv module"
  category: module
  kind: python_call_eq
  function: create.__module__.__eq__
  args: ["venv"]
  expected: true

# ---------------------------------------------------------------------------
# EnvBuilder.__init__ — __qualname__ (not covered in venv_extra or venv_extra2)
# venv_extra2 covered __module__ of __init__; this adds __qualname__.
# ---------------------------------------------------------------------------

invariant venv_extra3.EnvBuilder.init_qualname:
  description: "venv.EnvBuilder.__init__.__qualname__ == 'EnvBuilder.__init__' — dotted qualname for a class method"
  category: qualnames
  kind: python_call_eq
  function: EnvBuilder.__init__.__qualname__.__eq__
  args: ["EnvBuilder.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# class_names table — EnvBuilder via __name__.__eq__ (table form, new angle)
# Prior specs used invariant blocks; this spec uses a table with id_prefix.
# ---------------------------------------------------------------------------

table venv_extra3.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [EnvBuilder, EnvBuilder.__name__.__eq__, ["EnvBuilder"], true]

# ---------------------------------------------------------------------------
# method_modules table — __module__ for key EnvBuilder unbound methods
# venv_extra2 covered __name__ and __qualname__; here we add __module__.
# ---------------------------------------------------------------------------

table venv_extra3.EnvBuilder.method_modules:
  kind: python_call_eq
  category: method_modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [create,        EnvBuilder.create.__module__.__eq__,        ["venv"], true]
    - [setup_python,  EnvBuilder.setup_python.__module__.__eq__,  ["venv"], true]
    - [setup_scripts, EnvBuilder.setup_scripts.__module__.__eq__, ["venv"], true]
    - [post_setup,    EnvBuilder.post_setup.__module__.__eq__,    ["venv"], true]
