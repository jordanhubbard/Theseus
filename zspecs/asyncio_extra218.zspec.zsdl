spec: asyncio_extra218
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queue"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "asyncio.Queue.__module__ == 'asyncio.queues'; its methods have qualnames like 'Queue.put'."
    - "asyncio.Lock.__module__ == 'asyncio.locks'; acquire/release/locked all belong to Lock."
    - "asyncio.Event.__module__ == 'asyncio.locks'; set/clear/wait/is_set all belong to Event."
    - "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' on Python 3.14."
    - "verified with Python 3.14.3."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue method __name__ checks — extra218 namespace
#
# Queue exposes put, get, put_nowait, get_nowait, empty, full, qsize, join,
# and task_done as its primary public interface.
# ---------------------------------------------------------------------------

table asyncio_extra218.queue_method_names:
  description: "asyncio.Queue method __name__ checks in extra218 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio218qname

  columns: [id, function, args, expected, description]
  rows:
    - [put_name,        Queue.put.__name__.__eq__,        ["put"],        true, "Queue.put.__name__ == 'put'"]
    - [get_name,        Queue.get.__name__.__eq__,        ["get"],        true, "Queue.get.__name__ == 'get'"]
    - [put_nowait_name, Queue.put_nowait.__name__.__eq__, ["put_nowait"], true, "Queue.put_nowait.__name__ == 'put_nowait'"]
    - [get_nowait_name, Queue.get_nowait.__name__.__eq__, ["get_nowait"], true, "Queue.get_nowait.__name__ == 'get_nowait'"]
    - [empty_name,      Queue.empty.__name__.__eq__,      ["empty"],      true, "Queue.empty.__name__ == 'empty'"]
    - [full_name,       Queue.full.__name__.__eq__,       ["full"],       true, "Queue.full.__name__ == 'full'"]
    - [qsize_name,      Queue.qsize.__name__.__eq__,      ["qsize"],      true, "Queue.qsize.__name__ == 'qsize'"]
    - [join_name,       Queue.join.__name__.__eq__,       ["join"],       true, "Queue.join.__name__ == 'join'"]
    - [task_done_name,  Queue.task_done.__name__.__eq__,  ["task_done"],  true, "Queue.task_done.__name__ == 'task_done'"]

# ---------------------------------------------------------------------------
# asyncio.Queue method __qualname__ checks — extra218 namespace
# ---------------------------------------------------------------------------

table asyncio_extra218.queue_method_qualnames:
  description: "asyncio.Queue method __qualname__ checks in extra218 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio218qqualname

  columns: [id, function, args, expected, description]
  rows:
    - [put_qualname,        Queue.put.__qualname__.__eq__,        ["Queue.put"],        true, "Queue.put.__qualname__ == 'Queue.put'"]
    - [get_qualname,        Queue.get.__qualname__.__eq__,        ["Queue.get"],        true, "Queue.get.__qualname__ == 'Queue.get'"]
    - [put_nowait_qualname, Queue.put_nowait.__qualname__.__eq__, ["Queue.put_nowait"], true, "Queue.put_nowait.__qualname__ == 'Queue.put_nowait'"]
    - [get_nowait_qualname, Queue.get_nowait.__qualname__.__eq__, ["Queue.get_nowait"], true, "Queue.get_nowait.__qualname__ == 'Queue.get_nowait'"]
    - [empty_qualname,      Queue.empty.__qualname__.__eq__,      ["Queue.empty"],      true, "Queue.empty.__qualname__ == 'Queue.empty'"]
    - [full_qualname,       Queue.full.__qualname__.__eq__,       ["Queue.full"],       true, "Queue.full.__qualname__ == 'Queue.full'"]
    - [qsize_qualname,      Queue.qsize.__qualname__.__eq__,      ["Queue.qsize"],      true, "Queue.qsize.__qualname__ == 'Queue.qsize'"]
    - [join_qualname,       Queue.join.__qualname__.__eq__,       ["Queue.join"],       true, "Queue.join.__qualname__ == 'Queue.join'"]
    - [task_done_qualname,  Queue.task_done.__qualname__.__eq__,  ["Queue.task_done"],  true, "Queue.task_done.__qualname__ == 'Queue.task_done'"]

# ---------------------------------------------------------------------------
# asyncio.Queue class identity — extra218 namespace
# ---------------------------------------------------------------------------

table asyncio_extra218.queue_class_identity:
  description: "asyncio.Queue class __name__ and __module__ checks in extra218 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio218qident

  columns: [id, function, args, expected, description]
  rows:
    - [queue_name,   Queue.__name__.__eq__,   ["Queue"],          true, "asyncio.Queue.__name__ == 'Queue'"]
    - [queue_module, Queue.__module__.__eq__, ["asyncio.queues"], true, "asyncio.Queue.__module__ == 'asyncio.queues'"]

