# ---------------------------------------------------------------------------
# asyncio.Queue.put __name__ standalone — extra218 namespace
# ---------------------------------------------------------------------------

invariant asyncio_extra218.queue_put_name:
  description: "asyncio.Queue.put.__name__ == 'put'"
  category: identity
  kind: python_call_eq
  function: asyncio.Queue.put.__name__.__eq__
  args: ["put"]
  expected: true

