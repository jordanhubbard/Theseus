spec: functools_extra2536
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: __format__, __bytes__, and __fspath__ dict-presence checks for functools classes."
    - "Theme: custom formatting, bytes conversion, and filesystem path protocol dict-presence — checking whether classes define __format__, __bytes__, or __fspath__ in their class __dict__."
    - "functools.partial is a C extension type that wraps a callable with pre-applied positional and keyword arguments; it has no custom format specification, no bytes representation, and no filesystem path semantics. Verified with Python 3.14."
    - "functools.partialmethod is a pure-Python descriptor for use inside class bodies; it partially applies arguments to methods but itself defines no __format__, __bytes__, or __fspath__. Verified with Python 3.14."
    - "functools.cached_property is a pure-Python non-data descriptor that caches a computed value in the instance __dict__ on first access; it is a caching mechanism with no formatting, bytes-conversion, or path protocol. Verified with Python 3.14."
    - "functools.singledispatchmethod is a pure-Python descriptor that dispatches method calls based on the first non-self argument type; its class __dict__ defines no __format__, __bytes__, or __fspath__. Verified with Python 3.14."
    - "functools.singledispatch (the function-level decorator variant) wraps a callable for type-based dispatch; its underlying wrapper class defines no formatting, bytes, or path protocol. Verified with Python 3.14."
    - "functools.lru_cache is a callable wrapper providing bounded memoization; it has no string-formatting customisation, no bytes conversion, and no filesystem path role. Verified with Python 3.14."
    - "functools.itemgetter is a C extension type that retrieves items via __getitem__; it is a retrieval utility with no format, bytes, or path protocol in its class __dict__. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial — format/bytes/fspath protocol absence
#
# Theme: __format__, __bytes__, __fspath__ absent from functools.partial.__dict__.
# partial is a C extension type wrapping a callable; it carries no custom
# format specification, no bytes-conversion protocol, and no filesystem
# path semantics — it is a callable adapter, not a data representation type.
# ---------------------------------------------------------------------------

table functools_extra2536.partial_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from functools.partial.__dict__; wave 2536"
  kind: python_call_eq
  category: format_bytes_fspath
  id_prefix: ft2536

  columns: [id, function, args, expected]
  rows:
    - ["ft2536-001", "partial.__dict__.__contains__", ["__format__"], false]
    - ["ft2536-002", "partial.__dict__.__contains__", ["__bytes__"], false]
    - ["ft2536-003", "partial.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 2: functools.partialmethod — format/bytes/fspath protocol absence
#
# Theme: __format__, __bytes__, __fspath__ absent from functools.partialmethod.__dict__.
# partialmethod is a pure-Python descriptor used inside class definitions to
# pre-fill arguments on methods; it is a descriptor utility with no string
# formatting, bytes conversion, or filesystem path protocol of its own.
# ---------------------------------------------------------------------------

table functools_extra2536.partialmethod_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from functools.partialmethod.__dict__; wave 2536"
