    - ["ft2536-005", "partialmethod.__dict__.__contains__", ["__bytes__"], false]
    - ["ft2536-006", "partialmethod.__dict__.__contains__", ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 3: functools.cached_property — format/bytes/fspath protocol absence
#
# Theme: __format__, __bytes__, __fspath__ absent from functools.cached_property.__dict__.
# cached_property is a non-data descriptor; on first attribute access it calls
# the wrapped function and stores the result in the instance __dict__, bypassing
# itself on subsequent accesses. It has no formatting, bytes, or path role.
# ---------------------------------------------------------------------------

table functools_extra2536.cached_property_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from functools.cached_property.__dict__; wave 2536"
  kind: python_call_eq
  category: format_bytes_fspath
  id_prefix: ft2536

  columns: [id, function, args, expected]
  rows:
    - ["ft2536-007", "cached_property.__dict__.__contains__", ["__format__"], false]
    - ["ft2536-008", "cached_property.__dict__.__contains__", ["__bytes__"], false]
    - ["ft2536-009", "cached_property.__dict__.__contains__", ["__fspath__"], false]

