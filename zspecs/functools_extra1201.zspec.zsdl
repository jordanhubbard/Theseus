spec: functools_extra1201
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks functools.singledispatch.__doc__.__class__.__name__, functools.WRAPPER_ASSIGNMENTS.__contains__ for __module__/__name__/__qualname__/__annotations__/__doc__, functools.WRAPPER_UPDATES.__contains__ for __dict__, functools.WRAPPER_ASSIGNMENTS.__len__() == 5, functools.WRAPPER_UPDATES.__len__() == 1 — not covered in _extra1171/_extra1186"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra1201.singledispatch_doc_class_name:
  description: "functools.singledispatch __doc__.__class__.__name__ and related doc identity"
  kind: python_call_eq
  category: singledispatch_doc_class_name
  id_prefix: fn1201sd
  columns: [id, function, args, expected]
  rows:
    - [fn1201sd001, functools.singledispatch.__doc__.__class__.__name__.__eq__,          ["str"],       true]
    - [fn1201sd002, functools.singledispatch.__qualname__.__eq__,                        ["singledispatch"], true]
    - [fn1201sd003, functools.singledispatch.__module__.__eq__,                          ["functools"], true]
    - [fn1201sd004, functools.singledispatch.__class__.__name__.__eq__,                  ["function"],  true]
    - [fn1201sd005, functools.cached_property.__doc__.__class__.__name__.__eq__,         ["str"],       true]
    - [fn1201sd006, functools.cached_property.__qualname__.__eq__,                       ["cached_property"], true]
    - [fn1201sd007, functools.cached_property.__module__.__eq__,                         ["functools"], true]
    - [fn1201sd008, functools.cached_property.__class__.__name__.__eq__,                 ["type"],      true]

table functools_extra1201.wrapper_assignments_contains:
  description: "functools.WRAPPER_ASSIGNMENTS membership checks and length"
  kind: python_call_eq
  category: wrapper_assignments_contains
  id_prefix: fn1201wc
  columns: [id, function, args, expected]
  rows:
    - [fn1201wc001, functools.WRAPPER_ASSIGNMENTS.__contains__,   ["__module__"],      true]
    - [fn1201wc002, functools.WRAPPER_ASSIGNMENTS.__contains__,   ["__name__"],        true]
    - [fn1201wc003, functools.WRAPPER_ASSIGNMENTS.__contains__,   ["__qualname__"],    true]
    - [fn1201wc004, functools.WRAPPER_ASSIGNMENTS.__contains__,   ["__annotations__"], true]
    - [fn1201wc005, functools.WRAPPER_ASSIGNMENTS.__contains__,   ["__doc__"],         true]
    - [fn1201wc006, functools.WRAPPER_ASSIGNMENTS.__len__,        [],                  5]
    - [fn1201wc007, functools.WRAPPER_ASSIGNMENTS.__contains__,   ["__dict__"],        false]
    - [fn1201wc008, functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__, ["tuple"], true]

table functools_extra1201.wrapper_updates_contains_and_len:
  description: "functools.WRAPPER_UPDATES membership checks and length"
  kind: python_call_eq
  category: wrapper_updates_contains_and_len
  id_prefix: fn1201wu
  columns: [id, function, args, expected]
  rows:
    - [fn1201wu001, functools.WRAPPER_UPDATES.__contains__,   ["__dict__"],   true]
    - [fn1201wu002, functools.WRAPPER_UPDATES.__len__,        [],             1]
    - [fn1201wu003, functools.WRAPPER_UPDATES.__class__.__name__.__eq__,   ["tuple"],   true]
    - [fn1201wu004, functools.WRAPPER_UPDATES.__contains__,   ["__module__"],  false]
    - [fn1201wu005, functools.WRAPPER_UPDATES.__contains__,   ["__name__"],    false]
    - [fn1201wu006, functools.partial.__module__.__eq__,      ["functools"],   true]
    - [fn1201wu007, functools.partial.__qualname__.__eq__,    ["partial"],     true]
    - [fn1201wu008, functools.partial.__class__.__name__.__eq__, ["type"],     true]
