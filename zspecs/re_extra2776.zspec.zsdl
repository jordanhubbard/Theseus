spec: re_extra2776
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra.zspec.zsdl — covers existing re invariants"
    - "re_extra2761.zspec.zsdl — covers __matmul__/__truediv__/__iadd__ dict-presence"
    - "re_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "re_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "re_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 632 (re_extra2776) theme: __isub__, __imul__, and __itruediv__ dict-presence checks."
    - "Neither re.Pattern nor re.Match defines __isub__, __imul__, or __itruediv__ in its own __dict__."
    - "__isub__ supports the -= operator; regex objects are pattern-matching types, not numeric types."
    - "__imul__ supports the *= operator; regex objects do not implement in-place multiplication semantics."
    - "__itruediv__ supports the /= operator; regex objects do not implement in-place true-division semantics."
    - "Covers re.Pattern (type(re.compile(''))) and re.Match (type(re.match('', '')))."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __isub__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2776.no_isub_in_re_classes:
  description: "__isub__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the -= in-place subtraction protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2776

  columns: [id, function, args, expected]
  rows:
    - ["re2776001", "re.Pattern.__dict__.__contains__", ["__isub__"], false]
    - ["re2776002", "re.Match.__dict__.__contains__",   ["__isub__"], false]

# ---------------------------------------------------------------------------
# __imul__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2776.no_imul_in_re_classes:
  description: "__imul__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the *= in-place multiplication protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2776

  columns: [id, function, args, expected]
  rows:
    - ["re2776003", "re.Pattern.__dict__.__contains__", ["__imul__"], false]
    - ["re2776004", "re.Match.__dict__.__contains__",   ["__imul__"], false]

# ---------------------------------------------------------------------------
# __itruediv__ dict-presence — re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2776.no_itruediv_in_re_classes:
  description: "__itruediv__ is absent from re.Pattern and re.Match __dict__s — regex objects do not implement the /= in-place true-division protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2776

  columns: [id, function, args, expected]
  rows:
    - ["re2776005", "re.Pattern.__dict__.__contains__", ["__itruediv__"], false]
    - ["re2776006", "re.Match.__dict__.__contains__",   ["__itruediv__"], false]

# ---------------------------------------------------------------------------
# Complementary: re.Pattern and re.Match have regex methods but not in-place arithmetic operator hooks
# Confirms that regex objects are pattern-matching types, not numeric types
# ---------------------------------------------------------------------------

table re_extra2776.re_has_regex_methods_not_inplace_arithmetic_operator_hooks:
  description: "re.Pattern defines match/search/sub/findall but NOT __isub__/__imul__/__itruediv__; re.Match defines group/groups/start/end but NOT __isub__/__imul__/__itruediv__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2776

  columns: [id, function, args, expected]
  rows:
    - ["re2776007", "re.Pattern.__dict__.__contains__", ["match"],        true]
    - ["re2776008", "re.Pattern.__dict__.__contains__", ["search"],       true]
    - ["re2776009", "re.Pattern.__dict__.__contains__", ["sub"],          true]
    - ["re2776010", "re.Pattern.__dict__.__contains__", ["findall"],      true]
    - ["re2776011", "re.Pattern.__dict__.__contains__", ["__isub__"],     false]
    - ["re2776012", "re.Pattern.__dict__.__contains__", ["__imul__"],     false]
    - ["re2776013", "re.Pattern.__dict__.__contains__", ["__itruediv__"], false]
    - ["re2776014", "re.Match.__dict__.__contains__",   ["group"],        true]
    - ["re2776015", "re.Match.__dict__.__contains__",   ["groups"],       true]
    - ["re2776016", "re.Match.__dict__.__contains__",   ["start"],        true]
    - ["re2776017", "re.Match.__dict__.__contains__",   ["end"],          true]
    - ["re2776018", "re.Match.__dict__.__contains__",   ["__isub__"],     false]
    - ["re2776019", "re.Match.__dict__.__contains__",   ["__imul__"],     false]
    - ["re2776020", "re.Match.__dict__.__contains__",   ["__itruediv__"], false]
