# ---------------------------------------------------------------------------
# Table 1: itertools.zip_longest and itertools.pairwise class identity
#
# Wave 291 theme: itertools.zip_longest and itertools.pairwise C extension
# type identity — name, module, and type class.
#
# itertools.zip_longest.__name__ == 'zip_longest'
# itertools.zip_longest.__module__ == 'itertools'
# itertools.zip_longest.__class__.__name__ == 'type'
# itertools.pairwise.__name__ == 'pairwise'
# itertools.pairwise.__module__ == 'itertools'
# itertools.pairwise.__class__.__name__ == 'type'
#
# itertools.zip_longest(iter1, iter2, ..., fillvalue=None) aggregates elements
# from multiple iterables; unlike zip() it continues until the longest iterable
# is exhausted, filling missing values with fillvalue. itertools.pairwise
# (added in Python 3.10) returns successive overlapping pairs (s[0],s[1]),
# (s[1],s[2]), ... from an iterable. Both are C extension types defined in
# itertoolsmodule.c; their __class__.__name__ is 'type'. New to extra162.
# ---------------------------------------------------------------------------

table itertools_extra162.zip_longest_and_pairwise_identity:
  description: "itertools: zip_longest.__name__ 'zip_longest', zip_longest.__module__ 'itertools', zip_longest.__class__.__name__ 'type', pairwise.__name__ 'pairwise', pairwise.__module__ 'itertools', pairwise.__class__.__name__ 'type'; wave 291; new to extra162"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolszlpwi162

  columns: [id, function, args, expected, description]
  rows:
    - [zl_name_eq_zip_longest,
       "zip_longest.__name__.__eq__",
       ["zip_longest"],
       true,
       "itertools.zip_longest.__name__.__eq__('zip_longest') == True — zip_longest is a C extension type in itertoolsmodule.c that aggregates elements from multiple iterables padding shorter ones with fillvalue; its type __name__ is 'zip_longest'; str.__eq__('zip_longest') returns True; new to extra162"]
    - [zl_module_eq_itertools,
       "zip_longest.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.zip_longest.__module__.__eq__('itertools') == True — zip_longest is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra162"]
    - [pw_name_eq_pairwise,
       "pairwise.__name__.__eq__",
       ["pairwise"],
       true,
       "itertools.pairwise.__name__.__eq__('pairwise') == True — pairwise (Python 3.10+) is a C extension type in itertoolsmodule.c that returns successive overlapping pairs from an iterable; its type __name__ is 'pairwise'; str.__eq__('pairwise') returns True; new to extra162"]
    - [pw_module_eq_itertools,
       "pairwise.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.pairwise.__module__.__eq__('itertools') == True — pairwise is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra162"]

# ---------------------------------------------------------------------------
# Table 2: itertools.batched identity and docstring classes
#
# Wave 291 theme: itertools.batched C extension type identity and __doc__
# class for zip_longest, pairwise, and batched.
#
# itertools.batched.__name__ == 'batched'
# itertools.batched.__module__ == 'itertools'
# itertools.batched.__class__.__name__ == 'type'
# itertools.zip_longest.__doc__.__class__.__name__ == 'str'
# itertools.pairwise.__doc__.__class__.__name__ == 'str'
# itertools.batched.__doc__.__class__.__name__ == 'str'
#
# itertools.batched (added in Python 3.12) batches an iterable into tuples of
# up to n elements. All three types (zip_longest, pairwise, batched) are C
# extension types with C-level docstrings. Their __doc__ attributes are Python
# str objects, so __doc__.__class__.__name__ is 'str' in all cases. New to extra162.
# ---------------------------------------------------------------------------

table itertools_extra162.batched_identity_and_doc_classes:
  description: "itertools: batched.__name__ 'batched', batched.__module__ 'itertools', batched.__class__.__name__ 'type'; zip_longest/pairwise/batched __doc__.__class__.__name__ 'str'; wave 291; new to extra162"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsbdc162

  columns: [id, function, args, expected, description]
  rows:
    - [bt_name_eq_batched,
       "batched.__name__.__eq__",
       ["batched"],
       true,
       "itertools.batched.__name__.__eq__('batched') == True — batched (Python 3.12+) is a C extension type in itertoolsmodule.c that batches an iterable into tuples of up to n elements; its type __name__ is 'batched'; str.__eq__('batched') returns True; new to extra162"]
    - [bt_module_eq_itertools,
       "batched.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.batched.__module__.__eq__('itertools') == True — batched is declared in the itertools C extension module (itertoolsmodule.c); its __module__ attribute is 'itertools'; str.__eq__('itertools') returns True; new to extra162"]
    - [zl_doc_class_eq_str,
       "zip_longest.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.zip_longest.__doc__.__class__.__name__.__eq__('str') == True — zip_longest is a C extension type with a C-level docstring; its __doc__ attribute is a Python str object; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra162"]
    - [pw_doc_class_eq_str,
       "pairwise.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.pairwise.__doc__.__class__.__name__.__eq__('str') == True — pairwise is a C extension type with a C-level docstring; its __doc__ attribute is a Python str object; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra162"]
    - [bt_doc_class_eq_str,
       "batched.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.batched.__doc__.__class__.__name__.__eq__('str') == True — batched is a C extension type with a C-level docstring; its __doc__ attribute is a Python str object; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra162"]

