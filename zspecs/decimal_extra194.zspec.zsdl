# ---------------------------------------------------------------------------
# Standalone invariants — decimalstr194
# ---------------------------------------------------------------------------

invariant decimal_extra194.Decimal.str_qualname_eq:
  description: "decimal.Decimal.__str__.__qualname__.__eq__('Decimal.__str__') returns True — __str__ converts a Decimal to its string representation; qualname 'Decimal.__str__' has len=15 ('Decimal.'=8+'__str__'=7=15); Decimal('1.5').__str__() == '1.5'; compare: __repr__ qualname='Decimal.__repr__' len=16; quantize qualname='Decimal.quantize' also len=16; to_integral_value/to_integral_exact qualnames len=25 (longest); NEW in decimal_extra194: first standalone Decimal.__str__ qualname invariant in decimalstr194 namespace; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "Decimal.__str__.__qualname__.__eq__"
  args: ["Decimal.__str__"]
  expected: true

invariant decimal_extra194.Decimal.repr_qualname_len:
  description: "decimal.Decimal.__repr__.__qualname__.__len__() == 16 — 'Decimal.__repr__' has 16 chars ('Decimal.'=8+'__repr__'=8=16); __repr__ returns a string representation suitable for use in source code; Decimal('1.5') produces \"Decimal('1.5')\"; compare: __str__ qualname='Decimal.__str__' len=15; quantize qualname='Decimal.quantize' also len=16; __format__ len=18; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "Decimal.__repr__.__qualname__.__len__"
  args: []
  expected: 16

invariant decimal_extra194.Decimal.format_qualname_len:
  description: "decimal.Decimal.__format__.__qualname__.__len__() == 18 — 'Decimal.__format__' has 18 chars ('Decimal.'=8+'__format__'=10=18); __format__ is called by format() and f-strings; supports fixed-point, scientific and engineering notation via format spec; compare: __repr__ len=16; normalize qualname='Decimal.normalize' len=17; to_eng_string len=21; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: "Decimal.__format__.__qualname__.__len__"
  args: []
  expected: 18

invariant decimal_extra194.Decimal.to_eng_string_qualname_len:
  description: "decimal.Decimal.to_eng_string.__qualname__.__len__() == 21 — 'Decimal.to_eng_string' has 21 chars ('Decimal.'=8+'to_eng_string'=13=21); to_eng_string() converts to engineering notation where the exponent is a multiple of 3; compare: to_integral_value/to_integral_exact len=25 (longest); normalize len=17; __format__ len=18; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.to_eng_string.__qualname__.__len__
  args: []
  expected: 21

invariant decimal_extra194.Decimal.to_integral_value_qualname_eq:
  description: "decimal.Decimal.to_integral_value.__qualname__.__eq__('Decimal.to_integral_value') returns True — to_integral_value() rounds to the nearest integer; qualname 'Decimal.to_integral_value' has len=25 ('Decimal.'=8+'to_integral_value'=17=25) — tied for longest qualname in spec; compare: to_integral_exact qualname='Decimal.to_integral_exact' also len=25; to_eng_string len=21; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.to_integral_value.__qualname__.__eq__
  args: ["Decimal.to_integral_value"]
  expected: true

invariant decimal_extra194.Decimal.to_integral_exact_qualname_eq:
  description: "decimal.Decimal.to_integral_exact.__qualname__.__eq__('Decimal.to_integral_exact') returns True — to_integral_exact() rounds to the nearest integer and also sets the Inexact or Rounded signal if rounding occurs; qualname 'Decimal.to_integral_exact' has len=25 ('Decimal.'=8+'to_integral_exact'=17=25); compare: to_integral_value qualname='Decimal.to_integral_value' also len=25 (same length); verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.to_integral_exact.__qualname__.__eq__
  args: ["Decimal.to_integral_exact"]
  expected: true

invariant decimal_extra194.Decimal.normalize_qualname_len:
  description: "decimal.Decimal.normalize.__qualname__.__len__() == 17 — 'Decimal.normalize' has 17 chars ('Decimal.'=8+'normalize'=9=17); normalize() reduces the coefficient to its shortest form by removing trailing zeros; compare: __format__ len=18; to_eng_string len=21; __repr__/quantize len=16; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.normalize.__qualname__.__len__
  args: []
  expected: 17

invariant decimal_extra194.Decimal.quantize_qualname_eq:
  description: "decimal.Decimal.quantize.__qualname__.__eq__('Decimal.quantize') returns True — quantize() returns a value equal to the original but with the exponent set to match the provided exponent; qualname 'Decimal.quantize' has len=16 ('Decimal.'=8+'quantize'=8=16); compare qualname lengths in spec: __str__=15, __repr__=16, quantize=16, normalize=17, __format__=18, to_eng_string=21, to_integral_value=25, to_integral_exact=25; verified with Python 3.14.3"
  category: method_qualnames
  kind: python_call_eq
  function: Decimal.quantize.__qualname__.__eq__
  args: ["Decimal.quantize"]
  expected: true

