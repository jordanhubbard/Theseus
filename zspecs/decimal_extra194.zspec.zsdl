spec: decimal_extra194
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic Specification, Version 1.72"
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl — covers Decimal.__str__, is_finite/is_nan/is_infinite/is_zero/is_signed/is_normal, as_tuple, class_name, getcontext"
    - "decimal_extra.zspec.zsdl — covers Decimal predicates, to_eng_string, Context/BasicContext/ExtendedContext/DefaultContext class names, rounding constants"
    - "decimal_extra193.zspec.zsdl — covers Decimal comparison/conversion method qualnames: __eq__, __lt__, __le__, __gt__, __ge__, __ne__, __bool__, __int__"
  notes:
    - "This spec covers decimal.Decimal string conversion method qualnames not already in previous decimal_extra specs."
    - "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' — len=15."
    - "decimal.Decimal.__repr__.__qualname__ == 'Decimal.__repr__' — len=16."
    - "decimal.Decimal.__format__.__qualname__ == 'Decimal.__format__' — len=18."
    - "decimal.Decimal.to_eng_string.__qualname__ == 'Decimal.to_eng_string' — len=21."
    - "decimal.Decimal.to_integral_value.__qualname__ == 'Decimal.to_integral_value' — len=25."
    - "decimal.Decimal.to_integral_exact.__qualname__ == 'Decimal.to_integral_exact' — len=25."
    - "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize' — len=17."
    - "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize' — len=16."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal dunder string conversion method qualnames — __str__, __repr__, __format__
# ---------------------------------------------------------------------------

table decimal_extra194.decimal_dunder_str_qualnames:
  description: "decimal.Decimal dunder string conversion method qualnames in decimalstr194 namespace — __str__ len=15, __repr__ len=16, __format__ len=18; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: decimalstr194

  columns: [id, function, args, expected, description]
  rows:
    - [str_qn,    "Decimal.__str__.__qualname__.__eq__",    ["Decimal.__str__"],    true, "decimal.Decimal.__str__.__qualname__ == 'Decimal.__str__' (len=15); verified with Python 3.14.3"]
    - [repr_qn,   "Decimal.__repr__.__qualname__.__eq__",   ["Decimal.__repr__"],   true, "decimal.Decimal.__repr__.__qualname__ == 'Decimal.__repr__' (len=16); verified with Python 3.14.3"]
    - [format_qn, "Decimal.__format__.__qualname__.__eq__", ["Decimal.__format__"], true, "decimal.Decimal.__format__.__qualname__ == 'Decimal.__format__' (len=18); verified with Python 3.14.3"]

