spec: uuid_extra1021
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks uuid module metadata types and class __weakref__ descriptor identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1021.module_metadata_types:
  description: "uuid module top-level attribute class name checks"
  kind: python_call_eq
  category: module_metadata
  id_prefix: uu1021x
  columns: [id, function, args, expected]
  rows:
    - [uu1021x001, uuid.__cached__.__class__.__name__.__eq__, ["str"],  true]
    - [uu1021x002, uuid.__file__.__class__.__name__.__eq__,   ["str"],  true]
    - [uu1021x003, uuid.__all__.__class__.__name__.__eq__,    ["list"], true]
    - [uu1021x004, uuid.__name__.__class__.__name__.__eq__,   ["str"],  true]
    - [uu1021x005, uuid.__doc__.__class__.__name__.__eq__,    ["str"],  true]
    - [uu1021x006, uuid.__package__.__class__.__name__.__eq__, ["str"], true]

table uuid_extra1021.class_weakref_descriptors:
  description: "uuid class __weakref__ getset_descriptor checks"
  kind: python_call_eq
  category: weakref_descriptors
  id_prefix: uu1021w
  columns: [id, function, args, expected]
  rows:
    - [uu1021w001, uuid.UUID.__weakref__.__class__.__name__.__eq__,     ["getset_descriptor"], true]
    - [uu1021w002, uuid.SafeUUID.__weakref__.__class__.__name__.__eq__, ["getset_descriptor"], true]
    - [uu1021w003, uuid.UUID.__class__.__name__.__eq__,                 ["type"],              true]
    - [uu1021w004, uuid.SafeUUID.__class__.__name__.__eq__,             ["EnumType"],          true]
    - [uu1021w005, uuid.UUID.__module__.__eq__,                         ["uuid"],              true]

table uuid_extra1021.function_globals_identity:
  description: "uuid function __globals__ class name checks"
  kind: python_call_eq
  category: function_globals
  id_prefix: uu1021g
  columns: [id, function, args, expected]
  rows:
    - [uu1021g001, uuid.uuid1.__globals__.__class__.__name__.__eq__,  ["dict"], true]
    - [uu1021g002, uuid.uuid3.__globals__.__class__.__name__.__eq__,  ["dict"], true]
    - [uu1021g003, uuid.uuid4.__globals__.__class__.__name__.__eq__,  ["dict"], true]
    - [uu1021g004, uuid.uuid5.__globals__.__class__.__name__.__eq__,  ["dict"], true]
    - [uu1021g005, uuid.uuid1.__module__.__eq__,                      ["uuid"], true]
