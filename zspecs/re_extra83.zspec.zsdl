spec: re_extra83
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra82."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error/__name__; re module-level function __code__ co_name and co_argcount; Pattern/Match method __qualname__ values and lengths; PatternError hierarchy; re.compile/__qualname__/__module__; re.match/sub/findall/split __qualname__; Match.start/end class name and qualname; re module function __module__ values; Pattern/Match method __doc__.__class__.__name__; Match method __qualname__ values and lengths; re module function __code__ attributes."
    - "This spec covers: re.Pattern.__name__; re.Pattern.__module__; re.Pattern.__bases__[0].__name__; re.Pattern.__mro__.__len__(); re.Match.__name__; re.Match.__module__; re.Match.__bases__[0].__name__; re.Match.__mro__.__len__(); re.Pattern.__dict__.__class__.__name__; re.Match.__dict__.__class__.__name__; re.Pattern.__qualname__ and __qualname__.__len__(); re.Match.__qualname__ and __qualname__.__len__(); re.PatternError.__name__; re.PatternError.__module__."
    - "re.Pattern.__name__ == 'Pattern' — the C type name as exposed through the re module."
    - "re.Pattern.__module__ == 're' — the re module re-exports Pattern (originally from _sre)."
    - "re.Pattern.__bases__[0].__name__ == 'object' — Pattern has a single base: object."
    - "re.Pattern.__mro__.__len__() == 2 — MRO is [Pattern, object]."
    - "re.Match.__name__ == 'Match' — the C type name as exposed through the re module."
    - "re.Match.__module__ == 're' — the re module re-exports Match."
    - "re.Match.__bases__[0].__name__ == 'object' — Match has a single base: object."
    - "re.Match.__mro__.__len__() == 2 — MRO is [Match, object]."
    - "re.Pattern.__dict__.__class__.__name__ == 'mappingproxy' — C type's __dict__ is a mappingproxy."
    - "re.Match.__dict__.__class__.__name__ == 'mappingproxy' — C type's __dict__ is a mappingproxy."
    - "re.Pattern.__qualname__ == 'Pattern' — length 7."
    - "re.Match.__qualname__ == 'Match' — length 5."
    - "re.PatternError.__name__ == 'PatternError' — introduced in Python 3.13 as alias for re.error."
    - "re.PatternError.__module__ == 're' — defined in the re module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern class identity: __name__, __module__, __bases__[0].__name__, __mro__.__len__()
# Pattern is a C type; its __module__ is 're' (re-exported from _sre).
# MRO: [Pattern, object] — length 2.
# Function values with [ must be double-quoted.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra83.Pattern_identity:
  description: "re.Pattern __name__, __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: reextra83

  columns: [id, function, args, expected]
  rows:
    - [pat_name,    Pattern.__name__.__eq__,                  ["Pattern"], true]
    - [pat_module,  Pattern.__module__.__eq__,                ["re"],      true]
    - [pat_base0,   "Pattern.__bases__[0].__name__.__eq__",   ["object"],  true]
    - [pat_mro_len, Pattern.__mro__.__len__,                  [],          2]

# ---------------------------------------------------------------------------
# re.Match class identity: __name__, __module__, __bases__[0].__name__, __mro__.__len__()
# Match is a C type; its __module__ is 're' (re-exported from _sre).
# MRO: [Match, object] — length 2.
# Function values with [ must be double-quoted.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra83.Match_identity:
  description: "re.Match __name__, __module__, __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: reextra83

  columns: [id, function, args, expected]
  rows:
    - [match_name,    Match.__name__.__eq__,                  ["Match"],  true]
    - [match_module,  Match.__module__.__eq__,                ["re"],     true]
    - [match_base0,   "Match.__bases__[0].__name__.__eq__",   ["object"], true]
    - [match_mro_len, Match.__mro__.__len__,                  [],         2]

# ---------------------------------------------------------------------------
# re.Pattern and re.Match __dict__ class and __qualname__ identity
# Both Pattern and Match are C types; their __dict__ is a mappingproxy.
# Pattern.__qualname__ == 'Pattern' (length 7).
# Match.__qualname__ == 'Match' (length 5).
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra83.Pattern_Match_dict_qualname:
  description: "Pattern and Match __dict__.__class__.__name__, __qualname__, and __qualname__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: reextra83

  columns: [id, function, args, expected]
  rows:
    - [pat_dict_class,  Pattern.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [mat_dict_class,  Match.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true]
    - [pat_qualname,    Pattern.__qualname__.__eq__,                ["Pattern"],      true]
    - [pat_qn_len,      Pattern.__qualname__.__len__,               [],               7]
    - [mat_qualname,    Match.__qualname__.__eq__,                  ["Match"],        true]
    - [mat_qn_len,      Match.__qualname__.__len__,                 [],               5]

# ---------------------------------------------------------------------------
# re.PatternError identity
# PatternError was introduced in Python 3.13 as an alias for re.error.
# __name__ == 'PatternError'; __module__ == 're'.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra83.PatternError_identity:
  description: "re.PatternError __name__ and __module__"
  kind: python_call_eq
  category: class_identity
  id_prefix: reextra83

  columns: [id, function, args, expected]
  rows:
    - [paterr_name,   PatternError.__name__.__eq__,   ["PatternError"], true]
    - [paterr_module, PatternError.__module__.__eq__, ["re"],           true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra83.Pattern.name:
  description: "re.Pattern.__name__ == 'Pattern' (C type re-exported through re module)"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra83.Pattern.module:
  description: "re.Pattern.__module__ == 're' (re-exported from _sre through re module)"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra83.Pattern.mro_len:
  description: "re.Pattern.__mro__.__len__() == 2 ([Pattern, object])"
  category: class_identity
  kind: python_call_eq
  function: Pattern.__mro__.__len__
  args: []
  expected: 2

invariant re_extra83.Match.qualname_len:
  description: "re.Match.__qualname__.__len__() == 5 ('Match' has 5 characters)"
  category: class_identity
  kind: python_call_eq
  function: Match.__qualname__.__len__
  args: []
  expected: 5

invariant re_extra83.PatternError.name:
  description: "re.PatternError.__name__ == 'PatternError' (Python 3.13+ alias for re.error)"
  category: class_identity
  kind: python_call_eq
  function: PatternError.__name__.__eq__
  args: ["PatternError"]
  expected: true
