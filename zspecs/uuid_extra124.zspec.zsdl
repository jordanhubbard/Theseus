spec: uuid_extra124
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra123.zspec.zsdl — covers UUID.__slots__ class name/length/contains / UUID.__weakref__ descriptor class name/qualname/name / UUID.int member_descriptor class name/name/qualname / UUID.__hash__ code co_argcount (table + invariants)."
    - "uuid_extra122.zspec.zsdl — covers UUID.__init__/__str__/__repr__/__eq__ co_varnames[0] ('self') and co_varnames.__len__() / co_argcount for __str__/__repr__/__eq__ (table + invariants)."
    - "uuid_extra121.zspec.zsdl — covers uuid6/uuid7/uuid8 function __name__/__qualname__/__module__/__code__.co_argcount identity / uuid.NIL and uuid.MAX sentinel UUID hex values and __class__.__name__ (table + invariants)."
    - "uuid_extra99.zspec.zsdl — covers UUID.__init__ co_name/co_argcount/__qualname__/__qualname__.__len__ / UUID.__str__/__repr__/__eq__/__hash__/__lt__ method qualname equality and length (table + invariants)."
    - "uuid_extra97.zspec.zsdl — covers UUID property fget qualname string equality / property qualname lengths / type(UUID.hex).__name__=='property' (table + invariants)."
    - "uuid_extra96.zspec.zsdl — covers uuid1/uuid3/uuid4/uuid5 __code__.co_name equality and co_argcount / UUID.__module__/__eq__('uuid') / UUID.__class__.__name__.__eq__('type') / UUID.__qualname__ equality and length (table + invariants)."
    - "uuid_extra95.zspec.zsdl — covers SafeUUID.safe.value==0 / SafeUUID.unsafe.value==-1 / UUID.hex/bytes/urn/fields/variant/version fget.__qualname__.__len__() (table + invariants)."
    - "uuid_extra94.zspec.zsdl — covers UUID.__slots__ class name/length/contents / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 / UUID.__setattr__.__class__.__name__=='function' (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior uuid spec files."
    - "Wave 312 theme: uuid.UUID property __class__.__name__ equality via __eq__ / UUID.is_safe member_descriptor qualname and name lengths / UUID.hex/bytes/bytes_le/fields/node fget __code__.co_argcount / fget __class__.__name__ / property fget qualname length cross-checks."
    - "uuid.UUID.hex.__class__.__name__ == 'property'. All 15 UUID attributes (hex, bytes, bytes_le, fields, node, etc.) are property objects, not member_descriptors. The task description was incorrect; actual values are 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__class__.__name__ == 'function'. All UUID property fgets are pure-Python functions. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__code__.co_argcount == 1. All UUID property fgets take only 'self'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.is_safe.__class__.__name__ == 'member_descriptor'. UUID.is_safe is a __slots__ entry (not a property), so it is a member_descriptor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.is_safe.__qualname__ == 'UUID.is_safe'. len == 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.is_safe.__name__ == 'is_safe'. len == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid_extra97 anchors property fget qualname string equality. This spec anchors __class__.__name__ equality via __eq__ calls and fget co_argcount under uuidprop124."
    - "uuid_extra95 anchors hex/bytes/urn/fields/variant/version fget.__qualname__.__len__(). This spec anchors hex/bytes/bytes_le/fields/node fget qualname lengths as cross-checks."
    - "Note: UUID.hex/bytes/bytes_le/fields/node are all pure-Python property objects (fget is a 'function'). The only member_descriptor slots in UUID are 'int', 'is_safe', and the __weakref__ getset_descriptor."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.hex.__class__.__name__.__eq__('property')
# uuid.UUID.bytes.__class__.__name__.__eq__('property')
# uuid.UUID.bytes_le.__class__.__name__.__eq__('property')
# uuid.UUID.fields.__class__.__name__.__eq__('property')
# uuid.UUID.node.__class__.__name__.__eq__('property')
#
# Wave 312 theme: UUID property __class__.__name__ equality.
#
# UUID.hex, UUID.bytes, UUID.bytes_le, UUID.fields, and UUID.node are all
# property objects — uuid.UUID is a pure-Python class (Lib/uuid.py) that uses
# @property decorators for computed attributes. Their __class__.__name__ is
# 'property' (the built-in property type). uuid_extra97 anchors type(UUID.hex)
# .__name__=='property' at table level; this spec anchors UUID.hex.__class__.__name__
# via __eq__ calls under uuidprop124. The distinction: type(x).__name__ and
# x.__class__.__name__ both yield 'property' for property objects.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra124.UUID_property_class_names:
  description: "UUID.hex/__class__.__name__.__eq__('property')==True / UUID.bytes/__class__.__name__.__eq__('property')==True / UUID.bytes_le/__class__.__name__.__eq__('property')==True / UUID.fields/__class__.__name__.__eq__('property')==True / UUID.node/__class__.__name__.__eq__('property')==True — UUID is a pure-Python class; all computed attributes are @property descriptors; extra97 anchors type(UUID.hex).__name__ at table level; first uuidprop124 anchor via __class__.__name__.__eq__"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidprop124

  columns: [id, function, args, expected, description]
  rows:
    - [hex_class,      "UUID.hex.__class__.__name__.__eq__",      ["property"], true, "UUID.hex is a property object (pure-Python @property decorator)"]
    - [bytes_class,    "UUID.bytes.__class__.__name__.__eq__",    ["property"], true, "UUID.bytes is a property object"]
    - [bytes_le_class, "UUID.bytes_le.__class__.__name__.__eq__", ["property"], true, "UUID.bytes_le is a property object"]
    - [fields_class,   "UUID.fields.__class__.__name__.__eq__",   ["property"], true, "UUID.fields is a property object"]
    - [node_class,     "UUID.node.__class__.__name__.__eq__",     ["property"], true, "UUID.node is a property object"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__class__.__name__.__eq__('function')
# uuid.UUID.hex.fget.__code__.co_argcount.__eq__(1)
# uuid.UUID.bytes.fget.__code__.co_argcount.__eq__(1)
# uuid.UUID.bytes_le.fget.__code__.co_argcount.__eq__(1)
# uuid.UUID.fields.fget.__code__.co_argcount.__eq__(1)
#
# Wave 312 theme: UUID property fget class name and co_argcount.
#
# Each UUID property's fget is a pure-Python function (class 'function').
# All property fgets take exactly one argument (self), so co_argcount==1.
# uuid_extra97 anchors property fget qualname string equality; this spec
# adds fget.__class__.__name__ and fget.__code__.co_argcount under uuidprop124.
# No prior uuid spec anchors fget co_argcount for hex/bytes/bytes_le/fields.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra124.UUID_property_fget_class_and_argcount:
  description: "UUID.hex/fget/__class__.__name__.__eq__('function')==True / UUID.hex/fget/__code__/co_argcount.__eq__(1)==True / UUID.bytes/fget/__code__/co_argcount.__eq__(1)==True / UUID.bytes_le/fget/__code__/co_argcount.__eq__(1)==True / UUID.fields/fget/__code__/co_argcount.__eq__(1)==True — property fgets are pure-Python functions taking only 'self'; extra97 anchors fget qualname string equality; first uuidprop124 anchor for fget class name and co_argcount"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidprop124

  columns: [id, function, args, expected, description]
  rows:
    - [hex_fget_class,     "UUID.hex.fget.__class__.__name__.__eq__",      ["function"], true, "UUID.hex.fget is a pure-Python function (class 'function')"]
    - [hex_fget_argc,      "UUID.hex.fget.__code__.co_argcount.__eq__",    [1],          true, "UUID.hex.fget takes only 'self' (co_argcount == 1)"]
    - [bytes_fget_argc,    "UUID.bytes.fget.__code__.co_argcount.__eq__",  [1],          true, "UUID.bytes.fget takes only 'self' (co_argcount == 1)"]
    - [bytes_le_fget_argc, "UUID.bytes_le.fget.__code__.co_argcount.__eq__", [1],        true, "UUID.bytes_le.fget takes only 'self' (co_argcount == 1)"]
    - [fields_fget_argc,   "UUID.fields.fget.__code__.co_argcount.__eq__", [1],          true, "UUID.fields.fget takes only 'self' (co_argcount == 1)"]

# ---------------------------------------------------------------------------
# uuid.UUID.is_safe.__class__.__name__.__eq__('member_descriptor')
# uuid.UUID.is_safe.__qualname__.__eq__('UUID.is_safe')
# uuid.UUID.is_safe.__name__.__eq__('is_safe')
# uuid.UUID.is_safe.__qualname__.__len__()==12
# uuid.UUID.is_safe.__name__.__len__()==7
#
# Wave 312 theme: UUID.is_safe member_descriptor identity and lengths.
#
# UUID.is_safe is a member_descriptor — a C-level descriptor created for the
# 'is_safe' entry in UUID.__slots__. Unlike the property descriptors (hex, bytes,
# etc.), is_safe is a raw slot member. Its __qualname__ is 'UUID.is_safe' (12 chars)
# and __name__ is 'is_safe' (7 chars). uuid_extra123 anchors UUID.int member_descriptor
# identity; this spec anchors UUID.is_safe member_descriptor under uuidprop124 as
# a parallel cross-check. No prior uuid spec anchors is_safe as a member_descriptor
# via __eq__ calls. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra124.UUID_is_safe_member_descriptor:
  description: "UUID.is_safe/__class__.__name__.__eq__('member_descriptor')==True / UUID.is_safe/__qualname__.__eq__('UUID.is_safe')==True / UUID.is_safe/__name__.__eq__('is_safe')==True / UUID.is_safe/__qualname__/__len__()==12 / UUID.is_safe/__name__/__len__()==7 — is_safe is a __slots__ member_descriptor (not a property); stores SafeUUID enum value; extra123 anchors UUID.int member_descriptor; this spec anchors UUID.is_safe; first uuidprop124 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: uuidprop124

  columns: [id, function, args, expected, description]
  rows:
    - [is_safe_class,   "UUID.is_safe.__class__.__name__.__eq__", ["member_descriptor"], true, "UUID.is_safe is a member_descriptor (C slot created by __slots__)"]
    - [is_safe_qualname, "UUID.is_safe.__qualname__.__eq__",       ["UUID.is_safe"],     true, "UUID.is_safe.__qualname__ is 'UUID.is_safe' (class prefix + slot name)"]
    - [is_safe_name,    "UUID.is_safe.__name__.__eq__",            ["is_safe"],          true, "UUID.is_safe.__name__ is 'is_safe' (the slot name)"]
    - [is_safe_qlen,    "UUID.is_safe.__qualname__.__len__",       [],                   12,   "len('UUID.is_safe') == 12 ('UUID.'=5 + 'is_safe'=7)"]
    - [is_safe_nlen,    "UUID.is_safe.__name__.__len__",           [],                   7,    "len('is_safe') == 7"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.__class__.__name__.__eq__('property') — standalone
#
# uuid.UUID.hex.__class__.__name__ is 'property'. UUID.hex is a @property
# descriptor providing the 32-character hex string representation of the UUID
# (e.g., '12345678123412341234123456789abc'). Like all computed UUID attributes,
# it is a property (not a member_descriptor or getset_descriptor), because UUID
# is a pure-Python class using @property decorators. uuid_extra97 anchors
# type(UUID.hex).__name__=='property'; this is the first standalone for
# UUID.hex.__class__.__name__.__eq__('property') under uuidprop124.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra124.UUID_hex_class_property:
  description: "uuid.UUID.hex.__class__.__name__.__eq__('property') == True — UUID.hex is a @property providing the 32-char hex string; uuid is a pure-Python class so computed attributes are property objects; extra97 anchors type(UUID.hex).__name__; first standalone for UUID.hex.__class__.__name__.__eq__ under uuidprop124"
  category: type_identity
  kind: python_call_eq
  function: "UUID.hex.__class__.__name__.__eq__"
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.bytes.__class__.__name__.__eq__('property') — standalone
#
# uuid.UUID.bytes.__class__.__name__ is 'property'. UUID.bytes provides the
# UUID as a 16-byte big-endian bytes object. It is a @property decorator (pure-Python)
# like all other UUID computed attributes. No prior uuid spec anchors
# UUID.bytes.__class__.__name__.__eq__('property') as a standalone under uuidprop124.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra124.UUID_bytes_class_property:
  description: "uuid.UUID.bytes.__class__.__name__.__eq__('property') == True — UUID.bytes is a @property providing the UUID as a 16-byte big-endian bytes object; pure-Python class uses @property for computed attributes; first standalone for UUID.bytes.__class__.__name__.__eq__ under uuidprop124"
  category: type_identity
  kind: python_call_eq
  function: "UUID.bytes.__class__.__name__.__eq__"
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.is_safe.__class__.__name__.__eq__('member_descriptor') — standalone
#
# uuid.UUID.is_safe.__class__.__name__ is 'member_descriptor'. UUID.is_safe
# stores a SafeUUID enum value indicating whether the UUID was generated using
# a method guaranteed to avoid collisions (SafeUUID.safe) or not
# (SafeUUID.unsafe). It is a __slots__ member (not a property) because UUID's
# __slots__ declaration explicitly includes 'is_safe'. uuid_extra123 anchors
# UUID.int as a member_descriptor; this is the first standalone for
# UUID.is_safe.__class__.__name__.__eq__('member_descriptor') under uuidprop124.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra124.UUID_is_safe_class_member_descriptor:
  description: "uuid.UUID.is_safe.__class__.__name__.__eq__('member_descriptor') == True — UUID.is_safe is a __slots__ member (not a property) storing the SafeUUID enum value; parallel to UUID.int which is also a member_descriptor; extra123 anchors UUID.int; first standalone for UUID.is_safe.__class__.__name__.__eq__ under uuidprop124"
  category: type_identity
  kind: python_call_eq
  function: "UUID.is_safe.__class__.__name__.__eq__"
  args: ["member_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.is_safe.__qualname__.__eq__('UUID.is_safe') — standalone
#
# uuid.UUID.is_safe.__qualname__ is 'UUID.is_safe' (12 chars). The member_descriptor
# for the 'is_safe' slot carries a __qualname__ that includes the class prefix
# 'UUID.' followed by the slot name 'is_safe'. This mirrors the pattern seen in
# UUID.int.__qualname__ == 'UUID.int' (anchored in extra123). No prior uuid spec
# anchors UUID.is_safe.__qualname__.__eq__('UUID.is_safe') as a standalone under
# uuidprop124. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra124.UUID_is_safe_qualname:
  description: "uuid.UUID.is_safe.__qualname__.__eq__('UUID.is_safe') == True — is_safe member_descriptor __qualname__ includes the class prefix 'UUID.'; mirrors UUID.int.__qualname__=='UUID.int' (extra123); first standalone for UUID.is_safe.__qualname__.__eq__ under uuidprop124"
  category: type_identity
  kind: python_call_eq
  function: "UUID.is_safe.__qualname__.__eq__"
  args: ["UUID.is_safe"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__code__.co_argcount.__eq__(1) — standalone
#
# uuid.UUID.hex.fget.__code__.co_argcount is 1. The getter function for the
# UUID.hex property takes exactly one argument: self (the UUID instance).
# This is the standard signature for @property getters. The computed value
# hex() returns a 32-character lowercase hexadecimal string (the UUID's
# 128-bit integer rendered as hex without hyphens). No prior uuid spec anchors
# UUID.hex.fget.__code__.co_argcount as a standalone under uuidprop124.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra124.UUID_hex_fget_co_argcount:
  description: "uuid.UUID.hex.fget.__code__.co_argcount.__eq__(1) == True — UUID.hex.fget takes only 'self' (co_argcount=1); standard @property getter signature; fget returns 32-char hex string of UUID's 128-bit integer; first standalone for UUID.hex.fget co_argcount under uuidprop124"
  category: type_identity
  kind: python_call_eq
  function: "UUID.hex.fget.__code__.co_argcount.__eq__"
  args: [1]
  expected: true

