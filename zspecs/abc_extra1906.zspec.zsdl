    - ["ab1906002", "abc.ABC.__dict__.__contains__", ["__reversed__"], false]
    - ["ab1906003", "abc.abstractmethod.__dict__.__contains__", ["__reversed__"], false]
    - ["ab1906004", "abc.abstractclassmethod.__dict__.__contains__", ["__reversed__"], false]
    - ["ab1906005", "abc.abstractstaticmethod.__dict__.__contains__", ["__reversed__"], false]
    - ["ab1906006", "abc.abstractproperty.__dict__.__contains__", ["__reversed__"], false]

