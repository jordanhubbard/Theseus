spec: abc_extra1906
version: ">=3.9"
backend: python_module(abc)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "Wave 574 (_extra1906): __reversed__ reverse iteration protocol; __missing__ dict protocol; __match_args__ structural pattern matching (3.10+); __qualname__ values."
    - "abc.ABCMeta is a metaclass (subclass of type); its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "abc.ABC is a Python class using ABCMeta as its metaclass; its __dict__ does not contain __reversed__, __missing__, or __match_args__."
    - "abc.abstractmethod is a Python decorator class; its __dict__ is empty of all dunder methods including __wrapped__, __isabstractmethod__, __call__, __get__."
    - "abc.ABCMeta.__dict__ contains __new__, __instancecheck__, __subclasscheck__, __module__, __doc__."
    - "abc.ABCMeta.__qualname__ == 'ABCMeta' — top-level metaclass."
    - "abc.ABC.__qualname__ == 'ABC' — top-level Python class."
    - "abc.abstractmethod.__qualname__ == 'abstractmethod' — top-level Python decorator class."
    - "abc.abstractmethod.__dict__ does not contain __wrapped__, __isabstractmethod__, __call__, or __get__ — these are looked up via the descriptor protocol on the type, not stored in the instance __dict__."
    - "abc.abstractclassmethod, abc.abstractstaticmethod, abc.abstractproperty are deprecated subclasses; none define __reversed__, __missing__, or __match_args__."
    - "abc.abstractclassmethod.__qualname__ == 'abstractclassmethod' — deprecated decorator class."
    - "abc.abstractstaticmethod.__qualname__ == 'abstractstaticmethod' — deprecated decorator class."
    - "abc.abstractproperty.__qualname__ == 'abstractproperty' — deprecated decorator class."
    - "abc.ABC.__dict__ contains __module__, __doc__, __slots__, __abstractmethods__, __firstlineno__, __static_attributes__."
    - "abc.ABCMeta.__dict__ contains __new__, __instancecheck__, __subclasscheck__, __module__, __doc__, register."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

error_model: python_exceptions

table abc_extra1906.reversed_protocol:
