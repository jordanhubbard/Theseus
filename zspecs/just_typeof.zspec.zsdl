spec: just_typeof
version: ">=3.2.0"
backend: node(just-typeof)

docs: https://www.npmjs.com/package/just-typeof

provenance:
  derived_from:
    - "just-typeof README — https://www.npmjs.com/package/just-typeof"
    - "Test vectors verified with just-typeof via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-typeof source"
  notes:
    - "just-typeof is an npm package. Install: npm install just-typeof"
    - "The module exports a single function that returns a precise type string."
    - "Unlike typeof, distinguishes array, null, and object separately."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a type string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_typeof.typeOf:
  kind: node_module_call_eq
  function: ~
  category: classify
  id_prefix: jtypeof

  columns: [id, args, expected]
  rows:
    - [string,  ["hello"],     "string"]
    - [number,  [42],          "number"]
    - [array,   [[1, 2, 3]],   "array"]
    - [null,    [null],        "null"]
    - [object,  [{"a": 1}],   "object"]
