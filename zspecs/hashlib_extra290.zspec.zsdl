spec: hashlib_extra290
version: ">=3.9"
backend: python_module(hashlib)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Secure hashes and message digests"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py, Modules/_hashopenssl.c, Modules/_blake2/, Modules/_sha3/"
  notes:
    - "sha256, sha512, sha1, md5, sha224, sha384 constructors are builtin_function_or_method"
    - "sha3_256, sha3_512, sha3_224, sha3_384, shake_128, shake_256 are builtin_function_or_method"
    - "blake2b and blake2s are type (not builtin_function_or_method)"
    - "hashlib.new is a plain Python function; pbkdf2_hmac is builtin_function_or_method"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table hashlib_extra290.sha2_family_class_names:
  description: "Class names of SHA-2 and legacy hash constructors exposed directly on hashlib"
  kind: python_call_eq
  category: identity
  id_prefix: hlex290

  columns: [id, function, args, expected, description]
  rows:
    - [hlex290_001, hashlib.sha256.__class__.__name__, [], builtin_function_or_method, "sha256 constructor class name"]
    - [hlex290_002, hashlib.sha512.__class__.__name__, [], builtin_function_or_method, "sha512 constructor class name"]
    - [hlex290_003, hashlib.sha1.__class__.__name__, [], builtin_function_or_method, "sha1 constructor class name"]
    - [hlex290_004, hashlib.md5.__class__.__name__, [], builtin_function_or_method, "md5 constructor class name"]
    - [hlex290_005, hashlib.sha224.__class__.__name__, [], builtin_function_or_method, "sha224 constructor class name"]
    - [hlex290_006, hashlib.sha384.__class__.__name__, [], builtin_function_or_method, "sha384 constructor class name"]

table hashlib_extra290.sha3_and_blake2_class_names:
  description: "Class names of SHA-3, BLAKE2, and SHAKE constructors exposed directly on hashlib"
  kind: python_call_eq
  category: identity
  id_prefix: hlex290b

  columns: [id, function, args, expected, description]
  rows:
    - [hlex290b_001, hashlib.sha3_256.__class__.__name__, [], builtin_function_or_method, "sha3_256 constructor class name"]
    - [hlex290b_002, hashlib.sha3_512.__class__.__name__, [], builtin_function_or_method, "sha3_512 constructor class name"]
    - [hlex290b_003, hashlib.sha3_224.__class__.__name__, [], builtin_function_or_method, "sha3_224 constructor class name"]
    - [hlex290b_004, hashlib.sha3_384.__class__.__name__, [], builtin_function_or_method, "sha3_384 constructor class name"]
    - [hlex290b_005, hashlib.blake2b.__class__.__name__, [], type, "blake2b constructor class name (type, not builtin)"]
    - [hlex290b_006, hashlib.blake2s.__class__.__name__, [], type, "blake2s constructor class name (type, not builtin)"]
    - [hlex290b_007, hashlib.shake_128.__class__.__name__, [], builtin_function_or_method, "shake_128 constructor class name"]
    - [hlex290b_008, hashlib.shake_256.__class__.__name__, [], builtin_function_or_method, "shake_256 constructor class name"]

invariant hashlib_extra290.new_is_function:
  description: "hashlib.new is a plain Python function"
  category: identity
  kind: python_call_eq
  function: hashlib.new.__class__.__name__
  args: []
  expected: function

invariant hashlib_extra290.pbkdf2_hmac_is_builtin:
  description: "hashlib.pbkdf2_hmac is a builtin_function_or_method"
  category: identity
  kind: python_call_eq
  function: hashlib.pbkdf2_hmac.__class__.__name__
  args: []
  expected: builtin_function_or_method
