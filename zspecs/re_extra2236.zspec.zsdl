spec: re_extra2236
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re.zspec.zsdl"
  notes:
    - "Wave _extra2236: __slots__ and slot descriptor protocol checks for re classes."
    - "Covers __slots__, __weakref__, __dict__, __abstractmethods__, __init__, __new__, __subclasshook__ presence in re class dicts."
    - "re.Pattern and re.Match are C extension types; neither exposes __slots__, __weakref__, __dict__, __abstractmethods__, __init__, __new__, or __subclasshook__ in their own __dict__."
    - "re.RegexFlag is an IntFlag subclass; it defines __new__ in its own __dict__ but not the other slot-related dunder attributes."
    - "re.error is a pure-Python exception subclass; it defines __init__ and __weakref__ in its own __dict__ but not __slots__, __dict__, __abstractmethods__, __new__, or __subclasshook__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table re_extra2236.Pattern_slot_protocol:
  description: "re.Pattern __slots__/__weakref__/__dict__/__abstractmethods__/__init__/__new__/__subclasshook__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2236

  columns: [id, function, args, expected]
  rows:
    - ["re2236001", "re.Pattern.__dict__.__contains__", ["__slots__"], false]
    - ["re2236002", "re.Pattern.__dict__.__contains__", ["__weakref__"], false]
    - ["re2236003", "re.Pattern.__dict__.__contains__", ["__dict__"], false]
    - ["re2236004", "re.Pattern.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["re2236005", "re.Pattern.__dict__.__contains__", ["__init__"], false]
    - ["re2236006", "re.Pattern.__dict__.__contains__", ["__new__"], false]
    - ["re2236007", "re.Pattern.__dict__.__contains__", ["__subclasshook__"], false]

