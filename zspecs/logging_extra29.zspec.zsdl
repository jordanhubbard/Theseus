spec: logging_extra29
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging_extra28.zspec.zsdl — covers __module__.__len__()==7 for Logger/Handler/Formatter/Filter/LogRecord; __name__.__len__() for Logger/Handler/Formatter/Filter/LogRecord; getLogger/__qualname__.__eq__ and __qualname__.__len__; basicConfig/__qualname__.__eq__ and __qualname__.__len__."
    - "logging_extra27.zspec.zsdl — covers Logger/Handler/Formatter/Filter/LogRecord __init__.__name__, NOTSET/WARN/FATAL values, Logger/Handler/Formatter/Filter __module__ cross-namespace anchors."
    - "logging_extra26.zspec.zsdl — covers Logger/__qualname__/__module__/__bases__[0].__name__, RootLogger/__qualname__/__module__/__bases__[0].__name__, level constants DEBUG/INFO/WARNING/ERROR/CRITICAL/NOTSET values."
    - "logging_extra25.zspec.zsdl — covers Handler/Formatter __qualname__/__module__, StreamHandler/FileHandler __qualname__/__bases__[0].__name__, LogRecord.__module__."
    - "logging_extra24.zspec.zsdl — covers __qualname__ for StreamHandler.emit, FileHandler.emit, NullHandler.emit, Filter.filter, LogRecord class and getMessage, getLogger/basicConfig/makeLogRecord."
    - "logging_extra23.zspec.zsdl — covers __qualname__ for Logger.debug/info/warning/error/critical/exception, Handler.emit/handle, Formatter.format."
  notes:
    - "This spec extends logging_extra28.zspec.zsdl."
    - "Prior specs covered: Logger/Handler/Formatter/Filter/LogRecord __name__/__module__/__qualname__/__bases__[0].__name__, DEBUG/INFO/WARNING/ERROR/CRITICAL/NOTSET/WARN/FATAL values, getLogger/basicConfig/__name__/__qualname__, Logger/Handler/Formatter/Filter/__init__.__name__, LogRecord/__init__.__name__, Logger/Handler/Formatter/Filter/__module__, __module__.__len__()==7 for five classes, __name__.__len__() for five classes."
    - "This spec covers: __module__.__len__()==7 for getLogger/basicConfig/warning/error/info/debug/critical (module-level functions); __module__.__len__()==7 for FileHandler/StreamHandler (cross-namespace anchors from extra29); __name__.__len__() for FileHandler/StreamHandler; __qualname__.__len__() for FileHandler/StreamHandler; __name__.__len__() for warning/error/info/debug/critical module-level functions."
    - "logging.getLogger.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.basicConfig.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.warning.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.error.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.info.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.debug.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.critical.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.FileHandler.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.StreamHandler.__module__ == 'logging' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.FileHandler.__name__ == 'FileHandler' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.StreamHandler.__name__ == 'StreamHandler' — len 13. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.FileHandler.__qualname__ == 'FileHandler' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.StreamHandler.__qualname__ == 'StreamHandler' — len 13. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.warning.__name__ == 'warning' — len 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.error.__name__ == 'error' — len 5. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.info.__name__ == 'info' — len 4. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.debug.__name__ == 'debug' — len 5. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.critical.__name__ == 'critical' — len 8. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__()==7 for module-level functions getLogger, basicConfig,
# warning, error, info, debug, critical
#
# logging_extra28 covers __module__.__len__()==7 for Logger/Handler/Formatter/
# Filter/LogRecord (class objects). No prior spec measures __module__.__len__()
# for the module-level function objects. All are defined in 'logging' (len 7).
# ---------------------------------------------------------------------------

table logging_extra29.function_module_lengths:
  description: "len(__module__) == 7 for getLogger/basicConfig/warning/error/info/debug/critical — all in 'logging'; novel for module-level functions"
  kind: python_call_eq
  category: function_module
  id_prefix: fml29

  columns: [id, function, args, expected]
  rows:
    - [getLogger,   getLogger.__module__.__len__,   [], 7]
    - [basicConfig, basicConfig.__module__.__len__, [], 7]
    - [warning,     warning.__module__.__len__,     [], 7]
    - [error,       error.__module__.__len__,       [], 7]
    - [info,        info.__module__.__len__,         [], 7]
    - [debug,       debug.__module__.__len__,       [], 7]
    - [critical,    critical.__module__.__len__,    [], 7]

# ---------------------------------------------------------------------------
# __module__.__len__()==7 for FileHandler and StreamHandler
#
# logging_extra25 covers FileHandler/StreamHandler __qualname__/__bases__[0].__name__.
# logging_extra27 covers Logger/Handler/Formatter/Filter __module__ eq.
# No prior spec checks __module__.__len__() for FileHandler or StreamHandler
# as standalone invariants.
# ---------------------------------------------------------------------------

invariant logging_extra29.FileHandler.module_len:
  description: "len(logging.FileHandler.__module__) == 7 — 'logging' has 7 characters; cross-namespace anchor from extra29"
  category: class_module
  kind: python_call_eq
  function: FileHandler.__module__.__len__
  args: []
  expected: 7

invariant logging_extra29.StreamHandler.module_len:
  description: "len(logging.StreamHandler.__module__) == 7 — 'logging' has 7 characters; cross-namespace anchor from extra29"
  category: class_module
  kind: python_call_eq
  function: StreamHandler.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# __name__.__len__() and __qualname__.__len__() for FileHandler and StreamHandler
#
# logging_extra28 covers __name__.__len__() for Logger/Handler/Formatter/Filter/
# LogRecord. No prior spec covers __name__.__len__() for FileHandler or
# StreamHandler. FileHandler: 11, StreamHandler: 13. Qualname equals name
# for both (top-level classes).
# ---------------------------------------------------------------------------

table logging_extra29.handler_subclass_name_lengths:
  description: "len(__name__) and len(__qualname__) for FileHandler (11) and StreamHandler (13)"
  kind: python_call_eq
  category: class_names
  id_prefix: hsnl29

  columns: [id, function, args, expected]
  rows:
    - [FileHandler_name,       FileHandler.__name__.__len__,       [], 11]
    - [FileHandler_qualname,   FileHandler.__qualname__.__len__,   [], 11]
    - [StreamHandler_name,     StreamHandler.__name__.__len__,     [], 13]
    - [StreamHandler_qualname, StreamHandler.__qualname__.__len__, [], 13]

# ---------------------------------------------------------------------------
# __name__.__len__() for module-level log functions: warning, error, info,
# debug, critical
#
# No prior spec checks __name__.__len__() for any of these five functions.
# warning=7, error=5, info=4, debug=5, critical=8.
# ---------------------------------------------------------------------------

invariant logging_extra29.warning.name_len:
  description: "len(logging.warning.__name__) == 7 — len('warning') == 7; novel invariant"
  category: function_names
  kind: python_call_eq
  function: warning.__name__.__len__
  args: []
  expected: 7

invariant logging_extra29.critical.name_len:
  description: "len(logging.critical.__name__) == 8 — len('critical') == 8; novel invariant"
  category: function_names
  kind: python_call_eq
  function: critical.__name__.__len__
  args: []
  expected: 8

table logging_extra29.log_function_name_lengths:
  description: "len(__name__) for error (5), info (4), debug (5) — novel invariants for module-level log functions"
  kind: python_call_eq
  category: function_names
  id_prefix: lfnl29

  columns: [id, function, args, expected]
  rows:
    - [error, error.__name__.__len__, [], 5]
    - [info,  info.__name__.__len__,  [], 4]
    - [debug, debug.__name__.__len__, [], 5]
