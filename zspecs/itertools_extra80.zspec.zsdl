spec: itertools_extra80
version: ">=3.10"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra79.zspec.zsdl."
    - "This spec covers: __qualname__.__len__() for all 16 itertools C types (Wave 245)."
    - "count.__qualname__ == 'count' (len 5) — C type; __qualname__ is just the class name. Verified with Python 3.14.3."
    - "cycle.__qualname__ == 'cycle' (len 5) — C type; __qualname__ is just the class name. Verified with Python 3.14.3."
    - "repeat.__qualname__ == 'repeat' (len 6) — C type; __qualname__ is just the class name. Verified with Python 3.14.3."
    - "accumulate.__qualname__ == 'accumulate' (len 10) — C type. Verified with Python 3.14.3."
    - "chain.__qualname__ == 'chain' (len 5) — C type. Verified with Python 3.14.3."
    - "compress.__qualname__ == 'compress' (len 8) — C type. Verified with Python 3.14.3."
    - "dropwhile.__qualname__ == 'dropwhile' (len 9) — C type. Verified with Python 3.14.3."
    - "filterfalse.__qualname__ == 'filterfalse' (len 11) — C type. Verified with Python 3.14.3."
    - "groupby.__qualname__ == 'groupby' (len 7) — C type. Verified with Python 3.14.3."
    - "islice.__qualname__ == 'islice' (len 6) — C type. Verified with Python 3.14.3."
    - "pairwise.__qualname__ == 'pairwise' (len 8) — C type added in Python 3.10. Verified with Python 3.14.3."
    - "permutations.__qualname__ == 'permutations' (len 12) — C type. Verified with Python 3.14.3."
    - "product.__qualname__ == 'product' (len 7) — C type. Verified with Python 3.14.3."
    - "starmap.__qualname__ == 'starmap' (len 7) — C type. Verified with Python 3.14.3."
    - "takewhile.__qualname__ == 'takewhile' (len 9) — C type. Verified with Python 3.14.3."
    - "zip_longest.__qualname__ == 'zip_longest' (len 11) — C type. Verified with Python 3.14.3."
    - "version set to >=3.10 because pairwise was added in Python 3.10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Short-name itertools type __qualname__ lengths (len 5) — extra80
#
# Wave 245 theme: __qualname__.__len__() for all 16 itertools C types.
#
# itertools.count.__qualname__.__len__()  == 5
# itertools.cycle.__qualname__.__len__()  == 5
# itertools.chain.__qualname__.__len__()  == 5
#
# No prior itertools spec checks count/cycle/chain __qualname__.__len__() via itrtoolsextra80. New to extra80.
# ---------------------------------------------------------------------------

table itertools_extra80.qualname_len_5:
  description: "count/__qualname__.__len__()==5; cycle/__qualname__.__len__()==5; chain/__qualname__.__len__()==5; wave 245 itertools C type __qualname__ lengths; new to extra80"
  kind: python_call_eq
  category: type_identity
  id_prefix: itrtoolsextra80

  columns: [id, function, args, expected, description]
  rows:
    - [count_qualname_len_eq_5,
       "count.__qualname__.__len__",
       [],
       5,
       "itertools.count.__qualname__.__len__() == 5 — count is a C extension type defined in Modules/itertoolsmodule.c; for top-level C types the __qualname__ equals the plain class name 'count' (5 chars); str.__len__() returns 5; no prior itertools spec checks count.__qualname__.__len__() via itrtoolsextra80; new to extra80"]
    - [cycle_qualname_len_eq_5,
       "cycle.__qualname__.__len__",
       [],
       5,
       "itertools.cycle.__qualname__.__len__() == 5 — cycle is a C extension type defined in Modules/itertoolsmodule.c; for top-level C types the __qualname__ equals the plain class name 'cycle' (5 chars); str.__len__() returns 5; no prior itertools spec checks cycle.__qualname__.__len__() via itrtoolsextra80; new to extra80"]
    - [chain_qualname_len_eq_5,
       "chain.__qualname__.__len__",
       [],
       5,
       "itertools.chain.__qualname__.__len__() == 5 — chain is a C extension type defined in Modules/itertoolsmodule.c; for top-level C types the __qualname__ equals the plain class name 'chain' (5 chars); str.__len__() returns 5; no prior itertools spec checks chain.__qualname__.__len__() via itrtoolsextra80; new to extra80"]

