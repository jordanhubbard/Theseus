spec: theseus_code_cr
version: ">=3.0"
backend: python_cleanroom(theseus_code_cr)
blocks: code

docs: https://docs.python.org/3/library/code.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/code.html"
  not_derived_from:
    - "CPython source: Lib/code.py"
  notes:
    - "Clean-room code module. Do NOT import code."

error_model: python_exceptions

invariant theseus_code_cr.code2_interpreter:
  description: "InteractiveInterpreter can execute code"
  category: behavior
  kind: python_call_eq
  function: code2_interpreter
  args: []
  expected: true

invariant theseus_code_cr.code2_console:
  description: "InteractiveConsole exists and is instantiatable"
  category: behavior
  kind: python_call_eq
  function: code2_console
  args: []
  expected: true

invariant theseus_code_cr.code2_push:
  description: "push() returns True for incomplete input"
  category: behavior
  kind: python_call_eq
  function: code2_push
  args: []
  expected: true
