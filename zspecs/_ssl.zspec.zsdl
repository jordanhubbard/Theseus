spec: _ssl
version: ">=3.6"
backend: python_module(_ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "RFC 5246 — The Transport Layer Security (TLS) Protocol Version 1.2"
    - "RFC 8446 — The Transport Layer Security (TLS) Protocol Version 1.3"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "_ssl source: Modules/_ssl.c (CPython C extension wrapping OpenSSL)"
  not_derived_from:
    - "CPython source: Lib/ssl.py (Python wrapper)"
    - "OpenSSL source internals"
  notes:
    - "_ssl is the C extension that backs the ssl module. It wraps OpenSSL and exposes SSLError, MemoryBIO, SSLObject, and various constants."
    - "SSLError is a subclass of OSError, consistent with socket.error and other network-related exceptions in Python 3."
    - "MemoryBIO is an in-memory I/O buffer used for non-blocking TLS without an underlying socket."
    - "CERT_NONE == 0, CERT_OPTIONAL == 1, CERT_REQUIRED == 2 are stable integer constants defined in ssl.py and exposed through _ssl."
    - "HAS_TLS_UNIQUE is a bool indicating whether the tls-unique channel binding is supported; its type is always bool."
    - "OPENSSL_VERSION is a human-readable string identifying the OpenSSL version in use."
    - "OPENSSL_VERSION_NUMBER is an integer encoding the OpenSSL version numerically (e.g. 0x30000000 for OpenSSL 3.0)."
    - "All expected values verified by running Python 3.12 _ssl module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "_ssl.SSLError is raised for TLS protocol errors, certificate verification failures, and handshake failures. It inherits from OSError."
  stderr: "null"
  stickiness: "N/A — class and constant checks are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant _ssl.SSLError_name:
  description: "SSLError.__name__ == 'SSLError'"
  category: classnames
  kind: python_call_eq
  function: SSLError.__name__.__eq__
  args: ["SSLError"]
  expected: true

invariant _ssl.SSLError_base:
  description: "SSLError.__bases__[0].__name__ == 'OSError'"
  category: classnames
  kind: python_call_eq
  function: SSLError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "OSError"

invariant _ssl.MemoryBIO_name:
  description: "MemoryBIO.__name__ == 'MemoryBIO'"
  category: classnames
  kind: python_call_eq
  function: MemoryBIO.__name__.__eq__
  args: ["MemoryBIO"]
  expected: true

invariant _ssl.SSLObject_name:
  description: "SSLObject.__name__ == 'SSLObject'"
  category: classnames
  kind: python_call_eq
  function: SSLObject.__name__.__eq__
  args: ["SSLObject"]
  expected: true

# ---------------------------------------------------------------------------
# Certificate verification constants
# ---------------------------------------------------------------------------

invariant _ssl.CERT_NONE_value:
  description: "CERT_NONE == 0"
  category: constants
  kind: python_call_eq
  function: CERT_NONE.__eq__
  args: [0]
  expected: true

invariant _ssl.CERT_OPTIONAL_value:
  description: "CERT_OPTIONAL == 1"
  category: constants
  kind: python_call_eq
  function: CERT_OPTIONAL.__eq__
  args: [1]
  expected: true

invariant _ssl.CERT_REQUIRED_value:
  description: "CERT_REQUIRED == 2"
  category: constants
  kind: python_call_eq
  function: CERT_REQUIRED.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# OpenSSL version attribute type checks
# ---------------------------------------------------------------------------

invariant _ssl.OPENSSL_VERSION_type:
  description: "OPENSSL_VERSION.__class__.__name__ == 'str' — human-readable version string"
  category: constants
  kind: python_call_eq
  function: OPENSSL_VERSION.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant _ssl.OPENSSL_VERSION_NUMBER_type:
  description: "OPENSSL_VERSION_NUMBER.__class__.__name__ == 'int' — numeric version encoding"
  category: constants
  kind: python_call_eq
  function: OPENSSL_VERSION_NUMBER.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant _ssl.HAS_TLS_UNIQUE_type:
  description: "HAS_TLS_UNIQUE.__class__.__name__ == 'bool'"
  category: constants
  kind: python_call_eq
  function: HAS_TLS_UNIQUE.__class__.__name__.__eq__
  args: ["bool"]
  expected: true
