spec: struct_extra180
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.pack.__qualname__ == 'pack' — top-level function; qualname equals simple name."
    - "struct.unpack.__qualname__ == 'unpack' — top-level function."
    - "struct.pack_into.__qualname__ == 'pack_into' — top-level function."
    - "struct.unpack_from.__qualname__ == 'unpack_from' — top-level function."
    - "struct.iter_unpack.__name__ == 'iter_unpack' — len=11; iter_unpack is a C builtin_function_or_method."
    - "struct.iter_unpack.__module__ == '_struct' — iter_unpack is implemented in the _struct C extension."
    - "struct.Struct.pack.__name__ == 'pack' — Struct.pack method name."
    - "struct.Struct.unpack.__name__ == 'unpack' — Struct.unpack method name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct module-level function __qualname__ identity
#
# struct.pack.__qualname__       == 'pack'
# struct.unpack.__qualname__     == 'unpack'
# struct.pack_into.__qualname__  == 'pack_into'
# struct.unpack_from.__qualname__ == 'unpack_from'
#
# Top-level functions in struct have qualnames equal to their simple names
# since they are not nested inside any class or function scope.
# ---------------------------------------------------------------------------

table struct_extra180.struct_func_qualnames:
  description: "struct module-level function __qualname__ values; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: structqualnames180

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qualname_eq,
       pack.__qualname__.__eq__,
       ["pack"],
       true,
       "struct.pack.__qualname__.__eq__('pack') == True — top-level function; qualname equals name; new to extra180"]
    - [unpack_qualname_eq,
       unpack.__qualname__.__eq__,
       ["unpack"],
       true,
       "struct.unpack.__qualname__.__eq__('unpack') == True — top-level function; qualname equals name; new to extra180"]
    - [pack_into_qualname_eq,
       pack_into.__qualname__.__eq__,
       ["pack_into"],
       true,
       "struct.pack_into.__qualname__.__eq__('pack_into') == True — top-level function; qualname equals name; new to extra180"]
    - [unpack_from_qualname_eq,
       unpack_from.__qualname__.__eq__,
       ["unpack_from"],
       true,
       "struct.unpack_from.__qualname__.__eq__('unpack_from') == True — top-level function; qualname equals name; new to extra180"]

# ---------------------------------------------------------------------------
# Table 2: struct.iter_unpack __name__ and __module__ identity
#
# struct.iter_unpack.__name__   == 'iter_unpack' (len=11)
# struct.iter_unpack.__module__ == '_struct'
#
# iter_unpack is a C-level builtin_function_or_method implemented in the
# _struct extension module; it does not have __qualname__ like pure Python
# functions. Its __module__ is '_struct', not 'struct'.
# ---------------------------------------------------------------------------

table struct_extra180.struct_iter_unpack_identity:
  description: "struct.iter_unpack __name__ (len=11) and __module__ ('_struct') identity; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: structqualnames180

  columns: [id, function, args, expected, description]
  rows:
    - [iter_unpack_name_eq,
       iter_unpack.__name__.__eq__,
       ["iter_unpack"],
       true,
       "struct.iter_unpack.__name__.__eq__('iter_unpack') == True — len=11; C builtin function name; new to extra180"]
    - [iter_unpack_name_len,
       iter_unpack.__name__.__len__,
       [],
       11,
       "struct.iter_unpack.__name__.__len__() == 11 — 'iter_unpack' has 11 characters; new to extra180"]
    - [iter_unpack_module_eq,
       iter_unpack.__module__.__eq__,
       ["_struct"],
       true,
       "struct.iter_unpack.__module__.__eq__('_struct') == True — implemented in the _struct C extension; new to extra180"]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct method __name__ values
#
# struct.Struct.pack.__name__   == 'pack'
# struct.Struct.unpack.__name__ == 'unpack'
#
# The Struct class wraps a compiled format string. Its pack and unpack
# methods are C-level slot wrappers whose __name__ equals the short method
# name, not the qualified 'Struct.pack' form.
# ---------------------------------------------------------------------------

table struct_extra180.struct_class_method_names:
  description: "struct.Struct class method __name__ values for pack and unpack; new to extra180"
  kind: python_call_eq
  category: identity
  id_prefix: structqualnames180

  columns: [id, function, args, expected, description]
  rows:
    - [struct_pack_name_eq,
       Struct.pack.__name__.__eq__,
       ["pack"],
       true,
       "struct.Struct.pack.__name__.__eq__('pack') == True — Struct.pack method is named 'pack'; new to extra180"]
    - [struct_unpack_name_eq,
       Struct.unpack.__name__.__eq__,
       ["unpack"],
       true,
       "struct.Struct.unpack.__name__.__eq__('unpack') == True — Struct.unpack method is named 'unpack'; new to extra180"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra180
# ---------------------------------------------------------------------------

invariant struct_extra180.pack_qualname_is_pack:
  description: "struct.pack.__qualname__ == 'pack' — top-level function; qualname equals simple name; new to extra180"
  category: identity
  kind: python_call_eq
  function: pack.__qualname__.__eq__
  args: ["pack"]
  expected: true

invariant struct_extra180.unpack_qualname_is_unpack:
  description: "struct.unpack.__qualname__ == 'unpack' — top-level function; qualname equals simple name; new to extra180"
  category: identity
  kind: python_call_eq
  function: unpack.__qualname__.__eq__
  args: ["unpack"]
  expected: true

invariant struct_extra180.pack_into_qualname_is_pack_into:
  description: "struct.pack_into.__qualname__ == 'pack_into' — top-level function; qualname equals simple name; new to extra180"
  category: identity
  kind: python_call_eq
  function: pack_into.__qualname__.__eq__
  args: ["pack_into"]
  expected: true

invariant struct_extra180.unpack_from_qualname_is_unpack_from:
  description: "struct.unpack_from.__qualname__ == 'unpack_from' — top-level function; qualname equals simple name; new to extra180"
  category: identity
  kind: python_call_eq
