invariant struct_extra180.iter_unpack_name_is_iter_unpack:
  description: "struct.iter_unpack.__name__ == 'iter_unpack' — len=11; C builtin function; new to extra180"
  category: identity
  kind: python_call_eq
  function: iter_unpack.__name__.__eq__
  args: ["iter_unpack"]
  expected: true

invariant struct_extra180.iter_unpack_module_is_struct_c:
  description: "struct.iter_unpack.__module__ == '_struct' — implemented in the _struct C extension, not pure Python struct; new to extra180"
  category: identity
  kind: python_call_eq
  function: iter_unpack.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra180.struct_pack_name_is_pack:
  description: "struct.Struct.pack.__name__ == 'pack' — Struct.pack method is named 'pack'; new to extra180"
  category: identity
  kind: python_call_eq
  function: Struct.pack.__name__.__eq__
  args: ["pack"]
  expected: true

invariant struct_extra180.struct_unpack_name_is_unpack:
  description: "struct.Struct.unpack.__name__ == 'unpack' — Struct.unpack method is named 'unpack'; new to extra180"
  category: identity
