spec: socket_extra182
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra181.zspec.zsdl — prior extras."
  notes:
    - "socket.error.__name__ == 'OSError' — socket.error is a direct alias for the built-in OSError."
    - "socket.timeout.__name__ == 'TimeoutError' — socket.timeout is a direct alias for built-in TimeoutError."
    - "socket.herror.__name__ == 'herror' — len=6; host-resolution error defined in socket module."
    - "socket.herror.__module__ == 'socket' — herror is defined in the socket module namespace."
    - "socket.herror.__bases__[0].__name__ == 'OSError' — herror inherits from OSError."
    - "socket.herror.__qualname__ == 'herror' — top-level class, qualname equals name."
    - "socket.gaierror.__name__ == 'gaierror' — len=8; getaddrinfo error defined in socket module."
    - "socket.gaierror.__module__ == 'socket' — gaierror is defined in the socket module namespace."
    - "socket.gaierror.__bases__[0].__name__ == 'OSError' — gaierror inherits from OSError."
    - "socket.gaierror.__qualname__ == 'gaierror' — top-level class, qualname equals name."
    - "socket.error.__name__.__len__() == 7 — 'OSError' has 7 characters."
    - "socket.timeout.__name__.__len__() == 12 — 'TimeoutError' has 12 characters."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket.error and socket.timeout alias identity
#
# socket.error.__name__          == 'OSError'      (socket.error is an alias for OSError)
# socket.error.__qualname__      == 'OSError'
# socket.timeout.__name__        == 'TimeoutError' (socket.timeout is an alias for TimeoutError)
# socket.timeout.__qualname__    == 'TimeoutError'
#
# These are direct aliases to built-in exception types. New to extra182.
# ---------------------------------------------------------------------------

table socket_extra182.error_timeout_alias_identity:
  description: "socket.error and socket.timeout alias identity as OSError and TimeoutError; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: socketerr182

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,
       error.__name__.__eq__,
       ["OSError"],
       true,
       "socket.error.__name__.__eq__('OSError') == True — socket.error is a direct alias for built-in OSError; new to extra182"]
    - [error_qualname_eq,
       error.__qualname__.__eq__,
       ["OSError"],
       true,
       "socket.error.__qualname__.__eq__('OSError') == True — qualname confirms the alias points to OSError; new to extra182"]
    - [timeout_name_eq,
       timeout.__name__.__eq__,
       ["TimeoutError"],
       true,
       "socket.timeout.__name__.__eq__('TimeoutError') == True — socket.timeout is a direct alias for built-in TimeoutError; new to extra182"]
    - [timeout_qualname_eq,
       timeout.__qualname__.__eq__,
       ["TimeoutError"],
       true,
       "socket.timeout.__qualname__.__eq__('TimeoutError') == True — qualname confirms the alias points to TimeoutError; new to extra182"]

# ---------------------------------------------------------------------------
# Table 2: socket.herror class identity
#
# socket.herror.__name__           == 'herror'  (len=6)
# socket.herror.__module__         == 'socket'
# socket.herror.__qualname__       == 'herror'
# socket.herror.__bases__[0].__name__ == 'OSError'
#
# herror is raised for host-resolution failures (e.g., gethostbyname). New to extra182.
# ---------------------------------------------------------------------------

table socket_extra182.herror_identity:
  description: "socket.herror __name__, __module__, __qualname__, and base class identity; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: socketerr182

  columns: [id, function, args, expected, description]
  rows:
    - [herror_name_eq,
       herror.__name__.__eq__,
       ["herror"],
       true,
       "socket.herror.__name__.__eq__('herror') == True — host-resolution error class is named 'herror'; len=6; new to extra182"]
    - [herror_name_len,
       herror.__name__.__len__,
       [],
       6,
       "socket.herror.__name__.__len__() == 6 — 'herror' has 6 characters; new to extra182"]
    - [herror_module_eq,
       herror.__module__.__eq__,
       ["socket"],
       true,
       "socket.herror.__module__.__eq__('socket') == True — herror is defined in the socket module; new to extra182"]
    - [herror_base_name_eq,
       "herror.__bases__[0].__name__.__eq__",
       ["OSError"],
       true,
       "socket.herror.__bases__[0].__name__.__eq__('OSError') == True — herror inherits from OSError; new to extra182"]

# ---------------------------------------------------------------------------
# Table 3: socket.gaierror class identity
#
# socket.gaierror.__name__           == 'gaierror'  (len=8)
# socket.gaierror.__module__         == 'socket'
# socket.gaierror.__qualname__       == 'gaierror'
# socket.gaierror.__bases__[0].__name__ == 'OSError'
#
# gaierror is raised for getaddrinfo/getnameinfo failures. New to extra182.
# ---------------------------------------------------------------------------

table socket_extra182.gaierror_identity:
  description: "socket.gaierror __name__, __module__, __qualname__, and base class identity; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: socketerr182

  columns: [id, function, args, expected, description]
  rows:
    - [gaierror_name_eq,
       gaierror.__name__.__eq__,
       ["gaierror"],
       true,
       "socket.gaierror.__name__.__eq__('gaierror') == True — address-info error class is named 'gaierror'; len=8; new to extra182"]
    - [gaierror_name_len,
       gaierror.__name__.__len__,
       [],
       8,
       "socket.gaierror.__name__.__len__() == 8 — 'gaierror' has 8 characters; new to extra182"]
    - [gaierror_module_eq,
       gaierror.__module__.__eq__,
       ["socket"],
       true,
       "socket.gaierror.__module__.__eq__('socket') == True — gaierror is defined in the socket module; new to extra182"]
    - [gaierror_base_name_eq,
       "gaierror.__bases__[0].__name__.__eq__",
       ["OSError"],
       true,
       "socket.gaierror.__bases__[0].__name__.__eq__('OSError') == True — gaierror inherits from OSError; new to extra182"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra182
# ---------------------------------------------------------------------------

invariant socket_extra182.error_name_is_OSError:
  description: "socket.error.__name__ == 'OSError' — socket.error is a direct alias for the built-in OSError; new to extra182"
  category: identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

invariant socket_extra182.timeout_name_is_TimeoutError:
  description: "socket.timeout.__name__ == 'TimeoutError' — socket.timeout is a direct alias for built-in TimeoutError; new to extra182"
  category: identity
  kind: python_call_eq
  function: timeout.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant socket_extra182.herror_name_is_herror:
  description: "socket.herror.__name__ == 'herror' — len=6; raised for host-resolution failures; new to extra182"
  category: identity
  kind: python_call_eq
  function: herror.__name__.__eq__
  args: ["herror"]
  expected: true

invariant socket_extra182.herror_module_is_socket:
  description: "socket.herror.__module__ == 'socket' — herror is defined in the socket module namespace; new to extra182"
  category: identity
  kind: python_call_eq
  function: herror.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra182.herror_base_is_OSError:
  description: "socket.herror.__bases__[0].__name__ == 'OSError' — herror inherits directly from OSError; new to extra182"
  category: identity
  kind: python_call_eq
  function: "herror.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant socket_extra182.gaierror_name_is_gaierror:
  description: "socket.gaierror.__name__ == 'gaierror' — len=8; raised for getaddrinfo/getnameinfo failures; new to extra182"
  category: identity
  kind: python_call_eq
  function: gaierror.__name__.__eq__
  args: ["gaierror"]
  expected: true

invariant socket_extra182.gaierror_module_is_socket:
  description: "socket.gaierror.__module__ == 'socket' — gaierror is defined in the socket module namespace; new to extra182"
  category: identity
  kind: python_call_eq
  function: gaierror.__module__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra182.gaierror_base_is_OSError:
  description: "socket.gaierror.__bases__[0].__name__ == 'OSError' — gaierror inherits directly from OSError; new to extra182"
  category: identity
  kind: python_call_eq
  function: "gaierror.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

invariant socket_extra182.herror_qualname_is_herror:
  description: "socket.herror.__qualname__ == 'herror' — top-level class, qualname equals name; new to extra182"
  category: identity
  kind: python_call_eq
  function: herror.__qualname__.__eq__
  args: ["herror"]
  expected: true

invariant socket_extra182.gaierror_qualname_is_gaierror:
  description: "socket.gaierror.__qualname__ == 'gaierror' — top-level class, qualname equals name; new to extra182"
  category: identity
  kind: python_call_eq
  function: gaierror.__qualname__.__eq__
  args: ["gaierror"]
  expected: true
