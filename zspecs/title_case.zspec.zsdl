spec: title_case
version: ">=3.0.0"
backend: node(title-case)

docs: https://www.npmjs.com/package/title-case

provenance:
  derived_from:
    - "title-case README — https://www.npmjs.com/package/title-case"
    - "Test vectors verified with title-case@3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "title-case source"
  notes:
    - "title-case is an npm package. Install: npm install title-case@3"
    - "title-case v3 is CommonJS. v4+ is ESM-only."
    - "titleCase(str) capitalises the first letter of each whitespace-separated word without lowercasing the rest."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns title-cased string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table title_case.titleCase:
  kind: node_module_call_eq
  function: titleCase
  category: titleCase
  id_prefix: tc

  columns: [id, args, expected]
  rows:
    - [basic,    ["hello world"],      "Hello World"]
    - [three,    ["foo bar baz"],      "Foo Bar Baz"]
    - [single,   ["hello"],            "Hello"]
    - [upper,    ["HELLO WORLD"],      "HELLO WORLD"]
    - [mixed,    ["hello WORLD"],      "Hello WORLD"]
