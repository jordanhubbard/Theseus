spec: re_extra206
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra205.zspec.zsdl — covers re.__spec__ deeper attributes"
    - "re_extra.zspec.zsdl — covers Pattern/Match/error class metadata, flag constants, match/search/sub/split/findall behavior"
  notes:
    - "re has __all__; re.__all__.__class__.__name__ == 'list'; confirmed Python 3.14.3 macOS."
    - "re.__all__.__len__() == 31; confirmed Python 3.14.3 macOS."
    - "All ten target names are present in re.__all__: compile, match, search, sub, split, findall, finditer, Pattern, Match, error."
    - "re.__all__.__contains__(name) returns True for all ten names; confirmed Python 3.14.3 macOS."
    - "re.__all__ also contains: fullmatch, subn, purge, escape, A, I, L, M, S, X, U, ASCII, IGNORECASE, LOCALE, MULTILINE, DOTALL, VERBOSE, UNICODE, NOFLAG, RegexFlag, PatternError."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.__all__ class name and length
# __class__.__name__ == 'list', __len__() == 31
# ---------------------------------------------------------------------------

table re_extra206.all_class_and_len:
  description: "re.__all__ type identity and length"
  kind: python_call_eq
  category: all_identity
  id_prefix: reall206

  columns: [id, function, args, expected, description]
  rows:
    - [class_name_eq,  re.__all__.__class__.__name__.__eq__,  ["list"], true,  "re.__all__.__class__.__name__ == 'list'; re.__all__ is a plain list; confirmed Python 3.14.3 macOS"]
    - [class_name_len, re.__all__.__class__.__name__.__len__,  [],       4,     "re.__all__.__class__.__name__.__len__() == 4; 'list' has l(1)i(2)s(3)t(4); confirmed Python 3.14.3 macOS"]
    - [len_eq,         re.__all__.__len__,                    [],       31,    "re.__all__.__len__() == 31; re exports 31 public names; confirmed Python 3.14.3 macOS"]
    - [len_gt_ten,     re.__all__.__len__,                    [],       31,    "re.__all__.__len__() == 31; exports exceed ten; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.__all__ membership — function names
# compile, match, search, sub, split, findall, finditer
# ---------------------------------------------------------------------------

table re_extra206.all_membership_functions:
  description: "re.__all__ membership checks for public function names"
  kind: python_call_eq
  category: all_membership
  id_prefix: reall206

  columns: [id, function, args, expected, description]
  rows:
    - [compile_in,   re.__all__.__contains__,  ["compile"],   true,  "re.__all__.__contains__('compile') == True; compile builds a compiled Pattern object; confirmed Python 3.14.3 macOS"]
    - [match_in,     re.__all__.__contains__,  ["match"],     true,  "re.__all__.__contains__('match') == True; match tries to apply the pattern at the start of string; confirmed Python 3.14.3 macOS"]
    - [search_in,    re.__all__.__contains__,  ["search"],    true,  "re.__all__.__contains__('search') == True; search scans through string looking for a match; confirmed Python 3.14.3 macOS"]
    - [sub_in,       re.__all__.__contains__,  ["sub"],       true,  "re.__all__.__contains__('sub') == True; sub replaces matches with a replacement string; confirmed Python 3.14.3 macOS"]
    - [split_in,     re.__all__.__contains__,  ["split"],     true,  "re.__all__.__contains__('split') == True; split splits string by the occurrences of pattern; confirmed Python 3.14.3 macOS"]
    - [findall_in,   re.__all__.__contains__,  ["findall"],   true,  "re.__all__.__contains__('findall') == True; findall returns all non-overlapping matches; confirmed Python 3.14.3 macOS"]
    - [finditer_in,  re.__all__.__contains__,  ["finditer"],  true,  "re.__all__.__contains__('finditer') == True; finditer returns an iterator of match objects; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.__all__ membership — types and exception
# Pattern, Match, error
# ---------------------------------------------------------------------------

table re_extra206.all_membership_types:
  description: "re.__all__ membership checks for Pattern, Match, and error"
  kind: python_call_eq
  category: all_membership
  id_prefix: reall206

  columns: [id, function, args, expected, description]
  rows:
    - [Pattern_in, re.__all__.__contains__,  ["Pattern"], true,  "re.__all__.__contains__('Pattern') == True; Pattern is the type of compiled regex objects; confirmed Python 3.14.3 macOS"]
    - [Match_in,   re.__all__.__contains__,  ["Match"],   true,  "re.__all__.__contains__('Match') == True; Match is the type of match objects returned by match/search; confirmed Python 3.14.3 macOS"]
    - [error_in,   re.__all__.__contains__,  ["error"],   true,  "re.__all__.__contains__('error') == True; error is the exception raised for invalid patterns; confirmed Python 3.14.3 macOS"]
    - [len_check,  re.__all__.__len__,        [],          31,    "re.__all__.__len__() == 31 cross-check; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra206.all_class_name_eq:
  description: "re.__all__.__class__.__name__ == 'list' — re.__all__ is a plain list; confirmed Python 3.14.3 macOS"
  category: all_identity
  kind: python_call_eq
  function: re.__all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant re_extra206.all_len_eq:
  description: "re.__all__.__len__() == 31 — re exports 31 public names; confirmed Python 3.14.3 macOS"
  category: all_identity
  kind: python_call_eq
  function: re.__all__.__len__
  args: []
  expected: 31

invariant re_extra206.all_contains_compile:
  description: "re.__all__.__contains__('compile') == True — compile is re's primary API entry point; confirmed Python 3.14.3 macOS"
  category: all_membership
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["compile"]
  expected: true

invariant re_extra206.all_contains_match:
  description: "re.__all__.__contains__('match') == True — match is one of the core regex functions; confirmed Python 3.14.3 macOS"
  category: all_membership
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["match"]
  expected: true

invariant re_extra206.all_contains_Pattern:
  description: "re.__all__.__contains__('Pattern') == True — Pattern is the compiled regex type; confirmed Python 3.14.3 macOS"
  category: all_membership
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["Pattern"]
  expected: true

invariant re_extra206.all_contains_Match:
  description: "re.__all__.__contains__('Match') == True — Match is the match result type; confirmed Python 3.14.3 macOS"
  category: all_membership
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["Match"]
  expected: true

invariant re_extra206.all_contains_error:
  description: "re.__all__.__contains__('error') == True — error is raised for invalid regex patterns; confirmed Python 3.14.3 macOS"
  category: all_membership
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["error"]
  expected: true

invariant re_extra206.all_contains_finditer:
  description: "re.__all__.__contains__('finditer') == True — finditer returns an iterator over all match objects; confirmed Python 3.14.3 macOS"
  category: all_membership
  kind: python_call_eq
  function: re.__all__.__contains__
  args: ["finditer"]
  expected: true

