spec: pretty_bytes
version: ">=5.0.0"
backend: node(pretty-bytes)

docs: https://github.com/sindresorhus/pretty-bytes#readme

provenance:
  derived_from:
    - "pretty-bytes README — https://github.com/sindresorhus/pretty-bytes#readme"
    - "Test vectors verified with pretty-bytes@5.6.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "pretty-bytes source: index.js"
  notes:
    - "pretty-bytes@5 (CJS) exports the prettyBytes function as the module default."
    - "prettyBytes(bytes) returns a human-readable string using SI units."
    - "0 bytes -> '0 B'; 1024 -> '1.02 kB'; 1000000 -> '1 MB'."
    - "pretty-bytes@6+ is ESM-only; use @5 for CJS compatibility."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a human-readable string. No errors for numeric inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table pretty_bytes.format:
  kind: node_module_call_eq
  function: ~
  category: format
  id_prefix: pb

  columns: [id, args, expected]
  rows:
    - [zero,    [0],        "0 B"]
    - [one_kb,  [1024],     "1.02 kB"]
    - [one_mb,  [1000000],  "1 MB"]
