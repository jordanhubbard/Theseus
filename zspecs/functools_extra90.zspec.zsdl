invariant functools_extra90.cached_property_bases0_name:
  description: "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property directly inherits from object; wave 249; new to extra90"
  kind: python_call_eq
  function: "cached_property.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra90.cached_property_mro_len:
