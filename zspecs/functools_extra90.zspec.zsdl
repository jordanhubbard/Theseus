spec: functools_extra90
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra89

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra89.zspec.zsdl."
    - "This spec covers: functools cached_property/singledispatchmethod/partialmethod/partial class attributes — __bases__, __mro__, __qualname__, __name__, __module__ (Wave 249)."
    - "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property is a pure-Python class with single base. Verified with Python 3.14.3."
    - "functools.cached_property.__mro__.__len__() == 2 — [cached_property, object]. Verified with Python 3.14.3."
    - "functools.cached_property.__qualname__.__len__() == 15 — 'cached_property' is 15 chars. Verified with Python 3.14.3."
    - "functools.cached_property.__name__.__len__() == 15 — 'cached_property' is 15 chars. Verified with Python 3.14.3."
    - "functools.cached_property.__module__.__len__() == 9 — 'functools' is 9 chars. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__bases__[0].__name__ == 'object' — singledispatchmethod has single base. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__mro__.__len__() == 2 — [singledispatchmethod, object]. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__qualname__.__len__() == 20 — 'singledispatchmethod' is 20 chars. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__name__.__len__() == 20 — 'singledispatchmethod' is 20 chars. Verified with Python 3.14.3."
    - "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod has single base. Verified with Python 3.14.3."
    - "functools.partialmethod.__mro__.__len__() == 2 — [partialmethod, object]. Verified with Python 3.14.3."
    - "functools.partialmethod.__qualname__.__len__() == 13 — 'partialmethod' is 13 chars. Verified with Python 3.14.3."
    - "functools.partialmethod.__name__.__len__() == 13 — 'partialmethod' is 13 chars. Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object' — partial is a C extension type with single base. Verified with Python 3.14.3."
    - "functools.partial.__mro__.__len__() == 2 — [partial, object]. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# cached_property class attribute group 1 — __bases__/__mro__/__qualname__ — extra90
#
# Wave 249 theme: cached_property/singledispatchmethod/partialmethod/partial class attrs.
#
# functools.cached_property.__bases__[0].__name__    == 'object'
# functools.cached_property.__mro__.__len__()        == 2
# functools.cached_property.__qualname__.__len__()   == 15
# functools.cached_property.__name__.__len__()       == 15
#
# No prior functools spec checks cached_property __bases__/__mro__/__qualname__.__len__ via functoolsextra90. New to extra90.
# ---------------------------------------------------------------------------

table functools_extra90.cached_property_attrs_group1:
  description: "cached_property __bases__[0].__name__/mro len/qualname len/name len; wave 249 functools class attrs; new to extra90"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra90

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_bases0_name_eq_object,
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property is a pure-Python class in Lib/functools.py; it inherits directly from object with no intermediate base classes; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; no prior functools spec checks cached_property.__bases__[0].__name__ via functoolsextra90; new to extra90"]
    - [cached_property_mro_len_eq_2,
       "cached_property.__mro__.__len__",
       [],
       2,
       "functools.cached_property.__mro__.__len__() == 2 — cached_property MRO is [cached_property, object]; a simple single-inheritance chain; tuple.__len__() returns 2; no prior functools spec checks cached_property.__mro__.__len__ via functoolsextra90; new to extra90"]
    - [cached_property_qualname_len_eq_15,
       "cached_property.__qualname__.__len__",
       [],
       15,
       "functools.cached_property.__qualname__.__len__() == 15 — __qualname__ is 'cached_property' (15 chars: c,a,c,h,e,d,_,p,r,o,p,e,r,t,y); str.__len__() returns 15; no prior functools spec checks cached_property.__qualname__.__len__ via functoolsextra90; new to extra90"]
    - [cached_property_name_len_eq_15,
       "cached_property.__name__.__len__",
       [],
       15,
       "functools.cached_property.__name__.__len__() == 15 — __name__ is 'cached_property' (15 chars); str.__len__() returns 15; no prior functools spec checks cached_property.__name__.__len__ via functoolsextra90; new to extra90"]

