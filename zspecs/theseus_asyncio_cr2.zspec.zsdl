spec: theseus_asyncio_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_asyncio_cr2)
blocks: asyncio

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
    - "PEP 3156 — Asynchronous IO Support"
  notes:
    - "Clean-room extended asyncio utilities. Do NOT import asyncio."
    - "Future: represents a pending result; set_result(v) and result() methods."
    - "iscoroutine(obj): return True if obj is a coroutine object."
    - "isfuture(obj): return True if obj is a Future-like object."
    - "asyncio2_future_result(): f=Future(); f.set_result(42); f.result() == 42."
    - "asyncio2_iscoroutine(): define async def coro(): pass; iscoroutine(coro()) == True."
    - "asyncio2_isfuture(): isfuture(Future()) == True."
    - "Zero-arg invariant signatures — def asyncio2_future_result(): return hardcoded_result"
    - "Future: stores a result value; raises InvalidStateError if result() before set_result()."
    - "iscoroutine: check via inspect.iscoroutine equivalent — hasattr and coroutine flag."
    - "isfuture: check for _asyncio_future_blocking attr or isinstance of Future base."
    - "Export: Future, iscoroutine(obj), isfuture(obj), run(coro), get_event_loop()."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_asyncio_cr2.future_result:
  description: "Future().set_result(42); result() == 42"
  category: Future
  kind: python_call_eq
  function: asyncio2_future_result
  args: []
  expected: 42

invariant theseus_asyncio_cr2.iscoroutine:
  description: "iscoroutine(async def coro(): pass; coro()) == True"
  category: iscoroutine
  kind: python_call_eq
  function: asyncio2_iscoroutine
  args: []
  expected: true

invariant theseus_asyncio_cr2.isfuture:
  description: "isfuture(Future()) == True"
  category: isfuture
  kind: python_call_eq
  function: asyncio2_isfuture
  args: []
  expected: true
