spec: object_depth
version: ">=0.0.3"
backend: node(object-depth)

docs: https://www.npmjs.com/package/object-depth

provenance:
  derived_from:
    - "object-depth README — https://www.npmjs.com/package/object-depth"
    - "Test vectors verified with object-depth via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "object-depth source"
  notes:
    - "object-depth is an npm package. Install: npm install object-depth"
    - "Returns the nesting depth of an object. A flat object has depth 1."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a non-negative integer."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_depth.depth:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: odepth

  columns: [id, args, expected]
  rows:
    - [flat,   [{"a": 1}],              1]
    - [two,    [{"a": {"b": 1}}],       2]
    - [three,  [{"a": {"b": {"c": 1}}}],  3]
    - [empty,  [{}],                    1]
