spec: dataloader
version: ">=2.0.0"
backend: node(dataloader)

docs: https://github.com/graphql/dataloader#readme

provenance:
  derived_from:
    - "DataLoader README — https://github.com/graphql/dataloader#readme"
    - "Test vectors verified with dataloader via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "dataloader source"
  notes:
    - "Batching/caching layer in front of slow data sources — ubiquitous in GraphQL servers."
    - "Install: npm install dataloader"
    - "v2 CJS; module export IS the DataLoader class."
    - "Constructor takes (batchLoadFn, options); function arg can't be passed via JSON, so spec covers shape only."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Per-load promises reject if batchLoadFn throws or returns mismatched array length."
  stderr: "null"
  stickiness: "Loaders maintain a per-instance cache; clear() / clearAll() / prime()."
  codes: {}

invariant dataloader.module_is_class:
  description: "Module export is the DataLoader class (Function)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant dataloader.constructor_arity:
  description: "DataLoader takes (batchLoadFn, options) — function.length 2"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 2

invariant dataloader.prototype_has_load:
  description: "DataLoader.prototype.load is defined (callable instance method)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.load.constructor.name"}
  expected: "Function"

invariant dataloader.prototype_has_loadMany:
  description: "DataLoader.prototype.loadMany is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.loadMany.constructor.name"}
  expected: "Function"

invariant dataloader.prototype_has_clear:
  description: "DataLoader.prototype.clear is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.clear.constructor.name"}
  expected: "Function"

invariant dataloader.prototype_has_clearAll:
  description: "DataLoader.prototype.clearAll is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.clearAll.constructor.name"}
  expected: "Function"

invariant dataloader.prototype_has_prime:
  description: "DataLoader.prototype.prime is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "prototype.prime.constructor.name"}
  expected: "Function"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T16:57:01Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
