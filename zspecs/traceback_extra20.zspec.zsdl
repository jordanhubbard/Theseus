spec: traceback_extra20
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends prior traceback specs through traceback_extra19.zspec.zsdl."
    - "traceback_extra18 covers: module-level function __qualname__ values (format_exc, format_tb, format_stack, print_exc, print_tb, extract_tb, extract_stack) and class __qualname__ for TracebackException and StackSummary."
    - "traceback_extra19 covers: class-bound method __qualname__ for TracebackException.from_exception/format/format_exception_only, StackSummary.extract/from_list/format, and FrameSummary class __qualname__."
    - "Focus: __module__ attributes for TracebackException, StackSummary, and FrameSummary classes; __module__ attributes for module-level functions print_exc, format_exc, print_tb; and FrameSummary.__init__.__qualname__."
    - "traceback.TracebackException.__module__ == 'traceback' — top-level class defined in the traceback module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.StackSummary.__module__ == 'traceback' — top-level class defined in the traceback module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.FrameSummary.__module__ == 'traceback' — top-level class defined in the traceback module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.print_exc.__module__ == 'traceback' — module-level function; __module__ equals the module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.format_exc.__module__ == 'traceback' — module-level function; __module__ equals the module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.print_tb.__module__ == 'traceback' — module-level function; __module__ equals the module name. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "traceback.FrameSummary.__init__.__qualname__ == 'FrameSummary.__init__' — constructor method qualname includes owning class. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# traceback class __module__ values
#
# No prior traceback spec records __module__ for TracebackException,
# StackSummary, or FrameSummary. All three are top-level classes defined in
# the traceback module, so __module__ == 'traceback'.
# ---------------------------------------------------------------------------

invariant traceback_extra20.TracebackException.module:
  description: "traceback.TracebackException.__module__ == 'traceback' — class defined in the traceback module"
  category: class_module
  kind: python_call_eq
  function: TracebackException.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra20.StackSummary.module:
  description: "traceback.StackSummary.__module__ == 'traceback' — class defined in the traceback module"
  category: class_module
  kind: python_call_eq
  function: StackSummary.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra20.FrameSummary.module:
  description: "traceback.FrameSummary.__module__ == 'traceback' — class defined in the traceback module"
  category: class_module
  kind: python_call_eq
  function: FrameSummary.__module__.__eq__
  args: ["traceback"]
  expected: true

# ---------------------------------------------------------------------------
# traceback module-level function __module__ values
#
# Module-level functions have __module__ equal to the module name string.
# No prior traceback spec records __module__ for print_exc, format_exc, or
# print_tb. These were covered for __qualname__ in traceback_extra18 but
# not for __module__.
# ---------------------------------------------------------------------------

invariant traceback_extra20.print_exc.module:
  description: "traceback.print_exc.__module__ == 'traceback' — module-level function defined in traceback"
  category: function_module
  kind: python_call_eq
  function: print_exc.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra20.format_exc.module:
  description: "traceback.format_exc.__module__ == 'traceback' — module-level function defined in traceback"
  category: function_module
  kind: python_call_eq
  function: format_exc.__module__.__eq__
  args: ["traceback"]
  expected: true

invariant traceback_extra20.print_tb.module:
  description: "traceback.print_tb.__module__ == 'traceback' — module-level function defined in traceback"
  category: function_module
  kind: python_call_eq
  function: print_tb.__module__.__eq__
  args: ["traceback"]
  expected: true

# ---------------------------------------------------------------------------
# traceback.FrameSummary.__init__.__qualname__
#
# FrameSummary.__init__ is the constructor. Its __qualname__ takes the form
# 'FrameSummary.__init__' (class-prefixed). No prior traceback spec records
# __qualname__ for FrameSummary.__init__.
# ---------------------------------------------------------------------------

invariant traceback_extra20.FrameSummary.__init__.qualname:
  description: "traceback.FrameSummary.__init__.__qualname__ == 'FrameSummary.__init__' — constructor qualname includes owning class"
  category: method_qualname
  kind: python_call_eq
  function: "FrameSummary.__init__.__qualname__.__eq__"
  args: ["FrameSummary.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all seven __module__ and method __qualname__ checks
#
# Covers TracebackException/StackSummary/FrameSummary class __module__ (3),
# print_exc/format_exc/print_tb function __module__ (3), and
# FrameSummary.__init__.__qualname__ (1).
# ---------------------------------------------------------------------------

table traceback_extra20.modules_and_init_qualname:
  description: "__module__ values for traceback classes and functions, and FrameSummary.__init__.__qualname__"
  kind: python_call_eq
  category: class_module

  columns: [id, function, args, expected]
  rows:
    - [TracebackException_module,  TracebackException.__module__.__eq__,       ["traceback"],          true]
    - [StackSummary_module,        StackSummary.__module__.__eq__,             ["traceback"],          true]
    - [FrameSummary_module,        FrameSummary.__module__.__eq__,             ["traceback"],          true]
    - [print_exc_module,           print_exc.__module__.__eq__,                ["traceback"],          true]
    - [format_exc_module,          format_exc.__module__.__eq__,               ["traceback"],          true]
    - [print_tb_module,            print_tb.__module__.__eq__,                 ["traceback"],          true]
    - [FrameSummary_init_qualname, "FrameSummary.__init__.__qualname__.__eq__", ["FrameSummary.__init__"], true]
