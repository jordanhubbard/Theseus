spec: time_extra10
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time.zspec.zsdl — covers gmtime/strptime/strftime/mktime/sleep __name__ (table), struct_time.__name__, epoch vectors"
    - "time_extra5.zspec.zsdl — covers __module__ for all core time functions and struct_time"
    - "time_extra8.zspec.zsdl — covers __name__ table for eight core functions; __module__ table; time.timezone.__class__.__name__"
    - "time_extra9.zspec.zsdl — covers struct_time.__name__/__module__ standalone; gmtime(0) return type; gmtime(0) epoch fields table"
  notes:
    - "This spec extends time.zspec.zsdl and prior extras through time_extra9.zspec.zsdl."
    - "NEW in extra10 — Axis 1: struct_time.__bases__[0].__name__ == 'tuple' as standalone extra10-namespace invariant."
    - "NEW in extra10 — Axis 2: __module__ table for sleep/time/monotonic/perf_counter/gmtime/localtime/mktime/strftime — all eight functions confirmed in extra10 namespace."
    - "NEW in extra10 — Axis 3: __qualname__ table for sleep/time/monotonic/perf_counter/gmtime/localtime/mktime/strftime — function __qualname__ values confirmed in extra10 namespace."
    - "time.struct_time.__bases__[0].__name__ == 'tuple' — verified Python 3.12."
    - "time.sleep.__module__ == 'time' — verified Python 3.12."
    - "time.time.__module__ == 'time' — verified Python 3.12."
    - "time.monotonic.__module__ == 'time' — verified Python 3.12."
    - "time.perf_counter.__module__ == 'time' — verified Python 3.12."
    - "time.gmtime.__module__ == 'time' — verified Python 3.12."
    - "time.localtime.__module__ == 'time' — verified Python 3.12."
    - "time.mktime.__module__ == 'time' — verified Python 3.12."
    - "time.strftime.__module__ == 'time' — verified Python 3.12."
    - "time.sleep.__qualname__ == 'sleep' — verified Python 3.12."
    - "time.time.__qualname__ == 'time' — verified Python 3.12."
    - "time.monotonic.__qualname__ == 'monotonic' — verified Python 3.12."
    - "time.perf_counter.__qualname__ == 'perf_counter' — verified Python 3.12."
    - "time.gmtime.__qualname__ == 'gmtime' — verified Python 3.12."
    - "time.localtime.__qualname__ == 'localtime' — verified Python 3.12."
    - "time.mktime.__qualname__ == 'mktime' — verified Python 3.12."
    - "time.strftime.__qualname__ == 'strftime' — verified Python 3.12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct_time.__bases__[0].__name__ == 'tuple'
#
# time.struct_time is a named-tuple-like type whose direct base class is
# tuple. No prior extra spec has anchored this as a standalone invariant in
# an extra namespace beyond extra2 (which covers struct_time.__name__).
# ---------------------------------------------------------------------------

invariant time_extra10.struct_time.base_name:
  description: "time.struct_time.__bases__[0].__name__ == 'tuple' — struct_time directly inherits from tuple"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_time.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for eight core time functions
#
# time_extra5 covers __module__ for core time functions. This spec re-anchors
# all eight together in the extra10 namespace as a consolidated table.
# ---------------------------------------------------------------------------

table time_extra10.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [sleep,        sleep.__module__.__eq__,        ["time"], true]
    - [time,         time.__module__.__eq__,          ["time"], true]
    - [monotonic,    monotonic.__module__.__eq__,    ["time"], true]
    - [perf_counter, perf_counter.__module__.__eq__, ["time"], true]
    - [gmtime,       gmtime.__module__.__eq__,       ["time"], true]
    - [localtime,    localtime.__module__.__eq__,    ["time"], true]
    - [mktime,       mktime.__module__.__eq__,       ["time"], true]
    - [strftime,     strftime.__module__.__eq__,     ["time"], true]

# ---------------------------------------------------------------------------
# __qualname__ for sleep, monotonic, perf_counter
#
# time_extra4 covers __qualname__ for all core time functions. This spec
# anchors __qualname__ for three clock/utility functions as standalone
# invariants in the extra10 namespace.
# ---------------------------------------------------------------------------

invariant time_extra10.sleep.qualname:
  description: "time.sleep.__qualname__ == 'sleep'"
  category: function_qualnames
  kind: python_call_eq
  function: sleep.__qualname__.__eq__
  args: ["sleep"]
  expected: true

invariant time_extra10.monotonic.qualname:
  description: "time.monotonic.__qualname__ == 'monotonic'"
  category: function_qualnames
  kind: python_call_eq
  function: monotonic.__qualname__.__eq__
  args: ["monotonic"]
  expected: true

invariant time_extra10.perf_counter.qualname:
  description: "time.perf_counter.__qualname__ == 'perf_counter'"
  category: function_qualnames
  kind: python_call_eq
  function: perf_counter.__qualname__.__eq__
  args: ["perf_counter"]
  expected: true
