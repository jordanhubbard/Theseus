spec: os_path_extra13
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py"
  notes:
    - "This spec extends os_path.zspec.zsdl through os_path_extra12.zspec.zsdl."
    - "os_path_extra12 covers join multi-component and edge cases; normpath slash-collapse, dot-removal, and dotdot-resolution."
    - "os_path_extra11 covers join dot-prefix and abs-mid-with-suffix; normpath leading-dot-slash, deep-abs two dotdots, rel two dotdots; return-type checks for join/normpath/dirname/basename/relpath."
    - "os_path_extra10 covers normpath '/a/b/../c', '/a/b/./c', '/a//b', '/a/b/c/../..'."
    - "NOT yet covered: basename('') == '' — empty string input."
    - "NOT yet covered: dirname('') == '' — empty string input."
    - "NOT yet covered: basename('/') == '' — root has no basename."
    - "NOT yet covered: dirname('/') == '/' — root dirname is itself."
    - "NOT yet covered: split('') == ('', '') — split of empty string."
    - "NOT yet covered: split('/') == ('/', '') — split of root."
    - "NOT yet covered: commonpath(['/a/b', '/a/b']) == '/a/b' — identical paths."
    - "NOT yet covered: commonpath(['/a/b/c/d', '/a/b']) == '/a/b' — ancestor as common path."
    - "NOT yet covered: normcase('Hello') == 'Hello' — POSIX normcase is identity."
    - "NOT yet covered: isabs.__name__ == 'isabs' — function identity check."
    - "NOT yet covered: exists.__name__ == 'exists' — function identity check."
    - "basename('') == ''; dirname('') == '' — empty string edge cases."
    - "basename('/') == ''; dirname('/') == '/' — root path edge cases."
    - "split('') == ('', ''); split('/') == ('/', '') via __getitem__ on the tuple."
    - "commonpath(['/a/b', '/a/b']) == '/a/b'; commonpath(['/a/b/c/d', '/a/b']) == '/a/b'."
    - "normcase('Hello') == 'Hello' — POSIX normcase is the identity function."
    - "isabs.__name__ == 'isabs'; exists.__name__ == 'exists' — function name metadata."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# os.path.basename and os.path.dirname — empty string and root edge cases
#
# No prior os_path spec covers basename(''), basename('/'), dirname(''), or
# dirname('/'). These are fundamental boundary conditions for the two functions.
# ---------------------------------------------------------------------------

table os_path_extra13.basename_cases:
  description: "os.path.basename edge cases: empty string and root path"
  kind: python_call_eq
  category: basename
  id_prefix: bn13

  columns: [id, function, args, expected]
  rows:
    - [empty,  basename, [""],  ""]
    - [root,   basename, ["/"], ""]

table os_path_extra13.dirname_cases:
  description: "os.path.dirname edge cases: empty string and root path"
  kind: python_call_eq
  category: dirname
  id_prefix: dn13

  columns: [id, function, args, expected]
  rows:
    - [empty,  dirname, [""],  ""]
    - [root,   dirname, ["/"], "/"]

# ---------------------------------------------------------------------------
# os.path.split — tuple components for edge-case inputs
#
# No prior os_path spec covers split('') or split('/') with __getitem__ access
# on the result tuple. Both head and tail are verified for each input.
# ---------------------------------------------------------------------------

table os_path_extra13.split_cases:
  description: "os.path.split result tuple components for empty string and root"
  kind: python_call_eq
  category: split
  id_prefix: sp13

  columns: [id, function, args, expected, method, method_args]
  rows:
    - [empty_head, split, [""],  "", __getitem__, [0]]
    - [empty_tail, split, [""],  "", __getitem__, [1]]
    - [root_head,  split, ["/"], "/", __getitem__, [0]]
    - [root_tail,  split, ["/"], "",  __getitem__, [1]]

# ---------------------------------------------------------------------------
# os.path.commonpath — identical paths and ancestor/descendant pairs
#
# No prior os_path spec covers commonpath(). Verify the common path when both
# inputs are identical and when one is a strict ancestor of the other.
# ---------------------------------------------------------------------------

invariant os_path_extra13.commonpath.identical:
  description: "os.path.commonpath(['/a/b', '/a/b']) == '/a/b' — identical inputs"
  category: commonpath
  kind: python_call_eq
  function: commonpath
  args: [["/a/b", "/a/b"]]
  expected: "/a/b"

invariant os_path_extra13.commonpath.ancestor:
  description: "os.path.commonpath(['/a/b/c/d', '/a/b']) == '/a/b' — ancestor is the common path"
  category: commonpath
  kind: python_call_eq
  function: commonpath
  args: [["/a/b/c/d", "/a/b"]]
  expected: "/a/b"

# ---------------------------------------------------------------------------
# os.path.normcase — POSIX identity function
#
# No prior os_path spec covers normcase(). On POSIX systems normcase is the
# identity: it returns the path unchanged regardless of case.
# ---------------------------------------------------------------------------

invariant os_path_extra13.normcase.identity:
  description: "os.path.normcase('Hello') == 'Hello' — POSIX normcase is the identity function"
  category: normcase
  kind: python_call_eq
  function: normcase
  args: ["Hello"]
  expected: "Hello"

invariant os_path_extra13.normcase.path_unchanged:
  description: "os.path.normcase('/Foo/Bar') == '/Foo/Bar' — POSIX normcase leaves slashes and case untouched"
  category: normcase
  kind: python_call_eq
  function: normcase
  args: ["/Foo/Bar"]
  expected: "/Foo/Bar"

# ---------------------------------------------------------------------------
# Function identity metadata — __name__ checks for isabs and exists
#
# No prior os_path spec verifies isabs.__name__ or exists.__name__ as
# standalone invariants. These anchor function identity in the extra13 namespace.
# ---------------------------------------------------------------------------

table os_path_extra13.function_names:
  description: "os.path function __name__ attributes for isabs and exists"
  kind: python_call_eq
  category: function_identity
  id_prefix: fn13

  columns: [id, function, args, expected]
  rows:
    - [isabs,  isabs.__name__.__eq__,  ["isabs"],  true]
    - [exists, exists.__name__.__eq__, ["exists"], true]
