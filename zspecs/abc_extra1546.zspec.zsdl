spec: abc_extra1546
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 550 (_extra1546): bitwise operator dict-presence checks for abc classes."
    - "abc.ABCMeta and abc.ABC are not bitwise types."
    - "None of these classes define __and__, __or__, __xor__, __invert__, __lshift__, __rshift__ or reflected variants in their own __dict__."
    - "abc.ABCMeta.__module__ == 'abc'; abc.ABC.__module__ == 'abc' on CPython 3.14."
    - "ABCMeta.__dict__ contains: __new__, register, __instancecheck__, __subclasscheck__."
    - "ABC.__dict__ contains: __slots__, __abstractmethods__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# ABCMeta — bitwise operator dict-presence (all False)
# ---------------------------------------------------------------------------

table abc_extra1546.abcmeta_bitwise_ops:
  description: "abc.ABCMeta.__dict__ does not contain any bitwise operator dunder"
  kind: python_call_eq
  category: bitwise_presence
  id_prefix: ab1546am

  columns: [id, function, args, expected]
  rows:
    - [ab1546am001, abc.ABCMeta.__dict__.__contains__, ["__and__"],     false]
    - [ab1546am002, abc.ABCMeta.__dict__.__contains__, ["__or__"],      false]
    - [ab1546am003, abc.ABCMeta.__dict__.__contains__, ["__xor__"],     false]
    - [ab1546am004, abc.ABCMeta.__dict__.__contains__, ["__invert__"],  false]
    - [ab1546am005, abc.ABCMeta.__dict__.__contains__, ["__lshift__"],  false]
    - [ab1546am006, abc.ABCMeta.__dict__.__contains__, ["__rshift__"],  false]
    - [ab1546am007, abc.ABCMeta.__dict__.__contains__, ["__rand__"],    false]
    - [ab1546am008, abc.ABCMeta.__dict__.__contains__, ["__ror__"],     false]
    - [ab1546am009, abc.ABCMeta.__dict__.__contains__, ["__rxor__"],    false]
    - [ab1546am010, abc.ABCMeta.__dict__.__contains__, ["__rlshift__"], false]
    - [ab1546am011, abc.ABCMeta.__dict__.__contains__, ["__rrshift__"], false]

# ---------------------------------------------------------------------------
# ABC — bitwise operator dict-presence (all False)
# ---------------------------------------------------------------------------

table abc_extra1546.abc_bitwise_ops:
  description: "abc.ABC.__dict__ does not contain any bitwise operator dunder"
  kind: python_call_eq
  category: bitwise_presence
  id_prefix: ab1546ab

  columns: [id, function, args, expected]
  rows:
    - [ab1546ab001, abc.ABC.__dict__.__contains__, ["__and__"],     false]
    - [ab1546ab002, abc.ABC.__dict__.__contains__, ["__or__"],      false]
    - [ab1546ab003, abc.ABC.__dict__.__contains__, ["__xor__"],     false]
    - [ab1546ab004, abc.ABC.__dict__.__contains__, ["__invert__"],  false]
    - [ab1546ab005, abc.ABC.__dict__.__contains__, ["__lshift__"],  false]
    - [ab1546ab006, abc.ABC.__dict__.__contains__, ["__rshift__"],  false]
    - [ab1546ab007, abc.ABC.__dict__.__contains__, ["__rand__"],    false]
    - [ab1546ab008, abc.ABC.__dict__.__contains__, ["__ror__"],     false]
    - [ab1546ab009, abc.ABC.__dict__.__contains__, ["__rxor__"],    false]
    - [ab1546ab010, abc.ABC.__dict__.__contains__, ["__rlshift__"], false]
    - [ab1546ab011, abc.ABC.__dict__.__contains__, ["__rrshift__"], false]

# ---------------------------------------------------------------------------
# ABCMeta — actual method dict-presence (positive checks)
# ---------------------------------------------------------------------------

table abc_extra1546.abcmeta_method_presence:
  description: "abc.ABCMeta.__dict__ contains its defining methods and class identity"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ab1546mp

  columns: [id, function, args, expected]
  rows:
    - [ab1546mp001, abc.ABCMeta.__dict__.__contains__, ["register"],          true]
    - [ab1546mp002, abc.ABCMeta.__dict__.__contains__, ["__instancecheck__"], true]
    - [ab1546mp003, abc.ABCMeta.__dict__.__contains__, ["__new__"],           true]
    - [ab1546mp004, abc.ABCMeta.__dict__.__contains__, ["__subclasscheck__"], true]
    - [ab1546mp005, abc.ABCMeta.__name__.__eq__,        ["ABCMeta"],          true]
    - [ab1546mp006, abc.ABCMeta.__module__.__eq__,      ["abc"],              true]
