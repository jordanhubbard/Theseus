spec: theseus_termios_cr
version: ">=3.0"
backend: python_cleanroom(theseus_termios_cr)
blocks: termios

docs: https://docs.python.org/3/library/termios.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/termios.html"
  not_derived_from:
    - "CPython source: Modules/termios.c"
  notes:
    - "Clean-room termios module. Do NOT import termios."

error_model: python_exceptions

invariant theseus_termios_cr.termios2_constants:
  description: "TCSANOW, TCSADRAIN, TCSAFLUSH constants exist"
  category: behavior
  kind: python_call_eq
  function: termios2_constants
  args: []
  expected: true

invariant theseus_termios_cr.termios2_baud_rates:
  description: "B9600, B115200 baud rate constants exist"
  category: behavior
  kind: python_call_eq
  function: termios2_baud_rates
  args: []
  expected: true

invariant theseus_termios_cr.termios2_tcgetattr:
  description: "tcgetattr() function exists"
  category: behavior
  kind: python_call_eq
  function: termios2_tcgetattr
  args: []
  expected: true
