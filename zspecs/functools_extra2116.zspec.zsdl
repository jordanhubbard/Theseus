spec: functools_extra2116
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2116 (_extra2116): __or__/__ror__/__ior__, __and__/__rand__/__iand__, __xor__/__rxor__/__ixor__ dict-presence checks for functools types."
    - "Theme: set/dict merge operators (union, intersection, symmetric-difference) — NOT numeric bitwise ops."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "functools.partial does NOT define any of the nine merge/set operators in its own __dict__ — it is a callable wrapper, not a set or dict type."
    - "functools.partialmethod does NOT define any of the nine operators — it is a descriptor helper, not a collection type."
    - "functools.cached_property does NOT define any of the nine operators — it is a property descriptor, not a collection type."
    - "functools._lru_cache_wrapper does NOT define any of the nine operators — it is an internal C wrapper type for LRU-cached callables."
    - "functools.singledispatchmethod does NOT define any of the nine operators — it is a dispatch helper, not a collection type."
    - "functools._CacheInfo does NOT define any of the nine operators — it is a namedtuple subclass tracking cache statistics."
    - "functools._PlaceholderType does NOT define any of the nine operators — it is a sentinel type, not a collection."
    - "None of the functools wrapper types implement the set/dict merge protocol; they have no membership or combinatorial semantics."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __or__ / __ror__ / __ior__ dict-presence (dict-merge / set-union)
#
# None of the functools types define these in their own __dict__.
# These operators implement dict merging (d1 | d2) and set union (s1 | s2).
# Functional wrappers have no such semantics.
# ---------------------------------------------------------------------------

table functools_extra2116.or_operator:
  description: "functools types __or__/__ror__/__ior__ dict-presence checks — all False (no dict-merge/set-union protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2116

  columns: [id, function, args, expected]
  rows:
    - ["ft2116001", "functools.partial.__dict__.__contains__", ["__or__"], false]
    - ["ft2116002", "functools.partial.__dict__.__contains__", ["__ror__"], false]
    - ["ft2116003", "functools.partial.__dict__.__contains__", ["__ior__"], false]
    - ["ft2116004", "functools.partialmethod.__dict__.__contains__", ["__or__"], false]
    - ["ft2116005", "functools.partialmethod.__dict__.__contains__", ["__ror__"], false]
    - ["ft2116006", "functools.partialmethod.__dict__.__contains__", ["__ior__"], false]
    - ["ft2116007", "functools.cached_property.__dict__.__contains__", ["__or__"], false]
    - ["ft2116008", "functools.cached_property.__dict__.__contains__", ["__ror__"], false]
    - ["ft2116009", "functools.cached_property.__dict__.__contains__", ["__ior__"], false]
    - ["ft2116010", "functools._lru_cache_wrapper.__dict__.__contains__", ["__or__"], false]
    - ["ft2116011", "functools._lru_cache_wrapper.__dict__.__contains__", ["__ror__"], false]
    - ["ft2116012", "functools._lru_cache_wrapper.__dict__.__contains__", ["__ior__"], false]
    - ["ft2116013", "functools.singledispatchmethod.__dict__.__contains__", ["__or__"], false]
    - ["ft2116014", "functools.singledispatchmethod.__dict__.__contains__", ["__ror__"], false]
    - ["ft2116015", "functools.singledispatchmethod.__dict__.__contains__", ["__ior__"], false]

# ---------------------------------------------------------------------------
