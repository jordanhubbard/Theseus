spec: functools_extra2386
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 606 (_extra2386): __str__ and __repr__ implementation type classification."
    - "Python-defined __repr__ returns 'function'; C-extension returns 'wrapper_descriptor'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table functools_extra2386.repr_class_names:
  description: "functools class __repr__ implementation type via .__repr__.__class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2386
  columns: [id, function, args, expected]
  rows:
    - ["ft2386001", "functools.partial.__repr__.__class__.__name__", [], "wrapper_descriptor"]
    - ["ft2386002", "functools.partialmethod.__repr__.__class__.__name__", [], "function"]
    - ["ft2386003", "functools.cached_property.__repr__.__class__.__name__", [], "wrapper_descriptor"]
    - ["ft2386004", "functools._lru_cache_wrapper.__repr__.__class__.__name__", [], "wrapper_descriptor"]

table functools_extra2386.str_class_names:
  description: "functools class __str__ implementation type via .__str__.__class__.__name__"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2386
  columns: [id, function, args, expected]
  rows:
    - ["ft2386005", "functools.partial.__str__.__class__.__name__", [], "wrapper_descriptor"]
    - ["ft2386006", "functools.partialmethod.__str__.__class__.__name__", [], "wrapper_descriptor"]
    - ["ft2386007", "functools.cached_property.__str__.__class__.__name__", [], "wrapper_descriptor"]
    - ["ft2386008", "functools._lru_cache_wrapper.__str__.__class__.__name__", [], "wrapper_descriptor"]

table functools_extra2386.repr_is_wrapper_descriptor:
  description: "C-implemented functools classes have __repr__ of kind wrapper_descriptor (inherited from object)"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2386
  columns: [id, function, args, expected]
  rows:
    - ["ft2386009", "functools.partial.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["ft2386010", "functools.cached_property.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["ft2386011", "functools._lru_cache_wrapper.__repr__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

table functools_extra2386.partialmethod_repr_is_function:
  description: "functools.partialmethod defines __repr__ in Python so its __repr__.__class__.__name__ is 'function'"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2386
  columns: [id, function, args, expected]
  rows:
    - ["ft2386012", "functools.partialmethod.__repr__.__class__.__name__.__eq__", ["function"], true]
    - ["ft2386013", "functools.partialmethod.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

table functools_extra2386.str_all_wrapper_descriptor:
  description: "All checked functools classes inherit __str__ from object → wrapper_descriptor"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2386
  columns: [id, function, args, expected]
  rows:
    - ["ft2386014", "functools.partial.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["ft2386015", "functools.partialmethod.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["ft2386016", "functools.cached_property.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]
    - ["ft2386017", "functools._lru_cache_wrapper.__str__.__class__.__name__.__eq__", ["wrapper_descriptor"], true]

table functools_extra2386.class_name_consistency:
  description: "Cross-check: __repr__.__class__ and __str__.__class__ are consistent across all four functools subjects"
  kind: python_call_eq
