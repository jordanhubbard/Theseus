  description: "functools.partial class name attrs: __name__='partial'(7), __qualname__='partial'(7), __doc__ type 'str'; __new__ qualname 'partial.__new__'(15) type 'builtin_function_or_method'; wave 264; new to extra118"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolspca118

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — functools.partial is a C-extension type defined in Modules/_functoolsmodule.c; its __name__ attribute is 'partial'; str.__eq__('partial') returns True; new to extra118"]
    - [partial_name_len_7,
       "partial.__name__.__len__",
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters: p-a-r-t-i-a-l; str.__len__() returns 7; int.__eq__(7) returns True; new to extra118"]
    - [partial_qualname_eq,
       "partial.__qualname__.__eq__",
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — functools.partial is defined at module scope; its __qualname__ is 'partial' (same as __name__ for top-level classes); str.__eq__('partial') returns True; new to extra118"]
    - [partial_doc_type_str,
       "partial.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — functools.partial has a docstring defined in the C extension; type(functools.partial.__doc__).__name__ is 'str'; str.__eq__('str') returns True; new to extra118"]
    - [partial_new_qualname,
       "partial.__new__.__qualname__.__eq__",
       ["partial.__new__"],
       true,
       "functools.partial.__new__.__qualname__.__eq__('partial.__new__') == True — functools.partial.__new__ is the C-level static method responsible for creating partial instances; its __qualname__ follows the 'ClassName.__new__' dotted pattern; str.__eq__('partial.__new__') returns True; new to extra118"]
    - [partial_new_qualname_len_15,
       "partial.__new__.__qualname__.__len__",
       [],
       15,
       "functools.partial.__new__.__qualname__.__len__() == 15 — 'partial.__new__' has 15 characters: p-a-r-t-i-a-l-.-_-_-n-e-w-_-_ (7+1+7); str.__len__() returns 15; int.__eq__(15) returns True; new to extra118"]
    - [partial_new_type_builtin,
       "partial.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "functools.partial.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — functools.partial.__new__ is a C-level static method; when accessed on the class it is a 'builtin_function_or_method'; str.__eq__('builtin_function_or_method') returns True; new to extra118"]

# ---------------------------------------------------------------------------
# Table 2: functools.lru_cache and functools.cache code attributes
#
# Wave 264 theme: functools.lru_cache is a pure-Python decorator function
# defined in Lib/functools.py. Its __code__.co_name is 'lru_cache' and
# its __qualname__ is 'lru_cache' (len 9: l-r-u-_-c-a-c-h-e). It has
# co_argcount 2 (maxsize and typed parameters). functools.cache is a simpler
# wrapper with co_argcount 1 (just the user_function). functools.cache
# __qualname__ is 'cache' (len 5: c-a-c-h-e). The co_name always matches
# the function's own def-statement name.
#
# functools.lru_cache.__code__.co_name == 'lru_cache'
# functools.lru_cache.__code__.co_argcount == 2
# functools.lru_cache.__qualname__ == 'lru_cache'
# len(functools.lru_cache.__qualname__) == 9
# functools.cache.__code__.co_name == 'cache'
# functools.cache.__code__.co_argcount == 1
# functools.cache.__qualname__ == 'cache'
#
# New to extra118.
# ---------------------------------------------------------------------------

