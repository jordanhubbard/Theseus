spec: pathlib_extra2731
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2701.zspec.zsdl — covers __lshift__/__rshift__/__invert__ dict-presence"
    - "pathlib_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 629 (pathlib_extra2731) theme: __trunc__, __floor__, and __ceil__ dict-presence checks."
    - "None of the pathlib classes define __trunc__, __floor__, or __ceil__ in their own __dict__."
    - "__trunc__ supports math.trunc(); pathlib path objects are filesystem path types, not numeric types."
    - "__floor__ supports math.floor(); pathlib path objects do not implement floor-rounding numeric semantics."
    - "__ceil__ supports math.ceil(); pathlib path objects do not implement ceiling-rounding numeric semantics."
    - "pathlib uses __truediv__ (the / operator) for path joining — none of __trunc__, __floor__, or __ceil__ are used."
    - "Covers pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2731.no_trunc_in_pathlib_classes:
  description: "__trunc__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the math.trunc() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2731

  columns: [id, function, args, expected]
  rows:
    - ["pp2731001", "pathlib.PurePath.__dict__.__contains__",        ["__trunc__"], false]
    - ["pp2731002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__trunc__"], false]
    - ["pp2731003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__trunc__"], false]
    - ["pp2731004", "pathlib.Path.__dict__.__contains__",            ["__trunc__"], false]

