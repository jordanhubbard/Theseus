  columns: [id, function, args, expected]
  rows:
    - ["pp2731005", "pathlib.PurePath.__dict__.__contains__",        ["__floor__"], false]
    - ["pp2731006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__floor__"], false]
    - ["pp2731007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__floor__"], false]
    - ["pp2731008", "pathlib.Path.__dict__.__contains__",            ["__floor__"], false]

# ---------------------------------------------------------------------------
# __ceil__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2731.no_ceil_in_pathlib_classes:
  description: "__ceil__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the math.ceil() protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2731

  columns: [id, function, args, expected]
  rows:
    - ["pp2731009", "pathlib.PurePath.__dict__.__contains__",        ["__ceil__"], false]
    - ["pp2731010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__ceil__"], false]
    - ["pp2731011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__ceil__"], false]
    - ["pp2731012", "pathlib.Path.__dict__.__contains__",            ["__ceil__"], false]

# ---------------------------------------------------------------------------
# Complementary: pathlib classes have path-manipulation methods but not rounding numeric hooks
# Confirms that path objects use __truediv__ for joining and have no __trunc__/__floor__/__ceil__ semantics
# ---------------------------------------------------------------------------

table pathlib_extra2731.pathlib_has_path_methods_not_rounding_numeric_hooks:
  description: "pathlib.PurePath defines __str__/__truediv__/__fspath__ but NOT __trunc__/__floor__/__ceil__; pathlib.Path defines stat/exists/open but NOT __trunc__/__floor__/__ceil__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2731

  columns: [id, function, args, expected]
  rows:
    - ["pp2731013", "pathlib.PurePath.__dict__.__contains__", ["__str__"],     true]
    - ["pp2731014", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"], true]
    - ["pp2731015", "pathlib.PurePath.__dict__.__contains__", ["__fspath__"],  true]
    - ["pp2731016", "pathlib.PurePath.__dict__.__contains__", ["__trunc__"],   false]
    - ["pp2731017", "pathlib.PurePath.__dict__.__contains__", ["__floor__"],   false]
    - ["pp2731018", "pathlib.PurePath.__dict__.__contains__", ["__ceil__"],    false]
    - ["pp2731019", "pathlib.Path.__dict__.__contains__",     ["stat"],        true]
    - ["pp2731020", "pathlib.Path.__dict__.__contains__",     ["exists"],      true]
    - ["pp2731021", "pathlib.Path.__dict__.__contains__",     ["open"],        true]
    - ["pp2731022", "pathlib.Path.__dict__.__contains__",     ["__trunc__"],   false]
    - ["pp2731023", "pathlib.Path.__dict__.__contains__",     ["__floor__"],   false]
    - ["pp2731024", "pathlib.Path.__dict__.__contains__",     ["__ceil__"],    false]
