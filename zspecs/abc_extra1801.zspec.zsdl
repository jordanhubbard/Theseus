spec: abc_extra1801
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 567 (_extra1801): __bool__/__len__ truth-value and context manager protocol dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra1801.truth_protocol:
  description: "abc types __bool__ and __len__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1801

  columns: [id, function, args, expected]
  rows:
    - ["ab1801001", "abc.ABC.__dict__.__contains__", ["__bool__"], false]
    - ["ab1801002", "abc.ABC.__dict__.__contains__", ["__len__"], false]
    - ["ab1801003", "abc.ABCMeta.__dict__.__contains__", ["__bool__"], false]
    - ["ab1801004", "abc.ABCMeta.__dict__.__contains__", ["__len__"], false]
    - ["ab1801005", "abc.abstractmethod.__dict__.__contains__", ["__bool__"], false]
    - ["ab1801006", "abc.abstractmethod.__dict__.__contains__", ["__len__"], false]

table abc_extra1801.abcmeta_protocol:
  description: "ABCMeta dict-presence checks for metaclass protocol methods"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1801

  columns: [id, function, args, expected]
  rows:
    - ["ab1801007", "abc.ABCMeta.__dict__.__contains__", ["__instancecheck__"], true]
    - ["ab1801008", "abc.ABCMeta.__dict__.__contains__", ["__subclasscheck__"], true]
    - ["ab1801009", "abc.ABCMeta.__dict__.__contains__", ["register"], true]
    - ["ab1801010", "abc.ABCMeta.__dict__.__contains__", ["__subclasshook__"], false]
    - ["ab1801011", "abc.ABC.__dict__.__contains__", ["__subclasshook__"], true]
    - ["ab1801012", "abc.ABC.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ab1801013", "abc.abstractmethod.__dict__.__contains__", ["__call__"], true]
    - ["ab1801014", "abc.abstractmethod.__dict__.__contains__", ["__get__"], true]

table abc_extra1801.abstractmethod_attrs:
  description: "abc.abstractmethod and ABCMeta attribute dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1801

  columns: [id, function, args, expected]
  rows:
    - ["ab1801015", "abc.abstractmethod.__dict__.__contains__", ["__isabstractmethod__"], false]
    - ["ab1801016", "abc.abstractmethod.__dict__.__contains__", ["__wrapped__"], false]
    - ["ab1801017", "abc.abstractmethod.__dict__.__contains__", ["__doc__"], true]
    - ["ab1801018", "abc.abstractmethod.__dict__.__contains__", ["__module__"], true]
    - ["ab1801019", "abc.ABCMeta.__dict__.__contains__", ["__doc__"], true]
    - ["ab1801020", "abc.ABCMeta.__dict__.__contains__", ["get_cache_token"], true]
    - ["ab1801021", "abc.ABCMeta.__dict__.__contains__", ["_dump_registry"], true]
    - ["ab1801022", "abc.ABCMeta.__dict__.__contains__", ["__abstractmethods__"], false]
