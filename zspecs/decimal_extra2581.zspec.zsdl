spec: decimal_extra2581
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra2521.zspec.zsdl — covers __bool__, __int__, __index__ dict-presence"
    - "decimal_extra1876.zspec.zsdl — covers attr-access and introspection protocol"
  notes:
    - "Wave 2581 theme: __call__ dict-presence. No decimal class defines __call__ in its own __dict__."
    - "decimal.Decimal is a full numeric type with __add__, __mul__, __sub__ etc. but NOT __call__."
    - "decimal.Context is a configuration/rounding context object — it is NOT callable via __call__."
    - "decimal.Context() creates a Context instance via __init__/__new__, not __call__ on an instance."
    - "decimal.DecimalException, decimal.InvalidOperation, and decimal.DivisionByZero are exception classes — none define __call__."
    - "decimal.Overflow is an exception subclass and also does NOT define __call__ in its own __dict__."
    - "All decimal classes are instantiated via type.__call__ (metaclass machinery), not by defining __call__ themselves."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __call__ dict-presence — decimal.Decimal, decimal.Context, decimal.DecimalException
# ---------------------------------------------------------------------------

table decimal_extra2581.core_types_no_call:
  description: "__call__ is absent from decimal.Decimal, decimal.Context, and decimal.DecimalException __dict__s"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2581

  columns: [id, function, args, expected]
  rows:
    - ["dc2581001", "decimal.Decimal.__dict__.__contains__",          ["__call__"], false]
    - ["dc2581002", "decimal.Context.__dict__.__contains__",          ["__call__"], false]
    - ["dc2581003", "decimal.DecimalException.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# __call__ dict-presence — exception subclasses
# decimal.InvalidOperation, decimal.DivisionByZero, decimal.Overflow
# ---------------------------------------------------------------------------

table decimal_extra2581.exception_subclasses_no_call:
  description: "__call__ is absent from decimal exception subclass __dict__s — exception classes are not functors"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2581

  columns: [id, function, args, expected]
  rows:
    - ["dc2581004", "decimal.InvalidOperation.__dict__.__contains__", ["__call__"], false]
    - ["dc2581005", "decimal.DivisionByZero.__dict__.__contains__",   ["__call__"], false]
    - ["dc2581006", "decimal.Overflow.__dict__.__contains__",         ["__call__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal DOES define arithmetic operators (not __call__)
# Confirms Decimal is a rich numeric type that just does not define __call__
# ---------------------------------------------------------------------------

table decimal_extra2581.decimal_arithmetic_not_callable:
  description: "decimal.Decimal defines __add__, __mul__, __sub__ (numeric type) but NOT __call__ (not a functor)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2581

  columns: [id, function, args, expected]
  rows:
    - ["dc2581007", "decimal.Decimal.__dict__.__contains__", ["__add__"],  true]
    - ["dc2581008", "decimal.Decimal.__dict__.__contains__", ["__mul__"],  true]
    - ["dc2581009", "decimal.Decimal.__dict__.__contains__", ["__sub__"],  true]
    - ["dc2581010", "decimal.Decimal.__dict__.__contains__", ["__call__"], false]
    - ["dc2581011", "decimal.Decimal.__dict__.__contains__", ["__iter__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Context defines __init__ and __repr__ but NOT __call__
# Context is configured via construction, not invocation — __call__ absent
# ---------------------------------------------------------------------------

table decimal_extra2581.context_init_not_callable:
  description: "decimal.Context defines __init__, __repr__, __copy__ but NOT __call__ — it is a config object, not a functor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2581

  columns: [id, function, args, expected]
  rows:
    - ["dc2581012", "decimal.Context.__dict__.__contains__", ["__init__"],  true]
    - ["dc2581013", "decimal.Context.__dict__.__contains__", ["__repr__"],  true]
    - ["dc2581014", "decimal.Context.__dict__.__contains__", ["__copy__"],  true]
    - ["dc2581015", "decimal.Context.__dict__.__contains__", ["__call__"],  false]
    - ["dc2581016", "decimal.Context.__dict__.__contains__", ["__iter__"],  false]
    - ["dc2581017", "decimal.Decimal.__dict__.__contains__", ["__call__"],  false]
    - ["dc2581018", "decimal.DecimalException.__dict__.__contains__", ["__call__"], false]
    - ["dc2581019", "decimal.InvalidOperation.__dict__.__contains__", ["__call__"], false]
    - ["dc2581020", "decimal.DivisionByZero.__dict__.__contains__",   ["__call__"], false]
