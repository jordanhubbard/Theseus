spec: re_extra32
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra31.zspec.zsdl — covers split/findall/finditer/purge/escape __module__.__len__()==2; split/findall/finditer/purge/escape __name__.__len__(); Pattern/__name__.__len__()==7; Match/__name__.__len__()==5; Pattern/__qualname__.__len__()==7; Match/__qualname__.__len__()==5."
  notes:
    - "This spec extends re_extra31.zspec.zsdl."
    - "Prior specs covered: re.compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge __name__/__module__/__qualname__, Pattern/Match/__name__/__module__/__qualname__/__bases__[0].__name__, re.error/__name__/__module__, re.IGNORECASE/MULTILINE/DOTALL/VERBOSE values, all public function __module__.__len__()==2 and __name__.__len__(), Pattern/__name__.__len__()==7, Match/__name__.__len__()==5, Pattern/__qualname__.__len__()==7, Match/__qualname__.__len__()==5, Pattern/__mro__.__len__()==2, Match/__mro__.__len__()==2, error/__mro__.__len__()==4, Pattern/__bases__[0].__name__=='object', Match/__bases__[0].__name__=='object'."
    - "This spec covers: Pattern.match/__qualname__.__len__()==13; Pattern.search/__qualname__.__len__()==14; Pattern.findall/__qualname__.__len__()==15; Pattern.sub/__qualname__.__len__()==11; Pattern.split/__qualname__.__len__()==13; Pattern.fullmatch/__qualname__.__len__()==17; Pattern.finditer/__qualname__.__len__()==16; Pattern.subn/__qualname__.__len__()==12; Match.group/__qualname__.__len__()==11; Match.groups/__qualname__.__len__()==12; Match.span/__qualname__.__len__()==10; Match.start/__qualname__.__len__()==11; Match.end/__qualname__.__len__()==9."
    - "re.Pattern.match.__qualname__ == 'Pattern.match' (len 13). No prior spec checks __qualname__.__len__() for any Pattern method. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Pattern.search.__qualname__ == 'Pattern.search' (len 14). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Pattern.findall.__qualname__ == 'Pattern.findall' (len 15). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Pattern.sub.__qualname__ == 'Pattern.sub' (len 11). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Pattern.split.__qualname__ == 'Pattern.split' (len 13). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Pattern.fullmatch.__qualname__ == 'Pattern.fullmatch' (len 17). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Pattern.finditer.__qualname__ == 'Pattern.finditer' (len 16). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Pattern.subn.__qualname__ == 'Pattern.subn' (len 12). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Match.group.__qualname__ == 'Match.group' (len 11). No prior spec checks __qualname__.__len__() for any Match method. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Match.groups.__qualname__ == 'Match.groups' (len 12). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Match.span.__qualname__ == 'Match.span' (len 10). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Match.start.__qualname__ == 'Match.start' (len 11). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.Match.end.__qualname__ == 'Match.end' (len 9). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern method __qualname__.__len__() — novel invariants
#
# Prior specs (re_extra26) cover Pattern method __qualname__.__eq__() but no
# prior spec checks __qualname__.__len__() for any Pattern or Match method.
# Qualnames include the 'Pattern.' prefix, so lengths are always greater than
# the bare method name length.
# Pattern.match (13), Pattern.search (14), Pattern.findall (15),
# Pattern.sub (11), Pattern.split (13).
# ---------------------------------------------------------------------------

invariant re_extra32.Pattern.match.qualname_len:
  description: "re.Pattern.match.__qualname__.__len__() == 13 — 'Pattern.match' has 13 characters, novel invariant"
  category: string_length
  kind: python_call_eq
  function: Pattern.match.__qualname__.__len__
  args: []
  expected: 13

invariant re_extra32.Pattern.search.qualname_len:
  description: "re.Pattern.search.__qualname__.__len__() == 14 — 'Pattern.search' has 14 characters, novel invariant"
  category: string_length
  kind: python_call_eq
  function: Pattern.search.__qualname__.__len__
  args: []
  expected: 14

table re_extra32.pattern_method_qualname_lengths:
  description: "len(__qualname__) for Pattern.findall (15), Pattern.sub (11), Pattern.split (13), Pattern.fullmatch (17), Pattern.finditer (16), Pattern.subn (12) — novel invariants"
  kind: python_call_eq
  category: string_length
  id_prefix: pmql32

  columns: [id, function, args, expected]
  rows:
    - [findall,   Pattern.findall.__qualname__.__len__,   [], 15]
    - [sub,       Pattern.sub.__qualname__.__len__,       [], 11]
    - [split,     Pattern.split.__qualname__.__len__,     [], 13]
    - [fullmatch, Pattern.fullmatch.__qualname__.__len__, [], 17]
    - [finditer,  Pattern.finditer.__qualname__.__len__,  [], 16]
    - [subn,      Pattern.subn.__qualname__.__len__,      [], 12]

# ---------------------------------------------------------------------------
# re.Match method __qualname__.__len__() — novel invariants
#
# No prior spec checks __qualname__.__len__() for any Match method.
# Qualnames include the 'Match.' prefix (6 chars), so:
# Match.group (11), Match.groups (12), Match.span (10),
# Match.start (11), Match.end (9).
# ---------------------------------------------------------------------------

invariant re_extra32.Match.group.qualname_len:
  description: "re.Match.group.__qualname__.__len__() == 11 — 'Match.group' has 11 characters, novel invariant"
  category: string_length
  kind: python_call_eq
  function: Match.group.__qualname__.__len__
  args: []
  expected: 11

invariant re_extra32.Match.end.qualname_len:
  description: "re.Match.end.__qualname__.__len__() == 9 — 'Match.end' has 9 characters; shortest Match method qualname, novel invariant"
  category: string_length
  kind: python_call_eq
  function: Match.end.__qualname__.__len__
  args: []
  expected: 9

table re_extra32.match_method_qualname_lengths:
  description: "len(__qualname__) for Match.groups (12), Match.span (10), Match.start (11) — novel invariants"
  kind: python_call_eq
  category: string_length
  id_prefix: mmql32

  columns: [id, function, args, expected]
  rows:
    - [groups, Match.groups.__qualname__.__len__, [], 12]
    - [span,   Match.span.__qualname__.__len__,   [], 10]
    - [start,  Match.start.__qualname__.__len__,  [], 11]
