spec: uuid_extra1936
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol dict-presence checks, __set_name__ dict presence, __class__.__name__ checks."
    - "uuid.UUID does NOT define __get__/__set__/__delete__ in its own __dict__ (it is not itself a descriptor)."
    - "uuid.UUID property attributes (hex, bytes, version, variant, etc.) are property objects stored in uuid.UUID.__dict__; property.__dict__ DOES contain __get__/__set__/__delete__/__set_name__."
    - "uuid.UUID.__dict__['int'] is a member_descriptor (C slot); its type __dict__ has __get__/__set__/__delete__ but NOT __set_name__."
    - "Neither uuid.UUID nor uuid.SafeUUID define __set_name__ in their own __dict__."
    - "uuid.__class__.__name__ is 'module'; uuid.UUID.__class__.__name__ is 'type'; uuid.SafeUUID.__class__.__name__ is 'EnumType'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra1936.descriptor_protocol:
  description: "uuid.UUID and uuid.SafeUUID __get__/__set__/__delete__ dict-presence checks (not descriptors)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1936

  columns: [id, function, args, expected]
  rows:
    - ["uu1936001", "uuid.UUID.__dict__.__contains__", ["__get__"], false]
    - ["uu1936002", "uuid.UUID.__dict__.__contains__", ["__set__"], false]
    - ["uu1936003", "uuid.UUID.__dict__.__contains__", ["__delete__"], false]
    - ["uu1936004", "uuid.SafeUUID.__dict__.__contains__", ["__get__"], false]
    - ["uu1936005", "uuid.SafeUUID.__dict__.__contains__", ["__set__"], false]
    - ["uu1936006", "uuid.SafeUUID.__dict__.__contains__", ["__delete__"], false]

table uuid_extra1936.set_name_protocol:
  description: "uuid.UUID and uuid.SafeUUID __set_name__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1936

  columns: [id, function, args, expected]
  rows:
    - ["uu1936011", "uuid.UUID.__dict__.__contains__", ["__set_name__"], false]
    - ["uu1936012", "uuid.SafeUUID.__dict__.__contains__", ["__set_name__"], false]
    - ["uu1936013", "uuid.__dict__.__contains__", ["__set_name__"], false]

table uuid_extra1936.property_descriptor_protocol:
  description: "uuid.UUID property attributes are property descriptors; property.__dict__ has __get__/__set__/__delete__/__set_name__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1936

  columns: [id, function, args, expected]
  rows:
    - ["uu1936021", "uuid.UUID.__dict__.__contains__", ["hex"], true]
    - ["uu1936022", "uuid.UUID.__dict__.__contains__", ["bytes"], true]
    - ["uu1936023", "uuid.UUID.__dict__.__contains__", ["version"], true]
    - ["uu1936024", "uuid.UUID.__dict__.__contains__", ["variant"], true]
    - ["uu1936025", "uuid.UUID.__dict__.__contains__", ["bytes_le"], true]
    - ["uu1936026", "uuid.UUID.__dict__.__contains__", ["fields"], true]
    - ["uu1936027", "uuid.UUID.__dict__.__contains__", ["node"], true]
    - ["uu1936028", "uuid.UUID.__dict__.__contains__", ["time"], true]
    - ["uu1936029", "uuid.UUID.__dict__.__contains__", ["clock_seq"], true]
    - ["uu1936030", "uuid.UUID.__dict__.__contains__", ["int"], true]

table uuid_extra1936.property_type_descriptor_protocol:
  description: "property type itself has __get__/__set__/__delete__/__set_name__ in property.__dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1936

  columns: [id, function, args, expected]
  rows:
    - ["uu1936031", "property.__dict__.__contains__", ["__get__"], true]
    - ["uu1936032", "property.__dict__.__contains__", ["__set__"], true]
    - ["uu1936033", "property.__dict__.__contains__", ["__delete__"], true]
    - ["uu1936034", "property.__dict__.__contains__", ["__set_name__"], true]

table uuid_extra1936.module_descriptor_protocol:
  description: "uuid module-level __get__/__set__/__delete__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1936

  columns: [id, function, args, expected]
  rows:
    - ["uu1936041", "uuid.__dict__.__contains__", ["__get__"], false]
    - ["uu1936042", "uuid.__dict__.__contains__", ["__set__"], false]
    - ["uu1936043", "uuid.__dict__.__contains__", ["__delete__"], false]

table uuid_extra1936.uuid_dict_known_members:
  description: "uuid.UUID dict-presence checks for well-known members"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1936

  columns: [id, function, args, expected]
  rows:
    - ["uu1936051", "uuid.UUID.__dict__.__contains__", ["__init__"], true]
    - ["uu1936052", "uuid.UUID.__dict__.__contains__", ["__repr__"], true]
    - ["uu1936053", "uuid.UUID.__dict__.__contains__", ["__str__"], true]
    - ["uu1936054", "uuid.UUID.__dict__.__contains__", ["__slots__"], true]
    - ["uu1936055", "uuid.UUID.__dict__.__contains__", ["__doc__"], true]
    - ["uu1936056", "uuid.UUID.__dict__.__contains__", ["__module__"], true]
    - ["uu1936057", "uuid.SafeUUID.__dict__.__contains__", ["safe"], true]
    - ["uu1936058", "uuid.SafeUUID.__dict__.__contains__", ["unsafe"], true]
    - ["uu1936059", "uuid.SafeUUID.__dict__.__contains__", ["unknown"], true]
    - ["uu1936060", "uuid.SafeUUID.__dict__.__contains__", ["__doc__"], true]
    - ["uu1936061", "uuid.SafeUUID.__dict__.__contains__", ["__module__"], true]

table uuid_extra1936.class_name_checks:
  description: "uuid __class__.__name__ checks for module, type, and enum metaclass"
  kind: python_call_eq
  category: attribute_value
  id_prefix: uu1936

  columns: [id, function, args, expected]
  rows:
    - ["uu1936071", "uuid.__class__.__name__.__eq__", ["module"], true]
    - ["uu1936072", "uuid.UUID.__class__.__name__.__eq__", ["type"], true]
    - ["uu1936073", "uuid.SafeUUID.__class__.__name__.__eq__", ["EnumType"], true]
