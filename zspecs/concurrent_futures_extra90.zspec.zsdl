    - [tpe_bases0_name,  "ThreadPoolExecutor.__bases__[0].__name__.__eq__",  ["Executor"],                  true, "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor' — inherits from Executor; verified with Python 3.14.3"]
