spec: concurrent_futures_extra90
version: ">=3.9"
backend: python_module(concurrent.futures)
extends: concurrent_futures_extra89

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra89.zspec.zsdl."
    - "This spec covers: wave 253 theme — concurrent.futures ThreadPoolExecutor and ProcessPoolExecutor class identity (__module__, __bases__[0].__name__, __mro__.__len__()). NEW in extra90: ThreadPoolExecutor.__module__=='concurrent.futures.thread'; ThreadPoolExecutor.__bases__[0].__name__=='Executor'; ThreadPoolExecutor.__mro__.__len__()==3; ProcessPoolExecutor.__module__=='concurrent.futures.process'; ProcessPoolExecutor.__bases__[0].__name__=='Executor'; ProcessPoolExecutor.__mro__.__len__()==3; Executor.__module__=='concurrent.futures._base'; Executor.__bases__[0].__name__=='object'; Executor.__mro__.__len__()==2; Future.__module__=='concurrent.futures._base'; Future.__bases__[0].__name__=='object'; Future.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'. ThreadPoolExecutor is defined in Lib/concurrent/futures/thread.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'. ThreadPoolExecutor inherits from Executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3. MRO is [ThreadPoolExecutor, Executor, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process'. ProcessPoolExecutor is defined in Lib/concurrent/futures/process.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'. ProcessPoolExecutor inherits from Executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3. MRO is [ProcessPoolExecutor, Executor, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__module__ == 'concurrent.futures._base'. Executor is defined in Lib/concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__bases__[0].__name__ == 'object'. Executor inherits directly from object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__mro__.__len__() == 2. MRO is [Executor, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__module__ == 'concurrent.futures._base'. Future is defined in Lib/concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__bases__[0].__name__ == 'object'. Future inherits directly from object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__mro__.__len__() == 2. MRO is [Future, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

