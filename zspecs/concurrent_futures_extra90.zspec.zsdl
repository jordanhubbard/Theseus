# ---------------------------------------------------------------------------
# Standalone invariants — extra90
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra90.ThreadPoolExecutor_module:
  description: "concurrent.futures.ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread') returns True — ThreadPoolExecutor is defined in the submodule Lib/concurrent/futures/thread.py; its __module__ attribute is 'concurrent.futures.thread' (not 'concurrent.futures'); this reflects the internal submodule structure; NEW in extra90: first standalone __module__ invariant for ThreadPoolExecutor in cfexeccls90 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra90.ProcessPoolExecutor_module:
  description: "concurrent.futures.ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process') returns True — ProcessPoolExecutor is defined in the submodule Lib/concurrent/futures/process.py; its __module__ attribute is 'concurrent.futures.process' (not 'concurrent.futures'); NEW in extra90: first standalone __module__ invariant for ProcessPoolExecutor in cfexeccls90 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ProcessPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.process"]
  expected: true

invariant concurrent_futures_extra90.ThreadPoolExecutor_mro_len:
  description: "concurrent.futures.ThreadPoolExecutor.__mro__.__len__() == 3 — ThreadPoolExecutor's MRO is [ThreadPoolExecutor, Executor, object]; ThreadPoolExecutor directly inherits from Executor which inherits from object; there are no mixin classes or multiple inheritance; the mro length of 3 confirms this linear single-inheritance chain; NEW in extra90: first standalone __mro__.__len__ invariant for ThreadPoolExecutor in cfexeccls90 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__mro__.__len__
  args: []
  expected: 3

invariant concurrent_futures_extra90.Executor_bases0_is_object:
  description: "concurrent.futures.Executor.__bases__[0].__name__.__eq__('object') returns True — Executor is the abstract base class and inherits directly from object (no intermediate base); ThreadPoolExecutor and ProcessPoolExecutor both inherit from Executor; the mro length of 2 ([Executor, object]) confirms this; NEW in extra90: first standalone __bases__ invariant for Executor in cfexeccls90 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Executor.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra90.Future_module_is_base:
  description: "concurrent.futures.Future.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures.Future (not to be confused with asyncio.Future) is defined in Lib/concurrent/futures/_base.py alongside Executor; its __module__ is 'concurrent.futures._base', reflecting the internal submodule; NEW in extra90: first standalone __module__ invariant for concurrent.futures.Future in cfexeccls90 namespace; wave 253; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true
