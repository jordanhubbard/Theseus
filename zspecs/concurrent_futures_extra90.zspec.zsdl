# Wave 253 theme: ThreadPoolExecutor and ProcessPoolExecutor class identity.
#
# ThreadPoolExecutor.__module__ == 'concurrent.futures.thread'
# ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'
# ThreadPoolExecutor.__mro__.__len__() == 3
# ThreadPoolExecutor.__name__ == 'ThreadPoolExecutor'
# ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor'
# ---------------------------------------------------------------------------

