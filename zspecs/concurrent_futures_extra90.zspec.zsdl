    - [tpe_qualname,     ThreadPoolExecutor.__qualname__.__eq__,             ["ThreadPoolExecutor"],        true, "ThreadPoolExecutor.__qualname__ == 'ThreadPoolExecutor' — qualified name; verified with Python 3.14.3"]

