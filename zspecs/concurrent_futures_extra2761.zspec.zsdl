spec: concurrent_futures_extra2761
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "concurrent_futures_extra.zspec.zsdl — covers class names, module checks, function names, constant type checks"
    - "concurrent_futures_extra2.zspec.zsdl — covers module checks, constant values, method names"
  notes:
    - "Wave 631 theme: __matmul__, __truediv__, and __iadd__ dict-presence checks."
    - "None of the concurrent.futures public classes define __matmul__, __truediv__, or __iadd__ in their __dict__."
    - "Future is a pure-Python result container; ThreadPoolExecutor and ProcessPoolExecutor are executor pool classes."
    - "'__matmul__' in Future.__dict__ == False; likewise for __truediv__ and __iadd__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future — __matmul__/__truediv__/__iadd__
# dict-presence checks
#
# Future is a pure-Python result container (Lib/concurrent/futures/_base.py).
# It wraps the result of an async computation. It does not define numeric
# operator dunders: __matmul__, __truediv__, or __iadd__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2761.future_operator_dict:
  description: "concurrent.futures.Future __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2761f

  columns: [id, function, args, expected]
  rows:
    - ["cf2761f_matmul",  Future.__dict__.__contains__, ["__matmul__"],  false]
    - ["cf2761f_truediv", Future.__dict__.__contains__, ["__truediv__"], false]
    - ["cf2761f_iadd",    Future.__dict__.__contains__, ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor — __matmul__/__truediv__/__iadd__
# dict-presence checks
#
# ThreadPoolExecutor manages a pool of threads and dispatches callables to them.
# It does not implement arithmetic operator dunders.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2761.threadpoolexecutor_operator_dict:
  description: "concurrent.futures.ThreadPoolExecutor __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2761tpe

  columns: [id, function, args, expected]
  rows:
    - ["cf2761tpe_matmul",  ThreadPoolExecutor.__dict__.__contains__, ["__matmul__"],  false]
    - ["cf2761tpe_truediv", ThreadPoolExecutor.__dict__.__contains__, ["__truediv__"], false]
    - ["cf2761tpe_iadd",    ThreadPoolExecutor.__dict__.__contains__, ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor — __matmul__/__truediv__/__iadd__
# dict-presence checks
#
# ProcessPoolExecutor manages a pool of worker processes. Like ThreadPoolExecutor,
# it is a task dispatching class and does not define numeric operator dunders.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2761.processpoolexecutor_operator_dict:
  description: "concurrent.futures.ProcessPoolExecutor __matmul__, __truediv__, __iadd__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2761ppe

  columns: [id, function, args, expected]
  rows:
    - ["cf2761ppe_matmul",  ProcessPoolExecutor.__dict__.__contains__, ["__matmul__"],  false]
    - ["cf2761ppe_truediv", ProcessPoolExecutor.__dict__.__contains__, ["__truediv__"], false]
    - ["cf2761ppe_iadd",    ProcessPoolExecutor.__dict__.__contains__, ["__iadd__"],    false]

# ---------------------------------------------------------------------------
# Full 3×3 cross-type matrix — all concurrent.futures types, all three operator dunders
#
# Consolidates the complete 3×3 dict-presence check in one table.
# Every cell is False: Future, ThreadPoolExecutor, and ProcessPoolExecutor
# do not define @, /, or += operator dunders in their __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2761.all_types_matmul_truediv_iadd_matrix:
  description: "Full 3×3 dict-presence matrix for concurrent.futures types vs __matmul__/__truediv__/__iadd__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2761mx

  columns: [id, function, args, expected]
  rows:
    - ["cf2761mx_f_mm",   Future.__dict__.__contains__,              ["__matmul__"],  false]
    - ["cf2761mx_f_td",   Future.__dict__.__contains__,              ["__truediv__"], false]
    - ["cf2761mx_f_ia",   Future.__dict__.__contains__,              ["__iadd__"],    false]
    - ["cf2761mx_tpe_mm", ThreadPoolExecutor.__dict__.__contains__,  ["__matmul__"],  false]
    - ["cf2761mx_tpe_td", ThreadPoolExecutor.__dict__.__contains__,  ["__truediv__"], false]
    - ["cf2761mx_tpe_ia", ThreadPoolExecutor.__dict__.__contains__,  ["__iadd__"],    false]
    - ["cf2761mx_ppe_mm", ProcessPoolExecutor.__dict__.__contains__,  ["__matmul__"],  false]
    - ["cf2761mx_ppe_td", ProcessPoolExecutor.__dict__.__contains__,  ["__truediv__"], false]
