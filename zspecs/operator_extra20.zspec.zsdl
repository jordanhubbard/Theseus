spec: operator_extra20
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra19.zspec.zsdl."
    - "operator_extra19 covers: getitem/contains/length_hint/index/concat call results."
    - "operator_extra18 covers: comparison (eq/ne/lt/le/gt/ge), not_, and bitwise (and_/or_/xor) call results."
    - "No prior operator spec records __name__.__eq__ for add/sub/mul/truediv/floordiv/mod/pow/neg together in the extra20 namespace."
    - "All eight arithmetic operator functions have __name__ equal to their simple string name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__eq__ table — eight arithmetic operator functions
#
# Verifies that each function's __name__ attribute equals its simple string name.
# No prior operator spec groups add/sub/mul/truediv/floordiv/mod/pow/neg
# together in a single table in the extra20 namespace.
# ---------------------------------------------------------------------------

table operator_extra20.names:
  kind: python_call_eq
  category: function_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra20.names.add,
       add.__name__.__eq__,
       ["add"],
       true,
       "operator.add.__name__ == 'add'"]
    - [operator_extra20.names.sub,
       sub.__name__.__eq__,
       ["sub"],
       true,
       "operator.sub.__name__ == 'sub'"]
    - [operator_extra20.names.mul,
       mul.__name__.__eq__,
       ["mul"],
       true,
       "operator.mul.__name__ == 'mul'"]
    - [operator_extra20.names.truediv,
       truediv.__name__.__eq__,
       ["truediv"],
       true,
       "operator.truediv.__name__ == 'truediv'"]
    - [operator_extra20.names.floordiv,
       floordiv.__name__.__eq__,
       ["floordiv"],
       true,
       "operator.floordiv.__name__ == 'floordiv'"]
    - [operator_extra20.names.mod,
       mod.__name__.__eq__,
       ["mod"],
       true,
       "operator.mod.__name__ == 'mod'"]
    - [operator_extra20.names.pow,
       pow.__name__.__eq__,
       ["pow"],
       true,
       "operator.pow.__name__ == 'pow'"]
    - [operator_extra20.names.neg,
       neg.__name__.__eq__,
       ["neg"],
       true,
       "operator.neg.__name__ == 'neg'"]

# ---------------------------------------------------------------------------
# Arithmetic call results — add, sub, mul, truediv, floordiv, mod, pow, neg
#
# Verifies that each arithmetic operator function returns the expected value
# for simple integer arguments. No prior operator spec records all eight
# arithmetic call results in the extra20 namespace.
# ---------------------------------------------------------------------------

table operator_extra20.arithmetic_calls:
  kind: python_call_eq
  category: call_results
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra20.arithmetic_calls.add,
       add,
       [10, 3],
       13,
       "operator.add(10, 3) == 13 — integer addition"]
    - [operator_extra20.arithmetic_calls.sub,
       sub,
       [10, 3],
       7,
       "operator.sub(10, 3) == 7 — integer subtraction"]
    - [operator_extra20.arithmetic_calls.mul,
       mul,
       [10, 3],
       30,
       "operator.mul(10, 3) == 30 — integer multiplication"]
    - [operator_extra20.arithmetic_calls.floordiv,
       floordiv,
       [10, 3],
       3,
       "operator.floordiv(10, 3) == 3 — integer floor division"]
    - [operator_extra20.arithmetic_calls.mod,
       mod,
       [10, 3],
       1,
       "operator.mod(10, 3) == 1 — integer modulo"]
    - [operator_extra20.arithmetic_calls.pow,
       pow,
       [2, 8],
       256,
       "operator.pow(2, 8) == 256 — integer exponentiation"]
    - [operator_extra20.arithmetic_calls.neg,
       neg,
       [42],
       -42,
       "operator.neg(42) == -42 — integer negation"]

# ---------------------------------------------------------------------------
# truediv call result (standalone invariant)
#
# operator.truediv(10, 4) == 2.5 — true division always returns a float.
# Kept as a standalone invariant because the expected value is a float,
# which is distinct from the integer results in the arithmetic_calls table.
# No prior operator spec records this in the extra20 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra20.arithmetic_calls.truediv:
  description: "operator.truediv(10, 4) == 2.5 — true division returns float"
  category: call_results
  kind: python_call_eq
  function: truediv
  args: [10, 4]
  expected: 2.5
