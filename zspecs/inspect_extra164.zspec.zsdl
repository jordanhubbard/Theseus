spec: inspect_extra164
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.Parameter.empty.__name__ '_empty'; inspect.Parameter.empty.__module__ 'inspect'; inspect.Parameter.empty.__class__.__name__ 'type'; inspect.Signature.empty.__name__ '_empty'; inspect.BoundArguments.arguments.__class__.__name__ 'member_descriptor'; inspect.Parameter.__name__ 'Parameter'; inspect.Parameter.__module__ 'inspect' (Wave 293)."
    - "inspect.Parameter.empty.__name__ == '_empty' — inspect.Parameter.empty is a sentinel class defined in Lib/inspect.py as '_empty'; it is used to indicate that a Parameter has no default value and no annotation; its __name__ is '_empty'. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__module__ == 'inspect' — the _empty sentinel class is defined at module scope in Lib/inspect.py; its __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.Parameter.empty.__class__.__name__ == 'type' — inspect.Parameter.empty is a class object (the _empty class itself, not an instance); its __class__ is the metaclass 'type'; __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "inspect.Signature.empty.__name__ == '_empty' — inspect.Signature.empty is the same object as inspect.Parameter.empty; both are the _empty sentinel class; its __name__ is '_empty'. Verified with Python 3.14.3."
    - "inspect.BoundArguments.arguments.__class__.__name__ == 'member_descriptor' — accessing BoundArguments.arguments on the class (not an instance) returns a C member descriptor; its __class__.__name__ is 'member_descriptor'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.Parameter.empty sentinel identity
#
# Wave 293 theme: inspect.Parameter.empty — the _empty sentinel class identity
# attributes including __name__, __module__, and metaclass.
#
# inspect.Parameter.empty.__name__ == '_empty'
# inspect.Parameter.empty.__module__ == 'inspect'
# inspect.Parameter.empty.__class__.__name__ == 'type'
# inspect.Signature.empty.__name__ == '_empty'
#
# inspect.Parameter.empty is a special sentinel class defined in Lib/inspect.py
# as class _empty: pass. It is assigned as a class attribute on Parameter and
# Signature to represent the absence of a default value or annotation. Accessing
# it on the class returns the _empty class itself (not an instance). Its __name__
# is '_empty', its __module__ is 'inspect', and its __class__ is the metaclass
# 'type'. inspect.Signature.empty is the same object. New to extra164.
# ---------------------------------------------------------------------------

table inspect_extra164.parameter_empty_sentinel_identity:
  description: "inspect.Parameter.empty: __name__ '_empty', __module__ 'inspect', __class__.__name__ 'type'; Signature.empty.__name__ '_empty'; wave 293; new to extra164"
  kind: python_call_eq
  category: identity
  id_prefix: inspectpesi164

  columns: [id, function, args, expected, description]
  rows:
    - [param_empty_name_eq_empty,
       "Parameter.empty.__name__.__eq__",
       ["_empty"],
       true,
       "inspect.Parameter.empty.__name__.__eq__('_empty') == True — Parameter.empty is the _empty sentinel class defined in Lib/inspect.py; it signals that a parameter has no default value or annotation; its class __name__ is '_empty'; str.__eq__('_empty') returns True; new to extra164"]
    - [param_empty_module_eq_inspect,
       "Parameter.empty.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.empty.__module__.__eq__('inspect') == True — the _empty sentinel class is defined at module level in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra164"]
    - [param_empty_class_name_eq_type,
       "Parameter.empty.__class__.__name__.__eq__",
       ["type"],
       true,
       "inspect.Parameter.empty.__class__.__name__.__eq__('type') == True — Parameter.empty is the _empty class itself (not an instance of it); as a class object its __class__ is the metaclass 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra164"]
    - [sig_empty_name_eq_empty,
       "Signature.empty.__name__.__eq__",
       ["_empty"],
       true,
       "inspect.Signature.empty.__name__.__eq__('_empty') == True — Signature.empty is the same object as Parameter.empty; both reference the single _empty sentinel class defined in Lib/inspect.py; its __name__ is '_empty'; str.__eq__('_empty') returns True; new to extra164"]

# ---------------------------------------------------------------------------
# Table 2: inspect.BoundArguments.arguments descriptor and Parameter identity
#
# Wave 293 theme: inspect.BoundArguments.arguments class-level descriptor type
# and inspect.Parameter class identity.
#
# inspect.BoundArguments.arguments.__class__.__name__ == 'member_descriptor'
# inspect.Parameter.__name__ == 'Parameter'
# inspect.Parameter.__module__ == 'inspect'
# inspect.Parameter.empty.__class__.__name__ == 'type' (cross-check)
#
# inspect.BoundArguments holds the result of Signature.bind(). Its .arguments
# attribute on instances is an OrderedDict mapping parameter names to values.
# Accessing BoundArguments.arguments on the class itself returns the underlying
# C member descriptor (because BoundArguments is defined as a C namedtuple-like
# structure in Lib/inspect.py backed by a __slots__ member); its
# __class__.__name__ is 'member_descriptor'. inspect.Parameter is the Python
# class in Lib/inspect.py that represents an individual function parameter.
# New to extra164.
# ---------------------------------------------------------------------------

table inspect_extra164.boundarguments_arguments_descriptor_and_parameter_identity:
  description: "inspect.BoundArguments.arguments.__class__.__name__ 'member_descriptor'; Parameter.__name__ 'Parameter', Parameter.__module__ 'inspect'; wave 293; new to extra164"
  kind: python_call_eq
  category: identity
  id_prefix: inspectbadpi164

  columns: [id, function, args, expected, description]
  rows:
    - [ba_args_desc_cls_member,
       "BoundArguments.arguments.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "inspect.BoundArguments.arguments.__class__.__name__.__eq__('member_descriptor') == True — accessing BoundArguments.arguments on the class (not an instance) returns the C member descriptor slot; its __class__.__name__ is 'member_descriptor'; str.__eq__('member_descriptor') returns True; new to extra164"]
    - [param_name_eq_parameter,
       "Parameter.__name__.__eq__",
       ["Parameter"],
       true,
       "inspect.Parameter.__name__.__eq__('Parameter') == True — inspect.Parameter is the Python class in Lib/inspect.py representing an individual function parameter with attributes name/default/annotation/kind; its class __name__ is 'Parameter'; str.__eq__('Parameter') returns True; new to extra164"]
    - [param_module_eq_inspect,
       "Parameter.__module__.__eq__",
       ["inspect"],
       true,
       "inspect.Parameter.__module__.__eq__('inspect') == True — inspect.Parameter is defined in Lib/inspect.py; its __module__ is 'inspect'; str.__eq__('inspect') returns True; new to extra164"]
    - [param_empty_class_ne_str,
       "Parameter.empty.__class__.__name__.__eq__",
       ["str"],
       false,
       "inspect.Parameter.empty.__class__.__name__.__eq__('str') == False — Parameter.empty is the _empty sentinel class itself; it is a class object (metaclass 'type'), not a str instance; __class__.__name__ is 'type' not 'str'; str.__eq__('str') returns False; new to extra164"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra164
# ---------------------------------------------------------------------------

invariant inspect_extra164.parameter_empty_name_empty:
  description: "inspect.Parameter.empty.__name__ == '_empty' — sentinel class for absent default/annotation; wave 293; new to extra164"
  kind: python_call_eq
  function: Parameter.empty.__name__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra164.parameter_empty_module_inspect:
  description: "inspect.Parameter.empty.__module__ == 'inspect' — _empty sentinel class is defined in Lib/inspect.py; wave 293; new to extra164"
  kind: python_call_eq
  function: Parameter.empty.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra164.parameter_empty_class_type:
  description: "inspect.Parameter.empty.__class__.__name__ == 'type' — Parameter.empty is the _empty class itself; its metaclass is 'type'; wave 293; new to extra164"
  kind: python_call_eq
  function: Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra164.signature_empty_name_empty:
  description: "inspect.Signature.empty.__name__ == '_empty' — same object as Parameter.empty; the single _empty sentinel; wave 293; new to extra164"
  kind: python_call_eq
  function: Signature.empty.__name__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra164.boundarguments_arguments_member_descriptor:
  description: "inspect.BoundArguments.arguments.__class__.__name__ == 'member_descriptor' — class-level access returns the C member descriptor slot; wave 293; new to extra164"
  kind: python_call_eq
  function: BoundArguments.arguments.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant inspect_extra164.parameter_name_parameter:
  description: "inspect.Parameter.__name__ == 'Parameter' — the Parameter class in Lib/inspect.py represents a single function parameter; wave 293; new to extra164"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra164.parameter_module_inspect:
  description: "inspect.Parameter.__module__ == 'inspect' — Parameter is defined in Lib/inspect.py; wave 293; new to extra164"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra164.signature_empty_module_inspect:
  description: "inspect.Signature.empty.__module__ == 'inspect' — Signature.empty is the _empty sentinel class defined in Lib/inspect.py; wave 293; new to extra164"
  kind: python_call_eq
  function: Signature.empty.__module__.__eq__
  args: ["inspect"]
  expected: true
