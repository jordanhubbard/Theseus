spec: decimal_extra72
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra71."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal.__dict__.__contains__ for arithmetic/conversion dunders; Decimal.__sub__/__neg__/__abs__/__bool__/__float__/__int__ __class__.__name__ == 'wrapper_descriptor'; Context.__qualname__/__bases__/__mro__."
    - "decimal_extra71 covers Decimal.__sub__/__neg__/__abs__/__bool__/__float__/__int__ wrapper_descriptor identity; Decimal.__sub__ qualname; Context class hierarchy."
    - "This spec covers: Decimal.__lt__/__le__/__gt__/__ge__/__eq__/__hash__ __class__.__name__ == 'wrapper_descriptor'; Context.__dict__.__class__.__name__ == 'mappingproxy'; Context.__dict__.__contains__ for quantize/add/sqrt/clear_flags."
    - "decimal.Decimal.__lt__.__class__.__name__ == 'wrapper_descriptor' — C slot wrapper for less-than comparison."
    - "decimal.Decimal.__le__.__class__.__name__ == 'wrapper_descriptor' — C slot wrapper for less-than-or-equal comparison."
    - "decimal.Decimal.__gt__.__class__.__name__ == 'wrapper_descriptor' — C slot wrapper for greater-than comparison."
    - "decimal.Decimal.__ge__.__class__.__name__ == 'wrapper_descriptor' — C slot wrapper for greater-than-or-equal comparison."
    - "decimal.Decimal.__eq__.__class__.__name__ == 'wrapper_descriptor' — C slot wrapper for equality comparison."
    - "decimal.Decimal.__hash__.__class__.__name__ == 'wrapper_descriptor' — C slot wrapper for hashing."
    - "decimal.Context.__dict__.__class__.__name__ == 'mappingproxy' — C extension type __dict__ is always a mappingproxy."
    - "decimal.Context.__dict__.__contains__('quantize') == True — Context defines quantize() directly in C."
    - "decimal.Context.__dict__.__contains__('add') == True — Context defines add() directly in C."
    - "decimal.Context.__dict__.__contains__('sqrt') == True — Context defines sqrt() directly in C."
    - "decimal.Context.__dict__.__contains__('clear_flags') == True — Context defines clear_flags() directly in C."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal comparison operator wrapper_descriptor identity
# __lt__, __le__, __gt__, __ge__ are C slot wrappers on Decimal.
# Their __class__.__name__ == 'wrapper_descriptor'.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra72.Decimal_comparison_wrapper_class:
  description: "Decimal.__lt__, __le__, __gt__, __ge__ __class__.__name__ == 'wrapper_descriptor'"
  kind: python_call_eq
  category: slot_wrappers
  id_prefix: decimalmore72

  columns: [id, function, args, expected]
  rows:
    - [lt_cls, Decimal.__lt__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [le_cls, Decimal.__le__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [gt_cls, Decimal.__gt__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - [ge_cls, Decimal.__ge__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Decimal equality and hash wrapper_descriptor identity
# __eq__ and __hash__ are also C slot wrappers on Decimal.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra72.Decimal_eq_hash_wrapper_class:
  description: "Decimal.__eq__ and __hash__ __class__.__name__ == 'wrapper_descriptor'"
  kind: python_call_eq
  category: slot_wrappers
  id_prefix: decimalmore72

  columns: [id, function, args, expected]
  rows:
    - [eq_cls,   Decimal.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - [hash_cls, Decimal.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Context.__dict__ class name
# Context is a C extension type; its __dict__ attribute is a mappingproxy.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra72.Context_dict_class:
  description: "Context.__dict__.__class__.__name__ == 'mappingproxy'"
  kind: python_call_eq
  category: class_dict
  id_prefix: decimalmore72

  columns: [id, function, args, expected]
  rows:
    - [ctx_dict_cls, Context.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# Context.__dict__ membership for key methods
# quantize, add, sqrt, and clear_flags are all defined directly in the C
# Context type (_decimal extension).
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra72.Context_dict_contains:
  description: "Context.__dict__ contains quantize, add, sqrt, clear_flags"
  kind: python_call_eq
  category: class_dict
  id_prefix: decimalmore72

  columns: [id, function, args, expected]
  rows:
    - [ctx_has_quantize,     "Context.__dict__.__contains__", ["quantize"],     true]
    - [ctx_has_add,          "Context.__dict__.__contains__", ["add"],          true]
    - [ctx_has_sqrt,         "Context.__dict__.__contains__", ["sqrt"],         true]
    - [ctx_has_clear_flags,  "Context.__dict__.__contains__", ["clear_flags"],  true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra72.Decimal_lt.wrapper_descriptor:
  description: "decimal.Decimal.__lt__.__class__.__name__ == 'wrapper_descriptor'"
  category: slot_wrappers
  kind: python_call_eq
  function: Decimal.__lt__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra72.Decimal_ge.wrapper_descriptor:
  description: "decimal.Decimal.__ge__.__class__.__name__ == 'wrapper_descriptor'"
  category: slot_wrappers
  kind: python_call_eq
  function: Decimal.__ge__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra72.Decimal_hash.wrapper_descriptor:
  description: "decimal.Decimal.__hash__.__class__.__name__ == 'wrapper_descriptor'"
  category: slot_wrappers
  kind: python_call_eq
  function: Decimal.__hash__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra72.Context_dict_class:
  description: "decimal.Context.__dict__.__class__.__name__ == 'mappingproxy'"
  category: class_dict
  kind: python_call_eq
  function: Context.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant decimal_extra72.Context_dict.has_quantize:
  description: "decimal.Context.__dict__.__contains__('quantize') == True"
  category: class_dict
  kind: python_call_eq
  function: "Context.__dict__.__contains__"
  args: ["quantize"]
  expected: true
