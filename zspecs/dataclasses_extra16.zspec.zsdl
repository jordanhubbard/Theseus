spec: dataclasses_extra16
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses documentation"
    - "PEP 557 — Data Classes"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl, dataclasses_field.zspec.zsdl, and dataclasses_extra through dataclasses_extra15.zspec.zsdl."
    - "dataclasses_extra15 covers: Field/__name__.__len__, InitVar/__name__.__len__, FrozenInstanceError/__name__.__len__, Field/__qualname__.__len__, InitVar/__qualname__.__len__, is_dataclass/__qualname__.__len__, make_dataclass/__qualname__.__len__; dataclass/__module__; field/__module__."
    - "dataclasses_extra14 covers: Field/__bases__ len/[0]; FrozenInstanceError/__bases__[0].__name__; module/__name__/__eq__; dataclass/__qualname__; replace/__name__/__name__.__len__; is_dataclass/__name__.__len__."
    - "dataclasses_extra13 covers: __name__.__len__ for field/asdict/astuple/make_dataclass; __qualname__ table for fields/asdict/astuple/replace/is_dataclass; Field/__qualname__; InitVar/__qualname__; __loader__.__class__.__name__; FrozenInstanceError/__qualname__.__len__."
    - "NOT yet covered: dataclasses.replace.__qualname__.__len__() == 7 — qualname length as standalone invariant."
    - "NOT yet covered: dataclasses.fields.__qualname__.__len__() == 6 — qualname length as standalone invariant."
    - "NOT yet covered: dataclasses.asdict.__qualname__.__len__() == 6 — qualname length as standalone invariant."
    - "NOT yet covered: dataclasses.astuple.__qualname__.__len__() == 7 — qualname length as standalone invariant."
    - "NOT yet covered: dataclasses.FrozenInstanceError.__mro__[0].__name__ == 'FrozenInstanceError' — MRO self-identity as standalone invariant."
    - "NOT yet covered: dataclasses.fields.__module__.__eq__('dataclasses') as a standalone invariant (extra8 table only)."
    - "NOT yet covered: dataclasses.asdict.__module__.__eq__('dataclasses') as a standalone invariant (extra8 table only)."
    - "NOT yet covered: dataclasses.astuple.__module__.__eq__('dataclasses') as a standalone invariant (extra8 table only)."
    - "dataclasses.replace.__qualname__.__len__() == 7."
    - "dataclasses.fields.__qualname__.__len__() == 6."
    - "dataclasses.asdict.__qualname__.__len__() == 6."
    - "dataclasses.astuple.__qualname__.__len__() == 7."
    - "dataclasses.FrozenInstanceError.__mro__[0].__name__ == 'FrozenInstanceError'."
    - "dataclasses.fields.__module__ == 'dataclasses' — standalone __eq__ invariant."
    - "dataclasses.asdict.__module__ == 'dataclasses' — standalone __eq__ invariant."
    - "dataclasses.astuple.__module__ == 'dataclasses' — standalone __eq__ invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __qualname__ string lengths — replace, fields, asdict, astuple
#
# dataclasses_extra13 covers __qualname__.__eq__ for these functions via table
# and extra15 covers make_dataclass/__qualname__.__len__ and
# is_dataclass/__qualname__.__len__. No prior spec checks __qualname__.__len__
# for replace, fields, asdict, or astuple. For top-level functions qualname
# equals name so the lengths are the same as the name lengths.
# ---------------------------------------------------------------------------

table dataclasses_extra16.function_qualname_lengths:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualnamelen

  columns: [id, function, args, expected]
  rows:
    - [fields,  fields.__qualname__.__len__,  [], 6]
    - [asdict,  asdict.__qualname__.__len__,  [], 6]
    - [astuple, astuple.__qualname__.__len__, [], 7]
    - [replace, replace.__qualname__.__len__, [], 7]

# ---------------------------------------------------------------------------
# FrozenInstanceError MRO[0] — self-identity
#
# dataclasses_extra10 covers FrozenInstanceError.__mro__.__getitem__(1) ==
# 'AttributeError', extra11 covers MRO[2..4]. No prior spec checks MRO[0]
# for FrozenInstanceError as a standalone invariant.
# MRO[0] must always be the class itself.
# ---------------------------------------------------------------------------

invariant dataclasses_extra16.FrozenInstanceError.mro_first:
  description: "dataclasses.FrozenInstanceError.__mro__[0].__name__ == 'FrozenInstanceError' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: FrozenInstanceError.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "FrozenInstanceError"

# ---------------------------------------------------------------------------
# fields, asdict, astuple — __module__ as standalone invariants
#
# dataclasses_extra8 covers __module__ for these functions in a table, but
# no prior spec verifies them as individual standalone __eq__ invariants.
# All top-level dataclasses functions have __module__ == 'dataclasses'.
# ---------------------------------------------------------------------------

invariant dataclasses_extra16.fields.module:
  description: "dataclasses.fields.__module__ == 'dataclasses' — standalone __eq__ invariant"
  category: module_attrs
  kind: python_call_eq
  function: fields.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra16.asdict.module:
  description: "dataclasses.asdict.__module__ == 'dataclasses' — standalone __eq__ invariant"
  category: module_attrs
  kind: python_call_eq
  function: asdict.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra16.astuple.module:
  description: "dataclasses.astuple.__module__ == 'dataclasses' — standalone __eq__ invariant"
  category: module_attrs
  kind: python_call_eq
  function: astuple.__module__.__eq__
  args: ["dataclasses"]
  expected: true

# ---------------------------------------------------------------------------
# make_dataclass and is_dataclass — __module__ as standalone invariants
#
# No prior spec checks make_dataclass.__module__ or is_dataclass.__module__
# as standalone boolean invariants (extra8 covers them in a table only).
# ---------------------------------------------------------------------------

invariant dataclasses_extra16.make_dataclass.module:
  description: "dataclasses.make_dataclass.__module__ == 'dataclasses' — standalone __eq__ invariant"
  category: module_attrs
  kind: python_call_eq
  function: make_dataclass.__module__.__eq__
  args: ["dataclasses"]
  expected: true

invariant dataclasses_extra16.is_dataclass.module:
  description: "dataclasses.is_dataclass.__module__ == 'dataclasses' — standalone __eq__ invariant"
  category: module_attrs
  kind: python_call_eq
  function: is_dataclass.__module__.__eq__
  args: ["dataclasses"]
  expected: true
