spec: traceback_extra17
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback.zspec.zsdl through traceback_extra16.zspec.zsdl."
    - "traceback_extra16 covers: __mro__[-1].__name__ == 'object' for TracebackException/StackSummary/FrameSummary; traceback.__name__ == 'traceback'; traceback.__package__ == ''."
    - "traceback_extra14 covers: __class__.__name__ == 'function' for all 16 module-level functions."
    - "traceback_extra13 covers: __name__/__qualname__/__module__ for all public module-level functions."
    - "traceback_extra10 covers: TracebackException.__init__.__qualname__; FrameSummary.__getitem__/__len__ qualnames."
    - "traceback_extra9 covers: TracebackException method qualnames; FrameSummary.__init__/__repr__ qualnames; MRO lengths."
    - "NOT yet covered in any prior spec: traceback.TracebackException.__class__.__name__ == 'type' as a standalone invariant."
    - "NOT yet covered in any prior spec: traceback.StackSummary.__class__.__name__ == 'type' as a standalone invariant."
    - "NOT yet covered in any prior spec: traceback.FrameSummary.__class__.__name__ == 'type' as a standalone invariant."
    - "NOT yet covered in any prior spec: TracebackException.__eq__.__qualname__ == 'TracebackException.__eq__' as a standalone invariant."
    - "NOT yet covered in any prior spec: TracebackException.__str__.__qualname__ == 'TracebackException.__str__' as a standalone invariant."
    - "NOT yet covered in any prior spec: traceback.__loader__.__class__.__name__ == 'SourceFileLoader' as a standalone invariant."
    - "NOT yet covered in any prior spec: FrameSummary.__slots__.__len__() == 10 as a standalone invariant."
    - "TracebackException/StackSummary/FrameSummary are all defined at module level; their __class__.__name__ == 'type'."
    - "TracebackException defines __eq__ and __str__ at the class level; both report compound qualnames."
    - "traceback is loaded from Lib/traceback.py by the SourceFileLoader."
    - "FrameSummary.__slots__ holds 10 named slots: filename, lineno, end_lineno, colno, end_colno, name, _lines, _lines_dedented, locals, _code."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __class__.__name__ for TracebackException, StackSummary, FrameSummary
#
# traceback_extra14 records __class__.__name__ == 'function' for all 16
# module-level functions. No prior spec records __class__.__name__ for
# the three traceback classes. All three are defined at module level;
# their metaclass is the builtin 'type'.
# ---------------------------------------------------------------------------

invariant traceback_extra17.TracebackException.class_name:
  description: "traceback.TracebackException.__class__.__name__ == 'type' — defined at module level"
  category: class_identity
  kind: python_call_eq
  function: TracebackException.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant traceback_extra17.StackSummary.class_name:
  description: "traceback.StackSummary.__class__.__name__ == 'type' — defined at module level"
  category: class_identity
  kind: python_call_eq
  function: StackSummary.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant traceback_extra17.FrameSummary.class_name:
  description: "traceback.FrameSummary.__class__.__name__ == 'type' — defined at module level"
  category: class_identity
  kind: python_call_eq
  function: FrameSummary.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# TracebackException special method __qualname__ — __eq__ and __str__
#
# traceback_extra9 covers TracebackException.format/format_exception_only/
# print/from_exception method qualnames. traceback_extra10 covers __init__.
# No prior spec records __eq__ or __str__ qualnames for TracebackException.
# Both are defined in the class body; their __qualname__ includes the class
# name prefix: 'TracebackException.__eq__' and 'TracebackException.__str__'.
# ---------------------------------------------------------------------------

invariant traceback_extra17.TracebackException.eq_qualname:
  description: "traceback.TracebackException.__eq__.__qualname__ == 'TracebackException.__eq__'"
  category: function_identity
  kind: python_call_eq
  function: TracebackException.__eq__.__qualname__.__eq__
  args: ["TracebackException.__eq__"]
  expected: true

invariant traceback_extra17.TracebackException.str_qualname:
  description: "traceback.TracebackException.__str__.__qualname__ == 'TracebackException.__str__'"
  category: function_identity
  kind: python_call_eq
  function: TracebackException.__str__.__qualname__.__eq__
  args: ["TracebackException.__str__"]
  expected: true

# ---------------------------------------------------------------------------
# traceback module loader — __loader__.__class__.__name__
#
# traceback_extra16 records traceback.__name__ and traceback.__package__.
# No prior spec records the loader type. traceback is a pure-Python stdlib
# module; it is loaded via importlib's SourceFileLoader.
# ---------------------------------------------------------------------------

invariant traceback_extra17.module.loader_class:
  description: "traceback.__loader__.__class__.__name__ == 'SourceFileLoader' — loaded from Lib/traceback.py"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# FrameSummary.__slots__ — length
#
# No prior spec records the length of FrameSummary.__slots__. The slots tuple
# holds 10 named fields: filename, lineno, end_lineno, colno, end_colno,
# name, _lines, _lines_dedented, locals, _code. This invariant confirms the
# slot count is stable across CPython versions >= 3.9.
# ---------------------------------------------------------------------------

invariant traceback_extra17.FrameSummary.slots_len:
  description: "traceback.FrameSummary.__slots__.__len__() == 10 — ten named slots"
  category: class_attrs
  kind: python_call_eq
  function: FrameSummary.__slots__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# __class__.__name__ table — TracebackException, StackSummary, FrameSummary
#
# Consolidates the three class metaclass checks in a single table.
# ---------------------------------------------------------------------------

table traceback_extra17.class_metaclass_names:
  description: "__class__.__name__ == 'type' for TracebackException, StackSummary, FrameSummary"
  kind: python_call_eq
  category: class_identity

  columns: [id, function, args, expected]
  rows:
    - [TracebackException, TracebackException.__class__.__name__.__eq__, ["type"], true]
    - [StackSummary,       StackSummary.__class__.__name__.__eq__,       ["type"], true]
    - [FrameSummary,       FrameSummary.__class__.__name__.__eq__,       ["type"], true]
