spec: ft3196
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 660 (ft3196): __pow__, __lshift__, __rshift__ dict-presence checks for functools types."
    - "None of the four functools types define __pow__, __lshift__, or __rshift__ in their own __dict__."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "functools._lru_cache_wrapper is accessed as type(functools.lru_cache(lambda: None)) at runtime; functools._lru_cache_wrapper is the internal C wrapper class."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3196.pow:
  description: "functools types __pow__ dict-presence checks; wave 660"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3196
  columns: [id, function, args, expected]
  rows:
    - ["ft3196001", operator.contains, [functools.partial.__dict__,            "__pow__"], false]
    - ["ft3196002", operator.contains, [functools.partialmethod.__dict__,      "__pow__"], false]
    - ["ft3196003", operator.contains, [functools.cached_property.__dict__,    "__pow__"], false]
    - ["ft3196004", operator.contains, [functools._lru_cache_wrapper.__dict__, "__pow__"], false]

