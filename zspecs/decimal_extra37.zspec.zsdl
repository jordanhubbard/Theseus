spec: decimal_extra37
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra36.zspec.zsdl — covers DecimalException/__name__=='DecimalException'/__module__=='decimal'; DecimalException.__bases__[0].__name__=='ArithmeticError'; InvalidOperation/__name__=='InvalidOperation'/__bases__[0].__name__=='DecimalException'; DivisionByZero/Overflow/Underflow/Inexact __name__ equality."
    - "decimal_extra35.zspec.zsdl — covers DefaultContext.prec==28/Emin==-999999/Emax==999999/rounding/clamp direct attribute access."
    - "decimal_extra34.zspec.zsdl — covers decimal.__name__.__len__()==7; getcontext() Emax/Emin/rounding via method chain; Decimal quantize behavioral."
    - "decimal_extra33.zspec.zsdl — covers Decimal.__pos__/__int__/__ceil__ and other dunder __qualname__.__len__()."
    - "decimal_extra24.zspec.zsdl — covers Decimal.__module__.__eq__('decimal') / __module__.__len__()==7."
    - "decimal_extra20.zspec.zsdl — covers ROUND_UP/ROUND_DOWN/ROUND_HALF_EVEN __len__()."
    - "decimal_extra17.zspec.zsdl — covers ROUND_* __class__.__name__.__eq__('str')."
    - "decimal_extra14.zspec.zsdl — covers getcontext().prec==28 via method chain."
    - "decimal_extra13.zspec.zsdl — covers Decimal.__name__.__eq__('Decimal'); ROUND_DOWN/ROUND_UP equality."
    - "decimal_extra.zspec.zsdl — covers DefaultContext.__class__.__name__.__eq__('Context')."
  notes:
    - "This spec extends decimal_extra36.zspec.zsdl."
    - "Prior specs collectively covered: Decimal/Context/__module__/__name__/__qualname__ and lengths; all Decimal/Context method __qualname__.__len__(); all exception class __name__ equality (DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow/Inexact); exception hierarchy via __bases__[0].__name__; all ROUND_* constants; getcontext()/DefaultContext attribute access; behavioral tests."
    - "This spec covers: decimal.InvalidOperation.__module__ == 'decimal' (NOVEL — decimal_extra36 covers InvalidOperation.__name__.__eq__ and __bases__[0].__name__ but not __module__.__eq__ as standalone invariant; novel equality in decimal_extra37 namespace); decimal.DivisionByZero.__module__ == 'decimal' (NOVEL — decimal_extra36 covers DivisionByZero.__name__ but not __module__); decimal.Overflow.__module__ == 'decimal' (NOVEL — decimal_extra36 covers Overflow.__name__ but not __module__); decimal.Underflow.__module__ == 'decimal' (NOVEL); decimal.Inexact.__module__ == 'decimal' (NOVEL); decimal.Rounded.__name__ == 'Rounded' (NOVEL — no prior decimal spec checks Rounded.__name__.__eq__; Rounded is a decimal signal not covered by decimal_extra36's four-class table); decimal.Subnormal.__name__ == 'Subnormal' (NOVEL — no prior decimal spec covers Subnormal.__name__.__eq__); decimal.Clamped.__name__ == 'Clamped' (NOVEL — no prior decimal spec covers Clamped.__name__.__eq__); decimal.FloatOperation.__name__ == 'FloatOperation' (NOVEL — no prior decimal spec covers FloatOperation.__name__.__eq__)."
    - "decimal.InvalidOperation.__module__ == 'decimal'. decimal_extra36 covers InvalidOperation.__name__=='InvalidOperation' and __bases__[0].__name__=='DecimalException' but not __module__.__eq__. InvalidOperation is defined in the decimal module. Novel standalone equality anchor in decimal_extra37. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DivisionByZero.__module__ == 'decimal'. decimal_extra36 covers DivisionByZero.__name__=='DivisionByZero' but not __module__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Overflow.__module__ == 'decimal'. decimal_extra36 covers Overflow.__name__=='Overflow' but not __module__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Underflow.__module__ == 'decimal'. decimal_extra36 covers Underflow.__name__=='Underflow' but not __module__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Inexact.__module__ == 'decimal'. decimal_extra36 covers Inexact.__name__=='Inexact' but not __module__. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Rounded.__name__ == 'Rounded'. Rounded is raised when a result is rounded (IEEE 754 signal). It is a DecimalException subclass. No prior decimal spec covers Rounded.__name__.__eq__. decimal_extra36 covers DivisionByZero/Overflow/Underflow/Inexact but not Rounded. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Subnormal.__name__ == 'Subnormal'. Subnormal is raised when a result is subnormal (before rounding). DecimalException subclass. No prior decimal spec covers this. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Clamped.__name__ == 'Clamped'. Clamped is raised when the exponent is changed to fit the context. DecimalException subclass. No prior decimal spec covers this. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.FloatOperation.__name__ == 'FloatOperation'. FloatOperation is raised (or logged) when a float is mixed into a decimal operation. DecimalException subclass. No prior decimal spec covers this. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal exception subclass __module__ attributes
#
# InvalidOperation, DivisionByZero, Overflow, Underflow, and Inexact are all
# DecimalException subclasses. decimal_extra36 covers their __name__ equality
# but not their __module__. All five are defined in the decimal module, so
# __module__ == 'decimal' for each.
#
# All five novel standalone equality anchors in decimal_extra37 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra37.exception_subclass_modules:
  description: "decimal exception subclass __module__ attributes: InvalidOperation/DivisionByZero/Overflow/Underflow/Inexact __module__=='decimal' — decimal_extra36 covers their __name__ equality but not __module__; all five novel equality anchors in decimal_extra37 namespace"
  kind: python_call_eq
  category: class_identity
  id_prefix: desm37

  columns: [id, function, args, expected]
  rows:
    - [InvalidOperation_module, InvalidOperation.__module__.__eq__, ["decimal"], true]
    - [DivisionByZero_module,   DivisionByZero.__module__.__eq__,  ["decimal"], true]
    - [Overflow_module,         Overflow.__module__.__eq__,        ["decimal"], true]
    - [Underflow_module,        Underflow.__module__.__eq__,       ["decimal"], true]
    - [Inexact_module,          Inexact.__module__.__eq__,         ["decimal"], true]

# ---------------------------------------------------------------------------
# Additional decimal exception subclass __name__ attributes
#
# Rounded, Subnormal, Clamped, and FloatOperation are decimal signal classes
# not covered by decimal_extra36. Each is a DecimalException subclass:
#
#   Rounded.__name__        == 'Rounded'         (raised when rounding occurs)
#   Subnormal.__name__      == 'Subnormal'        (raised for subnormal results)
#   Clamped.__name__        == 'Clamped'          (raised when exponent is clamped)
#   FloatOperation.__name__ == 'FloatOperation'   (raised when float mixes with Decimal)
#
# All four novel equality anchors in decimal_extra37 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra37.additional_exception_names:
  description: "decimal additional exception subclass __name__ attributes: Rounded/Subnormal/Clamped/FloatOperation — decimal_extra36 covers DivisionByZero/Overflow/Underflow/Inexact but not these four; all novel equality anchors in decimal_extra37 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: daen37

  columns: [id, function, args, expected]
  rows:
    - [Rounded_name,        Rounded.__name__.__eq__,        ["Rounded"],        true]
    - [Subnormal_name,      Subnormal.__name__.__eq__,      ["Subnormal"],      true]
    - [Clamped_name,        Clamped.__name__.__eq__,        ["Clamped"],        true]
    - [FloatOperation_name, FloatOperation.__name__.__eq__, ["FloatOperation"], true]
