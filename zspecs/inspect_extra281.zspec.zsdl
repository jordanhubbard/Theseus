spec: inspect_extra281
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.Signature is a pure-Python class: __module__ == 'inspect', __class__.__name__ == 'type', __bases__[0].__name__ == 'object'."
    - "Signature.__name__ == 'Signature' (9 chars); top-level class in the inspect module."
    - "inspect.Signature.empty is a sentinel class: __name__ == '_empty', __module__ == 'inspect', __qualname__ == '_empty'."
    - "Signature.empty.__class__.__name__ == 'type' — the sentinel is itself a class object."
    - "inspect.signature is a pure-Python function: __module__ == 'inspect', __class__.__name__ == 'function'."
    - "inspect.signature.__doc__ is not None — signature ships with a docstring."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Signature — class identity
#
# Signature.__name__ == 'Signature' (9 chars); __module__ == 'inspect'.
# Signature.__class__.__name__ == 'type' (it is a class).
# Signature.__bases__[0].__name__ == 'object' (inherits directly from object).
# ---------------------------------------------------------------------------

table inspect_extra281.signature_class_identity:
  description: "inspect.Signature class identity — __name__, __module__, __class__.__name__, __bases__[0].__name__, name length; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex281sci

  columns: [id, function, args, expected, description]
  rows:
    - [sci_name_eq,   Signature.__name__.__eq__,                    ["Signature"], true, "inspect.Signature.__name__ == 'Signature'; verified with Python 3.14.3"]
    - [sci_name_len,  Signature.__name__.__len__,                    [],           9,    "inspect.Signature.__name__.__len__() == 9 — 'Signature' has 9 chars; verified with Python 3.14.3"]
    - [sci_mod_eq,    Signature.__module__.__eq__,                   ["inspect"],  true, "inspect.Signature.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [sci_cls_eq,    Signature.__class__.__name__.__eq__,           ["type"],     true, "inspect.Signature.__class__.__name__ == 'type' (it is a class); verified with Python 3.14.3"]
    - [sci_base_eq,   "Signature.__bases__[0].__name__.__eq__",      ["object"],   true, "inspect.Signature.__bases__[0].__name__ == 'object' — inherits directly from object; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect.Signature.empty — sentinel class identity
#
# Signature.empty.__name__ == '_empty'; __module__ == 'inspect'; __qualname__ == '_empty'.
# Signature.empty.__class__.__name__ == 'type' — the sentinel is a class object.
# inspect.signature.__doc__ is not None.
# ---------------------------------------------------------------------------

table inspect_extra281.signature_empty_and_func:
  description: "inspect.Signature.empty sentinel identity and inspect.signature function doc; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex281se

  columns: [id, function, args, expected, description]
  rows:
    - [se_name_eq,  "Signature.empty.__name__.__eq__",          ["_empty"],  true,  "inspect.Signature.empty.__name__ == '_empty'; verified with Python 3.14.3"]
    - [se_mod_eq,   "Signature.empty.__module__.__eq__",        ["inspect"], true,  "inspect.Signature.empty.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [se_qn_eq,    "Signature.empty.__qualname__.__eq__",      ["_empty"],  true,  "inspect.Signature.empty.__qualname__ == '_empty'; verified with Python 3.14.3"]
    - [se_cls_eq,   "Signature.empty.__class__.__name__.__eq__", ["type"],   true,  "inspect.Signature.empty.__class__.__name__ == 'type' — sentinel is a class object; verified with Python 3.14.3"]
    - [se_sg_doc,   signature.__doc__.__eq__,                   [null],      false, "inspect.signature.__doc__ is not None — signature ships with a docstring; verified with Python 3.14.3"]
    - [se_sg_cls,   signature.__class__.__name__.__eq__,        ["function"], true, "inspect.signature.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra281
# ---------------------------------------------------------------------------

invariant inspect_extra281.signature_class_name_is_signature:
  description: "inspect.Signature.__name__ == 'Signature' — the class __name__ matches the public API name"
  category: identity
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra281.signature_class_module_is_inspect:
  description: "inspect.Signature.__module__ == 'inspect' — Signature is defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra281.signature_class_bases_object:
  description: "inspect.Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object"
  category: identity
  kind: python_call_eq
  function: "Signature.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra281.signature_class_name_length_is_9:
  description: "inspect.Signature.__name__.__len__() == 9 — 'Signature' has 9 characters"
  category: identity
  kind: python_call_eq
  function: Signature.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra281.signature_empty_name_is_empty:
  description: "inspect.Signature.empty.__name__ == '_empty' — the sentinel class is named '_empty'"
  category: identity
  kind: python_call_eq
  function: "Signature.empty.__name__.__eq__"
  args: ["_empty"]
  expected: true

invariant inspect_extra281.signature_empty_module_is_inspect:
  description: "inspect.Signature.empty.__module__ == 'inspect' — the _empty sentinel is defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: "Signature.empty.__module__.__eq__"
  args: ["inspect"]
  expected: true

invariant inspect_extra281.signature_empty_is_type:
  description: "inspect.Signature.empty.__class__.__name__ == 'type' — the empty sentinel is a class (type) object"
  category: identity
  kind: python_call_eq
  function: "Signature.empty.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

invariant inspect_extra281.signature_func_has_docstring:
  description: "inspect.signature.__doc__.__eq__(None) == False — the signature function ships with a non-None docstring"
  category: identity
  kind: python_call_eq
  function: signature.__doc__.__eq__
  args: [null]
  expected: false
