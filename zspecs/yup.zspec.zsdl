spec: yup
version: ">=1.0.0"
backend: node(yup)

docs: https://github.com/jquense/yup#readme

provenance:
  derived_from:
    - "yup README — https://github.com/jquense/yup#readme"
    - "Test vectors verified with yup via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "yup source"
  notes:
    - "Schema validator with type inference, used heavily by Formik."
    - "Install: npm install yup"
    - "v1 CJS; named exports string / number / boolean / date / array / object / mixed."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Schema methods chain; isValidSync returns boolean; validateSync throws ValidationError."
  stderr: "null"
  stickiness: "N/A — schemas are immutable; chained methods return new schemas."
  codes:
    ValidationError: "Raised by validateSync/validate when input fails"

# string schemas
invariant yup.string_accepts_string:
  description: "yup.string().isValidSync('hi') is true"
  category: string
  kind: node_chain_eq
  entry: named
  function: string
  entry_args: []
  chain:
    - {method: isValidSync, args: ["hi"]}
  expected: true

invariant yup.string_min_rejects_short:
  description: "yup.string().min(3).isValidSync('hi') is false"
  category: string
  kind: node_chain_eq
  entry: named
  function: string
  entry_args: []
  chain:
    - {method: min, args: [3]}
    - {method: isValidSync, args: ["hi"]}
  expected: false

invariant yup.string_min_accepts_long:
  description: "yup.string().min(3).isValidSync('hello') is true"
  category: string
  kind: node_chain_eq
  entry: named
  function: string
  entry_args: []
  chain:
    - {method: min, args: [3]}
    - {method: isValidSync, args: ["hello"]}
  expected: true

invariant yup.string_email_valid:
  description: "yup.string().email().isValidSync('a@b.co') is true"
  category: string
  kind: node_chain_eq
  entry: named
  function: string
  entry_args: []
  chain:
    - {method: email, args: []}
    - {method: isValidSync, args: ["a@b.co"]}
  expected: true

invariant yup.string_email_invalid:
  description: "yup.string().email().isValidSync('not-email') is false"
  category: string
  kind: node_chain_eq
  entry: named
  function: string
  entry_args: []
  chain:
    - {method: email, args: []}
    - {method: isValidSync, args: ["not-email"]}
  expected: false

# number schemas
invariant yup.number_cast_string:
  description: "yup.number().cast('42') returns 42"
  category: number
  kind: node_chain_eq
  entry: named
  function: number
  entry_args: []
  chain:
    - {method: cast, args: ["42"]}
  expected: 42

invariant yup.number_cast_float:
  description: "yup.number().cast('3.14') returns 3.14"
  category: number
  kind: node_chain_eq
  entry: named
  function: number
  entry_args: []
  chain:
    - {method: cast, args: ["3.14"]}
  expected: 3.14

invariant yup.number_min_rejects_negative:
  description: "yup.number().min(0).isValidSync(-1) is false"
  category: number
  kind: node_chain_eq
  entry: named
  function: number
  entry_args: []
  chain:
    - {method: min, args: [0]}
    - {method: isValidSync, args: [-1]}
  expected: false

invariant yup.boolean_accepts_true:
  description: "yup.boolean().isValidSync(true) is true"
  category: boolean
  kind: node_chain_eq
  entry: named
  function: boolean
  entry_args: []
  chain:
    - {method: isValidSync, args: [true]}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:43:04Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
