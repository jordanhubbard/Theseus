spec: inspect_extra286
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect.Parameter kinds, inspect.Signature, and inspect.BoundArguments identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Parameter kind constants (POSITIONAL_ONLY etc.) are instances of _ParameterKind enum"
    - "Parameter.empty and Signature.empty are both the same sentinel object; its __class__.__name__ is 'type' in Python 3.14"
    - "BoundArguments is defined in inspect module alongside Signature"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra286.parameter_kind_classes:
  description: "All Parameter kind constants are instances of _ParameterKind"
  kind: python_call_eq
  category: identity
  id_prefix: ipkc

  columns: [id, function, args, expected, description]
  rows:
    - [ipkc001, inspect.Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__, ["_ParameterKind"], true, "POSITIONAL_ONLY is a _ParameterKind"]
    - [ipkc002, inspect.Parameter.POSITIONAL_OR_KEYWORD.__class__.__name__.__eq__, ["_ParameterKind"], true, "POSITIONAL_OR_KEYWORD is a _ParameterKind"]
    - [ipkc003, inspect.Parameter.VAR_POSITIONAL.__class__.__name__.__eq__, ["_ParameterKind"], true, "VAR_POSITIONAL is a _ParameterKind"]
    - [ipkc004, inspect.Parameter.KEYWORD_ONLY.__class__.__name__.__eq__, ["_ParameterKind"], true, "KEYWORD_ONLY is a _ParameterKind"]
    - [ipkc005, inspect.Parameter.VAR_KEYWORD.__class__.__name__.__eq__, ["_ParameterKind"], true, "VAR_KEYWORD is a _ParameterKind"]

table inspect_extra286.signature_boundarguments_identity:
  description: "__name__ and __module__ for Signature and BoundArguments"
  kind: python_call_eq
  category: identity
  id_prefix: isbi

  columns: [id, function, args, expected, description]
  rows:
    - [isbi001, inspect.Signature.__name__.__eq__, ["Signature"], true, "Signature.__name__ is 'Signature'"]
    - [isbi002, inspect.Signature.__module__.__eq__, ["inspect"], true, "Signature.__module__ is 'inspect'"]
    - [isbi003, inspect.BoundArguments.__name__.__eq__, ["BoundArguments"], true, "BoundArguments.__name__ is 'BoundArguments'"]
    - [isbi004, inspect.BoundArguments.__module__.__eq__, ["inspect"], true, "BoundArguments.__module__ is 'inspect'"]
    - [isbi005, inspect.Parameter.__name__.__eq__, ["Parameter"], true, "Parameter.__name__ is 'Parameter'"]
    - [isbi006, inspect.Parameter.__module__.__eq__, ["inspect"], true, "Parameter.__module__ is 'inspect'"]

invariant inspect_extra286.parameter_empty_class:
  description: "Parameter.empty.__class__.__name__ is 'type'"
  category: identity
  kind: python_call_eq
  function: inspect.Parameter.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra286.signature_empty_class:
  description: "Signature.empty.__class__.__name__ is 'type'"
  category: identity
  kind: python_call_eq
  function: inspect.Signature.empty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra286.boundarguments_module:
  description: "BoundArguments is defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: inspect.BoundArguments.__module__.__eq__
  args: ["inspect"]
  expected: true
