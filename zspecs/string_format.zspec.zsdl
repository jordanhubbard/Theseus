spec: string_format
version: ">=2.0.0"
backend: node(string-format)

docs: https://github.com/davidchambers/string-format#readme

provenance:
  derived_from:
    - "string-format README — https://github.com/davidchambers/string-format#readme"
    - "Python str.format() — inspiration"
    - "Test vectors verified with string-format via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "string-format source"
  notes:
    - "Python-style str.format() implementation: positional ({0}, {1}), implicit ({}), and named ({key}) substitutions."
    - "Install: npm install string-format"
    - "Module export IS the format function."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string template."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table string_format.format:
  kind: node_module_call_eq
  category: format
  function: ~
  id_prefix: format

  columns: [id, args, expected]
  rows:
    - [implicit_position,
       ["Hello, {}", "world"],
       "Hello, world"]

    - [numeric_indices,
       ["{0}-{1}", "a", "b"],
       "a-b"]

    - [reverse_index,
       ["{1}-{0}", "a", "b"],
       "b-a"]

    - [named_from_object,
       ["{name}", {name: "Alice"}],
       "Alice"]

    - [no_template_passthrough,
       ["plain text"],
       "plain text"]

    - [empty_template,
       [""],
       ""]

    - [duplicate_placeholders,
       ["{0}-{0}", "X"],
       "X-X"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:11:54Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
