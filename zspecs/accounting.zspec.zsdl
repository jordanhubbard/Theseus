spec: accounting
version: ">=0.4.0"
backend: node(accounting)

docs: https://github.com/openexchangerates/accounting.js#readme

provenance:
  derived_from:
    - "accounting README — https://github.com/openexchangerates/accounting.js#readme"
    - "Test vectors verified with accounting@0.4.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "accounting source"
  notes:
    - "accounting exports { formatMoney, formatNumber, toFixed, unformat }."
    - "formatMoney(n) formats a number as USD with default symbol $, thousand separator comma."
    - "formatNumber(n) formats a number with thousand separators but no currency symbol."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns formatted string. No errors for numeric inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table accounting.format:
  kind: node_module_call_eq
  category: format
  id_prefix: acct

  columns: [id, function, args, expected]
  rows:
    - [money,       formatMoney,   [1234.56],    "$1,234.56"]
    - [money_neg,   formatMoney,   [-1234.56],   "$-1,234.56"]
    - [number,      formatNumber,  [1000000],    "1,000,000"]
    - [toFixed,     toFixed,       [3.14159, 2], "3.14"]
