spec: accounting
version: ">=0.4.0"
backend: node(accounting)

docs: https://www.npmjs.com/package/accounting

provenance:
  derived_from:
    - "accounting README — https://www.npmjs.com/package/accounting"
    - "Test vectors verified with accounting via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "accounting source"
  notes:
    - "accounting is an npm package. Install: npm install accounting"
    - "accounting.formatMoney(n) formats a number as currency (default USD)."
    - "accounting.formatNumber(n) formats a number with thousands separators."
    - "accounting.toFixed(n, precision) rounds to a fixed number of decimal places."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns formatted string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table accounting.formatMoney:
  kind: node_module_call_eq
  function: formatMoney
  category: format
  id_prefix: acctmoney

  columns: [id, args, expected]
  rows:
    - [positive, [12345.67],  "$12,345.67"]
    - [negative, [-12345.67], "$-12,345.67"]

table accounting.formatNumber:
  kind: node_module_call_eq
  function: formatNumber
  category: format
  id_prefix: acctnumber

  columns: [id, args, expected]
  rows:
    - [million, [1234567], "1,234,567"]
    - [small,   [42],      "42"]

table accounting.toFixed:
  kind: node_module_call_eq
  function: toFixed
  category: math
  id_prefix: acctfixed

  columns: [id, args, expected]
  rows:
    - [two,   [1.005, 2], "1.00"]
    - [three, [3.14159, 3], "3.142"]
