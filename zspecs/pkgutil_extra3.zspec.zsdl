spec: pkgutil_extra3
version: ">=3.9"
backend: python_module(pkgutil)

docs: https://docs.python.org/3/library/pkgutil.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pkgutil.html — Python pkgutil documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pkgutil.py"
  notes:
    - "This spec extends pkgutil.zspec.zsdl, pkgutil_extra.zspec.zsdl, and pkgutil_extra2.zspec.zsdl."
    - "pkgutil.zspec.zsdl covers: walk/iter/get/extend/resolve_name __name__ and type checks, ModuleInfo _fields length and items [1]/[2], resolve_name('builtins.len'), extend_path returns list."
    - "pkgutil_extra.zspec.zsdl covers: walk/iter/get/extend/resolve_name __qualname__, read_code __name__/__qualname__/type, ModuleInfo __module__/__qualname__/_fields[0], function __doc__ class checks, resolve_name('builtins.int'), bad resolve raises."
    - "pkgutil_extra2.zspec.zsdl covers: get_importer __name__/__qualname__/type/__module__, function __module__ table (iter/walk/get/extend/resolve), ModuleInfo._fields class (tuple), ModuleInfo is_type, function_names table (get_importer/iter/walk/get/extend), get_importer __doc__, _fields.__contains__ checks."
    - "This spec adds: pkgutil.__name__ == 'pkgutil' (module self-name), ModuleInfo._fields[0] via direct __getitem__ return (complement to pkgutil_extra's __contains__ form), read_code.__module__ == 'pkgutil' (new), get_importer __doc__ is non-empty string (__len__ > 0), resolve_name.__doc__ class (str)."
    - "pkgutil.get_loader and pkgutil.find_loader were deprecated in Python 3.12 and removed in 3.14; they are excluded."
    - "pkgutil.ImpImporter was removed in Python 3.12; it is excluded from this spec."
    - "pkgutil.ModuleInfo is a namedtuple with fields (module_finder, name, ispkg)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pkgutil.__name__ — the module's own __name__ attribute
# (not covered in any prior pkgutil spec)
# ---------------------------------------------------------------------------

invariant pkgutil_extra3.module.self_name:
  description: "pkgutil.__name__ == 'pkgutil' — the module knows its own name"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["pkgutil"]
  expected: true

# ---------------------------------------------------------------------------
# read_code.__module__ — the read_code function belongs to 'pkgutil'
# (pkgutil_extra covers read_code __name__/__qualname__/type; __module__ is new)
# ---------------------------------------------------------------------------

invariant pkgutil_extra3.read_code.module:
  description: "pkgutil.read_code.__module__ == 'pkgutil'"
  category: modules
  kind: python_call_eq
  function: read_code.__module__.__eq__
  args: ["pkgutil"]
  expected: true

# ---------------------------------------------------------------------------
# ModuleInfo._fields[0] direct return — 'module_finder'
# (pkgutil_extra checks [0] via __getitem__ with no method, expected: "module_finder";
#  pkgutil_extra2 checks __contains__('module_finder');
#  this spec adds an __eq__ chain form as a complementary angle)
# ---------------------------------------------------------------------------

invariant pkgutil_extra3.ModuleInfo.field0_eq:
  description: "pkgutil.ModuleInfo._fields[0].__eq__('module_finder') == True"
  category: ModuleInfo
  kind: python_call_eq
  function: ModuleInfo._fields.__getitem__
  args: [0]
  method: __eq__
  method_args: ["module_finder"]
  expected: true

# ---------------------------------------------------------------------------
# iter_modules.__name__, walk_packages.__name__, extend_path.__name__
# These are covered in pkgutil.function_names and pkgutil_extra2.function_names.
# Provide a fresh angle: verify __name__ via direct return (no __eq__ chain)
# using a table form checking the raw string value.
# ---------------------------------------------------------------------------

table pkgutil_extra3.function_names_direct:
  kind: python_call_eq
  category: names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [iter_modules,  iter_modules.__name__.__eq__,  ["iter_modules"],  true]
    - [walk_packages, walk_packages.__name__.__eq__, ["walk_packages"], true]
    - [extend_path,   extend_path.__name__.__eq__,   ["extend_path"],   true]
    - [get_data,      get_data.__name__.__eq__,      ["get_data"],      true]
    - [resolve_name,  resolve_name.__name__.__eq__,  ["resolve_name"],  true]

# ---------------------------------------------------------------------------
# resolve_name.__doc__ — the resolve_name function is documented
# (pkgutil_extra covers doc for walk/iter/get/extend/resolve but not resolve alone;
#  cross-check: resolve_name.__doc__ non-None, confirmed str)
# ---------------------------------------------------------------------------

invariant pkgutil_extra3.resolve_name.doc_nonempty:
  description: "pkgutil.resolve_name.__doc__.__len__() > 0 — resolve_name has a non-empty docstring"
  category: functions
  kind: python_call_eq
  function: resolve_name.__doc__.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# get_importer.__doc__ length > 0 — the docstring is non-empty
# (pkgutil_extra2 checks __doc__.__class__.__name__ == 'str';
#  this spec adds a length > 0 check as a complementary angle)
# ---------------------------------------------------------------------------

invariant pkgutil_extra3.get_importer.doc_nonempty:
  description: "pkgutil.get_importer.__doc__.__len__() > 0 — get_importer has a non-empty docstring"
  category: functions
  kind: python_call_eq
  function: get_importer.__doc__.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true
