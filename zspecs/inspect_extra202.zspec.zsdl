spec: inspect_extra202
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers module-level dunder attributes of inspect: __name__, __package__, __spec__.name, __loader__.__class__.__name__, __builtins__.__class__.__name__."
    - "inspect.__name__ == 'inspect' — module identity attribute. Verified with Python 3.14.3."
    - "inspect.__package__ == '' — top-level module; __package__ is empty string. Verified with Python 3.14.3."
    - "inspect.__spec__.name == 'inspect' — ModuleSpec.name attribute equals module name. Verified with Python 3.14.3."
    - "inspect.__loader__.__class__.__name__ == 'SourceFileLoader' — inspect is a pure Python source file; loader is SourceFileLoader. Verified with Python 3.14.3."
    - "inspect.__builtins__.__class__.__name__ == 'dict' — in a module context __builtins__ is a dict. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect module __name__ and __package__ identity
#
# inspect.__name__ == 'inspect'
# inspect.__package__ == ''
# inspect.__name__.__class__.__name__ == 'str'
# inspect.__package__.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table inspect_extra202.module_name_package:
  description: "inspect.__name__ and __package__ identity; new to extra202"
  kind: python_call_eq
  category: module_identity
  id_prefix: inspectmod202

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,
       __name__.__eq__,
       ["inspect"],
       true,
       "inspect.__name__.__eq__('inspect') == True — module __name__ attribute equals 'inspect'; new to extra202"]
    - [module_name_class_str,
       __name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.__name__.__class__.__name__.__eq__('str') == True — module __name__ is a str; new to extra202"]
    - [module_package_eq,
       __package__.__eq__,
       [""],
       true,
       "inspect.__package__.__eq__('') == True — top-level module; __package__ is empty string; new to extra202"]
    - [module_package_class_str,
       __package__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.__package__.__class__.__name__.__eq__('str') == True — module __package__ is a str; new to extra202"]

# ---------------------------------------------------------------------------
# Table 2: inspect __spec__ attributes
#
# inspect.__spec__.name == 'inspect'
# inspect.__spec__.__class__.__name__ == 'ModuleSpec'
# inspect.__spec__.parent == ''
# inspect.__spec__.has_location == True
# ---------------------------------------------------------------------------

table inspect_extra202.module_spec_attrs:
  description: "inspect.__spec__ name, class, parent and has_location identity; new to extra202"
  kind: python_call_eq
  category: module_spec
  id_prefix: inspectmod202

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,
       __spec__.name.__eq__,
       ["inspect"],
       true,
       "inspect.__spec__.name.__eq__('inspect') == True — ModuleSpec.name attribute equals 'inspect'; new to extra202"]
    - [spec_class_name_eq,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "inspect.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — __spec__ is a ModuleSpec instance; new to extra202"]
    - [spec_parent_eq,
       __spec__.parent.__eq__,
       [""],
       true,
       "inspect.__spec__.parent.__eq__('') == True — top-level module; spec.parent is empty string; new to extra202"]
    - [spec_has_location_eq,
       __spec__.has_location.__eq__,
       [true],
       true,
       "inspect.__spec__.has_location.__eq__(True) == True — inspect is a source file module; has_location is True; new to extra202"]

# ---------------------------------------------------------------------------
# Table 3: inspect __loader__, __builtins__ and __doc__ class identity
#
# inspect.__loader__.__class__.__name__ == 'SourceFileLoader'
# inspect.__builtins__.__class__.__name__ == 'dict'
# inspect.__doc__.__class__.__name__ == 'str'
# inspect.__spec__.origin.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table inspect_extra202.loader_builtins_identity:
  description: "inspect __loader__.__class__.__name__, __builtins__ type, __doc__ type and spec.origin type; new to extra202"
  kind: python_call_eq
  category: loader_builtins
  id_prefix: inspectmod202

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_name_eq,
       __loader__.__class__.__name__.__eq__,
       ["SourceFileLoader"],
       true,
       "inspect.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — inspect uses SourceFileLoader (pure Python source file); new to extra202"]
    - [builtins_class_name_eq,
       "__builtins__.__class__.__name__.__eq__",
       ["dict"],
       true,
       "inspect.__builtins__.__class__.__name__.__eq__('dict') == True — in module context __builtins__ is a dict; new to extra202"]
    - [doc_class_name_eq,
       __doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.__doc__.__class__.__name__.__eq__('str') == True — module __doc__ is a str; new to extra202"]
    - [spec_origin_class_name_eq,
       __spec__.origin.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.__spec__.origin.__class__.__name__.__eq__('str') == True — spec.origin is a str (file path); new to extra202"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra202
# ---------------------------------------------------------------------------

invariant inspect_extra202.module_name_eq:
  description: "inspect.__name__ == 'inspect' — module identity attribute is 'inspect'; new to extra202"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra202.module_package_eq:
  description: "inspect.__package__ == '' — top-level module; __package__ is empty string; new to extra202"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant inspect_extra202.spec_name_eq:
  description: "inspect.__spec__.name == 'inspect' — ModuleSpec.name attribute equals module name; new to extra202"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra202.spec_class_name_eq:
  description: "inspect.__spec__.__class__.__name__ == 'ModuleSpec' — __spec__ is a ModuleSpec instance; new to extra202"
  kind: python_call_eq
  function: "__spec__.__class__.__name__.__eq__"
  args: ["ModuleSpec"]
  expected: true

invariant inspect_extra202.spec_parent_eq:
  description: "inspect.__spec__.parent == '' — top-level module; spec.parent is empty string; new to extra202"
  kind: python_call_eq
  function: __spec__.parent.__eq__
  args: [""]
  expected: true

invariant inspect_extra202.spec_has_location_eq:
  description: "inspect.__spec__.has_location == True — inspect is a source file module; has_location is True; new to extra202"
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

invariant inspect_extra202.loader_class_name_eq:
  description: "inspect.__loader__.__class__.__name__ == 'SourceFileLoader' — inspect uses SourceFileLoader; new to extra202"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant inspect_extra202.builtins_class_name_eq:
  description: "inspect.__builtins__.__class__.__name__ == 'dict' — in module context __builtins__ is a dict; new to extra202"
  kind: python_call_eq
  function: "__builtins__.__class__.__name__.__eq__"
  args: ["dict"]
  expected: true
