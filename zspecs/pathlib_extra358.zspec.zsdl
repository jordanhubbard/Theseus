spec: pathlib_extra358
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pathlib.Path.__bases__[0] is PurePath; pathlib.PurePath.__bases__[0] is object"
    - "pathlib.PosixPath and pathlib.WindowsPath both extend Path"
    - "pathlib.PurePosixPath extends PurePath"
    - "WindowsPath is instantiable only on Windows; on macOS/Linux it raises NotImplementedError at instantiation but class attributes are still accessible"
    - "All class __name__, __module__, __bases__[0].__name__ values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib class identity — class names
# ---------------------------------------------------------------------------

table pathlib_extra358.class_names:
  description: "pathlib class __name__ identity checks — Path, PurePath, PosixPath, WindowsPath, PurePosixPath; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibname358

  columns: [id, function, args, expected]
  rows:
    - [path_name,          pathlib.Path.__name__.__eq__,          ["Path"],          true]
    - [purepath_name,      pathlib.PurePath.__name__.__eq__,      ["PurePath"],      true]
    - [posixpath_name,     pathlib.PosixPath.__name__.__eq__,     ["PosixPath"],     true]
    - [windowspath_name,   pathlib.WindowsPath.__name__.__eq__,   ["WindowsPath"],   true]
    - [pureposixpath_name, pathlib.PurePosixPath.__name__.__eq__, ["PurePosixPath"], true]

# ---------------------------------------------------------------------------
# pathlib class identity — module attributes
# ---------------------------------------------------------------------------

table pathlib_extra358.class_modules:
  description: "pathlib class __module__ identity checks — all five classes report __module__ as 'pathlib'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibmod358

  columns: [id, function, args, expected]
  rows:
    - [path_module,          pathlib.Path.__module__.__eq__,          ["pathlib"], true]
    - [purepath_module,      pathlib.PurePath.__module__.__eq__,      ["pathlib"], true]
    - [posixpath_module,     pathlib.PosixPath.__module__.__eq__,     ["pathlib"], true]
    - [windowspath_module,   pathlib.WindowsPath.__module__.__eq__,   ["pathlib"], true]
    - [pureposixpath_module, pathlib.PurePosixPath.__module__.__eq__, ["pathlib"], true]

# ---------------------------------------------------------------------------
# pathlib class identity — base class names
# ---------------------------------------------------------------------------

table pathlib_extra358.class_bases:
  description: "pathlib class __bases__[0].__name__ identity checks — Path extends PurePath; PurePath extends object; PosixPath and WindowsPath extend Path; PurePosixPath extends PurePath; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibbase358

  columns: [id, function, args, expected]
  rows:
    - [path_base,          "pathlib.Path.__bases__[0].__name__.__eq__",          ["PurePath"], true]
    - [purepath_base,      "pathlib.PurePath.__bases__[0].__name__.__eq__",      ["object"],   true]
    - [posixpath_base,     "pathlib.PosixPath.__bases__[0].__name__.__eq__",     ["Path"],     true]
    - [windowspath_base,   "pathlib.WindowsPath.__bases__[0].__name__.__eq__",   ["Path"],     true]
    - [pureposixpath_base, "pathlib.PurePosixPath.__bases__[0].__name__.__eq__", ["PurePath"], true]
