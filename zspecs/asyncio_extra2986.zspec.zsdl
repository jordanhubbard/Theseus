spec: as2986
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/asyncio-task.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-sync.html"
    - "CPython docs — https://docs.python.org/3/library/asyncio-eventloop.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "asyncio source: internal C-level accelerators (_asyncio extension)"
  notes:
    - "Wave 646 — theme: __len__, __length_hint__, __contains__ dict-presence (container/sequence protocol)."
    - "Tests operator.contains(SomeClass.__dict__, '__len__') etc. for asyncio classes."
    - "Classes covered: Task, Future, Queue, Event, Semaphore, BoundedSemaphore, Lock, Condition, Handle, TimerHandle, Timeout, TaskGroup."
    - "None of these asyncio concurrency primitives define __len__, __length_hint__, or __contains__ in their own __dict__."
    - "asyncio.Queue has a qsize() method and full()/empty() predicates but deliberately does not implement the Sized or Container protocols via __len__/__contains__."
    - "Task and Future are C-accelerated (_asyncio); the __dict__ check still correctly returns False for these container slots."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# None of the asyncio classes define __len__; all results are false.
# asyncio.Queue exposes qsize() but does not implement __len__.
# ---------------------------------------------------------------------------

table as2986.len:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: container_len
  id_prefix: len

  columns: [id, function, args, expected]
  rows:
    - ["len_Task",             operator.contains, [Task.__dict__,             "__len__"], false]
    - ["len_Future",           operator.contains, [Future.__dict__,           "__len__"], false]
    - ["len_Queue",            operator.contains, [Queue.__dict__,            "__len__"], false]
    - ["len_Event",            operator.contains, [Event.__dict__,            "__len__"], false]
    - ["len_Semaphore",        operator.contains, [Semaphore.__dict__,        "__len__"], false]
    - ["len_BoundedSemaphore", operator.contains, [BoundedSemaphore.__dict__, "__len__"], false]
    - ["len_Lock",             operator.contains, [Lock.__dict__,             "__len__"], false]
    - ["len_Condition",        operator.contains, [Condition.__dict__,        "__len__"], false]
    - ["len_Handle",           operator.contains, [Handle.__dict__,           "__len__"], false]
    - ["len_TimerHandle",      operator.contains, [TimerHandle.__dict__,      "__len__"], false]
    - ["len_Timeout",          operator.contains, [Timeout.__dict__,          "__len__"], false]
    - ["len_TaskGroup",        operator.contains, [TaskGroup.__dict__,        "__len__"], false]

