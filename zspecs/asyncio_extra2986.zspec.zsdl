# ---------------------------------------------------------------------------
# combined — all three operators for a cross-class sample
#
# Spot-checks __len__, __length_hint__, __contains__ absence across a
# representative selection of asyncio classes in a single table.
# 8 classes x 3 operators = 24 rows.
# ---------------------------------------------------------------------------

table as2986.combined:
