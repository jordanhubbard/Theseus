spec: re_extra154
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re module flag integer values. IGNORECASE==2, MULTILINE==8, DOTALL==16, VERBOSE==64, UNICODE==32. Each flag has a short alias (I, M, S, X, U) that is the identical object (re.I is re.IGNORECASE). The flag type is RegexFlag (an enum.IntFlag subclass), not plain int."
    - "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — unlike io seek constants which are plain int, re flags are instances of re.RegexFlag, an enum.IntFlag subclass; they support bitwise OR combination and still compare equal to their integer values via __eq__."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — RegexFlag inherits from IntFlag (from the enum module); this is why re.IGNORECASE.__eq__(2) is True even though the type is RegexFlag, not int."
    - "Flag values: NOFLAG=0, IGNORECASE=2, LOCALE=4, MULTILINE=8, DOTALL=16, UNICODE=32, VERBOSE=64, DEBUG=128, ASCII=256, TEMPLATE=512. These are powers of 2 (except NOFLAG=0) allowing bitwise combination."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re flag integer values — long-form flag names
# IGNORECASE==2, MULTILINE==8, DOTALL==16, VERBOSE==64, UNICODE==32
# All are RegexFlag enum members, not plain ints.
# ---------------------------------------------------------------------------

table re_extra154.flag_values_long:
  description: "re flag integer values (long form): IGNORECASE==2, MULTILINE==8, DOTALL==16, UNICODE==32, VERBOSE==64; all are RegexFlag enum members (IntFlag subclass)"
  kind: python_call_eq
  category: identity
  id_prefix: reflags154

  columns: [id, function, args, expected, description]
  rows:
    - [ignorecase_val,  IGNORECASE.__eq__,  [2],  true, "re.IGNORECASE.__eq__(2) == True (IGNORECASE has value 2; makes the pattern case-insensitive so [A-Z] also matches [a-z]; equivalent to adding (?i) inline in the pattern; type is RegexFlag not plain int)"]
    - [multiline_val,   MULTILINE.__eq__,   [8],  true, "re.MULTILINE.__eq__(8) == True (MULTILINE has value 8; makes ^ and $ match at line boundaries rather than only string start/end; equivalent to (?m) inline; value 8 == 2**3)"]
    - [dotall_val,      DOTALL.__eq__,      [16], true, "re.DOTALL.__eq__(16) == True (DOTALL has value 16; makes '.' match any character including newline; without DOTALL, '.' matches everything except '\\n'; equivalent to (?s) inline; value 16 == 2**4)"]
    - [unicode_val,     UNICODE.__eq__,     [32], true, "re.UNICODE.__eq__(32) == True (UNICODE has value 32; enables Unicode matching for \\w \\d \\s and \\b; the default for str patterns in Python 3; equivalent to (?u) inline; value 32 == 2**5)"]
    - [verbose_val,     VERBOSE.__eq__,     [64], true, "re.VERBOSE.__eq__(64) == True (VERBOSE has value 64; allows whitespace and comments in patterns for readability; whitespace is ignored unless escaped or in a character class; equivalent to (?x) inline; value 64 == 2**6)"]

# ---------------------------------------------------------------------------
# re flag integer values — short alias names
# I==2, M==8, S==16, U==32, X==64
# Short aliases are the same objects as long aliases (re.I is re.IGNORECASE).
# ---------------------------------------------------------------------------

table re_extra154.flag_values_short:
  description: "re flag integer values (short aliases): I==2, M==8, S==16, U==32, X==64; each short alias is the identical RegexFlag object as its long-form counterpart"
  kind: python_call_eq
  category: identity
  id_prefix: reflags154

  columns: [id, function, args, expected, description]
  rows:
    - [i_val,   I.__eq__,  [2],  true, "re.I.__eq__(2) == True (re.I is the short alias for IGNORECASE; re.I is re.IGNORECASE (same object); value 2; using re.I is idiomatic in short scripts while re.IGNORECASE is preferred for readability in larger codebases)"]
    - [m_val,   M.__eq__,  [8],  true, "re.M.__eq__(8) == True (re.M is the short alias for MULTILINE; re.M is re.MULTILINE (same object); value 8; commonly used as re.compile(pattern, re.M) for multiline matching)"]
    - [s_val,   S.__eq__,  [16], true, "re.S.__eq__(16) == True (re.S is the short alias for DOTALL; re.S is re.DOTALL (same object); value 16; the letter S comes from 're.DOTALL' but uses the first letter of 'SINGLE LINE' mode (as it was originally called in Perl))"]
    - [u_val,   U.__eq__,  [32], true, "re.U.__eq__(32) == True (re.U is the short alias for UNICODE; re.U is re.UNICODE (same object); value 32; in Python 3 str patterns have UNICODE active by default, so re.U is rarely needed explicitly)"]
    - [x_val,   X.__eq__,  [64], true, "re.X.__eq__(64) == True (re.X is the short alias for VERBOSE; re.X is re.VERBOSE (same object); value 64; 'X' stands for 'eXtended' mode — a Perl/PCRE convention; enables whitespace and # comments in regex patterns)"]

# ---------------------------------------------------------------------------
# re flag type — RegexFlag is an IntFlag subclass
# re.IGNORECASE.__class__.__name__ == 'RegexFlag'
# re.IGNORECASE.__class__.__module__ == 're'
# re.RegexFlag.__bases__[0].__name__ == 'IntFlag'
# ---------------------------------------------------------------------------

table re_extra154.flag_type_identity:
  description: "re flags are RegexFlag (IntFlag subclass) instances: __class__.__name__=='RegexFlag', __class__.__module__=='re', RegexFlag.__bases__[0].__name__=='IntFlag'"
  kind: python_call_eq
  category: identity
  id_prefix: reflags154

  columns: [id, function, args, expected, description]
  rows:
    - [flag_cls_name,      IGNORECASE.__class__.__name__.__eq__,    ["RegexFlag"], true, "re.IGNORECASE.__class__.__name__ == 'RegexFlag' (re flags are instances of the RegexFlag enum.IntFlag subclass, NOT plain int; this means they support bitwise OR (re.I | re.M) and print with symbolic names like 're.RegexFlag.IGNORECASE')"]
    - [flag_cls_module,    IGNORECASE.__class__.__module__.__eq__,  ["re"],        true, "re.IGNORECASE.__class__.__module__ == 're' (RegexFlag is defined in the public re module; __class__.__module__ == 're' confirms it is a public API type, not an internal from _sre or enum internals)"]
    - [regex_flag_base,    "RegexFlag.__bases__[0].__name__.__eq__",  ["IntFlag"],   true, "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' (RegexFlag's direct base is IntFlag from the enum module; IntFlag makes flags combinable with | and ensures int compatibility via __int__ and __eq__)"]
    - [dotall_cls_eq,      DOTALL.__class__.__name__.__eq__,        ["RegexFlag"], true, "re.DOTALL.__class__.__name__ == 'RegexFlag' (confirmed that DOTALL also has type RegexFlag; all re flag constants share the same type)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra154.IGNORECASE_is_2:
  description: "re.IGNORECASE.__eq__(2) == True — IGNORECASE has integer value 2 (== 2**1); it is a RegexFlag enum member (IntFlag subclass) that compares equal to integer 2; makes patterns case-insensitive so '[a-z]' also matches '[A-Z]'; can be combined with other flags using bitwise OR: re.IGNORECASE | re.MULTILINE == 10"
  category: identity
  kind: python_call_eq
  function: IGNORECASE.__eq__
  args: [2]
  expected: true

invariant re_extra154.MULTILINE_is_8:
  description: "re.MULTILINE.__eq__(8) == True — MULTILINE has integer value 8 (== 2**3); makes '^' match at the start of each line and '$' match at the end of each line (not just the whole string); flags skip powers of 2: 2 (IGNORECASE), skip 4 (LOCALE), 8 (MULTILINE), 16 (DOTALL), 32 (UNICODE), 64 (VERBOSE)"
  category: identity
  kind: python_call_eq
  function: MULTILINE.__eq__
  args: [8]
  expected: true

invariant re_extra154.DOTALL_is_16:
  description: "re.DOTALL.__eq__(16) == True — DOTALL has integer value 16 (== 2**4); makes '.' match any character including newline '\\n'; without DOTALL, '.' does not match newlines which is a common source of regex bugs when matching multi-line text; re.S is the short alias and the same object"
  category: identity
  kind: python_call_eq
  function: DOTALL.__eq__
  args: [16]
  expected: true

invariant re_extra154.VERBOSE_is_64:
  description: "re.VERBOSE.__eq__(64) == True — VERBOSE has integer value 64 (== 2**6); allows whitespace and '#' comments in regex patterns for readability; skips 32 (UNICODE) and 128 (DEBUG) as neighbors; VERBOSE patterns ignore unescaped whitespace and '#' to end-of-line, enabling multi-line regex with documentation"
  category: identity
  kind: python_call_eq
  function: VERBOSE.__eq__
  args: [64]
  expected: true

invariant re_extra154.UNICODE_is_32:
  description: "re.UNICODE.__eq__(32) == True — UNICODE has integer value 32 (== 2**5); enables Unicode character category matching for \\w, \\d, \\s, \\b; in Python 3 this is the default for str patterns so explicitly passing re.UNICODE (or re.U) is usually redundant; it is distinct from ASCII (256) which restricts to ASCII-only matching"
  category: identity
  kind: python_call_eq
  function: UNICODE.__eq__
  args: [32]
  expected: true

invariant re_extra154.flag_type_is_RegexFlag:
  description: "re.IGNORECASE.__class__.__name__ == 'RegexFlag' — re flags are instances of re.RegexFlag, an enum.IntFlag subclass defined in the re module; unlike io.SEEK_SET which is a plain int, re flags are typed enum members; this means re.IGNORECASE.__class__ is re.RegexFlag, not int; IntFlag inheritance ensures integer arithmetic and bitwise operations work correctly on flags"
  category: identity
  kind: python_call_eq
  function: IGNORECASE.__class__.__name__.__eq__
  args: ["RegexFlag"]
  expected: true

