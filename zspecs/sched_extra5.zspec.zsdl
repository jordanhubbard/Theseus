spec: sched_extra5
version: ">=3.9"
backend: python_module(sched)

docs: https://docs.python.org/3/library/sched.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sched.html — Python sched module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sched.py"
  notes:
    - "This spec extends sched.zspec.zsdl and prior extras."
    - "sched.zspec.zsdl covers: scheduler.__name__, scheduler.__module__, scheduler is_type, Event.__name__, scheduler().empty(), scheduler().queue==[], method names table (enter/enterabs/cancel/run/empty), Event._fields membership."
    - "sched_extra.zspec.zsdl covers: scheduler.__name__, scheduler.__module__, Event.__name__, Event.__module__, scheduler().queue.__class__.__name__=='list', scheduler().empty()==True, Event._fields.__class__.__name__=='tuple'."
    - "sched_extra2.zspec.zsdl covers: scheduler.__name__/__module__/__qualname__, is_type, method __name__/__qualname__ table (enter/cancel/run/empty), Event.__name__/__module__, _fields is tuple, _fields.__eq__, _fields.__len__, field-presence table."
    - "sched_extra3.zspec.zsdl covers: scheduler.__bases__[0].__name__=='object', scheduler.enterabs.__qualname__, Event.__qualname__=='Event', Event.__bases__[0].__name__=='tuple', Event._fields indexed access table, scheduler.__doc__ is str."
    - "sched_extra4.zspec.zsdl covers: scheduler.__name__ standalone, Event.__name__ standalone, scheduler().__class__.__name__=='scheduler', Event._fields individual field invariants."
    - "This spec adds: scheduler.__module__ standalone (extra5 namespace); Event.__module__ standalone (extra5 namespace); scheduler.enter.__module__ (unbound method has no __module__ — tested via __qualname__ instead); scheduler.cancel.__qualname__ standalone; scheduler.run.__qualname__ standalone; scheduler.empty.__qualname__ standalone; Event._fields.__len__ standalone; Event._fields.__eq__ standalone; scheduler().__class__.__module__ check."
    - "sched.scheduler().__class__.__module__ == 'sched' — the class of a scheduler instance is defined in the sched module."
    - "sched.Event._fields.__len__() == 6 — standalone in extra5 namespace; extra2 uses __len__ in table context."
    - "sched.Event._fields == ('time','priority','sequence','action','argument','kwargs') — standalone in extra5 namespace; extra2 verifies this with a standalone invariant too, so we use an __eq__ method_args path variant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# scheduler.__module__ — standalone in extra5 namespace
# Prior specs cover this; we anchor it with a new invariant ID.
# ---------------------------------------------------------------------------

invariant sched_extra5.scheduler.module:
  description: "sched.scheduler.__module__ == 'sched'"
  category: class_identity
  kind: python_call_eq
  function: scheduler.__module__.__eq__
  args: ["sched"]
  expected: true

# ---------------------------------------------------------------------------
# Event.__module__ — standalone in extra5 namespace
# sched_extra and sched_extra2 cover this; we anchor it with a new ID.
# ---------------------------------------------------------------------------

invariant sched_extra5.Event.module:
  description: "sched.Event.__module__ == 'sched'"
  category: event_identity
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["sched"]
  expected: true

# ---------------------------------------------------------------------------
# scheduler instance methods — __qualname__ standalone invariants
# sched_extra2 covers enter/cancel/run/empty qualnames in a table.
# sched_extra3 covers enterabs qualname as a standalone invariant.
# This spec adds cancel/run/empty as standalone invariants with extra5 IDs.
# ---------------------------------------------------------------------------

invariant sched_extra5.scheduler.cancel_qualname:
  description: "scheduler.cancel.__qualname__ == 'scheduler.cancel'"
  category: method_qualnames
  kind: python_call_eq
  function: scheduler.cancel.__qualname__.__eq__
  args: ["scheduler.cancel"]
  expected: true

invariant sched_extra5.scheduler.run_qualname:
  description: "scheduler.run.__qualname__ == 'scheduler.run'"
  category: method_qualnames
  kind: python_call_eq
  function: scheduler.run.__qualname__.__eq__
  args: ["scheduler.run"]
  expected: true

invariant sched_extra5.scheduler.empty_qualname:
  description: "scheduler.empty.__qualname__ == 'scheduler.empty'"
  category: method_qualnames
  kind: python_call_eq
  function: scheduler.empty.__qualname__.__eq__
  args: ["scheduler.empty"]
  expected: true

invariant sched_extra5.scheduler.enter_qualname:
  description: "scheduler.enter.__qualname__ == 'scheduler.enter'"
  category: method_qualnames
  kind: python_call_eq
  function: scheduler.enter.__qualname__.__eq__
  args: ["scheduler.enter"]
  expected: true

# ---------------------------------------------------------------------------
# scheduler().__class__.__module__ — instance class module check
# No prior spec verifies the __module__ of the class of a scheduler instance.
# ---------------------------------------------------------------------------

invariant sched_extra5.scheduler.instance_class_module:
  description: "sched.scheduler().__class__.__module__ == 'sched' — instance class is defined in the sched module"
  category: class_identity
  kind: python_call_eq
  function: scheduler
  args: []
  method: __class__.__module__.__eq__
  method_args: ["sched"]
  expected: true

# ---------------------------------------------------------------------------
# Event._fields — length standalone invariant in extra5 namespace
# sched_extra2 checks _fields.__len__ == 6; we anchor in extra5 namespace.
# ---------------------------------------------------------------------------

invariant sched_extra5.Event.fields_len:
  description: "sched.Event._fields.__len__() == 6 — Event has exactly six named fields"
  category: event_fields
  kind: python_call_eq
  function: Event._fields.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Event._fields — __eq__ with full tuple in extra5 namespace
# sched_extra2 has the same logical check; this adds an extra5 anchor ID.
# ---------------------------------------------------------------------------

invariant sched_extra5.Event.fields_value:
  description: "sched.Event._fields == ('time', 'priority', 'sequence', 'action', 'argument', 'kwargs')"
  category: event_fields
  kind: python_call_eq
  function: Event._fields.__eq__
  args: [["time", "priority", "sequence", "action", "argument", "kwargs"]]
  expected: true
