spec: indent_string
version: ">=4.0.0"
backend: node(indent-string)

docs: https://github.com/sindresorhus/indent-string#readme

provenance:
  derived_from:
    - "indent-string README — https://github.com/sindresorhus/indent-string#readme"
    - "Test vectors verified with indent-string@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "indent-string source: index.js"
  notes:
    - "indent-string@4 (CJS) exports the indentString function as the module default."
    - "indentString(str, count) prepends count spaces to each line."
    - "indentString(str, count, opts) where opts.indent overrides the indent character."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string with each line indented. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table indent_string.indent:
  kind: node_module_call_eq
  function: ~
  category: indent
  id_prefix: is

  columns: [id, args, expected]
  rows:
    - [single,   ["hello", 2],                            "  hello"]
    - [multiline, ["hello\nworld", 1, {"indent": "> "}],  "> hello\n> world"]
