spec: pathlib_extra2326
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 602 (_extra2326): numeric constants and fixed-size attribute checks."
    - "pathlib has no integer constants; this file checks module __name__ and class __name__ attributes."
    - "pathlib.PurePath.__bases__ has length 1 (base is object) in Python 3.14."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: Module identity
# ---------------------------------------------------------------------------

table pathlib_extra2326.module_identity:
  description: "pathlib module-level __name__ attribute"
  kind: python_call_eq
  category: constants
  id_prefix: pp2326

  columns: [id, function, args, expected]
  rows:
    - ["pp2326001", "pathlib.__name__", [], "pathlib"]

# ---------------------------------------------------------------------------
# Table 2: Pure path class __name__ attributes
# ---------------------------------------------------------------------------

table pathlib_extra2326.pure_class_names:
  description: "pathlib pure path class __name__ attributes"
  kind: python_call_eq
  category: constants
  id_prefix: pp2326

  columns: [id, function, args, expected]
  rows:
    - ["pp2326002", "pathlib.PurePath.__name__",        [], "PurePath"]
    - ["pp2326003", "pathlib.PurePosixPath.__name__",   [], "PurePosixPath"]
    - ["pp2326004", "pathlib.PureWindowsPath.__name__", [], "PureWindowsPath"]

# ---------------------------------------------------------------------------
# Table 3: Concrete path class __name__ attributes
# ---------------------------------------------------------------------------

table pathlib_extra2326.concrete_class_names:
  description: "pathlib concrete path class __name__ attributes"
  kind: python_call_eq
  category: constants
  id_prefix: pp2326

  columns: [id, function, args, expected]
  rows:
    - ["pp2326005", "pathlib.Path.__name__",        [], "Path"]
    - ["pp2326006", "pathlib.PosixPath.__name__",   [], "PosixPath"]
    - ["pp2326007", "pathlib.WindowsPath.__name__", [], "WindowsPath"]

# ---------------------------------------------------------------------------
# Table 4: Class __bases__ size — fixed-size attribute checks
# ---------------------------------------------------------------------------

table pathlib_extra2326.bases_sizes:
  description: "pathlib class __bases__ tuple length checks"
  kind: python_call_eq
  category: constants
  id_prefix: pp2326

  columns: [id, function, args, expected]
  rows:
    - ["pp2326008", "pathlib.PurePath.__bases__.__len__",        [], 1]
    - ["pp2326009", "pathlib.PurePosixPath.__bases__.__len__",   [], 1]
    - ["pp2326010", "pathlib.PureWindowsPath.__bases__.__len__", [], 1]
    - ["pp2326011", "pathlib.Path.__bases__.__len__",            [], 1]

# ---------------------------------------------------------------------------
# Table 5: Class type identity — all classes are instances of 'type'
# ---------------------------------------------------------------------------

table pathlib_extra2326.class_types:
  description: "pathlib path classes are all instances of type"
  kind: python_call_eq
  category: constants
  id_prefix: pp2326

  columns: [id, function, args, expected]
  rows:
    - ["pp2326012", "pathlib.PurePath.__class__.__name__",        [], "type"]
    - ["pp2326013", "pathlib.PurePosixPath.__class__.__name__",   [], "type"]
    - ["pp2326014", "pathlib.PureWindowsPath.__class__.__name__", [], "type"]
    - ["pp2326015", "pathlib.Path.__class__.__name__",            [], "type"]

# ---------------------------------------------------------------------------
# Table 6: Module attribute — confirm classes belong to pathlib
# ---------------------------------------------------------------------------

table pathlib_extra2326.class_modules:
  description: "pathlib path class __module__ attributes"
  kind: python_call_eq
  category: constants
  id_prefix: pp2326

  columns: [id, function, args, expected]
  rows:
    - ["pp2326016", "pathlib.PurePath.__module__",        [], "pathlib"]
    - ["pp2326017", "pathlib.PurePosixPath.__module__",   [], "pathlib"]
    - ["pp2326018", "pathlib.PureWindowsPath.__module__", [], "pathlib"]
    - ["pp2326019", "pathlib.Path.__module__",            [], "pathlib"]
    - ["pp2326020", "pathlib.PosixPath.__module__",       [], "pathlib"]
