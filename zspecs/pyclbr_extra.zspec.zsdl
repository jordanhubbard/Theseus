spec: pyclbr_extra
version: ">=3.9"
backend: python_module(pyclbr)

docs: https://docs.python.org/3/library/pyclbr.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pyclbr.html — Python pyclbr module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pyclbr.py"
  notes:
    - "Extends pyclbr.zspec.zsdl with __name__, __module__, __bases__, and class-hierarchy invariants."
    - "pyclbr.readmodule.__name__ == 'readmodule' and __module__ == 'pyclbr'."
    - "pyclbr.readmodule_ex.__name__ == 'readmodule_ex' and __module__ == 'pyclbr'."
    - "pyclbr.Function.__name__ == 'Function' and __module__ == 'pyclbr'."
    - "pyclbr.Class.__name__ == 'Class' and __module__ == 'pyclbr'."
    - "pyclbr.Class.__bases__[0].__name__ == '_Object' — Class inherits from the internal _Object base."
    - "pyclbr.Function.__bases__[0].__name__ == '_Object' — Function also inherits from _Object."
    - "Both Class and Function are Python-level classes; their __class__.__name__ == 'type'."
    - "All expected values verified by running Python 3.12 pyclbr module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# readmodule and readmodule_ex — __name__ attributes
# ---------------------------------------------------------------------------

table pyclbr_extra.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [readmodule,    readmodule.__name__.__eq__,    ["readmodule"],    true]
    - [readmodule_ex, readmodule_ex.__name__.__eq__, ["readmodule_ex"], true]

# ---------------------------------------------------------------------------
# readmodule and readmodule_ex — __module__ attributes
# ---------------------------------------------------------------------------

table pyclbr_extra.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [readmodule,    readmodule.__module__.__eq__,    ["pyclbr"],  true]
    - [readmodule_ex, readmodule_ex.__module__.__eq__, ["pyclbr"],  true]

# ---------------------------------------------------------------------------
# Function class — name and module
# ---------------------------------------------------------------------------

invariant pyclbr_extra.Function.class_name:
  description: "pyclbr.Function.__name__ == 'Function'"
  category: class_names
  kind: python_call_eq
  function: Function.__name__.__eq__
  args: ["Function"]
  expected: true

invariant pyclbr_extra.Function.module:
  description: "pyclbr.Function.__module__ == 'pyclbr'"
  category: class_modules
  kind: python_call_eq
  function: Function.__module__.__eq__
  args: ["pyclbr"]
  expected: true

# ---------------------------------------------------------------------------
# Class class — name and module
# ---------------------------------------------------------------------------

invariant pyclbr_extra.Class.class_name:
  description: "pyclbr.Class.__name__ == 'Class'"
  category: class_names
  kind: python_call_eq
  function: Class.__name__.__eq__
  args: ["Class"]
  expected: true

invariant pyclbr_extra.Class.module:
  description: "pyclbr.Class.__module__ == 'pyclbr'"
  category: class_modules
  kind: python_call_eq
  function: Class.__module__.__eq__
  args: ["pyclbr"]
  expected: true

# ---------------------------------------------------------------------------
# Class.__bases__[0] — internal _Object base class
#
# pyclbr.Class inherits from pyclbr._Object, an internal base that provides
# shared attributes (name, file, lineno, module). Checking __bases__[0].__name__
# pins this internal hierarchy against accidental refactoring.
# ---------------------------------------------------------------------------

invariant pyclbr_extra.Class.base_class_name:
  description: "pyclbr.Class.__bases__[0].__name__ == '_Object' — Class inherits from the internal _Object base"
  category: class_hierarchy
  kind: python_call_eq
  function: Class.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_Object"

invariant pyclbr_extra.Class.base_class_module:
  description: "pyclbr.Class.__bases__[0].__module__ == 'pyclbr' — _Object is defined in pyclbr"
  category: class_hierarchy
  kind: python_call_eq
  function: Class.__bases__.__getitem__
  args: [0]
  method: __module__
  method_args: []
  expected: "pyclbr"

# ---------------------------------------------------------------------------
# Function.__bases__[0] — same _Object base class
# ---------------------------------------------------------------------------

invariant pyclbr_extra.Function.base_class_name:
  description: "pyclbr.Function.__bases__[0].__name__ == '_Object' — Function also inherits from _Object"
  category: class_hierarchy
  kind: python_call_eq
  function: Function.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "_Object"

# ---------------------------------------------------------------------------
# Class and Function are type objects (not instances)
# ---------------------------------------------------------------------------

table pyclbr_extra.class_is_type:
  kind: python_call_eq
  category: class_types
  id_prefix: is_type

  columns: [id, function, args, expected]
  rows:
    - [Class,    Class.__class__.__name__.__eq__,    ["type"],  true]
    - [Function, Function.__class__.__name__.__eq__, ["type"],  true]
