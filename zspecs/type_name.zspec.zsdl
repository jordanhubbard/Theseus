spec: type_name
version: ">=2.0.2"
backend: node(type-name)

docs: https://www.npmjs.com/package/type-name

provenance:
  derived_from:
    - "type-name README — https://www.npmjs.com/package/type-name"
    - "Test vectors verified with type-name via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "type-name source"
  notes:
    - "type-name is an npm package. Install: npm install type-name"
    - "Returns the type name of a value as a string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table type_name.typeName:
  kind: node_module_call_eq
  function: ~
  category: type
  id_prefix: tname

  columns: [id, args, expected]
  rows:
    - [obj,     [{}],       "Object"]
    - [array,   [[1, 2]],   "Array"]
    - [num,     [42],       "number"]
    - [str,     ["hello"],  "string"]
    - [bool,    [true],     "boolean"]
    - [null_v,  [null],     "null"]
