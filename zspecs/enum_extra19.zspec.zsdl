spec: enum_extra19
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra18.zspec.zsdl."
    - "enum_extra18 covers: __qualname__.__len__() for Enum/Flag/IntFlag/auto/unique/nonmember/member; EnumType/__qualname__.__eq__ and __qualname__.__len__; EnumMeta/__qualname__.__eq__ as 'EnumType'; IntFlag/__qualname__.__eq__; StrEnum/__qualname__.__eq__."
    - "enum_extra17 covers: StrEnum/IntFlag/EnumMeta/ReprEnum __name__.__len__; IntEnum/StrEnum __qualname__.__len__; StrEnum/__bases__[1]=='ReprEnum'; IntEnum/__bases__[1]=='ReprEnum'; IntEnum/__mro__[2]=='ReprEnum'; Flag/__mro__[1]=='Enum'; EnumMeta/__mro__[1]=='type'; StrEnum/__mro__[3]=='Enum'."
    - "enum_extra16 covers: Enum/__bases__.__len__/__bases__[0]; Flag/__bases__.__len__/__bases__[0]; EnumMeta/__bases__.__len__/__bases__[0]; auto/__bases__[0]; Enum/__mro__[0] (mro_first_is_self); EnumMeta/__mro__[0]."
    - "enum_extra13 covers: IntEnum/__mro__.__len__==5; IntEnum/__mro__[1]=='int'; IntEnum/__mro__[2]=='ReprEnum'; auto/__mro__.__len__==2; auto/__mro__[1]=='object'; unique/__qualname__/__module__."
    - "enum_extra10 covers: Enum/__mro__[0]=='Enum'; IntEnum/__mro__[0]=='IntEnum'; auto/__bases__[0].__name__=='int'; Enum/__bases__.__len__==1."
    - "enum_extra12 covers: EnumMeta/__mro__.__len__==3; Flag/__mro__.__len__==3."
    - "enum_extra5 covers: Flag/__mro__[0]=='Flag'; IntFlag/__mro__[0]=='IntFlag'."
    - "Focus of this spec: __name__.__len__() for unique, nonmember, member — no prior spec; MRO[0] for auto and unique — no prior spec checks auto/__mro__[0] or unique/__mro__[0]; IntEnum tail MRO entries [3] and [4] — not yet covered; unique/__mro__ length and last entry — fully fresh."
    - "NOT yet covered (entering this spec): unique.__name__.__len__()==6; nonmember.__name__.__len__()==9; member.__name__.__len__()==6; auto.__mro__[0].__name__=='auto'; unique.__mro__[0].__name__=='unique'; IntEnum.__mro__[3].__name__=='Enum'; IntEnum.__mro__[4].__name__=='object'; unique.__mro__.__len__()==2; unique.__mro__[1].__name__=='object'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for unique, nonmember, member
#
# enum_extra17 covers StrEnum/IntFlag/EnumMeta/ReprEnum name lengths.
# enum_extra15 covers Enum/Flag/IntEnum/auto name lengths.
# No prior spec checks __name__.__len__() for unique, nonmember, or member.
# Lengths: unique='unique'=6, nonmember='nonmember'=9, member='member'=6.
# nonmember and member are Python 3.11+ additions.
# ---------------------------------------------------------------------------

invariant enum_extra19.unique.name_len:
  description: "enum.unique.__name__.__len__() == 6 — 'unique' is 6 characters"
  category: class_names
  kind: python_call_eq
  function: unique.__name__.__len__
  args: []
  expected: 6

invariant enum_extra19.nonmember.name_len:
  description: "enum.nonmember.__name__.__len__() == 9 — 'nonmember' is 9 characters (Python 3.11+)"
  category: class_names
  version: ">=3.11"
  kind: python_call_eq
  function: nonmember.__name__.__len__
  args: []
  expected: 9

invariant enum_extra19.member.name_len:
  description: "enum.member.__name__.__len__() == 6 — 'member' is 6 characters (Python 3.11+)"
  category: class_names
  version: ">=3.11"
  kind: python_call_eq
  function: member.__name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# MRO[0] self-identity for auto and unique
#
# enum_extra16 covers Enum/EnumMeta MRO[0]; enum_extra10 covers IntEnum MRO[0];
# enum_extra5 covers Flag/IntFlag MRO[0].
# No prior spec checks auto.__mro__[0].__name__ or unique.__mro__[0].__name__.
# For every class, MRO[0] is always the class itself.
# ---------------------------------------------------------------------------

invariant enum_extra19.auto.mro_first:
  description: "enum.auto.__mro__[0].__name__ == 'auto' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: auto.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "auto"

invariant enum_extra19.unique.mro_first:
  description: "enum.unique.__mro__[0].__name__ == 'unique' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: unique.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "unique"

# ---------------------------------------------------------------------------
# StrEnum MRO[0] self-identity (Python 3.11+)
#
# enum_extra5 covers Flag/IntFlag MRO[0]; extra10 covers Enum/IntEnum MRO[0].
# No prior spec checks StrEnum.__mro__[0].__name__ (StrEnum is Python 3.11+).
# ---------------------------------------------------------------------------

invariant enum_extra19.StrEnum.mro_first:
  description: "enum.StrEnum.__mro__[0].__name__ == 'StrEnum' — first MRO entry is the class itself (Python 3.11+)"
  category: class_hierarchy
  version: ">=3.11"
  kind: python_call_eq
  function: StrEnum.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "StrEnum"

# ---------------------------------------------------------------------------
# IntEnum tail MRO entries: positions [3] and [4]
#
# enum_extra13 covers IntEnum/__mro__[1] == 'int' and [2] == 'ReprEnum'.
# IntEnum's full MRO is [IntEnum, int, ReprEnum, Enum, object] — length 5.
# No prior spec checks positions [3] ('Enum') or [4] ('object').
# ---------------------------------------------------------------------------

invariant enum_extra19.IntEnum.mro_entry3:
  description: "enum.IntEnum.__mro__[3].__name__ == 'Enum' — fourth MRO entry of IntEnum is Enum"
  category: class_hierarchy
  kind: python_call_eq
  function: IntEnum.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "Enum"

invariant enum_extra19.IntEnum.mro_entry4:
  description: "enum.IntEnum.__mro__[4].__name__ == 'object' — last MRO entry of IntEnum is object"
  category: class_hierarchy
  kind: python_call_eq
  function: IntEnum.__mro__.__getitem__
  args: [4]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# unique.__mro__ — length and second entry
#
# No prior spec checks unique.__mro__.__len__() or unique.__mro__[1].__name__.
# unique is a plain decorator class; its MRO is [unique, object] — length 2.
# MRO[0] is covered above. MRO[1] is object.
# ---------------------------------------------------------------------------

invariant enum_extra19.unique.mro_len:
  description: "enum.unique.__mro__.__len__() == 2 — MRO is [unique, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: unique.__mro__.__len__
  args: []
  expected: 2

invariant enum_extra19.unique.mro_last:
  description: "enum.unique.__mro__[1].__name__ == 'object' — last MRO entry of unique is object"
  category: class_hierarchy
  kind: python_call_eq
  function: unique.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"
