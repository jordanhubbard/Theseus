spec: abc_extra1891
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "abc module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party abc extensions"
  notes:
    - "Tests unary arithmetic protocol and async iteration protocol membership in abc types"
    - "None of the abc types implement unary arithmetic dunder methods"
    - "abc types do not implement async iteration protocol"
    - "abstractproperty is deprecated since 3.3 but remains present through 3.14"
    - "update_abstractmethods was added in Python 3.10"
    - "get_cache_token reflects ABCMeta cache invalidation mechanism"
  created_at: "2026-04-12"

table abc_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["ab1891-ua-001", "abc.ABC.__dict__.__contains__", ["__abs__"], false]
    - ["ab1891-ua-002", "abc.ABC.__dict__.__contains__", ["__neg__"], false]
    - ["ab1891-ua-003", "abc.ABC.__dict__.__contains__", ["__pos__"], false]
    - ["ab1891-ua-004", "abc.ABCMeta.__dict__.__contains__", ["__abs__"], false]
    - ["ab1891-ua-005", "abc.ABCMeta.__dict__.__contains__", ["__neg__"], false]
    - ["ab1891-ua-006", "abc.abstractmethod.__dict__.__contains__", ["__abs__"], false]
    - ["ab1891-ua-007", "abc.abstractmethod.__dict__.__contains__", ["__neg__"], false]
    - ["ab1891-ua-008", "abc.abstractmethod.__dict__.__contains__", ["__round__"], false]

