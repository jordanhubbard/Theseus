spec: catboost_rust
version: ">=3.9"
backend: rust_module(catboost_rust)

docs: https://catboost.ai/en/docs/concepts/python-reference_catboostclassifier

provenance:
  derived_from:
    - "https://catboost.ai/en/docs/ — CatBoost documentation"
  not_derived_from:
    - "catboost source: catboost/python-package/catboost/core.py"
  notes:
    - "CatBoost is a gradient boosting library with categorical feature support."
    - "CatBoostClassifier(iterations=50).get_params()['iterations'] == 50."
    - "CatBoostClassifier(depth=4).get_params()['depth'] == 4."
    - "CatBoostClassifier().get_params()['loss_function'] == 'Logloss'."
    - "Expose catboost_iterations(n) -> int: CatBoostClassifier(iterations=n).get_params()['iterations']."
    - "Expose catboost_depth(d) -> int: CatBoostClassifier(depth=d).get_params()['depth']."
    - "Expose catboost_loss_function() -> str: CatBoostClassifier().get_params()['loss_function']."
    - "All test vectors verified against catboost 1.2.7."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# catboost_iterations — iterations parameter roundtrip
table catboost_rust.params.iterations:
  kind: python_call_eq
  category: iterations
  id_prefix: cb_iter
  function: catboost_iterations

  columns: [id, args, expected]
  rows:
    - [fifty,   [50],  50]
    - [hundred, [100], 100]
    - [ten,     [10],  10]

# catboost_depth — depth parameter roundtrip
table catboost_rust.params.depth:
  kind: python_call_eq
  category: depth
  id_prefix: cb_depth
  function: catboost_depth

  columns: [id, args, expected]
  rows:
    - [four, [4], 4]
    - [six,  [6], 6]

# catboost_loss_function — default loss function
invariant catboost_rust.params.loss_function:
  description: "CatBoostClassifier default loss_function == 'Logloss'"
  category: loss_function
  kind: python_call_eq
  function: catboost_loss_function
  args: []
  expected: "Logloss"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:08:08Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
