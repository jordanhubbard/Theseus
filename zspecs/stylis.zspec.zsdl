spec: stylis
version: ">=4.0.0"
backend: node(stylis)

docs: https://stylis.js.org

provenance:
  derived_from:
    - "Stylis README — https://github.com/thysultan/stylis"
    - "Test vectors verified with stylis via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "stylis source"
  notes:
    - "CSS-in-JS preprocessor — minified CSS compilation engine for emotion / styled-components."
    - "Install: npm install stylis"
    - "v4 ESM only; named exports compile / serialize / stringify / middleware / plus a few constants."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant stylis.compile_returns_array:
  description: "compile() returns an Array (the rule list)"
  category: compile
  kind: node_chain_eq
  entry: named
  function: compile
  entry_args: [".foo { color: red; }"]
  chain:
    - {get: "constructor.name"}
  expected: "Array"

invariant stylis.compile_first_node_type:
  description: "First compiled node has type 'rule'"
  category: compile
  kind: node_chain_eq
  entry: named
  function: compile
  entry_args: [".foo { color: red; }"]
  chain:
    - {method: at, args: [0]}
    - {get: type}
  expected: "rule"

invariant stylis.compile_first_node_value:
  description: "First compiled node value is the selector"
  category: compile
  kind: node_chain_eq
  entry: named
  function: compile
  entry_args: [".foo { color: red; }"]
  chain:
    - {method: at, args: [0]}
    - {get: value}
  expected: ".foo"

invariant stylis.compile_array_length:
  description: "compile of one rule has length 1"
  category: compile
  kind: node_chain_eq
  entry: named
  function: compile
  entry_args: [".foo { color: red; }"]
  chain:
    - {get: length}
  expected: 1

invariant stylis.compile_two_rules_length:
  description: "compile of two rules has length 2"
  category: compile
  kind: node_chain_eq
  entry: named
  function: compile
  entry_args: [".foo { color: red; } .bar { color: blue; }"]
  chain:
    - {get: length}
  expected: 2

invariant stylis.has_compile_function:
  description: "compile is exported as a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "compile.constructor.name"}
  expected: "Function"

invariant stylis.has_serialize_function:
  description: "serialize is exported as a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "serialize.constructor.name"}
  expected: "Function"

invariant stylis.has_stringify_function:
  description: "stringify is exported as a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "stringify.constructor.name"}
  expected: "Function"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:27:19Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
