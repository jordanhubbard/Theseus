spec: re_extra280
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "re_extra279 covers re.sub, re.split, re.findall, re.subn behavioral contracts."
    - "This spec focuses on re.compile() result attributes: groups, pattern, and flags."
    - "re.compile(r'(\\w+)').groups == 1 — one capturing group in the pattern."
    - "re.compile(r'(\\w+)(\\d+)').groups == 2 — two capturing groups in the pattern."
    - "re.compile(r'').groups == 0 — empty pattern has no groups."
    - "re.compile(r'(\\w+)(\\d+)(\\s+)').groups == 3 — three capturing groups."
    - "re.compile(r'(\\w+)').pattern == '(\\\\w+)' — .pattern preserves the original pattern string."
    - "re.compile(r'').pattern == '' — empty pattern stored as empty string."
    - "re.compile(r'hello').pattern == 'hello' — literal pattern preserved exactly."
    - "re.compile(r'hello').flags == 32 — default flags include re.UNICODE (value 32) only."
    - "re.compile(r'hello', re.IGNORECASE).flags == 34 — re.IGNORECASE (2) combined with re.UNICODE (32)."
    - "re.compile(r'hello', re.MULTILINE).flags == 40 — re.MULTILINE (8) combined with re.UNICODE (32)."
    - "The result of re.compile() is an instance of re.Pattern; type(re.compile('')).__name__ == 'Pattern'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile().groups — number of capturing groups in the compiled pattern
# re.compile(r'(\w+)').groups == 1, re.compile(r'').groups == 0, etc.
# ---------------------------------------------------------------------------

table re_extra280.compile_groups:
  description: "re.compile().groups — count of capturing groups in the compiled pattern"
  kind: python_call_eq
  category: compile
  id_prefix: groups
  function: compile
  method: groups

  columns: [id, args, expected, description]
  rows:
    - [no_groups,     [""],                     0, "re.compile(r'').groups == 0 — empty pattern has no capturing groups"]
    - [one_group,     ["(\\w+)"],               1, "re.compile(r'(\\w+)').groups == 1 — single capturing group"]
    - [two_groups,    ["(\\w+)(\\d+)"],          2, "re.compile(r'(\\w+)(\\d+)').groups == 2 — two capturing groups"]
    - [three_groups,  ["(\\w+)(\\d+)(\\s+)"],    3, "re.compile(r'(\\w+)(\\d+)(\\s+)').groups == 3 — three capturing groups"]
    - [literal_only,  ["hello"],                 0, "re.compile(r'hello').groups == 0 — literal pattern has no capturing groups"]

# ---------------------------------------------------------------------------
# re.compile().pattern — the original pattern string is stored verbatim
# ---------------------------------------------------------------------------

table re_extra280.compile_pattern:
  description: "re.compile().pattern — the original pattern string stored on the compiled object"
  kind: python_call_eq
  category: compile
  id_prefix: pattern
  function: compile
  method: pattern

  columns: [id, args, expected, description]
  rows:
    - [empty,         [""],           "",          "re.compile(r'').pattern == '' — empty pattern stored as empty string"]
    - [literal,       ["hello"],      "hello",     "re.compile(r'hello').pattern == 'hello' — literal pattern preserved exactly"]
    - [one_group,     ["(\\w+)"],     "(\\w+)",    "re.compile(r'(\\w+)').pattern == '(\\w+)' — pattern string preserved with backslash"]
    - [two_groups,    ["(\\w+)(\\d+)"], "(\\w+)(\\d+)", "re.compile(r'(\\w+)(\\d+)').pattern == '(\\w+)(\\d+)'"]

# ---------------------------------------------------------------------------
# re.compile().flags — integer flag value on the compiled pattern object
# Default flags include re.UNICODE (32). Adding re.IGNORECASE adds 2 (total 34).
# Adding re.MULTILINE adds 8 (total 40).
# ---------------------------------------------------------------------------

invariant re_extra280.compile_flags.default:
  description: "re.compile(r'hello').flags == 32 — default compile flags include only re.UNICODE (value 32)"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["hello"]
  method: flags
  expected: 32

invariant re_extra280.compile_flags.ignorecase:
  description: "re.compile(r'hello', re.IGNORECASE).flags == 34 — IGNORECASE (2) combined with UNICODE (32)"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["hello", 2]
  method: flags
  expected: 34

invariant re_extra280.compile_flags.multiline:
  description: "re.compile(r'hello', re.MULTILINE).flags == 40 — MULTILINE (8) combined with UNICODE (32)"
  category: compile
  kind: python_call_eq
  function: compile
  args: ["hello", 8]
  method: flags
  expected: 40

# ---------------------------------------------------------------------------
# re.compile() result type identity
# ---------------------------------------------------------------------------

invariant re_extra280.compile_type.name:
  description: "type(re.compile('')).__name__ == 'Pattern' — re.compile() returns a Pattern instance"
  category: compile
  kind: python_call_eq
  function: compile
  args: [""]
  method: __class__.__name__
  expected: "Pattern"

invariant re_extra280.compile_type.module:
  description: "type(re.compile('')).__module__ == 're' — the Pattern class belongs to the re module"
  category: compile
  kind: python_call_eq
  function: compile
  args: [""]
  method: __class__.__module__
  expected: "re"

# ---------------------------------------------------------------------------
# re.compile is a function
# ---------------------------------------------------------------------------

invariant re_extra280.compile.is_function:
  description: "re.compile.__class__.__name__ == 'function' — compile is a Python-level function"
  category: compile
  kind: python_call_eq
  function: compile.__class__.__name__.__eq__
  args: ["function"]
  expected: true
