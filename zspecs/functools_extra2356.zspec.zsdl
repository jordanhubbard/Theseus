spec: functools_extra2356
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 604 (_extra2356): __init__ and __new__ implementation type classification."
    - "functools.partial is a C type: __init__ == 'wrapper_descriptor', __new__ == 'builtin_function_or_method'."
    - "functools.partialmethod is a Python class with a custom __new__ (_partial_new): __init__ == 'wrapper_descriptor', __new__ == 'function'."
    - "functools.cached_property is a Python class with custom __init__: __init__ == 'function', __new__ == 'builtin_function_or_method'."
    - "functools._lru_cache_wrapper is a C type: __init__ == 'wrapper_descriptor', __new__ == 'builtin_function_or_method'."
    - "functools.reduce is a builtin_function_or_method (C-level)."
    - "functools.lru_cache and functools.wraps are plain Python functions."
    - "functools.cached_property.__doc__ is None (no docstring defined on the class itself on this platform)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __init__ implementation type for functools classes
# ---------------------------------------------------------------------------

table functools_extra2356.init_types:
  description: "functools class __init__ implementation type — 'wrapper_descriptor' for C types, 'function' for Python-defined __init__"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2356
  columns: [id, function, args, expected]
  rows:
    - ["ft2356001", "functools.partial.__init__.__class__.__name__",           [], "wrapper_descriptor"]
    - ["ft2356002", "functools.partialmethod.__init__.__class__.__name__",     [], "wrapper_descriptor"]
    - ["ft2356003", "functools.cached_property.__init__.__class__.__name__",   [], "function"]
    - ["ft2356004", "functools._lru_cache_wrapper.__init__.__class__.__name__", [], "wrapper_descriptor"]

# ---------------------------------------------------------------------------
# __new__ implementation type for functools classes
# ---------------------------------------------------------------------------

table functools_extra2356.new_types:
  description: "functools class __new__ implementation type — 'builtin_function_or_method' for C-provided __new__, 'function' for Python-defined __new__"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2356
  columns: [id, function, args, expected]
  rows:
    - ["ft2356005", "functools.partial.__new__.__class__.__name__",            [], "builtin_function_or_method"]
    - ["ft2356006", "functools.partialmethod.__new__.__class__.__name__",      [], "function"]
    - ["ft2356007", "functools.cached_property.__new__.__class__.__name__",    [], "builtin_function_or_method"]
    - ["ft2356008", "functools._lru_cache_wrapper.__new__.__class__.__name__", [], "builtin_function_or_method"]

# ---------------------------------------------------------------------------
# Module-level function __class__.__name__ — builtin vs Python function
# ---------------------------------------------------------------------------

table functools_extra2356.function_class_names:
  description: "functools module-level function implementation type — reduce is C-level builtin, lru_cache/wraps/total_ordering/cache/singledispatch are Python functions"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2356
  columns: [id, function, args, expected]
  rows:
    - ["ft2356009", "functools.reduce.__class__.__name__",           [], "builtin_function_or_method"]
    - ["ft2356010", "functools.lru_cache.__class__.__name__",        [], "function"]
    - ["ft2356011", "functools.wraps.__class__.__name__",            [], "function"]
    - ["ft2356012", "functools.total_ordering.__class__.__name__",   [], "function"]
    - ["ft2356013", "functools.cache.__class__.__name__",            [], "function"]
    - ["ft2356014", "functools.singledispatch.__class__.__name__",   [], "function"]

# ---------------------------------------------------------------------------
# __doc__ class names for key functools classes and functions
# ---------------------------------------------------------------------------

table functools_extra2356.doc_class_names:
  description: "functools __doc__.__class__.__name__ — str for documented objects, NoneType for undocumented"
  kind: python_call_eq
  category: type_identity
  id_prefix: ft2356
  columns: [id, function, args, expected]
  rows:
    - ["ft2356015", "functools.partial.__doc__.__class__.__name__",            [], "str"]
    - ["ft2356016", "functools.partialmethod.__doc__.__class__.__name__",      [], "str"]
    - ["ft2356017", "functools.reduce.__doc__.__class__.__name__",             [], "str"]
    - ["ft2356018", "functools.lru_cache.__doc__.__class__.__name__",          [], "str"]
    - ["ft2356019", "functools.wraps.__doc__.__class__.__name__",              [], "str"]
    - ["ft2356020", "functools._lru_cache_wrapper.__doc__.__class__.__name__", [], "str"]
    - ["ft2356021", "functools.cached_property.__doc__.__class__.__name__",    [], "NoneType"]
