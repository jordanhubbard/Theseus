spec: asyncio_extra2101
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-stream.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2101 (asyncio_extra2101): __class_getitem__, __init_subclass__, __subclasshook__, __mro_entries__ dict-presence checks."
    - "asyncio.Task defines __class_getitem__ in its own __dict__ (Python 3.9+) — it supports generic alias subscripting."
    - "asyncio.Future defines __class_getitem__ in its own __dict__ (Python 3.9+) — it supports generic alias subscripting."
    - "asyncio.Queue defines __class_getitem__ in its own __dict__ (Python 3.9+) — it supports generic alias subscripting."
    - "asyncio.Event does NOT define __class_getitem__ in its own __dict__."
    - "asyncio.Lock does NOT define __class_getitem__ in its own __dict__."
    - "asyncio.StreamReader does NOT define __class_getitem__ in its own __dict__."
    - "asyncio.Semaphore does NOT define __class_getitem__ in its own __dict__."
    - "None of the checked classes define __init_subclass__ in their own __dict__ — inherited from object."
    - "None of the checked classes define __subclasshook__ in their own __dict__."
    - "None of the checked classes define __mro_entries__ in their own __dict__ — MRO resolution protocol is absent."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra2101.class_getitem_protocol:
  description: "asyncio classes __class_getitem__ dict-presence checks — generic alias protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2101

  columns: [id, function, args, expected]
  rows:
    - ["as2101001", "asyncio.Task.__dict__.__contains__", ["__class_getitem__"], true]
    - ["as2101002", "asyncio.Future.__dict__.__contains__", ["__class_getitem__"], true]
    - ["as2101003", "asyncio.Queue.__dict__.__contains__", ["__class_getitem__"], true]
    - ["as2101004", "asyncio.Event.__dict__.__contains__", ["__class_getitem__"], false]
    - ["as2101005", "asyncio.Lock.__dict__.__contains__", ["__class_getitem__"], false]
    - ["as2101006", "asyncio.StreamReader.__dict__.__contains__", ["__class_getitem__"], false]
    - ["as2101007", "asyncio.Semaphore.__dict__.__contains__", ["__class_getitem__"], false]

