spec: struct_extra38
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra37.zspec.zsdl — covers struct.Struct.__bases__[0].__name__.__eq__('object') and struct.pack_into/unpack_from/iter_unpack __qualname__.__eq__ (module-level); struct.calcsize('P')==8."
    - "struct_extra27.zspec.zsdl — covers Struct/__mro__.__len__()==2; error/__mro__.__len__()==4; Struct/__bases__[0]/__name__.__len__()==6; error/__bases__[0]/__name__.__len__()==9 (length checks only, NOT string eq values)."
    - "struct_extra9.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__eq__ as Struct class METHOD attributes."
    - "struct_extra4.zspec.zsdl — covers error.__qualname__.__eq__('error') and Struct.__qualname__.__eq__('Struct'); module-level function __qualname__.__eq__ table."
    - "struct_extra2.zspec.zsdl — covers Struct.__bases__[0].__name__=='object' via module-level check."
    - "struct_extra.zspec.zsdl — covers error.__bases__[0].__name__=='Exception' via __bases__.__getitem__."
  notes:
    - "This spec extends struct through struct_extra37; it does NOT duplicate invariants present in those files."
    - "Coverage gap 1: struct_extra37 covers Struct.__bases__[0].__name__.__eq__('object') (__name__ axis). struct_extra27 covers error.__bases__[0].__name__.__len__()==9 (__name__ axis, length only). But NO prior spec checks Struct.__bases__[0].__qualname__.__eq__('object') or error.__bases__[0].__qualname__.__eq__('Exception') via the __qualname__ attribute chain. For builtin types 'object' and 'Exception', __qualname__ == __name__, but accessing via .__qualname__ is a distinct attribute chain and an independent regression vector. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.Struct.__bases__[0].__qualname__ == 'object'. Struct inherits directly from object. struct_extra37 covers __bases__[0].__name__.__eq__('object') (__name__ axis); struct_extra2 covers same via __name__. No prior spec checks __bases__[0].__qualname__ for Struct. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__qualname__ == 'Exception'. struct.error inherits from Exception. struct_extra covers error.__bases__[0].__name__=='Exception' via __getitem__; struct_extra27 covers __name__.__len__()==9. No prior spec checks error.__bases__[0].__qualname__.__eq__('Exception') via the .__qualname__ chain. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "Coverage gap 2: struct_extra27 covers Struct.__mro__.__len__()==2 and error.__mro__.__len__()==4 (counts only). No prior spec checks the __name__ string values of individual mro entries via __eq__. Struct.__mro__[1].__name__ == 'object'; error.__mro__[1].__name__ == 'Exception'; error.__mro__[2].__name__ == 'BaseException'; error.__mro__[3].__name__ == 'object'. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[1].__name__ == 'Exception'. error inherits from Exception; its second mro entry is Exception. No prior spec checks individual mro entry __name__ values via __eq__. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "struct.error.__mro__[2].__name__ == 'BaseException'. The third mro entry for error. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct and struct.error __bases__[0].__qualname__ string eq checks
#
# struct_extra37 covers Struct.__bases__[0].__name__.__eq__('object') (__name__ axis).
# struct_extra2 covers Struct.__bases__[0].__name__=='object' (__name__ axis).
# struct_extra covers error.__bases__[0].__name__=='Exception' via __getitem__.
# struct_extra27 covers error.__bases__[0].__name__.__len__()==9 (__name__ length).
# No prior spec checks .__bases__[0].__qualname__ for Struct or error.
# For builtin types, __qualname__ == __name__, but .__qualname__ is a distinct
# attribute chain and provides an independent regression vector.
# ---------------------------------------------------------------------------

table struct_extra38.bases_qualname_eq:
  description: "struct.Struct/__bases__[0]/__qualname__.__eq__('object') and error/__bases__[0]/__qualname__.__eq__('Exception') — novel __qualname__ axis; extra37 covers Struct __bases__[0].__name__.__eq__('object'); extra2/extra cover same via __name__; no prior spec checks __qualname__ attribute for these base classes"
  kind: python_call_eq
  category: type_structure
  id_prefix: sbqe38

  columns: [id, function, args, expected]
  rows:
    - [Struct_base_qualname_eq, "Struct.__bases__[0].__qualname__.__eq__", ["object"],    true]
    - [error_base_qualname_eq,  "error.__bases__[0].__qualname__.__eq__",  ["Exception"], true]

# ---------------------------------------------------------------------------
# struct.error mro entry __name__ string eq values
#
# struct_extra27 covers error.__mro__.__len__()==4 (count only).
# No prior spec checks the __name__ of individual mro entries via __eq__.
# error.__mro__ == (error, Exception, BaseException, object)
# Entries at index 1, 2, 3 have __name__ 'Exception', 'BaseException', 'object'.
# ---------------------------------------------------------------------------

table struct_extra38.error_mro_name_eq:
  description: "struct.error.__mro__[1]/__name__.__eq__('Exception') and __mro__[2]/__name__.__eq__('BaseException') — novel: extra27 covers error/__mro__.__len__()==4 (count only); no prior spec checks individual error mro entry __name__ string eq values"
  kind: python_call_eq
  category: type_structure
  id_prefix: semne38

  columns: [id, function, args, expected]
  rows:
    - [error_mro1_name_eq, "error.__mro__[1].__name__.__eq__", ["Exception"],    true]
    - [error_mro2_name_eq, "error.__mro__[2].__name__.__eq__", ["BaseException"], true]
