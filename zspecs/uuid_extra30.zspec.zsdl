spec: uuid_extra30
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra29.zspec.zsdl — covers UUID/__module__/__len__()==4; SafeUUID/__module__/__len__()==4; SafeUUID/__mro__/__len__()==3; UUID/__mro__/__len__()==2; getnode/__qualname__/__len__()==7; uuid4/__doc__/__class__/__name__/__len__()==3."
    - "uuid_extra28.zspec.zsdl — covers UUID.time_low/time_mid/clock_seq_low property descriptor class name lens (8); time_low/time_mid/clock_seq_low fget __qualname__.__len__()."
    - "uuid_extra27.zspec.zsdl — covers UUID.bytes_le.__class__.__name__.__len__()==8; uuid3/uuid5 result __class__.__name__.__len__()==4; NAMESPACE_URL.__class__.__qualname__.__len__()==4."
    - "uuid_extra26.zspec.zsdl — covers UUID.int/is_safe member_descriptor class name len (17); UUID.hex/urn/variant/version property descriptor class name len (8)."
    - "uuid_extra23.zspec.zsdl — covers UUID.hex/bytes/bytes_le.fget.__qualname__.__len__(); UUID.__dict__.__class__.__name__.__len__()==12; uuid1/3/4/5 __qualname__.__len__()==5."
    - "uuid_extra22.zspec.zsdl — covers UUID.__slots__.__class__.__name__.__eq__('tuple') and UUID.__slots__.__len__()==3."
    - "uuid_extra21.zspec.zsdl — covers uuid1/3/4/5 __name__.__len__()==5; NAMESPACE_URL/OID/X500 __class__.__module__.__len__()==4."
    - "uuid_extra16.zspec.zsdl — covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__ __qualname__.__eq__ and __qualname__.__len__()."
  notes:
    - "This spec extends uuid through uuid_extra29; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: uuid1/3/4/5 __name__.__len__()==5 (extra21); uuid1/3/4/5 __qualname__.__len__()==5 (extra23); UUID.__module__.__len__()==4 (extra29, via len); UUID.__bases__[0].__name__ is 'object' — no prior spec checks this directly as a string eq value."
    - "uuid.UUID.__name__ == 'UUID'. No prior spec checks UUID.__name__ as a string eq value (extra21 covers __name__.__len__()==5 for uuid1/3/4/5 functions, not the class). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__ == 'uuid'. extra29 covers UUID.__module__.__len__()==4 but NOT the string value via __eq__. The string equality check is a distinct invariant. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.UUID.__bases__[0].__name__ == 'object'. UUID directly subclasses object. No prior spec checks UUID.__bases__ in any capacity. The bases tuple contains exactly one element (object). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__name__ == 'uuid4'. extra21 covers uuid4.__name__.__len__()==5 but not the string value. Checking __eq__ directly is a novel invariant. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__module__ == 'uuid'. uuid4 is defined in the uuid Python module. No prior spec checks uuid4.__module__ as a string value (extra23 uses qualname which implies module context but does not check __module__ directly). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__name__ == 'uuid1'. Same pattern as uuid4: extra21 covers __len__()==5 but not the eq value. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__name__ == 'uuid3'. Same pattern. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__name__ == 'uuid5'. Same pattern. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'. NAMESPACE_DNS is a UUID instance; its __class__.__name__ is 'UUID'. extra27 covers uuid3/uuid5 result __class__.__name__.__len__()==4 (same length, different object). No prior spec checks NAMESPACE_DNS.__class__.__name__ as a string value. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__name__ and uuid.UUID.__module__ string eq checks
#
# extra21 covers uuid1/3/4/5 __name__.__len__()==5 (function names, not class).
# extra29 covers UUID.__module__.__len__()==4 (length, not value).
# Neither checks UUID.__name__ or UUID.__module__ as direct string eq values.
# ---------------------------------------------------------------------------

table uuid_extra30.UUID_class_identity:
  description: "uuid.UUID.__name__=='UUID' and uuid.UUID.__module__=='uuid' — novel string eq checks; extra21 covers function __name__.__len__() only; extra29 covers UUID.__module__.__len__() only"
  kind: python_call_eq
  category: module_metadata
  id_prefix: uci30

  columns: [id, function, args, expected]
  rows:
    - [UUID_name_eq,   UUID.__name__.__eq__,   ["UUID"], true]
    - [UUID_module_eq, UUID.__module__.__eq__,  ["uuid"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__bases__[0].__name__ == 'object'
#
# UUID directly subclasses object with no intermediate base classes.
# UUID.__bases__ == (object,) so UUID.__bases__[0].__name__ == 'object'.
# No prior spec checks UUID.__bases__ in any capacity.
# Note: function contains '[' so it must be quoted per ZSDL rules.
# ---------------------------------------------------------------------------

invariant uuid_extra30.UUID.bases_name:
  description: "uuid.UUID.__bases__[0].__name__ == 'object' — UUID directly subclasses object; novel: no prior uuid spec checks __bases__ for any class"
  category: class_introspection
  kind: python_call_eq
  function: "UUID.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# uuid function __name__ string eq checks for uuid1/uuid3/uuid4/uuid5
#
# extra21 covers uuid1/3/4/5 __name__.__len__()==5 (length only).
# No prior spec verifies the actual __name__ string values via __eq__.
# uuid4.__module__ is also verified: 'uuid' (no prior spec checks __module__
# as a string value for any uuid function).
# ---------------------------------------------------------------------------

table uuid_extra30.uuid_function_names:
  description: "uuid.uuid1/3/4/5 __name__ string eq checks — novel: extra21 covers __name__.__len__()==5 only; this verifies the actual string values"
  kind: python_call_eq
  category: function_names
  id_prefix: ufn30

  columns: [id, function, args, expected]
  rows:
    - [uuid1_name_eq, uuid1.__name__.__eq__, ["uuid1"], true]
    - [uuid3_name_eq, uuid3.__name__.__eq__, ["uuid3"], true]
    - [uuid4_name_eq, uuid4.__name__.__eq__, ["uuid4"], true]
    - [uuid5_name_eq, uuid5.__name__.__eq__, ["uuid5"], true]

# ---------------------------------------------------------------------------
# uuid.uuid4.__module__ == 'uuid'
#
# uuid4 is defined in the uuid Python module. No prior spec checks __module__
# as a string eq value for any uuid function (extra29 covers UUID.__module__
# for the class object only, not for functions).
# ---------------------------------------------------------------------------

invariant uuid_extra30.uuid4.module_eq:
  description: "uuid.uuid4.__module__ == 'uuid' — uuid4 is defined in the uuid module; novel: no prior spec checks __module__ as a string eq value for any uuid function"
  category: module_metadata
  kind: python_call_eq
  function: uuid4.__module__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'
#
# NAMESPACE_DNS is a predefined UUID constant representing the DNS namespace.
# Its class is UUID, so __class__.__name__ == 'UUID'.
# extra27 covers uuid3/uuid5 result __class__.__name__.__len__()==4 (same
# length) but for function return values, not the NAMESPACE constants.
# No prior spec checks NAMESPACE_DNS.__class__.__name__ as a string value.
# ---------------------------------------------------------------------------

invariant uuid_extra30.NAMESPACE_DNS.class_name_eq:
  description: "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — NAMESPACE_DNS is a UUID instance; novel: no prior spec checks NAMESPACE_DNS.__class__.__name__ as a string eq value"
  category: class_introspection
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true
