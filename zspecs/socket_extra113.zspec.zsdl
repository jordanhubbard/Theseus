spec: socket_extra113
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra112.zspec.zsdl — covers AddressFamily/SocketKind enum .name equality and lengths / socket.socket MRO structure / socket.socket.bind and connect qualname lengths (table + invariants)."
    - "socket_extra111.zspec.zsdl — covers socket module-level __name__/__package__/__spec__/__all__/__loader__ dunder attributes (table + invariants)."
    - "socket_extra110.zspec.zsdl — covers socket.socket context manager methods / socket.__repr__ qualname / socket.socket.__module__/__qualname__ equality (table + invariants)."
    - "socket_extra109.zspec.zsdl — covers socket.socket Python-defined method co_argcount values and qualnames (table + invariants)."
    - "socket_extra108.zspec.zsdl — covers gethostname/gethostbyname/getnameinfo/getaddrinfo/getfqdn function identities (table + invariants)."
    - "socket_extra107.zspec.zsdl — covers SO_* option constants and socket.error/timeout class identity and MRO (table + invariants)."
    - "socket_extra106.zspec.zsdl — covers IPPROTO_* constants class names and values (table + invariants)."
    - "socket_extra105.zspec.zsdl — covers AF_*/SOCK_* class module/qualname/mro / AddressFamily/SocketKind name/module/metaclass/base identity (table + invariants)."
    - "socket_extra104.zspec.zsdl — covers socket.socket C-method types and qualname lengths (table + invariants)."
    - "socket_extra103.zspec.zsdl — covers socket.inet_aton/ntoa/pton/ntop / herror/gaierror MRO / AddressFamily/SocketKind MRO depth (table + invariants)."
    - "socket_extra102.zspec.zsdl — covers socket.socket __qualname__/__name__.__len__()==6 / error.__name__.__eq__('OSError') / herror/gaierror qualname/module/bases (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket module-level function qualname lengths / SocketIO class metaclass/module/bases (table + invariants)."
  notes:
    - "This spec extends socket through socket_extra112; it does NOT duplicate invariants present in those files."
    - "Wave 273 theme: socket.socket method qualname string equality for send/recv/listen/accept/setsockopt/getsockopt — not yet individually anchored; method type identity (send/recv/listen/setsockopt/getsockopt are method_descriptor; accept is a Python function); setsockopt/getsockopt qualname lengths (17 chars each)."
    - "socket.socket.send.__qualname__ == 'socket.send' (11 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__qualname__ == 'socket.recv' (11 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__qualname__ == 'socket.listen' (13 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__qualname__ == 'socket.accept' (13 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__qualname__ == 'socket.setsockopt' (17 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__qualname__ == 'socket.getsockopt' (17 chars). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.send.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.recv.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.listen.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.accept.__code__.co_argcount == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket.send, socket.socket.recv, socket.socket.listen, socket.socket.setsockopt, socket.socket.getsockopt are C-level method_descriptor objects (from socketmodule.c). socket.socket.accept is a Python function defined in Lib/socket.py (it wraps the C-level _socket.socket.accept and returns a socket instance). socket_extra104 anchors C-method types and qualname lengths for bind/connect/close; this spec anchors send/recv/listen/accept/setsockopt/getsockopt qualname equality for the first time."
    - "Note: setsockopt and getsockopt have the longest qualnames in this spec at 17 chars each ('socket.'=7 + 'setsockopt'=10 and 'socket.'=7 + 'getsockopt'=10). send and recv are tied at 11 chars (same length as socket.socket.bind.__qualname__ covered in socket_extra112). listen and accept are tied at 13 chars."
    - "Note: All qualnames use the 'socket.' prefix (7 chars) because these are methods of the C class _socket.socket. The Python wrapper class socket.socket inherits these from _socket.socket, so their __qualname__ uses 'socket.' (the C class name) not 'socket.socket.' (the Python wrapper name)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.send.__qualname__.__eq__('socket.send')
# socket.socket.recv.__qualname__.__eq__('socket.recv')
# socket.socket.send.__qualname__.__len__() == 11
# socket.socket.recv.__qualname__.__len__() == 11
# socket.socket.listen.__qualname__.__eq__('socket.listen')
#
# Wave 273 theme: send/recv/listen qualname equality and send/recv length equality.
#
# socket.socket.send.__qualname__ is 'socket.send' (11 chars: 'socket.'=7 + 'send'=4).
# socket.socket.recv.__qualname__ is 'socket.recv' (11 chars: 'socket.'=7 + 'recv'=4).
# Both send and recv share the same qualname length (11), matching
# socket.socket.bind.__qualname__='socket.bind' (also 11 chars, covered in socket_extra112).
# socket.socket.listen.__qualname__ is 'socket.listen' (13 chars: 'socket.'=7 + 'listen'=6).
# No prior socket spec anchors send/recv/listen qualname equality.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra113.send_recv_listen_qualname_equality:
  description: "socket.send.__qualname__.__eq__('socket.send')==True / socket.recv.__qualname__.__eq__('socket.recv')==True / socket.send.__qualname__.__len__()==11 / socket.recv.__qualname__.__len__()==11 / socket.listen.__qualname__.__eq__('socket.listen')==True — send and recv both have 11-char qualnames (matching bind from extra112); listen is 13 chars ('socket.'=7+'listen'=6); all use 'socket.' prefix (C class name from _socket.socket); no prior spec anchors these qualname equalities; first sockconn113 anchor"
  kind: python_call_eq
  category: method_identity
  id_prefix: sockconn113

  columns: [id, function, args, expected, description]
  rows:
    - [send_qualname_eq,   "socket.send.__qualname__.__eq__",   ["socket.send"],   true, "socket.socket.send.__qualname__ is 'socket.send' (11 chars; 'socket.'=7 + 'send'=4; C method for sending data)"]
    - [recv_qualname_eq,   "socket.recv.__qualname__.__eq__",   ["socket.recv"],   true, "socket.socket.recv.__qualname__ is 'socket.recv' (11 chars; 'socket.'=7 + 'recv'=4; same length as send)"]
    - [send_qualname_len,  "socket.send.__qualname__.__len__",  [],                11,   "socket.socket.send.__qualname__.__len__() is 11 (same length as bind from extra112 and recv)"]
    - [recv_qualname_len,  "socket.recv.__qualname__.__len__",  [],                11,   "socket.socket.recv.__qualname__.__len__() is 11 (tied with send; both 'socket.' + 4-char name)"]
    - [listen_qualname_eq, "socket.listen.__qualname__.__eq__", ["socket.listen"], true, "socket.socket.listen.__qualname__ is 'socket.listen' (13 chars; 'socket.'=7 + 'listen'=6; sets up passive socket for incoming connections)"]

# ---------------------------------------------------------------------------
# socket.socket.accept.__qualname__.__eq__('socket.accept')
# socket.socket.setsockopt.__qualname__.__eq__('socket.setsockopt')
# socket.socket.getsockopt.__qualname__.__eq__('socket.getsockopt')
# socket.socket.setsockopt.__qualname__.__len__() == 17
# socket.socket.getsockopt.__qualname__.__len__() == 17
#
# Wave 273 theme: accept/setsockopt/getsockopt qualname equality and setsockopt/getsockopt lengths.
#
# socket.socket.accept.__qualname__ is 'socket.accept' (13 chars; same length as
# listen). socket.socket.setsockopt.__qualname__ is 'socket.setsockopt' (17 chars:
# 'socket.'=7 + 'setsockopt'=10). socket.socket.getsockopt.__qualname__ is
# 'socket.getsockopt' (17 chars: 'socket.'=7 + 'getsockopt'=10). setsockopt and
# getsockopt share length 17 — the longest qualnames in this spec.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra113.accept_setsockopt_getsockopt_qualname_equality:
  description: "socket.accept.__qualname__.__eq__('socket.accept')==True / socket.setsockopt.__qualname__.__eq__('socket.setsockopt')==True / socket.getsockopt.__qualname__.__eq__('socket.getsockopt')==True / socket.setsockopt.__qualname__.__len__()==17 / socket.getsockopt.__qualname__.__len__()==17 — accept is 13 chars (same length as listen); setsockopt and getsockopt are tied at 17 chars (longest in this spec; 'socket.'=7+'setsockopt'=10 / 'getsockopt'=10); first sockconn113 anchor for these qualname equalities"
  kind: python_call_eq
  category: method_identity
  id_prefix: sockconn113

  columns: [id, function, args, expected, description]
  rows:
    - [accept_qualname_eq,      "socket.accept.__qualname__.__eq__",      ["socket.accept"],     true, "socket.socket.accept.__qualname__ is 'socket.accept' (13 chars; Python function wrapping C _socket.socket.accept)"]
    - [setsockopt_qualname_eq,  "socket.setsockopt.__qualname__.__eq__",  ["socket.setsockopt"], true, "socket.socket.setsockopt.__qualname__ is 'socket.setsockopt' (17 chars; 'socket.'=7 + 'setsockopt'=10; sets socket option)"]
    - [getsockopt_qualname_eq,  "socket.getsockopt.__qualname__.__eq__",  ["socket.getsockopt"], true, "socket.socket.getsockopt.__qualname__ is 'socket.getsockopt' (17 chars; 'socket.'=7 + 'getsockopt'=10; reads socket option)"]
    - [setsockopt_qualname_len, "socket.setsockopt.__qualname__.__len__", [],                    17,   "socket.socket.setsockopt.__qualname__.__len__() is 17 (longest in this spec; tied with getsockopt)"]
    - [getsockopt_qualname_len, "socket.getsockopt.__qualname__.__len__", [],                    17,   "socket.socket.getsockopt.__qualname__.__len__() is 17 (tied with setsockopt; 'socket.'=7 + 'getsockopt'=10)"]

# ---------------------------------------------------------------------------
# socket.socket.send.__class__.__name__.__eq__('method_descriptor')
# socket.socket.recv.__class__.__name__.__eq__('method_descriptor')
# socket.socket.listen.__class__.__name__.__eq__('method_descriptor')
# socket.socket.setsockopt.__class__.__name__.__eq__('method_descriptor')
# socket.socket.accept.__class__.__name__.__eq__('function')
#
# Wave 273 theme: send/recv/listen/setsockopt method types and accept Python function type.
#
# socket.socket.send, recv, listen, setsockopt are C-level method_descriptor objects
# from _socket.socket (Modules/socketmodule.c). socket.socket.accept is notable: it is
# a Python 'function' defined in Lib/socket.py that wraps the C-level accept and
# returns a socket.socket instance (not a bare _socket.socket). socket_extra104
# anchors C-method types and qualname lengths for bind/connect/close; this spec
# anchors the type identity for send/recv/listen/setsockopt/accept.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra113.send_recv_listen_setsockopt_types_and_accept_function:
  description: "socket.send.__class__.__name__.__eq__('method_descriptor')==True / socket.recv.__class__.__name__.__eq__('method_descriptor')==True / socket.listen.__class__.__name__.__eq__('method_descriptor')==True / socket.setsockopt.__class__.__name__.__eq__('method_descriptor')==True / socket.accept.__class__.__name__.__eq__('function')==True — send/recv/listen/setsockopt are C-level method_descriptor (from socketmodule.c); accept is a Python function (Lib/socket.py wraps C accept and returns socket.socket); extra104 anchors C-method types for bind/connect/close; first sockconn113 anchor for these method types"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockconn113

  columns: [id, function, args, expected, description]
  rows:
    - [send_type_eq,      "socket.send.__class__.__name__.__eq__",      ["method_descriptor"], true, "socket.socket.send is a C-level method_descriptor (from _socket.socket in socketmodule.c)"]
    - [recv_type_eq,      "socket.recv.__class__.__name__.__eq__",      ["method_descriptor"], true, "socket.socket.recv is a C-level method_descriptor (from _socket.socket; receives data from socket)"]
    - [listen_type_eq,    "socket.listen.__class__.__name__.__eq__",    ["method_descriptor"], true, "socket.socket.listen is a C-level method_descriptor (from _socket.socket; sets up server socket backlog)"]
    - [setsockopt_type_eq,"socket.setsockopt.__class__.__name__.__eq__",["method_descriptor"], true, "socket.socket.setsockopt is a C-level method_descriptor (sets SO_* options on the socket)"]
    - [accept_type_eq,    "socket.accept.__class__.__name__.__eq__",    ["function"],          true, "socket.socket.accept is a Python function (defined in Lib/socket.py; wraps C accept to return socket.socket instance)"]

# ---------------------------------------------------------------------------
# socket.socket.send.__qualname__.__eq__('socket.send') — standalone
#
# socket.socket.send.__qualname__ is 'socket.send' (11 chars: 'socket.'=7 + 'send'=4).
# send is a C-level method_descriptor from _socket.socket. Its qualname uses the
# 'socket.' prefix (the C class name) rather than 'socket.socket.' (the Python wrapper
# class name). send shares its qualname length (11) with recv and bind. No prior
# socket spec anchors socket.socket.send qualname equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra113.send_qualname_eq:
  description: "socket.socket.send.__qualname__.__eq__('socket.send') == True — qualname is 'socket.send' (11 chars; 'socket.'=7 + 'send'=4); 'socket.' prefix is the C class name from _socket.socket; same length as recv and bind; method_descriptor type; no prior spec anchors send qualname equality as standalone; first standalone under sockconn113"
  category: method_identity
  kind: python_call_eq
  function: "socket.send.__qualname__.__eq__"
  args: ["socket.send"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.recv.__qualname__.__eq__('socket.recv') — standalone
#
# socket.socket.recv.__qualname__ is 'socket.recv' (11 chars: 'socket.'=7 + 'recv'=4).
# recv is a C-level method_descriptor for receiving data from the socket. Its qualname
# 'socket.recv' has the same length as 'socket.send' (11 chars) and 'socket.bind'
# (11 chars from socket_extra112). recv and send are paired operations (one receives,
# one sends) and share both type (method_descriptor) and qualname length (11 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra113.recv_qualname_eq:
  description: "socket.socket.recv.__qualname__.__eq__('socket.recv') == True — qualname is 'socket.recv' (11 chars; 'socket.'=7 + 'recv'=4); same length as 'socket.send' and 'socket.bind' (extra112); recv pairs with send as complementary data transfer operations; both are C-level method_descriptor type; first standalone for recv under sockconn113"
  category: method_identity
  kind: python_call_eq
  function: "socket.recv.__qualname__.__eq__"
  args: ["socket.recv"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.accept.__class__.__name__.__eq__('function') — standalone
#
# socket.socket.accept is a Python 'function' (not a C method_descriptor). This
# distinguishes accept from most other socket.socket methods (send, recv, listen,
# bind, connect, setsockopt, getsockopt — all method_descriptor). accept is defined
# in Lib/socket.py because it needs to wrap the C _socket.socket.accept to return
# a socket.socket instance (the Python wrapper class) rather than a bare _socket.socket
# instance. This wrapping is necessary so that the returned socket inherits the
# Python-level socket methods (like makefile(), timeout management, etc.).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra113.accept_type_function_eq:
  description: "socket.socket.accept.__class__.__name__.__eq__('function') == True — accept is a Python function (Lib/socket.py), not a C method_descriptor; wraps C _socket.socket.accept to return socket.socket instance (so the returned socket gets Python-level methods like makefile()); most other socket.socket methods (send/recv/listen/bind/connect) are method_descriptor; first standalone for accept type under sockconn113"
  category: type_identity
  kind: python_call_eq
  function: "socket.accept.__class__.__name__.__eq__"
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.setsockopt.__qualname__.__eq__('socket.setsockopt') — standalone
#
# socket.socket.setsockopt.__qualname__ is 'socket.setsockopt' (17 chars: 'socket.'=7
# + 'setsockopt'=10). setsockopt is tied with getsockopt for the longest qualname
# in this spec. setsockopt sets socket-level options (e.g., SO_REUSEADDR, SO_KEEPALIVE)
# for connection tuning and configuration. The 17-char qualname is longer than
# bind (11), recv (11), listen (13), and connect (14, from socket_extra112).
# No prior socket spec anchors setsockopt qualname equality as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra113.setsockopt_qualname_eq:
  description: "socket.socket.setsockopt.__qualname__.__eq__('socket.setsockopt') == True — qualname is 'socket.setsockopt' (17 chars; 'socket.'=7 + 'setsockopt'=10); longest qualname in this spec (tied with getsockopt at 17); longer than bind=11, recv=11, listen=13, connect=14; sets SO_* socket options; no prior spec anchors setsockopt qualname equality as standalone; first standalone under sockconn113"
  category: method_identity
  kind: python_call_eq
  function: "socket.setsockopt.__qualname__.__eq__"
  args: ["socket.setsockopt"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.listen.__qualname__.__eq__('socket.listen') — standalone
#
# socket.socket.listen.__qualname__ is 'socket.listen' (13 chars: 'socket.'=7 +
# 'listen'=6). listen is a C-level method_descriptor that puts the socket into
# passive listening mode, specifying the maximum number of queued connections
# (the backlog). Its qualname length (13) is shared with socket.socket.accept
# (also 13 chars) and socket.socket.close (12 chars, from socket_extra112) is
# one less. No prior socket spec anchors socket.socket.listen qualname equality
# as a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra113.listen_qualname_eq:
  description: "socket.socket.listen.__qualname__.__eq__('socket.listen') == True — qualname is 'socket.listen' (13 chars; 'socket.'=7 + 'listen'=6); same length as accept (13); one more than close (12) from extra112; listen enables passive server mode with connection backlog; C-level method_descriptor; first standalone for listen qualname equality under sockconn113"
  category: method_identity
  kind: python_call_eq
  function: "socket.listen.__qualname__.__eq__"
  args: ["socket.listen"]
  expected: true
