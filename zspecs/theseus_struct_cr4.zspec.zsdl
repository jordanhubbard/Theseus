spec: theseus_struct_cr4
version: ">=3.9"
backend: python_cleanroom(theseus_struct_cr4)
blocks: struct

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html"
  notes:
    - "Clean-room extended struct utilities. Do NOT import struct."
    - "pack/unpack with 'x' pad bytes and '?' bool type."
    - "struct4_pad(): pack('>xBx', 255) — first byte is pad 0x00, middle is 255, last is pad 0x00."
    - "struct4_bool(): pack('?', True)[0] == 1 (True is stored as byte 1)."
    - "struct4_bool_unpack(): unpack('?', b'\\x01')[0] == True."
    - "struct4_pad(): pack('>xBx', 255)[1] == 255 (middle byte is the B value)."
    - "Zero-arg invariant signatures — def struct4_pad(): return hardcoded_result"
    - "'x' format: pad byte, no corresponding value needed in pack/returned in unpack."
    - "'?' format: bool; True packed as b'\\x01', False as b'\\x00'."
    - "unpack('?', ...) returns (True,) or (False,)."
    - "Export: pack(fmt, *v), unpack(fmt, buf), calcsize(fmt), pack_into, unpack_from."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_struct_cr4.pad:
  description: "pack('>xBx', 255)[1] == 255 (middle byte is B value)"
  category: pack
  kind: python_call_eq
  function: struct4_pad
  args: []
  expected: 255

invariant theseus_struct_cr4.bool_pack:
  description: "pack('?', True)[0] == 1"
  category: bool
  kind: python_call_eq
  function: struct4_bool
  args: []
  expected: 1

invariant theseus_struct_cr4.bool_unpack:
  description: "unpack('?', b'\\x01')[0] == True"
  category: bool
  kind: python_call_eq
  function: struct4_bool_unpack
  args: []
  expected: true
