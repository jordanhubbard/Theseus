spec: struct_extra2026
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
    - "CPython source: Modules/_struct.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__, __floordiv__, __mod__, __pow__, __divmod__ dict-presence checks."
    - "struct.Struct is a binary packing type, not an arithmetic type; it defines none of these division, modulo, or exponentiation protocols."
    - "struct.error is an Exception subclass; it defines no arithmetic protocols in its own __dict__."
    - "All division/modulo/exponentiation dunder methods are absent from both struct.Struct.__dict__ and struct.error.__dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2026.struct_truediv_protocol:
  description: "struct.Struct __truediv__/__rtruediv__/__itruediv__ dict-presence checks (Struct is not arithmetic)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2026

  columns: [id, function, args, expected]
  rows:
    - ["st2026001", "struct.Struct.__dict__.__contains__", ["__truediv__"], false]
    - ["st2026002", "struct.Struct.__dict__.__contains__", ["__rtruediv__"], false]
    - ["st2026003", "struct.Struct.__dict__.__contains__", ["__itruediv__"], false]

