spec: glom_rust
version: ">=3.9"
backend: rust_module(glom_rust)

docs: https://glom.readthedocs.io/

provenance:
  derived_from:
    - "https://glom.readthedocs.io/ — glom library documentation"
  not_derived_from:
    - "glom source: glom/core.py"
  notes:
    - "glom is a Python data access and manipulation tool."
    - "glom.glom(target, spec) — access nested data using spec."
    - "glom({'a': {'b': 1}}, 'a.b') == 1."
    - "glom({'x': [1,2,3]}, ('x', ['x'])) — list comprehension."
    - "glom.glom([1,2,3], ['x']) applies spec to each item."
    - "Expose glom_path(d, path) -> any: glom.glom(d, path)."
    - "Expose glom_default(d, path, default) -> any: glom.glom(d, glom.Coalesce(path, default=default))."
    - "glom({'a': {'b': 42}}, 'a.b') == 42."
    - "glom({'x': 10}, 'x') == 10."
    - "glom({'a': 1}, glom.Coalesce('missing', default='fallback')) == 'fallback'."
    - "All test vectors verified against glom 23.5.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# glom_path — nested path access
table glom_rust.path.access:
  kind: python_call_eq
  category: path
  id_prefix: gl_path
  function: glom_path

  columns: [id, args, expected]
  rows:
    - [simple,    [{"x": 10},             "x"],     10]
    - [nested,    [{"a": {"b": 42}},      "a.b"],   42]
    - [deep,      [{"a": {"b": {"c": 7}}},"a.b.c"], 7]
    - [str_val,   [{"name": "Alice"},     "name"],  "Alice"]

# glom_default — fallback for missing path
table glom_rust.default.access:
  kind: python_call_eq
  category: default
  id_prefix: gl_def
  function: glom_default

  columns: [id, args, expected]
  rows:
    - [present,  [{"x": 5},  "x",       0], 5]
    - [missing,  [{},        "missing",  0], 0]
    - [str_miss, [{"a": 1},  "b",       "fallback"], "fallback"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:24:24Z
