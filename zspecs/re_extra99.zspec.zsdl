spec: re_extra99
version: ">=3.9"
backend: python_module(re)
extends: re_extra98

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re_extra98.zspec.zsdl."
    - "This spec covers: re function __code__ attrs and re.Pattern/__Match/__error __name__ values."
    - "re.compile.__code__.co_name = 'compile', co_argcount = 2."
    - "re.match, re.fullmatch, re.search, re.sub, re.subn, re.findall, re.finditer all have co_argcount = 3."
    - "re.split co_argcount = 2, re.escape co_argcount = 1, re.purge co_argcount = 0."
    - "All re module functions have __module__ == 're'."
    - "re.Pattern.__name__ = 'Pattern', re.Match.__name__ = 'Match'."
    - "re.error.__name__ = 'PatternError' in Python 3.14 (re.error was renamed to re.PatternError; re.error is an alias)."
    - "re.PatternError.__name__ = 'PatternError'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re function __code__.co_name equality (each function's co_name == its own name)
# compile, match, search, sub, subn -> co_name == function name
# ---------------------------------------------------------------------------

table re_extra99.function_co_name_equality:
  description: "re module function __code__.co_name equals the function's own name for compile, match, fullmatch, search, sub, subn"
  kind: python_call_eq
  category: code_attrs
  id_prefix: recompilecode99

  columns: [id, function, args, expected]
  rows:
    - [compile_coname,   compile.__code__.co_name.__eq__,   ["compile"],   true]
    - [match_coname,     match.__code__.co_name.__eq__,     ["match"],     true]
    - [fullmatch_coname, fullmatch.__code__.co_name.__eq__, ["fullmatch"], true]
    - [search_coname,    search.__code__.co_name.__eq__,    ["search"],    true]
    - [sub_coname,       sub.__code__.co_name.__eq__,       ["sub"],       true]
    - [subn_coname,      subn.__code__.co_name.__eq__,      ["subn"],      true]
    - [compile_not_re,   compile.__code__.co_name.__eq__,   ["re"],        false]

# ---------------------------------------------------------------------------
# re function __code__.co_argcount values
# compile=2, match=search=sub=subn=findall=finditer=fullmatch=3,
# split=2, escape=1, purge=0
# ---------------------------------------------------------------------------

table re_extra99.function_co_argcount_values:
  description: "re module function __code__.co_argcount values: compile=2, match/fullmatch/search/sub/subn/findall/finditer=3, split=2, escape=1, purge=0"
  kind: python_call_eq
  category: code_attrs
  id_prefix: recompilecode99

  columns: [id, function, args, expected]
  rows:
    - [compile_argc,   compile.__code__.co_argcount.__eq__,   [2], true]
    - [match_argc,     match.__code__.co_argcount.__eq__,     [3], true]
    - [fullmatch_argc, fullmatch.__code__.co_argcount.__eq__, [3], true]
    - [search_argc,    search.__code__.co_argcount.__eq__,    [3], true]
    - [sub_argc,       sub.__code__.co_argcount.__eq__,       [3], true]
    - [subn_argc,      subn.__code__.co_argcount.__eq__,      [3], true]
    - [findall_argc,   findall.__code__.co_argcount.__eq__,   [3], true]
    - [finditer_argc,  finditer.__code__.co_argcount.__eq__,  [3], true]
    - [split_argc,     split.__code__.co_argcount.__eq__,     [2], true]
    - [escape_argc,    escape.__code__.co_argcount.__eq__,    [1], true]
    - [purge_argc,     purge.__code__.co_argcount.__eq__,     [0], true]
    - [compile_not_3,  compile.__code__.co_argcount.__eq__,   [3], false]

# ---------------------------------------------------------------------------
# re function __module__ equality (all == 're')
# ---------------------------------------------------------------------------

table re_extra99.function_module_equality:
  description: "re module functions all have __module__ == 're': compile, match, fullmatch, search, sub, subn, split, findall, finditer, escape, purge"
  kind: python_call_eq
  category: code_attrs
  id_prefix: recompilecode99

  columns: [id, function, args, expected]
  rows:
    - [compile_mod,   compile.__module__.__eq__,   ["re"], true]
    - [match_mod,     match.__module__.__eq__,     ["re"], true]
    - [fullmatch_mod, fullmatch.__module__.__eq__, ["re"], true]
    - [search_mod,    search.__module__.__eq__,    ["re"], true]
    - [sub_mod,       sub.__module__.__eq__,       ["re"], true]
    - [subn_mod,      subn.__module__.__eq__,      ["re"], true]
    - [split_mod,     split.__module__.__eq__,     ["re"], true]
    - [findall_mod,   findall.__module__.__eq__,   ["re"], true]
    - [finditer_mod,  finditer.__module__.__eq__,  ["re"], true]
    - [escape_mod,    escape.__module__.__eq__,    ["re"], true]
    - [purge_mod,     purge.__module__.__eq__,     ["re"], true]
    - [compile_not_sre, compile.__module__.__eq__, ["sre_compile"], false]

# ---------------------------------------------------------------------------
# re.Pattern.__name__, re.Match.__name__, re.error.__name__ (PatternError in 3.14)
# ---------------------------------------------------------------------------

table re_extra99.type_name_attrs:
  description: "re.Pattern.__name__ == 'Pattern', re.Match.__name__ == 'Match', re.error.__name__ == 'PatternError' (re.error is an alias for re.PatternError in Python 3.14)"
  kind: python_call_eq
  category: type_names
  id_prefix: recompilecode99

  columns: [id, function, args, expected]
  rows:
    - [pattern_name,      Pattern.__name__.__eq__,      ["Pattern"],      true]
    - [match_name,        Match.__name__.__eq__,        ["Match"],        true]
    - [error_name,        error.__name__.__eq__,        ["PatternError"], true]
    - [patternerr_name,   PatternError.__name__.__eq__, ["PatternError"], true]
    - [pattern_not_re,    Pattern.__name__.__eq__,      ["re.Pattern"],   false]
    - [error_not_old,     error.__name__.__eq__,        ["error"],        false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra99.compile.co_name_is_compile:
  description: "re.compile.__code__.co_name == 'compile' (the code object's co_name is set to the function's source-level name at definition time)"
  category: code_attrs
  kind: python_call_eq
  function: compile.__code__.co_name.__eq__
  args: ["compile"]
  expected: true

invariant re_extra99.compile.co_argcount_is_2:
  description: "re.compile.__code__.co_argcount == 2 (re.compile takes pattern and flags=0 as its two positional parameters)"
  category: code_attrs
  kind: python_call_eq
  function: compile.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant re_extra99.match.co_argcount_is_3:
  description: "re.match.__code__.co_argcount == 3 (re.match takes pattern, string, and flags=0 as its three positional parameters)"
  category: code_attrs
  kind: python_call_eq
  function: match.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant re_extra99.Pattern.name_is_Pattern:
  description: "re.Pattern.__name__ == 'Pattern' (the compiled regex type's __name__ is the bare type name, not the module-qualified name)"
  category: type_names
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra99.error.name_is_PatternError:
  description: "re.error.__name__ == 'PatternError' (in Python 3.14, re.error was renamed to re.PatternError; re.error remains as a backward-compatible alias but __name__ reflects the canonical new name)"
  category: type_names
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["PatternError"]
  expected: true
