spec: multiprocessing_extra229
version: ">=3.4"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool — Pool documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec covers multiprocessing.pool.Pool class identity and method contracts."
    - "multiprocessing.Pool at the top-level namespace is a bound method (factory); the real class is accessible as pool.Pool after the pool submodule is pre-imported."
    - "pool.Pool.__name__ == 'Pool' — 4 characters."
    - "pool.Pool.__module__ == 'multiprocessing.pool' — defined in the pool submodule (20 chars)."
    - "pool.Pool.__bases__[0].__name__ == 'object' — Pool directly inherits from object."
    - "pool.Pool.__qualname__ == 'Pool' — simple top-level class name."
    - "pool.Pool.map.__name__ == 'map'; __qualname__ == 'Pool.map' (8 chars)."
    - "pool.Pool.apply.__name__ == 'apply'; __qualname__ == 'Pool.apply' (10 chars)."
    - "pool.Pool.close.__name__ == 'close'; __qualname__ == 'Pool.close' (10 chars)."
    - "pool.Pool.terminate.__name__ == 'terminate'; __qualname__ == 'Pool.terminate' (14 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.pool.Pool class identity contracts
#
# Verifies __name__, __module__, __qualname__ to confirm the class is defined
# in multiprocessing.pool and carries expected identity attributes.
# Pool is accessed via pool.Pool (submodule preloaded by the harness).
# ---------------------------------------------------------------------------

table multiprocessing_extra229.pool_class_identity:
  description: "multiprocessing.pool.Pool class identity: name, module, qualname; new to extra229"
  kind: python_call_eq
  category: class_identity
  id_prefix: mppool229

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name_eq,
       pool.Pool.__name__.__eq__,
       ["Pool"],
       true,
       "multiprocessing.pool.Pool.__name__.__eq__('Pool') == True — class carries unqualified name 'Pool'; new to extra229"]
    - [pool_module_eq,
       pool.Pool.__module__.__eq__,
       ["multiprocessing.pool"],
       true,
       "multiprocessing.pool.Pool.__module__.__eq__('multiprocessing.pool') == True — Pool defined in pool submodule; new to extra229"]
    - [pool_qualname_eq,
       pool.Pool.__qualname__.__eq__,
       ["Pool"],
       true,
       "multiprocessing.pool.Pool.__qualname__.__eq__('Pool') == True — top-level class; qualname equals __name__; new to extra229"]
    - [pool_name_len_4,
       pool.Pool.__name__.__len__,
       [],
       4,
       "multiprocessing.pool.Pool.__name__.__len__() == 4 — 'Pool' has exactly 4 characters; new to extra229"]
    - [pool_module_len_20,
       pool.Pool.__module__.__len__,
       [],
       20,
       "multiprocessing.pool.Pool.__module__.__len__() == 20 — 'multiprocessing.pool' has 20 characters; new to extra229"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.pool.Pool base class contract
#
# Pool.__bases__[0].__name__ == 'object' — Pool directly inherits from object.
# The function path contains '[' so must be double-quoted.
# ---------------------------------------------------------------------------

table multiprocessing_extra229.pool_base_class:
  description: "multiprocessing.pool.Pool base class identity; new to extra229"
  kind: python_call_eq
  category: class_identity
  id_prefix: mppool229b

  columns: [id, function, args, expected, description]
  rows:
    - [pool_base_name_eq,
       "pool.Pool.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "multiprocessing.pool.Pool.__bases__[0].__name__.__eq__('object') == True — Pool directly subclasses object; new to extra229"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.pool.Pool method __name__ contracts
#
# map, apply, close, terminate each carry their simple __name__.
# ---------------------------------------------------------------------------

table multiprocessing_extra229.pool_method_names:
  description: "multiprocessing.pool.Pool method __name__ contracts; new to extra229"
  kind: python_call_eq
  category: method_names
  id_prefix: mppoolm229

  columns: [id, function, args, expected, description]
  rows:
    - [map_name_eq,
       pool.Pool.map.__name__.__eq__,
       ["map"],
       true,
       "multiprocessing.pool.Pool.map.__name__.__eq__('map') == True — method carries its simple name; new to extra229"]
    - [apply_name_eq,
       pool.Pool.apply.__name__.__eq__,
       ["apply"],
       true,
       "multiprocessing.pool.Pool.apply.__name__.__eq__('apply') == True — method carries its simple name; new to extra229"]
    - [close_name_eq,
       pool.Pool.close.__name__.__eq__,
       ["close"],
       true,
       "multiprocessing.pool.Pool.close.__name__.__eq__('close') == True — method carries its simple name; new to extra229"]
    - [terminate_name_eq,
       pool.Pool.terminate.__name__.__eq__,
       ["terminate"],
       true,
       "multiprocessing.pool.Pool.terminate.__name__.__eq__('terminate') == True — method carries its simple name; new to extra229"]

# ---------------------------------------------------------------------------
# Table 4: multiprocessing.pool.Pool method __qualname__ contracts
#
# map, apply, close, terminate each carry qualname 'Pool.<method>'.
# ---------------------------------------------------------------------------

table multiprocessing_extra229.pool_method_qualnames:
  description: "multiprocessing.pool.Pool method __qualname__ contracts; new to extra229"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mppoolm229

  columns: [id, function, args, expected, description]
  rows:
    - [map_qualname_eq,
       pool.Pool.map.__qualname__.__eq__,
       ["Pool.map"],
       true,
       "multiprocessing.pool.Pool.map.__qualname__ == 'Pool.map' (8 chars); new to extra229"]
    - [apply_qualname_eq,
       pool.Pool.apply.__qualname__.__eq__,
       ["Pool.apply"],
       true,
       "multiprocessing.pool.Pool.apply.__qualname__ == 'Pool.apply' (10 chars); new to extra229"]
    - [close_qualname_eq,
       pool.Pool.close.__qualname__.__eq__,
       ["Pool.close"],
       true,
       "multiprocessing.pool.Pool.close.__qualname__ == 'Pool.close' (10 chars); new to extra229"]
    - [terminate_qualname_eq,
       pool.Pool.terminate.__qualname__.__eq__,
       ["Pool.terminate"],
       true,
       "multiprocessing.pool.Pool.terminate.__qualname__ == 'Pool.terminate' (14 chars); new to extra229"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra229
# ---------------------------------------------------------------------------

invariant multiprocessing_extra229.Pool.name:
  description: "multiprocessing.pool.Pool.__name__ == 'Pool'; new to extra229"
  category: class_identity
  kind: python_call_eq
  function: pool.Pool.__name__.__eq__
  args: ["Pool"]
  expected: true

invariant multiprocessing_extra229.Pool.module:
  description: "multiprocessing.pool.Pool.__module__ == 'multiprocessing.pool'; new to extra229"
  category: class_identity
  kind: python_call_eq
  function: pool.Pool.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

