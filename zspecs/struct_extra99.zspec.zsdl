spec: struct_extra99
version: ">=3.9"
backend: python_module(struct)
extends: struct_extra98

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / Struct.size/__format__ qualname/name lengths and __objclass__.__name__ / Struct.__doc__ length (40) and equality (table + invariants)."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6 (table + invariants)."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() and error.__name__/__len__() (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__() (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance and __module__/__qualname__ (table + invariants)."
    - "struct_extra91.zspec.zsdl — covers struct.calcsize return values / struct.pack/__qualname__ / struct.Struct.__doc__/__class__.__name__ / struct.error/__class__.__name__ (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra98; it does NOT duplicate invariants present in those files."
    - "Wave 266 theme: struct module-level function __doc__ lengths / Struct.size and Struct.format __doc__ string contents / struct module __doc__ length."
    - "struct.__doc__.__len__() == 1278. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__doc__.__len__() == 176. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__doc__.__len__() == 173. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__doc__.__len__() == 66. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__doc__.__len__() == 274. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__doc__.__len__() == 188. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__doc__.__len__() == 239. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__doc__.__eq__('struct size in bytes') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__doc__.__eq__('struct format string') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__doc__.__len__() == 20. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__doc__.__len__() == 20. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.error.__doc__ is None (the struct.error exception has no docstring). This contrasts with the module-level function docstrings which are all non-None str objects."
    - "Note: struct.__doc__.__len__()==1278 is the C-level module docstring from _struct.c describing the pack/unpack format characters."
    - "Note: calcsize has the shortest docstring (66 chars) among the six module-level functions; pack_into has the longest (274 chars)."
    - "Note: Struct.size.__doc__ and Struct.format.__doc__ are 20-char C-level descriptor docstrings from _struct.c."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack.__doc__.__len__()==176
# struct.unpack.__doc__.__len__()==173
# struct.calcsize.__doc__.__len__()==66
# struct.pack_into.__doc__.__len__()==274
# struct.unpack_from.__doc__.__len__()==188
# struct.iter_unpack.__doc__.__len__()==239
#
# Wave 266 theme: struct module-level function __doc__ lengths.
#
# All six module-level struct functions have C-level docstrings (str objects)
# from _struct.c. calcsize has the shortest (66 chars); pack_into has the
# longest (274 chars). struct_extra92 anchors their __class__.__name__;
# struct_extra95/96 anchor their __qualname__/__name__ lengths and __module__;
# no prior struct spec anchors any module-level function __doc__.__len__()
# under structdoc99. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra99.module_fn_doc_lengths:
  description: "struct.pack/__doc__/__len__()==176 / unpack/__doc__/__len__()==173 / calcsize/__doc__/__len__()==66 / pack_into/__doc__/__len__()==274 / unpack_from/__doc__/__len__()==188 / iter_unpack/__doc__/__len__()==239 — all six module-level functions have C-level docstrings from _struct.c; calcsize shortest (66), pack_into longest (274); extra92 anchors class names; extra95/96 anchor qualname/name lengths; first structdoc99 anchor for function __doc__ lengths"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: structdoc99

  columns: [id, function, args, expected, description]
  rows:
    - [pack_doc_len,        pack.__doc__.__len__,        [], 176, "struct.pack docstring is 176 chars (describes byte packing from format string)"]
    - [unpack_doc_len,      unpack.__doc__.__len__,      [], 173, "struct.unpack docstring is 173 chars (describes tuple unpacking from bytes)"]
    - [calcsize_doc_len,    calcsize.__doc__.__len__,    [], 66,  "struct.calcsize docstring is 66 chars (shortest; returns packed size of format)"]
    - [pack_into_doc_len,   pack_into.__doc__.__len__,   [], 274, "struct.pack_into docstring is 274 chars (longest; packs into buffer at offset)"]
    - [unpack_from_doc_len, unpack_from.__doc__.__len__,  [], 188, "struct.unpack_from docstring is 188 chars (unpacks from buffer at offset)"]
    - [iter_unpack_doc_len, iter_unpack.__doc__.__len__,  [], 239, "struct.iter_unpack docstring is 239 chars (returns iterator over repeated packing)"]

# ---------------------------------------------------------------------------
# struct.Struct.size.__doc__.__eq__('struct size in bytes')
# struct.Struct.format.__doc__.__eq__('struct format string')
# struct.Struct.size.__doc__.__len__()==20
# struct.Struct.format.__doc__.__len__()==20
#
# Wave 266 theme: Struct.size and Struct.format descriptor __doc__ strings.
#
# struct.Struct.size and struct.Struct.format are getset_descriptor objects
# (anchored in struct_extra98). Each has a short C-level __doc__ string:
# Struct.size.__doc__ is 'struct size in bytes' (20 chars) and
# Struct.format.__doc__ is 'struct format string' (20 chars). Both are exactly
# 20 chars. struct_extra98 anchors their class names, qualnames, and __objclass__;
# no prior struct spec anchors their __doc__ equality or __doc__.__len__() under
# structdoc99. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra99.Struct_descriptor_doc_strings:
  description: "struct.Struct.size/__doc__.__eq__('struct size in bytes')==True / Struct.format/__doc__.__eq__('struct format string')==True / Struct.size/__doc__/__len__()==20 / Struct.format/__doc__/__len__()==20 — both getset_descriptor __doc__ strings are exactly 20 chars; 'struct size in bytes' for size; 'struct format string' for format; extra98 anchors descriptor class names and qualnames; first structdoc99 anchor for descriptor __doc__ equality and length"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: structdoc99

  columns: [id, function, args, expected, description]
  rows:
    - [size_doc_eq,      "Struct.size.__doc__.__eq__",    ["struct size in bytes"],   true, "Struct.size.__doc__ is 'struct size in bytes' (C-level descriptor docstring)"]
    - [format_doc_eq,    "Struct.format.__doc__.__eq__",  ["struct format string"],   true, "Struct.format.__doc__ is 'struct format string' (C-level descriptor docstring)"]
    - [size_doc_len,     Struct.size.__doc__.__len__,     [], 20,                         "'struct size in bytes' is 20 chars"]
    - [format_doc_len,   Struct.format.__doc__.__len__,   [], 20,                         "'struct format string' is 20 chars"]

# ---------------------------------------------------------------------------
# struct.__doc__.__len__()==1278
# struct.__doc__.__class__.__name__.__eq__('str')
#
# Wave 266 theme: struct module __doc__ length.
#
# struct.__doc__.__len__() is 1278. The module docstring is a C-level str from
# _struct.c that describes the purpose of the module and the format character
# reference (b, B, h, H, i, I, l, L, q, Q, f, d, s, p, etc.). It is much
# longer than the individual function docstrings. No prior struct spec anchors
# struct.__doc__.__len__()==1278 under structdoc99.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra99.module_doc_length:
  description: "struct.__doc__/__len__()==1278 / struct.__doc__.__class__.__name__.__eq__('str')==True — the struct module docstring is 1278 chars (C-level from _struct.c); describes module purpose and format character reference; no prior struct spec anchors module __doc__ length; first structdoc99 anchor"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: structdoc99

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_len,    __doc__.__len__,                [],      1278, "struct module docstring is 1278 chars (format character reference from _struct.c)"]
    - [module_doc_class,  "__doc__.__class__.__name__.__eq__", ["str"], true, "struct module docstring is a str object (not None)"]

# ---------------------------------------------------------------------------
# struct.pack.__doc__.__len__()==176 — standalone
#
# struct.pack.__doc__.__len__() is 176. The pack function docstring is a C-level
# str from _struct.c describing how to pack values into bytes according to a
# format string. Among the six module-level struct functions, pack has the second-
# longest docstring after pack_into (274). struct_extra96 anchors pack.__name__.__len__;
# struct_extra95 anchors pack.__qualname__.__len__(); no prior struct spec anchors
# pack.__doc__.__len__()==176 as a standalone under structdoc99.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra99.pack_doc_len_176:
  description: "struct.pack.__doc__.__len__() == 176 — pack docstring is 176 chars; C-level from _struct.c describing byte packing from format string; second-longest among module-level functions (after pack_into at 274); extra96 anchors pack.__name__.__len__; extra95 anchors __qualname__.__len__; first standalone for pack.__doc__.__len__() under structdoc99"
  category: doc_lengths
  kind: python_call_eq
  function: pack.__doc__.__len__
  args: []
  expected: 176

# ---------------------------------------------------------------------------
# struct.calcsize.__doc__.__len__()==66 — standalone
#
# struct.calcsize.__doc__.__len__() is 66. The calcsize function docstring is
# the shortest among the six module-level struct functions (66 chars). calcsize
# returns the number of bytes needed to pack the given format string, without
# actually packing any data. Its brief purpose makes for a concise docstring.
# struct_extra96 anchors calcsize.__name__.__len__; struct_extra95 anchors
# calcsize.__qualname__.__len__(); no prior struct spec anchors
# calcsize.__doc__.__len__()==66 as a standalone under structdoc99.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra99.calcsize_doc_len_66:
  description: "struct.calcsize.__doc__.__len__() == 66 — calcsize docstring is 66 chars; shortest among six module-level struct functions; calcsize returns the byte size of a packed format without packing data; extra96 anchors __name__.__len__; extra95 anchors __qualname__.__len__; first standalone for calcsize.__doc__.__len__() under structdoc99"
  category: doc_lengths
  kind: python_call_eq
  function: calcsize.__doc__.__len__
  args: []
  expected: 66

# ---------------------------------------------------------------------------
# struct.Struct.size.__doc__.__eq__('struct size in bytes') — standalone
#
# struct.Struct.size.__doc__ is 'struct size in bytes'. This is the C-level
# descriptor docstring set in _struct.c for the 'size' PyGetSetDef entry. It
# is a short, precise description of the attribute's meaning: the total byte
# size of the struct format. struct_extra98 anchors Struct.size.__class__.__name__
# =='getset_descriptor' and Struct.size.__qualname__.__eq__('Struct.size'); no
# prior struct spec anchors Struct.size.__doc__.__eq__ as a standalone under
# structdoc99. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra99.Struct_size_doc_eq:
  description: "struct.Struct.size.__doc__.__eq__('struct size in bytes') == True — Struct.size.__doc__ is 'struct size in bytes' (20 chars); C-level descriptor docstring from _struct.c for the size PyGetSetDef entry; extra98 anchors Struct.size class name and qualname equality; first standalone for Struct.size.__doc__ equality under structdoc99"
  category: doc_lengths
  kind: python_call_eq
  function: "Struct.size.__doc__.__eq__"
  args: ["struct size in bytes"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.format.__doc__.__eq__('struct format string') — standalone
#
# struct.Struct.format.__doc__ is 'struct format string'. This is the C-level
# descriptor docstring set in _struct.c for the 'format' PyGetSetDef entry.
# Like Struct.size.__doc__, it is exactly 20 chars. The format attribute provides
# read-only access to the format string that was used to create the Struct
# instance. struct_extra98 anchors Struct.format.__class__.__name__=='getset_descriptor'
# and Struct.format.__qualname__.__eq__('Struct.format'); no prior struct spec
# anchors Struct.format.__doc__.__eq__ as a standalone under structdoc99.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra99.Struct_format_doc_eq:
  description: "struct.Struct.format.__doc__.__eq__('struct format string') == True — Struct.format.__doc__ is 'struct format string' (20 chars); C-level descriptor docstring from _struct.c for the format PyGetSetDef entry; same length as Struct.size.__doc__ (both 20 chars); extra98 anchors format class name and qualname equality; first standalone for Struct.format.__doc__ equality under structdoc99"
  category: doc_lengths
  kind: python_call_eq
  function: "Struct.format.__doc__.__eq__"
  args: ["struct format string"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__doc__.__len__()==1278 — standalone
#
# struct.__doc__.__len__() is 1278. The struct module docstring is a C-level
# str from _struct.c that provides a comprehensive description of the module's
# purpose (converting between Python values and C structs) and lists all
# supported format characters. At 1278 chars it is substantially longer than
# any individual function or method docstring in the module. No prior struct
# spec anchors struct.__doc__.__len__()==1278 as a standalone under structdoc99.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra99.module_doc_len_1278:
  description: "struct.__doc__.__len__() == 1278 — struct module docstring is 1278 chars; C-level from _struct.c; covers module purpose and format character reference (b, h, i, l, q, f, d, s, p, etc.); substantially longer than any individual function docstring; no prior struct spec anchors __doc__.__len__() as a standalone; first standalone under structdoc99"
  category: doc_lengths
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 1278
