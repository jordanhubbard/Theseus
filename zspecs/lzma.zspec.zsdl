spec: lzma
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html
rfcs:
  - "XZ file format specification — https://tukaani.org/xz/xz-file-format.txt"

provenance:
  derived_from:
    - "Python 3 lzma documentation — https://docs.python.org/3/library/lzma.html"
    - "XZ file format specification — https://tukaani.org/xz/xz-file-format.txt"
    - "Test vectors verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_lzmamodule.c"
    - "CPython source: Lib/lzma.py"
    - "liblzma source: src/liblzma/"
  notes:
    - "lzma.compress() and lzma.decompress() operate on bytes objects."
    - "FORMAT_AUTO=0, FORMAT_XZ=1, FORMAT_ALONE=2, FORMAT_RAW=3 — integer constants."
    - "CHECK_NONE=0, CHECK_CRC32=1, CHECK_CRC64=4, CHECK_SHA256=10 — integer constants verified with Python 3.14."
    - "LZMAFile, LZMACompressor, LZMADecompressor are classes; compress, decompress, open are functions."
    - "LZMAError.__bases__[0].__name__ == 'Exception' — LZMAError inherits directly from Exception."
    - "compress(b'hello') returns bytes; decompress(compress(b'hello')) == b'hello' (roundtrip)."
    - "All constant values verified with Python 3.14 on macOS Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# class_names — LZMAFile, LZMACompressor, LZMADecompressor, LZMAError
# ---------------------------------------------------------------------------

table lzma.class_names:
  kind: python_call_eq
  category: classes
  id_prefix: class_name

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,          LZMAFile.__name__.__eq__,          ["LZMAFile"],          true]
    - [LZMACompressor,    LZMACompressor.__name__.__eq__,    ["LZMACompressor"],    true]
    - [LZMADecompressor,  LZMADecompressor.__name__.__eq__,  ["LZMADecompressor"],  true]
    - [LZMAError,         LZMAError.__name__.__eq__,         ["LZMAError"],         true]

# ---------------------------------------------------------------------------
# function_names — compress, decompress, open
# ---------------------------------------------------------------------------

table lzma.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: function_name

  columns: [id, function, args, expected]
  rows:
    - [compress,   compress.__name__.__eq__,   ["compress"],   true]
    - [decompress, decompress.__name__.__eq__, ["decompress"], true]
    - [open,       open.__name__.__eq__,       ["open"],       true]

# ---------------------------------------------------------------------------
# module — LZMAFile.__module__ == 'lzma'
# ---------------------------------------------------------------------------

invariant lzma.module.LZMAFile:
  description: "LZMAFile.__module__ == 'lzma'"
  category: module
  kind: python_call_eq
  function: LZMAFile.__module__.__eq__
  args: ["lzma"]
  expected: true

# ---------------------------------------------------------------------------
# constants — FORMAT_* and CHECK_* integer values
# ---------------------------------------------------------------------------

table lzma.constants.format:
  kind: python_call_eq
  category: constants
  id_prefix: format

  columns: [id, function, args, expected]
  rows:
    - [FORMAT_AUTO,  FORMAT_AUTO.__eq__,  [0], true]
    - [FORMAT_XZ,    FORMAT_XZ.__eq__,    [1], true]
    - [FORMAT_ALONE, FORMAT_ALONE.__eq__, [2], true]
    - [FORMAT_RAW,   FORMAT_RAW.__eq__,   [3], true]

table lzma.constants.check:
  kind: python_call_eq
  category: constants
  id_prefix: check

  columns: [id, function, args, expected]
  rows:
    - [CHECK_NONE,   CHECK_NONE.__eq__,   [0],  true]
    - [CHECK_CRC32,  CHECK_CRC32.__eq__,  [1],  true]
    - [CHECK_CRC64,  CHECK_CRC64.__eq__,  [4],  true]
    - [CHECK_SHA256, CHECK_SHA256.__eq__, [10], true]

# ---------------------------------------------------------------------------
# hierarchy — LZMAError inherits from Exception
# ---------------------------------------------------------------------------

invariant lzma.hierarchy.LZMAError_base:
  description: "LZMAError.__bases__[0].__name__ == 'Exception' — LZMAError inherits directly from Exception"
  category: hierarchy
  kind: python_call_eq
  function: LZMAError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# compress — returns bytes
# ---------------------------------------------------------------------------

invariant lzma.compress.returns_bytes:
  description: "compress(b'hello').__class__.__name__ == 'bytes' — compress() always returns a bytes object"
  category: compress
  kind: python_call_eq
  function: compress
  args: [{type: bytes_ascii, value: "hello"}]
  method: __class__
  method_chain: __name__
  expected: "bytes"

invariant lzma.check.none_supported:
  description: "is_check_supported(CHECK_NONE) == True — CHECK_NONE (0) is always supported"
  category: constants
  kind: python_call_eq
  function: is_check_supported
  args: [0]
  expected: true

invariant lzma.check.crc32_supported:
  description: "is_check_supported(CHECK_CRC32) == True — CRC32 check is always available"
  category: constants
  kind: python_call_eq
  function: is_check_supported
  args: [1]
  expected: true
