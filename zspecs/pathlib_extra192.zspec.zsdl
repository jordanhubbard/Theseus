  args: ["parts"]
  expected: true

invariant pathlib_extra192.drive_fget_name_eq:
  description: "pathlib.PurePath.drive.fget.__name__ == 'drive' — getter for the drive letter/UNC share property; confirmed Python 3.14.3 macOS"
  category: identity
