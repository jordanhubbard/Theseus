# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra192.purepath_name_eq:
  description: "pathlib.PurePath.__name__ == 'PurePath' — the class is named PurePath; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra192.purepath_name_len_8:
  description: "pathlib.PurePath.__name__.__len__() == 8 — 'PurePath' has 8 characters: P(1)u(2)r(3)e(4)P(5)a(6)t(7)h(8); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__name__.__len__
  args: []
  expected: 8

invariant pathlib_extra192.purepath_module_eq:
  description: "pathlib.PurePath.__module__ == 'pathlib' — PurePath is defined in the pathlib module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra192.path_mro_len_3:
  description: "pathlib.Path.__mro__ len == 3 — Path, PurePath, object; no PurePosixPath intermediate in Python 3.14.3 macOS; confirmed Python 3.14.3 macOS"
