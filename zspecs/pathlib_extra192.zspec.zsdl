spec: pathlib_extra192
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "pathlib.PurePath.__name__ == 'PurePath' (len=8)."
    - "pathlib.PurePath.__module__ == 'pathlib'."
    - "pathlib.Path.__mro__ len == 3: Path, PurePath, object (no PurePosixPath intermediate on Python 3.14.3 macOS)."
    - "pathlib.PurePath.__mro__ len == 2: PurePath, object."
    - "pathlib.PurePath.parts.fget.__name__ == 'parts' (len=5)."
    - "pathlib.PurePath.drive.fget.__name__ == 'drive' (len=5)."
    - "pathlib.PurePath.root.fget.__name__ == 'root' (len=4)."
    - "pathlib.PurePath.anchor.fget.__name__ == 'anchor' (len=6)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib.PurePath class identity — __name__ and __module__
# PurePath.__name__ == 'PurePath' (len=8), __module__ == 'pathlib'
# ---------------------------------------------------------------------------

table pathlib_extra192.purepath_identity:
  description: "pathlib.PurePath class identity: __name__ == 'PurePath' (len=8) and __module__ == 'pathlib'"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpure192

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,      pathlib.PurePath.__name__.__eq__,    ["PurePath"], true, "pathlib.PurePath.__name__ == 'PurePath' — class name is 'PurePath'; confirmed Python 3.14.3 macOS"]
    - [name_len,     pathlib.PurePath.__name__.__len__,   [],           8,    "pathlib.PurePath.__name__.__len__() == 8 — P(1)u(2)r(3)e(4)P(5)a(6)t(7)h(8); confirmed Python 3.14.3 macOS"]
    - [module_eq,    pathlib.PurePath.__module__.__eq__,  ["pathlib"],  true, "pathlib.PurePath.__module__ == 'pathlib' — defined in the pathlib module; confirmed Python 3.14.3 macOS"]
    - [module_len,   pathlib.PurePath.__module__.__len__, [],           7,    "pathlib.PurePath.__module__.__len__() == 7 — p(1)a(2)t(3)h(4)l(5)i(6)b(7); confirmed Python 3.14.3 macOS"]
    - [name_len_eq,  pathlib.PurePath.__name__.__len__.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "pathlib.PurePath.__name__.__len__ is a builtin method; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib MRO lengths — Path (3) and PurePath (2)
# Path.__mro__ len == 3: Path, PurePath, object
# PurePath.__mro__ len == 2: PurePath, object
# ---------------------------------------------------------------------------

table pathlib_extra192.mro_lengths:
  description: "pathlib MRO lengths: Path.__mro__ len == 3 (Path, PurePath, object); PurePath.__mro__ len == 2 (PurePath, object)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpure192

  columns: [id, function, args, expected, description]
  rows:
    - [path_mro_len,      "pathlib.Path.__mro__.__len__",     [], 3, "pathlib.Path.__mro__ len == 3: Path, PurePath, object — no PurePosixPath intermediate in Python 3.14.3 macOS MRO"]
    - [purepath_mro_len,  "pathlib.PurePath.__mro__.__len__", [], 2, "pathlib.PurePath.__mro__ len == 2: PurePath, object; confirmed Python 3.14.3 macOS"]
    - [path_mro_len_eq,   "pathlib.Path.__mro__.__len__.__class__.__name__.__eq__",     ["builtin_function_or_method"], true, "pathlib.Path.__mro__.__len__ is a builtin method; confirmed Python 3.14.3 macOS"]
    - [purepath_mro_eq,   "pathlib.PurePath.__mro__.__len__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "pathlib.PurePath.__mro__.__len__ is a builtin method; confirmed Python 3.14.3 macOS"]
    - [path_gt_purepath,  "pathlib.Path.__mro__.__len__.__eq__",                        [3],                           true, "pathlib.Path.__mro__ len == 3, one more than PurePath; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.PurePath property fget __name__ values
# parts (len=5), drive (len=5), root (len=4), anchor (len=6)
# ---------------------------------------------------------------------------

table pathlib_extra192.purepath_property_names:
  description: "pathlib.PurePath property fget __name__ values: parts(5), drive(5), root(4), anchor(6)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibpure192

  columns: [id, function, args, expected, description]
  rows:
    - [parts_name,   pathlib.PurePath.parts.fget.__name__.__eq__,   ["parts"],  true, "pathlib.PurePath.parts.fget.__name__ == 'parts' — property getter name for path components tuple; confirmed Python 3.14.3 macOS"]
    - [parts_len,    pathlib.PurePath.parts.fget.__name__.__len__,  [],         5,    "pathlib.PurePath.parts.fget.__name__.__len__() == 5 — p(1)a(2)r(3)t(4)s(5); confirmed Python 3.14.3 macOS"]
    - [drive_name,   pathlib.PurePath.drive.fget.__name__.__eq__,   ["drive"],  true, "pathlib.PurePath.drive.fget.__name__ == 'drive' — property getter name for drive letter/UNC share; confirmed Python 3.14.3 macOS"]
    - [drive_len,    pathlib.PurePath.drive.fget.__name__.__len__,  [],         5,    "pathlib.PurePath.drive.fget.__name__.__len__() == 5 — d(1)r(2)i(3)v(4)e(5); confirmed Python 3.14.3 macOS"]
    - [root_name,    pathlib.PurePath.root.fget.__name__.__eq__,    ["root"],   true, "pathlib.PurePath.root.fget.__name__ == 'root' — property getter name for root component; confirmed Python 3.14.3 macOS"]

