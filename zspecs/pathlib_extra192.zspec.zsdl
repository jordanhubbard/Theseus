  args: ["drive"]
  expected: true

invariant pathlib_extra192.root_fget_name_len_4:
  description: "pathlib.PurePath.root.fget.__name__.__len__() == 4 — 'root' has 4 characters: r(1)o(2)o(3)t(4); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.root.fget.__name__.__len__
  args: []
