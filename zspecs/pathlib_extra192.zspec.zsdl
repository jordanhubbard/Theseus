invariant pathlib_extra192.anchor_fget_name_len_6:
  description: "pathlib.PurePath.anchor.fget.__name__.__len__() == 6 — 'anchor' has 6 characters: a(1)n(2)c(3)h(4)o(5)r(6); confirmed Python 3.14.3 macOS"
