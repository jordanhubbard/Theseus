invariant pathlib_extra192.parts_fget_name_eq:
  description: "pathlib.PurePath.parts.fget.__name__ == 'parts' — getter for the path components tuple property; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
