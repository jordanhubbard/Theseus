spec: matplotlib_rust
version: ">=3.9"
backend: rust_module(matplotlib_rust)

docs: https://matplotlib.org/stable/api/

provenance:
  derived_from:
    - "https://matplotlib.org/stable/api/ — Matplotlib API documentation"
  not_derived_from:
    - "matplotlib source: matplotlib/figure.py"
  notes:
    - "Matplotlib is a plotting library for Python."
    - "matplotlib.colors.to_hex('red') == '#ff0000'."
    - "matplotlib.colors.to_hex('blue') == '#0000ff'."
    - "matplotlib.colors.to_hex('white') == '#ffffff'."
    - "matplotlib.colors.to_rgb('red') == (1.0, 0.0, 0.0)."
    - "np.linspace(0, 1, 3).tolist() == [0.0, 0.5, 1.0]."
    - "Expose mpl_color_hex(name) -> str: matplotlib.colors.to_hex(name)."
    - "Expose mpl_linspace_len(start, stop, num) -> int: len(np.linspace(start, stop, num))."
    - "Expose mpl_linspace_first(start, stop, num) -> float: np.linspace(start, stop, num)[0]."
    - "All test vectors verified against matplotlib 3.10.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# mpl_color_hex — named color to hex string
table matplotlib_rust.color.hex:
  kind: python_call_eq
  category: color_hex
  id_prefix: mpl_hex
  function: mpl_color_hex

  columns: [id, args, expected]
  rows:
    - [red,   ["red"],   "#ff0000"]
    - [blue,  ["blue"],  "#0000ff"]
    - [white, ["white"], "#ffffff"]
    - [black, ["black"], "#000000"]

# mpl_linspace_len — length of linspace array
table matplotlib_rust.linspace.length:
  kind: python_call_eq
  category: linspace_len
  id_prefix: mpl_ll
  function: mpl_linspace_len

  columns: [id, args, expected]
  rows:
    - [three, [0, 1, 3], 3]
    - [five,  [0, 4, 5], 5]
    - [one,   [0, 0, 1], 1]

# mpl_linspace_first — first element of linspace
invariant matplotlib_rust.linspace.first_zero:
  description: "linspace(0, 1, 3)[0] == 0.0"
  category: linspace_first
  kind: python_call_eq
  function: mpl_linspace_first
  args: [0, 1, 3]
  expected: 0.0

invariant matplotlib_rust.linspace.first_neg:
  description: "linspace(-1, 1, 3)[0] == -1.0"
  category: linspace_first
  kind: python_call_eq
  function: mpl_linspace_first
  args: [-1, 1, 3]
  expected: -1.0

