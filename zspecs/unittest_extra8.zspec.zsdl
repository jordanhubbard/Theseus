spec: unittest_extra8
version: ">=3.9"
backend: python_module(unittest.mock)

docs: https://docs.python.org/3/library/unittest.mock.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unittest.mock.html — Python unittest.mock documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/unittest/mock.py"
  notes:
    - "This spec covers unittest.mock axes not covered by unittest.zspec.zsdl through unittest_extra7.zspec.zsdl."
    - "Prior specs cover: unittest (not unittest.mock) class/function __name__, __module__, __qualname__, __bases__, and TestCase method names."
    - "NEW in this spec: unittest.mock class __name__ checks for MagicMock/Mock/NonCallableMock/NonCallableMagicMock; class __module__ checks confirming 'unittest.mock'; class __qualname__ checks; __bases__[0].__name__ checks for mock class hierarchy."
    - "MagicMock.__bases__[0].__name__ == 'MagicMixin' — MagicMock inherits from MagicMixin and Mock."
    - "Mock.__bases__[0].__name__ == 'CallableMixin' — Mock inherits from CallableMixin and NonCallableMock."
    - "NonCallableMock.__bases__[0].__name__ == 'Base' — NonCallableMock's first base is the internal Base class."
    - "NonCallableMagicMock.__bases__[0].__name__ == 'MagicMixin'."
    - "patch.__name__ == 'patch', patch.__module__ == 'unittest.mock', patch.__qualname__ == 'patch'."
    - "create_autospec.__name__ == 'create_autospec', __module__ == 'unittest.mock', __qualname__ == 'create_autospec'."
    - "patch.object.__name__ == '_patch_object' — the internal name of the patch.object function."
    - "patch.dict.__name__ == '_patch_dict'."
    - "patch.multiple.__name__ == '_patch_multiple'."
    - "patch.stopall.__name__ == '_patch_stopall'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Mock class __name__ checks
# ---------------------------------------------------------------------------

table unittest_extra8.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [MagicMock,            MagicMock.__name__.__eq__,            ["MagicMock"],            true]
    - [Mock,                 Mock.__name__.__eq__,                 ["Mock"],                 true]
    - [NonCallableMock,      NonCallableMock.__name__.__eq__,      ["NonCallableMock"],      true]
    - [NonCallableMagicMock, NonCallableMagicMock.__name__.__eq__, ["NonCallableMagicMock"], true]
    - [MagicMixin,           MagicMixin.__name__.__eq__,           ["MagicMixin"],           true]

# ---------------------------------------------------------------------------
# Mock class __module__ checks — all defined in unittest.mock
# ---------------------------------------------------------------------------

table unittest_extra8.class_modules:
  kind: python_call_eq
  category: class_modules
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [MagicMock,            MagicMock.__module__.__eq__,            ["unittest.mock"], true]
    - [Mock,                 Mock.__module__.__eq__,                 ["unittest.mock"], true]
    - [NonCallableMock,      NonCallableMock.__module__.__eq__,      ["unittest.mock"], true]
    - [NonCallableMagicMock, NonCallableMagicMock.__module__.__eq__, ["unittest.mock"], true]
    - [MagicMixin,           MagicMixin.__module__.__eq__,           ["unittest.mock"], true]

# ---------------------------------------------------------------------------
# Mock class __qualname__ checks
# ---------------------------------------------------------------------------

table unittest_extra8.class_qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: cqn

  columns: [id, function, args, expected]
  rows:
    - [MagicMock,            MagicMock.__qualname__.__eq__,            ["MagicMock"],            true]
    - [Mock,                 Mock.__qualname__.__eq__,                 ["Mock"],                 true]
    - [NonCallableMock,      NonCallableMock.__qualname__.__eq__,      ["NonCallableMock"],      true]
    - [NonCallableMagicMock, NonCallableMagicMock.__qualname__.__eq__, ["NonCallableMagicMock"], true]

# ---------------------------------------------------------------------------
# Mock class __bases__[0].__name__ — class hierarchy
# ---------------------------------------------------------------------------

table unittest_extra8.class_bases:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: base

  columns: [id, function, args, expected]
  rows:
    - [MagicMock,            MagicMock.__bases__.__getitem__,            [0], "MagicMixin"]
    - [Mock,                 Mock.__bases__.__getitem__,                 [0], "CallableMixin"]
    - [NonCallableMock,      NonCallableMock.__bases__.__getitem__,      [0], "Base"]
    - [NonCallableMagicMock, NonCallableMagicMock.__bases__.__getitem__, [0], "MagicMixin"]

# ---------------------------------------------------------------------------
# patch function __name__, __module__, __qualname__
# ---------------------------------------------------------------------------

invariant unittest_extra8.patch_name:
  description: "unittest.mock.patch.__name__ == 'patch'"
  category: function_names
  kind: python_call_eq
  function: patch.__name__.__eq__
  args: ["patch"]
  expected: true

invariant unittest_extra8.patch_module:
  description: "unittest.mock.patch.__module__ == 'unittest.mock'"
  category: function_modules
  kind: python_call_eq
  function: patch.__module__.__eq__
  args: ["unittest.mock"]
  expected: true

invariant unittest_extra8.patch_qualname:
  description: "unittest.mock.patch.__qualname__ == 'patch'"
  category: function_qualnames
  kind: python_call_eq
  function: patch.__qualname__.__eq__
  args: ["patch"]
  expected: true

# ---------------------------------------------------------------------------
# create_autospec __name__, __module__, __qualname__
# ---------------------------------------------------------------------------

invariant unittest_extra8.create_autospec_name:
  description: "unittest.mock.create_autospec.__name__ == 'create_autospec'"
  category: function_names
  kind: python_call_eq
  function: create_autospec.__name__.__eq__
  args: ["create_autospec"]
  expected: true

invariant unittest_extra8.create_autospec_module:
  description: "unittest.mock.create_autospec.__module__ == 'unittest.mock'"
  category: function_modules
  kind: python_call_eq
  function: create_autospec.__module__.__eq__
  args: ["unittest.mock"]
  expected: true

invariant unittest_extra8.create_autospec_qualname:
  description: "unittest.mock.create_autospec.__qualname__ == 'create_autospec'"
  category: function_qualnames
  kind: python_call_eq
  function: create_autospec.__qualname__.__eq__
  args: ["create_autospec"]
  expected: true
