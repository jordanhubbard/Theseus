spec: functools_extra2566
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2566 (_extra2566): __getattr__, __setattr__, __delattr__ dict-presence checks."
    - "functools.partial: C extension type — defines __setattr__ and __delattr__ to block mutation of read-only attributes (func, args, keywords), but does NOT define __getattr__ (uses inherited __getattribute__ for all lookups)."
    - "functools._singledispatchmethod_get: pure-Python descriptor — defines __getattr__ to proxy attribute access to the wrapped function, but does NOT define __setattr__ or __delattr__."
    - "functools.partialmethod: pure-Python class — defines none of __getattr__, __setattr__, __delattr__."
    - "functools.lru_cache / _lru_cache_wrapper / cached_property / singledispatch: none define __getattr__, __setattr__, or __delattr__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __setattr__ dict-presence for functools types
#
# functools.partial defines __setattr__ in its own __dict__ to raise
# AttributeError when callers attempt to assign to read-only slots such
# as .func, .args, and .keywords.  All other functools classes inherit
# __setattr__ from object without overriding it.
# ---------------------------------------------------------------------------

table functools_extra2566.setattr_protocol:
  description: "functools types __setattr__ dict-presence checks — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2566

  columns: [id, function, args, expected]
  rows:
    - ["ft2566001", "functools.partial.__dict__.__contains__", ["__setattr__"], true]
    - ["ft2566002", "functools.partialmethod.__dict__.__contains__", ["__setattr__"], false]
    - ["ft2566003", "functools.lru_cache.__dict__.__contains__", ["__setattr__"], false]
    - ["ft2566004", "functools._lru_cache_wrapper.__dict__.__contains__", ["__setattr__"], false]
    - ["ft2566005", "functools.cached_property.__dict__.__contains__", ["__setattr__"], false]

# ---------------------------------------------------------------------------
# Table 2: __delattr__ dict-presence for functools types
#
# functools.partial also defines __delattr__ (paired with __setattr__) to
# prevent deletion of its read-only attributes.  No other functools class
# overrides __delattr__ in its own __dict__.
# ---------------------------------------------------------------------------

table functools_extra2566.delattr_protocol:
  description: "functools types __delattr__ dict-presence checks — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2566

  columns: [id, function, args, expected]
  rows:
    - ["ft2566006", "functools.partial.__dict__.__contains__", ["__delattr__"], true]
    - ["ft2566007", "functools.partialmethod.__dict__.__contains__", ["__delattr__"], false]
    - ["ft2566008", "functools.lru_cache.__dict__.__contains__", ["__delattr__"], false]
    - ["ft2566009", "functools._lru_cache_wrapper.__dict__.__contains__", ["__delattr__"], false]
    - ["ft2566010", "functools.cached_property.__dict__.__contains__", ["__delattr__"], false]

# ---------------------------------------------------------------------------
# Table 3: __getattr__ dict-presence for functools types
#
# functools._singledispatchmethod_get defines __getattr__ to forward unknown
# attribute lookups to the wrapped function object (enabling transparent
# access to attributes like __doc__, __name__, __module__).
# functools.partial does NOT define __getattr__ — it uses __getattribute__
# for all attribute access.  No other functools class defines __getattr__.
# ---------------------------------------------------------------------------

table functools_extra2566.getattr_protocol:
  description: "functools types __getattr__ dict-presence checks — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2566

  columns: [id, function, args, expected]
  rows:
    - ["ft2566011", "functools._singledispatchmethod_get.__dict__.__contains__", ["__getattr__"], true]
    - ["ft2566012", "functools.partial.__dict__.__contains__", ["__getattr__"], false]
    - ["ft2566013", "functools.partialmethod.__dict__.__contains__", ["__getattr__"], false]
    - ["ft2566014", "functools.singledispatch.__dict__.__contains__", ["__getattr__"], false]
    - ["ft2566015", "functools.cached_property.__dict__.__contains__", ["__getattr__"], false]

# ---------------------------------------------------------------------------
# Table 4: functools.partial full attribute-access protocol summary
#
# functools.partial takes the unusual combination of defining __setattr__
# and __delattr__ (both present) while relying on the inherited
# __getattribute__ from object for reads.  __getattr__ is absent (it is
# only called on failed normal lookups, and partial has no use for it).
# __getattribute__ IS present because partial is a C extension type that
# overrides attribute reads for its built-in slots.
# ---------------------------------------------------------------------------

table functools_extra2566.partial_attr_protocol:
  description: "functools.partial full attribute-access protocol dict-presence — wave 2566 _extra2566"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2566

  columns: [id, function, args, expected]
  rows:
    - ["ft2566016", "functools.partial.__dict__.__contains__", ["__setattr__"], true]
    - ["ft2566017", "functools.partial.__dict__.__contains__", ["__delattr__"], true]
    - ["ft2566018", "functools.partial.__dict__.__contains__", ["__getattr__"], false]
    - ["ft2566019", "functools.partial.__dict__.__contains__", ["__getattribute__"], true]
    - ["ft2566020", "functools._singledispatchmethod_get.__dict__.__contains__", ["__setattr__"], false]
