table re_extra1936.class_name:
  description: "__class__.__name__ checks: re module, re types, and re.RegexFlag metaclass"
  kind: python_call_eq
  category: class_identity
  id_prefix: re1936

  columns: [id, function, args, expected]
  rows:
    - ["re1936017", "re.__class__.__name__.__eq__",          ["module"], true]
    - ["re1936018", "re.Pattern.__class__.__name__.__eq__",  ["type"],   true]
    - ["re1936019", "re.Match.__class__.__name__.__eq__",    ["type"],   true]
    - ["re1936020", "re.error.__class__.__name__.__eq__",    ["type"],   true]
    - ["re1936021", "re.RegexFlag.__class__.__name__.__eq__", ["EnumType"], true]

