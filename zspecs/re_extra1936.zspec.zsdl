    - ["re1936006", "re.Match.__dict__.__contains__",     ["__set__"], false]
    - ["re1936007", "re.error.__dict__.__contains__",     ["__set__"], false]
    - ["re1936008", "re.RegexFlag.__dict__.__contains__", ["__set__"], false]

