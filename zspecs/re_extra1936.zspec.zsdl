spec: re_extra1936
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/re.html"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl"
    - "re_patterns.zspec.zsdl"
    - "re_extra.zspec.zsdl"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol, __set_name__, __class__ checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "re.Pattern and re.Match are C extension types; they do NOT define __get__/__set__/__delete__ in their own __dict__."
    - "re.error is a Python exception class; it does not define descriptor protocol methods either."
    - "re.RegexFlag is an IntFlag enum; its __class__.__name__ reflects the enum metaclass (EnumType)."
    - "re module __class__.__name__ == 'module'; re.Pattern.__class__.__name__ == 'type'."
    - "re.RegexFlag.__class__.__name__ == 'EnumType' on Python 3.11+ (was 'EnumMeta' on earlier versions)."
  created_at: "2026-04-12"
error_model: python_exceptions

table re_extra1936.descriptor_get:
  description: "re types __get__ dict-presence checks — none define __get__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1936

  columns: [id, function, args, expected]
  rows:
    - ["re1936001", "re.Pattern.__dict__.__contains__",   ["__get__"], false]
    - ["re1936002", "re.Match.__dict__.__contains__",     ["__get__"], false]
    - ["re1936003", "re.error.__dict__.__contains__",     ["__get__"], false]
    - ["re1936004", "re.RegexFlag.__dict__.__contains__", ["__get__"], false]

