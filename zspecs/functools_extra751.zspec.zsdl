spec: functools_extra751
version: ">=3.9"
backend: python_module(functools)
docs: "Behavioral specs for functools module object identity and class name checks"
provenance:
  derived_from:
    - "Python 3.9+ standard library functools module"
  not_derived_from:
    - "any third-party functools extension"
  notes:
    - "Covers class name identity for core functools callables and types"
    - "All checks use __class__.__name__.__eq__ chain"
  created_at: "2026-04-12"
error_model: python_exceptions

table functools_extra751.class_names:
  description: "Verify __class__.__name__ for each functools attribute"
  kind: python_call_eq
  category: identity
  id_prefix: ft751xx
  columns: [id, function, args, expected]
  rows:
    - [ft751xx001, functools.reduce.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [ft751xx002, functools.cmp_to_key.__class__.__name__.__eq__, ["function"], true]
    - [ft751xx003, functools.lru_cache.__class__.__name__.__eq__, ["function"], true]
    - [ft751xx004, functools.cache.__class__.__name__.__eq__, ["function"], true]
    - [ft751xx005, functools.wraps.__class__.__name__.__eq__, ["function"], true]
    - [ft751xx006, functools.update_wrapper.__class__.__name__.__eq__, ["function"], true]
    - [ft751xx007, functools.partial.__class__.__name__.__eq__, ["type"], true]
    - [ft751xx008, functools.partialmethod.__class__.__name__.__eq__, ["type"], true]
    - [ft751xx009, functools.singledispatch.__class__.__name__.__eq__, ["function"], true]
    - [ft751xx010, functools.singledispatchmethod.__class__.__name__.__eq__, ["type"], true]
    - [ft751xx011, functools.cached_property.__class__.__name__.__eq__, ["type"], true]
    - [ft751xx012, functools.total_ordering.__class__.__name__.__eq__, ["function"], true]
