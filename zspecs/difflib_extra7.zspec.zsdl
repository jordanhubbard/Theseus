spec: difflib_extra7
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
    - "difflib.zspec.zsdl — covers SequenceMatcher ratio/find_longest/get_matching_blocks/get_opcodes tables; get_close_matches table; IS_CHARACTER_JUNK/IS_LINE_JUNK tables; Differ/__name__; HtmlDiff/__name__; function names."
    - "difflib_extra.zspec.zsdl — covers SequenceMatcher/__name__/__module__; Differ/__name__; HtmlDiff/__name__; unified_diff/context_diff/ndiff/get_close_matches __name__; behavioral get_close_matches."
    - "difflib_extra2.zspec.zsdl — covers SequenceMatcher/Differ/HtmlDiff __name__ table; base class checks; function_modules table; unified_diff first line; ndiff prefix; IS_LINE_JUNK/__name__; IS_CHARACTER_JUNK/__name__; SequenceMatcher.ratio_identical."
    - "difflib_extra3.zspec.zsdl — covers __qualname__ for SequenceMatcher/Differ/HtmlDiff/ndiff/unified_diff/context_diff/get_close_matches/restore; __module__ for SequenceMatcher/get_close_matches; get_close_matches('appel',...)."
    - "difflib_extra4.zspec.zsdl — covers SequenceMatcher/__name__/__module__/__qualname__; Differ/__name__/__qualname__; HtmlDiff/__name__/__qualname__ as extra4 anchors."
    - "difflib_extra5.zspec.zsdl — covers Differ/__module__; HtmlDiff/__module__; restore/__name__/__module__; IS_LINE_JUNK/__module__; IS_CHARACTER_JUNK/__module__; SequenceMatcher.quick_ratio disjoint; SequenceMatcher.real_quick_ratio equal-length; get_close_matches('banana',...)."
    - "difflib_extra6.zspec.zsdl — covers Differ/HtmlDiff/SequenceMatcher __name__/__module__ extra6 anchors; get_close_matches/__module__ anchor; unified_diff/context_diff/ndiff/restore/__name__ anchors; IS_LINE_JUNK/IS_CHARACTER_JUNK __name__ anchors."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior difflib spec."
    - "difflib.SequenceMatcher.__name__ == 'SequenceMatcher' — extra7-namespace anchor; covered in extra, extra2, extra4, extra6 namespaces."
    - "difflib.HtmlDiff.__name__ == 'HtmlDiff' — extra7-namespace anchor; covered in base spec, extra, extra2, extra4, extra6 namespaces."
    - "difflib.ndiff.__name__ == 'ndiff' — extra7-namespace anchor; covered in extra, extra2, extra6 namespaces."
    - "difflib.unified_diff.__name__ == 'unified_diff' — extra7-namespace anchor; covered in extra, extra6 namespaces."
    - "difflib.SequenceMatcher.__qualname__ == 'SequenceMatcher' — covered in extra3/extra4; extra7-namespace anchor."
    - "difflib.HtmlDiff.__qualname__ == 'HtmlDiff' — covered in extra3/extra4; extra7-namespace anchor."
    - "difflib.ndiff.__qualname__ == 'ndiff' — covered in extra3; extra7-namespace anchor."
    - "difflib.unified_diff.__qualname__ == 'unified_diff' — covered in extra3; extra7-namespace anchor."
    - "difflib.SequenceMatcher(None,'abcde','abcde').ratio() == 1.0 — identical 5-char sequences; extra2 covers identical 3-char; extra7 uses a 5-char vector."
    - "difflib.get_close_matches('appel',['ape','apple','peach','puppy']) == ['apple','ape'] — covered in extra3; extra7-namespace anchor."
    - "difflib.ndiff(['hello\\n'],['hello\\n']) first element starts with '  ' — equal-line prefix; no prior spec checks this specific prefix."
    - "difflib.unified_diff(['a\\n'],['b\\n'],lineterm='') contains a line starting with '@@' — hunk header present; new check not in prior specs."
    - "difflib.HtmlDiff.__bases__[0].__name__ == 'object' — HtmlDiff inherits from object; not covered in prior specs."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class and function __name__ — extra7-namespace grouped table
#
# Prior specs cover these in their respective namespaces (extra, extra2, extra4,
# extra6). This table provides extra7-namespace anchors for the four assigned
# axes using the dotted __eq__ chain pattern.
# ---------------------------------------------------------------------------

table difflib_extra7.name_attrs:
  kind: python_call_eq
  category: class_identity
  id_prefix: dname

  columns: [id, function, args, expected]
  rows:
    - [SequenceMatcher, SequenceMatcher.__name__.__eq__, ["SequenceMatcher"], true]
    - [HtmlDiff,        HtmlDiff.__name__.__eq__,        ["HtmlDiff"],        true]
    - [ndiff,           ndiff.__name__.__eq__,           ["ndiff"],           true]
    - [unified_diff,    unified_diff.__name__.__eq__,    ["unified_diff"],    true]

# ---------------------------------------------------------------------------
# Class and function __qualname__ — extra7-namespace grouped table
#
# difflib_extra3 and difflib_extra4 cover these in their namespaces.
# This table provides extra7-namespace anchors for the same four names.
# ---------------------------------------------------------------------------

table difflib_extra7.qualname_attrs:
  kind: python_call_eq
  category: class_identity
  id_prefix: dqname

  columns: [id, function, args, expected]
  rows:
    - [SequenceMatcher, SequenceMatcher.__qualname__.__eq__, ["SequenceMatcher"], true]
    - [HtmlDiff,        HtmlDiff.__qualname__.__eq__,        ["HtmlDiff"],        true]
    - [ndiff,           ndiff.__qualname__.__eq__,           ["ndiff"],           true]
    - [unified_diff,    unified_diff.__qualname__.__eq__,    ["unified_diff"],    true]

# ---------------------------------------------------------------------------
# HtmlDiff base class — inherits from object
#
# difflib_extra2 checks SequenceMatcher.__bases__[0].__name__ == 'object'.
# No prior spec checks HtmlDiff.__bases__[0].__name__. HtmlDiff is a plain
# class that also inherits directly from object.
# ---------------------------------------------------------------------------

invariant difflib_extra7.HtmlDiff.base_class:
  description: "difflib.HtmlDiff.__bases__[0].__name__ == 'object' — HtmlDiff inherits from object"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# SequenceMatcher.ratio — five-character identical sequences
#
# difflib_extra2 covers ratio of identical 3-character sequences ('abc'/'abc').
# This vector uses a 5-character sequence to provide a fresh data point.
# Two identical sequences of any length produce ratio == 1.0.
# ---------------------------------------------------------------------------

invariant difflib_extra7.SequenceMatcher.ratio_5chars:
  description: "difflib.SequenceMatcher(None,'abcde','abcde').ratio() == 1.0 — five identical chars"
  category: SequenceMatcher
  kind: python_call_eq
  function: SequenceMatcher
  args: [~, "abcde", "abcde"]
  method: ratio.__eq__
  method_args: [1.0]
  expected: true

# ---------------------------------------------------------------------------
# get_close_matches — 'appel' with word list
#
# difflib_extra3 covers get_close_matches('appel',...) in the extra3 namespace.
# This is the extra7-namespace anchor for the same vector.
# Result is ['apple', 'ape'] — ordered by score descending.
# ---------------------------------------------------------------------------

invariant difflib_extra7.get_close_matches.appel:
  description: "difflib.get_close_matches('appel',['ape','apple','peach','puppy']) == ['apple','ape']"
  category: get_close_matches
  kind: python_call_eq
  function: get_close_matches
  args: ["appel", ["ape", "apple", "peach", "puppy"]]
  expected: ["apple", "ape"]

# ---------------------------------------------------------------------------
# ndiff — equal-line prefix
#
# difflib_extra2 checks the ndiff prefix for differing lines ('-' prefix).
# No prior spec checks that an equal ndiff line starts with '  ' (two spaces).
# ndiff(['hello\n'], ['hello\n'])[0] == '  hello\n'.
# ---------------------------------------------------------------------------

invariant difflib_extra7.ndiff.equal_line_prefix:
  description: "difflib.ndiff(['hello\\n'],['hello\\n']) produces a single '  hello\\n' entry"
  category: ndiff
  kind: python_call_eq
  function: ndiff
  args: [["hello\n"], ["hello\n"]]
  method: __next__
  method_args: []
  expected: "  hello\n"

# ---------------------------------------------------------------------------
# unified_diff — hunk header presence
#
# No prior spec checks that unified_diff output contains a '@@' hunk header
# line. The third element (index 2) of unified_diff(['a\n'],['b\n'],lineterm='')
# is '@@ -1 +1 @@', confirming hunk header generation.
# ---------------------------------------------------------------------------

invariant difflib_extra7.unified_diff.hunk_header:
  description: "unified_diff(['a\\n'],['b\\n'],lineterm='')[2] == '@@ -1 +1 @@' — hunk header present"
  category: unified_diff
  kind: python_call_eq
  function: unified_diff
  args: [["a\n"], ["b\n"]]
  kwargs: {lineterm: ""}
  method: __next__.__next__.__next__
  method_args: []
  expected: "@@ -1 +1 @@"
