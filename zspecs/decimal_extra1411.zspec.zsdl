spec: decimal_extra1411
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers __sizeof__ method type/presence and __reduce_ex__ method type/presence for decimal module classes. decimal.Decimal.__sizeof__.__class__.__name__=='method_descriptor' and '__sizeof__' in decimal.Decimal.__dict__==True (Decimal is a C-level type from _decimal that defines its own __sizeof__). decimal.Context.__dict__.__contains__('__sizeof__')==False (Context does not define __sizeof__ in its own dict). decimal.DecimalException.__sizeof__.__class__.__name__=='method_descriptor'. decimal.InvalidOperation.__mro__.__len__()==6 (MRO: [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]; deepest chain in this batch). decimal.DecimalException.__mro__.__len__()==5. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "decimal.Decimal.__dict__.__contains__('__sizeof__')==True is the key distinguishing fact in this batch: Decimal is the only decimal class that defines __sizeof__ in its own __dict__. decimal.DecimalException.__name__.__len__()==16 ('DecimalException'=16 chars). decimal.InvalidOperation.__name__.__len__()==16 ('InvalidOperation'=16 chars; same length as DecimalException). decimal.Decimal.__name__.__len__()==7. decimal.Context.__name__.__len__()==7. None of the classes in this batch have '__reduce_ex__' in their own __dict__. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal class __sizeof__ type and dict presence checks — extra1411
#
# decimal.Decimal.__sizeof__.__class__.__name__             == 'method_descriptor'
# decimal.Decimal.__dict__.__contains__('__sizeof__')      == True
# decimal.Context.__sizeof__.__class__.__name__             == 'method_descriptor'
# decimal.Context.__dict__.__contains__('__sizeof__')      == False
# decimal.DecimalException.__dict__.__contains__('__sizeof__') == False
# decimal.InvalidOperation.__dict__.__contains__('__sizeof__') == False
# ---------------------------------------------------------------------------

table decimal_extra1411.decimal_sizeof_type:
  description: "decimal class __sizeof__ method type and __dict__ presence checks — wave 541 extra1411 theme. decimal.Decimal.__sizeof__.__class__.__name__=='method_descriptor' (Decimal is a C-level type from _decimal that defines its own __sizeof__; it is the only class in this batch with '__sizeof__' in its own __dict__). decimal.Decimal.__dict__.__contains__('__sizeof__')==True. decimal.Context.__sizeof__.__class__.__name__=='method_descriptor' (Context also C-level but does not define __sizeof__ in its own dict). decimal.Context.__dict__.__contains__('__sizeof__')==False. decimal.DecimalException.__dict__.__contains__('__sizeof__')==False (exception class inherits from ArithmeticError chain). decimal.InvalidOperation.__dict__.__contains__('__sizeof__')==False. All verified with Python 3.14.3."
  kind: python_call_eq
  category: sizeof_introspection
  id_prefix: dc1411sz

  columns: [id, function, args, expected, description]
  rows:
    - [dc1411sz001, decimal.Decimal.__sizeof__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "decimal.Decimal.__sizeof__.__class__.__name__ == 'method_descriptor' (C-level type with own __sizeof__); verified with Python 3.14.3"]
    - [dc1411sz002, decimal.Decimal.__dict__.__contains__,                         ["__sizeof__"],         true,  "decimal.Decimal.__dict__.__contains__('__sizeof__') == True (Decimal defines __sizeof__ in its own C-level dict); verified with Python 3.14.3"]
    - [dc1411sz003, decimal.Context.__sizeof__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "decimal.Context.__sizeof__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]
    - [dc1411sz004, decimal.Context.__dict__.__contains__,                         ["__sizeof__"],         false, "decimal.Context.__dict__.__contains__('__sizeof__') == False (Context inherits __sizeof__); verified with Python 3.14.3"]
    - [dc1411sz005, decimal.DecimalException.__dict__.__contains__,                ["__sizeof__"],         false, "decimal.DecimalException.__dict__.__contains__('__sizeof__') == False; verified with Python 3.14.3"]
    - [dc1411sz006, decimal.InvalidOperation.__dict__.__contains__,                ["__sizeof__"],         false, "decimal.InvalidOperation.__dict__.__contains__('__sizeof__') == False; verified with Python 3.14.3"]
    - [dc1411sz007, decimal.DecimalException.__sizeof__.__class__.__name__.__eq__, ["method_descriptor"], true,  "decimal.DecimalException.__sizeof__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]
    - [dc1411sz008, decimal.InvalidOperation.__sizeof__.__class__.__name__.__eq__, ["method_descriptor"], true,  "decimal.InvalidOperation.__sizeof__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# decimal class __reduce_ex__ type and dict presence checks — extra1411
#
# decimal.Decimal.__reduce_ex__.__class__.__name__             == 'method_descriptor'
# decimal.Decimal.__dict__.__contains__('__reduce_ex__')      == False
# decimal.Context.__dict__.__contains__('__reduce_ex__')      == False
# decimal.DecimalException.__reduce_ex__.__class__.__name__   == 'method_descriptor'
# decimal.InvalidOperation.__reduce_ex__.__class__.__name__   == 'method_descriptor'
# decimal.InvalidOperation.__dict__.__contains__('__reduce_ex__') == False
# ---------------------------------------------------------------------------

table decimal_extra1411.decimal_reduce_ex_type:
  description: "decimal class __reduce_ex__ method type and __dict__ presence checks — wave 541 extra1411 theme. decimal.Decimal.__reduce_ex__.__class__.__name__=='method_descriptor' (Decimal inherits __reduce_ex__ from object; not in its own __dict__ despite defining __sizeof__). decimal.Decimal.__dict__.__contains__('__reduce_ex__')==False. decimal.Context.__dict__.__contains__('__reduce_ex__')==False. decimal.DecimalException.__reduce_ex__.__class__.__name__=='method_descriptor' (inherits from BaseException chain; MRO is [DecimalException, ArithmeticError, Exception, BaseException, object] len=5). decimal.InvalidOperation.__reduce_ex__.__class__.__name__=='method_descriptor' (MRO len=6: [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]). decimal.InvalidOperation.__dict__.__contains__('__reduce_ex__')==False. All verified with Python 3.14.3."
  kind: python_call_eq
  category: reduce_ex_introspection
  id_prefix: dc1411rx

  columns: [id, function, args, expected, description]
  rows:
    - [dc1411rx001, decimal.Decimal.__reduce_ex__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "decimal.Decimal.__reduce_ex__.__class__.__name__ == 'method_descriptor' (inherited from object); verified with Python 3.14.3"]
    - [dc1411rx002, decimal.Decimal.__dict__.__contains__,                            ["__reduce_ex__"],      false, "decimal.Decimal.__dict__.__contains__('__reduce_ex__') == False (not in own dict even though __sizeof__ is); verified with Python 3.14.3"]
    - [dc1411rx003, decimal.Context.__dict__.__contains__,                            ["__reduce_ex__"],      false, "decimal.Context.__dict__.__contains__('__reduce_ex__') == False; verified with Python 3.14.3"]
    - [dc1411rx004, decimal.DecimalException.__reduce_ex__.__class__.__name__.__eq__, ["method_descriptor"], true,  "decimal.DecimalException.__reduce_ex__.__class__.__name__ == 'method_descriptor' (inherits from BaseException chain; MRO len=5); verified with Python 3.14.3"]
    - [dc1411rx005, decimal.DecimalException.__dict__.__contains__,                   ["__reduce_ex__"],      false, "decimal.DecimalException.__dict__.__contains__('__reduce_ex__') == False; verified with Python 3.14.3"]
    - [dc1411rx006, decimal.InvalidOperation.__reduce_ex__.__class__.__name__.__eq__, ["method_descriptor"], true,  "decimal.InvalidOperation.__reduce_ex__.__class__.__name__ == 'method_descriptor' (MRO len=6); verified with Python 3.14.3"]
    - [dc1411rx007, decimal.InvalidOperation.__dict__.__contains__,                   ["__reduce_ex__"],      false, "decimal.InvalidOperation.__dict__.__contains__('__reduce_ex__') == False; verified with Python 3.14.3"]
    - [dc1411rx008, decimal.Context.__reduce_ex__.__class__.__name__.__eq__,          ["method_descriptor"], true,  "decimal.Context.__reduce_ex__.__class__.__name__ == 'method_descriptor'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# decimal class MRO length and name checks — extra1411
#
# decimal.Decimal.__mro__.__len__()          == 2  ([Decimal, object])
# decimal.Context.__mro__.__len__()          == 2  ([Context, object])
# decimal.DecimalException.__mro__.__len__() == 5  ([DecimalException, ArithmeticError, Exception, BaseException, object])
# decimal.InvalidOperation.__mro__.__len__() == 6  ([InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object])
# decimal.DecimalException.__name__.__len__()== 16
# decimal.InvalidOperation.__name__.__len__()== 16
# ---------------------------------------------------------------------------

table decimal_extra1411.decimal_mro_and_name:
  description: "decimal class MRO length and class name length checks — wave 541 extra1411. decimal.Decimal.__mro__.__len__()==2 ([Decimal, object]; Decimal is a C-level type that subclasses object directly). decimal.Context.__mro__.__len__()==2 ([Context, object]; likewise C-level). decimal.DecimalException.__mro__.__len__()==5 ([DecimalException, ArithmeticError, Exception, BaseException, object]). decimal.InvalidOperation.__mro__.__len__()==6 ([InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]; deepest chain in this batch; InvalidOperation subclasses DecimalException which itself has a 5-deep chain). decimal.DecimalException.__name__.__len__()==16 ('DecimalException'=16 chars). decimal.InvalidOperation.__name__.__len__()==16 ('InvalidOperation'=16 chars; same length as DecimalException, both 16). decimal.Decimal.__name__.__len__()==7. decimal.Context.__name__.__len__()==7. All verified with Python 3.14.3."
  kind: python_call_eq
  category: mro_identity
  id_prefix: dc1411mr

  columns: [id, function, args, expected, description]
  rows:
    - [dc1411mr001, decimal.Decimal.__mro__.__len__,          [], 2,  "decimal.Decimal.__mro__.__len__() == 2 ([Decimal, object]; C-level type); verified with Python 3.14.3"]
    - [dc1411mr002, decimal.Context.__mro__.__len__,          [], 2,  "decimal.Context.__mro__.__len__() == 2 ([Context, object]; C-level type); verified with Python 3.14.3"]
    - [dc1411mr003, decimal.DecimalException.__mro__.__len__, [], 5,  "decimal.DecimalException.__mro__.__len__() == 5 ([DecimalException, ArithmeticError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [dc1411mr004, decimal.InvalidOperation.__mro__.__len__, [], 6,  "decimal.InvalidOperation.__mro__.__len__() == 6 ([InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]); verified with Python 3.14.3"]
    - [dc1411mr005, decimal.DecimalException.__name__.__len__, [], 16, "decimal.DecimalException.__name__.__len__() == 16 ('DecimalException'=16 chars); verified with Python 3.14.3"]
    - [dc1411mr006, decimal.InvalidOperation.__name__.__len__, [], 16, "decimal.InvalidOperation.__name__.__len__() == 16 ('InvalidOperation'=16 chars; same length as DecimalException); verified with Python 3.14.3"]
    - [dc1411mr007, decimal.Decimal.__name__.__len__,         [], 7,  "decimal.Decimal.__name__.__len__() == 7 ('Decimal'=7 chars); verified with Python 3.14.3"]
    - [dc1411mr008, decimal.Context.__name__.__len__,         [], 7,  "decimal.Context.__name__.__len__() == 7 ('Context'=7 chars; same length as Decimal); verified with Python 3.14.3"]
