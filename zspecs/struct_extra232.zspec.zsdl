spec: struct_extra232
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra231.zspec.zsdl — covers struct.pack/unpack/calcsize native byte order ('=') contracts"
    - "struct_extra230.zspec.zsdl — covers struct.error identity and pack raises contracts"
    - "struct_extra229.zspec.zsdl — covers pack('!H',1); pack('!H',65535); pack('!I',1); pack('!B',127); pack('!B',128)"
    - "struct_extra222.zspec.zsdl — covers pack('!B',0); pack('!B',255); pack('!H',0); pack('!H',256); pack('!I',256)"
    - "struct_extra214.zspec.zsdl — covers Struct('!H').pack(1); Struct('!I').pack(1)"
    - "_struct.zspec.zsdl — covers _struct C extension identity"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "struct.pack('!b', -1) == b'\\xff' — signed byte -1 in two's complement is 0xFF."
    - "struct.pack('!b', 127) == b'\\x7f' — signed byte max positive is 0x7F."
    - "struct.pack('!b', -128) == b'\\x80' — signed byte min negative is 0x80."
    - "struct.pack('!h', -1) == b'\\xff\\xff' — signed short -1 in two's complement is 0xFFFF."
    - "struct.pack('!h', 32767) == b'\\x7f\\xff' — signed short max positive is 0x7FFF."
    - "struct.pack('!i', -1) == b'\\xff\\xff\\xff\\xff' — signed int -1 in two's complement is 0xFFFFFFFF."
    - "struct.unpack('!b', b'\\xff')[0] == -1 — signed byte unpack of 0xFF is -1."
    - "struct.unpack('!h', b'\\xff\\xff')[0] == -1 — signed short unpack of 0xFFFF is -1."
    - "struct.unpack('!i', b'\\xff\\xff\\xff\\xff')[0] == -1 — signed int unpack of 0xFFFFFFFF is -1."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack signed byte ('!b') contracts
#
# struct.pack('!b', -1)   == b'\xff'
# struct.pack('!b', 127)  == b'\x7f'
# struct.pack('!b', -128) == b'\x80'
#
# '!b' means network/big-endian byte order, signed byte (int8_t in C).
# Range: [-128, 127]. Two's complement: -1 == 0xFF, 127 == 0x7F, -128 == 0x80.
# Prior struct specs cover only unsigned formats (B, H, I). Novel to struct_extra232.
# ---------------------------------------------------------------------------

table struct_extra232.pack_signed_byte_contracts:
  description: "pack('!b',-1)==b'\\xff'; pack('!b',127)==b'\\x7f'; pack('!b',-128)==b'\\x80'; struct.pack signed byte network byte order contracts; new to struct_extra232"
  kind: python_call_eq
  category: pack_signed
  id_prefix: struct232

  columns: [id, function, args, expected, description]
  rows:
    - [pack_nb_neg1,
       "pack('!b', -1).__eq__",
       ["\xff"],
       true,
       "struct.pack('!b', -1).__eq__(b'\\xff') == True — signed byte -1 in two's complement is 0xFF; network/big-endian byte order '!'; 'b' is signed byte (int8_t); -1 maps to all-bits-set byte b'\\xff'; novel signed byte pack anchor for -1; new to struct_extra232 namespace; verified Python 3.14.3"]
    - [pack_nb_127,
       "pack('!b', 127).__eq__",
       ["\x7f"],
       true,
       "struct.pack('!b', 127).__eq__(b'\\x7f') == True — signed byte 127 is the maximum positive value (2^7-1); encoded as 0x7F in two's complement; network/big-endian byte order; novel signed byte pack anchor for max positive; new to struct_extra232 namespace; verified Python 3.14.3"]
    - [pack_nb_neg128,
       "pack('!b', -128).__eq__",
       ["\x80"],
       true,
       "struct.pack('!b', -128).__eq__(b'\\x80') == True — signed byte -128 is the minimum value (-(2^7)); encoded as 0x80 in two's complement; high bit set, remaining bits zero; network/big-endian byte order; novel signed byte pack anchor for min negative; new to struct_extra232 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.pack signed short ('!h') contracts
#
# struct.pack('!h', -1)    == b'\xff\xff'
# struct.pack('!h', 32767) == b'\x7f\xff'
#
# '!h' means network/big-endian byte order, signed short (int16_t in C).
# Range: [-32768, 32767]. Two's complement: -1 == 0xFFFF, 32767 == 0x7FFF.
# Novel to struct_extra232.
# ---------------------------------------------------------------------------

table struct_extra232.pack_signed_short_contracts:
  description: "pack('!h',-1)==b'\\xff\\xff'; pack('!h',32767)==b'\\x7f\\xff'; struct.pack signed short network byte order contracts; new to struct_extra232"
  kind: python_call_eq
  category: pack_signed
  id_prefix: struct232a

  columns: [id, function, args, expected, description]
  rows:
    - [pack_nh_neg1,
       "pack('!h', -1).__eq__",
       ["\xff\xff"],
       true,
       "struct.pack('!h', -1).__eq__(b'\\xff\\xff') == True — signed short -1 in two's complement is 0xFFFF; network/big-endian byte order '!'; 'h' is signed short (int16_t); -1 maps to two all-bits-set bytes; novel signed short pack anchor for -1; new to struct_extra232 namespace; verified Python 3.14.3"]
    - [pack_nh_32767,
       "pack('!h', 32767).__eq__",
       ["\x7f\xff"],
       true,
       "struct.pack('!h', 32767).__eq__(b'\\x7f\\xff') == True — signed short 32767 is the maximum positive value (2^15-1); encoded as 0x7FFF in two's complement big-endian; high byte 0x7F, low byte 0xFF; novel signed short pack anchor for max positive; new to struct_extra232 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.pack signed int ('!i') and unpack signed contracts
#
# struct.pack('!i', -1) == b'\xff\xff\xff\xff'
# struct.unpack('!b', b'\xff')[0]             == -1
# struct.unpack('!h', b'\xff\xff')[0]         == -1
# struct.unpack('!i', b'\xff\xff\xff\xff')[0] == -1
#
# '!i' means network/big-endian byte order, signed int (int32_t in C).
# Unpack contracts confirm two's complement decoding of all-bits-set bytes.
# Novel to struct_extra232.
# ---------------------------------------------------------------------------

table struct_extra232.pack_unpack_signed_int_contracts:
  description: "pack('!i',-1)==b'\\xff\\xff\\xff\\xff'; unpack('!b',b'\\xff')[0]==-1; unpack('!h',b'\\xff\\xff')[0]==-1; unpack('!i',b'\\xff\\xff\\xff\\xff')[0]==-1; struct signed int pack/unpack contracts; new to struct_extra232"
  kind: python_call_eq
  category: pack_signed
  id_prefix: struct232b

  columns: [id, function, args, expected, description]
  rows:
    - [pack_ni_neg1,
       "pack('!i', -1).__eq__",
       ["\xff\xff\xff\xff"],
       true,
       "struct.pack('!i', -1).__eq__(b'\\xff\\xff\\xff\\xff') == True — signed int -1 in two's complement is 0xFFFFFFFF; network/big-endian byte order '!'; 'i' is signed int (int32_t); -1 maps to four all-bits-set bytes; novel signed int pack anchor for -1; new to struct_extra232 namespace; verified Python 3.14.3"]
    - [unpack_nb_xff,
       "unpack('!b', b'\\xff').__getitem__",
       [0],
       -1,
       "struct.unpack('!b', b'\\xff')[0] == -1 — signed byte unpack of b'\\xff' (0xFF); two's complement: high bit set, value = 0xFF - 256 = -1; network byte order; 'b' is signed byte; confirms two's complement decoding for signed type; novel signed byte unpack anchor; new to struct_extra232 namespace; verified Python 3.14.3"]
    - [unpack_nh_xff_xff,
       "unpack('!h', b'\\xff\\xff').__getitem__",
       [0],
       -1,
       "struct.unpack('!h', b'\\xff\\xff')[0] == -1 — signed short unpack of b'\\xff\\xff' (0xFFFF); two's complement: high bit set, value = 0xFFFF - 65536 = -1; network big-endian byte order; 'h' is signed short; novel signed short unpack anchor; new to struct_extra232 namespace; verified Python 3.14.3"]
    - [unpack_ni_all_xff,
       "unpack('!i', b'\\xff\\xff\\xff\\xff').__getitem__",
       [0],
       -1,
       "struct.unpack('!i', b'\\xff\\xff\\xff\\xff')[0] == -1 — signed int unpack of b'\\xff\\xff\\xff\\xff' (0xFFFFFFFF); two's complement: high bit set, value = 0xFFFFFFFF - 4294967296 = -1; network big-endian byte order; 'i' is signed int; novel signed int unpack anchor; new to struct_extra232 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra232.pack_signed_b_neg1:
  description: "struct.pack('!b', -1).__eq__(b'\\xff') == True — the signed byte format 'b' in struct uses two's complement representation; -1 in two's complement for int8_t is 0xFF (all 8 bits set); network/big-endian byte order '!' is used; the result is a 1-byte bytes object b'\\xff'; prior struct_extra specs cover only unsigned integer formats (B, H, I, Q); struct_extra232 is the first namespace to anchor signed byte pack contracts; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_signed
  kind: python_call_eq
  function: "pack('!b', -1).__eq__"
  args: ["\xff"]
  expected: true

invariant struct_extra232.unpack_signed_b_xff:
  description: "struct.unpack('!b', b'\\xff')[0] == -1 — signed byte unpack of a single byte 0xFF using two's complement; the high bit of 0xFF is set so the value is negative; two's complement of 0xFF as int8_t: 0xFF (255 unsigned) - 256 = -1; network/big-endian byte order; no prior struct spec anchors unpack of a signed type; struct_extra232 is the first namespace to record this signed unpack contract; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_signed
  kind: python_call_eq
  function: "unpack('!b', b'\\xff').__getitem__"
  args: [0]
  expected: -1

invariant struct_extra232.unpack_signed_i_all_xff:
  description: "struct.unpack('!i', b'\\xff\\xff\\xff\\xff')[0] == -1 — signed int unpack of 4 bytes all set to 0xFF; two's complement interpretation of 0xFFFFFFFF as int32_t gives -1 (0xFFFFFFFF unsigned = 4294967295; 4294967295 - 4294967296 = -1); network/big-endian byte order; 'i' is signed 32-bit integer; no prior struct spec anchors signed int unpack; struct_extra232 is the first namespace to anchor this contract; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_signed
  kind: python_call_eq
  function: "unpack('!i', b'\\xff\\xff\\xff\\xff').__getitem__"
  args: [0]
  expected: -1

invariant struct_extra232.pack_signed_b_max_127:
  description: "struct.pack('!b', 127).__eq__(b'\\x7f') == True — signed byte maximum positive value is 127 (2^7 - 1); encoded as 0x7F (0111 1111 in binary); high bit is 0 so the value is positive; network/big-endian byte order; 'b' format encodes int8_t range [-128, 127]; 127 is the int8_t maximum; no prior struct spec anchors signed byte pack for any value; struct_extra232 is the first namespace to record this; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: pack_signed
  kind: python_call_eq
  function: "pack('!b', 127).__eq__"
  args: ["\x7f"]
  expected: true
