spec: io_extra155
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.TextIOWrapper method __qualname__ values for read (18), readline (22), write/flush/close (19 each), seek/tell (18 each), truncate (22), detach (20), reconfigure (25 — the longest). Also covers io.TextIOWrapper.__doc__.__len__()==1330, io.TextIOWrapper.__bases__[0].__name__=='_TextIOBase' (len=11), and io.TextIOWrapper.__dict__.__contains__ for key I/O methods."
    - "io.TextIOWrapper method qualnames (shortest to longest): read/seek/tell (18), write/flush/close (19), detach (20), readline/truncate (22), reconfigure (25)."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (len=11); the private C-extension TextIOBase ABC is the direct base of TextIOWrapper."
    - "io.TextIOWrapper.__doc__.__len__() == 1330; the class-level docstring describes the character/line layer over BufferedIOBase."
    - "io.TextIOWrapper.__dict__.__contains__('read') == True; __contains__('readline') == True; __contains__('write') == True; __contains__('flush') == True; __contains__('close') == True."
    - "io.TextIOWrapper.__dict__.__contains__('readlines') == False — readlines is inherited from _IOBase, not defined in TextIOWrapper.__dict__ directly."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOWrapper method __qualname__ values
# Shortest: read/seek/tell (18). Longest: reconfigure (25).
# write/flush/close all share length 19.
# readline and truncate both share length 22.
# ---------------------------------------------------------------------------

table io_extra155.TextIOWrapper_method_qualnames:
  description: "io.TextIOWrapper method __qualname__ values: read/seek/tell=18, write/flush/close=19, detach=20, readline/truncate=22, reconfigure=25"
  kind: python_call_eq
  category: qualname
  id_prefix: iotw155

  columns: [id, function, args, expected, description]
  rows:
    - [read_qeq,        TextIOWrapper.read.__qualname__.__eq__,        ["TextIOWrapper.read"],        true, "io.TextIOWrapper.read.__qualname__ == 'TextIOWrapper.read' (len=18; reads up to size characters from the stream; one of the shortest TextIOWrapper method qualnames, tied with seek and tell)"]
    - [read_qlen,       TextIOWrapper.read.__qualname__.__len__,        [],                            18,   "io.TextIOWrapper.read.__qualname__.__len__() == 18 ('TextIOWrapper.read' has 18 characters; 'TextIOWrapper.' (14) + 'read' (4) = 18; tied with seek and tell)"]
    - [seek_qeq,        TextIOWrapper.seek.__qualname__.__eq__,        ["TextIOWrapper.seek"],        true, "io.TextIOWrapper.seek.__qualname__ == 'TextIOWrapper.seek' (len=18; moves stream position to given byte offset; tied with read and tell at 18)"]
    - [tell_qeq,        TextIOWrapper.tell.__qualname__.__eq__,        ["TextIOWrapper.tell"],        true, "io.TextIOWrapper.tell.__qualname__ == 'TextIOWrapper.tell' (len=18; returns current stream position as an opaque number; tied with read and seek at 18)"]
    - [write_qeq,       TextIOWrapper.write.__qualname__.__eq__,       ["TextIOWrapper.write"],       true, "io.TextIOWrapper.write.__qualname__ == 'TextIOWrapper.write' (len=19; writes string to stream; one of three TextIOWrapper methods with qualname length 19, along with flush and close)"]
    - [write_qlen,      TextIOWrapper.write.__qualname__.__len__,      [],                            19,   "io.TextIOWrapper.write.__qualname__.__len__() == 19 ('TextIOWrapper.write' has 19 characters; tied with flush and close at 19)"]
    - [flush_qeq,       TextIOWrapper.flush.__qualname__.__eq__,       ["TextIOWrapper.flush"],       true, "io.TextIOWrapper.flush.__qualname__ == 'TextIOWrapper.flush' (len=19; flushes write buffers; tied with write and close at 19)"]
    - [close_qeq,       TextIOWrapper.close.__qualname__.__eq__,       ["TextIOWrapper.close"],       true, "io.TextIOWrapper.close.__qualname__ == 'TextIOWrapper.close' (len=19; flushes and closes the stream; tied with write and flush at 19)"]
    - [detach_qeq,      TextIOWrapper.detach.__qualname__.__eq__,      ["TextIOWrapper.detach"],      true, "io.TextIOWrapper.detach.__qualname__ == 'TextIOWrapper.detach' (len=20; separates the underlying buffer from the TextIOWrapper and returns it; unique length 20 among TextIOWrapper methods)"]
    - [detach_qlen,     TextIOWrapper.detach.__qualname__.__len__,     [],                            20,   "io.TextIOWrapper.detach.__qualname__.__len__() == 20 ('TextIOWrapper.detach' has 20 characters; 'TextIOWrapper.' (14) + 'detach' (6) = 20; the only TextIOWrapper method at length 20)"]
    - [readline_qeq,    TextIOWrapper.readline.__qualname__.__eq__,    ["TextIOWrapper.readline"],    true, "io.TextIOWrapper.readline.__qualname__ == 'TextIOWrapper.readline' (len=22; reads up to size characters or until newline; tied with truncate at 22)"]
    - [readline_qlen,   TextIOWrapper.readline.__qualname__.__len__,   [],                            22,   "io.TextIOWrapper.readline.__qualname__.__len__() == 22 ('TextIOWrapper.readline' has 22 characters; tied with truncate at 22)"]
    - [truncate_qeq,    TextIOWrapper.truncate.__qualname__.__eq__,    ["TextIOWrapper.truncate"],    true, "io.TextIOWrapper.truncate.__qualname__ == 'TextIOWrapper.truncate' (len=22; truncates the stream to at most size characters; tied with readline at 22)"]
    - [reconfigure_qeq, TextIOWrapper.reconfigure.__qualname__.__eq__, ["TextIOWrapper.reconfigure"], true, "io.TextIOWrapper.reconfigure.__qualname__ == 'TextIOWrapper.reconfigure' (len=25; reconfigures encoding/errors/newline/line_buffering/write_through; the longest TextIOWrapper method qualname)"]
    - [reconfigure_qlen,TextIOWrapper.reconfigure.__qualname__.__len__,[],                            25,   "io.TextIOWrapper.reconfigure.__qualname__.__len__() == 25 ('TextIOWrapper.reconfigure' has 25 characters; 'TextIOWrapper.' (14) + 'reconfigure' (11) = 25; the longest method qualname in TextIOWrapper)"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper.__doc__ length and __bases__[0].__name__
# io.TextIOWrapper.__doc__.__len__() == 1330.
# io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (len=11).
# ---------------------------------------------------------------------------

table io_extra155.TextIOWrapper_doc_and_bases:
  description: "io.TextIOWrapper.__doc__.__len__()==1330; __bases__[0].__name__=='_TextIOBase' (len=11); __name__=='TextIOWrapper' (len=13)"
  kind: python_call_eq
  category: identity
  id_prefix: iotw155

  columns: [id, function, args, expected, description]
  rows:
    - [doc_len,         TextIOWrapper.__doc__.__len__,                    [],               1330, "io.TextIOWrapper.__doc__.__len__() == 1330 (the TextIOWrapper class docstring describes the character/line buffered layer over a BufferedIOBase object; 1330 characters, distinct from io.__doc__ (1473) covered in io_extra153)"]
    - [doc_cls_eq,      TextIOWrapper.__doc__.__class__.__name__.__eq__,  ["str"],          true, "io.TextIOWrapper.__doc__.__class__.__name__ == 'str' (TextIOWrapper has a non-None class docstring of type str)"]
    - [name_eq,         TextIOWrapper.__name__.__eq__,                    ["TextIOWrapper"],true, "io.TextIOWrapper.__name__ == 'TextIOWrapper' (len=13; the class name as a string attribute)"]
    - [name_len,        TextIOWrapper.__name__.__len__,                   [],               13,   "io.TextIOWrapper.__name__.__len__() == 13 ('TextIOWrapper' has 13 characters)"]
    - [base0_name_eq,   "TextIOWrapper.__bases__[0].__name__.__eq__",     ["_TextIOBase"],  true, "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (the private C-extension TextIOBase is the direct base of TextIOWrapper; all public io concrete classes wrap private C types)"]
    - [base0_name_len,  "TextIOWrapper.__bases__[0].__name__.__len__",    [],               11,   "io.TextIOWrapper.__bases__[0].__name__.__len__() == 11 ('_TextIOBase' has 11 characters including the leading underscore)"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper.__dict__.__contains__ membership checks
# key methods defined directly in TextIOWrapper's dict (not inherited).
# readlines is NOT in TextIOWrapper.__dict__ — it is inherited from _IOBase.
# ---------------------------------------------------------------------------

table io_extra155.TextIOWrapper_dict_contains:
  description: "io.TextIOWrapper.__dict__.__contains__: read/readline/write/flush/close/seek/tell/detach/reconfigure are True; readlines is False (inherited from _IOBase)"
  kind: python_call_eq
  category: identity
  id_prefix: iotw155

  columns: [id, function, args, expected, description]
  rows:
    - [has_read,        TextIOWrapper.__dict__.__contains__, ["read"],        true,  "io.TextIOWrapper.__dict__.__contains__('read') == True (read is defined directly in TextIOWrapper.__dict__, not inherited)"]
    - [has_readline,    TextIOWrapper.__dict__.__contains__, ["readline"],    true,  "io.TextIOWrapper.__dict__.__contains__('readline') == True (readline is defined directly in TextIOWrapper.__dict__)"]
    - [has_write,       TextIOWrapper.__dict__.__contains__, ["write"],       true,  "io.TextIOWrapper.__dict__.__contains__('write') == True (write is defined directly in TextIOWrapper.__dict__)"]
    - [has_flush,       TextIOWrapper.__dict__.__contains__, ["flush"],       true,  "io.TextIOWrapper.__dict__.__contains__('flush') == True (flush is defined directly in TextIOWrapper.__dict__)"]
    - [has_close,       TextIOWrapper.__dict__.__contains__, ["close"],       true,  "io.TextIOWrapper.__dict__.__contains__('close') == True (close is defined directly in TextIOWrapper.__dict__)"]
    - [has_seek,        TextIOWrapper.__dict__.__contains__, ["seek"],        true,  "io.TextIOWrapper.__dict__.__contains__('seek') == True (seek is defined directly in TextIOWrapper.__dict__)"]
    - [has_tell,        TextIOWrapper.__dict__.__contains__, ["tell"],        true,  "io.TextIOWrapper.__dict__.__contains__('tell') == True (tell is defined directly in TextIOWrapper.__dict__)"]
    - [has_detach,      TextIOWrapper.__dict__.__contains__, ["detach"],      true,  "io.TextIOWrapper.__dict__.__contains__('detach') == True (detach is defined directly in TextIOWrapper.__dict__; separates the underlying buffer from the wrapper)"]
    - [has_reconfigure, TextIOWrapper.__dict__.__contains__, ["reconfigure"], true,  "io.TextIOWrapper.__dict__.__contains__('reconfigure') == True (reconfigure is defined directly in TextIOWrapper.__dict__; allows changing encoding and related settings on an open stream)"]
    - [no_readlines,    TextIOWrapper.__dict__.__contains__, ["readlines"],   false, "io.TextIOWrapper.__dict__.__contains__('readlines') == False — readlines is NOT in TextIOWrapper.__dict__; it is inherited from _IOBase (whose __qualname__ is '_IOBase.readlines'); this is why TextIOWrapper.readlines.__qualname__ == '_IOBase.readlines' (len=17), not 'TextIOWrapper.readlines' (len=24)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra155.TextIOWrapper.read_qualname_len_18:
  description: "io.TextIOWrapper.read.__qualname__.__len__() == 18 ('TextIOWrapper.read' has 18 characters; 'TextIOWrapper.' (14) + 'read' (4) = 18; tied with seek and tell for the shortest TextIOWrapper method qualname; read() reads up to size characters from the stream)"
  category: qualname
  kind: python_call_eq
  function: TextIOWrapper.read.__qualname__.__len__
  args: []
  expected: 18

invariant io_extra155.TextIOWrapper.reconfigure_qualname_len_25:
  description: "io.TextIOWrapper.reconfigure.__qualname__.__len__() == 25 ('TextIOWrapper.reconfigure' has 25 characters; 'TextIOWrapper.' (14) + 'reconfigure' (11) = 25; the longest TextIOWrapper method qualname; reconfigure() allows changing encoding, errors, newline, line_buffering, and write_through on an already-open stream — unique to TextIOWrapper with no equivalent in BytesIO or StringIO)"
  category: qualname
  kind: python_call_eq
  function: TextIOWrapper.reconfigure.__qualname__.__len__
  args: []
  expected: 25

invariant io_extra155.TextIOWrapper.write_qualname_eq:
  description: "io.TextIOWrapper.write.__qualname__ == 'TextIOWrapper.write' (len=19) — write() is defined directly in TextIOWrapper (not inherited); it encodes the string and writes it to the underlying binary buffer; write is one of three TextIOWrapper methods with qualname length 19 (along with flush and close)"
  category: qualname
  kind: python_call_eq
  function: TextIOWrapper.write.__qualname__.__eq__
  args: ["TextIOWrapper.write"]
  expected: true

invariant io_extra155.TextIOWrapper.doc_len_1330:
  description: "io.TextIOWrapper.__doc__.__len__() == 1330 — the TextIOWrapper class docstring is 1330 characters long; it describes TextIOWrapper as a character/line layer over BufferedIOBase; this is distinct from io.__doc__ (1473 chars, the module-level docstring) and io.open.__doc__ (5959 chars, the open function docstring)"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__doc__.__len__
  args: []
  expected: 1330

invariant io_extra155.TextIOWrapper.base0_name_eq_TextIOBase:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (len=11) — TextIOWrapper's direct base is the private C-extension class _TextIOBase; this is consistent with the pattern where all public concrete io classes (BytesIO, StringIO, FileIO, TextIOWrapper) wrap private C types (_BufferedIOBase, _TextIOBase, _RawIOBase); the public abstract classes (TextIOBase, BufferedIOBase, IOBase) are Python ABC wrappers over these private C types"
  category: identity
  kind: python_call_eq
  function: "TextIOWrapper.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra155.TextIOWrapper.dict_no_readlines:
  description: "io.TextIOWrapper.__dict__.__contains__('readlines') == False — readlines is NOT defined in TextIOWrapper.__dict__; it is inherited from _IOBase (the root C-extension IO type); TextIOWrapper.readlines.__qualname__ == '_IOBase.readlines' (len=17), confirming it belongs to _IOBase rather than TextIOWrapper; this distinguishes readlines from read/readline/write/flush/close which ARE in TextIOWrapper.__dict__"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__dict__.__contains__
  args: ["readlines"]
  expected: false

invariant io_extra155.TextIOWrapper.dict_has_detach:
  description: "io.TextIOWrapper.__dict__.__contains__('detach') == True — detach is defined directly in TextIOWrapper.__dict__; it separates the underlying binary buffer from the TextIOWrapper and returns it; after detach(), the TextIOWrapper is in an unusable state; this method is unique to TextIOWrapper and has no equivalent in BytesIO, StringIO, or FileIO"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__dict__.__contains__
  args: ["detach"]
  expected: true

