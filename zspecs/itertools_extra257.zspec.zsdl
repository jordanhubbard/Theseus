# ---------------------------------------------------------------------------
# Standalone invariants — extra257
# ---------------------------------------------------------------------------

invariant itertools_extra257.islice.name_eq:
  description: "itertools.islice.__name__ == 'islice' — C-level type name; new to extra257"
  category: identity
  kind: python_call_eq
  function: islice.__name__.__eq__
  args: ["islice"]
  expected: true

invariant itertools_extra257.islice.module_eq:
  description: "itertools.islice.__module__ == 'itertools' — defined in itertools; new to extra257"
  category: identity
  kind: python_call_eq
  function: islice.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra257.islice.base_is_object:
  description: "itertools.islice.__bases__[0].__name__ == 'object' — inherits directly from object; new to extra257"
  category: identity
  kind: python_call_eq
  function: "islice.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra257.islice.new_qualname:
  description: "itertools.islice.__new__.__qualname__ == 'islice.__new__' — C-level constructor qualname; new to extra257"
