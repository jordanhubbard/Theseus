spec: itertools_extra257
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.islice, itertools.takewhile, and itertools.dropwhile class identity contracts."
    - "itertools.islice.__name__ == 'islice' — C-level type name. Verified with Python 3.14.3."
    - "itertools.islice.__module__ == 'itertools' — defined in itertools. Verified with Python 3.14.3."
    - "itertools.islice.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.3."
    - "itertools.islice.__new__.__qualname__ == 'islice.__new__' — C-level constructor qualname. Verified with Python 3.14.3."
    - "itertools.islice.__qualname__ == 'islice' — top-level class; qualname equals name. Verified with Python 3.14.3."
    - "itertools.takewhile.__name__ == 'takewhile' — C-level type name. Verified with Python 3.14.3."
    - "itertools.takewhile.__module__ == 'itertools' — defined in itertools. Verified with Python 3.14.3."
    - "itertools.takewhile.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.3."
    - "itertools.takewhile.__new__.__qualname__ == 'takewhile.__new__' — C-level constructor qualname. Verified with Python 3.14.3."
    - "itertools.dropwhile.__name__ == 'dropwhile' — C-level type name. Verified with Python 3.14.3."
    - "itertools.dropwhile.__module__ == 'itertools' — defined in itertools. Verified with Python 3.14.3."
    - "itertools.dropwhile.__bases__[0].__name__ == 'object' — inherits directly from object. Verified with Python 3.14.3."
    - "itertools.dropwhile.__new__.__qualname__ == 'dropwhile.__new__' — C-level constructor qualname. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.islice class identity contracts
#
# itertools.islice.__name__              == 'islice'
# itertools.islice.__module__            == 'itertools'
# itertools.islice.__bases__[0].__name__ == 'object'
# itertools.islice.__qualname__          == 'islice'
# itertools.islice.__new__.__qualname__  == 'islice.__new__'
#
# islice is a C-level iterator type. New to extra257.
# ---------------------------------------------------------------------------

table itertools_extra257.islice_identity:
  description: "itertools.islice name, module, base, qualname, __new__ qualname contracts; new to extra257"
  kind: python_call_eq
  category: identity
  id_prefix: itis257

  columns: [id, function, args, expected, description]
  rows:
    - [islice_name_eq,
       islice.__name__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — C-level type name; new to extra257"]
    - [islice_module_eq,
       islice.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.islice.__module__.__eq__('itertools') == True — defined in itertools; new to extra257"]
    - [islice_base_name_eq,
       "islice.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.islice.__bases__[0].__name__.__eq__('object') == True — inherits directly from object; new to extra257"]
    - [islice_qualname_eq,
       islice.__qualname__.__eq__,
       ["islice"],
       true,
       "itertools.islice.__qualname__.__eq__('islice') == True — top-level class; qualname equals name; new to extra257"]
    - [islice_new_qualname_eq,
       islice.__new__.__qualname__.__eq__,
       ["islice.__new__"],
       true,
       "itertools.islice.__new__.__qualname__.__eq__('islice.__new__') == True — C-level constructor qualname; new to extra257"]

