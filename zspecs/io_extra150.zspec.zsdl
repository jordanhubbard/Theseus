spec: io_extra150
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase method __qualname__ values and lengths."
    - "Key finding: all io ABC methods report qualnames using the PRIVATE C-extension class names (_IOBase, _RawIOBase, _BufferedIOBase, _TextIOBase), not the public Python ABC names (IOBase, RawIOBase, etc.). This reflects CPython's implementation where the public ABCs (io.IOBase etc.) are wrappers around private C-extension types."
    - "io.IOBase.readline.__qualname__ == '_IOBase.readline' (len=16) — uses _IOBase prefix, not IOBase."
    - "io.IOBase.flush and io.IOBase.close both have __qualname__ len=13 ('_IOBase.flush', '_IOBase.close')."
    - "io.IOBase.seek and io.IOBase.tell both have __qualname__ len=12 ('_IOBase.seek', '_IOBase.tell')."
    - "io.IOBase.readline, io.IOBase.truncate, io.IOBase.readable, io.IOBase.writable, io.IOBase.seekable all have __qualname__ len=16 or 17."
    - "io.RawIOBase.read.__qualname__ == '_RawIOBase.read' (len=15); readinto=19, readall=18, write=16."
    - "io.BufferedIOBase.read.__qualname__ == '_BufferedIOBase.read' (len=20); readinto=24, readinto1=25 (the two longest)."
    - "io.TextIOBase.seek and tell delegate to _IOBase (qualname len=12); read/readline/write/detach use _TextIOBase prefix."
    - "io.TextIOBase.readline.__qualname__ == '_TextIOBase.readline' (len=20)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase method __qualname__ lengths
# All IOBase methods carry the _IOBase prefix (the private C extension type).
# seek/tell: len=12; flush/close: len=13; readline/truncate/readable/writable/seekable: len=16;
# readlines: len=17; writelines: len=18.
# ---------------------------------------------------------------------------

table io_extra150.IOBase_method_qualname_lengths:
  description: "io.IOBase method __qualname__ lengths: seek/tell=12, flush/close=13, readline/truncate/readable/writable/seekable=16, readlines=17, writelines=18"
  kind: python_call_eq
  category: qualname
  id_prefix: iobase150

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_seek_qlen,      IOBase.seek.__qualname__.__len__,      [], 12, "io.IOBase.seek.__qualname__.__len__() == 12 ('_IOBase.seek' has 12 characters; methods inherit qualnames from the private C-extension class _IOBase)"]
    - [iobase_tell_qlen,      IOBase.tell.__qualname__.__len__,      [], 12, "io.IOBase.tell.__qualname__.__len__() == 12 ('_IOBase.tell' has 12 characters; tied with seek)"]
    - [iobase_flush_qlen,     IOBase.flush.__qualname__.__len__,     [], 13, "io.IOBase.flush.__qualname__.__len__() == 13 ('_IOBase.flush' has 13 characters)"]
    - [iobase_close_qlen,     IOBase.close.__qualname__.__len__,     [], 13, "io.IOBase.close.__qualname__.__len__() == 13 ('_IOBase.close' has 13 characters; tied with flush)"]
    - [iobase_readline_qlen,  IOBase.readline.__qualname__.__len__,  [], 16, "io.IOBase.readline.__qualname__.__len__() == 16 ('_IOBase.readline' has 16 characters)"]
    - [iobase_truncate_qlen,  IOBase.truncate.__qualname__.__len__,  [], 16, "io.IOBase.truncate.__qualname__.__len__() == 16 ('_IOBase.truncate' has 16 characters)"]
    - [iobase_readable_qlen,  IOBase.readable.__qualname__.__len__,  [], 16, "io.IOBase.readable.__qualname__.__len__() == 16 ('_IOBase.readable' has 16 characters)"]
    - [iobase_writable_qlen,  IOBase.writable.__qualname__.__len__,  [], 16, "io.IOBase.writable.__qualname__.__len__() == 16 ('_IOBase.writable' has 16 characters)"]
    - [iobase_seekable_qlen,  IOBase.seekable.__qualname__.__len__,  [], 16, "io.IOBase.seekable.__qualname__.__len__() == 16 ('_IOBase.seekable' has 16 characters)"]
    - [iobase_readlines_qlen, IOBase.readlines.__qualname__.__len__, [], 17, "io.IOBase.readlines.__qualname__.__len__() == 17 ('_IOBase.readlines' has 17 characters)"]
    - [iobase_writelines_qlen,IOBase.writelines.__qualname__.__len__,[], 18, "io.IOBase.writelines.__qualname__.__len__() == 18 ('_IOBase.writelines' has 18 characters; the longest IOBase method qualname)"]

# ---------------------------------------------------------------------------
# io.IOBase method __qualname__ string equality checks
# readline qualname == '_IOBase.readline'; flush == '_IOBase.flush'.
# The prefix '_IOBase' (7 chars) appears in all IOBase method qualnames.
# ---------------------------------------------------------------------------

table io_extra150.IOBase_method_qualname_equality:
  description: "io.IOBase method __qualname__ string equality: seek='_IOBase.seek', flush='_IOBase.flush', readline='_IOBase.readline', writelines='_IOBase.writelines'"
  kind: python_call_eq
  category: qualname
  id_prefix: iobase150

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_seek_qeq,      IOBase.seek.__qualname__.__eq__,      ["_IOBase.seek"],      true, "io.IOBase.seek.__qualname__ == '_IOBase.seek' (uses private C-extension class prefix, not public 'IOBase')"]
    - [iobase_flush_qeq,     IOBase.flush.__qualname__.__eq__,     ["_IOBase.flush"],     true, "io.IOBase.flush.__qualname__ == '_IOBase.flush'"]
    - [iobase_close_qeq,     IOBase.close.__qualname__.__eq__,     ["_IOBase.close"],     true, "io.IOBase.close.__qualname__ == '_IOBase.close'"]
    - [iobase_readline_qeq,  IOBase.readline.__qualname__.__eq__,  ["_IOBase.readline"],  true, "io.IOBase.readline.__qualname__ == '_IOBase.readline'"]
    - [iobase_writelines_qeq,IOBase.writelines.__qualname__.__eq__,["_IOBase.writelines"],true, "io.IOBase.writelines.__qualname__ == '_IOBase.writelines'"]
    - [iobase_seek_not_pub,  IOBase.seek.__qualname__.__eq__,      ["IOBase.seek"],       false,"io.IOBase.seek.__qualname__ != 'IOBase.seek' (qualname uses _IOBase not IOBase)"]

# ---------------------------------------------------------------------------
# io.RawIOBase and io.BufferedIOBase method __qualname__ lengths
# RawIOBase: read=15, write=16, readall=18, readinto=19.
# BufferedIOBase: read=20, write/read1=21, detach=22, readinto=24, readinto1=25.
# ---------------------------------------------------------------------------

table io_extra150.RawIOBase_BufferedIOBase_qualname_lengths:
  description: "io.RawIOBase method qualname lengths: read=15, write=16, readall=18, readinto=19; io.BufferedIOBase: read=20, write/read1=21, detach=22, readinto=24, readinto1=25"
  kind: python_call_eq
  category: qualname
  id_prefix: iobase150

  columns: [id, function, args, expected, description]
  rows:
    - [rawio_read_qlen,      RawIOBase.read.__qualname__.__len__,           [], 15, "io.RawIOBase.read.__qualname__.__len__() == 15 ('_RawIOBase.read' has 15 characters)"]
    - [rawio_write_qlen,     RawIOBase.write.__qualname__.__len__,          [], 16, "io.RawIOBase.write.__qualname__.__len__() == 16 ('_RawIOBase.write' has 16 characters)"]
    - [rawio_readall_qlen,   RawIOBase.readall.__qualname__.__len__,        [], 18, "io.RawIOBase.readall.__qualname__.__len__() == 18 ('_RawIOBase.readall' has 18 characters)"]
    - [rawio_readinto_qlen,  RawIOBase.readinto.__qualname__.__len__,       [], 19, "io.RawIOBase.readinto.__qualname__.__len__() == 19 ('_RawIOBase.readinto' has 19 characters; longest RawIOBase method qualname)"]
    - [bufio_read_qlen,      BufferedIOBase.read.__qualname__.__len__,      [], 20, "io.BufferedIOBase.read.__qualname__.__len__() == 20 ('_BufferedIOBase.read' has 20 characters)"]
    - [bufio_write_qlen,     BufferedIOBase.write.__qualname__.__len__,     [], 21, "io.BufferedIOBase.write.__qualname__.__len__() == 21 ('_BufferedIOBase.write' has 21 characters)"]
    - [bufio_read1_qlen,     BufferedIOBase.read1.__qualname__.__len__,     [], 21, "io.BufferedIOBase.read1.__qualname__.__len__() == 21 ('_BufferedIOBase.read1' has 21 characters; tied with write)"]
    - [bufio_detach_qlen,    BufferedIOBase.detach.__qualname__.__len__,    [], 22, "io.BufferedIOBase.detach.__qualname__.__len__() == 22 ('_BufferedIOBase.detach' has 22 characters)"]
    - [bufio_readinto_qlen,  BufferedIOBase.readinto.__qualname__.__len__,  [], 24, "io.BufferedIOBase.readinto.__qualname__.__len__() == 24 ('_BufferedIOBase.readinto' has 24 characters)"]
    - [bufio_readinto1_qlen, BufferedIOBase.readinto1.__qualname__.__len__, [], 25, "io.BufferedIOBase.readinto1.__qualname__.__len__() == 25 ('_BufferedIOBase.readinto1' has 25 characters; the longest BufferedIOBase method qualname)"]

# ---------------------------------------------------------------------------
# io.TextIOBase method __qualname__ lengths
# seek/tell delegate to _IOBase: len=12. read=16, write=17, detach=18, readline=20.
# ---------------------------------------------------------------------------

table io_extra150.TextIOBase_method_qualname_lengths:
  description: "io.TextIOBase method qualname lengths: seek/tell=12 (delegate to _IOBase), read=16, write=17, detach=18, readline=20"
  kind: python_call_eq
  category: qualname
  id_prefix: iobase150

  columns: [id, function, args, expected, description]
  rows:
    - [textio_seek_qlen,    TextIOBase.seek.__qualname__.__len__,    [], 12, "io.TextIOBase.seek.__qualname__.__len__() == 12 ('_IOBase.seek'; seek is inherited from _IOBase, not defined on _TextIOBase)"]
    - [textio_tell_qlen,    TextIOBase.tell.__qualname__.__len__,    [], 12, "io.TextIOBase.tell.__qualname__.__len__() == 12 ('_IOBase.tell'; tell also delegates to _IOBase)"]
    - [textio_read_qlen,    TextIOBase.read.__qualname__.__len__,    [], 16, "io.TextIOBase.read.__qualname__.__len__() == 16 ('_TextIOBase.read' has 16 characters)"]
    - [textio_write_qlen,   TextIOBase.write.__qualname__.__len__,   [], 17, "io.TextIOBase.write.__qualname__.__len__() == 17 ('_TextIOBase.write' has 17 characters)"]
    - [textio_detach_qlen,  TextIOBase.detach.__qualname__.__len__,  [], 18, "io.TextIOBase.detach.__qualname__.__len__() == 18 ('_TextIOBase.detach' has 18 characters)"]
    - [textio_readline_qlen,TextIOBase.readline.__qualname__.__len__, [], 20, "io.TextIOBase.readline.__qualname__.__len__() == 20 ('_TextIOBase.readline' has 20 characters; longest TextIOBase method qualname)"]
    - [textio_seek_eq,      TextIOBase.seek.__qualname__.__eq__,     ["_IOBase.seek"],     true, "io.TextIOBase.seek.__qualname__ == '_IOBase.seek' (not '_TextIOBase.seek'; seek comes from the _IOBase C layer)"]
    - [textio_readline_eq,  TextIOBase.readline.__qualname__.__eq__, ["_TextIOBase.readline"], true, "io.TextIOBase.readline.__qualname__ == '_TextIOBase.readline' (readline is defined on _TextIOBase)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra150.IOBase.seek_qualname_uses_private_prefix:
  description: "io.IOBase.seek.__qualname__ == '_IOBase.seek' — io ABC methods carry the private C-extension class name (_IOBase) in their __qualname__, not the public Python ABC name (IOBase). This reveals that the io ABCs are thin wrappers over C-extension types."
  category: qualname
  kind: python_call_eq
  function: IOBase.seek.__qualname__.__eq__
  args: ["_IOBase.seek"]
  expected: true

invariant io_extra150.IOBase.writelines_qualname_len_18:
  description: "io.IOBase.writelines.__qualname__.__len__() == 18 ('_IOBase.writelines' is the longest of all IOBase method qualnames; readline=16, readlines=17, writelines=18)"
  category: qualname
  kind: python_call_eq
  function: IOBase.writelines.__qualname__.__len__
  args: []
  expected: 18

invariant io_extra150.RawIOBase.readinto_qualname_len_19:
  description: "io.RawIOBase.readinto.__qualname__.__len__() == 19 ('_RawIOBase.readinto' is the longest RawIOBase method qualname; read=15, write=16, readall=18, readinto=19)"
  category: qualname
  kind: python_call_eq
  function: RawIOBase.readinto.__qualname__.__len__
  args: []
  expected: 19

invariant io_extra150.BufferedIOBase.readinto1_qualname_len_25:
  description: "io.BufferedIOBase.readinto1.__qualname__.__len__() == 25 ('_BufferedIOBase.readinto1' is the longest qualname among all io ABC methods covered in this spec; the '_BufferedIOBase' prefix alone is 15 characters)"
  category: qualname
  kind: python_call_eq
  function: BufferedIOBase.readinto1.__qualname__.__len__
  args: []
  expected: 25

invariant io_extra150.TextIOBase.seek_qualname_eq_IOBase:
  description: "io.TextIOBase.seek.__qualname__ == '_IOBase.seek' — TextIOBase.seek is not defined on _TextIOBase; it is inherited from _IOBase. This means TextIOBase.seek.__qualname__ is identical to IOBase.seek.__qualname__, revealing the shared C-layer root."
  category: qualname
  kind: python_call_eq
  function: TextIOBase.seek.__qualname__.__eq__
  args: ["_IOBase.seek"]
  expected: true

invariant io_extra150.BufferedIOBase.read_qualname_eq:
  description: "io.BufferedIOBase.read.__qualname__ == '_BufferedIOBase.read' (len=20); the '_BufferedIOBase' prefix has 15 characters, the same length as '_RawIOBase.read' in its entirety"
  category: qualname
  kind: python_call_eq
  function: BufferedIOBase.read.__qualname__.__eq__
  args: ["_BufferedIOBase.read"]
  expected: true

invariant io_extra150.IOBase.flush_qualname_len_13:
  description: "io.IOBase.flush.__qualname__.__len__() == 13 ('_IOBase.flush'); tied with close (13); shorter than readline (16) and longer than seek/tell (12)"
  category: qualname
  kind: python_call_eq
  function: IOBase.flush.__qualname__.__len__
  args: []
  expected: 13

invariant io_extra150.TextIOBase.readline_qualname_len_20:
  description: "io.TextIOBase.readline.__qualname__.__len__() == 20 ('_TextIOBase.readline' has 20 characters; this is the longest TextIOBase method qualname and ties with io.BufferedIOBase.read (20) in length)"
  category: qualname
  kind: python_call_eq
  function: TextIOBase.readline.__qualname__.__len__
  args: []
  expected: 20
