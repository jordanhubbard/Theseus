spec: ssl_extra16
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "OpenSSL source"
  notes:
    - "This spec extends ssl.zspec.zsdl and prior extras through ssl_extra15.zspec.zsdl."
    - "ssl.zspec.zsdl covers: SSLError/SSLContext/SSLSocket/SSLCertVerificationError __name__; SSLError.__bases__[0].__name__ == 'OSError'; SSLError.__module__; CERT_NONE/CERT_OPTIONAL/CERT_REQUIRED int values; HAS_SNI/HAS_ALPN type."
    - "ssl_extra5 covers: VerifyMode.__name__/__bases__/__module__."
    - "ssl_extra7 covers: SSLError/SSLContext/SSLSocket/SSLCertVerificationError __name__ (table); SSLError/__bases__[0]/__mro__[1].__name__."
    - "ssl_extra8 covers: SSLError/SSLContext/SSLSocket/SSLCertVerificationError __qualname__ (table)."
    - "ssl_extra11 covers: VerifyMode.CERT_NONE.value == 0 / CERT_OPTIONAL.value == 1 / CERT_REQUIRED.value == 2; CERT_NONE/OPTIONAL/REQUIRED .name member strings."
    - "ssl_extra2 covers: CERT_NONE.__class__.__name__ == 'VerifyMode'; CERT_REQUIRED.__class__.__name__ == 'VerifyMode'."
    - "ssl_extra4 covers: CERT_OPTIONAL.__class__.__name__ == 'VerifyMode'."
    - "ssl_extra13 covers: SSLContext.__bases__[0].__name__ and SSLSocket.__bases__[0].__name__."
    - "No prior spec covers: SSLError.__bases__.__len__() == 1 — SSLError has exactly one direct base class."
    - "No prior spec covers: SSLCertVerificationError.__bases__.__len__() == 1."
    - "No prior spec covers: SSLContext.__bases__.__len__() == 1 — SSLContext has exactly one direct base (object)."
    - "No prior spec covers: SSLSocket.__bases__.__len__() == 1."
    - "No prior spec covers: CERT_NONE.__int__() == 0 — calling __int__() directly on a VerifyMode enum member."
    - "No prior spec covers: CERT_OPTIONAL.__int__() == 1."
    - "No prior spec covers: CERT_REQUIRED.__int__() == 2."
    - "No prior spec covers: VerifyMode.__name__.__len__() == 10 — length of 'VerifyMode'."
    - "No prior spec covers: SSLError.__name__.__len__() == 8 — length of 'SSLError'."
    - "No prior spec covers: create_default_context.__name__.__len__() == 22 — length of 'create_default_context'."
    - "ssl.CERT_NONE, CERT_OPTIONAL, CERT_REQUIRED are VerifyMode IntEnum members; __int__() returns 0, 1, 2."
    - "SSLError has one direct base (OSError); SSLCertVerificationError has one direct base (SSLError)."
    - "SSLContext and SSLSocket have one direct base each (object and socket.socket respectively)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SSLError.__bases__.__len__() and SSLCertVerificationError.__bases__.__len__()
#
# ssl_extra7 covers SSLError.__mro__[1].__name__ and __bases__[0].__name__.
# ssl_extra14 covers SSLCertVerificationError.__bases__[0].__name__.
# No prior spec checks the count of direct base classes on either exception.
# Both have exactly one direct base class.
# ---------------------------------------------------------------------------

invariant ssl_extra16.SSLError.bases_len:
  description: "ssl.SSLError.__bases__.__len__() == 1 — SSLError has exactly one direct base class (OSError)"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLError.__bases__.__len__
  args: []
  expected: 1

invariant ssl_extra16.SSLCertVerificationError.bases_len:
  description: "ssl.SSLCertVerificationError.__bases__.__len__() == 1 — one direct base (SSLError)"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLCertVerificationError.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# SSLContext.__bases__.__len__() and SSLSocket.__bases__.__len__()
#
# ssl_extra13 checks SSLContext.__bases__[0].__name__ == 'object' and
# SSLSocket.__bases__[0].__name__ == 'socket'. No prior spec checks the count
# of direct base classes on SSLContext or SSLSocket.
# ---------------------------------------------------------------------------

invariant ssl_extra16.SSLContext.bases_len:
  description: "ssl.SSLContext.__bases__.__len__() == 1 — SSLContext has exactly one direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLContext.__bases__.__len__
  args: []
  expected: 1

invariant ssl_extra16.SSLSocket.bases_len:
  description: "ssl.SSLSocket.__bases__.__len__() == 1 — SSLSocket has exactly one direct base (socket.socket)"
  category: class_hierarchy
  kind: python_call_eq
  function: SSLSocket.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# CERT_NONE.__int__(), CERT_OPTIONAL.__int__(), CERT_REQUIRED.__int__()
#
# ssl_extra11 covers VerifyMode.CERT_NONE.value == 0 (via .value accessor).
# ssl.zspec.zsdl checks CERT_NONE == 0 as direct integer equality.
# No prior spec calls __int__() directly on VerifyMode enum members.
# IntEnum members support __int__(); values are 0, 1, 2 (OpenSSL constants).
# ---------------------------------------------------------------------------

invariant ssl_extra16.CERT_NONE.int_value:
  description: "ssl.CERT_NONE.__int__() == 0 — CERT_NONE VerifyMode member converts to int 0"
  category: constants
  kind: python_call_eq
  function: CERT_NONE.__int__
  args: []
  expected: 0

invariant ssl_extra16.CERT_OPTIONAL.int_value:
  description: "ssl.CERT_OPTIONAL.__int__() == 1 — CERT_OPTIONAL VerifyMode member converts to int 1"
  category: constants
  kind: python_call_eq
  function: CERT_OPTIONAL.__int__
  args: []
  expected: 1

invariant ssl_extra16.CERT_REQUIRED.int_value:
  description: "ssl.CERT_REQUIRED.__int__() == 2 — CERT_REQUIRED VerifyMode member converts to int 2"
  category: constants
  kind: python_call_eq
  function: CERT_REQUIRED.__int__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Class name string lengths — VerifyMode, SSLError, create_default_context
#
# No prior spec checks the length of any ssl class name or function name string.
# These verify the exact character counts of the string attribute values.
# ---------------------------------------------------------------------------

invariant ssl_extra16.VerifyMode.name_len:
  description: "ssl.VerifyMode.__name__.__len__() == 10 — len('VerifyMode') == 10"
  category: class_names
  kind: python_call_eq
  function: VerifyMode.__name__.__len__
  args: []
  expected: 10

invariant ssl_extra16.SSLError.name_len:
  description: "ssl.SSLError.__name__.__len__() == 8 — len('SSLError') == 8"
  category: class_names
  kind: python_call_eq
  function: SSLError.__name__.__len__
  args: []
  expected: 8

invariant ssl_extra16.SSLContext.name_len:
  description: "ssl.SSLContext.__name__.__len__() == 10 — len('SSLContext') == 10"
  category: class_names
  kind: python_call_eq
  function: SSLContext.__name__.__len__
  args: []
  expected: 10

invariant ssl_extra16.create_default_context.name_len:
  description: "ssl.create_default_context.__name__.__len__() == 22 — len('create_default_context') == 22"
  category: class_names
  kind: python_call_eq
  function: create_default_context.__name__.__len__
  args: []
  expected: 22
