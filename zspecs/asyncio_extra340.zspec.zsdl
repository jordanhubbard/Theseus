spec: asyncio_extra340
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "asyncio.__all__ is a tuple (not a list) on Python 3.14; __class__.__name__ == 'tuple'."
    - "len(asyncio.__all__) == 95 on Python 3.14.3 on macOS/Darwin 25.4.0."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio module identity
# ---------------------------------------------------------------------------

invariant asyncio_extra340.module.name:
  description: "asyncio.__name__ == 'asyncio'"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra340.module.package:
  description: "asyncio.__package__ == 'asyncio'"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra340.module.spec_name:
  description: "asyncio.__spec__.name == 'asyncio'"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["asyncio"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.__all__ — public API surface
#
# On Python 3.14.3: __all__ is a tuple with 95 elements.
# ---------------------------------------------------------------------------

invariant asyncio_extra340.all.is_tuple:
  description: "asyncio.__all__.__class__.__name__ == 'tuple'"
  category: all_export
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant asyncio_extra340.all.length:
  description: "len(asyncio.__all__) == 95 on Python 3.14"
  category: all_export
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 95

invariant asyncio_extra340.all.contains_task:
  description: "asyncio.__all__ contains 'Task'"
  category: all_export
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Task"]
  expected: true

invariant asyncio_extra340.all.contains_future:
  description: "asyncio.__all__ contains 'Future'"
  category: all_export
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Future"]
  expected: true

invariant asyncio_extra340.all.contains_cancelled_error:
  description: "asyncio.__all__ contains 'CancelledError'"
  category: all_export
  kind: python_call_eq
  function: __all__.__contains__
  args: ["CancelledError"]
  expected: true

invariant asyncio_extra340.all.contains_run:
  description: "asyncio.__all__ contains 'run'"
  category: all_export
  kind: python_call_eq
  function: __all__.__contains__
  args: ["run"]
  expected: true
