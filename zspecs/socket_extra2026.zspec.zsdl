spec: socket_extra2026
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
    - "CPython source: Lib/socket.py, Modules/_socket.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 582 (_extra2026): __truediv__, __floordiv__, __mod__, __pow__, __divmod__ dict-presence checks."
    - "socket.socket is not an arithmetic type; it defines none of these division, modulo, or exponentiation protocols in its own __dict__."
    - "socket.error, socket.timeout, and socket.gaierror are Exception subclasses; they define no arithmetic protocols."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; they inherit arithmetic methods from int but define none of these in their own __dict__."
    - "All division/modulo/exponentiation dunder methods are absent from all checked socket type dicts."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2026.socket_truediv_protocol:
  description: "socket.socket __truediv__/__rtruediv__/__itruediv__ dict-presence checks (socket is not arithmetic)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2026

  columns: [id, function, args, expected]
  rows:
    - ["sk2026001", "socket.socket.__dict__.__contains__", ["__truediv__"], false]
    - ["sk2026002", "socket.socket.__dict__.__contains__", ["__rtruediv__"], false]
    - ["sk2026003", "socket.socket.__dict__.__contains__", ["__itruediv__"], false]

