spec: difflib_extra5
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "Python 3 difflib documentation — https://docs.python.org/3/library/difflib.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
    - "difflib.zspec.zsdl — covers SequenceMatcher ratio/find_longest/get_matching_blocks/get_opcodes tables; get_close_matches table; IS_CHARACTER_JUNK/IS_LINE_JUNK tables; Differ/__name__; HtmlDiff/__name__; function names."
    - "difflib_extra.zspec.zsdl — covers SequenceMatcher/__name__/__module__; Differ/__name__; HtmlDiff/__name__; unified_diff/context_diff/ndiff/get_close_matches __name__; behavioral get_close_matches."
    - "difflib_extra2.zspec.zsdl — covers SequenceMatcher/Differ/HtmlDiff __name__ table; base class checks; function_modules table (unified_diff/ndiff/context_diff/get_close_matches); unified_diff first line; ndiff prefix; IS_LINE_JUNK/__name__; IS_CHARACTER_JUNK/__name__; SequenceMatcher.ratio_identical."
    - "difflib_extra3.zspec.zsdl — covers __qualname__ for SequenceMatcher/Differ/HtmlDiff/ndiff/unified_diff/context_diff/get_close_matches/restore; __module__ for SequenceMatcher/get_close_matches; get_close_matches('appel',['ape','apple','peach','puppy'])."
    - "difflib_extra4.zspec.zsdl — covers SequenceMatcher/__name__/__module__/__qualname__; Differ/__name__/__qualname__; HtmlDiff/__name__/__qualname__ as extra4 anchors."
  notes:
    - "This spec adds genuinely new test vectors not present in any prior difflib spec."
    - "difflib.Differ.__module__ == 'difflib' — difflib_extra2 function_modules table covers unified_diff/ndiff/context_diff/get_close_matches but NOT Differ or HtmlDiff; this is the first __module__ check for Differ."
    - "difflib.HtmlDiff.__module__ == 'difflib' — same gap; first __module__ check for HtmlDiff."
    - "difflib.restore.__name__ == 'restore' — difflib_extra3 covers restore.__qualname__; no prior spec checks restore.__name__ directly."
    - "difflib.restore.__module__ == 'difflib' — not in any prior spec."
    - "difflib.IS_LINE_JUNK.__module__ == 'difflib' — difflib_extra2 covers __name__ only; __module__ not in any prior spec."
    - "difflib.IS_CHARACTER_JUNK.__module__ == 'difflib' — same gap as IS_LINE_JUNK."
    - "SequenceMatcher(None,'abc','xyz').quick_ratio() == 0.0 — difflib.zspec.zsdl has quick_ratio for identical ('hello','hello') giving 1.0; no spec checks quick_ratio for disjoint sequences."
    - "SequenceMatcher(None,'abc','xyz').real_quick_ratio() == 1.0 — real_quick_ratio computes 2*min(len(a),len(b))/(len(a)+len(b)); for equal-length sequences this is 1.0 regardless of content; base spec covers real_quick_ratio only for identical inputs."
    - "get_close_matches('banana', ['bandana', 'banana', 'can'], n=2) == ['banana', 'bandana'] — new word set with n=2 limit; no prior spec uses 'banana'/'bandana'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Differ.__module__ and HtmlDiff.__module__
#
# difflib_extra2 covers function __module__ for unified_diff/ndiff/context_diff/
# get_close_matches but stops there. Differ and HtmlDiff __module__ are uncovered.
# ---------------------------------------------------------------------------

invariant difflib_extra5.Differ.module:
  description: "difflib.Differ.__module__ == 'difflib'"
  category: class_identity
  kind: python_call_eq
  function: Differ.__module__.__eq__
  args: ["difflib"]
  expected: true

invariant difflib_extra5.HtmlDiff.module:
  description: "difflib.HtmlDiff.__module__ == 'difflib'"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# restore — __name__ and __module__
#
# difflib_extra3 covers restore.__qualname__. No prior spec checks __name__
# or __module__ for restore independently.
# ---------------------------------------------------------------------------

invariant difflib_extra5.restore.name:
  description: "difflib.restore.__name__ == 'restore'"
  category: function_identity
  kind: python_call_eq
  function: restore.__name__.__eq__
  args: ["restore"]
  expected: true

invariant difflib_extra5.restore.module:
  description: "difflib.restore.__module__ == 'difflib'"
  category: function_identity
  kind: python_call_eq
  function: restore.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# IS_LINE_JUNK and IS_CHARACTER_JUNK — __module__ attribute
#
# difflib_extra2 covers __name__ for both predicates. No prior spec checks
# __module__ for either predicate.
# ---------------------------------------------------------------------------

invariant difflib_extra5.IS_LINE_JUNK.module:
  description: "difflib.IS_LINE_JUNK.__module__ == 'difflib'"
  category: junk_predicates
  kind: python_call_eq
  function: IS_LINE_JUNK.__module__.__eq__
  args: ["difflib"]
  expected: true

invariant difflib_extra5.IS_CHARACTER_JUNK.module:
  description: "difflib.IS_CHARACTER_JUNK.__module__ == 'difflib'"
  category: junk_predicates
  kind: python_call_eq
  function: IS_CHARACTER_JUNK.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# SequenceMatcher.quick_ratio() for disjoint sequences
#
# difflib.zspec.zsdl covers quick_ratio only for identical sequences (result 1.0).
# For completely disjoint sequences 'abc' vs 'xyz', quick_ratio() returns 0.0.
# This is the first vector combining quick_ratio with disjoint input.
# ---------------------------------------------------------------------------

invariant difflib_extra5.SequenceMatcher.quick_ratio_disjoint:
  description: "SequenceMatcher(None, 'abc', 'xyz').quick_ratio() == 0.0 — disjoint sequences"
  category: ratio
  kind: python_call_eq
  function: SequenceMatcher
  args: [null, "abc", "xyz"]
  method: quick_ratio
  method_args: []
  expected: 0.0

# ---------------------------------------------------------------------------
# SequenceMatcher.real_quick_ratio() for disjoint sequences
#
# difflib.zspec.zsdl covers real_quick_ratio only for identical sequences (1.0).
# For disjoint 'abc' vs 'xyz', real_quick_ratio() returns 0.0 (both length 3
# but no characters in common).
# ---------------------------------------------------------------------------

invariant difflib_extra5.SequenceMatcher.real_quick_ratio_equal_length:
  description: "SequenceMatcher(None, 'abc', 'xyz').real_quick_ratio() == 1.0 — equal-length sequences always give 1.0"
  category: ratio
  kind: python_call_eq
  function: SequenceMatcher
  args: [null, "abc", "xyz"]
  method: real_quick_ratio
  method_args: []
  expected: 1.0

# ---------------------------------------------------------------------------
# get_close_matches — new word set with n=2 limit
#
# No prior spec uses 'banana'/'bandana' as inputs. With default cutoff=0.6
# and n=2, both 'banana' (exact match, ratio 1.0) and 'bandana' (close match)
# score above the threshold. 'banana' ranks first (perfect match).
# ---------------------------------------------------------------------------

invariant difflib_extra5.get_close_matches.banana_n2:
  description: "get_close_matches('banana', ['bandana', 'banana', 'can'], n=2) == ['banana', 'bandana']"
  category: close_matches
  kind: python_call_eq
  function: get_close_matches
  args: ["banana", ["bandana", "banana", "can"]]
  kwargs: {n: 2}
  expected: ["banana", "bandana"]
