spec: hl3406
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 674 (hl3406): __bool__, __str__, __repr__ dict-presence checks for hashlib types."
    - "Theme: __bool__/__str__/__repr__ dict-presence (bool(x), str(x), repr(x))."
    - "All values False — hashlib types are cryptographic hash objects with no bool/str/repr conversion defined in their own __dict__."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __bool__, __str__, or __repr__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3406.bool:
  description: "hashlib types __bool__ dict-presence checks; wave 674"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3406
  columns: [id, function, args, expected]
  rows:
    - ["hl3406001", operator.contains, [type(hashlib.md5()).__dict__,        "__bool__"], false]
    - ["hl3406002", operator.contains, [type(hashlib.sha1()).__dict__,       "__bool__"], false]
    - ["hl3406003", operator.contains, [type(hashlib.sha256()).__dict__,     "__bool__"], false]
    - ["hl3406004", operator.contains, [type(hashlib.sha512()).__dict__,     "__bool__"], false]
    - ["hl3406005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__bool__"], false]

