spec: re_extra185
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "re.search.__name__=='search' (len=6); re.match.__name__=='match' (len=5); re.fullmatch.__name__=='fullmatch' (len=9)."
    - "re.findall.__name__=='findall' (len=7); re.finditer.__name__=='finditer' (len=8)."
    - "re.sub.__name__=='sub' (len=3); re.subn.__name__=='subn' (len=4); re.split.__name__=='split' (len=5)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re module search and match function name identity
# search (len=6), match (len=5), fullmatch (len=9)
# ---------------------------------------------------------------------------

table re_extra185.search_match_name_identity:
  description: "re module search/match function name identity: search.__name__=='search' (len=6); match.__name__=='match' (len=5); fullmatch.__name__=='fullmatch' (len=9)"
  kind: python_call_eq
  category: identity
  id_prefix: refuncs185

  columns: [id, function, args, expected, description]
  rows:
    - [search_name,    search.__name__.__eq__,    ["search"],    true,  "re.search.__name__ == 'search' — pattern search function name; confirmed Python 3.14.3 macOS"]
    - [search_len,     search.__name__.__len__,   [],            6,     "re.search.__name__.__len__() == 6 — 'search': s(1)e(2)a(3)r(4)c(5)h(6); confirmed Python 3.14.3 macOS"]
    - [match_name,     match.__name__.__eq__,     ["match"],     true,  "re.match.__name__ == 'match' — pattern match-at-start function name; confirmed Python 3.14.3 macOS"]
    - [match_len,      match.__name__.__len__,    [],            5,     "re.match.__name__.__len__() == 5 — 'match': m(1)a(2)t(3)c(4)h(5); confirmed Python 3.14.3 macOS"]
    - [fullmatch_name, fullmatch.__name__.__eq__,  ["fullmatch"],  true,  "re.fullmatch.__name__ == 'fullmatch' — whole-string match function name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re module findall and finditer function name identity
# findall (len=7), finditer (len=8)
# ---------------------------------------------------------------------------

table re_extra185.find_funcs_name_identity:
  description: "re module find function name identity: findall.__name__=='findall' (len=7); finditer.__name__=='finditer' (len=8); finditer is one character longer than findall"
  kind: python_call_eq
  category: identity
  id_prefix: refuncs185

  columns: [id, function, args, expected, description]
  rows:
    - [findall_name,   findall.__name__.__eq__,    ["findall"],   true,  "re.findall.__name__ == 'findall' — returns list of all matches; confirmed Python 3.14.3 macOS"]
    - [findall_len,    findall.__name__.__len__,   [],            7,     "re.findall.__name__.__len__() == 7 — 'findall': f(1)i(2)n(3)d(4)a(5)l(6)l(7); confirmed Python 3.14.3 macOS"]
    - [finditer_name,  finditer.__name__.__eq__,   ["finditer"],  true,  "re.finditer.__name__ == 'finditer' — returns iterator of match objects; confirmed Python 3.14.3 macOS"]
    - [finditer_len,   finditer.__name__.__len__,  [],            8,     "re.finditer.__name__.__len__() == 8 — 'finditer': f(1)i(2)n(3)d(4)i(5)t(6)e(7)r(8); confirmed Python 3.14.3 macOS"]
    - [fullmatch_len,  fullmatch.__name__.__len__,  [],            9,     "re.fullmatch.__name__.__len__() == 9 — 'fullmatch': f(1)u(2)l(3)l(4)m(5)a(6)t(7)c(8)h(9); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re module substitution and split function name identity
