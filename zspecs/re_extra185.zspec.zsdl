# ---------------------------------------------------------------------------

table re_extra185.sub_split_name_identity:
  description: "re module substitution/split function name identity: sub.__name__=='sub' (len=3); subn.__name__=='subn' (len=4); split.__name__=='split' (len=5)"
  kind: python_call_eq
  category: identity
  id_prefix: refuncs185

  columns: [id, function, args, expected, description]
  rows:
    - [sub_name,    sub.__name__.__eq__,    ["sub"],    true,  "re.sub.__name__ == 'sub' — substitution function name; confirmed Python 3.14.3 macOS"]
    - [sub_len,     sub.__name__.__len__,   [],         3,     "re.sub.__name__.__len__() == 3 — 'sub': s(1)u(2)b(3); confirmed Python 3.14.3 macOS"]
    - [subn_name,   subn.__name__.__eq__,   ["subn"],   true,  "re.subn.__name__ == 'subn' — substitution-with-count function name; confirmed Python 3.14.3 macOS"]
