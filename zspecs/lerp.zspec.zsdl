spec: lerp
version: ">=1.0.3"
backend: node(lerp)

docs: https://www.npmjs.com/package/lerp

provenance:
  derived_from:
    - "lerp README — https://www.npmjs.com/package/lerp"
    - "Test vectors verified with lerp via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "lerp source"
  notes:
    - "lerp is an npm package. Install: npm install lerp"
    - "Linear interpolation between two values given a t parameter in [0, 1]."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lerp.interpolate:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: lerp

  columns: [id, args, expected]
  rows:
    - [midpoint,  [0, 100, 0.5],  50]
    - [quarter,   [0, 10, 0.25],  2.5]
    - [start,     [0, 100, 0],    0]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:12:42Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
