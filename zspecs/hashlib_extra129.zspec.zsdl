spec: hashlib_extra129
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha224/sha256/sha384/sha512 constructor __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s class identity and __module__/__qualname__ / new __class__.__name__ / algorithms_guaranteed __len__()==14 (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership / algorithms_available membership / new/__qualname__/__len__() (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ equality (table + invariants)."
    - "hashlib_extra94.zspec.zsdl — covers hashlib.algorithms_available/algorithms_guaranteed set class identity / sha256/sha512/sha1/md5 constructor __class__.__name__=='builtin_function_or_method' (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra94 through hashlib_extra99."
    - "Wave 279 theme: hashlib sha constructor __qualname__.__len__() values and sha3/shake __qualname__.__len__() values — first anchor for all constructor qualname lengths."
    - "hashlib.sha256.__qualname__.__len__() == 14 ('openssl_sha256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__qualname__.__len__() == 14 ('openssl_sha512'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__.__len__() == 12 ('openssl_sha1'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__qualname__.__len__() == 11 ('openssl_md5'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__qualname__.__len__() == 14 ('openssl_sha224'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__qualname__.__len__() == 14 ('openssl_sha384'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__qualname__.__len__() == 16 ('openssl_sha3_256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__qualname__.__len__() == 16 ('openssl_sha3_512'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224.__qualname__.__len__() == 16 ('openssl_sha3_224'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384.__qualname__.__len__() == 16 ('openssl_sha3_384'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128.__qualname__.__len__() == 17 ('openssl_shake_128'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256.__qualname__.__len__() == 17 ('openssl_shake_256'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: sha256/sha512/sha224/sha384 all share qualname length 14; sha3_256/sha3_512/sha3_224/sha3_384 all share length 16; shake_128/shake_256 both have length 17. sha1 has length 12; md5 has length 11."
    - "Note: All OpenSSL-backed constructor qualnames carry the 'openssl_' prefix (8 chars), so the total length is 8 + len(algorithm_name). sha256=14, sha3_256=16, shake_128=17."
    - "Note: __qualname__.__len__() is distinct from __name__.__len__() for top-level C builtins — they are equal because __name__ == __qualname__ for these functions."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256.__qualname__.__len__()==14
# hashlib.sha512.__qualname__.__len__()==14
# hashlib.sha1.__qualname__.__len__()==12
# hashlib.md5.__qualname__.__len__()==11
# hashlib.sha224.__qualname__.__len__()==14
# hashlib.sha384.__qualname__.__len__()==14
#
# Wave 279 theme: classic SHA constructor __qualname__.__len__() values.
#
# All six classic SHA-family constructors carry the 'openssl_' prefix in their
# __qualname__. sha256/sha512/sha224/sha384 all have length 14 ('openssl_' 8 +
# 'sha256'/'sha512'/'sha224'/'sha384' 6). sha1 has length 12 ('openssl_sha1' 8+4).
# md5 has length 11 ('openssl_md5' 8+3). extra95 anchors __qualname__ equality;
# no prior hashlib spec anchors __qualname__.__len__() for these six under
# hashlibqlen129. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra129.sha_constructor_qualname_lengths:
  description: "hashlib.sha256/__qualname__/__len__()==14 / sha512/__qualname__/__len__()==14 / sha1/__qualname__/__len__()==12 / md5/__qualname__/__len__()==11 / sha224/__qualname__/__len__()==14 / sha384/__qualname__/__len__()==14 — all carry 'openssl_' prefix (8 chars) plus the algorithm name; sha256/sha512/sha224/sha384 share length 14; extra95 anchors qualname equality; first hashlibqlen129 anchor for constructor qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashlibqlen129

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_qlen, sha256.__qualname__.__len__, [], 14, "'openssl_sha256' is 14 chars ('openssl_'8 + 'sha256'6)"]
    - [sha512_qlen, sha512.__qualname__.__len__, [], 14, "'openssl_sha512' is 14 chars ('openssl_'8 + 'sha512'6)"]
    - [sha1_qlen,   sha1.__qualname__.__len__,   [], 12, "'openssl_sha1' is 12 chars ('openssl_'8 + 'sha1'4)"]
    - [md5_qlen,    md5.__qualname__.__len__,     [], 11, "'openssl_md5' is 11 chars ('openssl_'8 + 'md5'3)"]
    - [sha224_qlen, sha224.__qualname__.__len__,  [], 14, "'openssl_sha224' is 14 chars ('openssl_'8 + 'sha224'6)"]
    - [sha384_qlen, sha384.__qualname__.__len__,  [], 14, "'openssl_sha384' is 14 chars ('openssl_'8 + 'sha384'6)"]

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__qualname__.__len__()==16
# hashlib.sha3_512.__qualname__.__len__()==16
# hashlib.sha3_224.__qualname__.__len__()==16
# hashlib.sha3_384.__qualname__.__len__()==16
#
# Wave 279 theme: SHA-3 constructor __qualname__.__len__() values.
#
# All four SHA-3 constructors share qualname length 16: 'openssl_sha3_256' (8+8),
# 'openssl_sha3_512' (8+8), 'openssl_sha3_224' (8+8), 'openssl_sha3_384' (8+8).
# The 'sha3_' infix adds 5 chars to the algorithm base name relative to sha1/sha256
# etc. extra98 anchors sha3 __qualname__ equality; no prior hashlib spec anchors
# sha3 __qualname__.__len__() under hashlibqlen129. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra129.sha3_constructor_qualname_lengths:
  description: "hashlib.sha3_256/__qualname__/__len__()==16 / sha3_512/__qualname__/__len__()==16 / sha3_224/__qualname__/__len__()==16 / sha3_384/__qualname__/__len__()==16 — all four SHA-3 constructors share qualname length 16 ('openssl_sha3_xxx' = 'openssl_'8 + 'sha3_xxx'8); extra98 anchors sha3 qualname equality; first hashlibqlen129 anchor for sha3 qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashlibqlen129

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_qlen, sha3_256.__qualname__.__len__, [], 16, "'openssl_sha3_256' is 16 chars ('openssl_'8 + 'sha3_256'8)"]
    - [sha3_512_qlen, sha3_512.__qualname__.__len__, [], 16, "'openssl_sha3_512' is 16 chars ('openssl_'8 + 'sha3_512'8)"]
    - [sha3_224_qlen, sha3_224.__qualname__.__len__, [], 16, "'openssl_sha3_224' is 16 chars ('openssl_'8 + 'sha3_224'8)"]
    - [sha3_384_qlen, sha3_384.__qualname__.__len__, [], 16, "'openssl_sha3_384' is 16 chars ('openssl_'8 + 'sha3_384'8)"]

# ---------------------------------------------------------------------------
# hashlib.shake_128.__qualname__.__len__()==17
# hashlib.shake_256.__qualname__.__len__()==17
# hashlib.sha256.__qualname__.__len__()==14 (cross-check)
# hashlib.sha3_256.__qualname__.__len__()==16 (cross-check)
#
# Wave 279 theme: shake constructor __qualname__.__len__() and cross-group comparison.
#
# shake_128 and shake_256 both have qualname length 17: 'openssl_shake_128' (8+9)
# and 'openssl_shake_256' (8+9). The 'shake_' infix (6 chars) plus the 3-digit
# suffix (3 chars) = 9 total algorithm chars. extra98 anchors shake __qualname__
# equality; no prior hashlib spec anchors shake __qualname__.__len__() under
# hashlibqlen129. Cross-check: sha256 has 14 and sha3_256 has 16 for comparison.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra129.shake_constructor_qualname_lengths:
  description: "hashlib.shake_128/__qualname__/__len__()==17 / shake_256/__qualname__/__len__()==17 / sha256/__qualname__/__len__()==14 (cross-check) / sha3_256/__qualname__/__len__()==16 (cross-check) — shake_128 and shake_256 share length 17 ('openssl_shake_xxx'=8+9); longer than sha3_xxx (16) and sha_xxx (14); extra98 anchors shake qualname equality; first hashlibqlen129 anchor for shake qualname lengths"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: hashlibqlen129

  columns: [id, function, args, expected, description]
  rows:
    - [shake_128_qlen,      shake_128.__qualname__.__len__,  [], 17, "'openssl_shake_128' is 17 chars ('openssl_'8 + 'shake_128'9)"]
    - [shake_256_qlen,      shake_256.__qualname__.__len__,  [], 17, "'openssl_shake_256' is 17 chars ('openssl_'8 + 'shake_256'9)"]
    - [sha256_cross_check,  sha256.__qualname__.__len__,     [], 14, "sha256 qualname length 14 for cross-group comparison with sha3 (16) and shake (17)"]
    - [sha3_256_cross_check, sha3_256.__qualname__.__len__,  [], 16, "sha3_256 qualname length 16 for cross-group comparison with sha256 (14) and shake (17)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__qualname__.__len__()==14 — standalone
#
# hashlib.sha256.__qualname__.__len__() is 14. sha256.__qualname__ is
# 'openssl_sha256' — the 'openssl_' prefix (8 chars) plus the 6-char algorithm
# name 'sha256'. For top-level C builtins, __qualname__ equals __name__, so
# both have length 14. extra95 anchors sha256.__qualname__.__eq__('openssl_sha256');
# no prior hashlib spec anchors sha256.__qualname__.__len__()==14 as a standalone
# under hashlibqlen129. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra129.sha256_qualname_len_14:
  description: "hashlib.sha256.__qualname__.__len__() == 14 — sha256.__qualname__ is 'openssl_sha256' (8-char 'openssl_' prefix + 6-char 'sha256'); for top-level C builtins __qualname__ == __name__ so both are 14 chars; extra95 anchors qualname equality; first standalone for sha256.__qualname__.__len__() under hashlibqlen129"
  category: qualname_lengths
  kind: python_call_eq
  function: sha256.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# hashlib.md5.__qualname__.__len__()==11 — standalone
#
# hashlib.md5.__qualname__.__len__() is 11. md5.__qualname__ is 'openssl_md5' —
# the shortest among all six classic SHA-family constructors. The 'openssl_'
# prefix (8 chars) plus the 3-char algorithm name 'md5' = 11. extra95 anchors
# md5.__qualname__.__eq__('openssl_md5'); extra99 anchors md5.__name__.__eq__
# ('openssl_md5'); no prior hashlib spec anchors md5.__qualname__.__len__()==11
# as a standalone under hashlibqlen129. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra129.md5_qualname_len_11:
  description: "hashlib.md5.__qualname__.__len__() == 11 — md5.__qualname__ is 'openssl_md5' (8-char 'openssl_' prefix + 3-char 'md5'); shortest qualname among classic SHA-family constructors; extra95 anchors qualname equality; extra99 anchors __name__ equality; first standalone for md5.__qualname__.__len__() under hashlibqlen129"
  category: qualname_lengths
  kind: python_call_eq
  function: md5.__qualname__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# hashlib.sha1.__qualname__.__len__()==12 — standalone
#
# hashlib.sha1.__qualname__.__len__() is 12. sha1.__qualname__ is 'openssl_sha1' —
# the 'openssl_' prefix (8 chars) plus the 4-char algorithm name 'sha1' = 12.
# This is longer than md5 (11) but shorter than sha256/sha512/sha224/sha384 (all 14).
# extra95 anchors sha1.__qualname__.__eq__('openssl_sha1'); no prior hashlib spec
# anchors sha1.__qualname__.__len__()==12 as a standalone under hashlibqlen129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra129.sha1_qualname_len_12:
  description: "hashlib.sha1.__qualname__.__len__() == 12 — sha1.__qualname__ is 'openssl_sha1' (8-char 'openssl_' prefix + 4-char 'sha1'); longer than md5 (11) but shorter than sha256/sha224/sha384/sha512 (all 14); extra95 anchors qualname equality; first standalone for sha1.__qualname__.__len__() under hashlibqlen129"
  category: qualname_lengths
  kind: python_call_eq
  function: sha1.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# hashlib.shake_128.__qualname__.__len__()==17 — standalone
#
# hashlib.shake_128.__qualname__.__len__() is 17. shake_128.__qualname__ is
# 'openssl_shake_128' — the longest qualname among all hashlib constructors.
# The 'openssl_' prefix (8 chars) plus 'shake_128' (9 chars) = 17. shake_128
# and shake_256 share this maximum length. extra98 anchors
# shake_128.__qualname__.__eq__('openssl_shake_128'); no prior hashlib spec
# anchors shake_128.__qualname__.__len__()==17 as a standalone under hashlibqlen129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra129.shake_128_qualname_len_17:
  description: "hashlib.shake_128.__qualname__.__len__() == 17 — shake_128.__qualname__ is 'openssl_shake_128' (8-char 'openssl_' prefix + 9-char 'shake_128'); longest qualname among all hashlib constructors; shake_128 and shake_256 share this maximum length 17; extra98 anchors qualname equality; first standalone for shake_128.__qualname__.__len__() under hashlibqlen129"
  category: qualname_lengths
  kind: python_call_eq
  function: shake_128.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__qualname__.__len__()==16 — standalone
#
# hashlib.sha3_256.__qualname__.__len__() is 16. sha3_256.__qualname__ is
# 'openssl_sha3_256' — the 'openssl_' prefix (8 chars) plus 'sha3_256' (8 chars)
# = 16. All four SHA-3 constructors (sha3_224, sha3_256, sha3_384, sha3_512) share
# this length because 'sha3_224'/'sha3_256'/'sha3_384'/'sha3_512' are all 8 chars.
# extra98 anchors sha3_256.__qualname__.__eq__('openssl_sha3_256'); no prior hashlib
# spec anchors sha3_256.__qualname__.__len__()==16 as a standalone under hashlibqlen129.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra129.sha3_256_qualname_len_16:
  description: "hashlib.sha3_256.__qualname__.__len__() == 16 — sha3_256.__qualname__ is 'openssl_sha3_256' (8-char 'openssl_' prefix + 8-char 'sha3_256'); all four SHA-3 constructors share length 16 since sha3_224/sha3_256/sha3_384/sha3_512 are all 8-char algorithm names; extra98 anchors qualname equality; first standalone for sha3_256.__qualname__.__len__() under hashlibqlen129"
  category: qualname_lengths
  kind: python_call_eq
  function: sha3_256.__qualname__.__len__
  args: []
  expected: 16
