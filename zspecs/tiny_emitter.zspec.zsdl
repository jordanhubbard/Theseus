spec: tiny_emitter
version: ">=2.0.0"
backend: node(tiny-emitter)

docs: https://github.com/scottcorgan/tiny-emitter#readme

provenance:
  derived_from:
    - "tiny-emitter README — https://github.com/scottcorgan/tiny-emitter#readme"
    - "Test vectors verified with tiny-emitter via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "tiny-emitter source"
  notes:
    - "~250B browser-friendly event emitter — used by many small UI libs."
    - "Install: npm install tiny-emitter"
    - "v2 CJS; module export IS the constructor; .TinyEmitter is the same constructor (named export)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Methods never throw."
  stderr: "null"
  stickiness: "N/A — each emitter independent."
  codes: {}

invariant tiny_emitter.module_is_constructor:
  description: "Module export is a function (the TinyEmitter constructor)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant tiny_emitter.has_TinyEmitter_named:
  description: "Module exposes TinyEmitter as a named export (alias of itself)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "TinyEmitter.constructor.name"}
  expected: "Function"

invariant tiny_emitter.instance_has_emit:
  description: "Instance has .emit method"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {get: "emit.constructor.name"}
  expected: "Function"

invariant tiny_emitter.instance_has_on:
  description: "Instance has .on method"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {get: "on.constructor.name"}
  expected: "Function"

invariant tiny_emitter.instance_has_off:
  description: "Instance has .off method"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {get: "off.constructor.name"}
  expected: "Function"

invariant tiny_emitter.instance_has_once:
  description: "Instance has .once method"
  category: shape
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {get: "once.constructor.name"}
  expected: "Function"

invariant tiny_emitter.constructor_arity_zero:
  description: "TinyEmitter constructor takes no arguments"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 0
