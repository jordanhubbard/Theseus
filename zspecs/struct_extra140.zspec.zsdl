spec: struct_extra140
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra139.zspec.zsdl — covers struct module-level function __qualname__ string equality (pack/unpack/calcsize/pack_into/unpack_from/iter_unpack) / all six + Struct/__module__.__eq__('_struct') / full __doc__ length ordering (calcsize=66 < unpack=173 < pack=176 < unpack_from=188 < iter_unpack=239 < pack_into=274) (table + invariants)."
    - "struct_extra138.zspec.zsdl — covers Struct method __qualname__ string equality (pack/unpack/pack_into/unpack_from/iter_unpack) / __qualname__ length ordering / error.__name__/__qualname__/__bases__[0].__name__/__bases__[0].__name__.__len__() (table + invariants)."
    - "struct_extra137.zspec.zsdl — covers struct.pack/__doc__/__class__.__name__.__eq__('str') / Struct.format/__doc__/__len__()==20 / Struct.size/__doc__/__len__()==20 / format vs size __doc__ inequality / module function __doc__ length ordering (calcsize/unpack/pack/pack_into)."
    - "struct_extra136.zspec.zsdl — covers struct.Struct method __doc__ lengths (pack/pack_into/unpack/unpack_from/iter_unpack) / module-level pack_into/unpack_from/iter_unpack __doc__ lengths / module-level vs Struct-method __doc__ inequality."
    - "struct_extra135.zspec.zsdl — covers struct.Struct.__eq__ inherited from object / struct.error MRO member names / struct module-level function __doc__ lengths (pack/unpack/calcsize) / struct.__doc__.__len__() and __class__.__name__."
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths (all six) / Struct.size and Struct.format __doc__ equality and lengths / struct module __doc__ length."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() / error.__name__/__len__()."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__()."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra139."
    - "Wave 304 theme: struct.Struct.format/__class__.__name__.__eq__('getset_descriptor') / Struct.size/__class__.__name__.__eq__('getset_descriptor') / Struct.format/__qualname__.__eq__('Struct.format') and __len__()==13 / Struct.size/__qualname__.__eq__('Struct.size') and __len__()==11 / struct.__doc__.__class__.__name__.__eq__('str') and __len__()==1278 / struct.error/__doc__ is None (NoneType) / struct.error/__module__.__eq__('struct')."
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor' (len 17). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor' (len 17). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__qualname__ == 'Struct.format' (len 13). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__qualname__ == 'Struct.size' (len 11). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.__doc__.__len__() == 1278. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__doc__ is None (type NoneType). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct' (len 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.format and struct.Struct.size are both getset_descriptor objects (17 chars, not property objects). A getset_descriptor is a C-level descriptor created by PyGetSetDef in the C extension; it differs from Python's property class in that it is defined in C and has no Python getter function (fget). extra98 anchors Struct.size/Struct.__format__ getset_descriptor class names; this spec anchors format and size together."
    - "Note: struct.Struct.format.__qualname__ is 'Struct.format' (13 chars = 7-char 'Struct.' prefix + 6-char 'format'). struct.Struct.size.__qualname__ is 'Struct.size' (11 chars = 7-char prefix + 4-char 'size'). format (13) is 2 chars longer than size (11) because 'format' (6) is 2 chars longer than 'size' (4)."
    - "Note: struct.__doc__.__class__.__name__ is 'str' (the module docstring is a regular Python string). The module docstring is 1278 chars — substantially longer than the Struct class docstring (40 chars) because the module-level docstring describes all format characters and conventions."
    - "Note: struct.error.__doc__ is None (not a string). Exception classes defined in C extensions often have no docstring (None), unlike exceptions defined in Python source which typically have at least an empty-string docstring. struct.error is defined in the _struct C extension without a docstring."
    - "Note: struct.error.__module__ is 'struct' (6 chars), not '_struct'. This is because struct.error is exposed at the public module level (struct) and its __module__ attribute was set to 'struct' in the C implementation. This contrasts with struct.Struct.__module__ which is '_struct' (7 chars, with underscore)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.format.__class__.__name__.__eq__('getset_descriptor')
# struct.Struct.size.__class__.__name__.__eq__('getset_descriptor')
# struct.Struct.format.__class__.__name__.__len__()==17
# struct.Struct.format.__qualname__.__eq__('Struct.format')
# struct.Struct.size.__qualname__.__eq__('Struct.size')
#
# Wave 304 theme: Struct.format and Struct.size are getset_descriptor objects.
#
# Both Struct.format and Struct.size are C-level getset_descriptor objects (17 chars),
# not Python property objects. extra98 anchors Struct.size getset_descriptor class
# name and qualname; no prior struct spec anchors Struct.format getset_descriptor
# class name together with the qualname equality strings as a table under structprop140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra140.Struct_format_size_getset_identity:
  description: "struct.Struct.format/__class__.__name__.__eq__('getset_descriptor')==True / Struct.size/__class__.__name__.__eq__('getset_descriptor')==True / __class__.__name__.__len__()==17 / format/__qualname__.__eq__('Struct.format')==True / size/__qualname__.__eq__('Struct.size')==True — format and size are C-level getset_descriptor objects (17 chars), not Python properties; extra98 anchors size getset_descriptor; first structprop140 anchor for format class name and both qualname equality strings"
  kind: python_call_eq
  category: identity
  id_prefix: structprop140

  columns: [id, function, args, expected, description]
  rows:
    - [format_class_name,     Struct.format.__class__.__name__.__eq__, ["getset_descriptor"], true, "struct.Struct.format.__class__.__name__ == 'getset_descriptor' (C-level, not Python property)"]
    - [size_class_name,       Struct.size.__class__.__name__.__eq__,   ["getset_descriptor"], true, "struct.Struct.size.__class__.__name__ == 'getset_descriptor' (same C-level descriptor type as format)"]
    - [format_class_name_len, Struct.format.__class__.__name__.__len__, [],                   17,   "struct.Struct.format.__class__.__name__.__len__() is 17 ('getset_descriptor' = 17 chars)"]
    - [format_qualname_eq,    Struct.format.__qualname__.__eq__,       ["Struct.format"],     true, "struct.Struct.format.__qualname__ == 'Struct.format' (7-char prefix + 6-char 'format'; total 13)"]
    - [size_qualname_eq,      Struct.size.__qualname__.__eq__,         ["Struct.size"],       true, "struct.Struct.size.__qualname__ == 'Struct.size' (7-char prefix + 4-char 'size'; total 11)"]

# ---------------------------------------------------------------------------
# struct.Struct.format.__qualname__.__len__()==13
# struct.Struct.size.__qualname__.__len__()==11
#
# Wave 304 theme: Struct.format qualname (13) is 2 chars longer than Struct.size (11).
#
# The 'Struct.' prefix (7 chars) plus 'format' (6 chars) gives 13 chars for format.
# The 'Struct.' prefix (7 chars) plus 'size' (4 chars) gives 11 chars for size.
# format (13) is 2 chars longer than size (11) because 'format' (6) is 2 chars
# longer than 'size' (4). No prior struct spec anchors both qualname lengths
# together as a table under structprop140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra140.Struct_format_size_qualname_lengths:
  description: "struct.Struct.format/__qualname__/__len__()==13 / size/__qualname__/__len__()==11 — format (13 = 7 + 6) is 2 chars longer than size (11 = 7 + 4) because 'format' (6) is 2 chars longer than 'size' (4); both use the 7-char 'Struct.' prefix; no prior struct spec anchors both together as a table; first structprop140 anchor for this qualname length pair"
  kind: python_call_eq
  category: qualname_lengths
  id_prefix: structprop140

  columns: [id, function, args, expected, description]
  rows:
    - [format_qualname_len, Struct.format.__qualname__.__len__, [], 13, "struct.Struct.format.__qualname__.__len__() is 13 ('Struct.format' = 7-char prefix + 6-char 'format')"]
    - [size_qualname_len,   Struct.size.__qualname__.__len__,   [], 11, "struct.Struct.size.__qualname__.__len__() is 11 ('Struct.size' = 7-char prefix + 4-char 'size'; 2 chars shorter than format)"]

# ---------------------------------------------------------------------------
# struct.__doc__.__class__.__name__.__eq__('str')
# struct.__doc__.__len__()==1278
# struct.error.__doc__ is None (NoneType)
# struct.error.__module__.__eq__('struct')
# struct.error.__module__.__len__()==6
#
# Wave 304 theme: struct module docstring (str, 1278 chars) vs error.__doc__ (None).
#
# struct.__doc__ is a str (1278 chars). struct.error.__doc__ is None (NoneType),
# unlike the module-level docstring. struct.error.__module__ is 'struct' (6 chars,
# without underscore), different from Struct.__module__ ('_struct', 7 chars).
# extra135 anchors struct.__doc__.__len__() and __class__.__name__; extra97 anchors
# Struct/__module__/__len__()==7 and error/__module__/__len__()==6; no prior struct
# spec anchors struct.__doc__.__len__()==1278 or error.__doc__ None-class or
# error.__module__ equality string as a table under structprop140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra140.struct_doc_and_error_identity:
  description: "struct.__doc__/__class__.__name__.__eq__('str')==True / __doc__/__len__()==1278 / struct.error/__module__.__eq__('struct')==True / error/__module__/__len__()==6 — module docstring is 1278-char str; error.__doc__ is None; error.__module__ is 'struct' (6 chars, no underscore) unlike Struct.__module__ ('_struct', 7 chars); extra135 anchors __doc__.__class__.__name__; extra97 anchors error/__module__/__len__()==6; first structprop140 anchor for __doc__.__len__()==1278 and error module equality string"
  kind: python_call_eq
  category: identity
  id_prefix: structprop140

  columns: [id, function, args, expected, description]
  rows:
    - [doc_class_str,      __doc__.__class__.__name__.__eq__,   ["str"],    true, "struct.__doc__.__class__.__name__ == 'str' (module docstring is a regular Python string)"]
    - [doc_len_1278,       __doc__.__len__,                     [],         1278, "struct.__doc__.__len__() is 1278 (comprehensive format-character reference; 1278 chars)"]
    - [error_module_eq,    error.__module__.__eq__,             ["struct"], true, "struct.error.__module__ == 'struct' (6 chars; public module name without underscore)"]
    - [error_module_len,   error.__module__.__len__,            [],         6,    "struct.error.__module__.__len__() is 6 ('struct' = 6 chars; no underscore unlike '_struct' = 7)"]

# ---------------------------------------------------------------------------
# struct.Struct.format.__class__.__name__.__eq__('getset_descriptor') — standalone
#
# struct.Struct.format.__class__.__name__ is 'getset_descriptor'. format is a
# C-level getset_descriptor that returns the format string used to create the
# Struct instance (e.g., '>I' for a big-endian unsigned int). A getset_descriptor
# is defined by PyGetSetDef in the C extension and has no Python-level getter
# function, unlike a property object. extra98 anchors Struct.size as a
# getset_descriptor; no prior struct spec anchors Struct.format class name as a
# standalone under structprop140. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra140.Struct_format_class_getset_descriptor:
  description: "struct.Struct.format.__class__.__name__.__eq__('getset_descriptor') == True — C-level descriptor returning the format string (e.g., '>I'); defined by PyGetSetDef in _struct.c; different from Python property (no fget function); extra98 anchors Struct.size as getset_descriptor; first standalone for Struct.format class name under structprop140"
  category: identity
  kind: python_call_eq
  function: Struct.format.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.format.__qualname__.__eq__('Struct.format') — standalone
#
# struct.Struct.format.__qualname__ is 'Struct.format' (13 chars). The qualname
# 'Struct.format' uses the 7-char 'Struct.' prefix plus the 6-char 'format'.
# At 13 chars, format has the longer qualname of the two Struct attributes
# (format=13 vs size=11). The format descriptor returns the format string that
# was used to create the Struct instance — it stores the original format
# specification passed to the Struct constructor. No prior struct spec anchors
# Struct.format.__qualname__ == 'Struct.format' as a standalone under structprop140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra140.Struct_format_qualname_eq:
  description: "struct.Struct.format.__qualname__.__eq__('Struct.format') == True — 'Struct.format' (13 chars = 7-char 'Struct.' + 6-char 'format'); format descriptor returns the original format string passed to Struct(); longer qualname than size (11 chars); no prior struct spec anchors this as a standalone; first standalone under structprop140"
  category: qualname_identity
  kind: python_call_eq
  function: Struct.format.__qualname__.__eq__
  args: ["Struct.format"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.size.__qualname__.__eq__('Struct.size') — standalone
#
# struct.Struct.size.__qualname__ is 'Struct.size' (11 chars). The qualname
# 'Struct.size' uses the 7-char 'Struct.' prefix plus the 4-char 'size'.
# At 11 chars, size has the shorter qualname of the two Struct attributes
# (size=11 vs format=13). The size descriptor returns the number of bytes
# required to represent the struct — equivalent to calcsize(format_string).
# No prior struct spec anchors Struct.size.__qualname__ == 'Struct.size' as
# a standalone under structprop140. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra140.Struct_size_qualname_eq:
  description: "struct.Struct.size.__qualname__.__eq__('Struct.size') == True — 'Struct.size' (11 chars = 7-char 'Struct.' + 4-char 'size'); size descriptor returns number of bytes needed for the struct; shorter qualname than format (13 chars); no prior struct spec anchors this as a standalone; first standalone under structprop140"
  category: qualname_identity
  kind: python_call_eq
  function: Struct.size.__qualname__.__eq__
  args: ["Struct.size"]
  expected: true

# ---------------------------------------------------------------------------
# struct.__doc__.__len__()==1278 — standalone
#
# struct.__doc__.__len__() is 1278. The module docstring documents all format
# characters (x, c, b, B, h, H, i, I, l, L, q, Q, n, N, e, f, d, s, p, P),
# byte-order prefixes (@, =, <, >, !), and the padding rules. At 1278 chars it
# is substantially longer than Struct.__doc__ (40 chars), which merely names the
# class and its constructor signature. extra135 anchors struct.__doc__.__len__()
# at table level; this standalone cross-checks it under structprop140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra140.struct_doc_len_1278:
  description: "struct.__doc__.__len__() == 1278 — module docstring documents all format characters and byte-order prefixes; 1278 chars; substantially longer than Struct.__doc__ (40 chars); extra135 anchors at table level; cross-check standalone under structprop140"
  category: doc_lengths
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 1278

# ---------------------------------------------------------------------------
# struct.error.__module__.__eq__('struct') — standalone
#
# struct.error.__module__ is 'struct' (6 chars). struct.error is defined in the
# _struct C extension but its __module__ is set to 'struct' (the public module
# name, without underscore) rather than '_struct'. This means struct.error
# reports itself as belonging to the public 'struct' module, making the error
# class easier to catch and identify by users. By contrast, struct.Struct.__module__
# is '_struct' (7 chars, with underscore). No prior struct spec anchors
# struct.error.__module__.__eq__('struct') as a standalone under structprop140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra140.error_module_eq_struct:
  description: "struct.error.__module__.__eq__('struct') == True — 'struct' (6 chars, no underscore); struct.error is exposed at public module level; contrast with Struct.__module__ == '_struct' (7 chars, with underscore); no prior struct spec anchors this as a standalone; first standalone under structprop140"
  category: identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true
