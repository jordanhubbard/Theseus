spec: re_extra61
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra60.zspec.zsdl — covers re.__all__.__contains__ membership; re.__package__.__eq__('re'); re Pattern/error __doc__.__class__.__name__.__len__()==3."
    - "re_extra59.zspec.zsdl — covers re.__all__.__class__.__name__.__eq__('list') and __all__.__len__()==31; Pattern/Match/error/RegexFlag __eq__/__repr__/__hash__.__class__.__name__ chains."
    - "re_extra40.zspec.zsdl — covers re.__name__.__len__()==2; re.__package__.__len__()==2; re.__file__.__class__.__name__.__len__()==3."
  notes:
    - "This spec extends re_extra60.zspec.zsdl."
    - "Wave 225 theme: __loader__ identity + __spec__ attribute chains + __file__/__cached__ class name checks."
    - "re in Python 3.11+ is a package (Lib/re/__init__.py). Its loader is a SourceFileLoader instance. Therefore re.__loader__.__class__.__name__ == 'SourceFileLoader'."
    - "re.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — re is a pure Python package loaded by SourceFileLoader. The loader is an instance of SourceFileLoader, so __loader__.__class__.__name__ is 'SourceFileLoader'. No prior re spec checks __loader__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — the module's __spec__ is an importlib.machinery.ModuleSpec instance. No prior re spec checks __spec__.__class__.__name__.__eq__('ModuleSpec') as a table anchor. Novel for re. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.__file__.__class__.__name__.__eq__('str') == True — re_extra40 covers __file__.__class__.__name__.__len__()==3 (length). This equality anchor is distinct and novel in the reloader61 namespace. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "re.__cached__.__class__.__name__.__eq__('str') == True — re has a __cached__ attribute pointing to the compiled .pyc bytecode. Its type is str. No prior re spec checks __cached__.__class__.__name__. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.__loader__.__class__.__name__.__eq__('SourceFileLoader')
#
# re is a pure Python package (Lib/re/__init__.py) loaded by importlib's
# SourceFileLoader. The loader is a SourceFileLoader instance, so its
# __class__.__name__ is 'SourceFileLoader'.
#
# This contrasts with io where __loader__ is the FrozenImporter class object
# itself (=> __class__.__name__ == 'type').
#
# No prior re spec checks __loader__.__class__.__name__.
# Novel anchor in reloader61 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra61.loader_class_name:
  description: "re.__loader__.__class__.__name__.__eq__('SourceFileLoader') — re is a pure Python package (Lib/re/__init__.py) loaded by SourceFileLoader; the loader is an instance so __loader__.__class__.__name__=='SourceFileLoader'; contrasts with io (FrozenImporter class object => 'type'); no prior re spec checks __loader__.__class__.__name__; novel anchor in reloader61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: reloader61ldr

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_SourceFileLoader, __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true]

# ---------------------------------------------------------------------------
# re.__spec__.__class__.__name__.__eq__('ModuleSpec')
#
# The re module's __spec__ attribute is an importlib.machinery.ModuleSpec
# instance. The class name of ModuleSpec is 'ModuleSpec'.
#
#   re.__spec__.__class__.__name__.__eq__('ModuleSpec') == True
#
# No prior re spec checks __spec__.__class__.__name__.__eq__('ModuleSpec').
# Novel in reloader61 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra61.spec_class_name:
  description: "re.__spec__.__class__.__name__.__eq__('ModuleSpec') — re.__spec__ is an importlib.machinery.ModuleSpec instance; __spec__.__class__.__name__=='ModuleSpec'; no prior re spec checks __spec__.__class__.__name__ equality; novel in reloader61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: reloader61spec

  columns: [id, function, args, expected]
  rows:
    - [spec_class_name_ModuleSpec, "__spec__.__class__.__name__.__eq__", ["ModuleSpec"], true]

# ---------------------------------------------------------------------------
# re.__file__.__class__.__name__.__eq__('str')
# re.__cached__.__class__.__name__.__eq__('str')
#
# re is a pure Python package with both __file__ (path to re/__init__.py)
# and __cached__ (path to the compiled .pyc bytecode). Both are str.
#
#   re.__file__.__class__.__name__.__eq__('str')    == True
#   re.__cached__.__class__.__name__.__eq__('str')  == True
#
# re_extra40 covers __file__.__class__.__name__.__len__()==3 (length).
# The equality anchor __file__.__class__.__name__.__eq__('str') is distinct.
# No prior re spec checks __cached__.__class__.__name__. Both novel.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra61.file_cached_class_names:
  description: "re.__file__/__cached__.__class__.__name__.__eq__('str') — re is pure Python with both __file__ (path to re/__init__.py) and __cached__ (path to .pyc bytecode); both are str; re_extra40 covers __file__.__class__.__name__.__len__()==3 (length) but not __eq__('str') equality; no prior re spec checks __cached__.__class__.__name__; both novel anchors in reloader61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: reloader61files

  columns: [id, function, args, expected]
  rows:
    - [file_class_name_eq_str,   __file__.__class__.__name__.__eq__,   ["str"], true]
    - [cached_class_name_eq_str, __cached__.__class__.__name__.__eq__, ["str"], true]

invariant re_extra61.loader_class_name_SourceFileLoader:
  description: "re.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — re is a pure Python package loaded by SourceFileLoader; no prior re spec checks __loader__.__class__.__name__; novel anchor in reloader61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant re_extra61.spec_class_name_ModuleSpec:
  description: "re.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — re.__spec__ is an importlib.machinery.ModuleSpec instance; no prior re spec checks __spec__.__class__.__name__ equality; novel anchor in reloader61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant re_extra61.file_class_name_eq_str:
  description: "re.__file__.__class__.__name__.__eq__('str') == True — re.__file__ is a str path to re/__init__.py; re_extra40 covers the length (3) but not the equality; this equality anchor is novel in reloader61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __file__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra61.cached_class_name_eq_str:
  description: "re.__cached__.__class__.__name__.__eq__('str') == True — re.__cached__ is a str path to the compiled .pyc bytecode; no prior re spec checks __cached__.__class__.__name__; novel anchor in reloader61 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __cached__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
