table socket_extra213.getaddrinfo_doc_contains_extra:
  description: "socket.getaddrinfo __doc__ contains checks in socketdoc213a namespace — wave 213 theme: socket.getaddrinfo.__doc__.__contains__('family')==True; socket.getaddrinfo.__doc__.__contains__('socket')==True; socket.getaddrinfo.__doc__.__contains__('sequence')==True; socket.getaddrinfo.__doc__.__contains__('domain')==True; socket.getaddrinfo.__doc__.__contains__('service')==True; socket.getaddrinfo.__doc__.__contains__('Resolve')==True; socket.getaddrinfo.__doc__.__contains__('proto')==True; getaddrinfo resolves host/port into address info sequence with family, socket type, proto fields; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: socketdoc213a

  columns: [id, function, args, expected, description]
  rows:
    - [getaddrinfo_doc_has_family,   socket.getaddrinfo.__doc__.__contains__, ["family"],   true, "socket.getaddrinfo.__doc__ contains 'family'; family argument narrows address family; verified with Python 3.14.3"]
    - [getaddrinfo_doc_has_socket,   socket.getaddrinfo.__doc__.__contains__, ["socket"],   true, "socket.getaddrinfo.__doc__ contains 'socket'; results used to create a socket; verified with Python 3.14.3"]
    - [getaddrinfo_doc_has_sequence, socket.getaddrinfo.__doc__.__contains__, ["sequence"], true, "socket.getaddrinfo.__doc__ contains 'sequence'; returns a sequence of 5-tuples; verified with Python 3.14.3"]
    - [getaddrinfo_doc_has_domain,   socket.getaddrinfo.__doc__.__contains__, ["domain"],   true, "socket.getaddrinfo.__doc__ contains 'domain'; host is a domain name; verified with Python 3.14.3"]
    - [getaddrinfo_doc_has_service,  socket.getaddrinfo.__doc__.__contains__, ["service"],  true, "socket.getaddrinfo.__doc__ contains 'service'; port may be a string service name; verified with Python 3.14.3"]
    - [getaddrinfo_doc_has_Resolve,  socket.getaddrinfo.__doc__.__contains__, ["Resolve"],  true, "socket.getaddrinfo.__doc__ contains 'Resolve'; doc begins 'Resolve host and port'; verified with Python 3.14.3"]
    - [getaddrinfo_doc_has_proto,    socket.getaddrinfo.__doc__.__contains__, ["proto"],    true, "socket.getaddrinfo.__doc__ contains 'proto'; proto argument can narrow results; verified with Python 3.14.3"]

