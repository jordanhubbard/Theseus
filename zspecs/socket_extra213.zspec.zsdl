spec: socket_extra213
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All __doc__ contains checks verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket.__doc__ contains 'subclass', 'makefile', 'method', 'adding'."
    - "socket.getaddrinfo.__doc__ contains 'family', 'socket', 'sequence', 'domain', 'service', 'Resolve', 'proto'."
    - "socket.gethostname.__doc__ contains 'Return', 'current', 'string'."
    - "socket.gethostbyname.__doc__ contains 'address', 'IP', 'string', 'form'."
    - "socket.create_connection.__doc__ contains 'source', 'timeout', 'connect', 'tuple'."
    - "socket.setdefaulttimeout.__doc__ contains 'default', 'float', 'None', 'imported'."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket — __doc__ contains checks (different words from wave 379)
#
# socket.socket.__doc__ contains 'subclass', 'method', 'adding'
# ---------------------------------------------------------------------------

table socket_extra213.socket_class_doc_contains_extra:
  description: "socket.socket class __doc__ contains checks in socketdoc213 namespace — wave 213 theme: socket.socket.__doc__.__contains__('subclass')==True; socket.socket.__doc__.__contains__('method')==True; socket.socket.__doc__.__contains__('adding')==True; socket.socket's doc reads 'A subclass of _socket.socket adding the makefile() method'; all three words appear in this brief one-sentence docstring; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: socketdoc213

  columns: [id, function, args, expected, description]
  rows:
    - [socket_doc_has_subclass, socket.socket.__doc__.__contains__, ["subclass"], true, "socket.socket.__doc__ contains 'subclass'; socket.socket is a subclass of _socket.socket; verified with Python 3.14.3"]
    - [socket_doc_has_method,   socket.socket.__doc__.__contains__, ["method"],   true, "socket.socket.__doc__ contains 'method'; doc mentions the makefile() method; verified with Python 3.14.3"]
    - [socket_doc_has_adding,   socket.socket.__doc__.__contains__, ["adding"],   true, "socket.socket.__doc__ contains 'adding'; doc reads 'adding the makefile() method'; verified with Python 3.14.3"]
    - [socket_doc_has_makefile, socket.socket.__doc__.__contains__, ["makefile"], true, "socket.socket.__doc__ contains 'makefile'; confirms makefile() is the added method; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
