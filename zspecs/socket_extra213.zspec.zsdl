table socket_extra213.hostname_timeout_doc_contains_extra:
  description: "socket.gethostname, socket.gethostbyname, socket.create_connection, socket.setdefaulttimeout __doc__ contains checks in socketdoc213b namespace — wave 213 theme: socket.gethostname.__doc__.__contains__('Return')==True; socket.gethostname.__doc__.__contains__('current')==True; socket.gethostname.__doc__.__contains__('string')==True; socket.gethostbyname.__doc__.__contains__('address')==True; socket.gethostbyname.__doc__.__contains__('IP')==True; socket.gethostbyname.__doc__.__contains__('form')==True; socket.create_connection.__doc__.__contains__('source')==True; socket.create_connection.__doc__.__contains__('connect')==True; socket.create_connection.__doc__.__contains__('tuple')==True; socket.setdefaulttimeout.__doc__.__contains__('default')==True; socket.setdefaulttimeout.__doc__.__contains__('float')==True; socket.setdefaulttimeout.__doc__.__contains__('None')==True; socket.setdefaulttimeout.__doc__.__contains__('imported')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: socketdoc213b

  columns: [id, function, args, expected, description]
  rows:
    - [gethostname_doc_has_Return,     socket.gethostname.__doc__.__contains__,        ["Return"],  true, "socket.gethostname.__doc__ contains 'Return'; doc reads 'Return the current host name'; verified with Python 3.14.3"]
    - [gethostname_doc_has_current,    socket.gethostname.__doc__.__contains__,        ["current"], true, "socket.gethostname.__doc__ contains 'current'; returns the current host name; verified with Python 3.14.3"]
    - [gethostname_doc_has_string,     socket.gethostname.__doc__.__contains__,        ["string"],  true, "socket.gethostname.__doc__ contains 'string'; doc reads 'gethostname() -> string'; verified with Python 3.14.3"]
    - [gethostbyname_doc_has_address,  socket.gethostbyname.__doc__.__contains__,      ["address"], true, "socket.gethostbyname.__doc__ contains 'address'; returns IP address; verified with Python 3.14.3"]
    - [gethostbyname_doc_has_IP,       socket.gethostbyname.__doc__.__contains__,      ["IP"],      true, "socket.gethostbyname.__doc__ contains 'IP'; returns the IP address; verified with Python 3.14.3"]
    - [gethostbyname_doc_has_form,     socket.gethostbyname.__doc__.__contains__,      ["form"],    true, "socket.gethostbyname.__doc__ contains 'form'; doc reads 'a string of the form 255.255.255.255'; verified with Python 3.14.3"]
    - [create_conn_doc_has_source,     socket.create_connection.__doc__.__contains__,  ["source"],  true, "socket.create_connection.__doc__ contains 'source'; source_address parameter to bind before connecting; verified with Python 3.14.3"]
    - [create_conn_doc_has_connect,    socket.create_connection.__doc__.__contains__,  ["connect"], true, "socket.create_connection.__doc__ contains 'connect'; doc reads 'Connect to *address*'; verified with Python 3.14.3"]
    - [create_conn_doc_has_tuple,      socket.create_connection.__doc__.__contains__,  ["tuple"],   true, "socket.create_connection.__doc__ contains 'tuple'; address is a (host, port) 2-tuple; verified with Python 3.14.3"]
    - [setdefaulttimeout_doc_has_default, socket.setdefaulttimeout.__doc__.__contains__, ["default"], true, "socket.setdefaulttimeout.__doc__ contains 'default'; sets the default timeout; verified with Python 3.14.3"]
    - [setdefaulttimeout_doc_has_float,   socket.setdefaulttimeout.__doc__.__contains__, ["float"],   true, "socket.setdefaulttimeout.__doc__ contains 'float'; timeout is measured in seconds as a float; verified with Python 3.14.3"]
    - [setdefaulttimeout_doc_has_None,    socket.setdefaulttimeout.__doc__.__contains__, ["None"],    true, "socket.setdefaulttimeout.__doc__ contains 'None'; None value means no timeout; verified with Python 3.14.3"]
    - [setdefaulttimeout_doc_has_imported, socket.setdefaulttimeout.__doc__.__contains__, ["imported"], true, "socket.setdefaulttimeout.__doc__ contains 'imported'; default is None when module is first imported; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — socket_extra213
# ---------------------------------------------------------------------------

invariant socket_extra213.socket_doc_contains_subclass:
  description: "socket.socket.__doc__.__contains__('subclass') returns True — socket.socket's docstring reads 'A subclass of _socket.socket adding the makefile() method'; the word 'subclass' describes socket.socket's relationship to _socket.socket; socket.socket (defined in Lib/socket.py) is a Python-level subclass of _socket.socket (the C extension class in Modules/socketmodule.c); the Python subclass adds the makefile() method for file-like I/O; this inheritance means socket.socket inherits all C-level socket operations while gaining the Python-level makefile() convenience method; NEW in socket_extra213: first standalone socket.__doc__.__contains__('subclass') invariant in socketdoc213 namespace; wave 213; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.socket.__doc__.__contains__
  args: ["subclass"]
  expected: true

invariant socket_extra213.getaddrinfo_doc_contains_family:
  description: "socket.getaddrinfo.__doc__.__contains__('family') returns True — socket.getaddrinfo's docstring reads 'The family, type and proto arguments can be optionally specified in order to narrow the list of addresses returned'; the word 'family' refers to the address family such as socket.AF_INET (IPv4), socket.AF_INET6 (IPv6), or socket.AF_UNIX (Unix domain sockets); passing socket.AF_INET as family restricts getaddrinfo to return only IPv4 addresses; passing 0 (the default) returns all address families; the family field is the first element of each 5-tuple returned by getaddrinfo; NEW in socket_extra213: first standalone getaddrinfo.__doc__.__contains__('family') invariant; wave 213; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.getaddrinfo.__doc__.__contains__
  args: ["family"]
  expected: true

invariant socket_extra213.setdefaulttimeout_doc_contains_float:
  description: "socket.setdefaulttimeout.__doc__.__contains__('float') returns True — socket.setdefaulttimeout's docstring reads 'Set the default timeout in seconds (float) for new socket objects'; the word 'float' specifies the type of the timeout parameter; the timeout is measured in seconds and can be a fractional value like 2.5 (2500 milliseconds); using float allows sub-second timeout granularity; a value of 0.0 would set the socket to non-blocking mode; a value of None removes the timeout (blocking mode); the parenthetical '(float)' is a type annotation hint in the docstring; NEW in socket_extra213: first standalone setdefaulttimeout.__doc__.__contains__('float') invariant; wave 213; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.setdefaulttimeout.__doc__.__contains__
  args: ["float"]
  expected: true

invariant socket_extra213.create_connection_doc_contains_source:
  description: "socket.create_connection.__doc__.__contains__('source') returns True — socket.create_connection's docstring reads 'If *source_address* is set it must be a tuple of (host, port) for the socket to bind as a source address before making the connection'; the word 'source' appears as part of 'source_address' and 'source address'; the source_address parameter allows specifying the local bind address before connecting, which is needed when a host has multiple network interfaces and the connection must originate from a specific one; NEW in socket_extra213: first standalone create_connection.__doc__.__contains__('source') invariant; wave 213; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: socket.create_connection.__doc__.__contains__
  args: ["source"]
  expected: true

