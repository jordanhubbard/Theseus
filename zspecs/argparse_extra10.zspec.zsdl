spec: argparse_extra10
version: ">=3.9"
backend: python_module(argparse)

docs: https://docs.python.org/3/library/argparse.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/argparse.html — Python argparse module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/argparse.py"
    - "argparse.zspec.zsdl — covers __name__ table for all public classes, nargs constants, SUPPRESS/REMAINDER, parse_args, Namespace attrs, MRO checks"
    - "argparse_formatters.zspec.zsdl — covers formatter __name__/__module__/__bases__ tables, FileType, BooleanOptionalAction __bases__, exception __bases__"
    - "argparse_extra.zspec.zsdl — covers ArgumentParser/Namespace/HelpFormatter/ArgumentError/Action __name__/__module__, Action.__bases__[0], ArgumentDefaultsHelpFormatter/__name__, FileType/__name__/__module__, parse_args/__name__, add_argument/__name__"
    - "argparse_extra2.zspec.zsdl — covers __module__ table for formatters/exceptions, __bases__[0].__name__ invariants for ArgumentParser/Namespace/ArgumentError/ArgumentTypeError/HelpFormatter/RawText*/RawDescription*/ArgumentDefaults*"
    - "argparse_extra3.zspec.zsdl — covers class_names table, nargs_constants table, ArgumentParser/__module__, Namespace instance class, ArgumentError/ArgumentTypeError __bases__[0], ArgumentParser().prog type"
    - "argparse_extra4.zspec.zsdl — covers __qualname__ table for ArgumentParser/Namespace/Action/FileType/HelpFormatter/RawDescription*/RawText*/ArgumentDefaults*/MetavarType*/ArgumentError/ArgumentTypeError"
    - "argparse_extra5.zspec.zsdl — covers argparse module __name__, FileType/__bases__[0], BooleanOptionalAction/__bases__[0], SUPPRESS/REMAINDER/ONE_OR_MORE/ZERO_OR_MORE/OPTIONAL __class__.__name__"
    - "argparse_extra6.zspec.zsdl — covers BooleanOptionalAction/__qualname__, PARSER value/class, Namespace/__bases__[0].__name__, HelpFormatter/__bases__[0].__name__, ArgumentParser method names (set_defaults/format_help/format_usage/parse_known_args), ArgumentParser().description"
    - "argparse_extra7.zspec.zsdl — covers Action/__module__, FileType/__module__, formatter_bases table, ONE_OR_MORE __ne__/__len__, ArgumentParser().prefix_chars, ArgumentParser().add_help, formatter __name__ standalone invariants"
    - "argparse_extra8.zspec.zsdl — covers __bases__.__len__()==1 for ArgumentParser/Namespace/Action/HelpFormatter; ArgumentParser method names print_usage/print_help/convert_arg_line_to_args/exit/error"
    - "argparse_extra9.zspec.zsdl — covers FileType/ArgumentError/ArgumentTypeError metaclasses; ArgumentParser method names parse_intermixed_args/parse_known_intermixed_args/add_argument_group/add_mutually_exclusive_group/get_default; RawDescriptionHelpFormatter.__bases__.__len__()==1"
  notes:
    - "This spec extends the argparse chain; it does NOT duplicate invariants already present in any prior spec."
    - "Focus: __bases__.__len__()==1 for RawTextHelpFormatter/MetavarTypeHelpFormatter/ArgumentDefaultsHelpFormatter/BooleanOptionalAction/FileType/ArgumentError/ArgumentTypeError (extra8 covers ArgumentParser/Namespace/Action/HelpFormatter; extra9 covers RawDescriptionHelpFormatter; the remaining 7 are new); HelpFormatter method names start_section/end_section/add_usage/add_text/add_argument/format_help (no prior spec checks HelpFormatter methods); ArgumentParser.add_subparsers.__name__ (not in extra or any prior spec)."
    - "argparse.RawTextHelpFormatter.__bases__.__len__() == 1 — extra8 covers ArgumentParser/Namespace/Action/HelpFormatter; extra9 covers RawDescriptionHelpFormatter; RawTextHelpFormatter is new."
    - "argparse.MetavarTypeHelpFormatter.__bases__.__len__() == 1 — same gap."
    - "argparse.ArgumentDefaultsHelpFormatter.__bases__.__len__() == 1 — same gap."
    - "argparse.BooleanOptionalAction.__bases__.__len__() == 1 — same gap."
    - "argparse.FileType.__bases__.__len__() == 1 — same gap."
    - "argparse.ArgumentError.__bases__.__len__() == 1 — same gap."
    - "argparse.ArgumentTypeError.__bases__.__len__() == 1 — same gap."
    - "argparse.HelpFormatter.start_section.__name__ == 'start_section' — no prior spec checks any HelpFormatter instance method names."
    - "argparse.HelpFormatter.end_section.__name__ == 'end_section' — same gap."
    - "argparse.HelpFormatter.add_text.__name__ == 'add_text' — same gap."
    - "argparse.HelpFormatter.format_help.__name__ == 'format_help' — same gap."
    - "argparse.ArgumentParser.add_subparsers.__name__ == 'add_subparsers' — not in extra, extra6, extra8, or extra9."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__.__len__() == 1 for remaining formatter and exception classes.
#
# argparse_extra8 covers ArgumentParser/Namespace/Action/HelpFormatter.
# argparse_extra9 covers RawDescriptionHelpFormatter.
# This table adds: RawTextHelpFormatter, MetavarTypeHelpFormatter,
# ArgumentDefaultsHelpFormatter, BooleanOptionalAction, FileType,
# ArgumentError, ArgumentTypeError.
# ---------------------------------------------------------------------------

table argparse_extra10.bases_len:
  kind: python_call_eq
  category: hierarchy
  id_prefix: baselen10

  columns: [id, function, args, expected]
  rows:
    - [RawTextHelpFormatter,           RawTextHelpFormatter.__bases__.__len__,           [], 1]
    - [MetavarTypeHelpFormatter,       MetavarTypeHelpFormatter.__bases__.__len__,       [], 1]
    - [ArgumentDefaultsHelpFormatter,  ArgumentDefaultsHelpFormatter.__bases__.__len__,  [], 1]
    - [BooleanOptionalAction,          BooleanOptionalAction.__bases__.__len__,          [], 1]
    - [FileType,                       FileType.__bases__.__len__,                       [], 1]
    - [ArgumentError,                  ArgumentError.__bases__.__len__,                  [], 1]
    - [ArgumentTypeError,              ArgumentTypeError.__bases__.__len__,              [], 1]

# ---------------------------------------------------------------------------
# HelpFormatter method names.
#
# No prior argparse spec checks method names on HelpFormatter itself.
# These are the public methods used by action groups to build help text.
# ---------------------------------------------------------------------------

table argparse_extra10.HelpFormatter.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: hfmeth10

  columns: [id, function, args, expected]
  rows:
    - [start_section, HelpFormatter.start_section.__name__.__eq__, ["start_section"], true]
    - [end_section,   HelpFormatter.end_section.__name__.__eq__,   ["end_section"],   true]
    - [add_text,      HelpFormatter.add_text.__name__.__eq__,      ["add_text"],      true]
    - [format_help,   HelpFormatter.format_help.__name__.__eq__,   ["format_help"],   true]

# ---------------------------------------------------------------------------
# ArgumentParser.add_subparsers method name.
#
# No prior argparse spec checks add_subparsers.__name__. This method is the
# primary way to implement sub-commands with argparse.
# ---------------------------------------------------------------------------

invariant argparse_extra10.ArgumentParser.add_subparsers_name:
  description: "argparse.ArgumentParser.add_subparsers.__name__ == 'add_subparsers'"
  category: method_names
  kind: python_call_eq
  function: ArgumentParser.add_subparsers.__name__.__eq__
  args: ["add_subparsers"]
  expected: true

# ---------------------------------------------------------------------------
# BooleanOptionalAction.__bases__[0].__name__ == 'Action'
#
# argparse_extra5 checks BooleanOptionalAction.__bases__[0] via a different
# pattern (returning the class object). No prior spec checks the __name__ of
# that base class directly via __getitem__ + method.
# argparse_extra2 covers __bases__[0].__name__ for many classes but not
# BooleanOptionalAction (added in 3.9).
# ---------------------------------------------------------------------------

invariant argparse_extra10.BooleanOptionalAction.base_name:
  description: "argparse.BooleanOptionalAction.__bases__[0].__name__ == 'Action' — BooleanOptionalAction inherits from Action"
  category: hierarchy
  kind: python_call_eq
  function: BooleanOptionalAction.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Action"
