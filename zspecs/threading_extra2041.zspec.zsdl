spec: threading_extra2041
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rshift__, __and__, __or__, __xor__, __invert__ dict-presence checks."
    - "threading.Thread, threading.Event, threading.Lock, threading.Condition, threading.Semaphore, threading.Barrier are not bitwise types — none define bitwise operators."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"
error_model: python_exceptions

table threading_extra2041.lshift_protocol:
  description: "threading types __lshift__/__rlshift__/__ilshift__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2041
  columns: [id, function, args, expected]
  rows:
    - ["th2041001", "threading.Thread.__dict__.__contains__",    ["__lshift__"],  false]
    - ["th2041002", "threading.Event.__dict__.__contains__",     ["__lshift__"],  false]
    - ["th2041003", "threading.Lock.__dict__.__contains__",      ["__lshift__"],  false]
    - ["th2041004", "threading.Thread.__dict__.__contains__",    ["__rlshift__"], false]
    - ["th2041005", "threading.Event.__dict__.__contains__",     ["__rlshift__"], false]
    - ["th2041006", "threading.Lock.__dict__.__contains__",      ["__rlshift__"], false]
    - ["th2041007", "threading.Thread.__dict__.__contains__",    ["__ilshift__"], false]
    - ["th2041008", "threading.Event.__dict__.__contains__",     ["__ilshift__"], false]
    - ["th2041009", "threading.Lock.__dict__.__contains__",      ["__ilshift__"], false]

