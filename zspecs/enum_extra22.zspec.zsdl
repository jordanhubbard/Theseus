spec: enum_extra22
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl through enum_extra21.zspec.zsdl."
    - "enum_extra21 covers: combined __qualname__ table for Enum/IntEnum/Flag/IntFlag/StrEnum/auto/unique; combined __module__ table for the same seven; EnumMeta.__qualname__ == 'EnumType' standalone."
    - "enum_extra18 covers: EnumType/__qualname__.__len__; EnumMeta/__qualname__.__len__; member/__qualname__.__eq__; nonmember/__qualname__.__eq__."
    - "enum_extra14 covers: ReprEnum/__name__/__qualname__; EnumType/__name__."
    - "enum_extra12 covers: ReprEnum/__qualname__/__bases__.__len__."
    - "enum_extra9 covers: FlagBoundary/__name__/__module__; ReprEnum/__name__/__module__."
    - "Focus of this spec: (1) FlagBoundary.__qualname__ standalone; (2) FlagBoundary.__mro__.__len__() == 6; (3) FlagBoundary.__mro__ entries [1] and [5] by name; (4) ReprEnum.__mro__.__len__() == 3; (5) ReprEnum.__module__ standalone; (6) combined __name__ table for Enum/IntEnum/Flag/IntFlag in a single table distinct from prior specs."
    - "NOT yet covered (entering this spec): FlagBoundary.__qualname__ standalone invariant; FlagBoundary.__mro__.__len__() == 6; FlagBoundary.__mro__[1].__name__ == 'StrEnum'; FlagBoundary.__mro__[5].__name__ == 'object'; ReprEnum.__mro__.__len__() == 3; combined __name__ table for Enum/IntEnum/Flag/IntFlag."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Combined __name__ table for Enum, IntEnum, Flag, IntFlag
#
# Prior specs cover these __name__ values as standalone invariants scattered
# across enum_extra14 and later specs. No prior spec has Enum/IntEnum/Flag/IntFlag
# together as a single combined table in the enum_extra22 namespace.
# Enum.__name__ == 'Enum', IntEnum.__name__ == 'IntEnum',
# Flag.__name__ == 'Flag', IntFlag.__name__ == 'IntFlag'.
# ---------------------------------------------------------------------------

table enum_extra22.base_class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [Enum,    Enum.__name__.__eq__,    ["Enum"],    true]
    - [IntEnum, IntEnum.__name__.__eq__, ["IntEnum"], true]
    - [Flag,    Flag.__name__.__eq__,    ["Flag"],    true]
    - [IntFlag, IntFlag.__name__.__eq__, ["IntFlag"], true]

# ---------------------------------------------------------------------------
# FlagBoundary.__qualname__ standalone
#
# enum_extra9 covers FlagBoundary.__name__ and FlagBoundary.__module__ as
# standalone invariants. enum_extra12 covers FlagBoundary/__qualname__ only in
# a note entry. No prior spec encodes FlagBoundary.__qualname__.__eq__ as a
# callable invariant in any spec namespace.
# ---------------------------------------------------------------------------

invariant enum_extra22.FlagBoundary.qualname_eq:
  description: "enum.FlagBoundary.__qualname__ == 'FlagBoundary' (Python 3.11+)"
  category: qualnames
  kind: python_call_eq
  function: FlagBoundary.__qualname__.__eq__
  args: ["FlagBoundary"]
  expected: true

# ---------------------------------------------------------------------------
# FlagBoundary.__mro__ length and selected entries
#
# FlagBoundary is a StrEnum subclass; its MRO is:
#   [FlagBoundary, StrEnum, str, ReprEnum, Enum, object] — length 6.
# No prior spec covers FlagBoundary.__mro__.__len__() or its MRO entries.
# ---------------------------------------------------------------------------

invariant enum_extra22.FlagBoundary.mro.len:
  description: "enum.FlagBoundary.__mro__.__len__() == 6 — [FlagBoundary, StrEnum, str, ReprEnum, Enum, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: FlagBoundary.__mro__.__len__().__eq__
  args: [6]
  expected: true

invariant enum_extra22.FlagBoundary.mro.index1.name:
  description: "enum.FlagBoundary.__mro__[1].__name__ == 'StrEnum' — FlagBoundary inherits from StrEnum"
  category: class_hierarchy
  kind: python_call_eq
  function: FlagBoundary.__mro__.__getitem__(1).__name__.__eq__
  args: ["StrEnum"]
  expected: true

invariant enum_extra22.FlagBoundary.mro.index5.name:
  description: "enum.FlagBoundary.__mro__[5].__name__ == 'object' — last entry in FlagBoundary MRO is object"
  category: class_hierarchy
  kind: python_call_eq
  function: FlagBoundary.__mro__.__getitem__(5).__name__.__eq__
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# ReprEnum.__mro__ length
#
# ReprEnum is a thin Enum subclass; its MRO is:
#   [ReprEnum, Enum, object] — length 3.
# enum_extra12 covers ReprEnum/__qualname__ and ReprEnum/__bases__.__len__.
# No prior spec covers ReprEnum.__mro__.__len__().
# ---------------------------------------------------------------------------

invariant enum_extra22.ReprEnum.mro.len:
  description: "enum.ReprEnum.__mro__.__len__() == 3 — [ReprEnum, Enum, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: ReprEnum.__mro__.__len__().__eq__
  args: [3]
  expected: true

invariant enum_extra22.ReprEnum.mro.index1.name:
  description: "enum.ReprEnum.__mro__[1].__name__ == 'Enum' — ReprEnum's parent is Enum"
  category: class_hierarchy
  kind: python_call_eq
  function: ReprEnum.__mro__.__getitem__(1).__name__.__eq__
  args: ["Enum"]
  expected: true
