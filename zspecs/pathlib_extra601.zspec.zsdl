spec: pathlib_extra601
version: ">=3.9"
backend: python_module(pathlib)
docs: "Behavioral spec for pathlib class __doc__ type and PurePath method qualnames"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers pathlib class __doc__ attribute type and PurePath method qualname identity"
  created_at: "2026-04-12T00:00:00Z"

table pathlib_extra601.pl601dc:
  id_prefix: pl601dc

  description: "pathlib class __doc__ attributes are str instances"
  columns: [id, function, args, expected]
  rows:
    - [pl601dc01, "pathlib.Path.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [pl601dc02, "pathlib.PurePath.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [pl601dc03, "pathlib.PosixPath.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [pl601dc04, "pathlib.WindowsPath.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [pl601dc05, "pathlib.PurePosixPath.__doc__.__class__.__name__.__eq__", ["str"], true]
    - [pl601dc06, "pathlib.PureWindowsPath.__doc__.__class__.__name__.__eq__", ["str"], true]

table pathlib_extra601.pl601qn:
  id_prefix: pl601qn

  description: "pathlib.PurePath method qualnames"
  columns: [id, function, args, expected]
  rows:
    - [pl601qn01, "pathlib.PurePath.__str__.__qualname__.__eq__", ["PurePath.__str__"], true]
    - [pl601qn02, "pathlib.PurePath.__repr__.__qualname__.__eq__", ["PurePath.__repr__"], true]
    - [pl601qn03, "pathlib.PurePath.__eq__.__qualname__.__eq__", ["PurePath.__eq__"], true]
    - [pl601qn04, "pathlib.PurePath.__hash__.__qualname__.__eq__", ["PurePath.__hash__"], true]
    - [pl601qn05, "pathlib.PurePath.__lt__.__qualname__.__eq__", ["PurePath.__lt__"], true]
    - [pl601qn06, "pathlib.PurePath.__truediv__.__qualname__.__eq__", ["PurePath.__truediv__"], true]
    - [pl601qn07, "pathlib.PurePath.with_name.__qualname__.__eq__", ["PurePath.with_name"], true]
    - [pl601qn08, "pathlib.PurePath.with_suffix.__qualname__.__eq__", ["PurePath.with_suffix"], true]
