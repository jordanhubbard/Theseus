spec: contextlib_extra15
version: ">=3.10"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra14.zspec.zsdl."
    - "contextlib_extra14 covers: ExitStack MRO[1]/[2]/[3]; aclosing MRO[1]; nullcontext/__module__; closing/__module__; redirect_stdout/__module__; ContextDecorator/__qualname__; AsyncContextDecorator/__qualname__; AbstractContextManager/__qualname__; AbstractAsyncContextManager/__qualname__."
    - "contextlib_extra13 covers: suppress().__enter__() is None; AbstractContextManager MRO len/[1]; AbstractAsyncContextManager MRO len/[1]; nullcontext(True/0/False).__enter__()."
    - "contextlib_extra11 covers: redirect_stdout MRO len (5); redirect_stderr MRO len (5); __abstractmethods__.__len__ == 0 for suppress/closing/nullcontext/aclosing/redirect_stdout/redirect_stderr."
    - "NEW axes: redirect_stdout MRO[1] and MRO[2]; redirect_stderr MRO[1] and MRO[2]; nullcontext MRO[1] and MRO[2]; AsyncExitStack MRO len and MRO[1]/[2]/[3]; suppress.__name__ as standalone __eq__ invariant; aclosing MRO[2]."
    - "contextlib.redirect_stdout.__mro__[1].__name__ == '_RedirectStream' — private intermediate base."
    - "contextlib.redirect_stdout.__mro__[2].__name__ == 'AbstractContextManager' — abstract protocol."
    - "contextlib.redirect_stderr.__mro__[1].__name__ == '_RedirectStream' — same intermediate base as redirect_stdout."
    - "contextlib.redirect_stderr.__mro__[2].__name__ == 'AbstractContextManager' — abstract protocol."
    - "contextlib.nullcontext.__mro__[1].__name__ == 'AbstractContextManager' — first abstract base."
    - "contextlib.nullcontext.__mro__[2].__name__ == 'AbstractAsyncContextManager' — second abstract base."
    - "contextlib.AsyncExitStack.__mro__.__len__() == 5 — [AsyncExitStack, _BaseExitStack, AbstractAsyncContextManager, ABC, object]."
    - "contextlib.AsyncExitStack.__mro__[1].__name__ == '_BaseExitStack' — shared internal base with ExitStack."
    - "contextlib.AsyncExitStack.__mro__[2].__name__ == 'AbstractAsyncContextManager' — async abstract protocol."
    - "contextlib.AsyncExitStack.__mro__[3].__name__ == 'ABC' — ABC in AsyncExitStack MRO."
    - "contextlib.aclosing.__mro__[2].__name__ == 'ABC' — ABC is third in aclosing MRO."
    - "contextlib.suppress.__name__ == 'suppress' — standalone __eq__ invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# redirect_stdout MRO intermediate entries
#
# contextlib_extra11 confirmed redirect_stdout MRO length == 5.
# No prior spec checks the intermediate entries MRO[1] and MRO[2].
# redirect_stdout MRO: [redirect_stdout, _RedirectStream, AbstractContextManager, ABC, object]
# ---------------------------------------------------------------------------

invariant contextlib_extra15.redirect_stdout.mro_1:
  description: "contextlib.redirect_stdout.__mro__[1].__name__ == '_RedirectStream' — private intermediate base"
  category: redirect_mro
  kind: python_call_eq
  function: redirect_stdout.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "_RedirectStream"

invariant contextlib_extra15.redirect_stdout.mro_2:
  description: "contextlib.redirect_stdout.__mro__[2].__name__ == 'AbstractContextManager' — abstract protocol in MRO"
  category: redirect_mro
  kind: python_call_eq
  function: redirect_stdout.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "AbstractContextManager"

# ---------------------------------------------------------------------------
# redirect_stderr MRO intermediate entries
#
# contextlib_extra11 confirmed redirect_stderr MRO length == 5.
# No prior spec checks redirect_stderr MRO[1] or MRO[2].
# redirect_stderr MRO: [redirect_stderr, _RedirectStream, AbstractContextManager, ABC, object]
# ---------------------------------------------------------------------------

invariant contextlib_extra15.redirect_stderr.mro_1:
  description: "contextlib.redirect_stderr.__mro__[1].__name__ == '_RedirectStream' — shared private base with redirect_stdout"
  category: redirect_mro
  kind: python_call_eq
  function: redirect_stderr.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "_RedirectStream"

invariant contextlib_extra15.redirect_stderr.mro_2:
  description: "contextlib.redirect_stderr.__mro__[2].__name__ == 'AbstractContextManager' — abstract protocol in MRO"
  category: redirect_mro
  kind: python_call_eq
  function: redirect_stderr.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "AbstractContextManager"

# ---------------------------------------------------------------------------
# nullcontext MRO intermediate entries
#
# contextlib_extra11 confirmed nullcontext MRO length == 5.
# No prior spec checks nullcontext MRO[1] or MRO[2].
# nullcontext MRO: [nullcontext, AbstractContextManager, AbstractAsyncContextManager, ABC, object]
# Unlike redirect_*, nullcontext inherits from both abstract context manager ABCs.
# ---------------------------------------------------------------------------

invariant contextlib_extra15.nullcontext.mro_1:
  description: "contextlib.nullcontext.__mro__[1].__name__ == 'AbstractContextManager' — first abstract base in MRO"
  category: nullcontext_mro
  kind: python_call_eq
  function: nullcontext.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "AbstractContextManager"

invariant contextlib_extra15.nullcontext.mro_2:
  description: "contextlib.nullcontext.__mro__[2].__name__ == 'AbstractAsyncContextManager' — second abstract base in MRO"
  category: nullcontext_mro
  kind: python_call_eq
  function: nullcontext.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "AbstractAsyncContextManager"

# ---------------------------------------------------------------------------
# AsyncExitStack MRO — length and intermediate entries
#
# contextlib_extra10 covers ExitStack MRO length == 5.
# contextlib_extra14 covers ExitStack MRO[1]/[2]/[3] (ExitStack-specific).
# No prior spec checks AsyncExitStack MRO length or its intermediate entries.
# AsyncExitStack MRO: [AsyncExitStack, _BaseExitStack, AbstractAsyncContextManager, ABC, object]
# ---------------------------------------------------------------------------

invariant contextlib_extra15.AsyncExitStack.mro_len:
  description: "contextlib.AsyncExitStack.__mro__.__len__() == 5 — [AsyncExitStack, _BaseExitStack, AbstractAsyncContextManager, ABC, object]"
  category: async_exitstack_mro
  kind: python_call_eq
  function: AsyncExitStack.__mro__.__len__
  args: []
  expected: 5

invariant contextlib_extra15.AsyncExitStack.mro_1:
  description: "contextlib.AsyncExitStack.__mro__[1].__name__ == '_BaseExitStack' — shared internal base with ExitStack"
  category: async_exitstack_mro
  kind: python_call_eq
  function: AsyncExitStack.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "_BaseExitStack"

invariant contextlib_extra15.AsyncExitStack.mro_2:
  description: "contextlib.AsyncExitStack.__mro__[2].__name__ == 'AbstractAsyncContextManager' — async abstract protocol"
  category: async_exitstack_mro
  kind: python_call_eq
  function: AsyncExitStack.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "AbstractAsyncContextManager"

invariant contextlib_extra15.AsyncExitStack.mro_3:
  description: "contextlib.AsyncExitStack.__mro__[3].__name__ == 'ABC' — ABC in AsyncExitStack MRO"
  category: async_exitstack_mro
  kind: python_call_eq
  function: AsyncExitStack.__mro__.__getitem__
  args: [3]
  method: __name__
  expected: "ABC"

# ---------------------------------------------------------------------------
# aclosing MRO[2] — the ABC entry
#
# contextlib_extra14 checks aclosing MRO[1] == 'AbstractAsyncContextManager'.
# No prior spec checks aclosing MRO[2]. In the MRO
# [aclosing, AbstractAsyncContextManager, ABC, object], index 2 is ABC.
# ---------------------------------------------------------------------------

invariant contextlib_extra15.aclosing.mro_2:
  description: "contextlib.aclosing.__mro__[2].__name__ == 'ABC' — ABC is third in aclosing MRO"
  category: aclosing_mro
  kind: python_call_eq
  function: aclosing.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "ABC"

# ---------------------------------------------------------------------------
# suppress.__name__ — standalone __eq__ invariant
#
# contextlib_extra4 records suppress.__name__ in a table row.
# contextlib_extra12 covers standalone __name__ for contextmanager/closing/nullcontext etc.
# No prior spec asserts suppress.__name__ as a standalone __eq__ invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra15.suppress.name:
  description: "contextlib.suppress.__name__ == 'suppress' — standalone __eq__ invariant"
  category: class_names
  kind: python_call_eq
  function: suppress.__name__.__eq__
  args: ["suppress"]
  expected: true
