spec: depd
version: ">=2.0.0"
backend: node(depd)

docs: https://github.com/dougwilson/nodejs-depd#readme

provenance:
  derived_from:
    - "depd README — https://github.com/dougwilson/nodejs-depd#readme"
    - "Test vectors verified with depd via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "depd source"
  notes:
    - "Programmatic deprecation warnings — used by Express, body-parser, and other Node http frameworks."
    - "Install: npm install depd"
    - "v2 CJS; module export IS the depd(namespace) factory. Returned function is the deprecate logger; it carries _namespace and various helpers (.function, .property)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "Writes deprecation warnings to stderr unless silenced."
  stickiness: "Each namespace can be silenced via NO_DEPRECATION env var."
  codes: {}

invariant depd.module_is_function:
  description: "Module export is a function (factory)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant depd.module_arity:
  description: "Factory takes 1 arg (namespace)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 1

invariant depd.factory_returns_function:
  description: "depd('mymod') returns a function"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: ["mymod"]
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant depd.factory_records_namespace:
  description: "Returned logger carries the namespace as ._namespace"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: ["mymod"]
  chain:
    - {get: _namespace}
  expected: "mymod"

invariant depd.factory_has_function_helper:
  description: "Returned logger has .function helper"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: ["mymod"]
  chain:
    - {get: "function.constructor.name"}
  expected: "Function"

invariant depd.factory_has_property_helper:
  description: "Returned logger has .property helper"
  category: factory
  kind: node_chain_eq
  entry: module
  entry_args: ["mymod"]
  chain:
    - {get: "property.constructor.name"}
  expected: "Function"
