spec: re_extra249
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape, and compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern/Match/error class names, flags, match, search, sub, split, findall"
    - "re_extra248.zspec.zsdl — covers re.sub behavioral contracts and function identity"
  notes:
    - "This spec covers: re.search behavioral contracts — group, start, end, span, and the None case."
    - "re.search(r'\\d+', 'abc123def').group() == '123' — search finds digits in the interior; verified Python 3.14.3 macOS."
    - "re.search(r'\\d+', 'abc123def').start() == 3 — the match begins at index 3; verified Python 3.14.3 macOS."
    - "re.search(r'\\d+', 'abc123def').end() == 6 — the match ends at index 6 (exclusive); verified Python 3.14.3 macOS."
    - "re.search(r'\\d+', 'abc123def').span() == (3, 6) — span() returns (start, end) tuple; verified Python 3.14.3 macOS."
    - "re.search(r'\\d+', 'abc') is None — type(result).__name__ == 'NoneType'; verified Python 3.14.3 macOS."
    - "re.search(r'\\d+', 'abc123def').__class__.__name__ == 'Match' — successful search returns a Match object; verified Python 3.14.3 macOS."
    - "re.search(r'[a-z]+', 'hello world').group() == 'hello' — search for lowercase letters; verified Python 3.14.3 macOS."
    - "re.search(r'world', 'hello world').start() == 6 — search finds 'world' starting at position 6; verified Python 3.14.3 macOS."
    - "re.search function identity: __name__=='search', __module__=='re', __class__.__name__=='function'; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.search group() behavioral contracts
# group() returns the entire match string (same as group(0)).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra249.search_group:
  description: "re.search(pattern, string).group() behavioral contracts; verified Python 3.14.3"
  kind: python_call_eq
  category: search
  id_prefix: researchbeh249
  function: search
  method: group

  columns: [id, args, expected]
  rows:
    - [digits_abc123def,    ["\\d+", "abc123def"],    "123"]
    - [letters_hello_world, ["[a-z]+", "hello world"], "hello"]
    - [abc_in_abcdef,       ["abc", "abcdef"],         "abc"]
    - [world_in_string,     ["world", "hello world"],  "world"]
    - [digit_single,        ["\\d", "a1b2"],           "1"]

# ---------------------------------------------------------------------------
# re.search start() behavioral contracts
# start() returns the index in the string where the match begins.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra249.search_start:
  description: "re.search(pattern, string).start() behavioral contracts; verified Python 3.14.3"
  kind: python_call_eq
  category: search
  id_prefix: researchbeh249
  function: search
  method: start

  columns: [id, args, expected]
  rows:
    - [start_digits_abc123,  ["\\d+", "abc123def"],   3]
    - [start_abc_abcdef,     ["abc", "abcdef"],        0]
    - [start_world,          ["world", "hello world"], 6]
    - [start_letter_D,       ["[A-Z]", "abcDef"],      3]

# ---------------------------------------------------------------------------
# re.search end() behavioral contracts
# end() returns the index just past the end of the match (exclusive).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra249.search_end:
  description: "re.search(pattern, string).end() behavioral contracts; verified Python 3.14.3"
  kind: python_call_eq
  category: search
  id_prefix: researchbeh249
  function: search
  method: end

  columns: [id, args, expected]
  rows:
    - [end_digits_abc123,   ["\\d+", "abc123def"],   6]
    - [end_abc_abcdef,      ["abc", "abcdef"],        3]
    - [end_world,           ["world", "hello world"], 11]

# ---------------------------------------------------------------------------
# re.search — None result (no match) class name check
# re.search returns None when the pattern is not found.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra249.search_no_match:
  description: "re.search returns None for non-matching inputs; __class__.__name__ == 'NoneType'; verified Python 3.14.3"
  kind: python_call_eq
  category: search
  id_prefix: researchbeh249
  function: search
  method: __class__
  method_chain: __name__

  columns: [id, args, expected]
  rows:
    - [none_digits_abc,  ["\\d+",   "abc"],     "NoneType"]
    - [none_upper_lower, ["[A-Z]+", "abcdef"],  "NoneType"]
    - [none_world_foo,   ["world",  "hello"],   "NoneType"]

# ---------------------------------------------------------------------------
# re.search function identity
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra249.search_identity:
  description: "re.search function identity: __name__, __module__, __qualname__, __class__.__name__; verified Python 3.14.3"
  kind: python_call_eq
  category: function_identity
  id_prefix: researchbeh249

  columns: [id, function, args, expected]
  rows:
    - [name_eq,     search.__name__.__eq__,            ["search"],   true]
    - [module_eq,   search.__module__.__eq__,           ["re"],       true]
    - [qualname_eq, search.__qualname__.__eq__,         ["search"],   true]
    - [class_fn,    search.__class__.__name__.__eq__,   ["function"], true]
    - [name_not,    search.__name__.__eq__,             ["match"],    false]

# ---------------------------------------------------------------------------
# Standalone invariants — re.search group
# ---------------------------------------------------------------------------

invariant re_extra249.search.group.digits_abc123def:
  description: "re.search(r'\\d+', 'abc123def').group() == '123' — search finds the run of digits in the interior of the string; verified Python 3.14.3 macOS"
  category: search
  kind: python_call_eq
  function: search
  args: ["\\d+", "abc123def"]
  method: group
  expected: "123"

invariant re_extra249.search.group.hello_world:
  description: "re.search(r'[a-z]+', 'hello world').group() == 'hello' — search finds the first run of lowercase letters; verified Python 3.14.3 macOS"
  category: search
  kind: python_call_eq
  function: search
  args: ["[a-z]+", "hello world"]
  method: group
  expected: "hello"

# ---------------------------------------------------------------------------
# Standalone invariants — re.search start/end
# ---------------------------------------------------------------------------

invariant re_extra249.search.start.digits_abc123def:
  description: "re.search(r'\\d+', 'abc123def').start() == 3 — digits begin at index 3 (after 'abc'); verified Python 3.14.3 macOS"
  category: search
  kind: python_call_eq
  function: search
  args: ["\\d+", "abc123def"]
  method: start
  expected: 3

invariant re_extra249.search.end.digits_abc123def:
  description: "re.search(r'\\d+', 'abc123def').end() == 6 — digits end at index 6 (exclusive; '123' occupies positions 3,4,5); verified Python 3.14.3 macOS"
  category: search
  kind: python_call_eq
  function: search
  args: ["\\d+", "abc123def"]
  method: end
  expected: 6

invariant re_extra249.search.start.world:
  description: "re.search(r'world', 'hello world').start() == 6 — 'world' starts at index 6 in 'hello world'; verified Python 3.14.3 macOS"
  category: search
  kind: python_call_eq
  function: search
  args: ["world", "hello world"]
  method: start
  expected: 6

invariant re_extra249.search.end.world:
  description: "re.search(r'world', 'hello world').end() == 11 — 'world' (5 chars) ends at index 11 in 'hello world'; verified Python 3.14.3 macOS"
  category: search
  kind: python_call_eq
  function: search
  args: ["world", "hello world"]
  method: end
  expected: 11

# ---------------------------------------------------------------------------
# Standalone invariants — re.search no-match None type
# ---------------------------------------------------------------------------

invariant re_extra249.search.none.digits_in_abc:
  description: "re.search(r'\\d+', 'abc') returns None — type(result).__name__ == 'NoneType' when no match is found; verified Python 3.14.3 macOS"
  category: search
  kind: python_call_eq
  function: search
  args: ["\\d+", "abc"]
  method: __class__
  method_chain: __name__
  expected: "NoneType"

# ---------------------------------------------------------------------------
# Standalone invariants — re.search Match class
# ---------------------------------------------------------------------------

invariant re_extra249.search.match_class.digits_abc123def:
  description: "re.search(r'\\d+', 'abc123def').__class__.__name__ == 'Match' — a successful search returns a Match object; verified Python 3.14.3 macOS"
  category: search
  kind: python_call_eq
  function: search
  args: ["\\d+", "abc123def"]
  method: __class__
  method_chain: __name__
  expected: "Match"

# ---------------------------------------------------------------------------
# Standalone invariants — re.search function identity
# ---------------------------------------------------------------------------

invariant re_extra249.search.name_eq:
  description: "re.search.__name__ == 'search' — the function name is 'search'; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: search.__name__.__eq__
  args: ["search"]
  expected: true

invariant re_extra249.search.module_eq:
  description: "re.search.__module__ == 're' — search is defined in the re module; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: search.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra249.search.class_is_function:
  description: "re.search.__class__.__name__ == 'function' — search is a plain Python function; verified Python 3.14.3 macOS"
  category: function_identity
  kind: python_call_eq
  function: search.__class__.__name__.__eq__
  args: ["function"]
  expected: true
