spec: functools_extra205
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers __doc__.__class__.__name__ identity for public functools callables: partial, lru_cache, reduce, wraps, cached_property, singledispatch, update_wrapper, total_ordering."
    - "functools.partial.__doc__.__class__.__name__ == 'str' — partial is a C-level type with a string docstring. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__class__.__name__ == 'str' — lru_cache is a Python decorator factory with a string docstring. Verified with Python 3.14.3."
    - "functools.reduce.__doc__.__class__.__name__ == 'str' — reduce is a C-level builtin_function_or_method with a string docstring. Verified with Python 3.14.3."
    - "functools.wraps.__doc__.__class__.__name__ == 'str' — wraps is a Python function with a string docstring. Verified with Python 3.14.3."
    - "functools.cached_property.__doc__ is None — cached_property is a Python class whose __doc__ is None in Python 3.14.3; __class__.__name__ is 'NoneType'. Verified with Python 3.14.3."
    - "functools.singledispatch.__doc__.__class__.__name__ == 'str' — singledispatch is a Python function with a string docstring. Verified with Python 3.14.3."
    - "functools.update_wrapper.__doc__.__class__.__name__ == 'str' — update_wrapper is a Python function with a string docstring. Verified with Python 3.14.3."
    - "functools.total_ordering.__doc__.__class__.__name__ == 'str' — total_ordering is a Python function (class decorator) with a string docstring. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__.__class__.__name__ for C-level functools objects
#
# partial: C-level type; __doc__ is 'str'.
# reduce: C-level builtin_function_or_method; __doc__ is 'str'.
# cached_property: Python class; __doc__ is None → __class__.__name__ is 'NoneType'.
#
# These three represent the distinct docstring-presence patterns in functools.
# ---------------------------------------------------------------------------

table functools_extra205.doc_class_c_level:
  description: "functools C-level objects: partial.__doc__.__class__.__name__=='str'; reduce.__doc__.__class__.__name__=='str'; cached_property.__doc__.__class__.__name__=='NoneType'; new to extra205"
  kind: python_call_eq
  category: doc_class_identity
  id_prefix: functdocs205

  columns: [id, function, args, expected, description]
  rows:
    - [partial_doc_class_str,
       partial.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — partial is a C-level type; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra205"]
    - [reduce_doc_class_str,
       reduce.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.reduce.__doc__.__class__.__name__.__eq__('str') == True — reduce is a C-level builtin_function_or_method; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra205"]
    - [cached_property_doc_class_nonetype,
       cached_property.__doc__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "functools.cached_property.__doc__.__class__.__name__.__eq__('NoneType') == True — cached_property.__doc__ is None in Python 3.14.3; None.__class__.__name__ is 'NoneType'; new to extra205"]

# ---------------------------------------------------------------------------
# Table 2: __doc__.__class__.__name__ for Python-function functools decorators
#
# lru_cache, wraps, singledispatch: Python functions; __doc__ is 'str'.
# All three are decorator factories or decorator helpers in functools.
# ---------------------------------------------------------------------------

table functools_extra205.doc_class_py_decorators:
  description: "functools Python decorator functions: lru_cache, wraps, singledispatch __doc__.__class__.__name__=='str'; new to extra205"
  kind: python_call_eq
  category: doc_class_identity
  id_prefix: functdocs205

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_doc_class_str,
       lru_cache.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.lru_cache.__doc__.__class__.__name__.__eq__('str') == True — lru_cache is a Python decorator factory; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra205"]
    - [wraps_doc_class_str,
       wraps.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.wraps.__doc__.__class__.__name__.__eq__('str') == True — wraps is a Python decorator helper function; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra205"]
    - [singledispatch_doc_class_str,
       singledispatch.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.singledispatch.__doc__.__class__.__name__.__eq__('str') == True — singledispatch is a Python function (decorator factory); its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra205"]

# ---------------------------------------------------------------------------
# Table 3: __doc__.__class__.__name__ for remaining functools helpers
#
# update_wrapper, total_ordering: Python functions; __doc__ is 'str'.
# These are the remaining public functools callables not covered by tables 1-2.
# ---------------------------------------------------------------------------

table functools_extra205.doc_class_py_helpers:
  description: "functools Python helper functions: update_wrapper, total_ordering __doc__.__class__.__name__=='str'; new to extra205"
  kind: python_call_eq
  category: doc_class_identity
  id_prefix: functdocs205

  columns: [id, function, args, expected, description]
  rows:
    - [update_wrapper_doc_class_str,
       update_wrapper.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.update_wrapper.__doc__.__class__.__name__.__eq__('str') == True — update_wrapper is a Python function; its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra205"]
    - [total_ordering_doc_class_str,
       total_ordering.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.total_ordering.__doc__.__class__.__name__.__eq__('str') == True — total_ordering is a Python function (class decorator); its __doc__ is a non-None string; __class__.__name__ is 'str'; new to extra205"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra205
# ---------------------------------------------------------------------------

invariant functools_extra205.partial_doc_class:
  description: "functools.partial.__doc__.__class__.__name__ == 'str' — C-level type with string docstring; new to extra205"
  kind: python_call_eq
  function: partial.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra205.lru_cache_doc_class:
  description: "functools.lru_cache.__doc__.__class__.__name__ == 'str' — Python decorator factory with string docstring; new to extra205"
  kind: python_call_eq
  function: lru_cache.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra205.reduce_doc_class:
  description: "functools.reduce.__doc__.__class__.__name__ == 'str' — C-level builtin with string docstring; new to extra205"
  kind: python_call_eq
  function: reduce.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra205.wraps_doc_class:
  description: "functools.wraps.__doc__.__class__.__name__ == 'str' — Python decorator helper with string docstring; new to extra205"
  kind: python_call_eq
  function: wraps.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra205.cached_property_doc_class:
  description: "functools.cached_property.__doc__.__class__.__name__ == 'NoneType' — cached_property.__doc__ is None in Python 3.14.3; new to extra205"
  kind: python_call_eq
  function: cached_property.__doc__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant functools_extra205.singledispatch_doc_class:
  description: "functools.singledispatch.__doc__.__class__.__name__ == 'str' — Python decorator factory with string docstring; new to extra205"
  kind: python_call_eq
  function: singledispatch.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra205.update_wrapper_doc_class:
  description: "functools.update_wrapper.__doc__.__class__.__name__ == 'str' — Python function with string docstring; new to extra205"
  kind: python_call_eq
  function: update_wrapper.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra205.total_ordering_doc_class:
  description: "functools.total_ordering.__doc__.__class__.__name__ == 'str' — Python class decorator with string docstring; new to extra205"
  kind: python_call_eq
  function: total_ordering.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
