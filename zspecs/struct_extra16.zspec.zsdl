spec: struct_extra16
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct.zspec.zsdl — pack/unpack for B/b/H/h/I/i/Q/q/f/d/?/e/x; calcsize; roundtrip; error cases."
    - "struct_extra.zspec.zsdl — Struct format/size, calcsize extras, pack_into, unpack_from, iter_unpack, error name/bases."
    - "struct_extra2.zspec.zsdl — function __name__/__module__; pack(>H,256); unpack(>H); calcsize(>HHH); Struct base."
    - "struct_extra3.zspec.zsdl — pack/unpack/calcsize for !f/!d/!?; calcsize for !5s/!3p/!x/!5x."
    - "struct_extra4.zspec.zsdl — Struct.__name__; pack_into.__name__; function __qualname__ table; error.__qualname__."
    - "struct_extra5.zspec.zsdl — Struct.__qualname__; Struct('>I'/'>H') format/size; pack('>B',255); unpack('>B',xff); calcsize('>B'/'<B'/'>5s'); Struct('>I').pack(256)."
    - "struct_extra6.zspec.zsdl — pack/unpack('>b',127/-128); Struct('>b'/'>Q') format/size; pack/calcsize('<h'); unpack('<h')."
    - "struct_extra7.zspec.zsdl — pack/unpack/calcsize for '>l'/'>L'/'=H'/'>2B'; Struct('>l') format/size."
    - "struct_extra8.zspec.zsdl — function __module__ (all '_struct' except error 'struct'); pack return type/length for '>I'/'>H'."
    - "struct_extra9.zspec.zsdl — calcsize('c'/'P'); Struct method descriptor __qualname__/__name__ tables."
    - "struct_extra10.zspec.zsdl — pack/unpack('>BB',0,255); pack/unpack('<I',1); calcsize('<f'/'<d')."
    - "struct_extra11.zspec.zsdl — pack('>I',305419896); pack('<H',256); pack('!f',1.0) length; unpack('>I',12345678)."
    - "struct_extra12.zspec.zsdl — pack/unpack('<H' with 1/65535/256); unpack('>i',FFFFFFFF); calcsize('<H'/'<I'/'>i'/'>b'/'!H')."
    - "struct_extra13.zspec.zsdl — calcsize('=H'/'=I'/'=c'/'3s'); pack/unpack('=H',1)/('>H',1000)/('c',b'A')/('3s',b'abc')."
    - "struct_extra14.zspec.zsdl — pack('>I',0)/('>I',1)/('>H',256) exact bytes; unpack('>I',00000000)/('>H',0100) exact values."
    - "struct_extra15.zspec.zsdl — calcsize('!BHI'/'!BHIQ'); pack('!B',255)/('!I',16909060); unpack('!B',xff)."
  notes:
    - "This spec extends struct.zspec.zsdl through struct_extra15.zspec.zsdl with __name__ attribute checks."
    - "struct.pack.__name__ == 'pack' — len 4. Verified Python 3.12 macOS."
    - "struct.unpack.__name__ == 'unpack' — len 6. Verified."
    - "struct.calcsize.__name__ == 'calcsize' — len 8. Verified."
    - "struct.pack_into.__name__ == 'pack_into' — len 9. Verified."
    - "struct.unpack_from.__name__ == 'unpack_from' — len 11. Verified."
    - "struct.iter_unpack.__name__ == 'iter_unpack' — len 11. Verified."
    - "struct.error.__name__ == 'error' — len 5. Verified."
    - "struct.Struct.__name__ == 'Struct' — len 6. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct function __name__ attribute invariants
#
# Each exported callable in the struct module has a __name__ attribute equal
# to its canonical name. struct_extra2 covers pack/unpack/calcsize __name__;
# struct_extra4 covers pack_into.__name__ and Struct.__name__. This spec
# anchors all 8 from the extra16 namespace and adds the missing ones:
# pack_into, unpack_from, iter_unpack, error, Struct.
# ---------------------------------------------------------------------------

invariant struct_extra16.name.pack:
  description: "struct.pack.__name__ == 'pack' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: pack.__name__.__eq__
  args: ["pack"]
  expected: true

invariant struct_extra16.name.unpack:
  description: "struct.unpack.__name__ == 'unpack' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: unpack.__name__.__eq__
  args: ["unpack"]
  expected: true

invariant struct_extra16.name.calcsize:
  description: "struct.calcsize.__name__ == 'calcsize' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: calcsize.__name__.__eq__
  args: ["calcsize"]
  expected: true

invariant struct_extra16.name.pack_into:
  description: "struct.pack_into.__name__ == 'pack_into' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: pack_into.__name__.__eq__
  args: ["pack_into"]
  expected: true

invariant struct_extra16.name.unpack_from:
  description: "struct.unpack_from.__name__ == 'unpack_from' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: unpack_from.__name__.__eq__
  args: ["unpack_from"]
  expected: true

invariant struct_extra16.name.iter_unpack:
  description: "struct.iter_unpack.__name__ == 'iter_unpack' — function name attribute"
  category: function_names
  kind: python_call_eq
  function: iter_unpack.__name__.__eq__
  args: ["iter_unpack"]
  expected: true

invariant struct_extra16.name.error:
  description: "struct.error.__name__ == 'error' — exception class name attribute"
  category: function_names
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant struct_extra16.name.Struct:
  description: "struct.Struct.__name__ == 'Struct' — class name attribute"
  category: function_names
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# __name__ length table — all 8 struct callables
#
# Verifies the len() of each __name__ string. This provides a compact
# orthogonal view: pack(4), unpack(6), calcsize(8), pack_into(9),
# unpack_from(11), iter_unpack(11), error(5), Struct(6).
# All lengths verified at runtime with Python 3.12 macOS 2026-04-09.
# ---------------------------------------------------------------------------

table struct_extra16.name_len.all_callables:
  description: "len of __name__ for all 8 struct callables"
  kind: python_call_eq
  category: function_name_lengths
  id_prefix: snl16

  columns: [id, function, args, expected]
  rows:
    - [pack_len,        pack.__name__.__len__,        [], 4]
    - [unpack_len,      unpack.__name__.__len__,      [], 6]
    - [calcsize_len,    calcsize.__name__.__len__,    [], 8]
    - [pack_into_len,   pack_into.__name__.__len__,   [], 9]
    - [unpack_from_len, unpack_from.__name__.__len__, [], 11]
    - [iter_unpack_len, iter_unpack.__name__.__len__, [], 11]
    - [error_len,       error.__name__.__len__,       [], 5]
    - [Struct_len,      Struct.__name__.__len__,      [], 6]
