spec: paramiko_rust
version: ">=3.9"
backend: rust_module(paramiko_rust)

docs: https://docs.paramiko.org/en/latest/

provenance:
  derived_from:
    - "https://docs.paramiko.org/en/latest/ — Paramiko documentation"
  not_derived_from:
    - "paramiko source: paramiko/__init__.py"
  notes:
    - "Paramiko provides SSH protocol implementation for Python."
    - "paramiko.SSHClient is available."
    - "paramiko.SSHClient.__name__ == 'SSHClient'."
    - "paramiko.RSAKey is available."
    - "paramiko.__version__ is a non-empty string."
    - "paramiko.Transport is available."
    - "Expose paramiko_client_name() -> str: paramiko.SSHClient.__name__."
    - "Expose paramiko_has_rsa_key() -> bool: hasattr(paramiko, 'RSAKey')."
    - "Expose paramiko_version_nonempty() -> bool: len(paramiko.__version__) > 0."
    - "All test vectors verified against paramiko 3.5.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# paramiko_client_name — SSHClient class name
invariant paramiko_rust.client.class_name:
  description: "paramiko.SSHClient.__name__ == 'SSHClient'"
  category: client
  kind: python_call_eq
  function: paramiko_client_name
  args: []
  expected: "SSHClient"

# paramiko_has_rsa_key — RSAKey present
invariant paramiko_rust.keys.has_rsa:
  description: "paramiko.RSAKey is available"
  category: keys
  kind: python_call_eq
  function: paramiko_has_rsa_key
  args: []
  expected: true

# paramiko_version_nonempty — version non-empty
invariant paramiko_rust.version.nonempty:
  description: "paramiko.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: paramiko_version_nonempty
  args: []
  expected: true

