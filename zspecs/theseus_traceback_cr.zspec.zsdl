spec: theseus_traceback_cr
version: ">=3.8"
backend: python_cleanroom(theseus_traceback_cr)
blocks: traceback

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/traceback.html"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "Clean-room traceback module. Do NOT import traceback."

error_model: python_exceptions

invariant theseus_traceback_cr.traceback2_format_exc:
  description: "format_exc_test captures current exception as string"
  category: behavior
  kind: python_call_eq
  function: traceback2_format_exc
  args: []
  expected: true

invariant theseus_traceback_cr.traceback2_extract_stack:
  description: "extract_stack_test returns list of FrameSummary"
  category: behavior
  kind: python_call_eq
  function: traceback2_extract_stack
  args: []
  expected: true

invariant theseus_traceback_cr.traceback2_format_exception:
  description: "format_exception produces list of strings"
  category: behavior
  kind: python_call_eq
  function: traceback2_format_exception
  args: []
  expected: true
