spec: theseus_compression_lzma_cr
version: ">=3.14"
backend: python_cleanroom(theseus_compression_lzma_cr)
blocks: compression.lzma

docs: https://docs.python.org/3/library/compression.lzma.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/compression.lzma.html"
  not_derived_from:
    - "CPython source: Lib/compression/lzma.py"
  notes:
    - "Clean-room compression.lzma module (Python 3.14+). Do NOT import compression.lzma."

error_model: python_exceptions

invariant theseus_compression_lzma_cr.clzma2_compress:
  description: "compress/decompress roundtrip works"
  category: behavior
  kind: python_call_eq
  function: clzma2_compress
  args: []
  expected: true

invariant theseus_compression_lzma_cr.clzma2_constants:
  description: "LZMA check constants are exposed"
  category: behavior
  kind: python_call_eq
  function: clzma2_constants
  args: []
  expected: true

invariant theseus_compression_lzma_cr.clzma2_open:
  description: "open() creates a readable compressed file"
  category: behavior
  kind: python_call_eq
  function: clzma2_open
  args: []
  expected: true
