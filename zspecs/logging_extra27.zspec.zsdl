spec: logging_extra27
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging_extra22.zspec.zsdl — covers __mro__[-1].__name__ for nine major logging classes."
    - "logging_extra23.zspec.zsdl — covers __qualname__ for Logger.debug/info/warning/error/critical/exception, Handler.emit/handle, Formatter.format."
    - "logging_extra24.zspec.zsdl — covers __qualname__ for StreamHandler.emit, FileHandler.emit, NullHandler.emit, Filter.filter, LogRecord class and getMessage method, getLogger/basicConfig/makeLogRecord module-level functions."
    - "logging_extra25.zspec.zsdl — covers Handler/Formatter class __qualname__/__module__, Handler.setLevel/format method qualnames, Formatter.formatTime qualname, StreamHandler/FileHandler class __qualname__/__bases__[0].__name__, LogRecord.__module__."
    - "logging_extra26.zspec.zsdl — covers Logger.__qualname__/__module__/__bases__[0].__name__, RootLogger.__qualname__/__module__/__bases__[0].__name__, level constants DEBUG/INFO/WARNING/ERROR/CRITICAL/NOTSET values, DEBUG.__class__.__name__=='int', INFO/WARNING/ERROR/CRITICAL/NOTSET __class__.__name__ table."
  notes:
    - "This spec extends the logging chain through logging_extra26; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) logging.Logger.__init__.__name__ == '__init__' — the constructor method name; logging_extra23 covers Logger method qualnames but not __init__.__name__; (2) logging.Handler.__init__.__name__ == '__init__', logging.Formatter.__init__.__name__ == '__init__', logging.Filter.__init__.__name__ == '__init__', logging.LogRecord.__init__.__name__ == '__init__' — constructor method names for all five major classes; (3) logging.NOTSET==0, logging.WARN==30, logging.FATAL==50 — extra26 covers DEBUG/INFO/WARNING/ERROR/CRITICAL values but NOTSET was only in the table; WARN and FATAL are undocumented aliases checked here as standalones; (4) logging.Logger.__module__, logging.Handler.__module__, logging.Formatter.__module__, logging.Filter.__module__ as cross-namespace anchors — extra25/26 cover some; this spec covers all four together."
    - "logging.Logger.__init__.__name__ == '__init__' — len 8. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Handler.__init__.__name__ == '__init__' — len 8. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Formatter.__init__.__name__ == '__init__' — len 8. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Filter.__init__.__name__ == '__init__' — len 8. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.LogRecord.__init__.__name__ == '__init__' — len 8. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.NOTSET == 0 — extra26 covers NOTSET in the level_values table; standalone invariant here for cross-namespace anchor."
    - "logging.WARN == 30 — undocumented alias for WARNING; same integer value. No prior spec checks WARN. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.FATAL == 50 — undocumented alias for CRITICAL; same integer value. No prior spec checks FATAL. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Logger.__module__ == 'logging' — len 7. extra26 covers as standalone; cross-namespace anchor here."
    - "logging.Handler.__module__ == 'logging' — len 7. extra25 covers; cross-namespace anchor here."
    - "logging.Formatter.__module__ == 'logging' — len 7. extra25 covers; cross-namespace anchor here."
    - "logging.Filter.__module__ == 'logging' — len 7. No prior spec checks Filter.__module__ as a standalone. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __init__.__name__ for Logger, Handler, Formatter, Filter, LogRecord
#
# No prior spec checks __init__.__name__ for any of these five major logging
# classes. All Python class constructors are named '__init__' (len 8).
# ---------------------------------------------------------------------------

table logging_extra27.init_method_names:
  description: "__init__.__name__.__eq__ for Logger/Handler/Formatter/Filter/LogRecord — all constructor method names are '__init__'"
  kind: python_call_eq
  category: method_names
  id_prefix: imn27

  columns: [id, function, args, expected]
  rows:
    - [Logger,    "Logger.__init__.__name__.__eq__",    ["__init__"], true]
    - [Handler,   "Handler.__init__.__name__.__eq__",   ["__init__"], true]
    - [Formatter, "Formatter.__init__.__name__.__eq__", ["__init__"], true]
    - [Filter,    "Filter.__init__.__name__.__eq__",    ["__init__"], true]
    - [LogRecord, "LogRecord.__init__.__name__.__eq__", ["__init__"], true]

table logging_extra27.init_method_name_lengths:
  description: "len(__init__.__name__) == 8 for all five major logging classes — len('__init__') == 8"
  kind: python_call_eq
  category: method_names
  id_prefix: imnlen27

  columns: [id, function, args, expected]
  rows:
    - [Logger,    "Logger.__init__.__name__.__len__",    [], 8]
    - [Handler,   "Handler.__init__.__name__.__len__",   [], 8]
    - [Formatter, "Formatter.__init__.__name__.__len__", [], 8]
    - [Filter,    "Filter.__init__.__name__.__len__",    [], 8]
    - [LogRecord, "LogRecord.__init__.__name__.__len__", [], 8]

# ---------------------------------------------------------------------------
# logging.NOTSET standalone cross-namespace anchor
#
# logging_extra26 covers NOTSET in the level_values table (__eq__ == 0).
# This standalone invariant provides a cross-namespace anchor from extra27.
# ---------------------------------------------------------------------------

invariant logging_extra27.NOTSET.value_eq:
  description: "logging.NOTSET == 0 — cross-namespace anchor from extra27; extra26 covers in level_values table"
  category: level_constants
  kind: python_call_eq
  function: "NOTSET.__eq__"
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# logging.WARN and logging.FATAL — undocumented level aliases
#
# logging.WARN is an alias for WARNING (value 30).
# logging.FATAL is an alias for CRITICAL (value 50).
# Both are plain Python int constants. No prior spec checks either of these
# alias constants.
# ---------------------------------------------------------------------------

invariant logging_extra27.WARN.value_eq:
  description: "logging.WARN == 30 — undocumented alias for WARNING; same integer value; no prior spec checks WARN"
  category: level_constants
  kind: python_call_eq
  function: "WARN.__eq__"
  args: [30]
  expected: true

invariant logging_extra27.WARN.class_name_eq:
  description: "logging.WARN.__class__.__name__ == 'int' — WARN alias is a plain Python int"
  category: level_constants
  kind: python_call_eq
  "function": "WARN.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

invariant logging_extra27.FATAL.value_eq:
  description: "logging.FATAL == 50 — undocumented alias for CRITICAL; same integer value; no prior spec checks FATAL"
  category: level_constants
  kind: python_call_eq
  function: "FATAL.__eq__"
  args: [50]
  expected: true

invariant logging_extra27.FATAL.class_name_eq:
  description: "logging.FATAL.__class__.__name__ == 'int' — FATAL alias is a plain Python int"
  category: level_constants
  kind: python_call_eq
  "function": "FATAL.__class__.__name__.__eq__"
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# logging.Logger.__module__, Handler.__module__, Formatter.__module__,
# Filter.__module__ — cross-namespace anchors
#
# extra25 covers Handler.__module__ and Formatter.__module__.
# extra26 covers Logger.__module__ as a standalone.
# No prior spec covers Filter.__module__ as a standalone.
# All four are 'logging' (len 7). This table collects them together from extra27.
# ---------------------------------------------------------------------------

table logging_extra27.class_modules:
  description: "__module__.__eq__ for Logger/Handler/Formatter/Filter — all defined in 'logging'; cross-namespace anchors from extra27"
  kind: python_call_eq
  category: class_module
  id_prefix: cm27

  columns: [id, function, args, expected]
  rows:
    - [Logger,    "Logger.__module__.__eq__",    ["logging"], true]
    - [Handler,   "Handler.__module__.__eq__",   ["logging"], true]
    - [Formatter, "Formatter.__module__.__eq__", ["logging"], true]
    - [Filter,    "Filter.__module__.__eq__",    ["logging"], true]

invariant logging_extra27.Filter.module_eq:
  description: "logging.Filter.__module__ == 'logging' — no prior spec checks Filter.__module__ as a standalone invariant"
  category: class_module
  kind: python_call_eq
  function: "Filter.__module__.__eq__"
  args: ["logging"]
  expected: true

invariant logging_extra27.Filter.module_len:
  description: "len(logging.Filter.__module__) == 7 — len('logging') == 7"
  category: class_module
  kind: python_call_eq
  function: "Filter.__module__.__len__"
  args: []
  expected: 7
