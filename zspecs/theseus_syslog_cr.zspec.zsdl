spec: theseus_syslog_cr
version: ">=3.0"
backend: python_cleanroom(theseus_syslog_cr)
blocks: syslog

docs: https://docs.python.org/3/library/syslog.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/syslog.html"
  not_derived_from:
    - "CPython source: Modules/syslogmodule.c"
  notes:
    - "Clean-room syslog module. Do NOT import syslog."

error_model: python_exceptions

invariant theseus_syslog_cr.syslog2_constants:
  description: "LOG_ERR, LOG_WARNING, LOG_INFO constants exist"
  category: behavior
  kind: python_call_eq
  function: syslog2_constants
  args: []
  expected: true

invariant theseus_syslog_cr.syslog2_priority_names:
  description: "Priority name constants are correct integers"
  category: behavior
  kind: python_call_eq
  function: syslog2_priority_names
  args: []
  expected: true

invariant theseus_syslog_cr.syslog2_syslog:
  description: "syslog() function exists"
  category: behavior
  kind: python_call_eq
  function: syslog2_syslog
  args: []
  expected: true
