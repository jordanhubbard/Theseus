spec: hashlib_extra192
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
  notes:
    - "On macOS with Python 3.14.3, sha3_* constructors are OpenSSL-backed (openssl_sha3_*)."
    - "hashlib.sha3_224.__name__ == 'openssl_sha3_224' — len=16; OpenSSL-backed constructor."
    - "hashlib.sha3_224.__module__ == '_hashlib' — C extension backing OpenSSL digest routines."
    - "hashlib.sha3_224.__class__.__name__ == 'builtin_function_or_method' — OpenSSL-backed sha3 variants are C builtins, not C types."
    - "All four sha3 variant names share the same length of 16 characters (openssl_sha3_NNN)."
    - "hashlib.sha3_256.__module__ == '_hashlib' — same C extension as sha3_224."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: hashlib.sha3_224 name identity
#
# hashlib.sha3_224.__name__               == 'openssl_sha3_224'  (len=16)
# hashlib.sha3_224.__module__             == '_hashlib'
# hashlib.sha3_224.__class__.__name__     == 'builtin_function_or_method'
#
# On macOS with Python 3.14.3 linked against OpenSSL, the sha3_* entries in
# hashlib are OpenSSL-backed constructor functions rather than C types.
# Their __name__ includes the 'openssl_' prefix, their __module__ is
# '_hashlib', and their __class__ is 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

table hashlib_extra192.sha3_224_name_identity:
  description: "hashlib.sha3_224 name, module, and class identity; new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibsha3192

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_name_eq,
       hashlib.sha3_224.__name__.__eq__,
       ["openssl_sha3_224"],
       true,
       "hashlib.sha3_224.__name__.__eq__('openssl_sha3_224') == True — OpenSSL-backed constructor; len=16; new to extra192"]
    - [sha3_224_name_len,
       hashlib.sha3_224.__name__.__len__,
       [],
       16,
       "hashlib.sha3_224.__name__.__len__() == 16 — 'openssl_sha3_224' has 16 characters; new to extra192"]
    - [sha3_224_module_eq,
       hashlib.sha3_224.__module__.__eq__,
       ["_hashlib"],
       true,
       "hashlib.sha3_224.__module__.__eq__('_hashlib') == True — C extension backing OpenSSL digest routines; new to extra192"]
    - [sha3_224_class_name_eq,
       hashlib.sha3_224.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "hashlib.sha3_224.__class__.__name__.__eq__('builtin_function_or_method') == True — OpenSSL-backed sha3 is a C builtin; new to extra192"]

# ---------------------------------------------------------------------------
# Table 2: hashlib.sha3_256 name and module identity
#
# hashlib.sha3_256.__name__    == 'openssl_sha3_256'  (len=16)
# hashlib.sha3_256.__module__  == '_hashlib'
#
# sha3_256 shares the same OpenSSL-backed structure as sha3_224.  Both
# names are 16 characters long with the 'openssl_sha3_' prefix.
# ---------------------------------------------------------------------------

table hashlib_extra192.sha3_256_name_identity:
  description: "hashlib.sha3_256 name and module identity; new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibsha3192

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_name_eq,
       hashlib.sha3_256.__name__.__eq__,
       ["openssl_sha3_256"],
       true,
       "hashlib.sha3_256.__name__.__eq__('openssl_sha3_256') == True — OpenSSL-backed constructor; len=16; new to extra192"]
    - [sha3_256_name_len,
       hashlib.sha3_256.__name__.__len__,
       [],
       16,
       "hashlib.sha3_256.__name__.__len__() == 16 — 'openssl_sha3_256' has 16 characters; new to extra192"]
    - [sha3_256_module_eq,
       hashlib.sha3_256.__module__.__eq__,
       ["_hashlib"],
       true,
       "hashlib.sha3_256.__module__.__eq__('_hashlib') == True — same C extension as sha3_224; new to extra192"]
    - [sha3_256_class_name_eq,
       hashlib.sha3_256.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "hashlib.sha3_256.__class__.__name__.__eq__('builtin_function_or_method') == True — OpenSSL-backed sha3_256 is a C builtin; new to extra192"]

# ---------------------------------------------------------------------------
# Table 3: hashlib.sha3_384 and sha3_512 name identity
#
# hashlib.sha3_384.__name__  == 'openssl_sha3_384'  (len=16)
# hashlib.sha3_512.__name__  == 'openssl_sha3_512'  (len=16)
#
# All four sha3 variants produced by OpenSSL share the same __name__ length
# of 16 characters.  sha3_384 and sha3_512 confirm this uniformity.
# ---------------------------------------------------------------------------

table hashlib_extra192.sha3_384_512_name_identity:
  description: "hashlib.sha3_384 and sha3_512 name identity; all sha3 names are len=16; new to extra192"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibsha3192

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_384_name_eq,
       hashlib.sha3_384.__name__.__eq__,
       ["openssl_sha3_384"],
       true,
       "hashlib.sha3_384.__name__.__eq__('openssl_sha3_384') == True — OpenSSL-backed constructor; len=16; new to extra192"]
    - [sha3_384_name_len,
       hashlib.sha3_384.__name__.__len__,
       [],
       16,
       "hashlib.sha3_384.__name__.__len__() == 16 — 'openssl_sha3_384' has 16 characters; new to extra192"]
    - [sha3_512_name_eq,
       hashlib.sha3_512.__name__.__eq__,
       ["openssl_sha3_512"],
       true,
       "hashlib.sha3_512.__name__.__eq__('openssl_sha3_512') == True — OpenSSL-backed constructor; len=16; new to extra192"]
    - [sha3_512_name_len,
       hashlib.sha3_512.__name__.__len__,
       [],
       16,
       "hashlib.sha3_512.__name__.__len__() == 16 — 'openssl_sha3_512' has 16 characters; new to extra192"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra192
# ---------------------------------------------------------------------------

invariant hashlib_extra192.sha3_224_name_eq:
  description: "hashlib.sha3_224.__name__ == 'openssl_sha3_224' — OpenSSL-backed constructor; len=16; new to extra192"
  category: identity
  kind: python_call_eq
  function: hashlib.sha3_224.__name__.__eq__
  args: ["openssl_sha3_224"]
  expected: true

invariant hashlib_extra192.sha3_224_module_eq:
  description: "hashlib.sha3_224.__module__ == '_hashlib' — C extension backing OpenSSL digest routines; new to extra192"
  category: identity
  kind: python_call_eq
  function: hashlib.sha3_224.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra192.sha3_224_class_name_eq:
  description: "hashlib.sha3_224.__class__.__name__ == 'builtin_function_or_method' — OpenSSL sha3 variants are C builtins; new to extra192"
  category: identity
  kind: python_call_eq
  function: hashlib.sha3_224.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra192.sha3_256_name_eq:
  description: "hashlib.sha3_256.__name__ == 'openssl_sha3_256' — OpenSSL-backed constructor; len=16; new to extra192"
  category: identity
  kind: python_call_eq
  function: hashlib.sha3_256.__name__.__eq__
  args: ["openssl_sha3_256"]
  expected: true

invariant hashlib_extra192.sha3_256_module_eq:
  description: "hashlib.sha3_256.__module__ == '_hashlib' — same C extension as sha3_224; new to extra192"
  category: identity
  kind: python_call_eq
  function: hashlib.sha3_256.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra192.sha3_384_name_eq:
  description: "hashlib.sha3_384.__name__ == 'openssl_sha3_384' — OpenSSL-backed constructor; len=16; new to extra192"
  category: identity
  kind: python_call_eq
  function: hashlib.sha3_384.__name__.__eq__
  args: ["openssl_sha3_384"]
  expected: true

invariant hashlib_extra192.sha3_512_name_eq:
  description: "hashlib.sha3_512.__name__ == 'openssl_sha3_512' — OpenSSL-backed constructor; len=16; new to extra192"
  category: identity
  kind: python_call_eq
  function: hashlib.sha3_512.__name__.__eq__
  args: ["openssl_sha3_512"]
  expected: true

invariant hashlib_extra192.sha3_all_names_same_len:
  description: "hashlib.sha3_224.__name__.__len__() == 16 — all four sha3 variant names share length 16; new to extra192"
  category: identity
  kind: python_call_eq
  function: hashlib.sha3_224.__name__.__len__
  args: []
  expected: 16

