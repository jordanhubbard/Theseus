spec: decimal_extra260
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "libmpdec source"
  notes:
    - "decimal.__name__ == 'decimal' — the module name."
    - "decimal.__package__ == '' — decimal is a top-level module; __package__ is an empty string."
    - "decimal.__spec__.__class__.__name__ == 'ModuleSpec'."
    - "decimal.__spec__.name == 'decimal'."
    - "decimal.__loader__.__class__.__name__ == 'SourceFileLoader' — decimal is a Python source module."
    - "decimal.MAX_PREC == 999999999999999999 (type int) — maximum precision supported."
    - "decimal.MAX_EMAX == 999999999999999999 (type int) — maximum exponent value."
    - "decimal.MIN_EMIN == -999999999999999999 (type int) — minimum exponent value."
    - "decimal.HAVE_CONTEXTVAR == True (bool) — context variable support is available."
    - "decimal.HAVE_THREADS == True (bool) — thread-local context support is available."
    - "decimal.MIN_PREC does not exist in Python 3.14.4 (no such attribute on the module)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal module identity — __name__, __package__, __spec__
# ---------------------------------------------------------------------------

invariant decimal_extra260.module.name:
  description: "decimal.__name__ == 'decimal'"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra260.module.package:
  description: "decimal.__package__ == '' — top-level module, no parent package"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant decimal_extra260.module.spec_class:
  description: "decimal.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant decimal_extra260.module.spec_name:
  description: "decimal.__spec__.name == 'decimal'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra260.module.loader_class:
  description: "decimal.__loader__.__class__.__name__ == 'SourceFileLoader'"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# decimal numeric range constants — MAX_PREC, MAX_EMAX, MIN_EMIN
# ---------------------------------------------------------------------------

invariant decimal_extra260.MAX_PREC.value:
  description: "decimal.MAX_PREC == 999999999999999999"
  category: constants
  kind: python_call_eq
  function: MAX_PREC.__eq__
  args: [999999999999999999]
  expected: true

invariant decimal_extra260.MAX_PREC.type:
  description: "type(decimal.MAX_PREC).__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MAX_PREC.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra260.MAX_EMAX.value:
  description: "decimal.MAX_EMAX == 999999999999999999"
  category: constants
  kind: python_call_eq
  function: MAX_EMAX.__eq__
  args: [999999999999999999]
  expected: true

invariant decimal_extra260.MAX_EMAX.type:
  description: "type(decimal.MAX_EMAX).__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MAX_EMAX.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant decimal_extra260.MIN_EMIN.value:
  description: "decimal.MIN_EMIN == -999999999999999999"
  category: constants
  kind: python_call_eq
  function: MIN_EMIN.__eq__
  args: [-999999999999999999]
  expected: true

invariant decimal_extra260.MIN_EMIN.type:
  description: "type(decimal.MIN_EMIN).__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: MIN_EMIN.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# decimal build capability flags — HAVE_CONTEXTVAR, HAVE_THREADS
# ---------------------------------------------------------------------------

invariant decimal_extra260.HAVE_CONTEXTVAR.value:
  description: "decimal.HAVE_CONTEXTVAR == True — context variable support is available"
  category: constants
  kind: python_call_eq
  function: HAVE_CONTEXTVAR.__eq__
  args: [true]
  expected: true

invariant decimal_extra260.HAVE_CONTEXTVAR.type:
  description: "type(decimal.HAVE_CONTEXTVAR).__name__ == 'bool'"
  category: constants
  kind: python_call_eq
  function: HAVE_CONTEXTVAR.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

invariant decimal_extra260.HAVE_THREADS.value:
  description: "decimal.HAVE_THREADS == True — thread-local context support is available"
  category: constants
  kind: python_call_eq
  function: HAVE_THREADS.__eq__
  args: [true]
  expected: true

invariant decimal_extra260.HAVE_THREADS.type:
  description: "type(decimal.HAVE_THREADS).__name__ == 'bool'"
  category: constants
  kind: python_call_eq
  function: HAVE_THREADS.__class__.__name__.__eq__
  args: ["bool"]
  expected: true
