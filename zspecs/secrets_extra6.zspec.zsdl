spec: secrets_extra6
version: ">=3.9"
backend: python_module(secrets)

docs: https://docs.python.org/3/library/secrets.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/secrets.html — Python secrets module documentation"
    - "PEP 506 — Adding A Secrets Module To The Standard Library"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/secrets.py"
    - "secrets_extra.zspec.zsdl — covers function __name__/__module__; return type class checks"
    - "secrets_extra2.zspec.zsdl — covers function __name__ table; SystemRandom __name__/__module__/__bases__; token_bytes len32; token_hex len 2*n"
    - "secrets_extra3.zspec.zsdl — covers function __module__ invariants; DEFAULT_ENTROPY class and >= 16"
    - "secrets_extra4.zspec.zsdl — covers __qualname__ table; DEFAULT_ENTROPY == 32; token_urlsafe len 24/32; token_bytes len 4/8/64; token_hex len 4/32"
    - "secrets_extra5.zspec.zsdl — covers SystemRandom MRO, base class name, zero-length tokens, return class anchors"
  notes:
    - "This spec extends the secrets chain; it does NOT duplicate invariants present in any prior spec."
    - "Focus: token function lengths at byte counts not tested in any prior spec, plus DEFAULT_ENTROPY bit-count and SystemRandom.__bases__ length."
    - "Prior specs cover token_bytes at n=1/4/8/16/32/64 and n=0. NOT yet covered: n=2 and n=3."
    - "Prior specs cover token_hex at n=4/8/16/32 and n=0. NOT yet covered: n=2 and n=3."
    - "Prior specs cover token_urlsafe at n=0/8/16/24/32 (lengths 0/11/22/32/43). NOT yet covered: n=6 (->8 chars), n=8 (->11 chars), n=12 (->16 chars)."
    - "secrets.DEFAULT_ENTROPY * 8 == 256 — 32 bytes of entropy = 256 bits; prior specs verify the byte count but not the bit count."
    - "secrets.SystemRandom.__bases__.__len__() == 1 — SystemRandom has exactly one direct base class (Random)."
    - "secrets.choice([7]) == 7 and secrets.choice([0]) == 0 — additional single-element deterministic vectors."
    - "token_urlsafe(n) length formula: len == ceil(n * 4 / 3) with no padding (= len of base64url(n random bytes))."
    - "token_urlsafe(6) -> 8 chars; token_urlsafe(8) -> 11 chars; token_urlsafe(12) -> 16 chars."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# token_bytes — length at n=2 and n=3
#
# Prior specs cover n=0,1,4,8,16,32,64. NOT covered: n=2 or n=3.
# ---------------------------------------------------------------------------

invariant secrets_extra6.token_bytes.len_2:
  description: "len(secrets.token_bytes(2)) == 2 — always returns exactly 2 bytes"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [2]
  method: __len__
  expected: 2

invariant secrets_extra6.token_bytes.len_3:
  description: "len(secrets.token_bytes(3)) == 3 — always returns exactly 3 bytes"
  category: token_bytes
  kind: python_call_eq
  function: token_bytes
  args: [3]
  method: __len__
  expected: 3

# ---------------------------------------------------------------------------
# token_hex — length at n=2 and n=3
#
# Prior specs cover n=0,4,8,16,32. NOT covered: n=2 (-> 4 chars) or n=3 (-> 6 chars).
# token_hex(n) always returns 2*n hex characters.
# ---------------------------------------------------------------------------

invariant secrets_extra6.token_hex.len_2:
  description: "len(secrets.token_hex(2)) == 4 — 2 bytes encode to 4 hex chars"
  category: token_hex
  kind: python_call_eq
  function: token_hex
  args: [2]
  method: __len__
  expected: 4

invariant secrets_extra6.token_hex.len_3:
  description: "len(secrets.token_hex(3)) == 6 — 3 bytes encode to 6 hex chars"
  category: token_hex
  kind: python_call_eq
  function: token_hex
  args: [3]
  method: __len__
  expected: 6

# ---------------------------------------------------------------------------
# token_urlsafe — length at n=6, 8, 12
#
# Prior specs cover n=0,8,16,24,32 (lengths 0,11,22,32,43).
# NOT covered: n=6 (-> 8 chars), n=8 (-> 11 chars), n=12 (-> 16 chars).
# Length formula: floor((n * 4 + 2) / 3) for no-padding base64url.
# ---------------------------------------------------------------------------

invariant secrets_extra6.token_urlsafe.len_6:
  description: "len(secrets.token_urlsafe(6)) == 8 — base64url of 6 bytes yields 8 chars"
  category: token_urlsafe
  kind: python_call_eq
  function: token_urlsafe
  args: [6]
  method: __len__
  expected: 8

invariant secrets_extra6.token_urlsafe.len_8:
  description: "len(secrets.token_urlsafe(8)) == 11 — base64url of 8 bytes yields 11 chars"
  category: token_urlsafe
  kind: python_call_eq
  function: token_urlsafe
  args: [8]
  method: __len__
  expected: 11

invariant secrets_extra6.token_urlsafe.len_12:
  description: "len(secrets.token_urlsafe(12)) == 16 — base64url of 12 bytes yields 16 chars"
  category: token_urlsafe
  kind: python_call_eq
  function: token_urlsafe
  args: [12]
  method: __len__
  expected: 16

# ---------------------------------------------------------------------------
# DEFAULT_ENTROPY bit count
#
# secrets_extra3 checks DEFAULT_ENTROPY.__class__.__name__ == 'int' and >= 16.
# secrets_extra4 checks DEFAULT_ENTROPY == 32 (byte count).
# Not yet covered: the bit count interpretation: DEFAULT_ENTROPY * 8 == 256.
# ---------------------------------------------------------------------------

invariant secrets_extra6.DEFAULT_ENTROPY.bit_count:
  description: "secrets.DEFAULT_ENTROPY * 8 == 256 — 32 bytes of entropy equals 256 bits"
  category: constants
  kind: python_call_eq
  function: DEFAULT_ENTROPY.__mul__
  args: [8]
  method: __eq__
  method_args: [256]
  expected: true

# ---------------------------------------------------------------------------
# SystemRandom.__bases__ length == 1
#
# secrets_extra2 checks __bases__[0].__name__ == 'Random'.
# secrets_extra5 checks __bases__[0].__name__ == 'Random' (__eq__).
# Not yet covered: len(__bases__) == 1 — SystemRandom has exactly one direct base.
# ---------------------------------------------------------------------------

invariant secrets_extra6.SystemRandom.bases_length:
  description: "len(secrets.SystemRandom.__bases__) == 1 — SystemRandom has exactly one direct base class"
  category: SystemRandom
  kind: python_call_eq
  function: SystemRandom.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# choice() — additional single-element deterministic vectors
#
# secrets.zspec.zsdl covers choice([99]) == 99 and choice([42]) == 42.
# Not yet covered: choice([7]) == 7 and choice([0]) == 0.
# ---------------------------------------------------------------------------

invariant secrets_extra6.choice.single_element_7:
  description: "secrets.choice([7]) == 7 — single-element list always returns that element"
  category: choice
  kind: python_call_eq
  function: choice
  args: [[7]]
  expected: 7

invariant secrets_extra6.choice.single_element_0:
  description: "secrets.choice([0]) == 0 — single-element list with zero always returns 0"
  category: choice
  kind: python_call_eq
  function: choice
  args: [[0]]
  expected: 0
