spec: getpass_extra2
version: ">=3.9"
backend: python_module(getpass)

docs: https://docs.python.org/3/library/getpass.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/getpass.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "getpass source: terminal/tty interaction internals"
  notes:
    - "Extends getpass.zspec.zsdl and getpass_extra.zspec.zsdl with new axes."
    - "getpass.zspec.zsdl covers: GetPassWarning __name__/__module__/__bases__[0].__name__; getuser __name__/__module__; fallback_getpass __name__; unix_getpass __name__; getuser() returns non-empty/isascii/isidentifier."
    - "getpass_extra.zspec.zsdl covers: getuser __name__/__module__; getpass __module__; GetPassWarning __name__/__module__/__bases__[0].__name__; getuser().__class__.__name__."
    - "This spec adds: __qualname__ for GetPassWarning, getuser, and getpass (unix_getpass alias); GetPassWarning.__bases__.__len__; fallback_getpass __module__; unix_getpass __module__; getuser() return length is positive."
    - "getpass.GetPassWarning.__qualname__ == 'GetPassWarning' — module-level class, not nested."
    - "getpass.getuser.__qualname__ == 'getuser' — module-level function, not nested."
    - "getpass.getpass.__qualname__ == 'unix_getpass' — on POSIX, getpass is bound to unix_getpass."
    - "len(getpass.GetPassWarning.__bases__) == 1 — GetPassWarning has exactly one direct base class."
    - "getpass.fallback_getpass.__module__ == 'getpass' — defined in the getpass module."
    - "getpass.unix_getpass.__module__ == 'getpass' — defined in the getpass module."
    - "len(getpass.getuser()) > 0 confirmed via __gt__('') in getpass.zspec.zsdl; here verified via __len__ being positive."
    - "All expected values verified by running Python 3.12 getpass module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — GetPassWarning, getuser, getpass
#
# No prior getpass spec covers __qualname__ for any symbol.
# ---------------------------------------------------------------------------

invariant getpass_extra2.GetPassWarning.qualname:
  description: "getpass.GetPassWarning.__qualname__ == 'GetPassWarning' — module-level class, not nested"
  category: qualnames
  kind: python_call_eq
  function: GetPassWarning.__qualname__.__eq__
  args: ["GetPassWarning"]
  expected: true

invariant getpass_extra2.getuser.qualname:
  description: "getpass.getuser.__qualname__ == 'getuser' — module-level function, not nested"
  category: qualnames
  kind: python_call_eq
  function: getuser.__qualname__.__eq__
  args: ["getuser"]
  expected: true

invariant getpass_extra2.getpass.qualname:
  description: "getpass.getpass.__qualname__ == 'unix_getpass' — on POSIX, getpass is bound to unix_getpass"
  category: qualnames
  kind: python_call_eq
  function: getpass.__qualname__.__eq__
  args: ["unix_getpass"]
  expected: true

# ---------------------------------------------------------------------------
# GetPassWarning.__bases__ length
#
# Prior specs check __bases__[0].__name__ == 'UserWarning' but not the count.
# GetPassWarning has exactly one direct base class.
# ---------------------------------------------------------------------------

invariant getpass_extra2.GetPassWarning.bases_len:
  description: "len(getpass.GetPassWarning.__bases__) == 1 — GetPassWarning has exactly one direct base class"
  category: GetPassWarning
  kind: python_call_eq
  function: GetPassWarning.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# fallback_getpass and unix_getpass — module attribute
#
# Prior specs check __name__ for these functions but not __module__.
# ---------------------------------------------------------------------------

invariant getpass_extra2.fallback_getpass.module:
  description: "getpass.fallback_getpass.__module__ == 'getpass'"
  category: functions
  kind: python_call_eq
  function: fallback_getpass.__module__.__eq__
  args: ["getpass"]
  expected: true

invariant getpass_extra2.unix_getpass.module:
  description: "getpass.unix_getpass.__module__ == 'getpass'"
  category: functions
  kind: python_call_eq
  function: unix_getpass.__module__.__eq__
  args: ["getpass"]
  expected: true

# ---------------------------------------------------------------------------
# fallback_getpass and unix_getpass — __qualname__
#
# No prior spec covers __qualname__ for either of these functions.
# ---------------------------------------------------------------------------

invariant getpass_extra2.fallback_getpass.qualname:
  description: "getpass.fallback_getpass.__qualname__ == 'fallback_getpass'"
  category: qualnames
  kind: python_call_eq
  function: fallback_getpass.__qualname__.__eq__
  args: ["fallback_getpass"]
  expected: true

invariant getpass_extra2.unix_getpass.qualname:
  description: "getpass.unix_getpass.__qualname__ == 'unix_getpass'"
  category: qualnames
  kind: python_call_eq
  function: unix_getpass.__qualname__.__eq__
  args: ["unix_getpass"]
  expected: true

# ---------------------------------------------------------------------------
# getuser() — return value length is positive
#
# getpass.zspec.zsdl confirms getuser() > '' via __gt__. Here we confirm
# that the length of the returned string is greater than zero via __len__
# chained with __gt__.
# ---------------------------------------------------------------------------

invariant getpass_extra2.getuser.len_positive:
  description: "len(getpass.getuser()) > 0 — getuser() returns a non-empty string"
  category: getuser
  kind: python_call_eq
  function: getuser
  args: []
  method: __len__
  method_args: []
  method_chain: __gt__
  method_chain_args: [0]
  expected: true
