spec: functools_extra503
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module decorator and callable attributes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "__qualname__ is a string attribute set on every callable defined at module scope"
    - "__doc__ is a string or None; its __class__.__name__ should be 'str' for all documented callables"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra503.qualname_identity:
  description: "Each functools decorator or callable has the expected __qualname__ string"
  kind: python_call_eq
  category: attributes
  id_prefix: FQN

  columns: [id, function, args, expected]
  rows:
    - [FQN001, functools.lru_cache.__qualname__.__eq__, ["lru_cache"], true]
    - [FQN002, functools.cache.__qualname__.__eq__, ["cache"], true]
    - [FQN003, functools.cached_property.__qualname__.__eq__, ["cached_property"], true]
    - [FQN004, functools.singledispatch.__qualname__.__eq__, ["singledispatch"], true]
    - [FQN005, functools.total_ordering.__qualname__.__eq__, ["total_ordering"], true]
    - [FQN006, functools.partial.__qualname__.__eq__, ["partial"], true]
    - [FQN007, functools.reduce.__qualname__.__eq__, ["reduce"], true]
    - [FQN008, functools.wraps.__qualname__.__eq__, ["wraps"], true]
    - [FQN009, functools.cmp_to_key.__qualname__.__eq__, ["cmp_to_key"], true]

table functools_extra503.doc_class:
  description: "functools.lru_cache.__doc__ is a string object (its __class__.__name__ is 'str')"
  kind: python_call_eq
  category: attributes
  id_prefix: FDC

  columns: [id, function, args, expected]
  rows:
    - [FDC001, functools.lru_cache.__doc__.__class__.__name__.__eq__, ["str"], true]
