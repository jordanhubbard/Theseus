spec: asyncio_extra28
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec extends asyncio_extra27.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/wait_for/create_task/ensure_future/get_event_loop/new_event_loop/get_running_loop/__name__, Queue.__module__, Lock/Event/Semaphore/Condition/__module__, PriorityQueue/LifoQueue/__bases__[0].__name__, QueueEmpty/QueueFull/__bases__[0].__name__, CancelledError/TimeoutError/InvalidStateError/__module__, Queue.__bases__[0].__name__=='_LoopBoundMixin'."
    - "This spec covers: Queue/Lock/Event __module__.__len__(); Queue/Lock/Event/Semaphore __name__.__len__(); gather/sleep/wait/create_task/get_event_loop __qualname__."
    - "Queue.__module__ == 'asyncio.queues' — length 14."
    - "Lock.__module__ == 'asyncio.locks' — length 13."
    - "Event.__module__ == 'asyncio.locks' — length 13."
    - "Queue.__name__ == 'Queue' — length 5."
    - "Lock.__name__ == 'Lock' — length 4."
    - "Event.__name__ == 'Event' — length 5."
    - "Semaphore.__name__ == 'Semaphore' — length 9."
    - "gather.__qualname__ == 'gather' — module-level coroutine function."
    - "sleep.__qualname__ == 'sleep' — module-level coroutine function."
    - "wait.__qualname__ == 'wait' — module-level coroutine function."
    - "create_task.__qualname__ == 'create_task' — module-level function."
    - "get_event_loop.__qualname__ == 'get_event_loop' — module-level function."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __module__ length table — extra28 namespace
#
# asyncio.Queue.__module__ == 'asyncio.queues' (length 14).
# asyncio.Lock.__module__ == 'asyncio.locks' (length 13).
# asyncio.Event.__module__ == 'asyncio.locks' (length 13).
# Prior specs verify the string values; this spec adds the __len__() axis.
# ---------------------------------------------------------------------------

table asyncio_extra28.class_module_lengths:
  description: "asyncio class __module__ lengths in extra28 namespace"
  kind: python_call_eq
  category: class_modules
  id_prefix: clsmodlen28

  columns: [id, function, args, expected]
  rows:
    - [Queue, Queue.__module__.__len__, [], 14]
    - [Lock,  Lock.__module__.__len__,  [], 13]
    - [Event, Event.__module__.__len__, [], 13]

# ---------------------------------------------------------------------------
# Class __name__ length table — extra28 namespace
#
# asyncio.Queue.__name__ == 'Queue' (length 5).
# asyncio.Lock.__name__ == 'Lock' (length 4).
# asyncio.Event.__name__ == 'Event' (length 5).
# asyncio.Semaphore.__name__ == 'Semaphore' (length 9).
# Prior specs verify the string values; this spec adds the __len__() axis.
# ---------------------------------------------------------------------------

table asyncio_extra28.class_name_lengths:
  description: "asyncio class __name__ lengths in extra28 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: clsnamelen28

  columns: [id, function, args, expected]
  rows:
    - [Queue,     Queue.__name__.__len__,     [], 5]
    - [Lock,      Lock.__name__.__len__,      [], 4]
    - [Event,     Event.__name__.__len__,     [], 5]
    - [Semaphore, Semaphore.__name__.__len__, [], 9]

# ---------------------------------------------------------------------------
# Module-level function __qualname__ table — extra28 namespace
#
# asyncio.gather, sleep, wait, create_task, and get_event_loop are all
# module-level functions whose __qualname__ matches their __name__ — they are
# not nested inside any class. Prior specs check __name__ values; this spec
# adds __qualname__ verification for these five functions.
# gather.__qualname__ == 'gather' (length 6).
# sleep.__qualname__ == 'sleep' (length 5).
# wait.__qualname__ == 'wait' (length 4).
# create_task.__qualname__ == 'create_task' (length 11).
# get_event_loop.__qualname__ == 'get_event_loop' (length 14).
# ---------------------------------------------------------------------------

table asyncio_extra28.function_qualnames:
  description: "asyncio module-level function __qualname__ values in extra28 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: fqualname28

  columns: [id, function, args, expected]
  rows:
    - [gather,         gather.__qualname__.__eq__,         ["gather"],         true]
    - [sleep,          sleep.__qualname__.__eq__,          ["sleep"],          true]
    - [wait,           wait.__qualname__.__eq__,           ["wait"],           true]
    - [create_task,    create_task.__qualname__.__eq__,    ["create_task"],    true]
    - [get_event_loop, get_event_loop.__qualname__.__eq__, ["get_event_loop"], true]
