spec: itertools_extra81
version: ">=3.10"
backend: python_module(itertools)
extends: itertools_extra80

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra80.zspec.zsdl."
    - "This spec covers: __bases__.__len__() and __bases__[0].__name__ for all 16 itertools C types (Wave 245)."
    - "All 16 itertools C types have exactly one base class: object. Verified with Python 3.14.3."
    - "count.__bases__.__len__() == 1; count.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "cycle.__bases__.__len__() == 1; cycle.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "repeat.__bases__.__len__() == 1; repeat.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "accumulate.__bases__.__len__() == 1; accumulate.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "chain.__bases__.__len__() == 1; chain.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "compress.__bases__.__len__() == 1; compress.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "dropwhile.__bases__.__len__() == 1; dropwhile.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "filterfalse.__bases__.__len__() == 1; filterfalse.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "groupby.__bases__.__len__() == 1; groupby.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "islice.__bases__.__len__() == 1; islice.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "pairwise.__bases__.__len__() == 1; pairwise.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "permutations.__bases__.__len__() == 1; permutations.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "product.__bases__.__len__() == 1; product.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "starmap.__bases__.__len__() == 1; starmap.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "takewhile.__bases__.__len__() == 1; takewhile.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "zip_longest.__bases__.__len__() == 1; zip_longest.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "version set to >=3.10 because pairwise was added in Python 3.10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# count/cycle/repeat/accumulate __bases__ length and base name — extra81
#
# Wave 245 theme: __bases__.__len__()==1 and __bases__[0].__name__=='object' for all itertools C types.
#
# itertools.count.__bases__.__len__()       == 1
# itertools.count.__bases__[0].__name__     == 'object'
# itertools.cycle.__bases__.__len__()       == 1
# itertools.cycle.__bases__[0].__name__     == 'object'
# itertools.repeat.__bases__.__len__()      == 1
# itertools.repeat.__bases__[0].__name__    == 'object'
# itertools.accumulate.__bases__.__len__()  == 1
# itertools.accumulate.__bases__[0].__name__ == 'object'
#
# No prior itertools spec checks count/cycle/repeat/accumulate __bases__ via itrtoolsextra81. New to extra81.
# ---------------------------------------------------------------------------

table itertools_extra81.bases_group1:
  description: "count/cycle/repeat/accumulate __bases__.__len__()==1 and __bases__[0].__name__=='object'; wave 245 itertools C type __bases__ identity; new to extra81"
  kind: python_call_eq
  category: type_identity
  id_prefix: itrtoolsextra81

  columns: [id, function, args, expected, description]
  rows:
    - [count_bases_len_eq_1,
       "count.__bases__.__len__",
       [],
       1,
       "itertools.count.__bases__.__len__() == 1 — count is a C extension type defined in Modules/itertoolsmodule.c; it inherits directly from object and has exactly one base class; tuple.__len__() returns 1; no prior itertools spec checks count.__bases__.__len__() via itrtoolsextra81; new to extra81"]
    - [count_bases_0_name_eq_object,
       "count.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.count.__bases__[0].__name__.__eq__('object') == True — count is a C extension type that inherits directly from object; its only base class is object whose __name__ is 'object' (6 chars); str.__eq__('object') returns True; no prior itertools spec checks count.__bases__[0].__name__ via itrtoolsextra81; new to extra81"]
    - [cycle_bases_len_eq_1,
       "cycle.__bases__.__len__",
