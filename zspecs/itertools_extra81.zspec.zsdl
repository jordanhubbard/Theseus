       ["object"],
       true,
       "itertools.cycle.__bases__[0].__name__.__eq__('object') == True — cycle is a C extension type that inherits directly from object; its only base class is object whose __name__ is 'object' (6 chars); str.__eq__('object') returns True; no prior itertools spec checks cycle.__bases__[0].__name__ via itrtoolsextra81; new to extra81"]
    - [repeat_bases_len_eq_1,
       "repeat.__bases__.__len__",
       [],
       1,
       "itertools.repeat.__bases__.__len__() == 1 — repeat is a C extension type defined in Modules/itertoolsmodule.c; it inherits directly from object and has exactly one base class; tuple.__len__() returns 1; no prior itertools spec checks repeat.__bases__.__len__() via itrtoolsextra81; new to extra81"]
    - [repeat_bases_0_name_eq_object,
       "repeat.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.repeat.__bases__[0].__name__.__eq__('object') == True — repeat is a C extension type that inherits directly from object; its only base class is object whose __name__ is 'object' (6 chars); str.__eq__('object') returns True; no prior itertools spec checks repeat.__bases__[0].__name__ via itrtoolsextra81; new to extra81"]
    - [accumulate_bases_len_eq_1,
