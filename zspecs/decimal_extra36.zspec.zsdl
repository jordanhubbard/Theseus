spec: decimal_extra36
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra35.zspec.zsdl — covers decimal.DefaultContext.prec==28/Emin==-999999/Emax==999999/rounding=='ROUND_HALF_EVEN'/clamp==0 as direct attribute access."
    - "decimal_extra34.zspec.zsdl — covers decimal.__name__.__len__()==7; decimal.__file__.__class__.__name__.__len__()==3; getcontext().Emax==999999/Emin==-999999/rounding.__len__()==15 via method chain; Decimal quantize behavioral; Decimal 1/3 str len."
    - "decimal_extra33.zspec.zsdl — covers Decimal.__pos__/__int__/__ceil__/__bool__/__copy__/__float__/__round__/__floor__/__trunc__/__format__/__deepcopy__ __qualname__.__len__()."
    - "decimal_extra24.zspec.zsdl — covers Decimal.__module__.__eq__('decimal'); Decimal.__module__.__len__()==7."
    - "decimal_extra20.zspec.zsdl — covers ROUND_UP.__len__()==8; ROUND_DOWN.__len__()==10; ROUND_HALF_EVEN.__len__()==15."
    - "decimal_extra17.zspec.zsdl — covers ROUND_UP/ROUND_DOWN/ROUND_CEILING/ROUND_FLOOR __class__.__name__.__eq__('str')."
    - "decimal_extra14.zspec.zsdl — covers getcontext().prec==28 via method chain; getcontext().__class__.__name__=='Context'."
    - "decimal_extra13.zspec.zsdl — covers Decimal.__name__.__eq__('Decimal'); Decimal.__module__.__eq__('decimal'); ROUND_DOWN.__eq__('ROUND_DOWN'); ROUND_UP.__eq__('ROUND_UP')."
    - "decimal_extra.zspec.zsdl — covers DefaultContext.__class__.__name__.__eq__('Context')."
  notes:
    - "This spec extends decimal_extra35.zspec.zsdl."
    - "Prior specs collectively covered: Decimal/Context/__module__/__name__/__qualname__ and all lengths; all Decimal and Context method __qualname__.__len__(); exception class identity (various); all ROUND_* string constants equality and lengths; getcontext().prec==28 (via method chain); getcontext().Emax/Emin (via method chain); DefaultContext.prec/Emin/Emax/rounding/clamp direct attribute access; behavioral tests; DefaultContext.__class__.__name__=='Context'."
    - "This spec covers: decimal.DecimalException.__name__ == 'DecimalException' (NOVEL equality anchor in decimal_extra36 namespace; prior specs cover exception class identity in various forms but not DecimalException.__name__.__eq__ as standalone invariant here); decimal.DecimalException.__module__ == 'decimal' (NOVEL — no prior decimal spec anchors DecimalException.__module__.__eq__ in this namespace); decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' (NOVEL — no prior decimal spec checks DecimalException.__bases__[0].__name__.__eq__ as standalone invariant); decimal.InvalidOperation.__name__ == 'InvalidOperation' (NOVEL equality anchor); decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' (NOVEL — verifies exception hierarchy); decimal.DivisionByZero.__name__ == 'DivisionByZero' (NOVEL equality anchor); decimal.Overflow.__name__ == 'Overflow' (NOVEL equality anchor); decimal.Underflow.__name__ == 'Underflow' (NOVEL equality anchor); decimal.Inexact.__name__ == 'Inexact' (NOVEL equality anchor)."
    - "decimal.DecimalException.__name__ == 'DecimalException'. The root exception class for all decimal exceptions. __name__ == 'DecimalException'. Novel equality anchor in decimal_extra36 namespace. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DecimalException.__module__ == 'decimal'. DecimalException is defined in the decimal module. __module__ == 'decimal'. Novel equality anchor in decimal_extra36. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError'. DecimalException inherits directly from ArithmeticError (a built-in exception). Its __bases__ contains exactly one element: ArithmeticError. Novel standalone invariant — no prior decimal spec checks this. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.InvalidOperation.__name__ == 'InvalidOperation'. InvalidOperation is raised for invalid operations (e.g. 0/0). __name__ == 'InvalidOperation'. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException'. InvalidOperation inherits directly from DecimalException, placing it in the decimal exception hierarchy. Novel — verifies the inheritance chain. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DivisionByZero.__name__ == 'DivisionByZero'. Raised when a non-infinite number is divided by zero. __name__ == 'DivisionByZero'. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Overflow.__name__ == 'Overflow'. Raised when the exponent exceeds Emax. __name__ == 'Overflow'. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Underflow.__name__ == 'Underflow'. Raised when a subnormal result is rounded to zero. __name__ == 'Underflow'. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Inexact.__name__ == 'Inexact'. Raised when rounding causes loss of information. __name__ == 'Inexact'. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.DecimalException class identity: __name__, __module__, base class
#
# DecimalException is the root of the decimal exception hierarchy. It
# inherits from ArithmeticError (a Python built-in exception class).
#
#   DecimalException.__name__          == 'DecimalException'
#   DecimalException.__module__        == 'decimal'
#   DecimalException.__bases__[0].__name__ == 'ArithmeticError'
#
# All three novel equality anchors in decimal_extra36 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant decimal_extra36.DecimalException_name_eq:
  description: "decimal.DecimalException.__name__ == 'DecimalException' — root exception class for all decimal exceptions; novel equality anchor in decimal_extra36 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__name__.__eq__
  args: ["DecimalException"]
  expected: true

invariant decimal_extra36.DecimalException_module_eq:
  description: "decimal.DecimalException.__module__ == 'decimal' — DecimalException is defined in the decimal module; novel equality anchor in decimal_extra36; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: DecimalException.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra36.DecimalException_base_name_eq:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — DecimalException inherits directly from the built-in ArithmeticError; no prior decimal spec checks this; novel standalone invariant; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true

# ---------------------------------------------------------------------------
# decimal.InvalidOperation class identity: __name__ and base class
#
# InvalidOperation is raised for operations with no defined result (e.g., 0/0,
# inf - inf). It inherits directly from DecimalException.
#
#   InvalidOperation.__name__          == 'InvalidOperation'
#   InvalidOperation.__bases__[0].__name__ == 'DecimalException'
#
# Novel. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant decimal_extra36.InvalidOperation_name_eq:
  description: "decimal.InvalidOperation.__name__ == 'InvalidOperation' — raised for invalid operations such as 0/0 or inf-inf; novel equality anchor in decimal_extra36; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: InvalidOperation.__name__.__eq__
  args: ["InvalidOperation"]
  expected: true

invariant decimal_extra36.InvalidOperation_base_name_eq:
  description: "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' — InvalidOperation inherits directly from DecimalException; verifies the decimal exception hierarchy; novel standalone invariant; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: "InvalidOperation.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

# ---------------------------------------------------------------------------
# decimal exception subclass __name__ attributes
#
# DivisionByZero, Overflow, Underflow, and Inexact are all DecimalException
# subclasses representing specific signal conditions in decimal arithmetic.
#
#   DivisionByZero.__name__ == 'DivisionByZero'  (raised when x/0, x != 0, x finite)
#   Overflow.__name__       == 'Overflow'        (raised when exponent > Emax)
#   Underflow.__name__      == 'Underflow'       (raised when subnormal result rounded to 0)
#   Inexact.__name__        == 'Inexact'         (raised when rounding discards digits)
#
# All four novel equality anchors. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra36.exception_subclass_names:
  description: "decimal exception subclass __name__ attributes: DivisionByZero/Overflow/Underflow/Inexact — all novel equality anchors in decimal_extra36 namespace; each is a DecimalException subclass representing a specific IEEE 754 signal condition"
  kind: python_call_eq
  category: class_identity
  id_prefix: desn36

  columns: [id, function, args, expected]
  rows:
    - [DivisionByZero_name, DivisionByZero.__name__.__eq__, ["DivisionByZero"], true]
    - [Overflow_name,       Overflow.__name__.__eq__,       ["Overflow"],       true]
    - [Underflow_name,      Underflow.__name__.__eq__,      ["Underflow"],      true]
    - [Inexact_name,        Inexact.__name__.__eq__,        ["Inexact"],        true]
