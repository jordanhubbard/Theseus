spec: tqdm_rust
version: ">=3.9"
backend: rust_module(tqdm_rust)

docs: https://tqdm.github.io/

provenance:
  derived_from:
    - "https://tqdm.github.io/ — tqdm library documentation"
  not_derived_from:
    - "tqdm source: tqdm/main.py"
  notes:
    - "tqdm provides fast, extensible progress bars for Python."
    - "tqdm(iterable) wraps any iterable to show a progress bar."
    - "Expose tqdm_list(lst) -> list: list(tqdm(lst, disable=True)) — collect into list."
    - "Expose tqdm_len(lst) -> int: len(list(tqdm(lst, disable=True)))."
    - "Expose tqdm_sum(lst) -> int: sum(tqdm(lst, disable=True))."
    - "Expose tqdm_format_meter(n, total, elapsed) -> str: tqdm.format_meter(n, total, elapsed)."
    - "tqdm(range(5), disable=True) iterates [0,1,2,3,4]."
    - "list(tqdm([1,2,3], disable=True)) == [1,2,3]."
    - "sum(tqdm([1,2,3,4,5], disable=True)) == 15."
    - "tqdm.format_meter is a static method returning a formatted string."
    - "All test vectors verified against tqdm 4.67.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# tqdm_list — collect tqdm iterator into list
table tqdm_rust.iterate.list:
  kind: python_call_eq
  category: iterate
  id_prefix: tq_list
  function: tqdm_list

  columns: [id, args, expected]
  rows:
    - [three,  [[1, 2, 3]],      [1, 2, 3]]
    - [empty,  [[]],             []]
    - [five,   [[10, 20, 30, 40, 50]], [10, 20, 30, 40, 50]]

# tqdm_len — length of iteration
table tqdm_rust.iterate.length:
  kind: python_call_eq
  category: length
  id_prefix: tq_len
  function: tqdm_len

  columns: [id, args, expected]
  rows:
    - [three, [[1, 2, 3]], 3]
    - [zero,  [[]], 0]
    - [five,  [[1, 2, 3, 4, 5]], 5]

# tqdm_sum — sum over iteration
invariant tqdm_rust.iterate.sum_five:
  description: "sum over tqdm([1..5]) == 15"
  category: sum
  kind: python_call_eq
  function: tqdm_sum
  args: [[1, 2, 3, 4, 5]]
  expected: 15

invariant tqdm_rust.iterate.sum_empty:
  description: "sum over tqdm([]) == 0"
  category: sum
  kind: python_call_eq
  function: tqdm_sum
  args: [[]]
  expected: 0

