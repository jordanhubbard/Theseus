spec: functools_extra976
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks functools.partial, functools.partialmethod, functools.cached_property, and functools.lru_cache method qualnames and wrapper identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table functools_extra976.partial_method_qualnames:
  description: "functools.partial method __qualname__ identity"
  kind: python_call_eq
  category: partial_qualnames
  id_prefix: ft976pm
  columns: [id, function, args, expected]
  rows:
    - [ft976pm001, functools.partial.__new__.__qualname__.__eq__,    ["partial.__new__"],    true]
    - [ft976pm002, functools.partial.__init__.__qualname__.__eq__,   ["partial.__init__"],   true]
    - [ft976pm003, functools.partial.__call__.__qualname__.__eq__,   ["partial.__call__"],   true]
    - [ft976pm004, functools.partial.__repr__.__qualname__.__eq__,   ["partial.__repr__"],   true]
    - [ft976pm005, functools.partial.__reduce__.__qualname__.__eq__, ["partial.__reduce__"], true]
    - [ft976pm006, functools.partial.__setstate__.__qualname__.__eq__, ["partial.__setstate__"], true]

table functools_extra976.partialmethod_qualnames:
  description: "functools.partialmethod method __qualname__ identity"
  kind: python_call_eq
  category: partialmethod_qualnames
  id_prefix: ft976pmy
  columns: [id, function, args, expected]
  rows:
    - [ft976pmy001, functools.partialmethod.__init__.__qualname__.__eq__,  ["partialmethod.__init__"],  true]
    - [ft976pmy002, functools.partialmethod.__get__.__qualname__.__eq__,   ["partialmethod.__get__"],   true]
    - [ft976pmy003, functools.partialmethod.__repr__.__qualname__.__eq__,  ["partialmethod.__repr__"],  true]
    - [ft976pmy004, functools.partialmethod.__isabstractmethod__.__qualname__.__eq__, ["partialmethod.__isabstractmethod__"], true]

table functools_extra976.cached_property_qualnames:
  description: "functools.cached_property method __qualname__ identity"
  kind: python_call_eq
  category: cached_property_qualnames
  id_prefix: ft976cp
  columns: [id, function, args, expected]
  rows:
    - [ft976cp001, functools.cached_property.__init__.__qualname__.__eq__,     ["cached_property.__init__"],     true]
    - [ft976cp002, functools.cached_property.__get__.__qualname__.__eq__,      ["cached_property.__get__"],      true]
    - [ft976cp003, functools.cached_property.__set_name__.__qualname__.__eq__, ["cached_property.__set_name__"], true]
    - [ft976cp004, functools.cached_property.__set__.__qualname__.__eq__,      ["cached_property.__set__"],      true]
    - [ft976cp005, functools.cached_property.__class__.__name__.__eq__,        ["type"],                         true]
