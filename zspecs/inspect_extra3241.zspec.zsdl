spec: in3241
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 663 (in3241): __rtruediv__, __rfloordiv__, __rmod__ dict-presence checks for inspect types."
    - "Theme: __rtruediv__, __rfloordiv__, __rmod__ dict-presence (reflected division/modulo)."
    - "Reflected operators are called when the left operand doesn't support the operation."
    - "All values False — these types have no reflected division/modulo protocol."
    - "No inspect type defines __rtruediv__, __rfloordiv__, or __rmod__ in its own __dict__."
    - "inspect.FrameInfo, inspect.ArgInfo, inspect.FullArgSpec, inspect.Attribute are namedtuple subclasses."
    - "inspect.ClassFoundException and inspect.EndOfBlock are exception types."
    - "None of these types implement reflected division/modulo protocols directly."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table in3241.rtruediv:
  description: "inspect types __rtruediv__ dict-presence checks; wave 663"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: in3241
  columns: [id, function, args, expected]
  rows:
    - ["in3241001", operator.contains, [inspect.Parameter.__dict__,           "__rtruediv__"], false]
    - ["in3241002", operator.contains, [inspect.Signature.__dict__,           "__rtruediv__"], false]
    - ["in3241003", operator.contains, [inspect.BoundArguments.__dict__,      "__rtruediv__"], false]
    - ["in3241004", operator.contains, [inspect.FrameInfo.__dict__,           "__rtruediv__"], false]
    - ["in3241005", operator.contains, [inspect.ArgInfo.__dict__,             "__rtruediv__"], false]
    - ["in3241006", operator.contains, [inspect.FullArgSpec.__dict__,         "__rtruediv__"], false]
    - ["in3241007", operator.contains, [inspect.Attribute.__dict__,           "__rtruediv__"], false]
    - ["in3241008", operator.contains, [inspect.ClassFoundException.__dict__, "__rtruediv__"], false]
    - ["in3241009", operator.contains, [inspect.EndOfBlock.__dict__,          "__rtruediv__"], false]

