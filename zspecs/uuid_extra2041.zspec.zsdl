spec: uuid_extra2041
version: ">=3.9"
backend: python_module(uuid)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rshift__, __and__, __or__, __xor__, __invert__ dict-presence checks."
    - "uuid.UUID is not a bitwise type; it defines none of these bit-shift or bitwise protocols in its own __dict__."
    - "uuid.SafeUUID is an IntEnum subclass; it inherits bitwise methods from int but defines none of them in its own __dict__."
    - "All bit-shift and bitwise dunder methods are absent from both uuid.UUID.__dict__ and uuid.SafeUUID.__dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table uuid_extra2041.uuid_lshift_protocol:
  description: "uuid.UUID __lshift__/__rlshift__/__ilshift__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu2041

  columns: [id, function, args, expected]
  rows:
    - ["uu2041001", "uuid.UUID.__dict__.__contains__", ["__lshift__"],  false]
    - ["uu2041002", "uuid.UUID.__dict__.__contains__", ["__rlshift__"], false]
    - ["uu2041003", "uuid.UUID.__dict__.__contains__", ["__ilshift__"], false]

