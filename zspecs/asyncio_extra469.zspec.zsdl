  columns: [id, function, args, expected]
  rows:
    - [tmod001, asyncio.BaseTransport.__module__.__eq__, ["asyncio.transports"], true]
    - [tmod002, asyncio.Transport.__module__.__eq__, ["asyncio.transports"], true]

table asyncio_extra469.transport_bases:
