spec: asyncio_extra469
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio-protocol.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-protocol.html — asyncio protocol and transport class identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers class name and module identity for asyncio Protocol, DatagramProtocol, SubprocessProtocol, BaseTransport, Transport, DatagramTransport, and SubprocessTransport"
    - "__bases__[0] function fields are double-quoted per ZSDL rules"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra469.protocol_names:
  description: "asyncio protocol class __name__ identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: pname

  columns: [id, function, args, expected]
  rows:
    - [pname001, asyncio.Protocol.__name__.__eq__, ["Protocol"], true]
    - [pname002, asyncio.DatagramProtocol.__name__.__eq__, ["DatagramProtocol"], true]
    - [pname003, asyncio.SubprocessProtocol.__name__.__eq__, ["SubprocessProtocol"], true]

table asyncio_extra469.protocol_modules:
  description: "asyncio protocol class __module__ identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: pmod

  columns: [id, function, args, expected]
  rows:
    - [pmod001, asyncio.Protocol.__module__.__eq__, ["asyncio.protocols"], true]
    - [pmod002, asyncio.DatagramProtocol.__module__.__eq__, ["asyncio.protocols"], true]
    - [pmod003, asyncio.SubprocessProtocol.__module__.__eq__, ["asyncio.protocols"], true]

table asyncio_extra469.protocol_bases:
  description: "asyncio protocol class __bases__[0] identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: pbase

  columns: [id, function, args, expected]
  rows:
    - [pbase001, "asyncio.Protocol.__bases__[0].__name__.__eq__", ["BaseProtocol"], true]

table asyncio_extra469.transport_names:
  description: "asyncio transport class __name__ identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: tname

  columns: [id, function, args, expected]
  rows:
    - [tname001, asyncio.BaseTransport.__name__.__eq__, ["BaseTransport"], true]
    - [tname002, asyncio.Transport.__name__.__eq__, ["Transport"], true]
    - [tname003, asyncio.DatagramTransport.__name__.__eq__, ["DatagramTransport"], true]
    - [tname004, asyncio.SubprocessTransport.__name__.__eq__, ["SubprocessTransport"], true]

table asyncio_extra469.transport_modules:
