spec: decimal_extra67
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and prior extras through decimal_extra66."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal.__dict__ membership; MAX_PREC/MAX_EMAX."
    - "decimal_extra66 covers: Decimal.__dict__ membership for arithmetic methods; getcontext/setcontext class/module/doc."
    - "This spec covers: decimal exception hierarchy — DecimalException/InvalidOperation/Overflow/Underflow/DivisionByZero __name__, __module__, __bases__ chain; Overflow.__bases__ length == 2; Underflow.__bases__ length == 3; DivisionByZero.__bases__[0].__name__."
    - "decimal.DecimalException.__name__ == 'DecimalException'."
    - "decimal.DecimalException.__module__ == 'decimal'."
    - "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — root decimal exception subclasses ArithmeticError."
    - "decimal.InvalidOperation.__name__ == 'InvalidOperation'."
    - "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' — single base."
    - "decimal.Overflow.__name__ == 'Overflow'."
    - "decimal.Overflow.__bases__[0].__name__ == 'Inexact' — Overflow has two bases: Inexact and Rounded."
    - "decimal.Overflow.__bases__.__len__() == 2 — Overflow uses multiple inheritance."
    - "decimal.Underflow.__name__ == 'Underflow'."
    - "decimal.Underflow.__bases__.__len__() == 3 — Underflow inherits from Inexact, Rounded, and Subnormal."
    - "decimal.DivisionByZero.__name__ == 'DivisionByZero'."
    - "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException'."
    - "decimal.DivisionByZero.__bases__.__len__() == 2 — DivisionByZero also subclasses ZeroDivisionError."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# DecimalException and InvalidOperation identity
# Prior decimal specs check __qualname__ for exceptions (decimal_extra65 area).
# This table combines __name__ and __module__ in the extra67 namespace.
# Not covered in prior specs in this exact combination.
# ---------------------------------------------------------------------------

table decimal_extra67.exception_names_modules:
  description: "decimal exception __name__ and __module__ identity"
  kind: python_call_eq
  category: class_names
  id_prefix: decimalcode67

  columns: [id, function, args, expected]
  rows:
    - [decimal_exc_name,   DecimalException.__name__.__eq__,   ["DecimalException"], true]
    - [decimal_exc_module, DecimalException.__module__.__eq__, ["decimal"],           true]
    - [invalid_op_name,    InvalidOperation.__name__.__eq__,   ["InvalidOperation"], true]
    - [overflow_name,      Overflow.__name__.__eq__,           ["Overflow"],         true]
    - [underflow_name,     Underflow.__name__.__eq__,          ["Underflow"],        true]
    - [divbyzero_name,     DivisionByZero.__name__.__eq__,     ["DivisionByZero"],   true]

# ---------------------------------------------------------------------------
# DecimalException and InvalidOperation base class checks
# DecimalException.__bases__[0].__name__ == 'ArithmeticError'.
# InvalidOperation.__bases__[0].__name__ == 'DecimalException'.
# Function values containing [ must be double-quoted.
# ---------------------------------------------------------------------------

table decimal_extra67.exception_bases:
  description: "decimal exception base class __name__ values"
  kind: python_call_eq
  category: class_bases
  id_prefix: decimalcode67

  columns: [id, function, args, expected]
  rows:
    - [decimal_exc_base, "DecimalException.__bases__[0].__name__.__eq__", ["ArithmeticError"],  true]
    - [invalid_op_base,  "InvalidOperation.__bases__[0].__name__.__eq__", ["DecimalException"], true]
    - [divbyzero_base,   "DivisionByZero.__bases__[0].__name__.__eq__",   ["DecimalException"], true]
    - [overflow_base,    "Overflow.__bases__[0].__name__.__eq__",         ["Inexact"],          true]

# ---------------------------------------------------------------------------
# Overflow and Underflow base count checks — multiple inheritance
# Overflow inherits from Inexact and Rounded (2 bases).
# Underflow inherits from Inexact, Rounded, and Subnormal (3 bases).
# DivisionByZero inherits from DecimalException and ZeroDivisionError (2 bases).
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra67.exception_bases_length:
  description: "decimal exception __bases__.__len__() for multiple-inheritance exceptions"
  kind: python_call_eq
  category: class_bases
  id_prefix: decimalcode67

  columns: [id, function, args, expected]
  rows:
    - [overflow_bases_len,    Overflow.__bases__.__len__,    [], 2]
    - [underflow_bases_len,   Underflow.__bases__.__len__,   [], 3]
    - [divbyzero_bases_len,   DivisionByZero.__bases__.__len__, [], 2]
    - [invalid_op_bases_len,  InvalidOperation.__bases__.__len__, [], 1]

# ---------------------------------------------------------------------------
# Exception __name__ length checks
# DecimalException == 16 chars, InvalidOperation == 16, Overflow == 8,
# Underflow == 9, DivisionByZero == 14.
# Not covered in any prior decimal spec.
# ---------------------------------------------------------------------------

table decimal_extra67.exception_name_lengths:
  description: "decimal exception __name__ string lengths"
  kind: python_call_eq
  category: class_names
  id_prefix: decimalcode67

  columns: [id, function, args, expected]
  rows:
    - [decimal_exc_len, DecimalException.__name__.__len__, [], 16]
    - [invalid_op_len,  InvalidOperation.__name__.__len__, [], 16]
    - [overflow_len,    Overflow.__name__.__len__,         [], 8]
    - [underflow_len,   Underflow.__name__.__len__,        [], 9]
    - [divbyzero_len,   DivisionByZero.__name__.__len__,   [], 14]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra67.DecimalException.name_eq:
  description: "decimal.DecimalException.__name__ == 'DecimalException'"
  category: class_names
  kind: python_call_eq
  function: DecimalException.__name__.__eq__
  args: ["DecimalException"]
  expected: true

invariant decimal_extra67.DecimalException.base_arithmeticerror:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError'"
  category: class_bases
  kind: python_call_eq
  function: "DecimalException.__bases__[0].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra67.InvalidOperation.base_decimalexception:
  description: "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException'"
  category: class_bases
  kind: python_call_eq
  function: "InvalidOperation.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra67.Overflow.bases_len_2:
  description: "decimal.Overflow.__bases__.__len__() == 2 — multiple inheritance from Inexact and Rounded"
  category: class_bases
  kind: python_call_eq
  function: Overflow.__bases__.__len__
  args: []
  expected: 2

invariant decimal_extra67.Underflow.bases_len_3:
  description: "decimal.Underflow.__bases__.__len__() == 3 — multiple inheritance from Inexact, Rounded, Subnormal"
  category: class_bases
  kind: python_call_eq
  function: Underflow.__bases__.__len__
  args: []
  expected: 3
