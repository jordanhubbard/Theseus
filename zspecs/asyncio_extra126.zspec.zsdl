invariant asyncio_extra126.Queue_put_varnames_len_3:
  description: "asyncio.Queue.put.__code__.co_varnames.__len__() == 3 — asyncio.Queue.put.__code__.co_varnames is ('self', 'item', 'putter'); the 3 co_varnames are: self (the instance), item (the queued value), and putter (a local asyncio.Future used to wait for queue space when the queue is full); compare co_varnames lengths across Queue methods in this spec: task_done=1, get=2, get_nowait=2, put_nowait=2, put=3; put has the most co_varnames because it creates a putter future when the queue is at capacity; put.__code__.co_argcount is 2 (self, item); put.__code__.co_name is 'put' (len=3); Queue.__module__ is 'asyncio.queues'; NEW in extra126: first standalone Queue.put co_varnames length invariant in asyncioqueuecv126 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: asyncio.Queue.put.__code__.co_varnames.__len__
  args: []
  expected: 3

invariant asyncio_extra126.Queue_task_done_varnames_len_1:
  description: "asyncio.Queue.task_done.__code__.co_varnames.__len__() == 1 — asyncio.Queue.task_done.__code__.co_varnames is ('self',); this is the shortest co_varnames list among all Queue methods in this spec (task_done=1 < get=2 = get_nowait=2 = put_nowait=2 < put=3); task_done(self) is defined as a regular def (not async) with just self; it raises ValueError if called more times than items placed in the queue; task_done.__code__.co_name is 'task_done' (len=9); task_done.__code__.co_argcount is 1 (self only); Queue.task_done() is used with Queue.join() to signal that a previously enqueued task has been completed; NEW in extra126: first standalone Queue.task_done co_varnames length invariant in asyncioqueuecv126 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: asyncio.Queue.task_done.__code__.co_varnames.__len__
  args: []
  expected: 1

invariant asyncio_extra126.Queue_put_varnames_1_is_item:
  description: "asyncio.Queue.put.__code__.co_varnames.__getitem__(1).__eq__('item') returns 'item' — asyncio.Queue.put.__code__.co_varnames[1] is 'item' (the second positional parameter to put(self, item)); co_varnames[0] is 'self' and co_varnames[2] is 'putter' (a local variable); 'item' is 4 chars; compare first co_varnames: put[0]='self', put[1]='item', get[0]='self', put_nowait[0]='self', put_nowait[1]='item', task_done[0]='self'; both put and put_nowait have 'item' as their co_varnames[1], while get and task_done take only self; put.__code__.co_argcount is 2 (both self and item are positional params); NEW in extra126: first standalone Queue.put co_varnames[1] invariant in asyncioqueuecv126 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: asyncio.Queue.put.__code__.co_varnames.__getitem__
  args: [1]
  expected: "item"

invariant asyncio_extra126.Queue_get_argc_is_1:
  description: "asyncio.Queue.get.__code__.co_argcount.__eq__(1) returns True — asyncio.Queue.get is defined as 'async def get(self)' with exactly one positional parameter (self); co_argcount==1 (only self); co_varnames.__len__() is 2 (self plus local getter); compare co_argcount values across Queue methods: task_done=1, get=1, get_nowait=1, put_nowait=2, put=2; both get and task_done have co_argcount==1; both put and put_nowait have co_argcount==2; get.__code__.co_name is 'get' (len=3); get.__code__.co_varnames[0] is 'self'; Queue.get is a coroutine (async def) that waits for an item to become available; NEW in extra126: first standalone Queue.get co_argcount invariant in asyncioqueuecv126 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: asyncio.Queue.get.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant asyncio_extra126.Queue_put_nowait_varnames_len_2:
  description: "asyncio.Queue.put_nowait.__code__.co_varnames.__len__() == 2 — asyncio.Queue.put_nowait.__code__.co_varnames is ('self', 'item'); put_nowait has exactly 2 co_varnames (self and item) with no extra local variables; this contrasts with put which has 3 co_varnames (self, item, putter) because put is async and uses a putter Future for waiting; put_nowait raises QueueFull immediately if the queue is full rather than waiting — hence no putter local; put_nowait.__code__.co_argcount is 2 (self, item); put_nowait.__code__.co_name is 'put_nowait' (len=9); compare: put_nowait co_varnames len=2 while put co_varnames len=3 (one more for the waiting future); NEW in extra126: first standalone Queue.put_nowait co_varnames length invariant in asyncioqueuecv126 namespace; wave 255; verified with Python 3.14.3"
  category: code_inspection
  kind: python_call_eq
  function: asyncio.Queue.put_nowait.__code__.co_varnames.__len__
  args: []
  expected: 2

