# Wave 255 theme: asyncio.Queue method co_varnames.
#
# asyncio.Queue.put.__code__.co_varnames[0]  == 'self'  (param 0)
# asyncio.Queue.put.__code__.co_varnames[1]  == 'item'  (param 1)
# asyncio.Queue.put.__code__.co_argcount     == 2       (self, item)
# asyncio.Queue.put.__code__.co_varnames.__len__() == 3 (self, item, putter)
# asyncio.Queue.get.__code__.co_varnames[0]  == 'self'  (param 0)
# asyncio.Queue.get.__code__.co_argcount     == 1       (self only)
# asyncio.Queue.get.__code__.co_varnames.__len__() == 2 (self, getter)
# ---------------------------------------------------------------------------

table asyncio_extra126.asyncio_queue_put_get_varnames:
  description: "asyncio.Queue.put and get __code__.co_varnames checks in asyncioqueuecv126 namespace — wave 255 theme: asyncio.Queue methods are pure-Python (class='function') defined in Lib/asyncio/queues.py; asyncio.Queue.put.__code__.co_varnames.__getitem__(0).__eq__('self')==True (first co_varname is always 'self' for instance methods); asyncio.Queue.put.__code__.co_varnames.__getitem__(1).__eq__('item')==True (second co_varname is the item parameter); asyncio.Queue.put.__code__.co_argcount.__eq__(2)==True (two positional params: self and item); asyncio.Queue.put.__code__.co_varnames.__len__()==3 (3 total varnames: self, item, plus local variable putter used for waiting in the internal queue); asyncio.Queue.get.__code__.co_varnames.__getitem__(0).__eq__('self')==True (get only takes self); asyncio.Queue.get.__code__.co_argcount.__eq__(1)==True (one positional param: self); asyncio.Queue.get.__code__.co_varnames.__len__()==2 (2 varnames: self plus local variable getter); Queue.put is a coroutine (async def) that blocks if the queue is full; Queue.get is a coroutine (async def) that blocks if the queue is empty; both use internal putter/getter futures to implement async waiting; Queue.__module__ is 'asyncio.queues' (defined in Lib/asyncio/queues.py); Queue.__class__.__name__ is 'type'; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_inspection
  id_prefix: asyncioqueuecv126

  columns: [id, function, args, expected, description]
  rows:
