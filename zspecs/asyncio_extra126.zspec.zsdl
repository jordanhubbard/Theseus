    - [put_var1,     asyncio.Queue.put.__code__.co_varnames.__getitem__,   [1],    "item",  "asyncio.Queue.put.__code__.co_varnames[1] == 'item' (second param); verified with Python 3.14.3"]
    - [put_argc,     asyncio.Queue.put.__code__.co_argcount.__eq__,        [2],    true,    "asyncio.Queue.put.__code__.co_argcount == 2 (self, item); verified with Python 3.14.3"]
    - [put_varlen,   asyncio.Queue.put.__code__.co_varnames.__len__,       [],     3,       "asyncio.Queue.put.__code__.co_varnames.__len__() == 3 (self, item, putter); verified with Python 3.14.3"]
    - [get_var0,     asyncio.Queue.get.__code__.co_varnames.__getitem__,   [0],    "self",  "asyncio.Queue.get.__code__.co_varnames[0] == 'self' (get only takes self as positional param); verified with Python 3.14.3"]
