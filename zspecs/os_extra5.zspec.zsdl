spec: os_extra5
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/os.py"
    - "CPython source: Modules/posixmodule.c"
  notes:
    - "Extends os.zspec.zsdl, os_extra.zspec.zsdl, os_extra2.zspec.zsdl, os_extra3.zspec.zsdl, os_extra4.zspec.zsdl."
    - "os.zspec.zsdl covers in function_names table: getcwd, getenv, getpid, getppid, listdir, makedirs, remove, rename, stat, walk, urandom, cpu_count, strerror, getuid, getgid."
    - "os_extra2.zspec.zsdl covers in function_names table: getcwd, listdir, makedirs."
    - "This spec adds __name__ checks for functions not yet individually covered: scandir, removedirs, renames, symlink, link, unlink, mkdir, rmdir, chdir."
    - "os.rename.__name__ and os.remove.__name__ and os.walk.__name__ are in os.zspec.zsdl table; this spec provides individually named invariants for completeness."
    - "os.scandir.__name__ == 'scandir' — yields DirEntry objects for directory entries (Python 3.5+)."
    - "os.removedirs.__name__ == 'removedirs' — removes a directory tree by recursively removing empty parents."
    - "os.renames.__name__ == 'renames' — recursive rename that creates intermediate directories as needed."
    - "os.symlink.__name__ == 'symlink' — creates a symbolic link at dst pointing to src."
    - "os.link.__name__ == 'link' — creates a hard link."
    - "os.unlink.__name__ == 'unlink' — removes a file (alias for os.remove on POSIX)."
    - "os.mkdir.__name__ == 'mkdir' — creates a single directory."
    - "os.rmdir.__name__ == 'rmdir' — removes an empty directory."
    - "os.chdir.__name__ == 'chdir' — changes the current working directory."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks — new functions not individually covered in prior specs
#
# os.zspec.zsdl table covers: getcwd, getenv, getpid, getppid, listdir,
# makedirs, remove, rename, stat, walk, urandom, cpu_count, strerror,
# getuid, getgid — but as table rows, not named invariants.
# os_extra2.zspec.zsdl table covers: getcwd, listdir, makedirs.
# This spec provides individually named invariants for functions below.
# ---------------------------------------------------------------------------

invariant os_extra5.scandir.name:
  description: "os.scandir.__name__ == 'scandir'"
  category: function_names
  kind: python_call_eq
  function: scandir.__name__.__eq__
  args: ["scandir"]
  expected: true

invariant os_extra5.listdir.name:
  description: "os.listdir.__name__ == 'listdir'"
  category: function_names
  kind: python_call_eq
  function: listdir.__name__.__eq__
  args: ["listdir"]
  expected: true

