spec: decimal_extra257
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "Decimal arithmetic is exact: '1'+'2'=='3', '2'*'3'=='6', '10'-'3'=='7', '3'**'2'=='9'."
    - "Decimal('10') / Decimal('3') == '3.333333333333333333333333333' at default precision of 28."
    - "Decimal('Inf').is_infinite()==True, Decimal('NaN').is_nan()==True, Decimal('0').is_zero()==True."
    - "Decimal('1').is_finite()==True — a regular finite number."
    - "type(Decimal('Inf')).__name__ == 'Decimal' — special values are still Decimal instances."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal arithmetic — string representations of results
# ---------------------------------------------------------------------------

table decimal_extra257.arithmetic.str_repr:
  description: "Basic Decimal arithmetic — str() of result matches exact decimal encoding"
  kind: python_call_eq
  category: arithmetic
  id_prefix: arith
  function: Decimal
  method: __str__

  columns: [id, args, expected]
  rows:
    - [one,        ["1"],   "1"  ]
    - [two,        ["2"],   "2"  ]
    - [three,      ["3"],   "3"  ]
    - [six,        ["6"],   "6"  ]
    - [nine,       ["9"],   "9"  ]
    - [zero,       ["0"],   "0"  ]

# ---------------------------------------------------------------------------
# Decimal addition
# ---------------------------------------------------------------------------

invariant decimal_extra257.add.one_plus_two:
  description: "str(Decimal('1') + Decimal('2')) == '3'"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: __add__
  method_args: ["2"]
  method_chain: __str__
  expected: "3"

invariant decimal_extra257.add.two_plus_three:
  description: "str(Decimal('2') + Decimal('3')) == '5'"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["2"]
  method: __add__
  method_args: ["3"]
  method_chain: __str__
  expected: "5"

# ---------------------------------------------------------------------------
# Decimal multiplication
# ---------------------------------------------------------------------------

invariant decimal_extra257.mul.two_times_three:
  description: "str(Decimal('2') * Decimal('3')) == '6'"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["2"]
  method: __mul__
  method_args: ["3"]
  method_chain: __str__
  expected: "6"

invariant decimal_extra257.mul.three_squared:
  description: "str(Decimal('3') ** Decimal('2')) == '9'"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["3"]
  method: __pow__
  method_args: ["2"]
  method_chain: __str__
  expected: "9"

# ---------------------------------------------------------------------------
# Decimal subtraction
# ---------------------------------------------------------------------------

invariant decimal_extra257.sub.ten_minus_three:
  description: "str(Decimal('10') - Decimal('3')) == '7'"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["10"]
  method: __sub__
  method_args: ["3"]
  method_chain: __str__
  expected: "7"

# ---------------------------------------------------------------------------
# Decimal division — default 28-digit precision
# ---------------------------------------------------------------------------

invariant decimal_extra257.div.ten_div_three:
  description: "str(Decimal('10') / Decimal('3')) == '3.333333333333333333333333333' at default prec=28"
  category: arithmetic
  kind: python_call_eq
  function: Decimal
  args: ["10"]
  method: __truediv__
  method_args: ["3"]
  method_chain: __str__
  expected: "3.333333333333333333333333333"

# ---------------------------------------------------------------------------
# Decimal special-value predicates
# ---------------------------------------------------------------------------

invariant decimal_extra257.special.zero_is_zero:
  description: "Decimal('0').is_zero() == True"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: is_zero
  expected: true

invariant decimal_extra257.special.inf_is_infinite:
  description: "Decimal('Inf').is_infinite() == True"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["Inf"]
  method: is_infinite
  expected: true

invariant decimal_extra257.special.nan_is_nan:
  description: "Decimal('NaN').is_nan() == True"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: is_nan
  expected: true

invariant decimal_extra257.special.one_is_finite:
  description: "Decimal('1').is_finite() == True"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_finite
  expected: true

invariant decimal_extra257.special.inf_not_finite:
  description: "Decimal('Inf').is_finite() == False"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["Inf"]
  method: is_finite
  expected: false

invariant decimal_extra257.special.nan_not_finite:
  description: "Decimal('NaN').is_finite() == False"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: is_finite
  expected: false

# ---------------------------------------------------------------------------
# Decimal class identity — special values are Decimal instances
# ---------------------------------------------------------------------------

invariant decimal_extra257.class.name:
  description: "Decimal.__name__ == 'Decimal'"
  category: class_metadata
  kind: python_call_eq
  function: Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra257.class.module:
  description: "Decimal.__module__ == 'decimal'"
  category: class_metadata
  kind: python_call_eq
  function: Decimal.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra257.special.inf_class_name:
  description: "type(Decimal('Inf')).__name__ == 'Decimal' — Inf is still a Decimal instance"
  category: class_metadata
  kind: python_call_eq
  function: Decimal
  args: ["Inf"]
  method: __class__
  method_chain: __name__
  expected: "Decimal"

invariant decimal_extra257.special.nan_class_name:
  description: "type(Decimal('NaN')).__name__ == 'Decimal' — NaN is still a Decimal instance"
  category: class_metadata
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: __class__
  method_chain: __name__
  expected: "Decimal"

invariant decimal_extra257.special.zero_class_name:
  description: "type(Decimal('0')).__name__ == 'Decimal' — zero is a Decimal instance"
  category: class_metadata
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: __class__
  method_chain: __name__
  expected: "Decimal"
