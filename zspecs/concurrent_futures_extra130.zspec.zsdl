spec: concurrent_futures_extra130
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: wave 256 theme — concurrent.futures.InvalidStateError class hierarchy identity. NEW in extra130: concurrent.futures.InvalidStateError.__mro__.__len__()==5 (MRO=[InvalidStateError, Error, Exception, BaseException, object]); concurrent.futures.InvalidStateError.__name__=='InvalidStateError' (len=17); concurrent.futures.InvalidStateError.__module__=='concurrent.futures._base' (len=24); concurrent.futures.InvalidStateError.__qualname__=='InvalidStateError' (len=17); concurrent.futures.InvalidStateError.__bases__[0].__name__=='Error'; concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__=='Executor' (len=8); concurrent.futures.ProcessPoolExecutor.__mro__.__len__()==3; concurrent.futures.ProcessPoolExecutor.__module__=='concurrent.futures.process' (len=26); concurrent.futures.BrokenExecutor.__name__=='BrokenExecutor' (len=14); concurrent.futures.BrokenExecutor.__bases__[0].__name__=='RuntimeError'; concurrent.futures.BrokenExecutor.__mro__.__len__()==5. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.InvalidStateError.__mro__.__len__() == 5. MRO is [InvalidStateError, Error, Exception, BaseException, object] — the intermediate 'Error' class is concurrent.futures._base.Error. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base' (len=24). InvalidStateError is defined in Lib/concurrent/futures/_base.py, not in __init__.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'. BrokenExecutor inherits from RuntimeError (not Error or Exception), giving MRO [BrokenExecutor, RuntimeError, Exception, BaseException, object] (length=5). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.InvalidStateError class hierarchy — extra130
#
# Wave 256 theme: concurrent.futures.InvalidStateError class hierarchy identity.
#
# concurrent.futures.InvalidStateError.__mro__.__len__()         == 5
# concurrent.futures.InvalidStateError.__name__                  == 'InvalidStateError'  (len=17)
# concurrent.futures.InvalidStateError.__module__                == 'concurrent.futures._base'  (len=24)
# concurrent.futures.InvalidStateError.__qualname__              == 'InvalidStateError'  (len=17)
# concurrent.futures.InvalidStateError.__bases__[0].__name__     == 'Error'
# ---------------------------------------------------------------------------

table concurrent_futures_extra130.cf_invalid_state_error_identity:
  description: "concurrent.futures.InvalidStateError class hierarchy identity checks in cfinvalidstate130 namespace — wave 256 theme: InvalidStateError class hierarchy; InvalidStateError inherits from concurrent.futures._base.Error (an intermediate exception class), giving the 5-element MRO [InvalidStateError, Error, Exception, BaseException, object]; InvalidStateError.__name__.__eq__('InvalidStateError')==True (len=17); InvalidStateError.__module__.__eq__('concurrent.futures._base')==True (len=24: 'concurrent.futures._base'=24); InvalidStateError.__qualname__.__eq__('InvalidStateError')==True (len=17, module-level class so qualname equals name); InvalidStateError.__bases__[0].__name__.__eq__('Error')==True (the intermediate Error base class, not Exception); InvalidStateError.__mro__.__len__()==5 (MRO=[InvalidStateError, Error, Exception, BaseException, object]); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfinvalidstate130

  columns: [id, function, args, expected, description]
  rows:
    - [ise_name_eq,    "concurrent.futures.InvalidStateError.__name__.__eq__",                      ["InvalidStateError"],           true, "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError' (len=17); verified with Python 3.14.3"]
    - [ise_name_len,   "concurrent.futures.InvalidStateError.__name__.__len__",                     [],                             17,   "concurrent.futures.InvalidStateError.__name__.__len__() == 17; verified with Python 3.14.3"]
    - [ise_module_eq,  "concurrent.futures.InvalidStateError.__module__.__eq__",                    ["concurrent.futures._base"],    true, "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [ise_module_len, "concurrent.futures.InvalidStateError.__module__.__len__",                   [],                             24,   "concurrent.futures.InvalidStateError.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [ise_qn_eq,      "concurrent.futures.InvalidStateError.__qualname__.__eq__",                  ["InvalidStateError"],           true, "concurrent.futures.InvalidStateError.__qualname__ == 'InvalidStateError' (len=17); verified with Python 3.14.3"]
    - [ise_qn_len,     "concurrent.futures.InvalidStateError.__qualname__.__len__",                 [],                             17,   "concurrent.futures.InvalidStateError.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [ise_base0,      "concurrent.futures.InvalidStateError.__bases__[0].__name__.__eq__",         ["Error"],                      true, "concurrent.futures.InvalidStateError.__bases__[0].__name__ == 'Error' (intermediate base class); verified with Python 3.14.3"]
    - [ise_mro_len,    "concurrent.futures.InvalidStateError.__mro__.__len__",                      [],                             5,    "concurrent.futures.InvalidStateError.__mro__.__len__() == 5 — [InvalidStateError, Error, Exception, BaseException, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor class identity — extra130
#
# concurrent.futures.ProcessPoolExecutor.__name__              == 'ProcessPoolExecutor' (len=19)
# concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'  (len=8)
# concurrent.futures.ProcessPoolExecutor.__mro__.__len__()     == 3
# concurrent.futures.ProcessPoolExecutor.__module__            == 'concurrent.futures.process' (len=26)
# ---------------------------------------------------------------------------

table concurrent_futures_extra130.cf_process_pool_executor_identity:
  description: "concurrent.futures.ProcessPoolExecutor class identity checks in cfinvalidstate130 namespace — wave 256 theme: ProcessPoolExecutor class identity; ProcessPoolExecutor inherits from Executor (the abstract base class), giving the 3-element MRO [ProcessPoolExecutor, Executor, object]; ProcessPoolExecutor.__name__.__eq__('ProcessPoolExecutor')==True (len=19: 'Process'=7+'Pool'=4+'Executor'=8); ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (direct subclass of Executor, same as ThreadPoolExecutor); ProcessPoolExecutor.__mro__.__len__()==3 (MRO=[ProcessPoolExecutor, Executor, object]; same depth as ThreadPoolExecutor); ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process')==True (len=26: 'concurrent.futures.process'=26, defined in Lib/concurrent/futures/process.py); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfinvalidstate130a

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_name_eq,    "concurrent.futures.ProcessPoolExecutor.__name__.__eq__",                    ["ProcessPoolExecutor"],          true, "concurrent.futures.ProcessPoolExecutor.__name__ == 'ProcessPoolExecutor' (len=19); verified with Python 3.14.3"]
    - [ppe_name_len,   "concurrent.futures.ProcessPoolExecutor.__name__.__len__",                   [],                              19,   "concurrent.futures.ProcessPoolExecutor.__name__.__len__() == 19 ('Process'=7+'Pool'=4+'Executor'=8); verified with Python 3.14.3"]
    - [ppe_base0,      "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__",       ["Executor"],                    true, "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__ == 'Executor' (len=8); verified with Python 3.14.3"]
    - [ppe_base0_len,  "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__len__",      [],                              8,    "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__len__() == 8 ('Executor'=8); verified with Python 3.14.3"]
    - [ppe_mro_len,    "concurrent.futures.ProcessPoolExecutor.__mro__.__len__",                    [],                              3,    "concurrent.futures.ProcessPoolExecutor.__mro__.__len__() == 3 — [ProcessPoolExecutor, Executor, object]; verified with Python 3.14.3"]
    - [ppe_module_eq,  "concurrent.futures.ProcessPoolExecutor.__module__.__eq__",                  ["concurrent.futures.process"],  true, "concurrent.futures.ProcessPoolExecutor.__module__ == 'concurrent.futures.process' (len=26); verified with Python 3.14.3"]
    - [ppe_module_len, "concurrent.futures.ProcessPoolExecutor.__module__.__len__",                 [],                              26,   "concurrent.futures.ProcessPoolExecutor.__module__.__len__() == 26 ('concurrent.futures.process'=26); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.BrokenExecutor class identity — extra130
#
# concurrent.futures.BrokenExecutor.__name__              == 'BrokenExecutor' (len=14)
# concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'
# concurrent.futures.BrokenExecutor.__mro__.__len__()     == 5
# concurrent.futures.BrokenExecutor.__module__            == 'concurrent.futures._base' (len=24)
# ---------------------------------------------------------------------------

table concurrent_futures_extra130.cf_broken_executor_identity:
  description: "concurrent.futures.BrokenExecutor class identity checks in cfinvalidstate130 namespace — wave 256 theme: BrokenExecutor class identity; BrokenExecutor inherits from RuntimeError (not from Error, unlike InvalidStateError), giving the 5-element MRO [BrokenExecutor, RuntimeError, Exception, BaseException, object]; BrokenExecutor.__name__.__eq__('BrokenExecutor')==True (len=14: 'Broken'=6+'Executor'=8); BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError')==True (distinguishes it from InvalidStateError which bases on Error); BrokenExecutor.__mro__.__len__()==5 (same depth as InvalidStateError: both have 5-element MROs despite different intermediate bases); BrokenExecutor.__module__.__eq__('concurrent.futures._base')==True (len=24, same module as InvalidStateError); BrokenExecutor.__module__.__len__()==24; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfinvalidstate130b

  columns: [id, function, args, expected, description]
  rows:
    - [be_name_eq,    "concurrent.futures.BrokenExecutor.__name__.__eq__",                         ["BrokenExecutor"],              true, "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor' (len=14); verified with Python 3.14.3"]
    - [be_name_len,   "concurrent.futures.BrokenExecutor.__name__.__len__",                        [],                              14,   "concurrent.futures.BrokenExecutor.__name__.__len__() == 14 ('Broken'=6+'Executor'=8); verified with Python 3.14.3"]
    - [be_base0,      "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__",            ["RuntimeError"],                true, "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' (not Error; different from InvalidStateError); verified with Python 3.14.3"]
    - [be_mro_len,    "concurrent.futures.BrokenExecutor.__mro__.__len__",                         [],                              5,    "concurrent.futures.BrokenExecutor.__mro__.__len__() == 5 — [BrokenExecutor, RuntimeError, Exception, BaseException, object]; verified with Python 3.14.3"]
    - [be_module_eq,  "concurrent.futures.BrokenExecutor.__module__.__eq__",                       ["concurrent.futures._base"],    true, "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [be_module_len, "concurrent.futures.BrokenExecutor.__module__.__len__",                      [],                              24,   "concurrent.futures.BrokenExecutor.__module__.__len__() == 24 (same module as InvalidStateError); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra130
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra130.InvalidStateError_mro_len_5:
  description: "concurrent.futures.InvalidStateError.__mro__.__len__() == 5 — InvalidStateError's MRO is [InvalidStateError, Error, Exception, BaseException, object] (length=5); the intermediate 'Error' class is concurrent.futures._base.Error, a private exception base class defined in Lib/concurrent/futures/_base.py; this 5-level depth is deeper than ProcessPoolExecutor (depth=3 via [ProcessPoolExecutor, Executor, object]) and equal to BrokenExecutor (depth=5 via [BrokenExecutor, RuntimeError, Exception, BaseException, object]); InvalidStateError.__module__ is 'concurrent.futures._base' (len=24); InvalidStateError.__name__.__len__() is 17; NEW in extra130: first standalone InvalidStateError MRO length invariant in cfinvalidstate130 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.InvalidStateError.__mro__.__len__"
  args: []
  expected: 5

invariant concurrent_futures_extra130.InvalidStateError_name_len_17:
  description: "concurrent.futures.InvalidStateError.__name__.__len__() == 17 — InvalidStateError.__name__ is 'InvalidStateError' (17 chars: 'Invalid'=7 + 'State'=5 + 'Error'=5 = 17); this is the longest exception name in concurrent.futures: InvalidStateError=17 > BrokenExecutor=14 > CancelledError=14 > BrokenThreadPool=15 (not in this spec); InvalidStateError.__qualname__ is also 'InvalidStateError' (len=17, module-level class so qualname equals name); InvalidStateError.__module__ is 'concurrent.futures._base' (len=24); InvalidStateError.__bases__[0].__name__ is 'Error' (the intermediate concurrent.futures._base.Error base); NEW in extra130: first standalone InvalidStateError name length invariant in cfinvalidstate130 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.InvalidStateError.__name__.__len__"
  args: []
  expected: 17

invariant concurrent_futures_extra130.InvalidStateError_module_len_24:
  description: "concurrent.futures.InvalidStateError.__module__.__len__() == 24 — InvalidStateError.__module__ is 'concurrent.futures._base' (24 chars: 'concurrent'=10 + '.'=1 + 'futures'=7 + '.'=1 + '_base'=5 = 24); this is different from the package __name__ 'concurrent.futures' (18 chars) — the actual definition module is the private _base submodule; concurrent.futures.BrokenExecutor.__module__ is also 'concurrent.futures._base' (same len=24); ProcessPoolExecutor.__module__ is 'concurrent.futures.process' (len=26, the longest module name); NEW in extra130: first standalone InvalidStateError module length invariant in cfinvalidstate130 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.InvalidStateError.__module__.__len__"
  args: []
  expected: 24

invariant concurrent_futures_extra130.ProcessPoolExecutor_base_is_Executor:
  description: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor') returns True — ProcessPoolExecutor inherits from Executor (the abstract base class for all executors), giving the 3-element MRO [ProcessPoolExecutor, Executor, object]; Executor.__name__ is 'Executor' (len=8); ProcessPoolExecutor.__name__ is 'ProcessPoolExecutor' (len=19); ProcessPoolExecutor.__module__ is 'concurrent.futures.process' (len=26, the longest of the executor module names); ThreadPoolExecutor also inherits from Executor with the same 3-element MRO; Executor.__module__ is 'concurrent.futures._base' (the same private base module as InvalidStateError); NEW in extra130: first standalone ProcessPoolExecutor base class invariant in cfinvalidstate130 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra130.BrokenExecutor_mro_len_5:
  description: "concurrent.futures.BrokenExecutor.__mro__.__len__() == 5 — BrokenExecutor's MRO is [BrokenExecutor, RuntimeError, Exception, BaseException, object] (length=5); this matches InvalidStateError's MRO depth of 5 despite different intermediate bases — BrokenExecutor uses RuntimeError as its direct base while InvalidStateError uses Error; BrokenExecutor.__name__ is 'BrokenExecutor' (len=14); BrokenExecutor.__module__ is 'concurrent.futures._base' (len=24); contrast with ProcessPoolExecutor (MRO len=3, inherits from Executor) — executor classes have much shallower MROs than the exception classes; NEW in extra130: first standalone BrokenExecutor MRO length invariant in cfinvalidstate130 namespace; wave 256; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.BrokenExecutor.__mro__.__len__"
  args: []
  expected: 5
