spec: abc_extra271
version: ">=3.9"
backend: python_module(collections.abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.Callable.__module__ == 'collections.abc'; __bases__[0].__name__ == 'object'."
    - "collections.abc.Callable.__abstractmethods__ == frozenset({'__call__'}) — only __call__ must be implemented."
    - "collections.abc.Hashable.__module__ == 'collections.abc'; __bases__[0].__name__ == 'object'."
    - "collections.abc.Hashable.__abstractmethods__ == frozenset({'__hash__'}) — only __hash__ must be implemented."
    - "collections.abc.Sized.__module__ == 'collections.abc'; __bases__[0].__name__ == 'object'."
    - "collections.abc.Sized.__abstractmethods__ == frozenset({'__len__'}) — only __len__ must be implemented."
    - "collections.abc.Container.__module__ == 'collections.abc'; __bases__[0].__name__ == 'object'."
    - "collections.abc.Container.__abstractmethods__ == frozenset({'__contains__'}) — only __contains__ must be implemented."
    - "All four ABCs (Callable, Hashable, Sized, Container) inherit directly from object and each requires exactly one abstract method."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# collections.abc.Callable and Hashable class identity — table
#
# Both are single-abstract-method ABCs that inherit directly from object.
# Callable requires __call__; Hashable requires __hash__.
# ---------------------------------------------------------------------------

table abc_extra271.callable_hashable_identity:
  description: "collections.abc.Callable and Hashable class identity and abstract method names"
  kind: python_call_eq
  category: identity
  id_prefix: callhash271

  columns: [id, function, args, expected, description]
  rows:
    - [ca_name,      collections.abc.Callable.__name__.__eq__,              ["Callable"],       true, "collections.abc.Callable.__name__ == 'Callable'"]
    - [ca_module,    collections.abc.Callable.__module__.__eq__,            ["collections.abc"], true, "collections.abc.Callable.__module__ == 'collections.abc'"]
    - [ca_call_name, collections.abc.Callable.__call__.__name__.__eq__,     ["__call__"],        true, "collections.abc.Callable.__call__.__name__ == '__call__'"]
    - [ca_abstract,  "collections.abc.Callable.__abstractmethods__.__contains__", ["__call__"],  true, "collections.abc.Callable.__abstractmethods__ contains '__call__'"]
    - [ha_name,      collections.abc.Hashable.__name__.__eq__,              ["Hashable"],        true, "collections.abc.Hashable.__name__ == 'Hashable'"]
    - [ha_module,    collections.abc.Hashable.__module__.__eq__,            ["collections.abc"], true, "collections.abc.Hashable.__module__ == 'collections.abc'"]
    - [ha_hash_name, collections.abc.Hashable.__hash__.__name__.__eq__,     ["__hash__"],        true, "collections.abc.Hashable.__hash__.__name__ == '__hash__'"]
    - [ha_abstract,  "collections.abc.Hashable.__abstractmethods__.__contains__", ["__hash__"],  true, "collections.abc.Hashable.__abstractmethods__ contains '__hash__'"]

# ---------------------------------------------------------------------------
# collections.abc.Sized and Container class identity — table
#
# Both are single-abstract-method ABCs inheriting directly from object.
# Sized requires __len__; Container requires __contains__.
# ---------------------------------------------------------------------------

table abc_extra271.sized_container_identity:
  description: "collections.abc.Sized and Container class identity and abstract method names"
  kind: python_call_eq
  category: identity
  id_prefix: sizecont271

  columns: [id, function, args, expected, description]
  rows:
    - [si_name,      collections.abc.Sized.__name__.__eq__,                ["Sized"],           true, "collections.abc.Sized.__name__ == 'Sized'"]
    - [si_module,    collections.abc.Sized.__module__.__eq__,              ["collections.abc"], true, "collections.abc.Sized.__module__ == 'collections.abc'"]
    - [si_len_name,  collections.abc.Sized.__len__.__name__.__eq__,        ["__len__"],          true, "collections.abc.Sized.__len__.__name__ == '__len__'"]
    - [si_abstract,  "collections.abc.Sized.__abstractmethods__.__contains__", ["__len__"],      true, "collections.abc.Sized.__abstractmethods__ contains '__len__'"]
    - [co_name,      collections.abc.Container.__name__.__eq__,            ["Container"],       true, "collections.abc.Container.__name__ == 'Container'"]
    - [co_module,    collections.abc.Container.__module__.__eq__,          ["collections.abc"], true, "collections.abc.Container.__module__ == 'collections.abc'"]
    - [co_cont_name, collections.abc.Container.__contains__.__name__.__eq__, ["__contains__"],  true, "collections.abc.Container.__contains__.__name__ == '__contains__'"]
    - [co_abstract,  "collections.abc.Container.__abstractmethods__.__contains__", ["__contains__"], true, "collections.abc.Container.__abstractmethods__ contains '__contains__'"]

# ---------------------------------------------------------------------------
# Callable base class — standalone invariant
#
# Callable inherits directly from object.
# ---------------------------------------------------------------------------

invariant abc_extra271.Callable.bases0_name:
  description: "collections.abc.Callable.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Callable.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

