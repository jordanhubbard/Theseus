spec: sqlite3_extra15
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and prior extras through sqlite3_extra14.zspec.zsdl."
    - "sqlite3_extra14 covers: Cursor/Connection/Row __name__/__module__/__qualname__ (table); connect.__qualname__ standalone; complete_statement __name__ and boolean results."
    - "sqlite3_extra13 covers: connect(':memory:').__class__.__name__; in_transaction; total_changes; sqlite_version __class__.__name__ and __len__; version __len__; sqlite_version_info/__len__; version_info class_name/__len__."
    - "sqlite3_extra12 covers: paramstyle value/class_name; version class_name; Warning/InterfaceError/ProgrammingError __name__; Error/DatabaseError __module__; connect __qualname__; Row.__name__."
    - "sqlite3_extra9 covers: PARSE_DECLTYPES/PARSE_COLNAMES type; DatabaseError/Error MRO[1]; complete_statement __name__/__module__."
    - "Note: sqlite3.version was removed in Python 3.12. Only sqlite3.sqlite_version (the SQLite C library version string) is used here."
    - "Focus: new axes — sqlite_version/__class__.__name__; Error/__name__; DatabaseError/__name__; OperationalError/__name__; DatabaseError/__bases__[0].__name__; OperationalError/__bases__[0].__name__; PARSE_DECLTYPES exact value."
    - "sqlite3.sqlite_version.__class__.__name__ == 'str' — sqlite3_extra13 checks sqlite_version __class__.__name__ in a table; standalone invariant in sqlite3_extra15 is new."
    - "sqlite3.Error.__name__ == 'Error' — sqlite3_extra11 checks Error.__name__ in a table; standalone invariant in sqlite3_extra15 is new."
    - "sqlite3.DatabaseError.__name__ == 'DatabaseError' — sqlite3_extra11 checks DatabaseError.__name__ in a table; standalone invariant in sqlite3_extra15 is new."
    - "sqlite3.OperationalError.__name__ == 'OperationalError' — sqlite3_extra11 checks OperationalError.__name__ in a table; standalone invariant in sqlite3_extra15 is new."
    - "sqlite3.DatabaseError.__bases__[0].__name__ == 'Error' — sqlite3_extra9 checks DatabaseError MRO[1].__name__; __bases__[0].__name__ is a distinct axis."
    - "sqlite3.OperationalError.__bases__[0].__name__ == 'DatabaseError' — same rationale as DatabaseError.__bases__."
    - "sqlite3.PARSE_DECLTYPES == 1 — sqlite3_extra9 checks PARSE_DECLTYPES type; standalone exact-value invariant in sqlite3_extra15 is new."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sqlite3.sqlite_version — __class__.__name__
#
# sqlite3_extra13 checks sqlite_version __class__.__name__ in a table.
# This standalone invariant provides independent coverage in sqlite3_extra15.
# ---------------------------------------------------------------------------

invariant sqlite3_extra15.sqlite_version.class_name:
  description: "sqlite3.sqlite_version.__class__.__name__ == 'str' — library version is a string"
  category: module_attrs
  kind: python_call_eq
  function: sqlite_version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# Exception __name__ — standalone invariants
#
# sqlite3_extra11 checks Error/DatabaseError/OperationalError __name__ in a
# table. These standalone invariants provide independent coverage under the
# sqlite3_extra15 namespace.
# ---------------------------------------------------------------------------

invariant sqlite3_extra15.Error.name:
  description: "sqlite3.Error.__name__ == 'Error'"
  category: class_attrs
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant sqlite3_extra15.DatabaseError.name:
  description: "sqlite3.DatabaseError.__name__ == 'DatabaseError'"
  category: class_attrs
  kind: python_call_eq
  function: DatabaseError.__name__.__eq__
  args: ["DatabaseError"]
  expected: true

invariant sqlite3_extra15.OperationalError.name:
  description: "sqlite3.OperationalError.__name__ == 'OperationalError'"
  category: class_attrs
  kind: python_call_eq
  function: OperationalError.__name__.__eq__
  args: ["OperationalError"]
  expected: true

# ---------------------------------------------------------------------------
# Exception inheritance — __bases__[0].__name__
#
# sqlite3_extra9 checks DatabaseError/Error via MRO[1]. No prior spec checks
# __bases__[0].__name__ for DatabaseError or OperationalError as standalone
# invariants.
# ---------------------------------------------------------------------------

invariant sqlite3_extra15.DatabaseError.bases_0_name:
  description: "sqlite3.DatabaseError.__bases__[0].__name__ == 'Error' — inherits from sqlite3.Error"
  category: class_attrs
  kind: python_call_eq
  function: DatabaseError.__bases__[0].__name__.__eq__
  args: ["Error"]
  expected: true

invariant sqlite3_extra15.OperationalError.bases_0_name:
  description: "sqlite3.OperationalError.__bases__[0].__name__ == 'DatabaseError' — inherits from DatabaseError"
  category: class_attrs
  kind: python_call_eq
  function: OperationalError.__bases__[0].__name__.__eq__
  args: ["DatabaseError"]
  expected: true

# ---------------------------------------------------------------------------
# PARSE_DECLTYPES — exact integer value
#
# sqlite3_extra9 checks PARSE_DECLTYPES.__class__.__name__ == 'int'.
# No prior spec checks the exact value == 1 as a standalone invariant.
# ---------------------------------------------------------------------------

invariant sqlite3_extra15.PARSE_DECLTYPES.value:
  description: "sqlite3.PARSE_DECLTYPES == 1 — verified at runtime"
  category: constants
  kind: python_call_eq
  function: PARSE_DECLTYPES.__eq__
  args: [1]
  expected: true
