spec: decimal_extra271
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "decimal.MAX_PREC == 999999999999999999 on 64-bit CPython — the maximum decimal precision."
    - "decimal.MAX_EMAX == 999999999999999999 on 64-bit CPython — the maximum exponent."
    - "decimal.MIN_EMIN == -999999999999999999 on 64-bit CPython — the minimum exponent."
    - "decimal.MIN_ETINY == -1999999999999999997 on 64-bit CPython — MIN_EMIN - (MAX_PREC - 1)."
    - "All four constants are of type int."
    - "decimal.ROUND_HALF_UP, ROUND_HALF_EVEN, ROUND_CEILING, ROUND_FLOOR, ROUND_DOWN, ROUND_UP are str constants."
    - "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' — string sentinel used by Context.rounding."
    - "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' — the IEEE 754 default rounding mode."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: decimal platform-capacity integer constants
# ---------------------------------------------------------------------------

table decimal_extra271.platform_constants:
  description: "decimal.MAX_PREC, MAX_EMAX, MIN_EMIN, MIN_ETINY values on 64-bit CPython"
  kind: python_call_eq
  category: constants
  id_prefix: pc

  columns: [id, function, args, expected, description]
  rows:
    - [max_prec_val,   MAX_PREC.__eq__,   [999999999999999999],    true, "decimal.MAX_PREC == 999999999999999999 on 64-bit CPython"]
    - [max_emax_val,   MAX_EMAX.__eq__,   [999999999999999999],    true, "decimal.MAX_EMAX == 999999999999999999 on 64-bit CPython"]
    - [min_emin_val,   MIN_EMIN.__eq__,   [-999999999999999999],   true, "decimal.MIN_EMIN == -999999999999999999 on 64-bit CPython"]
    - [min_etiny_val,  MIN_ETINY.__eq__,  [-1999999999999999997],  true, "decimal.MIN_ETINY == -1999999999999999997 on 64-bit CPython"]
    - [max_prec_type,  MAX_PREC.__class__.__name__.__eq__,   ["int"], true, "type(decimal.MAX_PREC).__name__ == 'int'"]
    - [max_emax_type,  MAX_EMAX.__class__.__name__.__eq__,   ["int"], true, "type(decimal.MAX_EMAX).__name__ == 'int'"]
    - [min_emin_type,  MIN_EMIN.__class__.__name__.__eq__,   ["int"], true, "type(decimal.MIN_EMIN).__name__ == 'int'"]
    - [min_etiny_type, MIN_ETINY.__class__.__name__.__eq__,  ["int"], true, "type(decimal.MIN_ETINY).__name__ == 'int'"]

# ---------------------------------------------------------------------------
# Table: decimal rounding mode string constants
# ---------------------------------------------------------------------------

table decimal_extra271.rounding_constants:
  description: "decimal rounding mode string constant values: ROUND_HALF_UP, ROUND_HALF_EVEN, ROUND_CEILING, ROUND_FLOOR, ROUND_DOWN, ROUND_UP, ROUND_05UP"
  kind: python_call_eq
  category: constants
  id_prefix: rc

  columns: [id, function, args, expected, description]
  rows:
    - [half_up_val,    ROUND_HALF_UP.__eq__,    ["ROUND_HALF_UP"],    true, "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP'"]
    - [half_even_val,  ROUND_HALF_EVEN.__eq__,  ["ROUND_HALF_EVEN"],  true, "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' — IEEE 754 default"]
    - [ceiling_val,    ROUND_CEILING.__eq__,    ["ROUND_CEILING"],    true, "decimal.ROUND_CEILING == 'ROUND_CEILING'"]
    - [floor_val,      ROUND_FLOOR.__eq__,      ["ROUND_FLOOR"],      true, "decimal.ROUND_FLOOR == 'ROUND_FLOOR'"]
    - [down_val,       ROUND_DOWN.__eq__,       ["ROUND_DOWN"],       true, "decimal.ROUND_DOWN == 'ROUND_DOWN'"]
    - [up_val,         ROUND_UP.__eq__,         ["ROUND_UP"],         true, "decimal.ROUND_UP == 'ROUND_UP'"]
    - [zero5up_val,    ROUND_05UP.__eq__,       ["ROUND_05UP"],       true, "decimal.ROUND_05UP == 'ROUND_05UP'"]
    - [half_up_type,   ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"], true, "type(decimal.ROUND_HALF_UP).__name__ == 'str'"]
    - [half_even_type, ROUND_HALF_EVEN.__class__.__name__.__eq__, ["str"], true, "type(decimal.ROUND_HALF_EVEN).__name__ == 'str'"]

# ---------------------------------------------------------------------------
# Standalone invariants: platform constant values and relationships
# ---------------------------------------------------------------------------

invariant decimal_extra271.MAX_PREC.value:
  description: "decimal.MAX_PREC == 999999999999999999 on 64-bit CPython"
  category: constants
  kind: python_call_eq
  function: MAX_PREC.__eq__
  args: [999999999999999999]
  expected: true

invariant decimal_extra271.MAX_EMAX.value:
  description: "decimal.MAX_EMAX == 999999999999999999 on 64-bit CPython — MAX_EMAX equals MAX_PREC"
  category: constants
  kind: python_call_eq
  function: MAX_EMAX.__eq__
  args: [999999999999999999]
  expected: true

invariant decimal_extra271.MIN_EMIN.value:
  description: "decimal.MIN_EMIN == -999999999999999999 on 64-bit CPython — the negative of MAX_EMAX"
  category: constants
  kind: python_call_eq
  function: MIN_EMIN.__eq__
  args: [-999999999999999999]
  expected: true

invariant decimal_extra271.MIN_ETINY.value:
  description: "decimal.MIN_ETINY == -1999999999999999997 on 64-bit CPython — MIN_EMIN - (MAX_PREC - 1)"
  category: constants
  kind: python_call_eq
  function: MIN_ETINY.__eq__
  args: [-1999999999999999997]
  expected: true

invariant decimal_extra271.ROUND_HALF_UP.value:
  description: "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP' — string sentinel for round-half-away-from-zero"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_UP.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true

invariant decimal_extra271.ROUND_HALF_EVEN.value:
  description: "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN' — IEEE 754 default; also called banker's rounding"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra271.ROUND_HALF_UP.type_is_str:
  description: "type(decimal.ROUND_HALF_UP).__name__ == 'str' — rounding constants are plain strings"
  category: constants
  kind: python_call_eq
  function: ROUND_HALF_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true
