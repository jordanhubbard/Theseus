spec: struct_extra2071
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 585 (_extra2071): __pos__/__neg__, __getattribute__, __reduce__/__reduce_ex__, __copy__/__deepcopy__ dict-presence checks."
    - "struct.Struct defines __getattribute__ in its own __dict__ (C-level attribute guard). It is not numeric so __pos__/__neg__ are absent. __reduce__/__reduce_ex__/__copy__/__deepcopy__ are all absent from its own __dict__."
    - "struct.error is an Exception subclass; none of the numeric sign, pickle, or copy dunders appear in its own __dict__. __getattribute__ is likewise absent."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table struct_extra2071.unary_sign_protocol:
  description: "struct types __pos__/__neg__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2071

  columns: [id, function, args, expected]
  rows:
    - ["st2071001", "struct.Struct.__dict__.__contains__", ["__pos__"], false]
    - ["st2071002", "struct.Struct.__dict__.__contains__", ["__neg__"], false]
    - ["st2071003", "struct.error.__dict__.__contains__",  ["__pos__"], false]
    - ["st2071004", "struct.error.__dict__.__contains__",  ["__neg__"], false]

table struct_extra2071.getattribute_protocol:
  description: "struct types __getattribute__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2071

  columns: [id, function, args, expected]
  rows:
    - ["st2071005", "struct.Struct.__dict__.__contains__", ["__getattribute__"], true]
    - ["st2071006", "struct.error.__dict__.__contains__",  ["__getattribute__"], false]

