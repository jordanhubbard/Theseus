  rows:
    - ["st2071007", "struct.Struct.__dict__.__contains__", ["__reduce__"],    false]
    - ["st2071008", "struct.Struct.__dict__.__contains__", ["__reduce_ex__"], false]
    - ["st2071009", "struct.error.__dict__.__contains__",  ["__reduce__"],    false]
    - ["st2071010", "struct.error.__dict__.__contains__",  ["__reduce_ex__"], false]

