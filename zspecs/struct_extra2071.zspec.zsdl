    - ["st2071011", "struct.Struct.__dict__.__contains__", ["__copy__"],     false]
    - ["st2071012", "struct.Struct.__dict__.__contains__", ["__deepcopy__"], false]
    - ["st2071013", "struct.error.__dict__.__contains__",  ["__copy__"],     false]
    - ["st2071014", "struct.error.__dict__.__contains__",  ["__deepcopy__"], false]

