spec: lzma_extra13
version: ">=3.3"
backend: python_module(lzma)

docs: https://docs.python.org/3/library/lzma.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/lzma.html — Python lzma module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/lzma.py"
    - "CPython source: Modules/_lzmamodule.c"
  notes:
    - "This spec extends lzma_extra12.zspec.zsdl."
    - "Prior specs covered: LZMAFile/__name__/__module__/__qualname__, LZMAError/__name__/__module__, LZMACompressor/__name__/__module__, LZMADecompressor/__name__/__module__, open/__name__/__module__, compress/__name__/__module__, decompress/__name__/__module__, various __qualname__ checks, LZMAFile/__init__.__name__, LZMAError/__init__.__name__, open/__qualname__, compress/__qualname__, decompress/__qualname__, module/__len__() for all identifiers, __name__.__len__() for all identifiers."
    - "This spec covers: lzma.LZMAFile.__mro__.__len__(), lzma.LZMAError.__mro__.__len__(), lzma.LZMACompressor.__mro__.__len__(), lzma.LZMADecompressor.__mro__.__len__(), lzma.LZMAFile.__bases__[0].__name__.__len__(), lzma.LZMAError.__bases__[0].__name__.__len__(), lzma.LZMACompressor.__bases__[0].__name__.__len__(), lzma.LZMADecompressor.__bases__[0].__name__.__len__(), lzma.LZMAFile.__init__.__qualname__.__len__(), lzma.LZMAFile.read.__qualname__.__len__(), lzma.LZMAFile.write.__qualname__.__len__(), lzma.LZMAFile.close.__qualname__.__len__()."
    - "lzma.LZMAFile.__mro__.__len__() == 7: MRO is [LZMAFile, BaseStream, BufferedIOBase, _BufferedIOBase, IOBase, _IOBase, object]. Verified 2026-04-10."
    - "lzma.LZMAError.__mro__.__len__() == 4: MRO is [LZMAError, Exception, BaseException, object]. Verified 2026-04-10."
    - "lzma.LZMACompressor.__mro__.__len__() == 2: MRO is [LZMACompressor, object] — C extension type with no intermediate bases. Verified 2026-04-10."
    - "lzma.LZMADecompressor.__mro__.__len__() == 2: MRO is [LZMADecompressor, object] — C extension type with no intermediate bases. Verified 2026-04-10."
    - "lzma.LZMAFile.__bases__[0].__name__ == 'BaseStream' (len 10): LZMAFile directly inherits from the internal BaseStream mixin. Verified 2026-04-10."
    - "lzma.LZMAError.__bases__[0].__name__ == 'Exception' (len 9): LZMAError directly inherits from Exception. Verified 2026-04-10."
    - "lzma.LZMACompressor.__bases__[0].__name__ == 'object' (len 6): C extension type bases directly from object. Verified 2026-04-10."
    - "lzma.LZMADecompressor.__bases__[0].__name__ == 'object' (len 6): C extension type bases directly from object. Verified 2026-04-10."
    - "lzma.LZMAFile.__init__.__qualname__ == 'LZMAFile.__init__' (len 17). Verified 2026-04-10."
    - "lzma.LZMAFile.read.__qualname__ == 'LZMAFile.read' (len 13). Verified 2026-04-10."
    - "lzma.LZMAFile.write.__qualname__ == 'LZMAFile.write' (len 14). Verified 2026-04-10."
    - "lzma.LZMAFile.close.__qualname__ == 'LZMAFile.close' (len 14). Verified 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# LZMAFile.__mro__.__len__() == 7 — novel, extra13 anchor
#
# lzma.LZMAFile.__mro__ is [LZMAFile, BaseStream, BufferedIOBase,
# _BufferedIOBase, IOBase, _IOBase, object] — seven entries. No prior lzma
# spec checks __mro__.__len__() for LZMAFile. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra13.LZMAFile.mro_len:
  description: "lzma.LZMAFile.__mro__.__len__() == 7 — LZMAFile MRO has seven entries (extra13)"
  category: class_hierarchy
  kind: python_call_eq
  function: LZMAFile.__mro__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# LZMAError.__mro__.__len__() == 4 — novel, extra13 anchor
#
# lzma.LZMAError.__mro__ is [LZMAError, Exception, BaseException, object]
# — four entries. No prior lzma spec checks __mro__.__len__() for LZMAError.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra13.LZMAError.mro_len:
  description: "lzma.LZMAError.__mro__.__len__() == 4 — LZMAError MRO has four entries (extra13)"
  category: class_hierarchy
  kind: python_call_eq
  function: LZMAError.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# LZMACompressor.__mro__.__len__() == 2 — novel, extra13 anchor
#
# lzma.LZMACompressor.__mro__ is [LZMACompressor, object] — two entries.
# LZMACompressor is a C extension type that bases directly from object.
# No prior lzma spec checks __mro__.__len__() for LZMACompressor.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra13.LZMACompressor.mro_len:
  description: "lzma.LZMACompressor.__mro__.__len__() == 2 — LZMACompressor MRO has two entries (extra13)"
  category: class_hierarchy
  kind: python_call_eq
  function: LZMACompressor.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# LZMADecompressor.__mro__.__len__() == 2 — novel, extra13 anchor
#
# lzma.LZMADecompressor.__mro__ is [LZMADecompressor, object] — two entries.
# LZMADecompressor is a C extension type that bases directly from object.
# No prior lzma spec checks __mro__.__len__() for LZMADecompressor.
# Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra13.LZMADecompressor.mro_len:
  description: "lzma.LZMADecompressor.__mro__.__len__() == 2 — LZMADecompressor MRO has two entries (extra13)"
  category: class_hierarchy
  kind: python_call_eq
  function: LZMADecompressor.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# LZMAFile.__bases__[0].__name__.__len__() == 10 — novel, extra13 anchor
#
# lzma.LZMAFile.__bases__[0].__name__ == 'BaseStream' which has 10
# characters. LZMAFile inherits directly from the internal BaseStream mixin.
# No prior lzma spec checks __bases__[0].__name__.__len__(). Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra13.LZMAFile.bases0_name_len:
  description: "lzma.LZMAFile.__bases__[0].__name__.__len__() == 10 — 'BaseStream' has ten characters (extra13)"
  category: class_hierarchy
  kind: python_call_eq
  function: "LZMAFile.__bases__[0].__name__.__len__"
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# LZMAError.__bases__[0].__name__.__len__() == 9 — novel, extra13 anchor
#
# lzma.LZMAError.__bases__[0].__name__ == 'Exception' which has 9
# characters. LZMAError inherits directly from Exception. No prior lzma spec
# checks __bases__[0].__name__.__len__() for LZMAError. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra13.LZMAError.bases0_name_len:
  description: "lzma.LZMAError.__bases__[0].__name__.__len__() == 9 — 'Exception' has nine characters (extra13)"
  category: class_hierarchy
  kind: python_call_eq
  function: "LZMAError.__bases__[0].__name__.__len__"
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# LZMAFile.__init__.__qualname__.__len__() == 17 — novel, extra13 anchor
#
# lzma.LZMAFile.__init__.__qualname__ == 'LZMAFile.__init__' which has 17
# characters. No prior lzma spec checks __qualname__.__len__() for
# LZMAFile.__init__. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra13.LZMAFile.init_qualname_len:
  description: "lzma.LZMAFile.__init__.__qualname__.__len__() == 17 — 'LZMAFile.__init__' has seventeen characters (extra13)"
  category: name_lengths
  kind: python_call_eq
  function: LZMAFile.__init__.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# LZMAFile.read.__qualname__.__len__() == 13 — novel, extra13 anchor
#
# lzma.LZMAFile.read.__qualname__ == 'LZMAFile.read' which has 13
# characters. No prior lzma spec checks __qualname__.__len__() for
# LZMAFile.read. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra13.LZMAFile.read_qualname_len:
  description: "lzma.LZMAFile.read.__qualname__.__len__() == 13 — 'LZMAFile.read' has thirteen characters (extra13)"
  category: name_lengths
  kind: python_call_eq
  function: LZMAFile.read.__qualname__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# LZMAFile.write.__qualname__.__len__() == 14 — novel, extra13 anchor
#
# lzma.LZMAFile.write.__qualname__ == 'LZMAFile.write' which has 14
# characters. No prior lzma spec checks __qualname__.__len__() for
# LZMAFile.write. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra13.LZMAFile.write_qualname_len:
  description: "lzma.LZMAFile.write.__qualname__.__len__() == 14 — 'LZMAFile.write' has fourteen characters (extra13)"
  category: name_lengths
  kind: python_call_eq
  function: LZMAFile.write.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# LZMAFile.close.__qualname__.__len__() == 14 — novel, extra13 anchor
#
# lzma.LZMAFile.close.__qualname__ == 'LZMAFile.close' which has 14
# characters. No prior lzma spec checks __qualname__.__len__() for
# LZMAFile.close. Verified 2026-04-10.
# ---------------------------------------------------------------------------

invariant lzma_extra13.LZMAFile.close_qualname_len:
  description: "lzma.LZMAFile.close.__qualname__.__len__() == 14 — 'LZMAFile.close' has fourteen characters (extra13)"
  category: name_lengths
  kind: python_call_eq
  function: LZMAFile.close.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# __mro__.__len__() table — LZMAFile, LZMAError, LZMACompressor,
#                           LZMADecompressor (extra13)
#
# LZMAFile has a 7-entry MRO (inherits through BaseStream into the io
# hierarchy); LZMAError has 4 entries (exception chain); LZMACompressor and
# LZMADecompressor each have 2 entries (C extension types directly from
# object). This table anchors all four MRO depths from the extra13 namespace.
# ---------------------------------------------------------------------------

table lzma_extra13.mro_depths:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: mrodepth13

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,         LZMAFile.__mro__.__len__,         [], 7]
    - [LZMAError,        LZMAError.__mro__.__len__,        [], 4]
    - [LZMACompressor,   LZMACompressor.__mro__.__len__,   [], 2]
    - [LZMADecompressor, LZMADecompressor.__mro__.__len__, [], 2]

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__len__() table — LZMAFile, LZMAError,
#                                         LZMACompressor, LZMADecompressor
#                                         (extra13)
#
# LZMAFile.__bases__[0].__name__ == 'BaseStream' (len 10);
# LZMAError.__bases__[0].__name__ == 'Exception' (len 9);
# LZMACompressor.__bases__[0].__name__ == 'object' (len 6);
# LZMADecompressor.__bases__[0].__name__ == 'object' (len 6).
# This table anchors all four direct-base name lengths from extra13.
# ---------------------------------------------------------------------------

table lzma_extra13.bases0_name_lengths:
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: bases0nlen13

  columns: [id, function, args, expected]
  rows:
    - [LZMAFile,         "LZMAFile.__bases__[0].__name__.__len__",         [], 10]
    - [LZMAError,        "LZMAError.__bases__[0].__name__.__len__",        [], 9]
    - [LZMACompressor,   "LZMACompressor.__bases__[0].__name__.__len__",   [], 6]
    - [LZMADecompressor, "LZMADecompressor.__bases__[0].__name__.__len__", [], 6]

# ---------------------------------------------------------------------------
# LZMAFile method __qualname__.__len__() table — __init__, read, write,
#                                                close (extra13)
#
# No prior lzma spec presents method __qualname__.__len__() checks in a
# table. __init__=17, read=13, write=14, close=14. Verified 2026-04-10.
# ---------------------------------------------------------------------------

table lzma_extra13.LZMAFile_method_qualname_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: methqnlen13

  columns: [id, function, args, expected]
  rows:
    - [init,  LZMAFile.__init__.__qualname__.__len__,  [], 17]
    - [read,  LZMAFile.read.__qualname__.__len__,      [], 13]
    - [write, LZMAFile.write.__qualname__.__len__,     [], 14]
    - [close, LZMAFile.close.__qualname__.__len__,     [], 14]
