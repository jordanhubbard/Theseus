spec: atexit_extra
version: ">=3.9"
backend: python_module(atexit)

docs: https://docs.python.org/3/library/atexit.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/atexit.html — Python atexit module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/atexitmodule.c"
  notes:
    - "Extends atexit.zspec.zsdl with additional function name, module affiliation, and internal function invariants."
    - "atexit is a C-accelerated module in CPython; register and unregister are builtin_function_or_method objects."
    - "atexit.register.__name__ == 'register' — C-level name attribute matches the public Python name."
    - "atexit.unregister.__name__ == 'unregister' — analogously, unregister is a C builtin with correct __name__."
    - "atexit.register.__module__ == 'atexit' — C builtins from the atexit module report __module__ as 'atexit'."
    - "atexit._clear.__name__ == '_clear' — private but accessible function to remove all callbacks."
    - "atexit._run_exitfuncs.__name__ == '_run_exitfuncs' — private function that runs all registered callbacks."
    - "atexit._ncallbacks.__name__ == '_ncallbacks' — returns count of registered callbacks."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# register — name and module affiliation
# ---------------------------------------------------------------------------

invariant atexit_extra.register.name:
  description: "atexit.register.__name__ == 'register'"
  category: functions
  kind: python_call_eq
  function: register.__name__.__eq__
  args: ["register"]
  expected: true

invariant atexit_extra.register.module:
  description: "atexit.register.__module__ == 'atexit' — C builtin reports module as 'atexit'"
  category: functions
  kind: python_call_eq
  function: register.__module__.__eq__
  args: ["atexit"]
  expected: true

invariant atexit_extra.register.type:
  description: "atexit.register.__class__.__name__ == 'builtin_function_or_method'"
  category: functions
  kind: python_call_eq
  function: register.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# unregister — name
# ---------------------------------------------------------------------------

invariant atexit_extra.unregister.name:
  description: "atexit.unregister.__name__ == 'unregister'"
  category: functions
  kind: python_call_eq
  function: unregister.__name__.__eq__
  args: ["unregister"]
  expected: true

invariant atexit_extra.unregister.type:
  description: "atexit.unregister.__class__.__name__ == 'builtin_function_or_method'"
  category: functions
  kind: python_call_eq
  function: unregister.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# _clear — private function to remove all registered callbacks
# ---------------------------------------------------------------------------

invariant atexit_extra._clear.name:
  description: "atexit._clear.__name__ == '_clear'"
  category: internal_functions
  kind: python_call_eq
  function: _clear.__name__.__eq__
  args: ["_clear"]
  expected: true

invariant atexit_extra._clear.type:
  description: "atexit._clear.__class__.__name__ == 'builtin_function_or_method'"
  category: internal_functions
  kind: python_call_eq
  function: _clear.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# _ncallbacks — name (also covered in base spec for return value)
# ---------------------------------------------------------------------------

invariant atexit_extra._ncallbacks.name:
  description: "atexit._ncallbacks.__name__ == '_ncallbacks'"
  category: internal_functions
  kind: python_call_eq
  function: _ncallbacks.__name__.__eq__
  args: ["_ncallbacks"]
  expected: true

# ---------------------------------------------------------------------------
# _run_exitfuncs — private function that executes all registered callbacks
# ---------------------------------------------------------------------------

invariant atexit_extra._run_exitfuncs.name:
  description: "atexit._run_exitfuncs.__name__ == '_run_exitfuncs'"
  category: internal_functions
  kind: python_call_eq
  function: _run_exitfuncs.__name__.__eq__
  args: ["_run_exitfuncs"]
  expected: true

invariant atexit_extra._run_exitfuncs.type:
  description: "atexit._run_exitfuncs.__class__.__name__ == 'builtin_function_or_method'"
  category: internal_functions
  kind: python_call_eq
  function: _run_exitfuncs.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# Module identity
# ---------------------------------------------------------------------------

invariant atexit_extra.module_name:
  description: "atexit.__name__ == 'atexit' — the module's own __name__ attribute"
  category: module_identity
  kind: python_call_eq
  function: "__name__.__eq__"
  args: ["atexit"]
  expected: true

# ---------------------------------------------------------------------------
# Function table — name attributes across all public and private functions
# ---------------------------------------------------------------------------

table atexit_extra.function_names:
  kind: python_call_eq
  category: functions
  id_prefix: fname
  columns: [id, function, args, expected]
  rows:
    - [register,         register.__name__.__eq__,        ["register"],        true]
    - [unregister,       unregister.__name__.__eq__,       ["unregister"],       true]
    - [_clear,           _clear.__name__.__eq__,           ["_clear"],           true]
    - [_ncallbacks,      _ncallbacks.__name__.__eq__,      ["_ncallbacks"],      true]
    - [_run_exitfuncs,   _run_exitfuncs.__name__.__eq__,   ["_run_exitfuncs"],   true]
