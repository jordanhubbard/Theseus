spec: email_extra13
version: ">=3.6"
backend: python_module(email)

docs: https://docs.python.org/3/library/email.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/email.html — Python email module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/email/"
    - "email_extra4.zspec.zsdl — covers email.utils parseaddr/formataddr __qualname__/__module__; email.errors class qualnames; email.policy class qualnames; email.generator qualnames."
    - "email_extra8.zspec.zsdl — covers message.Message.__name__.__eq__."
    - "email_extra10.zspec.zsdl — covers message.Message.__qualname__.__eq__('Message'); utils.parseaddr/__qualname__.__len__; header.Header.__module__."
    - "email_extra11.zspec.zsdl — covers message.Message method __qualname__ values and lengths."
    - "email_extra12.zspec.zsdl — covers message.Message.__module__ and __bases__[0].__name__; MIMEText/__qualname__ and __module__; MIMEMultipart/__qualname__ and __module__; headerregistry.Address/__qualname__ and __module__; errors.MessageError/__qualname__ and __bases__[0].__name__; utils.parseaddr/formataddr standalone qualnames; MIME/Address/MessageError __qualname__ lengths."
  notes:
    - "This spec extends the email family through email_extra12; it does NOT duplicate invariants in any prior spec."
    - "Focus: email.parser.Parser class identity (__name__, __qualname__, __module__, __bases__[0].__name__) — no prior email spec checks any attribute on email.parser.Parser; email.parser.FeedParser class identity (__name__, __qualname__, __module__) — no prior email spec checks email.parser.FeedParser at all; email.mime.text.MIMEText.__bases__[0].__name__ and email.mime.multipart.MIMEMultipart.__bases__[0].__name__ — extra12 checks their __qualname__ and __module__, but no prior spec checks __bases__[0].__name__ on either MIME class; email.errors.MessageParseError class identity — no prior email spec checks MessageParseError; email.headerregistry.Address.__name__ — extra12 checks Address.__qualname__ and __module__; no prior spec checks Address.__name__."
    - "email.parser.Parser.__name__ == 'Parser' — no prior email spec checks any attribute on email.parser.Parser."
    - "email.parser.Parser.__qualname__ == 'Parser' — same rationale."
    - "email.parser.Parser.__module__ == 'email.parser' — same rationale."
    - "email.parser.Parser.__bases__[0].__name__ == 'object' — Parser inherits directly from object; no prior spec checks this."
    - "email.parser.FeedParser.__name__ == 'FeedParser' — no prior email spec checks any attribute on email.parser.FeedParser."
    - "email.parser.FeedParser.__qualname__ == 'FeedParser' — same rationale."
    - "email.parser.FeedParser.__module__ == 'email.feedparser' — FeedParser is defined in email.feedparser, not email.parser; no prior spec checks this."
    - "email.mime.text.MIMEText.__bases__[0].__name__ == 'MIMENonMultipart' — extra12 checks MIMEText.__qualname__ and __module__; no prior spec checks MIMEText.__bases__[0].__name__."
    - "email.mime.multipart.MIMEMultipart.__bases__[0].__name__ == 'MIMEBase' — extra12 checks MIMEMultipart.__qualname__ and __module__; no prior spec checks MIMEMultipart.__bases__[0].__name__."
    - "email.errors.MessageParseError.__name__ == 'MessageParseError' — no prior email spec checks any attribute of MessageParseError."
    - "email.errors.MessageParseError.__module__ == 'email.errors' — same rationale."
    - "email.errors.MessageParseError.__bases__[0].__name__ == 'MessageError' — MessageParseError inherits from MessageError; no prior spec checks this inheritance chain."
    - "email.headerregistry.Address.__name__ == 'Address' — extra12 checks Address.__qualname__ and __module__; no prior spec checks Address.__name__. For top-level classes __name__ == __qualname__ but the path is distinct."
    - "Parser.__qualname__ length == 6; FeedParser.__qualname__ length == 10; MessageParseError.__name__ length == 17. No prior email spec checks these lengths."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# email.parser.Parser class identity
#
# No prior email spec checks any attribute on email.parser.Parser. Parser is
# the high-level parser class defined in the email.parser submodule and
# inherits directly from object.
# ---------------------------------------------------------------------------

invariant email_extra13.Parser.name:
  description: "email.parser.Parser.__name__ == 'Parser' — no prior email spec checks any attribute on email.parser.Parser"
  category: class_identity
  kind: python_call_eq
  function: parser.Parser.__name__.__eq__
  args: ["Parser"]
  expected: true

invariant email_extra13.Parser.qualname:
  description: "email.parser.Parser.__qualname__ == 'Parser' — no prior email spec checks Parser.__qualname__"
  category: class_qualnames
  kind: python_call_eq
  function: parser.Parser.__qualname__.__eq__
  args: ["Parser"]
  expected: true

invariant email_extra13.Parser.module:
  description: "email.parser.Parser.__module__ == 'email.parser' — no prior email spec checks Parser.__module__"
  category: class_modules
  kind: python_call_eq
  function: parser.Parser.__module__.__eq__
  args: ["email.parser"]
  expected: true

invariant email_extra13.Parser.bases_name:
  description: "email.parser.Parser.__bases__[0].__name__ == 'object' — Parser inherits from object; no prior spec checks this"
  category: class_identity
  kind: python_call_eq
  function: "parser.Parser.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# email.parser.FeedParser class identity
#
# No prior email spec checks any attribute on email.parser.FeedParser.
# FeedParser is the incremental feed-based parser. Notably, it is defined
# in the email.feedparser submodule (not email.parser), so its __module__
# is 'email.feedparser' despite being re-exported from email.parser.
# ---------------------------------------------------------------------------

invariant email_extra13.FeedParser.name:
  description: "email.parser.FeedParser.__name__ == 'FeedParser' — no prior email spec checks any attribute on FeedParser"
  category: class_identity
  kind: python_call_eq
  function: parser.FeedParser.__name__.__eq__
  args: ["FeedParser"]
  expected: true

invariant email_extra13.FeedParser.qualname:
  description: "email.parser.FeedParser.__qualname__ == 'FeedParser' — no prior email spec checks FeedParser.__qualname__"
  category: class_qualnames
  kind: python_call_eq
  function: parser.FeedParser.__qualname__.__eq__
  args: ["FeedParser"]
  expected: true

invariant email_extra13.FeedParser.module:
  description: "email.parser.FeedParser.__module__ == 'email.feedparser' — defined in feedparser submodule, not email.parser"
  category: class_modules
  kind: python_call_eq
  function: parser.FeedParser.__module__.__eq__
  args: ["email.feedparser"]
  expected: true

# ---------------------------------------------------------------------------
# email.mime.text.MIMEText and MIMEMultipart __bases__[0].__name__
#
# email_extra12 checks MIMEText.__qualname__/__module__ and
# MIMEMultipart.__qualname__/__module__. No prior email spec checks
# __bases__[0].__name__ on either MIME class. MIMEText inherits from
# MIMENonMultipart; MIMEMultipart inherits from MIMEBase.
# ---------------------------------------------------------------------------

invariant email_extra13.MIMEText.bases_name:
  description: "email.mime.text.MIMEText.__bases__[0].__name__ == 'MIMENonMultipart' — no prior email spec checks MIMEText.__bases__[0].__name__"
  category: class_identity
  kind: python_call_eq
  function: "mime.text.MIMEText.__bases__[0].__name__.__eq__"
  args: ["MIMENonMultipart"]
  expected: true

invariant email_extra13.MIMEMultipart.bases_name:
  description: "email.mime.multipart.MIMEMultipart.__bases__[0].__name__ == 'MIMEBase' — no prior email spec checks MIMEMultipart.__bases__[0].__name__"
  category: class_identity
  kind: python_call_eq
  function: "mime.multipart.MIMEMultipart.__bases__[0].__name__.__eq__"
  args: ["MIMEBase"]
  expected: true

# ---------------------------------------------------------------------------
# email.errors.MessageParseError class identity
#
# No prior email spec checks any attribute on MessageParseError.
# MessageParseError is a subclass of MessageError defined in email.errors.
# It represents errors during message parsing.
# ---------------------------------------------------------------------------

invariant email_extra13.MessageParseError.name:
  description: "email.errors.MessageParseError.__name__ == 'MessageParseError' — no prior email spec checks any attribute on MessageParseError"
  category: class_identity
  kind: python_call_eq
  function: errors.MessageParseError.__name__.__eq__
  args: ["MessageParseError"]
  expected: true

invariant email_extra13.MessageParseError.module:
  description: "email.errors.MessageParseError.__module__ == 'email.errors' — no prior email spec checks MessageParseError.__module__"
  category: class_modules
  kind: python_call_eq
  function: errors.MessageParseError.__module__.__eq__
  args: ["email.errors"]
  expected: true

invariant email_extra13.MessageParseError.bases_name:
  description: "email.errors.MessageParseError.__bases__[0].__name__ == 'MessageError' — MessageParseError inherits from MessageError; no prior spec checks this"
  category: class_identity
  kind: python_call_eq
  function: "errors.MessageParseError.__bases__[0].__name__.__eq__"
  args: ["MessageError"]
  expected: true

# ---------------------------------------------------------------------------
# email.headerregistry.Address.__name__
#
# email_extra12 checks Address.__qualname__.__eq__('Address') and
# Address.__module__.__eq__('email.headerregistry'). No prior email spec
# checks Address.__name__. For top-level classes __name__ == __qualname__,
# but the attribute path is distinct — consistent with the pattern used
# in ipaddress and uuid specs.
# ---------------------------------------------------------------------------

invariant email_extra13.Address.name:
  description: "email.headerregistry.Address.__name__ == 'Address' — distinct from __qualname__ checked in extra12; no prior spec checks Address.__name__"
  category: class_identity
  kind: python_call_eq
  function: headerregistry.Address.__name__.__eq__
  args: ["Address"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__/__name__ string lengths for Parser, FeedParser, MessageParseError
#
# No prior email spec checks the string lengths of Parser.__qualname__,
# FeedParser.__qualname__, or MessageParseError.__name__.
# Parser == 6; FeedParser == 10; MessageParseError == 18.
# ---------------------------------------------------------------------------

table email_extra13.class_name_lengths:
  description: "Parser/FeedParser/MessageParseError __qualname__/__name__ string lengths — no prior email spec checks these lengths"
  kind: python_call_eq
  category: class_identity
  id_prefix: cnlen13

  columns: [id, function, args, expected]
  rows:
    - [Parser,            parser.Parser.__qualname__.__len__,               [], 6]
    - [FeedParser,        parser.FeedParser.__qualname__.__len__,           [], 10]
    - [MessageParseError, errors.MessageParseError.__name__.__len__,        [], 17]
