    - [tpe_init_varnames_cls, ThreadPoolExecutor.__init__.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true, "ThreadPoolExecutor.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple in CPython; ThreadPoolExecutor.__init__.__code__.co_varnames.__class__.__name__ is 'tuple'; NEW in extra68: first co_varnames.__class__.__name__.__eq__('tuple') check for ThreadPoolExecutor.__init__ in the cfcode68 namespace; verified with Python 3.14.3"]

