invariant concurrent_futures_extra68.ThreadPoolExecutor_init_co_name:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_name.__eq__('__init__') returns True — ThreadPoolExecutor is a pure Python class; its __init__ code object's co_name is '__init__'; NEW in extra68: first standalone co_name invariant for ThreadPoolExecutor.__init__ in the cfcode68 namespace; wave 237 first code object name invariant for ThreadPoolExecutor.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ThreadPoolExecutor.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant concurrent_futures_extra68.ThreadPoolExecutor_init_co_argcount_5:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__(5) returns True — ThreadPoolExecutor.__init__ has 5 positional parameters: self + max_workers + thread_name_prefix + initializer + initargs; co_argcount is 5; NEW in extra68: first standalone co_argcount invariant for ThreadPoolExecutor.__init__ in the cfcode68 namespace; wave 237 first code object argcount invariant for ThreadPoolExecutor.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__
  args: [5]
  expected: true

invariant concurrent_futures_extra68.Future_init_co_argcount_1:
  description: "concurrent.futures.Future.__init__.__code__.co_argcount.__eq__(1) returns True — Future.__init__ takes only self; co_argcount is 1; NEW in extra68: first standalone co_argcount invariant for Future.__init__ in the cfcode68 namespace; wave 237 first code object argcount invariant for Future.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Future.__init__.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant concurrent_futures_extra68.ThreadPoolExecutor_mro1_Executor:
  description: "concurrent.futures.ThreadPoolExecutor.__mro__[1].__name__.__eq__('Executor') returns True — second MRO entry is the immediate base class Executor; __mro__[1].__name__ is 'Executor'; NEW in extra68: first standalone __mro__[1].__name__ invariant for ThreadPoolExecutor in the cfcode68 namespace; wave 237 first MRO entry name invariant for ThreadPoolExecutor; verified with Python 3.14.3"
  category: mro
  kind: python_call_eq
  function: "ThreadPoolExecutor.__mro__[1].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra68.ThreadPoolExecutor_init_varnames_tuple:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — co_varnames is always a tuple in CPython; ThreadPoolExecutor.__init__.__code__.co_varnames.__class__.__name__ is 'tuple'; NEW in extra68: first standalone co_varnames class name invariant for ThreadPoolExecutor.__init__ in the cfcode68 namespace; wave 237 first co_varnames type invariant for ThreadPoolExecutor.__init__; verified with Python 3.14.3"
  category: code
