table concurrent_futures_extra68.Future_init_code:
  description: "concurrent.futures Future.__init__ code object attribute checks in cfcode68 namespace — wave 237 theme: Future __init__ code object attributes; Future.__init__.__code__.co_name=='__init__'; Future.__init__.__code__.co_argcount==1 (just self); NEW in extra68: first co_name and co_argcount checks for Future.__init__ in the cfcode68 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfcode68a

  columns: [id, function, args, expected, description]
  rows:
    - [future_init_co_name,     Future.__init__.__code__.co_name.__eq__,     ["__init__"], true, "Future.__init__.__code__.co_name == '__init__' — concurrent.futures.Future is a pure Python class; its __init__ code object's co_name is '__init__'; NEW in extra68: first co_name.__eq__('__init__') check for Future.__init__ in the cfcode68 namespace; verified with Python 3.14.3"]
    - [future_init_co_argcount, Future.__init__.__code__.co_argcount.__eq__, [1],          true, "Future.__init__.__code__.co_argcount == 1 — concurrent.futures.Future.__init__ takes only self; co_argcount is 1; NEW in extra68: first co_argcount.__eq__(1) check for Future.__init__ in the cfcode68 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures ThreadPoolExecutor MRO name checks — extra68
#
# Wave 237 theme: ThreadPoolExecutor MRO entry names.
#
# ThreadPoolExecutor.__mro__[0].__name__ == 'ThreadPoolExecutor'
# ThreadPoolExecutor.__mro__[1].__name__ == 'Executor'
# ThreadPoolExecutor.__mro__[2].__name__ == 'object'
# ---------------------------------------------------------------------------

table concurrent_futures_extra68.ThreadPoolExecutor_mro:
  description: "concurrent.futures ThreadPoolExecutor MRO entry name checks in cfcode68 namespace — wave 237 theme: ThreadPoolExecutor MRO entry names; ThreadPoolExecutor.__mro__[0].__name__=='ThreadPoolExecutor' (first MRO entry is always the class itself); ThreadPoolExecutor.__mro__[1].__name__=='Executor' (immediate base class); ThreadPoolExecutor.__mro__[2].__name__=='object' (root class); NEW in extra68: first MRO entry name checks for ThreadPoolExecutor in the cfcode68 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: mro
  id_prefix: cfcode68b

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_mro0_name, "ThreadPoolExecutor.__mro__[0].__name__.__eq__", ["ThreadPoolExecutor"], true, "ThreadPoolExecutor.__mro__[0].__name__ == 'ThreadPoolExecutor' — first MRO entry is always the class itself; __mro__[0].__name__ is 'ThreadPoolExecutor'; NEW in extra68: first __mro__[0].__name__ check for ThreadPoolExecutor in the cfcode68 namespace; verified with Python 3.14.3"]
    - [tpe_mro1_name, "ThreadPoolExecutor.__mro__[1].__name__.__eq__", ["Executor"],           true, "ThreadPoolExecutor.__mro__[1].__name__ == 'Executor' — second MRO entry is the immediate base class Executor; __mro__[1].__name__ is 'Executor'; NEW in extra68: first __mro__[1].__name__ check for ThreadPoolExecutor in the cfcode68 namespace; verified with Python 3.14.3"]
    - [tpe_mro2_name, "ThreadPoolExecutor.__mro__[2].__name__.__eq__", ["object"],             true, "ThreadPoolExecutor.__mro__[2].__name__ == 'object' — third MRO entry is object, the root of all Python classes; __mro__[2].__name__ is 'object'; NEW in extra68: first __mro__[2].__name__ check for ThreadPoolExecutor in the cfcode68 namespace; verified with Python 3.14.3"]

