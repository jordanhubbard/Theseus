spec: concurrent_futures_extra68
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec extends concurrent_futures_extra67.zspec.zsdl."
    - "Prior specs covered: ThreadPoolExecutor/ProcessPoolExecutor/Future/Executor __name__/__module__/__qualname__, exception identity and bases, submit/map/shutdown __qualname__, class __dict__/__mro__/__all__ metadata, method qualname/name equality and length tables, __loader__/__spec__/__file__/__cached__ class names, __spec__ attributes, code object attribute chains, __defaults__/__kwdefaults__ class names, doc content."
    - "This spec covers (cfcode68 namespace): wave 237 theme — concurrent.futures class __init__ code object attributes. NEW in extra68: ThreadPoolExecutor.__init__.__code__.co_name=='__init__'; ThreadPoolExecutor.__init__.__code__.co_argcount==5 (self + max_workers + thread_name_prefix + initializer + initargs); Future.__init__.__code__.co_name=='__init__'; Future.__init__.__code__.co_argcount==1 (just self); ThreadPoolExecutor.__init__.__code__.co_varnames.__class__.__name__=='tuple'; ThreadPoolExecutor.__mro__[0].__name__=='ThreadPoolExecutor'; ThreadPoolExecutor.__mro__[1].__name__=='Executor'; ThreadPoolExecutor.__mro__[2].__name__=='object'."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_name == '__init__'. ThreadPoolExecutor is a pure Python class in concurrent/futures/thread.py; its __init__ is a Python function; co_name is '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_argcount == 5. ThreadPoolExecutor.__init__ signature includes self + max_workers + thread_name_prefix + initializer + initargs = 5 positional parameters; co_argcount is 5. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__init__.__code__.co_name == '__init__'. Future is a pure Python class; its __init__ takes only self; co_name is '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__init__.__code__.co_argcount == 1. Future.__init__ takes only self; co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is always a tuple in CPython; ThreadPoolExecutor.__init__.__code__.co_varnames.__class__.__name__ is 'tuple'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__mro__[0].__name__ == 'ThreadPoolExecutor'. First entry in MRO is always the class itself. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__mro__[1].__name__ == 'Executor'. Second entry is the immediate base class Executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__mro__[2].__name__ == 'object'. Third entry is object, the root of all Python classes. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures ThreadPoolExecutor.__init__ code object checks — extra68
#
# Wave 237 theme: concurrent.futures class __init__ code object attributes.
#
# ThreadPoolExecutor.__init__.__code__.co_name == '__init__'
# ThreadPoolExecutor.__init__.__code__.co_argcount == 5
# ---------------------------------------------------------------------------

table concurrent_futures_extra68.ThreadPoolExecutor_init_code:
  description: "concurrent.futures ThreadPoolExecutor.__init__ code object attribute checks in cfcode68 namespace — wave 237 theme: concurrent.futures class __init__ code object attributes; ThreadPoolExecutor.__init__.__code__.co_name=='__init__' (pure Python class; code object stores the function name); ThreadPoolExecutor.__init__.__code__.co_argcount==5 (self + max_workers + thread_name_prefix + initializer + initargs); NEW in extra68: first co_name and co_argcount checks for ThreadPoolExecutor.__init__ in the cfcode68 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfcode68

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_init_co_name,     ThreadPoolExecutor.__init__.__code__.co_name.__eq__,     ["__init__"], true, "ThreadPoolExecutor.__init__.__code__.co_name == '__init__' — ThreadPoolExecutor is a pure Python class in concurrent/futures/thread.py; its __init__ code object's co_name is '__init__'; NEW in extra68: first co_name.__eq__('__init__') check for ThreadPoolExecutor.__init__ in the cfcode68 namespace; verified with Python 3.14.3"]
    - [tpe_init_co_argcount, ThreadPoolExecutor.__init__.__code__.co_argcount.__eq__, [5],          true, "ThreadPoolExecutor.__init__.__code__.co_argcount == 5 — ThreadPoolExecutor.__init__ has 5 positional parameters: self + max_workers + thread_name_prefix + initializer + initargs; co_argcount is 5; NEW in extra68: first co_argcount.__eq__(5) check for ThreadPoolExecutor.__init__ in the cfcode68 namespace; verified with Python 3.14.3"]

