spec: functools_extra1891
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "functools module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party functools extensions"
  notes:
    - "Tests unary arithmetic protocol and async iteration protocol membership in functools types"
    - "None of the functools types implement unary arithmetic dunder methods"
    - "None of the functools types implement async iteration protocol methods"
    - "singledispatch and singledispatchmethod are documented public API since Python 3.4 and 3.8 respectively"
  created_at: "2026-04-12"

table functools_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["fu1891-ua-001", "functools.partial.__dict__.__contains__", ["__abs__"], false]
    - ["fu1891-ua-002", "functools.partial.__dict__.__contains__", ["__neg__"], false]
    - ["fu1891-ua-003", "functools.partial.__dict__.__contains__", ["__pos__"], false]
    - ["fu1891-ua-004", "functools.partial.__dict__.__contains__", ["__round__"], false]
    - ["fu1891-ua-005", "functools.partial.__dict__.__contains__", ["__floor__"], false]
    - ["fu1891-ua-006", "functools.partial.__dict__.__contains__", ["__ceil__"], false]
    - ["fu1891-ua-007", "functools.partial.__dict__.__contains__", ["__trunc__"], false]
    - ["fu1891-ua-008", "functools.cached_property.__dict__.__contains__", ["__abs__"], false]

table functools_extra1891.async_iteration_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["fu1891-ai-001", "functools.partial.__dict__.__contains__", ["__aiter__"], false]
    - ["fu1891-ai-002", "functools.partial.__dict__.__contains__", ["__anext__"], false]
    - ["fu1891-ai-003", "functools.cached_property.__dict__.__contains__", ["__aiter__"], false]
    - ["fu1891-ai-004", "functools.cached_property.__dict__.__contains__", ["__anext__"], false]
    - ["fu1891-ai-005", "functools.partialmethod.__dict__.__contains__", ["__aiter__"], false]
    - ["fu1891-ai-006", "functools.partialmethod.__dict__.__contains__", ["__anext__"], false]
    - ["fu1891-ai-007", "functools.lru_cache.__dict__.__contains__", ["__aiter__"], false]
    - ["fu1891-ai-008", "functools.lru_cache.__dict__.__contains__", ["__anext__"], false]

table functools_extra1891.singledispatch_attrs:
  columns: [id, function, args, expected]
  rows:
    - ["fu1891-sd-001", "functools.__dict__.__contains__", ["singledispatch"], true]
    - ["fu1891-sd-002", "functools.__dict__.__contains__", ["singledispatchmethod"], true]
    - ["fu1891-sd-003", "functools.__dict__.__contains__", ["WRAPPER_ASSIGNMENTS"], true]
    - ["fu1891-sd-004", "functools.__dict__.__contains__", ["WRAPPER_UPDATES"], true]
    - ["fu1891-sd-005", "functools.partial.__dict__.__contains__", ["__abs__"], false]
    - ["fu1891-sd-006", "functools.partial.__dict__.__contains__", ["__neg__"], false]
    - ["fu1891-sd-007", "functools.partial.__dict__.__contains__", ["__length_hint__"], false]
    - ["fu1891-sd-008", "functools.partial.__dict__.__contains__", ["__fspath__"], false]
