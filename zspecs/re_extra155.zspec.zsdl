spec: re_extra155
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Pattern and re.Match class __name__ and __module__ values; and re.Match method __qualname__ values for group and groups."
    - "re.Pattern.__name__ == 'Pattern' (len=7); re.Pattern.__module__ == 're'. re.Match.__name__ == 'Match' (len=5); re.Match.__module__ == 're'. Both are implemented in _sre (the C extension) but their __module__ is set to 're' for clean public attribution."
    - "re.Match.group.__qualname__ == 'Match.group' (len=11; 'Match.' (6) + 'group' (5) = 11). re.Match.groups.__qualname__ == 'Match.groups' (len=12; 'Match.' (6) + 'groups' (6) = 12)."
    - "re.Pattern.match.__qualname__ == 'Pattern.match' (len=13) and re.Pattern.search.__qualname__ == 'Pattern.search' (len=14) and re.Pattern.findall.__qualname__ == 'Pattern.findall' (len=15) — all already covered in re_extra153. This spec focuses on Match method qualnames and class identity."
    - "The Match class prefix 'Match.' is 6 characters (compared to 'Pattern.' at 8 characters), so Match method qualnames are systematically shorter than equivalent-named Pattern methods."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern and re.Match class identity
# Pattern.__name__ == 'Pattern' (len=7), Pattern.__module__ == 're'
# Match.__name__ == 'Match' (len=5), Match.__module__ == 're'
# Both implemented in _sre C extension but __module__ is 're'.
# ---------------------------------------------------------------------------

table re_extra155.Pattern_Match_class_identity:
  description: "re.Pattern and re.Match class identity: __name__, __module__, and __name__.__len__() for both; both have __module__=='re' despite being implemented in _sre"
  kind: python_call_eq
  category: identity
  id_prefix: repm155

  columns: [id, function, args, expected, description]
  rows:
    - [pat_name_eq,    Pattern.__name__.__eq__,    ["Pattern"], true, "re.Pattern.__name__ == 'Pattern' (len=7; the class name for compiled regular expression objects; Python 3.7+ made re.Pattern the public name — previously it was only accessible as type(re.compile(''))); note 'Pattern' (7 chars) is the same length as 'Decimal' and 'Context' in the decimal module)"]
    - [pat_name_len,   Pattern.__name__.__len__,   [],          7,    "re.Pattern.__name__.__len__() == 7 ('Pattern' has 7 characters; same length as decimal.Decimal.__name__ and decimal.Context.__name__; both are 7-char class names)"]
    - [pat_module_eq,  Pattern.__module__.__eq__,  ["re"],      true, "re.Pattern.__module__ == 're' (Pattern is implemented in the _sre C extension but its __module__ is set to 're' for clean public attribution; this means type annotations referencing 're.Pattern' resolve correctly and help(re.Pattern) shows the right module)"]
    - [mat_name_eq,    Match.__name__.__eq__,       ["Match"],  true, "re.Match.__name__ == 'Match' (len=5; the class name for match objects returned by Pattern.match(), Pattern.search(), Pattern.fullmatch(); 'Match' is the shortest of the two primary re class names — shorter than 'Pattern' (7) by 2 characters)"]
    - [mat_name_len,   Match.__name__.__len__,      [],         5,    "re.Match.__name__.__len__() == 5 ('Match' has 5 characters; shorter than 'Pattern' (7); the Match class prefix 'Match.' (6) is also shorter than 'Pattern.' (8) so all Match method qualnames are shorter than their Pattern counterparts by 2 characters)"]
    - [mat_module_eq,  Match.__module__.__eq__,     ["re"],     true, "re.Match.__module__ == 're' (Match is also implemented in _sre but has __module__ == 're'; same pattern as Pattern; both primary re classes are attributed to the public 're' module rather than the private '_sre' C extension)"]

# ---------------------------------------------------------------------------
# re.Match method __qualname__ values
# Match prefix = 'Match.' = 6 chars (vs 'Pattern.' = 8 chars).
# group = 11, groups = 12.
# These are shorter than Pattern.match (13) because Match prefix is 2 shorter.
# ---------------------------------------------------------------------------

table re_extra155.Match_method_qualnames:
  description: "re.Match method __qualname__ values: group=11 ('Match.'(6)+'group'(5)), groups=12 ('Match.'(6)+'groups'(6)); Match prefix is 6 chars vs Pattern prefix 8 chars"
  kind: python_call_eq
  category: qualname
  id_prefix: repm155

  columns: [id, function, args, expected, description]
  rows:
    - [group_qeq,   Match.group.__qualname__.__eq__,    ["Match.group"],    true, "re.Match.group.__qualname__ == 'Match.group' (len=11; 'Match.' (6) + 'group' (5) = 11; group() returns the string matched by the RE or by a specific group number or name; group(0) or group() returns the entire match; this is the most commonly used Match method)"]
    - [group_qlen,  Match.group.__qualname__.__len__,   [],                 11,   "re.Match.group.__qualname__.__len__() == 11 ('Match.group' has 11 characters; compare with Pattern.sub (11) — both are 11 chars despite different prefixes: 'Match.' (6) + 'group' (5) == 'Pattern.' (8) + 'sub' (3))"]
    - [groups_qeq,  Match.groups.__qualname__.__eq__,   ["Match.groups"],   true, "re.Match.groups.__qualname__ == 'Match.groups' (len=12; 'Match.' (6) + 'groups' (6) = 12; groups() returns a tuple of all subgroups of the match (groups captured by parentheses); groups(default=None) sets the value for non-participating groups; compare with Pattern.subn (12) — same length, different prefix)"]
    - [groups_qlen, Match.groups.__qualname__.__len__,  [],                 12,   "re.Match.groups.__qualname__.__len__() == 12 ('Match.groups' has 12 characters; 1 longer than Match.group (11); 1 shorter than Pattern.match (13); the 'Match.' prefix (6) is 2 shorter than 'Pattern.' (8) so Match.groups (12) equals Pattern.subn (12) in length)"]
    - [pat_match_qeq,Pattern.match.__qualname__.__eq__, ["Pattern.match"],  true, "re.Pattern.match.__qualname__ == 'Pattern.match' (len=13; 'Pattern.' (8) + 'match' (5) = 13; match() tries to apply the pattern at the start of the string; returns a Match object on success or None; 2 chars longer than Match.groups (12) due to the longer 'Pattern.' prefix)"]
    - [pat_search_qeq,Pattern.search.__qualname__.__eq__,["Pattern.search"],true, "re.Pattern.search.__qualname__ == 'Pattern.search' (len=14; 'Pattern.' (8) + 'search' (6) = 14; search() scans through the string looking for the first location where the pattern matches; unlike match() which anchors to the start, search() finds the first match anywhere)"]
    - [pat_findall_qeq,Pattern.findall.__qualname__.__eq__,["Pattern.findall"],true,"re.Pattern.findall.__qualname__ == 'Pattern.findall' (len=15; 'Pattern.' (8) + 'findall' (7) = 15; findall() returns a list of all non-overlapping matches; if the pattern has groups, returns a list of groups instead of the full match strings)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra155.Pattern_name_eq:
  description: "re.Pattern.__name__ == 'Pattern' — the class name for compiled regular expression patterns; Python 3.7+ added re.Pattern as the public type alias (previously it was only accessible via type(re.compile(''))); 'Pattern' has 7 characters, the same length as decimal.Decimal.__name__ and decimal.Context.__name__ — all three primary identifiers in their respective modules are 7-char names"
  category: identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra155.Match_name_eq:
  description: "re.Match.__name__ == 'Match' — the class name for match objects returned by Pattern.match(), Pattern.search(), and Pattern.fullmatch(); 'Match' has 5 characters, which is 2 shorter than 'Pattern' (7); this length difference means Match method qualnames are consistently 2 characters shorter than same-named Pattern methods (e.g., Match.group (11) vs Pattern.match (13))"
  category: identity
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra155.Pattern_module_is_re:
  description: "re.Pattern.__module__ == 're' — Pattern's __module__ is the public 're' module even though it is implemented in the _sre C extension; the C extension explicitly sets __module__ = 're' so that isinstance checks and type annotations referencing 're.Pattern' work correctly; this same attribution pattern also applies to re.Match, which also has __module__ == 're'"
  category: identity
  kind: python_call_eq
  function: Pattern.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra155.Match_group_qualname_len_11:
  description: "re.Match.group.__qualname__.__len__() == 11 — 'Match.group' has 11 characters ('Match.' (6) + 'group' (5) = 11); this is the same length as re.Pattern.sub.__qualname__.__len__() (11) even though the prefixes differ ('Match.' is 6, 'Pattern.' is 8); Match.group is the primary method for extracting matched text from a Match object"
  category: qualname
  kind: python_call_eq
  function: Match.group.__qualname__.__len__
  args: []
  expected: 11

invariant re_extra155.Match_groups_qualname_len_12:
  description: "re.Match.groups.__qualname__.__len__() == 12 — 'Match.groups' has 12 characters ('Match.' (6) + 'groups' (6) = 12); groups() returns a tuple containing all the subgroups of the match (capturing groups in parentheses); the qualname length 12 equals re.Pattern.subn.__qualname__.__len__() (12) — an interesting coincidence across the two classes"
  category: qualname
  kind: python_call_eq
  function: Match.groups.__qualname__.__len__
  args: []
  expected: 12

