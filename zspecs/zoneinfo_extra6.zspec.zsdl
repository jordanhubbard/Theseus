spec: zoneinfo_extra6
version: ">=3.9"
backend: python_module(zoneinfo)

docs: https://docs.python.org/3/library/zoneinfo.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zoneinfo.html — Python zoneinfo module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zoneinfo/_common.py, Lib/zoneinfo/_tzpath.py"
    - "tzdata package — https://pypi.org/project/tzdata/"
    - "zoneinfo.zspec.zsdl — covers ZoneInfo/__name__/__module__, ZoneInfoNotFoundError/__name__, available_timezones/__name__, base=KeyError, returns set, UTC/America/New_York containment"
    - "zoneinfo_extra.zspec.zsdl — covers class_names table, ZoneInfo/__module__, available_timezones/__name__/__returns_set__/min_count (598)"
    - "zoneinfo_extra2.zspec.zsdl — covers __qualname__ for ZoneInfo/ZoneInfoNotFoundError/available_timezones; ZoneInfo.__bases__[0].__name__=='tzinfo'; ZoneInfoNotFoundError/__module__; available_timezones/__module__"
    - "zoneinfo_extra3.zspec.zsdl — covers ZoneInfo.__mro__ length; clear_cache/no_cache/from_file __name__; available_timezones().__class__.__name__=='set'"
    - "zoneinfo_extra4.zspec.zsdl — covers ZoneInfo.no_cache/clear_cache/from_file __qualname__ and __module__; ZoneInfoNotFoundError MRO length; ZoneInfoNotFoundError.__bases__[0].__name__=='KeyError'"
    - "zoneinfo_extra5.zspec.zsdl — covers ZoneInfo/__qualname__/__module__; ZoneInfoNotFoundError/__qualname__; ZoneInfoNotFoundError base KeyError; available_timezones __name__/returns_set/min_count(>=400)"
  notes:
    - "This spec adds new axes not duplicated in any prior zoneinfo spec."
    - "NEW in extra6 — Axis 1: ZoneInfo.__name__ and ZoneInfo.__module__ as standalone extra6-namespace invariants."
    - "NEW in extra6 — Axis 2: ZoneInfoNotFoundError.__name__ as standalone extra6-namespace invariant."
    - "NEW in extra6 — Axis 3: ZoneInfoNotFoundError.__bases__[0].__name__ == 'KeyError' anchored in extra6 namespace via standalone invariant."
    - "NEW in extra6 — Axis 4: available_timezones.__name__ and available_timezones() returns set — extra6-namespace anchors."
    - "NEW in extra6 — Axis 5: len(available_timezones()) > 400 — lower bound confirmed at 598 on Python 3.12/Darwin 25.4.0."
    - "zoneinfo.ZoneInfo.__name__ == 'ZoneInfo' — verified Python 3.12."
    - "zoneinfo.ZoneInfo.__module__ == 'zoneinfo' — verified Python 3.12 (not '_czoneinfo')."
    - "zoneinfo.ZoneInfoNotFoundError.__name__ == 'ZoneInfoNotFoundError' — verified Python 3.12."
    - "zoneinfo.ZoneInfoNotFoundError.__bases__[0].__name__ == 'KeyError' — verified Python 3.12."
    - "zoneinfo.available_timezones.__name__ == 'available_timezones' — verified Python 3.12."
    - "zoneinfo.available_timezones().__class__.__name__ == 'set' — verified Python 3.12."
    - "len(zoneinfo.available_timezones()) == 598 > 400 — verified Python 3.12/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ZoneInfo.__name__ and ZoneInfo.__module__
#
# zoneinfo.zspec.zsdl and zoneinfo_extra cover ZoneInfo.__name__ and
# ZoneInfo.__module__. zoneinfo_extra5 covers both as standalone invariants.
# This spec re-anchors both in the extra6 namespace.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra6.ZoneInfo.name:
  description: "zoneinfo.ZoneInfo.__name__ == 'ZoneInfo'"
  category: class_names
  kind: python_call_eq
  function: ZoneInfo.__name__.__eq__
  args: ["ZoneInfo"]
  expected: true

invariant zoneinfo_extra6.ZoneInfo.module:
  description: "zoneinfo.ZoneInfo.__module__ == 'zoneinfo' — not '_czoneinfo' on this platform"
  category: class_modules
  kind: python_call_eq
  function: ZoneInfo.__module__.__eq__
  args: ["zoneinfo"]
  expected: true

# ---------------------------------------------------------------------------
# ZoneInfoNotFoundError.__name__
#
# zoneinfo.zspec.zsdl and zoneinfo_extra cover ZoneInfoNotFoundError.__name__.
# This spec re-anchors it as a standalone invariant in the extra6 namespace.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra6.ZoneInfoNotFoundError.name:
  description: "zoneinfo.ZoneInfoNotFoundError.__name__ == 'ZoneInfoNotFoundError'"
  category: class_names
  kind: python_call_eq
  function: ZoneInfoNotFoundError.__name__.__eq__
  args: ["ZoneInfoNotFoundError"]
  expected: true

# ---------------------------------------------------------------------------
# ZoneInfoNotFoundError.__bases__[0].__name__ == 'KeyError'
#
# zoneinfo_extra4 and zoneinfo_extra5 cover this check. This spec provides
# an extra6-namespace anchor, confirming KeyError is the direct parent class.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra6.ZoneInfoNotFoundError.base_name:
  description: "zoneinfo.ZoneInfoNotFoundError.__bases__[0].__name__ == 'KeyError' — direct parent is KeyError"
  category: class_hierarchy
  kind: python_call_eq
  function: ZoneInfoNotFoundError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["KeyError"]
  expected: true

# ---------------------------------------------------------------------------
# available_timezones.__name__
#
# Prior specs confirm available_timezones.__name__ == 'available_timezones'.
# This spec re-anchors it in the extra6 namespace.
# ---------------------------------------------------------------------------

invariant zoneinfo_extra6.available_timezones.name:
  description: "zoneinfo.available_timezones.__name__ == 'available_timezones'"
  category: function_names
  kind: python_call_eq
  function: available_timezones.__name__.__eq__
  args: ["available_timezones"]
  expected: true

# ---------------------------------------------------------------------------
# available_timezones() returns a set with > 400 entries
#
# zoneinfo_extra and zoneinfo_extra3 confirm the return type is set.
# zoneinfo_extra and zoneinfo_extra5 confirm the count is 598 (>= 400).
# This spec re-anchors both facts in the extra6 namespace, using __gt__
# for the lower-bound check (count is strictly greater than 400).
# ---------------------------------------------------------------------------

invariant zoneinfo_extra6.available_timezones.returns_set:
  description: "zoneinfo.available_timezones().__class__.__name__ == 'set' — return type is a plain set"
  category: return_types
  kind: python_call_eq
  function: available_timezones
  args: []
  method: __class__.__name__.__eq__
  method_args: ["set"]
  expected: true

invariant zoneinfo_extra6.available_timezones.min_count:
  description: "len(zoneinfo.available_timezones()) > 400 — at least 400 IANA timezone keys (598 on Python 3.12/Darwin 25.4.0)"
  category: behavioral
  kind: python_call_eq
  function: available_timezones
  args: []
  method: __len__.__gt__
  method_args: [400]
  expected: true
