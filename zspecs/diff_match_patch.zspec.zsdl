spec: diff_match_patch
version: ">=1.0.0"
backend: node(diff-match-patch)

docs: https://github.com/google/diff-match-patch

provenance:
  derived_from:
    - "diff-match-patch documentation — https://github.com/google/diff-match-patch/wiki/API"
    - "Test vectors verified with diff-match-patch via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "diff-match-patch source"
  notes:
    - "Google's diff-match-patch — Myers diff + Bitap fuzzy match + Patch apply."
    - "Install: npm install diff-match-patch"
    - "diff_main(text1, text2) returns array of [op, text] tuples; op is -1 (DELETE), 0 (EQUAL), 1 (INSERT)."
    - "The exported diff_match_patch is a constructor; instances hold tuning parameters."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on string inputs."
  stderr: "null"
  stickiness: "N/A — each diff_main call independent."
  codes: {}

# diff_main(t1, t2) on a constructed instance
table diff_match_patch.diff_main:
  kind: node_chain_eq
  category: diff_main
  entry: constructor
  class: diff_match_patch
  entry_args: []
  id_prefix: diff

  columns: [id, chain, expected]
  rows:
    - [identical_strings,
       [{method: diff_main, args: ["abc", "abc"]}],
       [[0, "abc"]]]

    - [single_char_change,
       [{method: diff_main, args: ["hello", "hxllo"]}],
       [[0, "h"], [-1, "e"], [1, "x"], [0, "llo"]]]

    - [completely_different,
       [{method: diff_main, args: ["abc", "xyz"]}],
       [[-1, "abc"], [1, "xyz"]]]

    - [pure_insertion,
       [{method: diff_main, args: ["abc", "abcdef"]}],
       [[0, "abc"], [1, "def"]]]

    - [pure_deletion,
       [{method: diff_main, args: ["abcdef", "abc"]}],
       [[0, "abc"], [-1, "def"]]]

    - [empty_to_empty,
       [{method: diff_main, args: ["", ""]}],
       []]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:22:59Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
