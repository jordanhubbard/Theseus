spec: pathlib_extra796
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - pathlib module CPython source
    - Python standard library documentation
  not_derived_from:
    - any third-party path libraries
  notes:
    - Covers pathlib.Path, PurePath, PosixPath, PureWindowsPath, PurePosixPath, and WindowsPath class attributes
    - Checks __class__.__name__ for class objects and __doc__.__class__.__name__ for docstrings
  created_at: "2026-04-12"

table pathlib_extra796.name:
  description: Verify class-level attributes for pathlib path hierarchy classes
  kind: python_call_eq
  category: stdlib_identity
  id_prefix: pl796xx
  columns: [id, function, args, expected]
  rows:
    - [pl796xx001, pathlib.Path.cwd.__qualname__.__eq__, ["Path.cwd"], true]
    - [pl796xx002, pathlib.Path.home.__qualname__.__eq__, ["Path.home"], true]
    - [pl796xx003, pathlib.Path.__class__.__name__.__eq__, ["type"], true]
    - [pl796xx004, pathlib.PurePath.__class__.__name__.__eq__, ["type"], true]
    - [pl796xx005, pathlib.PosixPath.__class__.__name__.__eq__, ["type"], true]
    - [pl796xx006, pathlib.PureWindowsPath.__class__.__name__.__eq__, ["type"], true]
    - [pl796xx007, pathlib.PurePosixPath.__class__.__name__.__eq__, ["type"], true]
    - [pl796xx008, pathlib.WindowsPath.__class__.__name__.__eq__, ["type"], true]
    - [pl796xx009, pathlib.Path.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [pl796xx010, pathlib.PurePath.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [pl796xx011, pathlib.PosixPath.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [pl796xx012, pathlib.PureWindowsPath.__doc__.__class__.__name__.__eq__, ["str"], true]
