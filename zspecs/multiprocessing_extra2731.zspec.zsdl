# ---------------------------------------------------------------------------
# Table 4: synchronize types __trunc__/__floor__/__ceil__ checks
#
# Wave 629 theme: multiprocessing.synchronize Lock, RLock, Semaphore, and
# Event are IPC synchronization primitives. None define any rounding or
# truncation operator protocol in their own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2731.synchronize_rounding:
  description: "multiprocessing.synchronize types __trunc__/__floor__/__ceil__ dict-presence checks — IPC sync primitives define none"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2731

  columns: [id, function, args, expected]
  rows:
    - ["mp2731010", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__trunc__"], false]
    - ["mp2731011", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__floor__"], false]
    - ["mp2731012", "multiprocessing.synchronize.Lock.__dict__.__contains__",      ["__ceil__"],  false]
    - ["mp2731013", "multiprocessing.synchronize.RLock.__dict__.__contains__",     ["__trunc__"], false]
    - ["mp2731014", "multiprocessing.synchronize.RLock.__dict__.__contains__",     ["__floor__"], false]
    - ["mp2731015", "multiprocessing.synchronize.RLock.__dict__.__contains__",     ["__ceil__"],  false]
    - ["mp2731016", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__trunc__"], false]
    - ["mp2731017", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__floor__"], false]
    - ["mp2731018", "multiprocessing.synchronize.Semaphore.__dict__.__contains__", ["__ceil__"],  false]
    - ["mp2731019", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__trunc__"], false]
    - ["mp2731020", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__floor__"], false]
    - ["mp2731021", "multiprocessing.synchronize.Event.__dict__.__contains__",     ["__ceil__"],  false]
