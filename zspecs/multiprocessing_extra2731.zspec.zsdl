spec: multiprocessing_extra2731
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.pool.Pool"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 629 (_extra2731): __trunc__, __floor__, __ceil__ dict-presence checks (rounding/truncation operators)."
    - "multiprocessing.Process, multiprocessing.pool.Pool, and multiprocessing.pool.AsyncResult are process/IPC primitives, not numeric types."
    - "None of these types define truncation, floor, or ceiling rounding protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __trunc__ dict-presence checks
#
# Wave 629 theme: multiprocessing process and pool types do not implement
# the truncation operator. __trunc__ does not appear in any of these
# classes' own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra2731.trunc_protocol:
  description: "multiprocessing.Process, Pool, AsyncResult __trunc__ dict-presence checks — none define truncation in own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2731

  columns: [id, function, args, expected]
  rows:
    - ["mp2731001", "multiprocessing.Process.__dict__.__contains__",          ["__trunc__"], false]
    - ["mp2731002", "multiprocessing.pool.Pool.__dict__.__contains__",        ["__trunc__"], false]
    - ["mp2731003", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__trunc__"], false]

