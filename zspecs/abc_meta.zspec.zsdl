spec: abc_meta
version: ">=3.10"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "abc source: internal _abc C extension implementation details"
  notes:
    - "This spec covers ABCMeta methods, update_abstractmethods, and get_cache_token not covered in abc.zspec.zsdl."
    - "abc.update_abstractmethods(cls) re-computes __abstractmethods__ on a class after dynamic mutation (Python 3.10+)."
    - "update_abstractmethods is a builtin_function_or_method (implemented in _abc C extension)."
    - "update_abstractmethods.__module__ is '_abc' like get_cache_token."
    - "ABCMeta defines register(), __subclasshook__(), and __instancecheck__() as methods."
    - "ABCMeta.register is a function; its __name__ is 'register'."
    - "ABCMeta.__instancecheck__.__name__ == '__instancecheck__'."
    - "abstractmethod can be stacked with other decorators; the attribute __isabstractmethod__ is propagated."
    - "ABC.__abstractmethods__ is an empty frozenset — ABC itself has no abstract methods."
    - "frozenset().__class__.__name__ == 'frozenset'; we verify ABC.__abstractmethods__ is empty via __len__."
    - "ABCMeta has a register method accessible as an attribute — type is 'function'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# update_abstractmethods — exported from abc since Python 3.10
#
# abc.update_abstractmethods(cls) recomputes __abstractmethods__ after
# dynamic class mutation. It is implemented in the _abc C extension.
# ---------------------------------------------------------------------------

invariant abc_meta.update_abstractmethods.name:
  description: "abc.update_abstractmethods.__name__ == 'update_abstractmethods'"
  category: update_abstractmethods
  kind: python_call_eq
  function: update_abstractmethods.__name__.__eq__
  args: ["update_abstractmethods"]
  expected: true

invariant abc_meta.update_abstractmethods.type:
  description: "type(abc.update_abstractmethods).__name__ == 'builtin_function_or_method'"
  category: update_abstractmethods
  kind: python_call_eq
  function: update_abstractmethods.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant abc_meta.update_abstractmethods.module:
  description: "abc.update_abstractmethods.__module__ == '_abc'"
  category: update_abstractmethods
  kind: python_call_eq
  function: update_abstractmethods.__module__.__eq__
  args: ["_abc"]
  expected: true

# ---------------------------------------------------------------------------
# ABC.__abstractmethods__ — empty frozenset on the ABC helper class
#
# ABC defines no abstract methods of its own, so __abstractmethods__ is an
# empty frozenset. We verify its type name and that its length is zero.
# ---------------------------------------------------------------------------

invariant abc_meta.ABC.abstractmethods_type:
  description: "type(abc.ABC.__abstractmethods__).__name__ == 'frozenset'"
  category: abc_abstractmethods
  kind: python_call_eq
  function: ABC.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant abc_meta.ABC.abstractmethods_empty:
  description: "len(abc.ABC.__abstractmethods__) == 0 — ABC has no abstract methods"
  category: abc_abstractmethods
  kind: python_call_eq
  function: ABC.__abstractmethods__.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# ABCMeta.register — method available on the metaclass
#
# ABCMeta.register(cls) registers cls as a virtual subclass. We verify the
# attribute is present and is a function with the right __name__.
# ---------------------------------------------------------------------------

invariant abc_meta.ABCMeta.register_name:
  description: "abc.ABCMeta.register.__name__ == 'register'"
  category: abcmeta_methods
  kind: python_call_eq
  function: ABCMeta.register.__name__.__eq__
  args: ["register"]
  expected: true

invariant abc_meta.ABCMeta.register_is_function:
  description: "type(abc.ABCMeta.register).__name__ == 'function'"
  category: abcmeta_methods
  kind: python_call_eq
  function: ABCMeta.register.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta.__instancecheck__ — custom isinstance() hook
#
# ABCMeta overrides __instancecheck__ to support virtual subclasses.
# We verify the method is present with the right __name__.
# ---------------------------------------------------------------------------

invariant abc_meta.ABCMeta.instancecheck_name:
  description: "abc.ABCMeta.__instancecheck__.__name__ == '__instancecheck__'"
  category: abcmeta_methods
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__name__.__eq__
  args: ["__instancecheck__"]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta.__subclasshook__ — customisation point for subclass checks
#
# ABCMeta defines __subclasshook__ as a classmethod. We verify it is present
# and accessible on the metaclass.
# ---------------------------------------------------------------------------

invariant abc_meta.ABCMeta.subclasshook_name:
  description: "abc.ABCMeta.__subclasshook__.__name__ == '__subclasshook__'"
  category: abcmeta_methods
  kind: python_call_eq
  function: ABCMeta.__subclasshook__.__name__.__eq__
  args: ["__subclasshook__"]
  expected: true

# ---------------------------------------------------------------------------
# get_cache_token — module lives in C extension _abc
#
# get_cache_token is documented as returning an opaque token (an integer).
# Its __module__ is '_abc' because it is implemented in the C extension.
# This is distinct from abc.zspec.zsdl which only checked the token value.
# ---------------------------------------------------------------------------

invariant abc_meta.get_cache_token.module_is_c_ext:
  description: "abc.get_cache_token.__module__ == '_abc' — implemented in C extension"
  category: get_cache_token_meta
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_meta.get_cache_token.qualname:
  description: "abc.get_cache_token.__qualname__ == 'get_cache_token'"
  category: get_cache_token_meta
  kind: python_call_eq
  function: get_cache_token.__qualname__.__eq__
  args: ["get_cache_token"]
  expected: true

# ---------------------------------------------------------------------------
# abstractmethod — __wrapped__ is absent; isabstractmethod propagates
#
# abstractmethod.__isabstractmethod__ is True, confirming that the decorator
# marks itself as abstract (used when stacking with other decorators).
# This invariant is distinct from abc.zspec.zsdl which checked the attribute
# via abstractmethod.__isabstractmethod__.__eq__; here we reconfirm via the
# class-level attribute truthiness.
# ---------------------------------------------------------------------------

invariant abc_meta.abstractmethod.isabstractmethod_is_bool:
  description: "type(abc.abstractmethod.__isabstractmethod__).__name__ == 'bool'"
  category: abstractmethod_meta
  kind: python_call_eq
  function: abstractmethod.__isabstractmethod__.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

