spec: http_server_extra2
version: ">=3.9"
backend: python_module(http.server)

docs: https://docs.python.org/3/library/http.server.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/http.server.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/server.py"
    - "http_server.zspec.zsdl — covers __name__ table (HTTPServer/ThreadingHTTPServer/Base/Simple/CGIHTTPRequestHandler), BaseHTTPRequestHandler string constants, extensions_map type"
    - "http_server_handlers.zspec.zsdl — covers module table (Base/Simple/CGI/HTTPServer), hierarchy (Simple/CGI/HTTPServer bases), error_message_format type/len, simple server_version prefix, cgi_directories type/contents"
    - "http_server_extra.zspec.zsdl — covers BaseHTTPRequestHandler base (StreamRequestHandler), ThreadingHTTPServer module, ThreadingHTTPServer bases[0]/[1], handler string attr types table, HTTPServer.__qualname__, CGIHTTPRequestHandler.__qualname__, SimpleHTTPRequestHandler.index_pages type/contains, BaseHTTPRequestHandler.responses type/contains 200"
  notes:
    - "This spec adds __qualname__ vectors not covered in any prior http.server spec."
    - "http_server_extra already covers HTTPServer.__qualname__ and CGIHTTPRequestHandler.__qualname__ — those are skipped here."
    - "http.server.ThreadingHTTPServer.__qualname__ == 'ThreadingHTTPServer' — not covered in any prior spec."
    - "http.server.BaseHTTPRequestHandler.__qualname__ == 'BaseHTTPRequestHandler' — not covered in any prior spec."
    - "http.server.SimpleHTTPRequestHandler.__qualname__ == 'SimpleHTTPRequestHandler' — not covered in any prior spec."
    - "http.server.DEFAULT_ERROR_MESSAGE is a module-level str template for HTTP error responses."
    - "http.server.DEFAULT_ERROR_CONTENT_TYPE is a module-level str giving the content-type for error pages."
    - "http.server.DEFAULT_ERROR_CONTENT_TYPE == 'text/html;charset=utf-8' — value not checked in any prior spec (extra2 previously only checked type)."
    - "http.server.BaseHTTPRequestHandler.rbufsize == -1 — inherited from StreamRequestHandler; means unbuffered reads."
    - "http.server.BaseHTTPRequestHandler.wbufsize == 0 — zero write buffer size."
    - "http.server.BaseHTTPRequestHandler.disable_nagle_algorithm == False — TCP Nagle not disabled by default."
    - "http.server.BaseHTTPRequestHandler.responses contains 404 — Not Found must be present."
    - "http.server.BaseHTTPRequestHandler.responses contains 500 — Internal Server Error must be present."
    - "http.server.SimpleHTTPRequestHandler.index_pages[1] == 'index.htm' — second fallback index filename."
    - "http.server.SimpleHTTPRequestHandler.server_version == 'SimpleHTTP/0.6' — exact version string."
    - "http.server.SimpleHTTPRequestHandler.__module__ == 'http.server' — not covered as a standalone invariant in any prior spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — handler classes not covered in prior specs
# http_server_extra already has HTTPServer.__qualname__ and
# CGIHTTPRequestHandler.__qualname__; those are intentionally omitted here.
# ---------------------------------------------------------------------------

table http_server_extra2.qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ThreadingHTTPServer,      ThreadingHTTPServer.__qualname__.__eq__,      ["ThreadingHTTPServer"],      true]
    - [BaseHTTPRequestHandler,   BaseHTTPRequestHandler.__qualname__.__eq__,   ["BaseHTTPRequestHandler"],   true]
    - [SimpleHTTPRequestHandler, SimpleHTTPRequestHandler.__qualname__.__eq__, ["SimpleHTTPRequestHandler"], true]

# ---------------------------------------------------------------------------
# DEFAULT_ERROR_MESSAGE — module-level constant type check
# Not covered in any prior http.server spec.
# ---------------------------------------------------------------------------

invariant http_server_extra2.DEFAULT_ERROR_MESSAGE.class_name:
  description: "http.server.DEFAULT_ERROR_MESSAGE.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_ERROR_MESSAGE.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_ERROR_CONTENT_TYPE — type and value checks
# Value check is new; type was checked in an earlier version of this file.
# ---------------------------------------------------------------------------

invariant http_server_extra2.DEFAULT_ERROR_CONTENT_TYPE.class_name:
  description: "http.server.DEFAULT_ERROR_CONTENT_TYPE.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_ERROR_CONTENT_TYPE.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant http_server_extra2.DEFAULT_ERROR_CONTENT_TYPE.value:
  description: "http.server.DEFAULT_ERROR_CONTENT_TYPE == 'text/html;charset=utf-8'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_ERROR_CONTENT_TYPE.__eq__
  args: ["text/html;charset=utf-8"]
  expected: true

# ---------------------------------------------------------------------------
# BaseHTTPRequestHandler buffer and socket attributes
# rbufsize/wbufsize are inherited from StreamRequestHandler.
# disable_nagle_algorithm is defined directly on BaseHTTPRequestHandler.
# None of these are checked in any prior http.server spec.
# ---------------------------------------------------------------------------

invariant http_server_extra2.BaseHTTPRequestHandler.rbufsize:
  description: "BaseHTTPRequestHandler.rbufsize == -1 — unbuffered read socket"
  category: constants
  kind: python_call_eq
  function: BaseHTTPRequestHandler.rbufsize.__eq__
  args: [-1]
  expected: true

invariant http_server_extra2.BaseHTTPRequestHandler.wbufsize:
  description: "BaseHTTPRequestHandler.wbufsize == 0 — zero write buffer"
  category: constants
  kind: python_call_eq
  function: BaseHTTPRequestHandler.wbufsize.__eq__
  args: [0]
  expected: true

invariant http_server_extra2.BaseHTTPRequestHandler.disable_nagle_algorithm:
  description: "BaseHTTPRequestHandler.disable_nagle_algorithm == False — Nagle not disabled by default"
  category: constants
  kind: python_call_eq
  function: BaseHTTPRequestHandler.disable_nagle_algorithm.__eq__
  args: [false]
  expected: true

# ---------------------------------------------------------------------------
# BaseHTTPRequestHandler.responses — additional status code coverage
# http_server_extra covers type check and 200 presence.
# 404 and 500 have never been checked in any prior spec.
# ---------------------------------------------------------------------------

invariant http_server_extra2.responses.contains_404:
  description: "404 in BaseHTTPRequestHandler.responses — Not Found must be present"
  category: constants
  kind: python_call_eq
  function: BaseHTTPRequestHandler.responses.__contains__
  args: [404]
  expected: true

invariant http_server_extra2.responses.contains_500:
  description: "500 in BaseHTTPRequestHandler.responses — Internal Server Error must be present"
  category: constants
  kind: python_call_eq
  function: BaseHTTPRequestHandler.responses.__contains__
  args: [500]
  expected: true

# ---------------------------------------------------------------------------
# SimpleHTTPRequestHandler — additional index_pages and server_version checks
# http_server_extra covers index_pages type and 'index.html' presence.
# The second entry ('index.htm') and exact server_version value are new.
# ---------------------------------------------------------------------------

invariant http_server_extra2.SimpleHTTPRequestHandler.index_pages_len:
  description: "len(SimpleHTTPRequestHandler.index_pages) == 2 — two default index filenames"
  category: constants
  kind: python_call_eq
  function: SimpleHTTPRequestHandler.index_pages.__len__
  args: []
  expected: 2

invariant http_server_extra2.SimpleHTTPRequestHandler.index_pages_index_htm:
  description: "'index.htm' in SimpleHTTPRequestHandler.index_pages — second fallback filename"
  category: constants
  kind: python_call_eq
  function: SimpleHTTPRequestHandler.index_pages.__contains__
  args: ["index.htm"]
  expected: true

invariant http_server_extra2.SimpleHTTPRequestHandler.server_version:
  description: "SimpleHTTPRequestHandler.server_version == 'SimpleHTTP/0.6'"
  category: constants
  kind: python_call_eq
  function: SimpleHTTPRequestHandler.server_version.__eq__
  args: ["SimpleHTTP/0.6"]
  expected: true

