spec: http_server_extra2
version: ">=3.9"
backend: python_module(http.server)

docs: https://docs.python.org/3/library/http.server.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/http.server.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/http/server.py"
    - "http_server.zspec.zsdl — covers __name__ table (HTTPServer/ThreadingHTTPServer/Base/Simple/CGIHTTPRequestHandler), BaseHTTPRequestHandler string constants, extensions_map type"
    - "http_server_handlers.zspec.zsdl — covers module table (Base/Simple/CGI/HTTPServer), hierarchy (Simple/CGI/HTTPServer bases), error_message_format type/len, simple server_version prefix, cgi_directories type/contents"
    - "http_server_extra.zspec.zsdl — covers BaseHTTPRequestHandler base (StreamRequestHandler), ThreadingHTTPServer module, ThreadingHTTPServer bases[0]/[1], handler string attr types table, HTTPServer.__qualname__, CGIHTTPRequestHandler.__qualname__, SimpleHTTPRequestHandler.index_pages type/contains, BaseHTTPRequestHandler.responses type/contains 200"
  notes:
    - "This spec adds __qualname__ vectors not covered in any prior http.server spec."
    - "http_server_extra already covers HTTPServer.__qualname__ and CGIHTTPRequestHandler.__qualname__ — those are skipped here."
    - "http.server.ThreadingHTTPServer.__qualname__ == 'ThreadingHTTPServer' — not covered in any prior spec."
    - "http.server.BaseHTTPRequestHandler.__qualname__ == 'BaseHTTPRequestHandler' — not covered in any prior spec."
    - "http.server.SimpleHTTPRequestHandler.__qualname__ == 'SimpleHTTPRequestHandler' — not covered in any prior spec."
    - "http.server.DEFAULT_ERROR_MESSAGE is a module-level str template for HTTP error responses."
    - "http.server.DEFAULT_ERROR_CONTENT_TYPE is a module-level str giving the content-type for error pages."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — handler classes not covered in prior specs
# http_server_extra already has HTTPServer.__qualname__ and
# CGIHTTPRequestHandler.__qualname__; those are intentionally omitted here.
# ---------------------------------------------------------------------------

table http_server_extra2.qualnames:
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ThreadingHTTPServer,      ThreadingHTTPServer.__qualname__.__eq__,      ["ThreadingHTTPServer"],      true]
    - [BaseHTTPRequestHandler,   BaseHTTPRequestHandler.__qualname__.__eq__,   ["BaseHTTPRequestHandler"],   true]
    - [SimpleHTTPRequestHandler, SimpleHTTPRequestHandler.__qualname__.__eq__, ["SimpleHTTPRequestHandler"], true]

# ---------------------------------------------------------------------------
# DEFAULT_ERROR_MESSAGE — module-level constant type check
# Not covered in any prior http.server spec.
# ---------------------------------------------------------------------------

invariant http_server_extra2.DEFAULT_ERROR_MESSAGE.class_name:
  description: "http.server.DEFAULT_ERROR_MESSAGE.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_ERROR_MESSAGE.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# DEFAULT_ERROR_CONTENT_TYPE — module-level constant type check
# Not covered in any prior http.server spec.
# ---------------------------------------------------------------------------

invariant http_server_extra2.DEFAULT_ERROR_CONTENT_TYPE.class_name:
  description: "http.server.DEFAULT_ERROR_CONTENT_TYPE.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: DEFAULT_ERROR_CONTENT_TYPE.__class__.__name__.__eq__
  args: ["str"]
  expected: true
