spec: detect_newline
version: ">=4.0.0"
backend: node(detect-newline)

docs: https://github.com/sindresorhus/detect-newline#readme

provenance:
  derived_from:
    - "detect-newline README — https://github.com/sindresorhus/detect-newline#readme"
    - "Test vectors verified with detect-newline via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "detect-newline source"
  notes:
    - "Detects which newline style a string predominantly uses."
    - "Install: npm install detect-newline"
    - "Named exports: detectNewline (returns '\\n' / '\\r\\n' / undefined) and detectNewlineGraceful (defaults to '\\n' for no-newline input)."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table detect_newline.detectNewline:
  kind: node_module_call_eq
  category: detectNewline
  function: detectNewline
  id_prefix: nl

  columns: [id, args, expected]
  rows:
    - [lf,        ["a\nb"],          "\n"]
    - [crlf,      ["a\r\nb"],         "\r\n"]
    - [mixed_majority_lf,
                  ["a\nb\nc\r\nd"],   "\n"]
    - [no_newline_returns_undefined,
                  ["plain text"],     ~]

table detect_newline.detectNewlineGraceful:
  kind: node_module_call_eq
  category: detectNewlineGraceful
  function: detectNewlineGraceful
  id_prefix: graceful

  columns: [id, args, expected]
  rows:
    - [lf,                  ["a\nb"],           "\n"]
    - [crlf,                ["a\r\nb"],         "\r\n"]
    - [no_newline_default_lf,
                            ["plain text"],     "\n"]
    - [empty_default_lf,    [""],                "\n"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:16:18Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
