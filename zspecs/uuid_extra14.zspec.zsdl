spec: uuid_extra14
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra.zspec.zsdl — covers UUID.__name__/__module__; uuid1/3/4/5 __name__; NAMESPACE_* class names; UUID int/hex attribute types"
    - "uuid_extra2.zspec.zsdl — covers uuid1/3/4/5 __name__ standalone; NAMESPACE_* class names standalone"
    - "uuid_extra3.zspec.zsdl — covers uuid1/3/4/5 __module__; UUID.__bases__[0].__name__; UUID(int=0).version is None"
    - "uuid_extra4.zspec.zsdl — covers NAMESPACE_* class names (table); uuid4 version/class; UUID str format; NAMESPACE_DNS str repr"
    - "uuid_extra5.zspec.zsdl — covers __qualname__ for UUID and uuid1/3/4/5 (table)"
    - "uuid_extra6.zspec.zsdl — covers RESERVED_*/RFC_4122 class names; UUID.bytes/__class__/__name__; UUID.fields.__len__()==6"
    - "uuid_extra7.zspec.zsdl — covers SafeUUID metadata (__name__/__module__/__qualname__/safe.value/unsafe.value/__bases__[0]); NAMESPACE_* .version table (all==1); uuid1/uuid4 return class name and version"
    - "uuid_extra8.zspec.zsdl — covers UUID.__bases__.__len__()==1; NAMESPACE_DNS.int/__class__/__name__; NAMESPACE_URL.int/__class__.__name__; UUID.bytes/__class__.__name__"
    - "uuid_extra9.zspec.zsdl — covers uuid3/__doc__ and uuid5/__doc__ type; NAMESPACE_URL.bytes and NAMESPACE_DNS.bytes_le; SafeUUID.__bases__.__len__()==1"
    - "uuid_extra10.zspec.zsdl — covers NAMESPACE_URL/OID/X500 .bytes_le/__class__.__name__; NAMESPACE_*/node/__class__.__name__; zero UUID hex value and int value and hex len"
    - "uuid_extra11.zspec.zsdl — covers UUID.bytes.__len__()==16; UUID version from literal v4 string; UUID.__name__/__module__.__len__()==4; NAMESPACE_DNS.hex value and len; NAMESPACE_URL.__str__(); UUID hex len (non-zero input)"
    - "uuid_extra12.zspec.zsdl — covers UUID.__qualname__.__len__()==4; uuid1/3/4/5 __name__/__module__ string lengths (table); NAMESPACE_DNS/URL __class__.__name__.__len__()==4; UUID.__bases__.__getitem__(0).__name__"
    - "uuid_extra13.zspec.zsdl — covers UUID.__name__.__eq__('UUID') standalone; uuid4().__class__.__name__=='UUID' via method_chain; NAMESPACE_DNS/URL __class__.__name__.__eq__('UUID') table; UUID(int=0).__str__().__len__()==36; NAMESPACE_DNS.version==1"
  notes:
    - "This spec extends the uuid chain through extra13; it does NOT duplicate invariants in any prior spec."
    - "Focus: uuid1/3/4/5 __qualname__.__len__()==5 (uuid_extra5 covers __qualname__ via __eq__; uuid_extra12 covers __name__.__len__()==5; __qualname__.__len__() is new); SafeUUID.__qualname__.__len__()==8 (uuid_extra7 covers SafeUUID.__qualname__ via __eq__ but not length); UUID.__bases__[0].__name__.__len__()==6 (uuid_extra3 covers __bases__[0].__name__ via __eq__; length is new); NAMESPACE_OID/__class__.__name__.__len__()==4 and NAMESPACE_X500/__class__.__name__.__len__()==4 (uuid_extra12 covers DNS/URL but not OID/X500)."
    - "uuid.uuid1.__qualname__.__len__() == 5 — len('uuid1') == 5. uuid_extra5 checks __qualname__=='uuid1' via __eq__; uuid_extra12 checks __name__.__len__()==5. qualname length is a distinct axis."
    - "uuid.SafeUUID.__qualname__.__len__() == 8 — len('SafeUUID') == 8. uuid_extra7 checks __qualname__=='SafeUUID' via __eq__. Length not previously checked."
    - "uuid.UUID.__bases__[0].__name__.__len__() == 6 — len('object') == 6. uuid_extra3 checks __bases__[0].__name__=='object' via __eq__; length is new."
    - "uuid.NAMESPACE_OID.__class__.__name__.__len__() == 4 — len('UUID') == 4. uuid_extra12 checks NAMESPACE_DNS/URL class name lengths; OID/X500 are distinct namespaces not yet checked."
    - "uuid.NAMESPACE_X500.__class__.__name__.__len__() == 4 — same rationale."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid1/uuid3/uuid4/uuid5 __qualname__ string lengths
#
# uuid_extra5 covers __qualname__ == 'uuid1'/'uuid3'/'uuid4'/'uuid5' via __eq__
# in a table. uuid_extra12 covers __name__.__len__() for all four (all 5).
# Since __qualname__ == __name__ for these top-level functions, __qualname__.__len__()
# is the same value (5) but is accessed via a distinct attribute chain — new axis.
# ---------------------------------------------------------------------------

table uuid_extra14.factory_qualname_len:
  description: "Length of __qualname__ string for uuid factory functions — all 5 (len('uuid1'))"
  kind: python_call_eq
  category: factory_metadata
  id_prefix: qname_len14

  columns: [id, function, args, expected]
  rows:
    - [uuid1, uuid1.__qualname__.__len__, [], 5]
    - [uuid3, uuid3.__qualname__.__len__, [], 5]
    - [uuid4, uuid4.__qualname__.__len__, [], 5]
    - [uuid5, uuid5.__qualname__.__len__, [], 5]

# ---------------------------------------------------------------------------
# SafeUUID.__qualname__.__len__() == 8
#
# uuid_extra7 covers SafeUUID.__qualname__ == 'SafeUUID' via __eq__.
# No prior spec checks the length of the SafeUUID __qualname__ string.
# len('SafeUUID') == 8.
# ---------------------------------------------------------------------------

invariant uuid_extra14.SafeUUID.qualname_len:
  description: "uuid.SafeUUID.__qualname__.__len__() == 8 — len('SafeUUID') == 8"
  category: class_metadata
  kind: python_call_eq
  function: SafeUUID.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# UUID.__bases__[0].__name__.__len__() == 6
#
# uuid_extra3 covers UUID.__bases__[0].__name__ == 'object' via __eq__ directly.
# uuid_extra12 covers UUID.__bases__.__getitem__(0).__name__.__eq__('object').
# No prior spec checks the length of the base class name string. len('object') == 6.
# ---------------------------------------------------------------------------

invariant uuid_extra14.UUID.base_name_len:
  description: "uuid.UUID.__bases__[0].__name__.__len__() == 6 — len('object') == 6"
  category: class_hierarchy
  kind: python_call_eq
  function: "UUID.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# NAMESPACE_OID and NAMESPACE_X500 __class__.__name__.__len__() == 4
#
# uuid_extra12 covers NAMESPACE_DNS and NAMESPACE_URL __class__.__name__.__len__()==4.
# No prior spec checks the class name length for NAMESPACE_OID or NAMESPACE_X500.
# Both are UUID instances so __class__.__name__ == 'UUID', len('UUID') == 4.
# ---------------------------------------------------------------------------

invariant uuid_extra14.NAMESPACE_OID.class_name_len:
  description: "uuid.NAMESPACE_OID.__class__.__name__.__len__() == 4 — len('UUID') == 4"
  category: namespace_metadata
  kind: python_call_eq
  function: NAMESPACE_OID.__class__.__name__.__len__
  args: []
  expected: 4

invariant uuid_extra14.NAMESPACE_X500.class_name_len:
  description: "uuid.NAMESPACE_X500.__class__.__name__.__len__() == 4 — len('UUID') == 4"
  category: namespace_metadata
  kind: python_call_eq
  function: NAMESPACE_X500.__class__.__name__.__len__
  args: []
  expected: 4
