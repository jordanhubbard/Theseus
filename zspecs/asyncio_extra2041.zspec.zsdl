spec: asyncio_extra2041
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rshift__, __and__, __or__, __xor__, __invert__ dict-presence checks."
    - "asyncio types (Task, Future, Event, Lock, Queue) are concurrency primitives, not bitwise types."
    - "None of these types define bit-shift, bitwise AND/OR/XOR, or bitwise NOT protocols in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table asyncio_extra2041.lshift_protocol:
  description: "asyncio types __lshift__/__rlshift__/__ilshift__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as2041

  columns: [id, function, args, expected]
  rows:
    - ["as2041001", "asyncio.Task.__dict__.__contains__", ["__lshift__"], false]
    - ["as2041002", "asyncio.Task.__dict__.__contains__", ["__rlshift__"], false]
    - ["as2041003", "asyncio.Task.__dict__.__contains__", ["__ilshift__"], false]
    - ["as2041004", "asyncio.Future.__dict__.__contains__", ["__lshift__"], false]
    - ["as2041005", "asyncio.Future.__dict__.__contains__", ["__rlshift__"], false]
    - ["as2041006", "asyncio.Future.__dict__.__contains__", ["__ilshift__"], false]
    - ["as2041007", "asyncio.Event.__dict__.__contains__", ["__lshift__"], false]
    - ["as2041008", "asyncio.Event.__dict__.__contains__", ["__rlshift__"], false]
    - ["as2041009", "asyncio.Event.__dict__.__contains__", ["__ilshift__"], false]
    - ["as2041010", "asyncio.Lock.__dict__.__contains__", ["__lshift__"], false]
    - ["as2041011", "asyncio.Lock.__dict__.__contains__", ["__rlshift__"], false]
    - ["as2041012", "asyncio.Lock.__dict__.__contains__", ["__ilshift__"], false]
    - ["as2041013", "asyncio.Queue.__dict__.__contains__", ["__lshift__"], false]
    - ["as2041014", "asyncio.Queue.__dict__.__contains__", ["__rlshift__"], false]
    - ["as2041015", "asyncio.Queue.__dict__.__contains__", ["__ilshift__"], false]

