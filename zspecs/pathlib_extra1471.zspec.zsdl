spec: pathlib_extra1471
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py, Lib/pathlib/_local.py"
  notes:
    - "Wave 545 (_extra1471): focuses on __len__ and __getitem__ method presence and type checks for pathlib module classes."
    - "pathlib.PurePath does NOT define __len__ or __getitem__ in its own __dict__; path parts are exposed as a tuple via .parts, not via direct indexing on the path object."
    - "pathlib.PurePosixPath does NOT define __len__ or __getitem__ in its own __dict__."
    - "pathlib.PureWindowsPath does NOT define __len__ or __getitem__ in its own __dict__."
    - "pathlib.Path does NOT define __len__ or __getitem__ in its own __dict__."
    - "Path indexing is NOT supported directly on path objects; use p.parts[i] where parts returns a tuple."
    - "None of the pathlib path classes define __len__ or __getitem__ in their own __dict__; absence is expected for all classes."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table pathlib_extra1471.purepath_len_not_in_dict:
  description: "pathlib pure path classes __dict__ membership for __len__ — PurePath, PurePosixPath, and PureWindowsPath do not define __len__ in their own __dict__; pure path objects are not sequences; path parts are accessible via the .parts property which returns a tuple; all return False; verified with Python 3.14.4"
  kind: python_call_eq
  category: len_dict_membership
  id_prefix: pl1471ld
  columns: [id, function, args, expected]
  rows:
    - [pl1471ld001, pathlib.PurePath.__dict__.__contains__,        ["__len__"], false]
    - [pl1471ld002, pathlib.PurePosixPath.__dict__.__contains__,   ["__len__"], false]
    - [pl1471ld003, pathlib.PureWindowsPath.__dict__.__contains__,  ["__len__"], false]
    - [pl1471ld004, pathlib.Path.__dict__.__contains__,            ["__len__"], false]
    - [pl1471ld005, pathlib.PurePath.__dict__.__contains__,        ["__len__"], false]
    - [pl1471ld006, pathlib.PurePosixPath.__dict__.__contains__,   ["__len__"], false]

table pathlib_extra1471.purepath_getitem_not_in_dict:
  description: "pathlib pure path classes __dict__ membership for __getitem__ — PurePath, PurePosixPath, PureWindowsPath, and Path do not define __getitem__ in their own __dict__; path objects do not support subscript indexing; use p.parts which returns a tuple supporting __getitem__; all return False; verified with Python 3.14.4"
  kind: python_call_eq
  category: getitem_dict_membership
  id_prefix: pl1471gd
  columns: [id, function, args, expected]
  rows:
    - [pl1471gd001, pathlib.PurePath.__dict__.__contains__,        ["__getitem__"], false]
    - [pl1471gd002, pathlib.PurePosixPath.__dict__.__contains__,   ["__getitem__"], false]
    - [pl1471gd003, pathlib.PureWindowsPath.__dict__.__contains__,  ["__getitem__"], false]
    - [pl1471gd004, pathlib.Path.__dict__.__contains__,            ["__getitem__"], false]
    - [pl1471gd005, pathlib.PurePath.__dict__.__contains__,        ["__getitem__"], false]
    - [pl1471gd006, pathlib.PurePosixPath.__dict__.__contains__,   ["__getitem__"], false]

table pathlib_extra1471.path_len_not_in_dict:
  description: "pathlib.Path __dict__ membership for __len__ and __getitem__ — Path does not define __len__ or __getitem__ in its own __dict__; Path is a concrete subclass of PurePath and inherits no sequence protocol; both return False; verified with Python 3.14.4"
  kind: python_call_eq
  category: len_getitem_dict_membership
  id_prefix: pl1471pd
  columns: [id, function, args, expected]
  rows:
    - [pl1471pd001, pathlib.Path.__dict__.__contains__, ["__len__"],     false]
    - [pl1471pd002, pathlib.Path.__dict__.__contains__, ["__getitem__"], false]
    - [pl1471pd003, pathlib.Path.__dict__.__contains__, ["__len__"],     false]
    - [pl1471pd004, pathlib.Path.__dict__.__contains__, ["__getitem__"], false]
    - [pl1471pd005, pathlib.PureWindowsPath.__dict__.__contains__, ["__len__"],     false]
    - [pl1471pd006, pathlib.PureWindowsPath.__dict__.__contains__, ["__getitem__"], false]
