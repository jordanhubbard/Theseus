spec: re_extra40
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra39.zspec.zsdl — covers compile(IGNORECASE|MULTILINE).flags==42; error.__static_attributes__.__len__()==5/__getitem__(0)=='colno'; match three-group .groups().__len__()==3/group(0).__len__()==10; fullmatch date group().__len__()==10."
    - "re_extra38.zspec.zsdl — covers compile(IGNORECASE).flags==34/compile(MULTILINE).flags==40/compile(DOTALL).flags==48; split with capturing group (len 5); findall two groups (list of tuples, len 2); search lastgroup; escape dot+star."
    - "re_extra37.zspec.zsdl — covers Pattern/Match member_descriptor attribute __qualname__.__len__() for pattern/flags/groups/groupindex and string/re/pos/endpos/lastindex/lastgroup."
    - "re_extra34.zspec.zsdl — covers module-level function __qualname__.__len__() for compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge."
    - "re_extra31.zspec.zsdl — covers split/findall/finditer/purge/escape __module__.__len__()==2."
    - "re_extra30.zspec.zsdl — covers compile/match/search/fullmatch/sub __module__.__len__()==2; Pattern/Match __module__.__len__()==2."
  notes:
    - "This spec extends re_extra39.zspec.zsdl."
    - "Prior specs collectively covered: all Pattern/Match/__name__/__module__/__qualname__ and their lengths; all public function __name__/__module__/__qualname__/__qualname__.__len__(); error/__name__/__module__/__qualname__/__bases__; RegexFlag attributes; IGNORECASE/MULTILINE/DOTALL/VERBOSE values; Pattern/Match method __qualname__.__len__() for all main methods; module-level function __qualname__.__len__() and __module__.__len__(); Pattern/Match descriptor __qualname__.__len__(); compiled .flags with single and paired flags; split/findall/finditer behavioral tests; search lastgroup; escape; error.__static_attributes__; match three-group groups length."
    - "This spec covers: re.__name__.__len__()==2 (NOVEL — prior specs check function/class __name__ lengths but NOT the module __name__ attribute length); re.__package__.__len__()==2 (NOVEL — re.__package__=='re', both __name__ and __package__ are 'r'+'e'=2; novel module-level check); re.__file__.__class__.__name__.__len__()==3 (NOVEL — 'str', module file path type name length); re.subn behavioral: subn(r'\\d+', '#', 'a1b22c333') yields 'a#b#c#' (len 6) with count 3 (NOVEL — re_extra38/39 cover findall/split/search/escape behavioral tests but NOT subn; no prior re spec checks subn return value); compiled Pattern.findall behavioral: compile(r'\\d+').findall('a1b22c333').__len__()==3 and last match len 3 (NOVEL — prior findall tests use module-level re.findall; no prior spec checks compiled Pattern.findall behavioral results); compiled Pattern.search behavioral: compile(r'\\d+').search('abc123def456') group() '123' len 3, start 3, end 6 (NOVEL — prior specs test module-level search but NOT compiled Pattern.search behavioral results); re.sub with backreference: sub(r'(\\w+)', r'[\\1]', 'hello world') == '[hello] [world]' len 15 (NOVEL — no prior re spec uses a backreference replacement string)."
    - "re.__name__ == 're' — len 2. Prior re specs check function/class __name__ lengths (re_extra30/31/34) but NOT the module's own __name__ attribute. Novel module-level invariant. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.__package__ == 're' — len 2. re is itself a package (Lib/re/__init__.py). Both __name__ and __package__ equal 're'. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.__file__.__class__.__name__ == 'str' — len 3. The module __file__ is a .py path string. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.subn(r'\\d+', '#', 'a1b22c333') == ('a#b#c#', 3) — three digit runs replaced by '#'; result[0] len 6, result[1]==3. No prior re spec checks subn behavioral return value (subn.__name__/__module__/__qualname__ covered in prior specs, not the return value). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.compile(r'\\d+').findall('a1b22c333').__len__() == 3 — compiled Pattern.findall finds three digit runs ['1','22','333']; prior findall tests (extra17/38) use module-level re.findall not compiled Pattern.findall; novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.compile(r'\\d+').findall('a1b22c333')[-1].__len__() == 3 — last match '333' has 3 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.compile(r'\\d+').search('abc123def456').group().__len__() == 3 — compiled Pattern.search on 'abc123def456' finds '123' first (3 chars). No prior re spec tests compiled Pattern.search behavioral results. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.compile(r'\\d+').search('abc123def456').start() == 3 — the first digit run starts at index 3. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.compile(r'\\d+').search('abc123def456').end() == 6 — the first digit run ends at index 6 (exclusive). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.sub(r'(\\w+)', r'[\\1]', 'hello world').__len__() == 15 — backreference in repl wraps each word in brackets: 'hello world' -> '[hello] [world]' (15 chars). No prior re spec uses a backreference replacement string. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level attribute lengths
#
# Prior re specs check lengths of function/class __name__/__module__ attributes
# (re_extra30 covers compile/match/search/fullmatch/sub __module__.__len__()==2;
# re_extra31 covers split/findall/finditer/purge/escape __module__.__len__()==2;
# re_extra34 covers function __qualname__.__len__()). However, no prior re spec
# checks the module's own top-level attributes: __name__, __package__, or
# __file__.__class__.__name__. All three are novel module-level invariants.
#
#   re.__name__                    == 're'   -> len 2
#   re.__package__                 == 're'   -> len 2
#   re.__file__.__class__.__name__ == 'str'  -> len 3
#
# Note: re.__package__ == 're' because re is a package (Lib/re/__init__.py).
# Both __name__ and __package__ equal 're'. This differs from io.__package__==''
# (io is not a package).
# All verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra40.module_level_attr_lens:
  description: "re module-level attribute lengths — __name__(2)/__package__(2)/__file__.__class__.__name__(3); all novel; prior specs check function/class attribute lengths but not module-level __name__/__package__"
  kind: python_call_eq
  category: module_identity
  id_prefix: remal40

  columns: [id, function, args, expected]
  rows:
    - [module_name,     __name__.__len__,                    [], 2]
    - [module_package,  __package__.__len__,                 [], 2]
    - [file_class_name, __file__.__class__.__name__.__len__, [], 3]

# ---------------------------------------------------------------------------
# re.subn behavioral: substitution result and count
#
# re.subn(pattern, repl, string) returns a 2-tuple (new_string, count) where
# count is the number of substitutions made. Prior re specs cover subn's
# __name__/__module__/__qualname__ attributes (re_extra4/28/34) but no prior
# re spec tests the behavioral return value of subn().
#
# Applied to 'a1b22c333' replacing r'\d+' with '#':
#   '1', '22', '333' are each replaced once -> 3 substitutions
#   result[0] == 'a#b#c#'  -> len 6
#   result[1] == 3          -> three substitutions
#
# Both novel behavioral checks. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra40.subn_result_len:
  description: "re.subn(r'\\d+', '#', 'a1b22c333')[0].__len__() == 6 — 'a#b#c#' has 6 characters; three digit runs replaced; no prior re spec checks subn() return value; novel"
  category: subn
  kind: python_call_eq
  function: "subn.__call__(r'\\d+', '#', 'a1b22c333').__getitem__(0).__len__"
  args: []
  expected: 6

invariant re_extra40.subn_count:
  description: "re.subn(r'\\d+', '#', 'a1b22c333')[1] == 3 — three substitutions made (one per digit run); novel behavioral check of subn() count element"
  category: subn
  kind: python_call_eq
  function: "subn.__call__(r'\\d+', '#', 'a1b22c333').__getitem__(1).__eq__"
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# re.compile(r'\d+').findall behavioral: result count and last element
#
# re_extra38 covers findall with two capture groups (returning tuples) but does
# NOT cover compiled Pattern.findall() behavioral results. Applying the compiled
# pattern r'\d+' to 'a1b22c333' finds three digit runs: '1', '22', '333'.
#
#   compile(r'\d+').findall('a1b22c333').__len__()         == 3
#   compile(r'\d+').findall('a1b22c333')[-1].__len__()     == 3  ('333')
#
# No prior re spec checks compiled Pattern.findall() results (prior findall
# tests in extra17/38 use the module-level re.findall function, not a compiled
# Pattern's findall method). Both novel. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra40.compiled_findall_count:
  description: "re.compile(r'\\d+').findall('a1b22c333').__len__() == 3 — three digit runs found; no prior re spec checks compiled Pattern.findall() behavioral results; novel"
  category: findall
  kind: python_call_eq
  function: "compile.__call__(r'\\d+').findall.__call__('a1b22c333').__len__"
  args: []
  expected: 3

invariant re_extra40.compiled_findall_last_len:
  description: "re.compile(r'\\d+').findall('a1b22c333')[-1].__len__() == 3 — last match '333' has 3 characters; novel (prior findall tests use module-level re.findall, not compiled Pattern.findall)"
  category: findall
  kind: python_call_eq
  function: "compile.__call__(r'\\d+').findall.__call__('a1b22c333').__getitem__(-1).__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# re.compile(r'\d+').search('abc123def456') behavioral checks
#
# Prior re specs test module-level re.search() but not a compiled Pattern's
# .search() method returning a match. Applied to 'abc123def456' searching for
# r'\d+', the first digit run '123' is found at positions [3, 6).
#
#   group()  == '123'  -> len 3
#   start()  == 3      (first digit at index 3)
#   end()    == 6      (exclusive end of first digit run)
#
# No prior re spec tests compiled Pattern.search() behavioral results. Novel.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra40.compiled_search_group_len:
  description: "re.compile(r'\\d+').search('abc123def456').group().__len__() == 3 — first digit run '123' has 3 chars; novel: prior specs test module-level search but not compiled Pattern.search behavioral results"
  category: search
  kind: python_call_eq
  function: "compile.__call__(r'\\d+').search.__call__('abc123def456').group.__call__().__len__"
  args: []
  expected: 3

invariant re_extra40.compiled_search_start:
  description: "re.compile(r'\\d+').search('abc123def456').start() == 3 — first digit run starts at index 3; novel behavioral check of compiled Pattern.search"
  category: search
  kind: python_call_eq
  function: "compile.__call__(r'\\d+').search.__call__('abc123def456').start.__call__"
  args: []
  expected: 3

invariant re_extra40.compiled_search_end:
  description: "re.compile(r'\\d+').search('abc123def456').end() == 6 — first digit run ends at index 6 (exclusive); novel"
  category: search
  kind: python_call_eq
  function: "compile.__call__(r'\\d+').search.__call__('abc123def456').end.__call__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# re.sub with backreference replacement string
#
# re.sub(pattern, repl, string) accepts a replacement string with backreferences.
# r'\1' refers to the first capture group. No prior re spec uses a backreference
# replacement string in sub (prior specs use literal replacements or test
# module-level sub.__qualname__/__module__).
#
# Pattern r'(\w+)' applied to 'hello world' with repl r'[\1]':
#   'hello' -> '[hello]'
#   'world' -> '[world]'
# Result: '[hello] [world]'  -> len 15
#
# Novel. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra40.sub_backreference_len:
  description: "re.sub(r'(\\w+)', r'[\\1]', 'hello world').__len__() == 15 — backreference repl wraps each word in brackets: '[hello] [world]' has 15 chars; no prior re spec uses backreference replacement; novel"
  category: sub
  kind: python_call_eq
  function: "sub.__call__(r'(\\w+)', r'[\\1]', 'hello world').__len__"
  args: []
  expected: 15
