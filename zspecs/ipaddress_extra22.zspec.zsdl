spec: ipaddress_extra22
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress_extra5.zspec.zsdl — covers __qualname__.__eq__ for all address/network/interface classes and factory functions."
    - "ipaddress_extra16.zspec.zsdl — covers __qualname__.__len__() for IPv4Address/IPv6Address/IPv4Network/IPv6Network (all 11)."
    - "ipaddress_extra17.zspec.zsdl — covers __name__.__eq__ for utility functions; module __name__ and __package__."
    - "ipaddress_extra21.zspec.zsdl — covers IPv4Address/IPv6Address/IPv4Network/IPv6Network __module__; ip_address/ip_network/ip_interface __qualname__ and __module__; IPv4Interface/IPv6Interface __qualname__ and __qualname__ lengths."
  notes:
    - "This spec extends the ipaddress chain through ipaddress_extra21; it does NOT duplicate invariants in any prior spec."
    - "Focus: __name__.__eq__ for address/network/interface classes (IPv4Address/IPv6Address/IPv4Network/IPv6Network/IPv4Interface/IPv6Interface) — extra5 covers __qualname__ and extra16 covers __qualname__.__len__(), but no prior spec checks __name__ on any address, network, or interface class; __module__ for IPv4Interface/IPv6Interface — extra21 covers IPv4Address/IPv6Address/IPv4Network/IPv6Network __module__ in a table but does NOT include IPv4Interface/IPv6Interface; AddressValueError/__bases__[0].__name__ and NetmaskValueError/__bases__[0].__name__ — extra20 checks their __qualname__ as standalone invariants but no prior spec checks their __bases__[0].__name__; __name__ string lengths for address/network classes (all 11) and interface classes (both 13)."
    - "ipaddress.IPv4Address.__name__ == 'IPv4Address' — extra5 checks __qualname__; extra16 checks __qualname__.__len__; no prior ipaddress spec checks __name__.__eq__ on any address or network class."
    - "ipaddress.IPv6Address.__name__ == 'IPv6Address' — same rationale."
    - "ipaddress.IPv4Network.__name__ == 'IPv4Network' — same rationale."
    - "ipaddress.IPv6Network.__name__ == 'IPv6Network' — same rationale."
    - "ipaddress.IPv4Interface.__name__ == 'IPv4Interface' — extra21 checks __qualname__ as standalone; no prior spec checks __name__ on IPv4Interface."
    - "ipaddress.IPv6Interface.__name__ == 'IPv6Interface' — same rationale."
    - "ipaddress.IPv4Interface.__module__ == 'ipaddress' — extra21 checks __module__ for IPv4Address/IPv6Address/IPv4Network/IPv6Network in a table, but NOT for IPv4Interface or IPv6Interface."
    - "ipaddress.IPv6Interface.__module__ == 'ipaddress' — same gap as IPv4Interface.__module__."
    - "ipaddress.AddressValueError.__bases__[0].__name__ == 'ValueError' — extra20 checks AddressValueError.__qualname__ as standalone; no prior spec checks AddressValueError.__bases__[0].__name__. AddressValueError inherits directly from ValueError."
    - "ipaddress.NetmaskValueError.__bases__[0].__name__ == 'ValueError' — same rationale; NetmaskValueError also inherits from ValueError."
    - "Address/network class __name__ lengths: IPv4Address/IPv6Address/IPv4Network/IPv6Network are all 11 chars; IPv4Interface/IPv6Interface are both 13 chars. No prior ipaddress spec checks __name__.__len__() on any address, network, or interface class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IPv4Address, IPv6Address, IPv4Network, IPv6Network __name__
#
# ipaddress_extra5 checks __qualname__.__eq__ for all four classes in a table.
# ipaddress_extra16 checks __qualname__.__len__() for all four. No prior
# ipaddress spec checks __name__.__eq__ on any of these classes. For top-level
# classes __name__ == __qualname__, but the attribute path is distinct.
# ---------------------------------------------------------------------------

table ipaddress_extra22.address_network_names:
  description: "__name__.__eq__ for address and network classes — distinct from __qualname__ in extra5; no prior spec checks __name__ on these classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: anname22

  columns: [id, function, args, expected]
  rows:
    - [IPv4Address, IPv4Address.__name__.__eq__, ["IPv4Address"], true]
    - [IPv6Address, IPv6Address.__name__.__eq__, ["IPv6Address"], true]
    - [IPv4Network, IPv4Network.__name__.__eq__, ["IPv4Network"], true]
    - [IPv6Network, IPv6Network.__name__.__eq__, ["IPv6Network"], true]

# ---------------------------------------------------------------------------
# IPv4Interface and IPv6Interface __name__ and __module__
#
# ipaddress_extra21 checks IPv4Interface/IPv6Interface __qualname__ as
# standalone invariants and their __qualname__ lengths. No prior spec checks
# __name__ on either interface class. Additionally, extra21 checks __module__
# for IPv4Address/IPv6Address/IPv4Network/IPv6Network but NOT for IPv4Interface
# or IPv6Interface — this spec fills that gap.
# ---------------------------------------------------------------------------

table ipaddress_extra22.interface_names:
  description: "IPv4Interface/IPv6Interface __name__ — distinct from __qualname__ in extra21; no prior spec checks interface __name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: ifname22

  columns: [id, function, args, expected]
  rows:
    - [IPv4Interface, IPv4Interface.__name__.__eq__, ["IPv4Interface"], true]
    - [IPv6Interface, IPv6Interface.__name__.__eq__, ["IPv6Interface"], true]

table ipaddress_extra22.interface_modules:
  description: "IPv4Interface/IPv6Interface __module__ == 'ipaddress' — extra21 covers address/network classes but not interface classes"
  kind: python_call_eq
  category: class_modules
  id_prefix: ifmod22

  columns: [id, function, args, expected]
  rows:
    - [IPv4Interface, IPv4Interface.__module__.__eq__, ["ipaddress"], true]
    - [IPv6Interface, IPv6Interface.__module__.__eq__, ["ipaddress"], true]

# ---------------------------------------------------------------------------
# AddressValueError and NetmaskValueError __bases__[0].__name__
#
# ipaddress_extra5 covers AddressValueError/NetmaskValueError __qualname__ in
# a table. ipaddress_extra20 checks them as standalone invariants. No prior
# ipaddress spec checks __bases__[0].__name__ on either exception class. Both
# inherit directly from ValueError.
# ---------------------------------------------------------------------------

invariant ipaddress_extra22.AddressValueError.bases_name:
  description: "ipaddress.AddressValueError.__bases__[0].__name__ == 'ValueError' — no prior spec checks AddressValueError.__bases__[0].__name__"
  category: class_identity
  kind: python_call_eq
  function: "AddressValueError.__bases__[0].__name__.__eq__"
  args: ["ValueError"]
  expected: true

invariant ipaddress_extra22.NetmaskValueError.bases_name:
  description: "ipaddress.NetmaskValueError.__bases__[0].__name__ == 'ValueError' — no prior spec checks NetmaskValueError.__bases__[0].__name__"
  category: class_identity
  kind: python_call_eq
  function: "NetmaskValueError.__bases__[0].__name__.__eq__"
  args: ["ValueError"]
  expected: true

# ---------------------------------------------------------------------------
# Address and network class __name__ string lengths
#
# ipaddress_extra16 checks __qualname__.__len__() for IPv4Address/IPv6Address/
# IPv4Network/IPv6Network (all == 11). ipaddress_extra21 checks
# IPv4Interface/IPv6Interface __qualname__ lengths (both == 13). No prior
# ipaddress spec checks __name__.__len__() on any address, network, or
# interface class. For top-level classes __name__ == __qualname__ so the
# lengths are the same, but the attribute path is distinct.
# ---------------------------------------------------------------------------

table ipaddress_extra22.address_network_name_lengths:
  description: "address/network/interface class __name__ string lengths — distinct from __qualname__.__len__() in extra16/extra21"
  kind: python_call_eq
  category: class_identity
  id_prefix: annlen22

  columns: [id, function, args, expected]
  rows:
    - [IPv4Address,   IPv4Address.__name__.__len__,   [], 11]
    - [IPv6Address,   IPv6Address.__name__.__len__,   [], 11]
    - [IPv4Network,   IPv4Network.__name__.__len__,   [], 11]
    - [IPv6Network,   IPv6Network.__name__.__len__,   [], 11]
    - [IPv4Interface, IPv4Interface.__name__.__len__, [], 13]
    - [IPv6Interface, IPv6Interface.__name__.__len__, [], 13]
