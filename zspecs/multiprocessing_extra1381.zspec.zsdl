spec: multiprocessing_extra1381
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing: Process-based parallelism"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 539 (_extra1381): focuses on __abstractmethods__ frozenset checks and __isabstractmethod__ boolean checks."
    - "In Python 3.14, multiprocessing classes do NOT use ABCMeta; none have __abstractmethods__ in their __dict__."
    - "multiprocessing.Process, AuthenticationError, ProcessError, BufferTooShort, TimeoutError all lack __abstractmethods__."
    - "The metaclass of all inspected multiprocessing classes is the built-in 'type', not 'ABCMeta'."
    - "multiprocessing.Process uses a plain class hierarchy rooted at object, not an abstract base class hierarchy."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra1381.classes_abstractmethods_absent:
  description: "multiprocessing classes do not have __abstractmethods__ in their __dict__"
  kind: python_call_eq
  category: abstractmethods_dict_check
  id_prefix: mp1381aa
  columns: [id, function, args, expected]
  rows:
    - [mp1381aa001, multiprocessing.Process.__dict__.__contains__,            ["__abstractmethods__"], false]
    - [mp1381aa002, multiprocessing.AuthenticationError.__dict__.__contains__, ["__abstractmethods__"], false]
    - [mp1381aa003, multiprocessing.ProcessError.__dict__.__contains__,       ["__abstractmethods__"], false]
    - [mp1381aa004, multiprocessing.BufferTooShort.__dict__.__contains__,     ["__abstractmethods__"], false]
    - [mp1381aa005, multiprocessing.TimeoutError.__dict__.__contains__,       ["__abstractmethods__"], false]
    - [mp1381aa006, multiprocessing.Process.__dict__.__contains__,            ["__isabstractmethod__"], false]

table multiprocessing_extra1381.classes_metaclass_is_type_not_abcmeta:
  description: "multiprocessing classes have plain 'type' as metaclass, confirming absence of ABCMeta"
  kind: python_call_eq
  category: metaclass_check
  id_prefix: mp1381mc
  columns: [id, function, args, expected]
  rows:
    - [mp1381mc001, multiprocessing.Process.__class__.__name__.__eq__,            ["type"], true]
    - [mp1381mc002, multiprocessing.AuthenticationError.__class__.__name__.__eq__, ["type"], true]
    - [mp1381mc003, multiprocessing.ProcessError.__class__.__name__.__eq__,       ["type"], true]
    - [mp1381mc004, multiprocessing.BufferTooShort.__class__.__name__.__eq__,     ["type"], true]
    - [mp1381mc005, multiprocessing.TimeoutError.__class__.__name__.__eq__,       ["type"], true]
    - [mp1381mc006, multiprocessing.AuthenticationError.__class__.__name__.__eq__, ["type"], true]

table multiprocessing_extra1381.process_class_identity_names:
  description: "multiprocessing class identity: __name__ checks confirm class names without ABCMeta involvement"
  kind: python_call_eq
  category: class_identity
  id_prefix: mp1381ci
  columns: [id, function, args, expected]
  rows:
    - [mp1381ci001, multiprocessing.Process.__name__.__eq__,            ["Process"],            true]
    - [mp1381ci002, multiprocessing.AuthenticationError.__name__.__eq__, ["AuthenticationError"], true]
    - [mp1381ci003, multiprocessing.ProcessError.__name__.__eq__,       ["ProcessError"],       true]
    - [mp1381ci004, multiprocessing.BufferTooShort.__name__.__eq__,     ["BufferTooShort"],     true]
    - [mp1381ci005, multiprocessing.TimeoutError.__name__.__eq__,       ["TimeoutError"],       true]
    - [mp1381ci006, multiprocessing.Process.__bases__.__len__,          [],                     1]
