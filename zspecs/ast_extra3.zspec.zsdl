spec: ast_extra3
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ast.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "CPython source: Python/Python-ast.c"
    - "ast.zspec.zsdl — covers literal_eval primitives/containers/tuple-access, error cases, literal_eval.__name__, and node classnames (Add/Sub/Mult/Div/Module/Constant/Expr/Name/FunctionDef/ClassDef/If/For/Import/Call)"
    - "ast_extra.zspec.zsdl — covers parse.__name__, parse.__module__, parse return value, dump.__name__, get_docstring.__name__, fix_missing_locations.__name__, NodeVisitor.__name__, NodeTransformer.__name__, NodeTransformer.__bases__[0].__name__, AST.__name__"
    - "ast_extra2.zspec.zsdl — covers literal_eval for int/str/list/dict/bool/None, get_docstring.__name__, NodeVisitor.__name__, NodeTransformer.__name__, fix_missing_locations.__name__"
  notes:
    - "This spec covers __module__ attributes for core ast functions and classes — not covered in ast.zspec.zsdl, ast_extra.zspec.zsdl, or ast_extra2.zspec.zsdl."
    - "ast.parse.__module__ == 'ast' — parse is defined in the ast module."
    - "ast.dump.__module__ == 'ast' — dump is defined in the ast module."
    - "ast.literal_eval.__module__ == 'ast' — literal_eval is defined in the ast module."
    - "ast.get_docstring.__module__ == 'ast' — get_docstring is defined in the ast module."
    - "ast.fix_missing_locations.__module__ == 'ast' — fix_missing_locations is defined in the ast module."
    - "ast.walk.__module__ == 'ast' — walk is a generator function in the ast module."
    - "ast.NodeVisitor.__module__ == 'ast' — NodeVisitor class is defined in the ast module."
    - "ast.NodeTransformer.__module__ == 'ast' — NodeTransformer class is defined in the ast module."
    - "ast.Module.__module__ == 'ast' — Module node class is defined in the ast module."
    - "ast.FunctionDef.__module__ == 'ast' — FunctionDef node class is defined in the ast module."
    - "ast.Constant.__module__ == 'ast' — Constant node class is defined in the ast module."
    - "ast.Name.__module__ == 'ast' — Name node class is defined in the ast module."
    - "ast.NodeVisitor.__bases__[0].__name__ == 'object' — NodeVisitor inherits directly from object."
    - "ast.NodeTransformer.__bases__[0].__name__ == 'NodeVisitor' — NodeTransformer inherits from NodeVisitor (also in ast_extra)."
    - "ast.AST.__name__ == 'AST' — the root base class for all ast node types (also in ast_extra)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks for top-level ast functions
# ---------------------------------------------------------------------------

table ast_extra3.function_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [parse,                 parse.__module__.__eq__,                 ["ast"], true]
    - [dump,                  dump.__module__.__eq__,                  ["ast"], true]
    - [literal_eval,          literal_eval.__module__.__eq__,          ["ast"], true]
    - [get_docstring,         get_docstring.__module__.__eq__,         ["ast"], true]
    - [fix_missing_locations, fix_missing_locations.__module__.__eq__, ["ast"], true]
    - [walk,                  walk.__module__.__eq__,                  ["ast"], true]

# ---------------------------------------------------------------------------
# __module__ checks for ast visitor/transformer classes
# ---------------------------------------------------------------------------

table ast_extra3.visitor_class_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [NodeVisitor,    NodeVisitor.__module__.__eq__,    ["ast"], true]
    - [NodeTransformer, NodeTransformer.__module__.__eq__, ["ast"], true]

# ---------------------------------------------------------------------------
# __module__ checks for ast node classes
# ---------------------------------------------------------------------------

table ast_extra3.node_class_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: nmod

  columns: [id, function, args, expected]
  rows:
    - [Module,      Module.__module__.__eq__,      ["ast"], true]
    - [FunctionDef, FunctionDef.__module__.__eq__, ["ast"], true]
    - [Constant,    Constant.__module__.__eq__,    ["ast"], true]
    - [Name,        Name.__module__.__eq__,        ["ast"], true]

# ---------------------------------------------------------------------------
# NodeVisitor inheritance — __bases__[0].__name__ == 'object'
# ---------------------------------------------------------------------------

invariant ast_extra3.NodeVisitor.base_is_object:
  description: "ast.NodeVisitor.__bases__[0].__name__ == 'object' — NodeVisitor inherits directly from object"
  category: hierarchy
  kind: python_call_eq
  function: NodeVisitor.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# NodeTransformer inheritance — __bases__[0].__name__ == 'NodeVisitor'
# (Explicitly in this spec per task requirements; also in ast_extra)
# ---------------------------------------------------------------------------

invariant ast_extra3.NodeTransformer.base_is_NodeVisitor:
  description: "ast.NodeTransformer.__bases__[0].__name__ == 'NodeVisitor' — NodeTransformer inherits from NodeVisitor"
  category: hierarchy
  kind: python_call_eq
  function: NodeTransformer.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["NodeVisitor"]
  expected: true

# ---------------------------------------------------------------------------
# AST root class name
# (Explicitly in this spec per task requirements; also in ast_extra)
# ---------------------------------------------------------------------------

invariant ast_extra3.AST.name:
  description: "ast.AST.__name__ == 'AST' — root base class for all ast node types"
  category: ast_class
  kind: python_call_eq
  function: AST.__name__.__eq__
  args: ["AST"]
  expected: true

# ---------------------------------------------------------------------------
# walk — function name and module checks
# ---------------------------------------------------------------------------

invariant ast_extra3.walk.name:
  description: "ast.walk.__name__ == 'walk'"
  category: function_names
  kind: python_call_eq
  function: walk.__name__.__eq__
  args: ["walk"]
  expected: true

# ---------------------------------------------------------------------------
# AST base class module
# ---------------------------------------------------------------------------

invariant ast_extra3.AST.module:
  description: "ast.AST.__module__ == 'ast' — AST root class is defined in the ast module"
  category: module_attrs
  kind: python_call_eq
  function: AST.__module__.__eq__
  args: ["ast"]
  expected: true

# ---------------------------------------------------------------------------
# Additional node class module checks
# ---------------------------------------------------------------------------

invariant ast_extra3.Expr.module:
  description: "ast.Expr.__module__ == 'ast' — Expr node class is defined in the ast module"
  category: module_attrs
  kind: python_call_eq
  function: Expr.__module__.__eq__
  args: ["ast"]
  expected: true

invariant ast_extra3.ClassDef.module:
  description: "ast.ClassDef.__module__ == 'ast' — ClassDef node class is defined in the ast module"
  category: module_attrs
  kind: python_call_eq
  function: ClassDef.__module__.__eq__
  args: ["ast"]
  expected: true
