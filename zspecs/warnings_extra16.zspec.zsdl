spec: warnings_extra16
version: ">=3.9"
backend: python_module(warnings)

docs: https://docs.python.org/3/library/warnings.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/warnings.html — Python warnings module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/warnings.py"
    - "CPython source: Modules/_warnings.c"
  notes:
    - "This spec extends warnings.zspec.zsdl through warnings_extra15.zspec.zsdl."
    - "warnings_extra15 covers: catch_warnings/__name__/__module__/__qualname__; warn_explicit/__name__/__module__/__class__.__name__; resetwarnings and showwarning __name__/__module__."
    - "warnings_extra12 covers: WarningMessage/__class__.__name__ == 'type'; catch_warnings/__class__.__name__ == 'type'; deprecated all identity attrs."
    - "warnings_extra11 covers: WarningMessage/__name__/__module__/__bases__[0].__name__; warn/__qualname__; defaultaction value."
    - "NOT yet covered in any prior spec: WarningMessage.__mro__.__len__() == 2 as a standalone invariant."
    - "NOT yet covered in any prior spec: catch_warnings.__mro__.__len__() == 2 as a standalone invariant."
    - "NOT yet covered in any prior spec: catch_warnings.__bases__[0].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: WarningMessage.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: catch_warnings.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "NOT yet covered in any prior spec: deprecated.__mro__[-1].__name__ == 'object' as a standalone invariant."
    - "WarningMessage and catch_warnings both inherit directly from object; their MRO is length 2."
    - "catch_warnings.__bases__[0].__name__ == 'object' — catch_warnings inherits only from object."
    - "deprecated.__mro__[-1].__name__ == 'object' — deprecated MRO also terminates at object."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# WarningMessage — MRO length and terminal element
#
# warnings_extra11 records __name__/__module__/__bases__[0].__name__ for
# WarningMessage. warnings_extra12 records __class__.__name__ == 'type'.
# No prior spec records WarningMessage.__mro__.__len__() or
# WarningMessage.__mro__[-1].__name__ as standalone invariants.
# WarningMessage inherits only from object, giving MRO length 2.
# ---------------------------------------------------------------------------

invariant warnings_extra16.WarningMessage.mro_len:
  description: "warnings.WarningMessage.__mro__.__len__() == 2 — inherits only from object"
  category: class_hierarchy
  kind: python_call_eq
  function: WarningMessage.__mro__.__len__
  args: []
  expected: 2

invariant warnings_extra16.WarningMessage.mro_last:
  description: "warnings.WarningMessage.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "WarningMessage.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# catch_warnings — MRO length, terminal element, and base class name
#
# warnings_extra15 records catch_warnings __name__/__module__/__qualname__.
# warnings_extra12 records __class__.__name__ == 'type'.
# No prior spec records __mro__.__len__(), __mro__[-1].__name__, or
# __bases__[0].__name__ for catch_warnings as standalone invariants.
# catch_warnings inherits only from object, so MRO length is 2.
# ---------------------------------------------------------------------------

invariant warnings_extra16.catch_warnings.mro_len:
  description: "warnings.catch_warnings.__mro__.__len__() == 2 — inherits only from object"
  category: class_hierarchy
  kind: python_call_eq
  function: catch_warnings.__mro__.__len__
  args: []
  expected: 2

invariant warnings_extra16.catch_warnings.mro_last:
  description: "warnings.catch_warnings.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "catch_warnings.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant warnings_extra16.catch_warnings.base_class:
  description: "warnings.catch_warnings.__bases__[0].__name__ == 'object' — direct base is object"
  category: class_hierarchy
  kind: python_call_eq
  function: "catch_warnings.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# deprecated — MRO terminal element
#
# warnings_extra12 records deprecated.__mro__.__len__() == 2 and covers
# __name__/__qualname__/__module__/__class__.__name__/__bases__[0].__name__.
# No prior spec records deprecated.__mro__[-1].__name__ as a standalone
# invariant. Since deprecated inherits directly from object, __mro__[-1]
# is always object.
# ---------------------------------------------------------------------------

invariant warnings_extra16.deprecated.mro_last:
  description: "warnings.deprecated.__mro__[-1].__name__ == 'object' — MRO terminal element"
  category: class_hierarchy
  kind: python_call_eq
  function: "deprecated.__mro__[-1].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# MRO length table — WarningMessage, catch_warnings, deprecated
#
# Consolidates the MRO length checks for all three classes defined in the
# warnings module. All three inherit directly from object, giving MRO
# length 2 in every case.
# ---------------------------------------------------------------------------

table warnings_extra16.class_mro_lengths:
  description: "__mro__.__len__() == 2 for WarningMessage, catch_warnings, and deprecated"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, expected]
  rows:
    - [WarningMessage,   WarningMessage.__mro__.__len__,   [], 2]
    - [catch_warnings,   catch_warnings.__mro__.__len__,   [], 2]
    - [deprecated,       deprecated.__mro__.__len__,       [], 2]
