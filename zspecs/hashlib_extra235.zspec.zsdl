spec: hashlib_extra235
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "type(hashlib.sha256()).update.__qualname__ == 'HASH.update' — HASH class method qualname uses 'HASH.' prefix."
    - "type(hashlib.sha256()).digest.__qualname__ == 'HASH.digest' — digest method qualname is 'HASH.digest'."
    - "type(hashlib.sha256()).hexdigest.__qualname__ == 'HASH.hexdigest' — hexdigest method qualname is 'HASH.hexdigest'."
    - "type(hashlib.sha256()).copy.__qualname__ == 'HASH.copy' — copy method qualname is 'HASH.copy'."
    - "hashlib.sha256(b'').name == 'sha256' — name attribute for sha256 hash objects is 'sha256' (6 characters)."
    - "hashlib.md5(b'').name == 'md5' — name attribute for md5 hash objects is 'md5' (3 characters)."
    - "hashlib.sha1(b'').name == 'sha1' — name attribute for sha1 hash objects is 'sha1' (4 characters)."
    - "hashlib.sha256(b'').name.__len__() == 6 — length of 'sha256' is 6."
    - "hashlib.md5(b'').name.__len__() == 3 — length of 'md5' is 3."
    - "hashlib.sha1(b'').name.__len__() == 4 — length of 'sha1' is 4."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib HASH object method qualname contracts
#
# type(hashlib.sha256()).update.__qualname__    == 'HASH.update'
# type(hashlib.sha256()).digest.__qualname__    == 'HASH.digest'
# type(hashlib.sha256()).hexdigest.__qualname__ == 'HASH.hexdigest'
# type(hashlib.sha256()).copy.__qualname__      == 'HASH.copy'
#
# The internal HASH class is returned by hashlib hash constructors. Its
# methods have __qualname__ prefixed with 'HASH.' — the internal C class
# name. update() feeds data into the hash; digest() returns raw bytes;
# hexdigest() returns a hex string; copy() returns a copy of the state.
# ---------------------------------------------------------------------------

table hashlib_extra235.hash_method_qualnames:
  description: "HASH.update qualname=='HASH.update'; HASH.digest qualname=='HASH.digest'; HASH.hexdigest qualname=='HASH.hexdigest'; HASH.copy qualname=='HASH.copy'; HASH object method qualname contracts; new to extra235"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib235

  columns: [id, function, args, expected, description]
  rows:
    - [hash_update_qualname_eq,
       "sha256().__class__.update.__qualname__.__eq__",
       ["HASH.update"],
       true,
       "type(hashlib.sha256()).update.__qualname__.__eq__('HASH.update') == True — update() feeds data into the running hash; __qualname__ is 'HASH.update' using the internal HASH class name; new anchor in extra235 namespace; verified Python 3.14.3"]
    - [hash_digest_qualname_eq,
       "sha256().__class__.digest.__qualname__.__eq__",
       ["HASH.digest"],
       true,
       "type(hashlib.sha256()).digest.__qualname__.__eq__('HASH.digest') == True — digest() returns the hash value as a bytes object; __qualname__ is 'HASH.digest'; new anchor in extra235 namespace; verified Python 3.14.3"]
    - [hash_hexdigest_qualname_eq,
       "sha256().__class__.hexdigest.__qualname__.__eq__",
       ["HASH.hexdigest"],
       true,
       "type(hashlib.sha256()).hexdigest.__qualname__.__eq__('HASH.hexdigest') == True — hexdigest() returns the hash as a hex string; __qualname__ is 'HASH.hexdigest'; new anchor in extra235 namespace; verified Python 3.14.3"]
    - [hash_copy_qualname_eq,
       "sha256().__class__.copy.__qualname__.__eq__",
       ["HASH.copy"],
       true,
       "type(hashlib.sha256()).copy.__qualname__.__eq__('HASH.copy') == True — copy() returns a copy of the hash object; __qualname__ is 'HASH.copy'; new anchor in extra235 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib hash object name attribute contracts
#
# hashlib.sha256(b'').name == 'sha256'
# hashlib.md5(b'').name    == 'md5'
# hashlib.sha1(b'').name   == 'sha1'
#
# Each hash object exposes a name attribute identifying the algorithm.
# sha256 has a 6-character name; sha1 has 4; md5 has 3.
# ---------------------------------------------------------------------------

table hashlib_extra235.hash_name_attr:
  description: "sha256(b'').name=='sha256'; md5(b'').name=='md5'; sha1(b'').name=='sha1'; hash object name attribute contracts; new to extra235"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib235a

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_name_eq,
       "sha256(b'').name.__eq__",
       ["sha256"],
       true,
       "hashlib.sha256(b'').name.__eq__('sha256') == True — the name attribute of a sha256 hash object is 'sha256' (6 characters); new anchor in extra235 namespace; verified Python 3.14.3"]
    - [md5_name_eq,
       "md5(b'').name.__eq__",
       ["md5"],
       true,
       "hashlib.md5(b'').name.__eq__('md5') == True — the name attribute of an md5 hash object is 'md5' (3 characters); new anchor in extra235 namespace; verified Python 3.14.3"]
    - [sha1_name_eq,
       "sha1(b'').name.__eq__",
       ["sha1"],
       true,
       "hashlib.sha1(b'').name.__eq__('sha1') == True — the name attribute of a sha1 hash object is 'sha1' (4 characters); new anchor in extra235 namespace; verified Python 3.14.3"]
    - [sha256_name_len_6,
       "sha256(b'').name.__len__",
       [],
       6,
       "hashlib.sha256(b'').name.__len__() == 6 — 'sha256' has 6 characters; portable length anchor; new anchor in extra235 namespace; verified Python 3.14.3"]
    - [md5_name_len_3,
       "md5(b'').name.__len__",
       [],
       3,
       "hashlib.md5(b'').name.__len__() == 3 — 'md5' has 3 characters; shortest of the three algorithm names; portable length anchor; new anchor in extra235 namespace; verified Python 3.14.3"]
    - [sha1_name_len_4,
       "sha1(b'').name.__len__",
       [],
       4,
       "hashlib.sha1(b'').name.__len__() == 4 — 'sha1' has 4 characters; 1 more than 'md5'; portable length anchor; new anchor in extra235 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra235.hash_update_qualname_eq:
  description: "type(hashlib.sha256()).update.__qualname__.__eq__('HASH.update') == True — update() is the primary method for feeding data to a hash object; it accepts bytes-like objects and updates the internal digest state; its __qualname__ is 'HASH.update', using the internal C class name 'HASH' as a prefix; the 'HASH.' prefix is 5 characters and 'update' is 6, making 'HASH.update' 11 characters total; the HASH class is the concrete type returned by hashlib constructors like sha256(), md5(), and sha1(); extra235 is the first namespace to anchor this qualname as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "sha256().__class__.update.__qualname__.__eq__"
  args: ["HASH.update"]
  expected: true

invariant hashlib_extra235.sha256_name_eq:
  description: "hashlib.sha256(b'').name.__eq__('sha256') == True — the name attribute of a HASH object reports the algorithm name as a lowercase string; for sha256, the name is 'sha256' (6 characters); this attribute is part of the public HASH interface and is readable on any hash object returned by hashlib constructors; the 6-character length distinguishes it from 'md5' (3) and 'sha1' (4); extra235 is the first namespace to anchor hashlib.sha256(b'').name as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "sha256(b'').name.__eq__"
  args: ["sha256"]
  expected: true

invariant hashlib_extra235.hash_hexdigest_qualname_eq:
  description: "type(hashlib.sha256()).hexdigest.__qualname__.__eq__('HASH.hexdigest') == True — hexdigest() returns the hash value encoded as a hexadecimal string (twice as long as digest()); its __qualname__ is 'HASH.hexdigest' (14 characters: 'HASH.' (5) + 'hexdigest' (9)); the hexdigest method name is the longest of the four core HASH methods (update, digest, hexdigest, copy); extra235 is the first namespace to anchor HASH.hexdigest.__qualname__ as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "sha256().__class__.hexdigest.__qualname__.__eq__"
  args: ["HASH.hexdigest"]
  expected: true
