spec: async_mutex
version: ">=0.4.0"
backend: node(async-mutex)

docs: https://github.com/DirtyHairy/async-mutex#readme

provenance:
  derived_from:
    - "async-mutex README — https://github.com/DirtyHairy/async-mutex#readme"
    - "Test vectors verified with async-mutex via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "async-mutex source"
  notes:
    - "Promise-based mutual-exclusion primitives — Mutex / Semaphore — for coordinating async work."
    - "Install: npm install async-mutex"
    - "v0.4 CJS; named exports Mutex, Semaphore, withTimeout, tryAcquire, plus error sentinels (E_TIMEOUT/E_ALREADY_LOCKED/E_CANCELED)."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws E_TIMEOUT / E_ALREADY_LOCKED / E_CANCELED on contention."
  stderr: "null"
  stickiness: "Each Mutex/Semaphore instance owns its lock state."
  codes:
    E_TIMEOUT: "Acquire timed out"
    E_ALREADY_LOCKED: "tryAcquire on a held lock"
    E_CANCELED: "Pending acquire was canceled"

invariant async_mutex.has_Mutex:
  description: "Mutex class exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Mutex.constructor.name"}
  expected: "Function"

invariant async_mutex.Mutex_name:
  description: "Mutex.name is 'Mutex'"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Mutex.name"}
  expected: "Mutex"

invariant async_mutex.has_Semaphore:
  description: "Semaphore class exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Semaphore.constructor.name"}
  expected: "Function"

invariant async_mutex.has_withTimeout:
  description: "withTimeout helper exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "withTimeout.constructor.name"}
  expected: "Function"

invariant async_mutex.has_tryAcquire:
  description: "tryAcquire helper exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "tryAcquire.constructor.name"}
  expected: "Function"

invariant async_mutex.has_E_TIMEOUT:
  description: "E_TIMEOUT sentinel error exposed"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "E_TIMEOUT.constructor.name"}
  expected: "Error"

invariant async_mutex.has_E_ALREADY_LOCKED:
  description: "E_ALREADY_LOCKED sentinel error exposed"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "E_ALREADY_LOCKED.constructor.name"}
  expected: "Error"

invariant async_mutex.has_E_CANCELED:
  description: "E_CANCELED sentinel error exposed"
  category: errors
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "E_CANCELED.constructor.name"}
  expected: "Error"

invariant async_mutex.Mutex_proto_isLocked:
  description: "Mutex.prototype.isLocked is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Mutex.prototype.isLocked.constructor.name"}
  expected: "Function"

invariant async_mutex.Mutex_proto_acquire:
  description: "Mutex.prototype.acquire is defined"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "Mutex.prototype.acquire.constructor.name"}
  expected: "Function"
