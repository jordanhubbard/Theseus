spec: abc_extra1876
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "abc module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party abc extensions"
  notes:
    - "Tests attribute access protocol membership in abc types"
    - "ABCMeta ABC registry internals moved to C extension in Python 3.7; not in __dict__"
    - "ABC has no __slots__; ABCMeta defines register, __instancecheck__, __subclasscheck__"
  created_at: "2026-04-12"

