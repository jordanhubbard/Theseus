spec: multiprocessing_extra56
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Process — Process documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Queue — Queue documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.Pipe — Pipe documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "This spec extends multiprocessing_extra55.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__/__qualname__ tables (extra52), Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type' (extra45), Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins' (extra46), Pool/__doc__/__class__/__module__=='builtins' (extra50), Pool/__class__.__name__=='type' (multiprocessing_extra), Pool/active_children/ProcessError/AuthenticationError __class__.__module__.__eq__('builtins') (extra53), Process/__init__.__class__.__name__.__eq__('function') (extra53), Process/Pool __repr__.__class__.__name__ (extra54), Process __weakref__.__class__.__name__ (extra54), ProcessError/AuthenticationError exception __repr__.__class__.__name__ (extra54), mp.__all__.__class__.__name__.__eq__('list') (extra55), mp.__all__.__len__()==37 (extra55), Process/ProcessError/AuthenticationError __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra55)."
    - "This spec covers (mppkg56 namespace): multiprocessing.__all__.__contains__ membership for key members Process/Queue/Pipe/cpu_count/current_process — each returns True because these names are all present in mp.__all__ (37-item list). multiprocessing.__package__.__eq__('multiprocessing') — multiprocessing is a package (directory Lib/multiprocessing/ with __init__.py); __package__ == 'multiprocessing'; __len__() == 15. mp.Queue.__doc__.__class__.__name__.__eq__('str') and mp.Pool.__doc__.__class__.__name__.__eq__('str') — Queue and Pool are context-bound factory objects that return queue/pool objects and carry docstrings; __doc__ is a plain Python str. Note: mp.Process.__doc__ is None in Python 3.14.3, so Process is excluded from docstring class checks; mp.Queue and mp.Pool have docstrings. No prior multiprocessing spec has captured __all__.__contains__ membership checks or __package__.__eq__ as string equality."
    - "multiprocessing.__all__.__contains__('Process') returns True. mp.__all__ is a plain Python list of 37 exported names. 'Process' is one of them; __contains__('Process') returns True. No prior mp spec captured __all__.__contains__ membership checks. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__all__.__contains__('Queue') returns True. 'Queue' is in mp.__all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__all__.__contains__('Pipe') returns True. 'Pipe' is in mp.__all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__all__.__contains__('cpu_count') returns True. 'cpu_count' is in mp.__all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__all__.__contains__('current_process') returns True. 'current_process' is in mp.__all__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.__package__ == 'multiprocessing'. multiprocessing is a package (directory Lib/multiprocessing/ with __init__.py). For packages, Python sets __package__ to the package name string; here it is 'multiprocessing'. __eq__('multiprocessing') returns True. __len__() == 15. No prior mp spec captured __package__.__eq__ as a string equality check. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Queue.__doc__.__class__.__name__ == 'str'. mp.Queue is a context-bound object (not a bare class) that returns a queue; it carries the docstring 'Returns a queue object'. The docstring is a plain Python str; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True. Note: mp.Process.__doc__ is None in Python 3.14.3. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pool.__doc__.__class__.__name__ == 'str'. mp.Pool is a context-bound object that returns a pool; it carries the docstring 'Returns a process pool object'. The docstring is a plain Python str; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.__all__.__contains__ membership checks — extra56
#
# multiprocessing.__all__ is a plain Python list of 37 exported names.
# The following key members are all present in __all__:
#   Process, Queue, Pipe, cpu_count, current_process
#
# __contains__(name) returns True for each of these members.
# No prior multiprocessing spec has captured __all__.__contains__
# membership checks. Extra56 introduces this in the mppkg56 namespace.
# ---------------------------------------------------------------------------

table multiprocessing_extra56.all_contains_members:
  description: "multiprocessing.__all__.__contains__ membership checks in mppkg56 namespace — mp.__all__ is a plain Python list of 37 exported names; Process/Queue/Pipe/cpu_count/current_process are all present; __contains__(name) returns True for each; first __all__.__contains__ membership checks in any multiprocessing spec"
  kind: python_call_eq
  category: membership
  id_prefix: mppkg56contains

  columns: [id, function, args, expected, description]
  rows:
    - [Process,         __all__.__contains__, ["Process"],         true, "mp.__all__.__contains__('Process') == True — 'Process' is in mp.__all__ (37-item list); Process is the main multiprocessing process class defined in Lib/multiprocessing/process.py; first __all__.__contains__ membership check in any multiprocessing spec"]
    - [Queue,           __all__.__contains__, ["Queue"],           true, "mp.__all__.__contains__('Queue') == True — 'Queue' is in mp.__all__; Queue is the multiprocessing inter-process queue factory"]
    - [Pipe,            __all__.__contains__, ["Pipe"],            true, "mp.__all__.__contains__('Pipe') == True — 'Pipe' is in mp.__all__; Pipe creates a pair of Connection objects for inter-process communication"]
    - [cpu_count,       __all__.__contains__, ["cpu_count"],       true, "mp.__all__.__contains__('cpu_count') == True — 'cpu_count' is in mp.__all__; cpu_count returns the number of CPUs in the system"]
    - [current_process, __all__.__contains__, ["current_process"], true, "mp.__all__.__contains__('current_process') == True — 'current_process' is in mp.__all__; current_process returns a Process object representing the current process"]

# ---------------------------------------------------------------------------
# multiprocessing.__package__ identity check — extra56
#
# multiprocessing is a package (directory Lib/multiprocessing/ with __init__.py).
# For packages, Python sets __package__ equal to the package name string.
# multiprocessing.__package__ == 'multiprocessing'
# __eq__('multiprocessing') returns True; __len__() == 15.
#
# No prior multiprocessing spec has captured __package__.__eq__ as a string
# equality check. Extra56 introduces this in the mppkg56 namespace.
# ---------------------------------------------------------------------------

table multiprocessing_extra56.package_identity:
  description: "multiprocessing.__package__ identity in mppkg56 namespace — multiprocessing is a package (Lib/multiprocessing/__init__.py); __package__ == 'multiprocessing'; __eq__('multiprocessing') returns True; __len__() == 15; first __package__.__eq__ table in any multiprocessing spec"
  kind: python_call_eq
  category: package_identity
  id_prefix: mppkg56pkgid

  columns: [id, function, args, expected, description]
  rows:
    - [pkg_eq,  __package__.__eq__,  ["multiprocessing"], true, "mp.__package__.__eq__('multiprocessing') == True — multiprocessing is a package directory (Lib/multiprocessing/) with __init__.py; for packages __package__ equals the package name string 'multiprocessing'; first __package__ string equality check in any multiprocessing spec"]
    - [pkg_len, __package__.__len__, [],                  15,   "mp.__package__.__len__() == 15 — 'multiprocessing' has 15 characters; cross-check of the package name string length"]

# ---------------------------------------------------------------------------
# multiprocessing Queue/Pool __doc__.__class__.__name__ — extra56
#
# mp.Queue is a context-bound factory that carries the docstring
# 'Returns a queue object'. mp.Pool carries the docstring
# 'Returns a process pool object'. Both docstrings are plain Python str
# objects. str is a built-in type; __class__.__name__ == 'str'.
#
# Queue.__doc__.__class__.__name__.__eq__('str') returns True.
# Pool.__doc__.__class__.__name__.__eq__('str')  returns True.
#
# Note: mp.Process.__doc__ is None in Python 3.14.3 (the Process class
# body carries no docstring), so it is excluded from docstring class checks.
#
# No prior multiprocessing spec has captured __doc__.__class__.__name__
# as a string equality check at this dimension in the mppkg56 namespace.
# Extra56 introduces this in the mppkg56 namespace.
# ---------------------------------------------------------------------------

table multiprocessing_extra56.doc_class_name_eq:
  description: "multiprocessing Queue/Pool __doc__.__class__.__name__ in mppkg56 namespace — Queue and Pool carry docstrings that are plain Python str objects; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True; note mp.Process.__doc__ is None so it is excluded; novel docstring class check in mppkg56 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: mppkg56docname

  columns: [id, function, args, expected, description]
  rows:
    - [Queue, Queue.__doc__.__class__.__name__.__eq__, ["str"], true, "mp.Queue.__doc__.__class__.__name__ == 'str' — mp.Queue carries the docstring 'Returns a queue object'; the docstring is a plain Python str object; str is a built-in type; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True; first __doc__.__class__.__name__ equality check for Queue in any multiprocessing spec"]
    - [Pool,  Pool.__doc__.__class__.__name__.__eq__,  ["str"], true, "mp.Pool.__doc__.__class__.__name__ == 'str' — mp.Pool carries the docstring 'Returns a process pool object'; the docstring is a plain Python str; str is a built-in type; __class__.__name__ == 'str'; __doc__.__class__.__name__.__eq__('str') returns True"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra56
# ---------------------------------------------------------------------------

invariant multiprocessing_extra56.all_contains_Process:
  description: "mp.__all__.__contains__('Process') returns True — 'Process' is in mp.__all__ (37-item list); Process is the main multiprocessing process class; first __all__.__contains__ membership check in any multiprocessing spec"
  category: membership
  kind: python_call_eq
  function: __all__.__contains__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra56.all_contains_cpu_count:
  description: "mp.__all__.__contains__('cpu_count') returns True — 'cpu_count' is in mp.__all__; cpu_count returns the number of CPUs in the system; novel __all__.__contains__ membership check for cpu_count"
  category: membership
  kind: python_call_eq
  function: __all__.__contains__
  args: ["cpu_count"]
  expected: true

invariant multiprocessing_extra56.all_contains_current_process:
  description: "mp.__all__.__contains__('current_process') returns True — 'current_process' is in mp.__all__; current_process returns the current Process object; novel __all__.__contains__ membership check for current_process"
  category: membership
  kind: python_call_eq
  function: __all__.__contains__
  args: ["current_process"]
  expected: true

invariant multiprocessing_extra56.package_eq:
  description: "mp.__package__.__eq__('multiprocessing') returns True — multiprocessing is a package (Lib/multiprocessing/__init__.py); __package__ == 'multiprocessing'; first __package__ string equality invariant in any multiprocessing spec"
  category: package_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["multiprocessing"]
  expected: true

invariant multiprocessing_extra56.Queue_doc_class_name_eq:
  description: "mp.Queue.__doc__.__class__.__name__.__eq__('str') returns True — mp.Queue carries the docstring 'Returns a queue object' which is a plain Python str; str is a built-in type; __class__.__name__ == 'str'; novel docstring type check for Queue in mppkg56 namespace"
  category: class_names
  kind: python_call_eq
  function: Queue.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant multiprocessing_extra56.Pool_doc_class_name_eq:
  description: "mp.Pool.__doc__.__class__.__name__.__eq__('str') returns True — mp.Pool carries the docstring 'Returns a process pool object' which is a plain Python str; str is a built-in type; __class__.__name__ == 'str'; novel docstring type check for Pool in mppkg56 namespace"
  category: class_names
  kind: python_call_eq
  function: Pool.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
