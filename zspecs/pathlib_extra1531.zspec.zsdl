spec: pathlib_extra1531
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePath, PurePosixPath, PureWindowsPath, Path documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "CPython pathlib source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath name/stem/suffix/parts/parent/joinpath/str/as_posix/relative_to"
    - "pathlib_extra.zspec.zsdl — covers Path class identity, PurePosixPath component access extension, parent string values, truediv, parts"
    - "pathlib_extra1516.zspec.zsdl — covers arithmetic operator presence/absence (wave 548)"
  notes:
    - "Wave 549 (_extra1531): comparison operator __dict__ presence checks for pathlib module classes."
    - "pathlib.PurePath defines __lt__, __le__, __gt__, __ge__, __eq__, and __hash__ in its own __dict__ for lexicographic path comparison and ordering. __ne__ is NOT defined (uses default object __ne__ which negates __eq__)."
    - "PurePath comparison operators implement lexicographic ordering on the path string: PurePosixPath('/a') < PurePosixPath('/b') is True."
    - "__hash__ is defined alongside __eq__ to ensure PurePath objects are correctly hashable and can be used as dict keys or in sets."
    - "pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path do NOT define any comparison operators in their own __dict__; they inherit all comparison behavior from PurePath."
    - "Contrast with: io classes (none define any comparison operators), re.Pattern (defines all seven including __ne__), decimal.Decimal (defines all seven)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1531.purepath_comparison_ops_present:
  description: "pathlib.PurePath comparison operator presence — __lt__, __le__, __gt__, __ge__, __eq__, __hash__ are all defined in pathlib.PurePath.__dict__; PurePath implements lexicographic path ordering for sorting and set membership; __ne__ is the notable absence (inherited from object); wave 549"
  kind: python_call_eq
  category: comparison_ops
  id_prefix: pl1531pp
  columns: [id, function, args, expected, description]
  rows:
    - [pl1531pp001,
       pathlib.PurePath.__dict__.__contains__,
       ["__lt__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__lt__') == True — pathlib.PurePath defines __lt__ in its own __dict__; PurePath supports lexicographic less-than ordering on the case-folded path string; PurePosixPath('/a') < PurePosixPath('/b') is True; __lt__ is defined alongside __le__, __gt__, __ge__ to provide a complete ordering protocol; verified with Python 3.14.3"]
    - [pl1531pp002,
       pathlib.PurePath.__dict__.__contains__,
       ["__le__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__le__') == True — pathlib.PurePath defines __le__ in its own __dict__; PurePath supports less-than-or-equal ordering; PurePosixPath('/a') <= PurePosixPath('/a') is True; __le__ and __lt__ together enable sorted() and bisect module usage with PurePath objects; verified with Python 3.14.3"]
    - [pl1531pp003,
       pathlib.PurePath.__dict__.__contains__,
       ["__gt__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__gt__') == True — pathlib.PurePath defines __gt__ in its own __dict__; PurePath supports greater-than ordering; PurePosixPath('/b') > PurePosixPath('/a') is True; all four ordering operators (__lt__, __le__, __gt__, __ge__) are defined in PurePath.__dict__; verified with Python 3.14.3"]
    - [pl1531pp004,
       pathlib.PurePath.__dict__.__contains__,
       ["__ge__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__ge__') == True — pathlib.PurePath defines __ge__ in its own __dict__; PurePath supports greater-than-or-equal ordering; __ge__ completes the four-operator ordering set (__lt__, __le__, __gt__, __ge__) all defined in PurePath.__dict__; this enables PurePath objects to be fully sortable; verified with Python 3.14.3"]
    - [pl1531pp005,
       pathlib.PurePath.__dict__.__contains__,
       ["__eq__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__eq__') == True — pathlib.PurePath defines __eq__ in its own __dict__; PurePath equality comparison is case-sensitive on POSIX (PurePosixPath('/Abc') != PurePosixPath('/abc')) and case-insensitive on Windows (PureWindowsPath); __eq__ is defined alongside __hash__ to maintain the invariant that equal objects have equal hashes; verified with Python 3.14.3"]
    - [pl1531pp006,
       pathlib.PurePath.__dict__.__contains__,
       ["__hash__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__hash__') == True — pathlib.PurePath defines __hash__ in its own __dict__; __hash__ enables PurePath objects to be used as dict keys and set members; PurePath.__hash__ is consistent with __eq__: equal paths have equal hashes; contrast with io classes (no __hash__ in __dict__) and re.Match (no __hash__ in __dict__); verified with Python 3.14.3"]
    - [pl1531pp007,
       pathlib.PurePath.__dict__.__contains__,
       ["__ne__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__ne__') == False — pathlib.PurePath does NOT define __ne__ in its own __dict__; not-equal comparison is handled by the default object.__ne__ which negates __eq__; this is the expected Python 3 pattern: define __eq__ and __hash__, let __ne__ be inherited; contrast with re.Pattern and decimal.Decimal which both explicitly define __ne__ in their own __dict__; verified with Python 3.14.3"]
    - [pl1531pp008,
       pathlib.PurePath.__dict__.__contains__,
       ["__truediv__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__truediv__') == True — positive anchor confirming PurePath.__dict__ contains real operator definitions; __truediv__ is the path-joining operator (path / 'subdir'); its presence alongside the comparison operators confirms that PurePath.__dict__ is a substantive class dict, not a thin proxy; verified with Python 3.14.3"]

table pathlib_extra1531.purepath_subclasses_comparison_ops_absent:
  description: "pathlib.PurePosixPath, PureWindowsPath, and Path do not define comparison operators in their own __dict__ — they inherit all comparison behavior from PurePath; wave 549"
  kind: python_call_eq
  category: comparison_ops
  id_prefix: pl1531sc
  columns: [id, function, args, expected, description]
  rows:
    - [pl1531sc001,
       pathlib.PurePosixPath.__dict__.__contains__,
       ["__lt__"],
       false,
       "pathlib.PurePosixPath.__dict__.__contains__('__lt__') == False — pathlib.PurePosixPath does not define __lt__ in its own __dict__; PurePosixPath inherits __lt__ from pathlib.PurePath; the comparison operators are defined once in PurePath and inherited by all subclasses; verified with Python 3.14.3"]
    - [pl1531sc002,
       pathlib.PurePosixPath.__dict__.__contains__,
       ["__eq__"],
       false,
       "pathlib.PurePosixPath.__dict__.__contains__('__eq__') == False — pathlib.PurePosixPath does not define __eq__ in its own __dict__; equality comparison is inherited from pathlib.PurePath.__eq__; the PurePosixPath subclass adds no new comparison semantics beyond what PurePath provides; verified with Python 3.14.3"]
    - [pl1531sc003,
       pathlib.PurePosixPath.__dict__.__contains__,
       ["__hash__"],
       false,
       "pathlib.PurePosixPath.__dict__.__contains__('__hash__') == False — pathlib.PurePosixPath does not define __hash__ in its own __dict__; hashing is inherited from pathlib.PurePath.__hash__; PurePosixPath instances are hashable via the inherited definition; verified with Python 3.14.3"]
    - [pl1531sc004,
       pathlib.PureWindowsPath.__dict__.__contains__,
       ["__lt__"],
       false,
       "pathlib.PureWindowsPath.__dict__.__contains__('__lt__') == False — pathlib.PureWindowsPath does not define __lt__ in its own __dict__; PureWindowsPath inherits __lt__ from pathlib.PurePath; on Windows, path comparison is case-insensitive because PureWindowsPath normalizes path strings before comparison, but __lt__ itself is still defined on PurePath; verified with Python 3.14.3"]
    - [pl1531sc005,
       pathlib.PureWindowsPath.__dict__.__contains__,
       ["__eq__"],
       false,
       "pathlib.PureWindowsPath.__dict__.__contains__('__eq__') == False — pathlib.PureWindowsPath does not define __eq__ in its own __dict__; equality comparison is inherited from pathlib.PurePath.__eq__; PureWindowsPath instances compare case-insensitively because path normalization happens at construction time, not inside __eq__; verified with Python 3.14.3"]
    - [pl1531sc006,
       pathlib.PureWindowsPath.__dict__.__contains__,
       ["__hash__"],
       false,
       "pathlib.PureWindowsPath.__dict__.__contains__('__hash__') == False — pathlib.PureWindowsPath does not define __hash__ in its own __dict__; hashing is inherited from pathlib.PurePath.__hash__; the hash is computed on the normalized (case-folded) path string for PureWindowsPath; verified with Python 3.14.3"]
    - [pl1531sc007,
       pathlib.Path.__dict__.__contains__,
       ["__lt__"],
       false,
       "pathlib.Path.__dict__.__contains__('__lt__') == False — pathlib.Path does not define __lt__ in its own __dict__; Path inherits __lt__ from pathlib.PurePath through PurePosixPath or PureWindowsPath; the concrete Path class adds filesystem operations (stat, open, mkdir, etc.) but no new comparison semantics; verified with Python 3.14.3"]
    - [pl1531sc008,
       pathlib.Path.__dict__.__contains__,
       ["__eq__"],
       false,
       "pathlib.Path.__dict__.__contains__('__eq__') == False — pathlib.Path does not define __eq__ in its own __dict__; equality comparison is inherited from pathlib.PurePath; Path('/tmp/a') == Path('/tmp/a') is True via the inherited __eq__ comparing normalized path strings; verified with Python 3.14.3"]
    - [pl1531sc009,
       pathlib.Path.__dict__.__contains__,
       ["__hash__"],
       false,
       "pathlib.Path.__dict__.__contains__('__hash__') == False — pathlib.Path does not define __hash__ in its own __dict__; hashing is inherited from pathlib.PurePath; Path instances can be used as dict keys via the inherited __hash__; wave 549 confirms that comparison operators are defined exactly once in PurePath.__dict__ and inherited by all three subclasses (PurePosixPath, PureWindowsPath, Path); verified with Python 3.14.3"]

table pathlib_extra1531.purepath_comparison_summary:
  description: "pathlib.PurePath comparison operator summary — confirms the exact set defined vs absent: __lt__, __le__, __gt__, __ge__, __eq__, __hash__ present; __ne__ absent; cross-checks with PurePosixPath confirming inheritance; wave 549"
  kind: python_call_eq
  category: comparison_ops
  id_prefix: pl1531cs
  columns: [id, function, args, expected, description]
  rows:
    - [pl1531cs001,
       pathlib.PurePath.__dict__.__contains__,
       ["__lt__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__lt__') == True — summary: __lt__ is defined in PurePath.__dict__; one of the six comparison-related operators defined in PurePath.__dict__; verified with Python 3.14.3"]
    - [pl1531cs002,
       pathlib.PurePath.__dict__.__contains__,
       ["__le__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__le__') == True — summary: __le__ is defined in PurePath.__dict__; PurePath implements the full less-than/greater-than ordering pair; verified with Python 3.14.3"]
    - [pl1531cs003,
       pathlib.PurePath.__dict__.__contains__,
       ["__gt__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__gt__') == True — summary: __gt__ is defined in PurePath.__dict__; the ordering operators enable sorted(list_of_paths) to produce lexicographic ordering; verified with Python 3.14.3"]
    - [pl1531cs004,
       pathlib.PurePath.__dict__.__contains__,
       ["__ge__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__ge__') == True — summary: __ge__ is defined in PurePath.__dict__; the four ordering operators (__lt__, __le__, __gt__, __ge__) are all explicitly defined in PurePath.__dict__; verified with Python 3.14.3"]
    - [pl1531cs005,
       pathlib.PurePath.__dict__.__contains__,
       ["__eq__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__eq__') == True — summary: __eq__ is defined in PurePath.__dict__; equality check is path-string equality; defined together with __hash__ to satisfy the hash consistency invariant (a == b implies hash(a) == hash(b)); verified with Python 3.14.3"]
    - [pl1531cs006,
       pathlib.PurePath.__dict__.__contains__,
       ["__hash__"],
       true,
       "pathlib.PurePath.__dict__.__contains__('__hash__') == True — summary: __hash__ is defined in PurePath.__dict__; PurePath objects are hashable and can be used as dict keys; __hash__ is the sixth comparison-protocol method defined in PurePath.__dict__ (along with __lt__, __le__, __gt__, __ge__, __eq__); verified with Python 3.14.3"]
    - [pl1531cs007,
       pathlib.PurePath.__dict__.__contains__,
       ["__ne__"],
       false,
       "pathlib.PurePath.__dict__.__contains__('__ne__') == False — summary: __ne__ is NOT defined in PurePath.__dict__; this is the one comparison operator absent from PurePath's own dict; Python 3 inherits __ne__ = not __eq__ automatically from object when only __eq__ is defined; this differs from re.Pattern and decimal.Decimal which both explicitly define __ne__ in their own __dict__; verified with Python 3.14.3"]
    - [pl1531cs008,
       pathlib.PurePosixPath.__dict__.__contains__,
       ["__ge__"],
       false,
       "pathlib.PurePosixPath.__dict__.__contains__('__ge__') == False — cross-check: PurePosixPath does not redefine __ge__; the ordering operator is inherited from PurePath; this confirms the single-point-of-definition design: comparison operators are defined once in PurePath and inherited by PurePosixPath, PureWindowsPath, and Path; verified with Python 3.14.3"]
    - [pl1531cs009,
       pathlib.PurePosixPath.__dict__.__contains__,
       ["__le__"],
       false,
       "pathlib.PurePosixPath.__dict__.__contains__('__le__') == False — cross-check: PurePosixPath does not redefine __le__; inherited from PurePath; wave 549 survey result for pathlib: PurePath defines six comparison-protocol members (__lt__, __le__, __gt__, __ge__, __eq__, __hash__); PurePosixPath, PureWindowsPath, and Path define none; __ne__ is absent from all pathlib class __dict__ entries; verified with Python 3.14.3"]
