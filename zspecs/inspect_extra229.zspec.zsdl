spec: inspect_extra229
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.signature, inspect.getdoc, and inspect.getsourcefile behavioral contracts."
    - "inspect.signature(len).__class__.__name__ == 'Signature' — signature() returns a Signature object. Verified with Python 3.14.3."
    - "inspect.signature.__name__ == 'signature' — the signature function has __name__=='signature'. Verified with Python 3.14.3."
    - "inspect.getdoc(len) == 'Return the number of items in a container.' — full docstring of the len builtin. Verified with Python 3.14.3."
    - "inspect.getdoc(len).__contains__('Return') == True — docstring starts with 'Return'. Verified with Python 3.14.3."
    - "inspect.getdoc(len).__contains__('items') == True — docstring mentions 'items'. Verified with Python 3.14.3."
    - "inspect.getdoc.__name__ == 'getdoc' — getdoc function has __name__=='getdoc'. Verified with Python 3.14.3."
    - "inspect.getsourcefile.__name__ == 'getsourcefile' — getsourcefile function has __name__=='getsourcefile'. Verified with Python 3.14.3."
    - "inspect.Signature.__name__ == 'Signature' — Signature class has __name__=='Signature'. Verified with Python 3.14.3."
    - "inspect.Signature.__module__ == 'inspect' — Signature is defined in inspect module. Verified with Python 3.14.3."
    - "inspect.Parameter.__name__ == 'Parameter' — Parameter class has __name__=='Parameter'. Verified with Python 3.14.3."
    - "inspect.Parameter.__module__ == 'inspect' — Parameter is defined in inspect module. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.signature identity contracts
#
# inspect.signature.__name__ == 'signature'
# inspect.signature.__qualname__ == 'signature'
# inspect.signature.__module__ == 'inspect'
# inspect.signature.__name__.__len__() == 9
# inspect.Signature.__name__ == 'Signature'
#
# New to extra229.
# ---------------------------------------------------------------------------

table inspect_extra229.signature_identity:
  description: "inspect.signature identity contracts: __name__, __qualname__, __module__, name length; new to extra229"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra229sigid

  columns: [id, function, args, expected, description]
  rows:
    - [signature_name_eq,
       signature.__name__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__name__ == 'signature' — signature is a top-level function in Lib/inspect.py; its __name__ is 'signature'; __name__.__eq__('signature') returns True; new to extra229"]
    - [signature_qualname_eq,
       signature.__qualname__.__eq__,
       ["signature"],
       true,
       "inspect.signature.__qualname__ == 'signature' — signature is a top-level function with unqualified qualname; __qualname__.__eq__('signature') returns True; new to extra229"]
    - [signature_module_eq,
       signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.signature.__module__ == 'inspect' — signature is defined in the inspect module; __module__.__eq__('inspect') returns True; new to extra229"]
    - [signature_name_len_9,
       signature.__name__.__len__,
       [],
       9,
       "inspect.signature.__name__.__len__() == 9 — 'signature' has exactly 9 characters (s-i-g-n-a-t-u-r-e); __len__() returns 9; new to extra229"]
    - [Signature_name_eq,
       Signature.__name__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__name__ == 'Signature' — Signature is the class representing a callable's signature; __name__.__eq__('Signature') returns True; new to extra229"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getdoc identity and behavioral contracts
#
# inspect.getdoc.__name__ == 'getdoc'
# inspect.getdoc.__qualname__ == 'getdoc'
# inspect.getdoc.__module__ == 'inspect'
# inspect.getdoc.__name__.__len__() == 6
# inspect.getsourcefile.__name__ == 'getsourcefile'
#
# New to extra229.
# ---------------------------------------------------------------------------

table inspect_extra229.getdoc_identity:
  description: "inspect.getdoc and getsourcefile identity contracts: names, qualnames, module, lengths; new to extra229"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra229getdocid

  columns: [id, function, args, expected, description]
  rows:
    - [getdoc_name_eq,
       getdoc.__name__.__eq__,
       ["getdoc"],
       true,
       "inspect.getdoc.__name__ == 'getdoc' — getdoc is a top-level function in Lib/inspect.py that retrieves cleaned docstrings; __name__.__eq__('getdoc') returns True; new to extra229"]
    - [getdoc_qualname_eq,
       getdoc.__qualname__.__eq__,
       ["getdoc"],
       true,
       "inspect.getdoc.__qualname__ == 'getdoc' — getdoc is a top-level function with unqualified qualname; __qualname__.__eq__('getdoc') returns True; new to extra229"]
    - [getdoc_module_eq,
       getdoc.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getdoc.__module__ == 'inspect' — getdoc is defined in the inspect module; __module__.__eq__('inspect') returns True; new to extra229"]
    - [getdoc_name_len_6,
       getdoc.__name__.__len__,
       [],
       6,
       "inspect.getdoc.__name__.__len__() == 6 — 'getdoc' has exactly 6 characters (g-e-t-d-o-c); __len__() returns 6; new to extra229"]
    - [getsourcefile_name_eq,
       getsourcefile.__name__.__eq__,
       ["getsourcefile"],
       true,
       "inspect.getsourcefile.__name__ == 'getsourcefile' — getsourcefile is a top-level function in Lib/inspect.py; __name__.__eq__('getsourcefile') returns True; new to extra229"]

# ---------------------------------------------------------------------------
# Table 3: inspect.Signature and Parameter class identity contracts
#
# inspect.Signature.__name__ == 'Signature'
# inspect.Signature.__module__ == 'inspect'
# inspect.Parameter.__name__ == 'Parameter'
# inspect.Parameter.__module__ == 'inspect'
# inspect.getsourcefile.__name__.__len__() == 13
#
# New to extra229.
# ---------------------------------------------------------------------------

table inspect_extra229.signature_parameter_class_identity:
  description: "inspect.Signature and Parameter class identity contracts; getsourcefile name length; new to extra229"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra229sigparamcls

  columns: [id, function, args, expected, description]
  rows:
    - [Signature_module_eq,
       Signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.__module__ == 'inspect' — Signature is defined in Lib/inspect.py; __module__.__eq__('inspect') returns True; new to extra229"]
    - [Parameter_name_eq,
       Parameter.__name__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__name__ == 'Parameter' — Parameter represents a single call parameter; __name__.__eq__('Parameter') returns True; new to extra229"]
    - [Parameter_module_eq,
       Parameter.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Parameter.__module__ == 'inspect' — Parameter is defined in Lib/inspect.py; __module__.__eq__('inspect') returns True; new to extra229"]
    - [getsourcefile_name_len_13,
       getsourcefile.__name__.__len__,
       [],
       13,
       "inspect.getsourcefile.__name__.__len__() == 13 — 'getsourcefile' has exactly 13 characters (g-e-t-s-o-u-r-c-e-f-i-l-e); __len__() returns 13; new to extra229"]
    - [signature_qualname_len_9,
       signature.__qualname__.__len__,
       [],
       9,
       "inspect.signature.__qualname__.__len__() == 9 — qualname 'signature' has exactly 9 characters; __len__() returns 9; new to extra229"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra229
# ---------------------------------------------------------------------------

invariant inspect_extra229.signature_name_eq:
  description: "inspect.signature.__name__ == 'signature'; new to extra229"
  kind: python_call_eq
  function: signature.__name__.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra229.signature_qualname_eq:
  description: "inspect.signature.__qualname__ == 'signature'; new to extra229"
  kind: python_call_eq
  function: signature.__qualname__.__eq__
  args: ["signature"]
  expected: true

invariant inspect_extra229.signature_module_eq:
  description: "inspect.signature.__module__ == 'inspect'; new to extra229"
  kind: python_call_eq
  function: signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra229.signature_name_len_9:
  description: "inspect.signature.__name__.__len__() == 9 — 'signature' has 9 characters; new to extra229"
  kind: python_call_eq
  function: signature.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra229.getdoc_name_eq:
  description: "inspect.getdoc.__name__ == 'getdoc'; new to extra229"
  kind: python_call_eq
  function: getdoc.__name__.__eq__
  args: ["getdoc"]
  expected: true

invariant inspect_extra229.getdoc_module_eq:
  description: "inspect.getdoc.__module__ == 'inspect'; new to extra229"
  kind: python_call_eq
  function: getdoc.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra229.getdoc_name_len_6:
  description: "inspect.getdoc.__name__.__len__() == 6 — 'getdoc' has 6 characters; new to extra229"
  kind: python_call_eq
  function: getdoc.__name__.__len__
  args: []
  expected: 6

invariant inspect_extra229.getsourcefile_name_eq:
  description: "inspect.getsourcefile.__name__ == 'getsourcefile'; new to extra229"
  kind: python_call_eq
  function: getsourcefile.__name__.__eq__
  args: ["getsourcefile"]
  expected: true

invariant inspect_extra229.getsourcefile_name_len_13:
  description: "inspect.getsourcefile.__name__.__len__() == 13 — 'getsourcefile' has 13 characters; new to extra229"
  kind: python_call_eq
  function: getsourcefile.__name__.__len__
  args: []
  expected: 13

invariant inspect_extra229.Signature_name_eq:
  description: "inspect.Signature.__name__ == 'Signature'; new to extra229"
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra229.Signature_module_eq:
  description: "inspect.Signature.__module__ == 'inspect'; new to extra229"
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra229.Parameter_name_eq:
  description: "inspect.Parameter.__name__ == 'Parameter'; new to extra229"
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra229.Parameter_module_eq:
  description: "inspect.Parameter.__module__ == 'inspect'; new to extra229"
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true
