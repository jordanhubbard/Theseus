spec: abc_extra238
version: ">=3.4"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers ABCMeta class identity and ABC.__abstractmethods__ contracts."
    - "ABCMeta.__name__ == 'ABCMeta' — 7 characters; the metaclass for abstract base classes."
    - "ABCMeta.__module__ == 'abc' — 3 characters; defined in the abc module."
    - "ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta inherits from the built-in type metaclass."
    - "ABCMeta.__mro__.__len__() == 3 — MRO is [ABCMeta, type, object]."
    - "ABCMeta.__mro__[0].__name__ == 'ABCMeta'; [1] == 'type'; [2] == 'object'."
    - "ABCMeta.register.__name__ == 'register'; __qualname__ == 'ABCMeta.register' (16 chars)."
    - "ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (24 chars)."
    - "ABC.__abstractmethods__.__class__.__name__ == 'frozenset' — empty frozenset on the ABC helper."
    - "ABC.__abstractmethods__.__len__() == 0 — ABC itself has no abstract methods."
    - "ABCMeta.__abstractmethods__ raises AttributeError — ABCMeta is a metaclass, not an abstract class instance."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: ABCMeta class identity contracts
#
# ABCMeta.__name__, __module__, qualname, and string lengths.
# ---------------------------------------------------------------------------

table abc_extra238.abcmeta_identity:
  description: "abc.ABCMeta class identity: name, module, qualname lengths; new to extra238"
  kind: python_call_eq
  category: abcmeta_identity
  id_prefix: abc238abs

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_name_eq,
       ABCMeta.__name__.__eq__,
       ["ABCMeta"],
       true,
       "abc.ABCMeta.__name__.__eq__('ABCMeta') == True — 7 characters; new to extra238"]
    - [abcmeta_module_eq,
       ABCMeta.__module__.__eq__,
       ["abc"],
       true,
       "abc.ABCMeta.__module__.__eq__('abc') == True — 3 characters; new to extra238"]
    - [abcmeta_name_len_7,
       ABCMeta.__name__.__len__,
       [],
       7,
       "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters; new to extra238"]
    - [abcmeta_module_len_3,
       ABCMeta.__module__.__len__,
       [],
       3,
       "abc.ABCMeta.__module__.__len__() == 3 — 'abc' has 3 characters; new to extra238"]

# ---------------------------------------------------------------------------
# Table 2: ABCMeta base class and MRO contracts
#
# ABCMeta.__bases__[0].__name__ == 'type'; MRO length is 3.
# The function paths containing '[' must be double-quoted.
# ---------------------------------------------------------------------------

table abc_extra238.abcmeta_mro:
  description: "abc.ABCMeta base class and MRO contracts; new to extra238"
  kind: python_call_eq
  category: abcmeta_identity
  id_prefix: abc238abs

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_base_eq,
       "ABCMeta.__bases__[0].__name__.__eq__",
       ["type"],
       true,
       "abc.ABCMeta.__bases__[0].__name__.__eq__('type') == True — ABCMeta inherits from built-in type; new to extra238"]
    - [abcmeta_mro_len_3,
       ABCMeta.__mro__.__len__,
       [],
       3,
       "abc.ABCMeta.__mro__.__len__() == 3 — MRO is [ABCMeta, type, object]; new to extra238"]
    - [abcmeta_mro0_eq,
       "ABCMeta.__mro__[0].__name__.__eq__",
       ["ABCMeta"],
       true,
       "abc.ABCMeta.__mro__[0].__name__ == 'ABCMeta' — first MRO entry is ABCMeta itself; new to extra238"]
    - [abcmeta_mro1_eq,
       "ABCMeta.__mro__[1].__name__.__eq__",
       ["type"],
       true,
       "abc.ABCMeta.__mro__[1].__name__ == 'type' — second MRO entry is type; new to extra238"]
    - [abcmeta_mro2_eq,
       "ABCMeta.__mro__[2].__name__.__eq__",
       ["object"],
       true,
       "abc.ABCMeta.__mro__[2].__name__ == 'object' — third MRO entry is object; new to extra238"]

# ---------------------------------------------------------------------------
# Table 3: ABCMeta.register and __subclasshook__ method identity
#
# register.__name__, __qualname__ and lengths.
# ---------------------------------------------------------------------------

table abc_extra238.abcmeta_methods:
  description: "abc.ABCMeta method identity: register, __subclasshook__; new to extra238"
  kind: python_call_eq
  category: abcmeta_methods
  id_prefix: abc238abs

  columns: [id, function, args, expected, description]
  rows:
    - [register_name_eq,
       ABCMeta.register.__name__.__eq__,
       ["register"],
       true,
       "abc.ABCMeta.register.__name__.__eq__('register') == True — 8 characters; new to extra238"]
    - [register_qualname_eq,
       ABCMeta.register.__qualname__.__eq__,
       ["ABCMeta.register"],
       true,
       "abc.ABCMeta.register.__qualname__.__eq__('ABCMeta.register') == True — 16 characters; new to extra238"]
    - [register_qualname_len_16,
       ABCMeta.register.__qualname__.__len__,
       [],
       16,
       "abc.ABCMeta.register.__qualname__.__len__() == 16 — 'ABCMeta.register' has 16 characters; new to extra238"]
    - [subclasshook_qualname_eq,
       ABCMeta.__subclasshook__.__qualname__.__eq__,
       ["ABCMeta.__subclasshook__"],
       true,
       "abc.ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (24 chars); new to extra238"]
    - [subclasshook_qualname_len_24,
       ABCMeta.__subclasshook__.__qualname__.__len__,
       [],
       24,
       "abc.ABCMeta.__subclasshook__.__qualname__.__len__() == 24 — 'ABCMeta.__subclasshook__' has 24 characters; new to extra238"]

# ---------------------------------------------------------------------------
# Table 4: ABC.__abstractmethods__ type and length
#
# ABC.__abstractmethods__ is an empty frozenset; __class__.__name__ == 'frozenset'.
# ---------------------------------------------------------------------------

table abc_extra238.abc_abstractmethods:
  description: "abc.ABC.__abstractmethods__ type and length contracts; new to extra238"
  kind: python_call_eq
  category: abc_abstractmethods
  id_prefix: abc238abs

  columns: [id, function, args, expected, description]
  rows:
    - [abs_class_name_eq,
       ABC.__abstractmethods__.__class__.__name__.__eq__,
       ["frozenset"],
       true,
       "abc.ABC.__abstractmethods__.__class__.__name__.__eq__('frozenset') == True — empty frozenset; new to extra238"]
    - [abs_len_zero,
       ABC.__abstractmethods__.__len__,
       [],
       0,
       "abc.ABC.__abstractmethods__.__len__() == 0 — ABC has no abstract methods; new to extra238"]
    - [abs_class_name_len_9,
       ABC.__abstractmethods__.__class__.__name__.__len__,
       [],
       9,
       "abc.ABC.__abstractmethods__.__class__.__name__.__len__() == 9 — 'frozenset' has 9 characters; new to extra238"]

# ---------------------------------------------------------------------------
# ABCMeta.__abstractmethods__ raises AttributeError — extra238
#
# ABCMeta is a metaclass; it does not have __abstractmethods__ as an instance
# attribute. Accessing ABCMeta.__abstractmethods__ raises AttributeError.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant abc_extra238.ABCMeta_no_abstractmethods:
  description: "abc.ABCMeta.__abstractmethods__ raises AttributeError — ABCMeta is a metaclass and does not expose __abstractmethods__; new to extra238"
  category: abcmeta_identity
  kind: python_call_raises
  function: ABCMeta.__abstractmethods__.__class__.__name__.__len__
  args: []
  raises: AttributeError

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra238
# ---------------------------------------------------------------------------

invariant abc_extra238.ABCMeta.name:
  description: "abc.ABCMeta.__name__ == 'ABCMeta'; new to extra238"
  category: abcmeta_identity
  kind: python_call_eq
  function: ABCMeta.__name__.__eq__
  args: ["ABCMeta"]
  expected: true

invariant abc_extra238.ABCMeta.module:
  description: "abc.ABCMeta.__module__ == 'abc'; new to extra238"
  category: abcmeta_identity
  kind: python_call_eq
  function: ABCMeta.__module__.__eq__
  args: ["abc"]
  expected: true

invariant abc_extra238.ABCMeta.name_len:
  description: "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters; new to extra238"
  category: abcmeta_identity
  kind: python_call_eq
  function: ABCMeta.__name__.__len__
  args: []
  expected: 7

invariant abc_extra238.ABCMeta.base_name:
  description: "abc.ABCMeta.__bases__[0].__name__ == 'type' — ABCMeta inherits from built-in type; new to extra238"
  category: abcmeta_identity
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__name__.__eq__"
  args: ["type"]
  expected: true

invariant abc_extra238.ABCMeta.mro_len:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — MRO is [ABCMeta, type, object]; new to extra238"
  category: abcmeta_identity
  kind: python_call_eq
  function: ABCMeta.__mro__.__len__
  args: []
  expected: 3

invariant abc_extra238.ABCMeta.register_name:
  description: "abc.ABCMeta.register.__name__ == 'register'; new to extra238"
  category: abcmeta_methods
  kind: python_call_eq
  function: ABCMeta.register.__name__.__eq__
  args: ["register"]
  expected: true

invariant abc_extra238.ABCMeta.register_qualname:
  description: "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register'; new to extra238"
  category: abcmeta_methods
  kind: python_call_eq
  function: ABCMeta.register.__qualname__.__eq__
  args: ["ABCMeta.register"]
  expected: true

invariant abc_extra238.ABC.abstractmethods_class:
  description: "abc.ABC.__abstractmethods__.__class__.__name__ == 'frozenset'; new to extra238"
  category: abc_abstractmethods
  kind: python_call_eq
  function: ABC.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

invariant abc_extra238.ABC.abstractmethods_len:
  description: "abc.ABC.__abstractmethods__.__len__() == 0 — ABC has no abstract methods; new to extra238"
  category: abc_abstractmethods
  kind: python_call_eq
  function: ABC.__abstractmethods__.__len__
  args: []
  expected: 0
