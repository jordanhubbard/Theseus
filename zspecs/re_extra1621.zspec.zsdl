spec: re_extra1621
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "re.Pattern and re.Match are C extension types (from _sre); C types manage weakref support at the C level via tp_weaklistoffset"
    - "re.Pattern and re.Match do not expose __weakref__ in their class dicts — they are C types without tp_weaklistoffset set"
    - "re.error is a pure Python exception class (defined in Lib/re/__init__.py); Python type machinery adds __weakref__ to its own class dict at class creation"
    - "re.error inherits from Exception; as a Python class without __slots__, it has __weakref__ in its own class dict"
    - "re.RegexFlag is an IntFlag enum subclass; enums are Python classes but the metaclass does not add __weakref__ to each enum class's own dict"
    - "Instances of re.Pattern and re.Match cannot be weakly referenced (no __weakref__ slot)"
    - "Instances of re.error CAN be weakly referenced (inherits __weakref__ support from Exception chain)"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: C extension types — no __weakref__ in class dict
# ---------------------------------------------------------------------------

table re_extra1621.c_types_no_weakref:
  description: "re.Pattern and re.Match are C extension types — neither exposes __weakref__ in its own class dict; instances cannot be weakly referenced"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1621ct

  columns: [id, function, args, expected]
  rows:
    - ["re1621ct001", "re.Pattern.__dict__.__contains__", ["__weakref__"],    false]
    - ["re1621ct002", "re.Match.__dict__.__contains__",   ["__weakref__"],    false]
    - ["re1621ct003", "re.Pattern.__dict__.__contains__", ["__slots__"],      false]
    - ["re1621ct004", "re.Match.__dict__.__contains__",   ["__slots__"],      false]
    - ["re1621ct005", "re.Pattern.__dict__.__contains__", ["__dict__"],       false]
    - ["re1621ct006", "re.Match.__dict__.__contains__",   ["__dict__"],       false]
    - ["re1621ct007", "re.Pattern.__dict__.__contains__", ["pattern"],        true]
    - ["re1621ct008", "re.Pattern.__dict__.__contains__", ["flags"],          true]
    - ["re1621ct009", "re.Pattern.__dict__.__contains__", ["groups"],         true]
    - ["re1621ct010", "re.Pattern.__dict__.__contains__", ["groupindex"],     true]
    - ["re1621ct011", "re.Pattern.__dict__.__contains__", ["match"],          true]
    - ["re1621ct012", "re.Pattern.__dict__.__contains__", ["search"],         true]
    - ["re1621ct013", "re.Pattern.__dict__.__contains__", ["findall"],        true]
    - ["re1621ct014", "re.Pattern.__dict__.__contains__", ["sub"],            true]
    - ["re1621ct015", "re.Pattern.__dict__.__contains__", ["split"],          true]
    - ["re1621ct016", "re.Match.__dict__.__contains__",   ["group"],          true]
    - ["re1621ct017", "re.Match.__dict__.__contains__",   ["groups"],         true]
    - ["re1621ct018", "re.Match.__dict__.__contains__",   ["start"],          true]
    - ["re1621ct019", "re.Match.__dict__.__contains__",   ["end"],            true]
    - ["re1621ct020", "re.Match.__dict__.__contains__",   ["span"],           true]
    - ["re1621ct021", "re.Match.__dict__.__contains__",   ["re"],             true]
    - ["re1621ct022", "re.Match.__dict__.__contains__",   ["string"],         true]
    - ["re1621ct023", "re.Match.__dict__.__contains__",   ["pos"],            true]
    - ["re1621ct024", "re.Match.__dict__.__contains__",   ["endpos"],         true]
    - ["re1621ct025", "re.Match.__dict__.__contains__",   ["lastindex"],      true]
    - ["re1621ct026", "re.Match.__dict__.__contains__",   ["lastgroup"],      true]
    - ["re1621ct027", "re.Match.__dict__.__contains__",   ["regs"],           true]
    - ["re1621ct028", "re.Pattern.__dict__.__contains__", ["__repr__"],       true]
    - ["re1621ct029", "re.Match.__dict__.__contains__",   ["__repr__"],       true]
    - ["re1621ct030", "re.Pattern.__dict__.__contains__", ["fullmatch"],      true]

# ---------------------------------------------------------------------------
# Table 2: Python classes — __weakref__ present in class dict
# ---------------------------------------------------------------------------

table re_extra1621.python_classes_weakref:
  description: "re.error is a Python exception class; Python type machinery adds __weakref__ to its own class dict at creation. re.RegexFlag is an IntFlag enum; its __weakref__ presence reflects enum metaclass behavior."
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1621py

  columns: [id, function, args, expected]
  rows:
    - ["re1621py001", "re.error.__dict__.__contains__",    ["__weakref__"],   true]
    - ["re1621py002", "re.error.__dict__.__contains__",    ["__slots__"],     false]
    - ["re1621py003", "re.error.__dict__.__contains__",    ["__dict__"],      false]
    - ["re1621py004", "re.error.__dict__.__contains__",    ["__module__"],    true]
    - ["re1621py005", "re.error.__dict__.__contains__",    ["__doc__"],       true]
    - ["re1621py006", "re.error.__dict__.__contains__",    ["__init__"],      true]
    - ["re1621py007", "re.error.__dict__.__contains__",    ["__str__"],       true]
    - ["re1621py008", "re.error.__dict__.__contains__",    ["msg"],           true]
    - ["re1621py009", "re.error.__dict__.__contains__",    ["pattern"],       true]
    - ["re1621py010", "re.error.__dict__.__contains__",    ["pos"],           true]
    - ["re1621py011", "re.error.__dict__.__contains__",    ["lineno"],        true]
    - ["re1621py012", "re.error.__dict__.__contains__",    ["colno"],         true]
    - ["re1621py013", "re.RegexFlag.__dict__.__contains__", ["__weakref__"],  false]
    - ["re1621py014", "re.RegexFlag.__dict__.__contains__", ["__slots__"],    false]
    - ["re1621py015", "re.RegexFlag.__dict__.__contains__", ["__doc__"],      true]
    - ["re1621py016", "re.RegexFlag.__dict__.__contains__", ["IGNORECASE"],   true]
    - ["re1621py017", "re.RegexFlag.__dict__.__contains__", ["MULTILINE"],    true]
    - ["re1621py018", "re.RegexFlag.__dict__.__contains__", ["DOTALL"],       true]
    - ["re1621py019", "re.RegexFlag.__dict__.__contains__", ["VERBOSE"],      true]
    - ["re1621py020", "re.RegexFlag.__dict__.__contains__", ["ASCII"],        true]
    - ["re1621py021", "re.RegexFlag.__dict__.__contains__", ["UNICODE"],      true]
    - ["re1621py022", "re.RegexFlag.__dict__.__contains__", ["LOCALE"],       true]
    - ["re1621py023", "re.RegexFlag.__dict__.__contains__", ["__module__"],   true]
    - ["re1621py024", "re.error.__dict__.__contains__",    ["__weakref__"],   true]
    - ["re1621py025", "re.Pattern.__dict__.__contains__",  ["__weakref__"],   false]
    - ["re1621py026", "re.Match.__dict__.__contains__",    ["__weakref__"],   false]
    - ["re1621py027", "re.error.__dict__.__contains__",    ["__init__"],      true]
    - ["re1621py028", "re.RegexFlag.__dict__.__contains__", ["NOFLAG"],       true]
    - ["re1621py029", "re.error.__dict__.__contains__",    ["colno"],         true]
    - ["re1621py030", "re.RegexFlag.__dict__.__contains__", ["IGNORECASE"],   true]
