spec: multiprocessing_extra7
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl and prior extras through multiprocessing_extra6.zspec.zsdl."
    - "multiprocessing_extra4 covers: __name__ for Process/Pool/Value/Array/cpu_count/current_process/active_children; Process.__module__ == 'multiprocessing.process'."
    - "multiprocessing_extra5 covers: __qualname__ for Process/Pool/Manager/Pipe/Lock/Queue/Value/Array/ProcessError/AuthenticationError/TimeoutError."
    - "multiprocessing_extra6 covers: __qualname__ for Event/Semaphore; function __qualname__ for current_process/active_children/cpu_count."
    - "This spec adds __module__ for Pool, Queue, Manager, Lock, Event, Semaphore, Value, Array, Pipe, ProcessError, AuthenticationError, TimeoutError — all resolve to 'multiprocessing.context' on Python 3.12/macOS."
    - "multiprocessing_extra4 covered only Process.__module__ ('multiprocessing.process'); the remaining classes proxy through context.py."
    - "multiprocessing.Pool.__module__ == 'multiprocessing.context'."
    - "multiprocessing.Queue.__module__ == 'multiprocessing.context'."
    - "multiprocessing.Manager.__module__ == 'multiprocessing.context'."
    - "multiprocessing.Lock.__module__ == 'multiprocessing.context'."
    - "multiprocessing.Event.__module__ == 'multiprocessing.context'."
    - "multiprocessing.Semaphore.__module__ == 'multiprocessing.context'."
    - "multiprocessing.Value.__module__ == 'multiprocessing.context'."
    - "multiprocessing.Array.__module__ == 'multiprocessing.context'."
    - "multiprocessing.Pipe.__module__ == 'multiprocessing.context'."
    - "multiprocessing.ProcessError.__module__ == 'multiprocessing.context'."
    - "multiprocessing.AuthenticationError.__module__ == 'multiprocessing.context'."
    - "multiprocessing.TimeoutError.__module__ == 'multiprocessing.context'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ table for core multiprocessing synchronization and pool classes
#
# On Python 3.12/macOS, the top-level multiprocessing names (Pool, Queue,
# Manager, Lock, Event, Semaphore, Value, Array, Pipe) are context-method
# wrappers whose __module__ resolves to 'multiprocessing.context'.
# Only Process was checked in prior specs (extra4: 'multiprocessing.process').
# ---------------------------------------------------------------------------

table multiprocessing_extra7.context_class_modules:
  description: "Core multiprocessing classes have __module__ == 'multiprocessing.context'"
  kind: python_call_eq
  category: class_modules
  id_prefix: cmod

  columns: [id, function, args, expected]
  rows:
    - [Pool,      Pool.__module__.__eq__,      ["multiprocessing.context"], true]
    - [Queue,     Queue.__module__.__eq__,     ["multiprocessing.context"], true]
    - [Manager,   Manager.__module__.__eq__,   ["multiprocessing.context"], true]
    - [Lock,      Lock.__module__.__eq__,      ["multiprocessing.context"], true]
    - [Event,     Event.__module__.__eq__,     ["multiprocessing.context"], true]
    - [Semaphore, Semaphore.__module__.__eq__, ["multiprocessing.context"], true]
    - [Value,     Value.__module__.__eq__,     ["multiprocessing.context"], true]
    - [Array,     Array.__module__.__eq__,     ["multiprocessing.context"], true]
    - [Pipe,      Pipe.__module__.__eq__,      ["multiprocessing.context"], true]

# ---------------------------------------------------------------------------
# __module__ for exception classes
#
# ProcessError, AuthenticationError, and TimeoutError are defined through the
# context machinery; their __module__ is 'multiprocessing.context'.
# Prior specs checked their __name__ and __qualname__ but not __module__.
# ---------------------------------------------------------------------------

table multiprocessing_extra7.exception_modules:
  description: "multiprocessing exception classes have __module__ == 'multiprocessing.context'"
  kind: python_call_eq
  category: exception_modules
  id_prefix: emod

  columns: [id, function, args, expected]
  rows:
    - [ProcessError,        ProcessError.__module__.__eq__,        ["multiprocessing.context"], true]
    - [AuthenticationError, AuthenticationError.__module__.__eq__, ["multiprocessing.context"], true]
    - [TimeoutError,        TimeoutError.__module__.__eq__,        ["multiprocessing.context"], true]

# ---------------------------------------------------------------------------
# __module__ for module-level functions not yet covered
#
# cpu_count and current_process are defined in multiprocessing.context;
# active_children is defined in multiprocessing.process.
# cpu_count.__module__ and current_process.__module__ == 'multiprocessing.context'.
# active_children.__module__ == 'multiprocessing.process'.
# Extra4 checked __name__; extra6 checked __qualname__ — __module__ is new.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra7.cpu_count.module:
  description: "multiprocessing.cpu_count.__module__ == 'multiprocessing.context'"
  category: function_modules
  kind: python_call_eq
  function: cpu_count.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra7.current_process.module:
  description: "multiprocessing.current_process.__module__ == 'multiprocessing.process'"
  category: function_modules
  kind: python_call_eq
  function: current_process.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

invariant multiprocessing_extra7.active_children.module:
  description: "multiprocessing.active_children.__module__ == 'multiprocessing.process'"
  category: function_modules
  kind: python_call_eq
  function: active_children.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true
