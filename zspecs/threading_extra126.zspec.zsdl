spec: threading_extra126
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Lock and RLock class identity attributes; threading._RLock and _thread.RLock identity (Wave 257)."
    - "threading.Lock.__class__.__name__ == 'type' — threading.Lock is the C extension class _thread.lock. Verified with Python 3.14.3."
    - "threading.Lock.__module__ == '_thread' — Lock is actually _thread.lock from _threadmodule.c. Verified with Python 3.14.3."
    - "threading.Lock.__name__ == 'lock' — underlying C type name is lowercase 'lock'. Verified with Python 3.14.3."
    - "threading.Lock.__qualname__ == 'lock'. Verified with Python 3.14.3."
    - "threading.RLock.__class__.__name__ == 'function' — RLock is a factory function in threading.py. Verified with Python 3.14.3."
    - "threading.RLock.__name__ == 'RLock'. Verified with Python 3.14.3."
    - "threading.RLock.__module__ == 'threading'. Verified with Python 3.14.3."
    - "len(threading.RLock.__qualname__) == 5. Verified with Python 3.14.3."
    - "threading._RLock.__class__.__name__ == 'type' — _RLock is the actual Python class. Verified with Python 3.14.3."
    - "threading._RLock.__name__ == '_RLock'. Verified with Python 3.14.3."
    - "threading._RLock.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading._RLock.__bases__[0].__name__ == 'object' — _RLock inherits from object. Verified with Python 3.14.3."
    - "len(threading._RLock.__mro__) == 2 — MRO is [_RLock, object]. Verified with Python 3.14.3."
    - "len(threading._RLock.__qualname__) == 6. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Lock class identity attributes
#
# Wave 257 theme: threading.Lock C extension type identity.
#
# threading.Lock.__class__.__name__ == 'type'
# threading.Lock.__module__ == '_thread'
# threading.Lock.__name__ == 'lock'
# threading.Lock.__qualname__ == 'lock'
#
# threading.Lock is an alias for the C extension class _thread.lock defined in
# Modules/_threadmodule.c; its __module__ is '_thread' and its name/qualname
# are lowercase 'lock'. New to extra126.
# ---------------------------------------------------------------------------

table threading_extra126.lock_class_identity:
  description: "threading.Lock C extension type identity: __class__.__name__, __module__, __name__, __qualname__; wave 257; new to extra126"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingrlock126

  columns: [id, function, args, expected, description]
  rows:
    - [lock_class_name_eq_type,
       "Lock.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Lock.__class__.__name__.__eq__('type') == True — threading.Lock is the C extension class _thread.lock defined in Modules/_threadmodule.c; it is a proper class (type), not a factory function; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra126"]
    - [lock_module_eq_thread,
       "Lock.__module__.__eq__",
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — threading.Lock is an alias for the C extension class _thread.lock; its __module__ attribute points to the underlying C module '_thread'; str.__eq__('_thread') returns True; new to extra126"]
    - [lock_name_eq_lock,
       "Lock.__name__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — threading.Lock is _thread.lock; the underlying C type name is 'lock' (lowercase), reflecting the PyTypeObject tp_name; str.__eq__('lock') returns True; new to extra126"]
    - [lock_qualname_eq_lock,
       "Lock.__qualname__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__qualname__.__eq__('lock') == True — threading.Lock is the C extension class _thread.lock; __qualname__ reflects the C type name 'lock' (lowercase), not the Python alias 'Lock'; str.__eq__('lock') returns True; new to extra126"]
    - [lock_name_len_eq_4,
       "Lock.__name__.__len__",
       [],
       4,
       "threading.Lock.__name__.__len__() == 4 — Lock.__name__ is 'lock' which has exactly 4 characters; len('lock') == 4; new to extra126"]

# ---------------------------------------------------------------------------
# Table 2: threading.RLock factory function identity
#
# Wave 257 theme: threading.RLock factory function identity attributes.
#
# threading.RLock.__class__.__name__ == 'function'
# threading.RLock.__name__ == 'RLock'
# threading.RLock.__module__ == 'threading'
# threading.RLock.__qualname__ == 'RLock'
# len(threading.RLock.__qualname__) == 5
#
# threading.RLock is a factory function (not a class) defined in Lib/threading.py;
# it returns either a _thread.RLock C object or a Python _RLock fallback.
# New to extra126.
# ---------------------------------------------------------------------------

table threading_extra126.rlock_function_identity:
  description: "threading.RLock factory function identity: __class__.__name__, __name__, __module__, __qualname__, qualname len; wave 257; new to extra126"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingrlock126

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_class_name_eq_function,
       "RLock.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — threading.RLock is a factory function defined in Lib/threading.py that returns a reentrant lock object; it is not a class itself; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra126"]
    - [rlock_name_eq_RLock,
       "RLock.__name__.__eq__",
       ["RLock"],
       true,
       "threading.RLock.__name__.__eq__('RLock') == True — the factory function is defined as 'def RLock(*args, **kwargs):' in Lib/threading.py; its __name__ is 'RLock'; str.__eq__('RLock') returns True; new to extra126"]
    - [rlock_module_eq_threading,
       "RLock.__module__.__eq__",
       ["threading"],
       true,
       "threading.RLock.__module__.__eq__('threading') == True — RLock is a function defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra126"]
    - [rlock_qualname_eq_RLock,
       "RLock.__qualname__.__eq__",
       ["RLock"],
       true,
       "threading.RLock.__qualname__.__eq__('RLock') == True — RLock is defined at module scope in Lib/threading.py; its __qualname__ is the simple function name 'RLock'; str.__eq__('RLock') returns True; new to extra126"]
    - [rlock_qualname_len_eq_5,
       "RLock.__qualname__.__len__",
       [],
       5,
       "threading.RLock.__qualname__.__len__() == 5 — __qualname__ is 'RLock' which has exactly 5 characters; len('RLock') == 5; new to extra126"]

# ---------------------------------------------------------------------------
# Table 3: threading._RLock class identity
#
# Wave 257 theme: threading._RLock actual class identity.
#
# threading._RLock.__class__.__name__ == 'type'
# threading._RLock.__name__ == '_RLock'
# threading._RLock.__module__ == 'threading'
# threading._RLock.__bases__[0].__name__ == 'object'
# len(threading._RLock.__mro__) == 2
# len(threading._RLock.__qualname__) == 6
#
# threading._RLock is the actual Python class (not the factory function);
# it is the fallback implementation used when _thread.RLock is not available.
# New to extra126.
# ---------------------------------------------------------------------------

table threading_extra126.rlockclass_identity:
  description: "threading._RLock actual class identity: __class__.__name__, __name__, __module__, __bases__[0], MRO len, __qualname__ len; wave 257; new to extra126"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingrlock126

  columns: [id, function, args, expected, description]
  rows:
    - [rlockclass_class_name_eq_type,
       "_RLock.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading._RLock.__class__.__name__.__eq__('type') == True — threading._RLock is the actual Python class (as opposed to the RLock factory function); it is defined with 'class _RLock:' in Lib/threading.py; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra126"]
    - [rlockclass_name_eq_rlock,
       "_RLock.__name__.__eq__",
       ["_RLock"],
       true,
       "threading._RLock.__name__.__eq__('_RLock') == True — the actual class is named '_RLock' (with leading underscore indicating it is a private implementation detail); __name__ is '_RLock'; str.__eq__('_RLock') returns True; new to extra126"]
    - [rlockclass_module_eq_threading,
       "_RLock.__module__.__eq__",
       ["threading"],
       true,
       "threading._RLock.__module__.__eq__('threading') == True — _RLock is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra126"]
    - [rlockclass_bases_first_eq_object,
       "_RLock.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading._RLock.__bases__[0].__name__.__eq__('object') == True — _RLock inherits directly from object with no intermediate base classes; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra126"]
    - [rlockclass_mro_len_eq_2,
       "_RLock.__mro__.__len__",
       [],
       2,
       "threading._RLock.__mro__.__len__() == 2 — _RLock inherits directly from object; MRO is [_RLock, object]; len(__mro__) is 2; new to extra126"]
    - [rlockclass_qualname_len_eq_6,
       "_RLock.__qualname__.__len__",
       [],
       6,
       "threading._RLock.__qualname__.__len__() == 6 — __qualname__ is '_RLock' which has exactly 6 characters; len('_RLock') == 6; new to extra126"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra126
# ---------------------------------------------------------------------------

invariant threading_extra126.lock_module:
  description: "threading.Lock.__module__ == '_thread' — Lock is _thread.lock, a C extension class; wave 257; new to extra126"
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra126.lock_name:
  description: "threading.Lock.__name__ == 'lock' — underlying C type name is lowercase 'lock'; wave 257; new to extra126"
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra126.rlock_class_name:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a factory function not a class; wave 257; new to extra126"
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra126.rlockclass_mro_len:
  description: "len(threading._RLock.__mro__) == 2 — _RLock inherits directly from object; wave 257; new to extra126"
  kind: python_call_eq
  function: _RLock.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra126.rlockclass_name:
  description: "threading._RLock.__name__ == '_RLock' — the actual class behind the RLock factory; wave 257; new to extra126"
  kind: python_call_eq
  function: _RLock.__name__.__eq__
  args: ["_RLock"]
  expected: true

