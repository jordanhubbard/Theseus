    - [dc1471gd002, decimal.Context.__dict__.__contains__, ["__getitem__"], false]
    - [dc1471gd003, decimal.Decimal.__dict__.__contains__, ["__getitem__"], false]
    - [dc1471gd004, decimal.Context.__dict__.__contains__, ["__getitem__"], false]
    - [dc1471gd005, decimal.Decimal.__dict__.__contains__, ["__getitem__"], false]
    - [dc1471gd006, decimal.Context.__dict__.__contains__, ["__getitem__"], false]

table decimal_extra1471.exceptions_len_getitem_not_in_dict:
  description: "decimal exception classes __dict__ membership for __len__ and __getitem__ — DecimalException, InvalidOperation, Overflow, and Underflow do not define __len__ or __getitem__ in their own __dict__; decimal exceptions are exception subclasses and not sequences; all return False; verified with Python 3.14.4"
  kind: python_call_eq
  category: exceptions_dict_membership
  id_prefix: dc1471ed
  columns: [id, function, args, expected]
  rows:
