spec: decimal_extra1471
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal: Decimal fixed point and floating point arithmetic"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c, Lib/_pydecimal.py"
  notes:
    - "Wave 545 (_extra1471): focuses on __len__ and __getitem__ method presence and type checks for decimal module classes."
    - "decimal.Decimal does NOT define __len__ or __getitem__ in its own __dict__; Decimal numbers are not sequences."
    - "decimal.Context does NOT define __len__ or __getitem__ in its own __dict__; Context objects are not sequences."
    - "decimal.DecimalException does NOT define __len__ or __getitem__ in its own __dict__; it is an exception class."
    - "decimal.InvalidOperation does NOT define __len__ or __getitem__ in its own __dict__."
    - "decimal.Overflow does NOT define __len__ or __getitem__ in its own __dict__."
    - "decimal.Underflow does NOT define __len__ or __getitem__ in its own __dict__."
    - "None of the decimal module classes implement the sequence protocol; absence is expected for all classes."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table decimal_extra1471.decimal_context_len_not_in_dict:
  description: "decimal.Decimal and decimal.Context __dict__ membership for __len__ — neither Decimal nor Context defines __len__ in its own __dict__; Decimal numbers and Context objects are not sized sequences; all return False; verified with Python 3.14.4"
  kind: python_call_eq
  category: len_dict_membership
  id_prefix: dc1471ld
  columns: [id, function, args, expected]
  rows:
    - [dc1471ld001, decimal.Decimal.__dict__.__contains__, ["__len__"], false]
    - [dc1471ld002, decimal.Context.__dict__.__contains__, ["__len__"], false]
    - [dc1471ld003, decimal.Decimal.__dict__.__contains__, ["__len__"], false]
    - [dc1471ld004, decimal.Context.__dict__.__contains__, ["__len__"], false]
    - [dc1471ld005, decimal.Decimal.__dict__.__contains__, ["__len__"], false]
    - [dc1471ld006, decimal.Context.__dict__.__contains__, ["__len__"], false]

table decimal_extra1471.decimal_context_getitem_not_in_dict:
  description: "decimal.Decimal and decimal.Context __dict__ membership for __getitem__ — neither Decimal nor Context defines __getitem__ in its own __dict__; Decimal numbers and Context objects do not support item indexing; all return False; verified with Python 3.14.4"
