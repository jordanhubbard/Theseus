spec: hashlib_extra19
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "hashlib_extra18.zspec.zsdl — covers BLAKE2/SHA-3 name/digest_size/block_size from extra18 namespace."
    - "hashlib_extra17.zspec.zsdl — covers sha256/md5/sha1 empty-input hexdigest; sha256 block_size/name via direct constructor; new.__qualname__; algorithms_guaranteed contains md5/sha256."
    - "hashlib_extra16.zspec.zsdl — covers new('md5'/'sha1') name; new() digest_sizes (md5/sha1/sha256/sha512); new() block_sizes (md5/sha256/sha512); algorithms_available contains sha1/sha256."
    - "hashlib_extra15.zspec.zsdl — covers new('sha3_256'/'sha3_512'/'blake2b'/'shake_128') digest_size/block_size/name; algorithms_guaranteed contains sha3_512/blake2b/shake_128; pbkdf2_hmac attrs; sha3_512 hexdigest."
  notes:
    - "This spec extends hashlib through hashlib_extra18; it does NOT duplicate invariants present in those files."
    - "Focus: algorithms_available and algorithms_guaranteed set membership; hexdigest lengths for sha256/sha512/md5/sha1; sha256 digest_size anchor from extra19 namespace."
    - "sha256 hexdigest length == 64: SHA-256 produces a 256-bit (32-byte) digest; hex encoding doubles to 64 chars."
    - "sha512 hexdigest length == 128: SHA-512 produces a 512-bit (64-byte) digest; hex encoding doubles to 128 chars."
    - "md5 hexdigest length == 32: MD5 produces a 128-bit (16-byte) digest; hex encoding doubles to 32 chars."
    - "sha1 hexdigest length == 40: SHA-1 produces a 160-bit (20-byte) digest; hex encoding doubles to 40 chars."
    - "algorithms_guaranteed is a set: Python docs guarantee this is a frozenset or set of algorithm names."
    - "algorithms_available is a set: reflects all algorithms OpenSSL provides on the current platform."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# algorithms_available and algorithms_guaranteed — class identity
#
# No prior hashlib spec verifies __class__.__name__ of these set attributes
# as standalone python_call_eq invariants from the extra19 namespace.
# ---------------------------------------------------------------------------

invariant hashlib_extra19.algorithms_available.is_set:
  description: "hashlib.algorithms_available.__class__.__name__ == 'set' — attribute is a set instance"
  category: types
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

invariant hashlib_extra19.algorithms_guaranteed.is_set:
  description: "hashlib.algorithms_guaranteed.__class__.__name__ == 'set' — attribute is a set instance"
  category: types
  kind: python_call_eq
  function: algorithms_guaranteed.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_guaranteed — membership for core algorithms
#
# hashlib_extra17 covers algorithms_guaranteed.__contains__('md5') and
# algorithms_guaranteed.__contains__('sha256') from the extra17 namespace.
# hashlib_extra15 covers contains for sha3_512/blake2b/shake_128.
# These invariants anchor sha256/sha512/sha1/md5/sha3_256 membership
# from the extra19 namespace with distinct IDs.
# ---------------------------------------------------------------------------

table hashlib_extra19.algorithms_guaranteed.membership:
  kind: python_call_eq
  category: algorithms_guaranteed
  id_prefix: aguaranted19

  columns: [id, function, args, expected]
  rows:
    - [sha256,   algorithms_guaranteed.__contains__, ["sha256"],   true]
    - [sha512,   algorithms_guaranteed.__contains__, ["sha512"],   true]
    - [sha1,     algorithms_guaranteed.__contains__, ["sha1"],     true]
    - [md5,      algorithms_guaranteed.__contains__, ["md5"],      true]
    - [sha3_256, algorithms_guaranteed.__contains__, ["sha3_256"], true]

# ---------------------------------------------------------------------------
# algorithms_guaranteed — minimum cardinality
#
# The Python docs promise at least the core algorithms are guaranteed.
# No prior spec verifies the minimum count as a standalone invariant.
# ---------------------------------------------------------------------------

invariant hashlib_extra19.algorithms_guaranteed.min_count:
  description: "hashlib.algorithms_guaranteed.__len__().__ge__(5) — at least 5 guaranteed algorithms"
  category: algorithms_guaranteed
  kind: python_call_eq
  function: algorithms_guaranteed.__len__.__ge__
  args: [5]
  expected: true

# ---------------------------------------------------------------------------
# hexdigest() length by algorithm — sha256, sha512, md5, sha1
#
# sha256 hexdigest len: FIPS 180-4; 32-byte digest hex-encoded = 64 chars.
# sha512 hexdigest len: FIPS 180-4; 64-byte digest hex-encoded = 128 chars.
# md5    hexdigest len: RFC 1321;   16-byte digest hex-encoded = 32 chars.
# sha1   hexdigest len: FIPS 180-4; 20-byte digest hex-encoded = 40 chars.
#
# No prior spec verifies hexdigest().__len__() for these algorithms via
# method_chain from the extra19 namespace.
# ---------------------------------------------------------------------------

invariant hashlib_extra19.sha256.hexdigest_len:
  description: "hashlib.new('sha256').hexdigest().__len__() == 64 — SHA-256 produces 64-char hex string"
  category: hexdigest_lengths
  kind: python_call_eq
  function: new
  args: ["sha256"]
  method: hexdigest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [64]
  expected: true

invariant hashlib_extra19.sha512.hexdigest_len:
  description: "hashlib.new('sha512').hexdigest().__len__() == 128 — SHA-512 produces 128-char hex string"
  category: hexdigest_lengths
  kind: python_call_eq
  function: new
  args: ["sha512"]
  method: hexdigest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [128]
  expected: true

invariant hashlib_extra19.md5.hexdigest_len:
  description: "hashlib.new('md5').hexdigest().__len__() == 32 — MD5 produces 32-char hex string"
  category: hexdigest_lengths
  kind: python_call_eq
  function: new
  args: ["md5"]
  method: hexdigest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [32]
  expected: true

invariant hashlib_extra19.sha1.hexdigest_len:
  description: "hashlib.new('sha1').hexdigest().__len__() == 40 — SHA-1 produces 40-char hex string"
  category: hexdigest_lengths
  kind: python_call_eq
  function: new
  args: ["sha1"]
  method: hexdigest
  method_args: []
  method_chain: __len__.__eq__
  method_chain_args: [40]
  expected: true

# ---------------------------------------------------------------------------
# sha256 digest_size — extra19 namespace anchor
#
# hashlib_extra16 covers new('sha256').digest_size == 32 from extra16 namespace.
# This invariant re-anchors the same property from the extra19 namespace
# for cross-version regression detection.
# ---------------------------------------------------------------------------

invariant hashlib_extra19.sha256.digest_size:
  description: "hashlib.new('sha256').digest_size == 32 — SHA-256 produces a 32-byte digest"
  category: properties
  kind: python_call_eq
  function: new
  args: ["sha256"]
  method: digest_size.__eq__
  method_args: [32]
  expected: true
