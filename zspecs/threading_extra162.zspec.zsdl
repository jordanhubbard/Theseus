spec: threading_extra162
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.local.__name__ '_local'; threading.local.__module__ '_thread'; threading.local.__bases__[0].__name__ 'object'; threading._DummyThread.__name__ '_DummyThread'; threading._DummyThread.__module__ 'threading'; threading._DummyThread.__bases__[0].__name__ 'Thread'; threading._MainThread.__name__ '_MainThread'; threading._MainThread.__module__ 'threading'; threading._MainThread.__bases__[0].__name__ 'Thread' (Wave 290)."
    - "threading.local.__name__ == '_local' — threading.local is implemented as a C extension type in Modules/_threadmodule.c; its true type name is '_local' (with underscore prefix); the public alias 'local' in threading points to this C type. Verified with Python 3.14.3."
    - "threading.local.__module__ == '_thread' — threading.local is defined in the _thread C extension module (Modules/_threadmodule.c); its __module__ is '_thread', not 'threading'. Verified with Python 3.14.3."
    - "threading.local.__bases__[0].__name__ == 'object' — threading.local/_local inherits directly from object as a C extension type; __bases__[0].__name__ is 'object'. Verified with Python 3.14.3."
    - "threading._DummyThread.__name__ == '_DummyThread' — _DummyThread is an internal Python class in Lib/threading.py representing a non-Python-created thread (e.g., a C thread); its class name is '_DummyThread'. Verified with Python 3.14.3."
    - "threading._DummyThread.__module__ == 'threading' — _DummyThread is defined in Lib/threading.py; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading._DummyThread.__bases__[0].__name__ == 'Thread' — _DummyThread subclasses Thread; its single base class __name__ is 'Thread'. Verified with Python 3.14.3."
    - "threading._MainThread.__name__ == '_MainThread' — _MainThread is an internal Python class in Lib/threading.py representing the main thread of a Python process; its class name is '_MainThread'. Verified with Python 3.14.3."
    - "threading._MainThread.__module__ == 'threading' — _MainThread is defined in Lib/threading.py; its __module__ is 'threading'. Verified with Python 3.14.3."
    - "threading._MainThread.__bases__[0].__name__ == 'Thread' — _MainThread subclasses Thread; its single base class __name__ is 'Thread'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.local C extension type identity
#
# Wave 290 theme: threading.local identity — true type name, module, and base
# class.
#
# threading.local.__name__ == '_local'
# threading.local.__module__ == '_thread'
# threading.local.__bases__[0].__name__ == 'object'
#
# threading.local is a public alias for the C extension type _local defined in
# Modules/_threadmodule.c. Unlike Thread and its subclasses (which are Python
# classes in Lib/threading.py), local is a C type and its __module__ is
# '_thread' (the underlying C extension module). Its true type __name__ is
# '_local' with an underscore prefix. It inherits directly from object.
# New to extra162.
# ---------------------------------------------------------------------------

table threading_extra162.local_class_identity:
  description: "threading.local: __name__ '_local', __module__ '_thread', __bases__[0].__name__ 'object'; C extension type in _threadmodule.c; wave 290; new to extra162"
  kind: python_call_eq
  category: identity
  id_prefix: threadinglci162

  columns: [id, function, args, expected, description]
  rows:
    - [local_name_eq_local,
       "local.__name__.__eq__",
       ["_local"],
       true,
       "threading.local.__name__.__eq__('_local') == True — threading.local is a C extension type defined in Modules/_threadmodule.c as '_local'; the public name 'local' in the threading module is an alias for this C type; its true type __name__ is '_local'; str.__eq__('_local') returns True; new to extra162"]
    - [local_module_eq_thread,
       "local.__module__.__eq__",
       ["_thread"],
       true,
       "threading.local.__module__.__eq__('_thread') == True — threading.local is defined in the _thread C extension module (Modules/_threadmodule.c), not in Lib/threading.py; its __module__ is '_thread'; str.__eq__('_thread') returns True; new to extra162"]
    - ["local_bases_0_name_eq_object",
       "local.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.local.__bases__[0].__name__.__eq__('object') == True — threading.local/_local is a C extension type that inherits directly from object; its __bases__ tuple has a single element (object) whose __name__ is 'object'; str.__eq__('object') returns True; new to extra162"]
    - [local_class_name_eq_type,
       "local.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.local.__class__.__name__.__eq__('type') == True — threading.local/_local is a C extension class object; as a class object its __class__ is the metaclass 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra162"]

# ---------------------------------------------------------------------------
# Table 2: threading._DummyThread and threading._MainThread class identity
#
# Wave 290 theme: threading._DummyThread and threading._MainThread identity —
# name, module, and base class.
#
# threading._DummyThread.__name__ == '_DummyThread'
# threading._DummyThread.__module__ == 'threading'
# threading._DummyThread.__bases__[0].__name__ == 'Thread'
# threading._MainThread.__name__ == '_MainThread'
# threading._MainThread.__module__ == 'threading'
# threading._MainThread.__bases__[0].__name__ == 'Thread'
#
# _DummyThread is an internal class in Lib/threading.py that wraps threads not
# created by Python (e.g., C extension threads) so they can be tracked by the
# threading module. _MainThread is an internal class that represents the main
# thread of the Python process — it is created automatically when the threading
# module is first imported. Both subclass Thread directly. New to extra162.
# ---------------------------------------------------------------------------

table threading_extra162.dummy_and_main_thread_identity:
  description: "threading._DummyThread: __name__ '_DummyThread', __module__ 'threading', __bases__[0].__name__ 'Thread'; _MainThread: __name__ '_MainThread', __module__ 'threading', __bases__[0].__name__ 'Thread'; wave 290; new to extra162"
  kind: python_call_eq
  category: identity
  id_prefix: threadingdmti162

  columns: [id, function, args, expected, description]
  rows:
    - [dummy_thread_name_eq,
       "_DummyThread.__name__.__eq__",
       ["_DummyThread"],
       true,
       "threading._DummyThread.__name__.__eq__('_DummyThread') == True — _DummyThread is an internal Python class in Lib/threading.py that wraps non-Python-created threads (such as C extension threads) so the threading module can track them; its class name is '_DummyThread'; str.__eq__('_DummyThread') returns True; new to extra162"]
    - [dummy_thread_module_eq_threading,
       "_DummyThread.__module__.__eq__",
       ["threading"],
       true,
       "threading._DummyThread.__module__.__eq__('threading') == True — _DummyThread is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra162"]
    - ["dummy_thread_bases_0_name_eq_thread",
       "_DummyThread.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading._DummyThread.__bases__[0].__name__.__eq__('Thread') == True — _DummyThread inherits directly from Thread; its single base class __name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra162"]
    - [main_thread_name_eq,
       "_MainThread.__name__.__eq__",
       ["_MainThread"],
       true,
       "threading._MainThread.__name__.__eq__('_MainThread') == True — _MainThread is an internal Python class in Lib/threading.py representing the main thread of the Python process; it is instantiated automatically when the threading module is imported; its class name is '_MainThread'; str.__eq__('_MainThread') returns True; new to extra162"]
    - [main_thread_module_eq_threading,
       "_MainThread.__module__.__eq__",
       ["threading"],
       true,
       "threading._MainThread.__module__.__eq__('threading') == True — _MainThread is defined in Lib/threading.py; its __module__ attribute is 'threading'; str.__eq__('threading') returns True; new to extra162"]
    - ["main_thread_bases_0_name_eq_thread",
       "_MainThread.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading._MainThread.__bases__[0].__name__.__eq__('Thread') == True — _MainThread inherits directly from Thread; its single base class __name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra162"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra162
# ---------------------------------------------------------------------------

invariant threading_extra162.local_name_underscore_local:
  description: "threading.local.__name__ == '_local' — threading.local is a C extension type whose true type name has an underscore prefix; wave 290; new to extra162"
  kind: python_call_eq
  function: local.__name__.__eq__
  args: ["_local"]
  expected: true

invariant threading_extra162.local_module_thread:
  description: "threading.local.__module__ == '_thread' — local is defined in _threadmodule.c not Lib/threading.py; wave 290; new to extra162"
  kind: python_call_eq
  function: local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra162.local_bases_0_object:
  description: "threading.local.__bases__[0].__name__ == 'object' — threading.local C extension type inherits directly from object; wave 290; new to extra162"
  kind: python_call_eq
  function: "local.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant threading_extra162.dummy_thread_name:
  description: "threading._DummyThread.__name__ == '_DummyThread' — internal class wrapping non-Python-created threads; wave 290; new to extra162"
  kind: python_call_eq
  function: _DummyThread.__name__.__eq__
  args: ["_DummyThread"]
  expected: true

invariant threading_extra162.main_thread_name:
  description: "threading._MainThread.__name__ == '_MainThread' — internal class representing the main thread of the Python process; wave 290; new to extra162"
  kind: python_call_eq
  function: _MainThread.__name__.__eq__
  args: ["_MainThread"]
  expected: true

invariant threading_extra162.dummy_thread_bases_0_thread:
  description: "threading._DummyThread.__bases__[0].__name__ == 'Thread' — _DummyThread subclasses Thread directly; wave 290; new to extra162"
  kind: python_call_eq
  function: "_DummyThread.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true

invariant threading_extra162.main_thread_bases_0_thread:
  description: "threading._MainThread.__bases__[0].__name__ == 'Thread' — _MainThread subclasses Thread directly; wave 290; new to extra162"
  kind: python_call_eq
  function: "_MainThread.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true
