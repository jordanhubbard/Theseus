spec: pathlib_extra30
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra28.zspec.zsdl — covers __qualname__ for Path.read_text/write_text/resolve/iterdir and Path.is_absolute."
    - "pathlib_extra29.zspec.zsdl — covers __qualname__ for Path.stat/chmod/exists/is_file/is_dir/mkdir/rename/unlink/open."
    - "pathlib_extra4.zspec.zsdl — covers __name__ for Path.read_text/write_text/iterdir/glob/rglob."
  notes:
    - "This spec extends pathlib_extra29.zspec.zsdl."
    - "Focus: __qualname__ values for Path instance methods not yet covered in any prior spec: read_bytes, write_bytes, glob, rglob, absolute."
    - "Path.read_bytes.__qualname__ == 'Path.read_bytes' — instance method qualname includes class prefix."
    - "Path.write_bytes.__qualname__ == 'Path.write_bytes' — instance method qualname includes class prefix."
    - "Path.glob.__qualname__ == 'Path.glob' — instance method qualname includes class prefix."
    - "Path.rglob.__qualname__ == 'Path.rglob' — instance method qualname includes class prefix."
    - "Path.absolute.__qualname__ == 'Path.absolute' — instance method qualname includes class prefix."
    - "pathlib_extra4 covers __name__ for glob/rglob but not __qualname__; this spec fills that gap."
    - "pathlib_extra4 covers __name__ for read_text/write_text but not read_bytes/write_bytes; this spec adds read_bytes/write_bytes __qualname__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__ for Path methods not yet covered in prior specs
#
# pathlib_extra28 covers read_text/write_text/resolve/iterdir __qualname__.
# pathlib_extra4 covers glob/rglob/read_text/write_text __name__ (not __qualname__).
# No prior pathlib spec covers __qualname__ for read_bytes, write_bytes,
# glob, rglob, or absolute. For all, __qualname__ == 'Path.<method_name>'.
# Verified: read_bytes='Path.read_bytes', write_bytes='Path.write_bytes',
#           glob='Path.glob', rglob='Path.rglob', absolute='Path.absolute'.
# ---------------------------------------------------------------------------

table pathlib_extra30.path_extra_method_qualnames:
  description: "__qualname__ for Path instance methods read_bytes/write_bytes/glob/rglob/absolute"
  kind: python_call_eq
  category: method_identity
  id_prefix: pemq30

  columns: [id, function, args, expected]
  rows:
    - [read_bytes,  Path.read_bytes.__qualname__.__eq__,  ["Path.read_bytes"],  true]
    - [write_bytes, Path.write_bytes.__qualname__.__eq__, ["Path.write_bytes"], true]
    - [glob,        Path.glob.__qualname__.__eq__,        ["Path.glob"],        true]
    - [rglob,       Path.rglob.__qualname__.__eq__,       ["Path.rglob"],       true]
    - [absolute,    Path.absolute.__qualname__.__eq__,    ["Path.absolute"],    true]

# ---------------------------------------------------------------------------
# Standalone: Path.read_bytes.__qualname__ — binary read helper
#
# pathlib_extra4 covers Path.read_text.__name__ but not Path.read_bytes in
# any form. read_bytes is the binary counterpart to read_text, returning raw
# bytes from the file. Its qualname carries the standard 'Path.<method>'
# prefix since it is defined directly on Path.
# Verified: pathlib.Path.read_bytes.__qualname__ == 'Path.read_bytes'
# ---------------------------------------------------------------------------

invariant pathlib_extra30.Path.read_bytes.qualname:
  description: "pathlib.Path.read_bytes.__qualname__ == 'Path.read_bytes' — binary read helper defined on Path; qualname includes class prefix"
  category: method_identity
  kind: python_call_eq
  function: Path.read_bytes.__qualname__.__eq__
  args: ["Path.read_bytes"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: Path.glob.__qualname__ — pattern-based traversal
#
# pathlib_extra4 records Path.glob.__name__ == 'glob' but does not cover
# Path.glob.__qualname__. The qualname carries the 'Path.glob' prefix,
# distinguishing it as an instance method rather than a module-level
# function (unlike glob.glob whose __qualname__ == 'glob').
# Verified: pathlib.Path.glob.__qualname__ == 'Path.glob'
# ---------------------------------------------------------------------------

invariant pathlib_extra30.Path.glob.qualname:
  description: "pathlib.Path.glob.__qualname__ == 'Path.glob' — instance method qualname includes class prefix, unlike top-level glob.glob"
  category: method_identity
  kind: python_call_eq
  function: Path.glob.__qualname__.__eq__
  args: ["Path.glob"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone: Path.absolute.__qualname__ — returns absolute path
#
# absolute() resolves the path to an absolute path without resolving symlinks
# (unlike resolve()). No prior pathlib spec covers Path.absolute.__qualname__.
# pathlib_extra28 covers Path.resolve.__qualname__ but not absolute.
# Verified: pathlib.Path.absolute.__qualname__ == 'Path.absolute'
# ---------------------------------------------------------------------------

invariant pathlib_extra30.Path.absolute.qualname:
  description: "pathlib.Path.absolute.__qualname__ == 'Path.absolute' — makes path absolute without resolving symlinks; qualname includes class prefix"
  category: method_identity
  kind: python_call_eq
  function: Path.absolute.__qualname__.__eq__
  args: ["Path.absolute"]
  expected: true
