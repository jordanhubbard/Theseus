spec: concurrent_futures
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "concurrent.futures source: internal thread/process pool implementation"
  notes:
    - "concurrent.futures.Future() creates a pending future; done(), cancelled(), running() all return False."
    - "FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are string constants used with wait()."
    - "ThreadPoolExecutor.submit() returns a Future that is done after result() is called."
    - "CancelledError and TimeoutError are the primary exception types for future state errors."
    - "BrokenExecutor is the base class for executor-level errors (e.g. BrokenThreadPool)."
    - "InvalidStateError (Python 3.8+) is raised when a future is set to a result/exception in an invalid state."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name metadata
# ---------------------------------------------------------------------------

table concurrent_futures.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, function, args, expected]
  rows:
    - [threadpool,     ThreadPoolExecutor.__name__.__eq__,  ["ThreadPoolExecutor"],  true]
    - [processpool,    ProcessPoolExecutor.__name__.__eq__, ["ProcessPoolExecutor"], true]
    - [future,         Future.__name__.__eq__,              ["Future"],              true]
    - [executor,       Executor.__name__.__eq__,            ["Executor"],            true]
    - [cancelled_err,  CancelledError.__name__.__eq__,      ["CancelledError"],      true]
    - [timeout_err,    TimeoutError.__name__.__eq__,        ["TimeoutError"],        true]
    - [broken_exec,    BrokenExecutor.__name__.__eq__,      ["BrokenExecutor"],      true]
    - [invalid_state,  InvalidStateError.__name__.__eq__,   ["InvalidStateError"],   true]

# ---------------------------------------------------------------------------
# Function name metadata
# ---------------------------------------------------------------------------

table concurrent_futures.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [wait,         wait.__name__.__eq__,         ["wait"],         true]
    - [as_completed, as_completed.__name__.__eq__,  ["as_completed"], true]

# ---------------------------------------------------------------------------
# Future() initial state — not done, not cancelled, not running
# ---------------------------------------------------------------------------

invariant concurrent_futures.future_not_done:
  description: "concurrent.futures.Future().done() == False — a new Future is pending"
  category: future_state
  kind: python_call_eq
  function: Future
  args: []
  method: done
  method_args: []
  expected: false

invariant concurrent_futures.future_not_cancelled:
  description: "concurrent.futures.Future().cancelled() == False — a new Future has not been cancelled"
  category: future_state
  kind: python_call_eq
  function: Future
  args: []
  method: cancelled
  method_args: []
  expected: false

invariant concurrent_futures.future_not_running:
  description: "concurrent.futures.Future().running() == False — a new Future is not yet running"
  category: future_state
  kind: python_call_eq
  function: Future
  args: []
  method: running
  method_args: []
  expected: false

# ---------------------------------------------------------------------------
# Wait policy constants — string identity checks
# ---------------------------------------------------------------------------

invariant concurrent_futures.first_completed_value:
  description: "concurrent.futures.FIRST_COMPLETED == 'FIRST_COMPLETED'"
  category: constants
  kind: python_call_eq
  function: FIRST_COMPLETED.__eq__
  args: ["FIRST_COMPLETED"]
  expected: true

invariant concurrent_futures.first_exception_value:
  description: "concurrent.futures.FIRST_EXCEPTION == 'FIRST_EXCEPTION'"
  category: constants
  kind: python_call_eq
  function: FIRST_EXCEPTION.__eq__
  args: ["FIRST_EXCEPTION"]
  expected: true

invariant concurrent_futures.all_completed_value:
  description: "concurrent.futures.ALL_COMPLETED == 'ALL_COMPLETED'"
  category: constants
  kind: python_call_eq
  function: ALL_COMPLETED.__eq__
  args: ["ALL_COMPLETED"]
  expected: true
