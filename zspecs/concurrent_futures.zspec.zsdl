spec: concurrent_futures
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "concurrent.futures source: Lib/concurrent/futures/ (PSF; source inspection permitted)"
  not_derived_from:
    - "concurrent.futures internals: thread/process pool scheduling, OS-level concurrency"
  notes:
    - "concurrent.futures provides a high-level interface for asynchronously executing callables."
    - "The module exposes two concrete Executor subclasses: ThreadPoolExecutor and ProcessPoolExecutor."
    - "Future objects represent the result of an asynchronous computation."
    - "CancelledError and TimeoutError are re-exported from concurrent.futures._base."
    - "BrokenExecutor is raised when a thread or process pool becomes non-functional."
    - "InvalidStateError is raised when a Future is put into an invalid state."
    - "FIRST_COMPLETED, FIRST_EXCEPTION, ALL_COMPLETED are string sentinel constants used with wait()."
    - "All expected values verified by running Python 3.12 concurrent.futures module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Futures may raise CancelledError, TimeoutError, or BrokenExecutor depending on executor state."
  stderr: "null"
  stickiness: "N/A — class and constant checks are stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks
# ---------------------------------------------------------------------------

invariant concurrent_futures.Future_name:
  description: "Future class name is 'Future'"
  category: classnames
  kind: python_call_eq
  function: Future.__name__.__eq__
  args: ["Future"]
  expected: true

invariant concurrent_futures.Executor_name:
  description: "Executor class name is 'Executor'"
  category: classnames
  kind: python_call_eq
  function: Executor.__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures.ThreadPoolExecutor_name:
  description: "ThreadPoolExecutor class name is 'ThreadPoolExecutor'"
  category: classnames
  kind: python_call_eq
  function: ThreadPoolExecutor.__name__.__eq__
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures.ProcessPoolExecutor_name:
  description: "ProcessPoolExecutor class name is 'ProcessPoolExecutor'"
  category: classnames
  kind: python_call_eq
  function: ProcessPoolExecutor.__name__.__eq__
  args: ["ProcessPoolExecutor"]
  expected: true

invariant concurrent_futures.BrokenExecutor_name:
  description: "BrokenExecutor class name is 'BrokenExecutor'"
  category: classnames
  kind: python_call_eq
  function: BrokenExecutor.__name__.__eq__
  args: ["BrokenExecutor"]
  expected: true

invariant concurrent_futures.InvalidStateError_name:
  description: "InvalidStateError class name is 'InvalidStateError'"
  category: classnames
  kind: python_call_eq
  function: InvalidStateError.__name__.__eq__
  args: ["InvalidStateError"]
  expected: true

# ---------------------------------------------------------------------------
# Inheritance checks
# ---------------------------------------------------------------------------

invariant concurrent_futures.ThreadPoolExecutor_base:
  description: "ThreadPoolExecutor.__bases__[0].__name__ == 'Executor'"
  category: classnames
  kind: python_call_eq
  function: ThreadPoolExecutor.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Executor"

invariant concurrent_futures.ProcessPoolExecutor_base:
  description: "ProcessPoolExecutor.__bases__[0].__name__ == 'Executor'"
  category: classnames
  kind: python_call_eq
  function: ProcessPoolExecutor.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Executor"

invariant concurrent_futures.BrokenExecutor_base:
  description: "BrokenExecutor.__bases__[0].__name__ == 'RuntimeError'"
  category: classnames
  kind: python_call_eq
  function: BrokenExecutor.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "RuntimeError"

# ---------------------------------------------------------------------------
# Method name checks on Future
# ---------------------------------------------------------------------------

invariant concurrent_futures.Future_cancel_name:
  description: "Future.cancel.__name__ == 'cancel'"
  category: methods
  kind: python_call_eq
  function: Future.cancel.__name__.__eq__
  args: ["cancel"]
  expected: true

invariant concurrent_futures.Future_result_name:
  description: "Future.result.__name__ == 'result'"
  category: methods
  kind: python_call_eq
  function: Future.result.__name__.__eq__
  args: ["result"]
  expected: true

invariant concurrent_futures.Future_add_done_callback_name:
  description: "Future.add_done_callback.__name__ == 'add_done_callback'"
  category: methods
  kind: python_call_eq
  function: Future.add_done_callback.__name__.__eq__
  args: ["add_done_callback"]
  expected: true

# ---------------------------------------------------------------------------
# String constant checks
# ---------------------------------------------------------------------------

invariant concurrent_futures.FIRST_COMPLETED_value:
  description: "FIRST_COMPLETED == 'FIRST_COMPLETED'"
  category: constants
  kind: python_call_eq
  function: FIRST_COMPLETED.__eq__
  args: ["FIRST_COMPLETED"]
  expected: true

invariant concurrent_futures.FIRST_EXCEPTION_value:
  description: "FIRST_EXCEPTION == 'FIRST_EXCEPTION'"
  category: constants
  kind: python_call_eq
  function: FIRST_EXCEPTION.__eq__
  args: ["FIRST_EXCEPTION"]
  expected: true

invariant concurrent_futures.ALL_COMPLETED_value:
  description: "ALL_COMPLETED == 'ALL_COMPLETED'"
  category: constants
  kind: python_call_eq
  function: ALL_COMPLETED.__eq__
  args: ["ALL_COMPLETED"]
  expected: true
