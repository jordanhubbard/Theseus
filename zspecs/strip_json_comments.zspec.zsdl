spec: strip_json_comments
version: ">=3.0.0"
backend: node(strip-json-comments)

docs: https://github.com/sindresorhus/strip-json-comments#readme

provenance:
  derived_from:
    - "strip-json-comments README — https://github.com/sindresorhus/strip-json-comments#readme"
    - "Test vectors verified with strip-json-comments@3.1.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "strip-json-comments source: index.js"
  notes:
    - "strip-json-comments@3 exports the function directly as module.exports."
    - "stripJsonComments(str) removes // and /* */ style comments from a JSON string."
    - "Comments are replaced with whitespace to preserve character positions."
    - "Strings without comments are returned unchanged."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string with comments removed. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table strip_json_comments.passthrough:
  kind: node_module_call_eq
  function: ~
  category: passthrough
  id_prefix: sjc_pass

  columns: [id, args, expected]
  rows:
    - [no_comment,  ["{\"a\":1}"],  "{\"a\":1}"]
