spec: threading_extra151
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.__dict__.__contains__ membership checks — Thread True, Lock True, Condition True, Semaphore True, Event True, Barrier True, Timer True, RLock True, local True, current_thread True, main_thread True, active_count True (Wave 279)."
    - "threading.__dict__.__contains__('Thread') == True. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('Lock') == True. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('Condition') == True. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('Semaphore') == True. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('Event') == True. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('Barrier') == True. Verified with Python 3.14.3."
    - "threading.__dict__.__contains__('Timer') == True. Verified with Python 3.14.3."
    - "threading.Semaphore: __name__ 'Semaphore', __module__ 'threading', __bases__[0]=='object', MRO len 2, class dict len 12. Verified with Python 3.14.3."
    - "threading.Event: __name__ 'Event', __module__ 'threading', __bases__[0]=='object', MRO len 2, class dict len 14. Verified with Python 3.14.3."
    - "threading.Timer: __name__ 'Timer', __module__ 'threading', __bases__[0].__name__=='Thread', MRO len 3, class dict len 7. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.__dict__.__contains__ — synchronization primitive classes
#
# Wave 279 theme: threading module dict membership checks for sync primitives.
#
# threading.__dict__.__contains__('Thread') == True
# threading.__dict__.__contains__('Lock') == True
# threading.__dict__.__contains__('Condition') == True
# threading.__dict__.__contains__('Semaphore') == True
# threading.__dict__.__contains__('Event') == True
#
# These are all classes (Python or C extension) registered in the threading
# module dict. New to extra151.
# ---------------------------------------------------------------------------

table threading_extra151.module_dict_contains_sync_classes:
  description: "threading.__dict__.__contains__: Thread True, Lock True, Condition True, Semaphore True, Event True; sync primitive classes in module dict; wave 279; new to extra151"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmdcsync151

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_thread,
       "__dict__.__contains__",
       ["Thread"],
       true,
       "threading.__dict__.__contains__('Thread') == True — Thread is a Python class defined in Lib/threading.py; it represents a thread of execution; dict.__contains__('Thread') returns True; new to extra151"]
    - [dict_contains_lock,
       "__dict__.__contains__",
       ["Lock"],
       true,
       "threading.__dict__.__contains__('Lock') == True — threading.Lock is actually the C extension type _thread.lock exposed in the threading module dict; dict.__contains__('Lock') returns True; new to extra151"]
    - [dict_contains_condition,
       "__dict__.__contains__",
       ["Condition"],
       true,
       "threading.__dict__.__contains__('Condition') == True — Condition is a Python class defined in Lib/threading.py; it is a synchronization primitive that allows threads to wait for a condition; dict.__contains__('Condition') returns True; new to extra151"]
    - [dict_contains_semaphore,
       "__dict__.__contains__",
       ["Semaphore"],
       true,
       "threading.__dict__.__contains__('Semaphore') == True — Semaphore is a Python class defined in Lib/threading.py; it is a classic synchronization primitive based on a counter; dict.__contains__('Semaphore') returns True; new to extra151"]
    - [dict_contains_event,
       "__dict__.__contains__",
       ["Event"],
       true,
       "threading.__dict__.__contains__('Event') == True — Event is a Python class defined in Lib/threading.py; it is a simple synchronization object where threads wait for a flag to be set; dict.__contains__('Event') returns True; new to extra151"]

# ---------------------------------------------------------------------------
# Table 2: threading.__dict__.__contains__ — Barrier, Timer, RLock, local
#
# Wave 279 theme: threading module dict membership checks for more classes.
#
# threading.__dict__.__contains__('Barrier') == True
# threading.__dict__.__contains__('Timer') == True
# threading.__dict__.__contains__('RLock') == True
# threading.__dict__.__contains__('local') == True
# threading.__dict__.__contains__('current_thread') == True
#
# New to extra151.
# ---------------------------------------------------------------------------

table threading_extra151.module_dict_contains_more_classes:
  description: "threading.__dict__.__contains__: Barrier True, Timer True, RLock True, local True, current_thread True; wave 279; new to extra151"
  kind: python_call_eq
  category: identity
  id_prefix: threadingmdcmore151

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_barrier,
       "__dict__.__contains__",
       ["Barrier"],
       true,
       "threading.__dict__.__contains__('Barrier') == True — Barrier is a Python class defined in Lib/threading.py; it allows a fixed number of threads to synchronize at a barrier point; dict.__contains__('Barrier') returns True; new to extra151"]
    - [dict_contains_timer,
       "__dict__.__contains__",
       ["Timer"],
       true,
       "threading.__dict__.__contains__('Timer') == True — Timer is a Python class defined in Lib/threading.py that is a subclass of Thread and runs a function after a delay; dict.__contains__('Timer') returns True; new to extra151"]
    - [dict_contains_rlock,
       "__dict__.__contains__",
       ["RLock"],
       true,
       "threading.__dict__.__contains__('RLock') == True — RLock (reentrant lock) is available in the threading module dict; it can be acquired multiple times by the same thread; dict.__contains__('RLock') returns True; new to extra151"]
    - [dict_contains_local,
       "__dict__.__contains__",
       ["local"],
       true,
       "threading.__dict__.__contains__('local') == True — threading.local is actually _thread._local (a C extension type); it is exposed in the threading module dict as 'local'; dict.__contains__('local') returns True; new to extra151"]
    - [dict_contains_current_thread,
       "__dict__.__contains__",
       ["current_thread"],
       true,
       "threading.__dict__.__contains__('current_thread') == True — current_thread is a Python function defined in Lib/threading.py that returns the current Thread object; dict.__contains__('current_thread') returns True; new to extra151"]

# ---------------------------------------------------------------------------
# Table 3: threading.Semaphore, threading.Event, threading.Timer — class identity
#
# Wave 279 theme: class identity for Semaphore, Event, and Timer.
#
# threading.Semaphore.__name__ == 'Semaphore'
# threading.Semaphore.__module__ == 'threading'
# threading.Semaphore.__bases__[0].__name__ == 'object'
# len(threading.Semaphore.__mro__) == 2
# len(threading.Semaphore.__dict__) == 12
# threading.Event.__name__ == 'Event'
# threading.Event.__module__ == 'threading'
# len(threading.Event.__mro__) == 2
# len(threading.Event.__dict__) == 14
# threading.Timer.__bases__[0].__name__ == 'Thread'
# len(threading.Timer.__mro__) == 3
# len(threading.Timer.__dict__) == 7
#
# New to extra151.
# ---------------------------------------------------------------------------

table threading_extra151.semaphore_event_timer_identity:
  description: "threading.Semaphore: 'Semaphore', MRO len 2, dict len 12; threading.Event: 'Event', MRO len 2, dict len 14; threading.Timer: bases Thread, MRO len 3, dict len 7; wave 279; new to extra151"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingsemevttmr151

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_name_eq,
       "Semaphore.__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — Semaphore is a Python class defined in Lib/threading.py; __name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra151"]
    - [semaphore_module_eq_threading,
       "Semaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — Semaphore is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra151"]
    - [semaphore_mro_len_eq_2,
       "Semaphore.__mro__.__len__",
       [],
       2,
       "threading.Semaphore.__mro__.__len__() == 2 — Semaphore inherits directly from object; MRO is [Semaphore, object]; len(__mro__) == 2; new to extra151"]
    - [event_name_eq,
       "Event.__name__.__eq__",
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — Event is a Python class defined in Lib/threading.py; __name__ is 'Event'; str.__eq__('Event') returns True; new to extra151"]
    - [event_module_eq_threading,
       "Event.__module__.__eq__",
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — Event is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra151"]
    - [event_mro_len_eq_2,
       "Event.__mro__.__len__",
       [],
       2,
       "threading.Event.__mro__.__len__() == 2 — Event inherits directly from object; MRO is [Event, object]; len(__mro__) == 2; new to extra151"]
    - [event_dict_len_eq_14,
       "Event.__dict__.__len__",
       [],
       14,
       "threading.Event.__dict__.__len__() == 14 — Event has 14 entries in its class dict in Python 3.14.3 including is_set, set, clear, wait, and various dunders and properties; len == 14; verified with Python 3.14.3; new to extra151"]
    - [timer_name_eq,
       "Timer.__name__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — Timer is a Python class defined in Lib/threading.py that is a subclass of Thread; __name__ is 'Timer'; str.__eq__('Timer') returns True; new to extra151"]
    - [timer_bases_first_eq_thread,
       "Timer.__bases__[0].__name__.__eq__",
       ["Thread"],
       true,
       "threading.Timer.__bases__[0].__name__.__eq__('Thread') == True — Timer is a subclass of Thread; __bases__[0].__name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra151"]
    - [timer_mro_len_eq_3,
       "Timer.__mro__.__len__",
       [],
       3,
       "threading.Timer.__mro__.__len__() == 3 — Timer inherits from Thread which inherits from object; MRO is [Timer, Thread, object]; len(__mro__) == 3; new to extra151"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra151
# ---------------------------------------------------------------------------

invariant threading_extra151.dict_contains_thread:
  description: "threading.__dict__.__contains__('Thread') == True — Thread is in module dict; wave 279; new to extra151"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Thread"]
  expected: true

invariant threading_extra151.dict_contains_lock:
  description: "threading.__dict__.__contains__('Lock') == True — Lock is in module dict; wave 279; new to extra151"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Lock"]
  expected: true

invariant threading_extra151.dict_contains_condition:
  description: "threading.__dict__.__contains__('Condition') == True — Condition is in module dict; wave 279; new to extra151"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Condition"]
  expected: true

invariant threading_extra151.dict_contains_semaphore:
  description: "threading.__dict__.__contains__('Semaphore') == True — Semaphore is in module dict; wave 279; new to extra151"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Semaphore"]
  expected: true

invariant threading_extra151.dict_contains_event:
  description: "threading.__dict__.__contains__('Event') == True — Event is in module dict; wave 279; new to extra151"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Event"]
  expected: true

invariant threading_extra151.dict_contains_barrier:
  description: "threading.__dict__.__contains__('Barrier') == True — Barrier is in module dict; wave 279; new to extra151"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Barrier"]
  expected: true

invariant threading_extra151.dict_contains_timer:
  description: "threading.__dict__.__contains__('Timer') == True — Timer is in module dict; wave 279; new to extra151"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["Timer"]
  expected: true

invariant threading_extra151.semaphore_mro_len:
  description: "len(threading.Semaphore.__mro__) == 2 — Semaphore inherits from object only; wave 279; new to extra151"
  kind: python_call_eq
  function: Semaphore.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra151.timer_mro_len:
  description: "len(threading.Timer.__mro__) == 3 — Timer inherits from Thread which inherits from object; MRO len 3; wave 279; new to extra151"
  kind: python_call_eq
  function: Timer.__mro__.__len__
  args: []
  expected: 3

invariant threading_extra151.timer_bases_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer is a subclass of Thread; wave 279; new to extra151"
  kind: python_call_eq
  function: "Timer.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true
