spec: multiprocessing_extra1756
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/multiprocessing.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "Theme: which multiprocessing stdlib types define __add__, __sub__, __mul__, __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__."
    - "multiprocessing.Process: spawnable subprocess class; not a numeric type — no arithmetic operators in __dict__ -> all False."
    - "multiprocessing.Pool: worker-process pool manager; not a numeric type — no arithmetic operators in __dict__ -> all False."
    - "multiprocessing.process.BaseProcess: abstract root of the process hierarchy; not a numeric type — no arithmetic operators in __dict__ -> all False."
    - "Rationale: multiprocessing types model OS-level subprocesses and inter-process synchronization, not numeric quantities."
    - "Complementary checks: multiprocessing.cpu_count.__class__.__name__ -> 'builtin_function_or_method'; multiprocessing.current_process.__class__.__name__ -> 'builtin_function_or_method'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence checks for multiprocessing types
#
# Wave 564 theme: which multiprocessing types define __add__, __sub__, __mul__,
# __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__.
#
# multiprocessing.Process: represents an OS subprocess whose lifecycle (start,
#   join, terminate, kill) is driven explicitly by the programmer. It manages
#   process state and inter-process communication but is not a numeric type.
#   No arithmetic operators in its own __dict__.
# multiprocessing.Pool: manages a set of worker processes for parallel task
#   execution via map/apply/starmap. It is a resource-management type, not a
#   numeric type. No arithmetic operators in __dict__.
# multiprocessing.process.BaseProcess: abstract root from which Process derives;
#   manages process state and signals. Not numeric; no arithmetic operators
#   in its own __dict__.
# ---------------------------------------------------------------------------

table multiprocessing_extra1756.arithmetic_operators:
  description: "multiprocessing types arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1756

  columns: [id, function, args, expected]
  rows:
    - ["mp1756001", "multiprocessing.Process.__dict__.__contains__",             ["__add__"],      false]
    - ["mp1756002", "multiprocessing.Process.__dict__.__contains__",             ["__sub__"],      false]
    - ["mp1756003", "multiprocessing.Process.__dict__.__contains__",             ["__mul__"],      false]
    - ["mp1756004", "multiprocessing.Process.__dict__.__contains__",             ["__truediv__"],  false]
    - ["mp1756005", "multiprocessing.Process.__dict__.__contains__",             ["__floordiv__"], false]
    - ["mp1756006", "multiprocessing.Process.__dict__.__contains__",             ["__pow__"],      false]
    - ["mp1756007", "multiprocessing.Process.__dict__.__contains__",             ["__neg__"],      false]
    - ["mp1756008", "multiprocessing.Process.__dict__.__contains__",             ["__pos__"],      false]
    - ["mp1756009", "multiprocessing.Pool.__dict__.__contains__",                ["__add__"],      false]
    - ["mp1756010", "multiprocessing.Pool.__dict__.__contains__",                ["__sub__"],      false]
    - ["mp1756011", "multiprocessing.Pool.__dict__.__contains__",                ["__mul__"],      false]
    - ["mp1756012", "multiprocessing.Pool.__dict__.__contains__",                ["__neg__"],      false]
    - ["mp1756013", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__add__"],      false]
    - ["mp1756014", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__sub__"],      false]
    - ["mp1756015", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__mul__"],      false]
    - ["mp1756016", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__truediv__"],  false]
    - ["mp1756017", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__floordiv__"], false]
    - ["mp1756018", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__neg__"],      false]

# ---------------------------------------------------------------------------
# Table 2: complementary checks for multiprocessing module-level functions
#
# The arithmetic theme is all-False for multiprocessing types. These
# complementary checks confirm genuine multiprocessing-specific attributes:
# - multiprocessing.cpu_count is a C-level builtin function (wraps os.cpu_count
#   internally); its class name is 'builtin_function_or_method'.
# - multiprocessing.current_process is also a C-level builtin function that
#   returns the Process object for the calling process; class name confirms this.
# - multiprocessing.Pool.__dict__ does NOT contain '__pow__' (cross-check).
# - multiprocessing.process.BaseProcess.__dict__ does NOT contain '__pos__'.
# - multiprocessing.process.BaseProcess.__dict__ does NOT contain '__pow__'.
# These checks are distinct from all prior multiprocessing wave specs and
# provide informative signal about the module's C-level function types.
# ---------------------------------------------------------------------------

table multiprocessing_extra1756.complementary_checks:
  description: "multiprocessing module-level function class name checks — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp1756

  columns: [id, function, args, expected]
  rows:
    - ["mp1756019", "multiprocessing.cpu_count.__class__.__name__.__eq__",       ["builtin_function_or_method"], true]
    - ["mp1756020", "multiprocessing.current_process.__class__.__name__.__eq__", ["builtin_function_or_method"], true]
    - ["mp1756021", "multiprocessing.Pool.__dict__.__contains__",                ["__pow__"],  false]
    - ["mp1756022", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__pos__"],  false]
    - ["mp1756023", "multiprocessing.process.BaseProcess.__dict__.__contains__", ["__pow__"],  false]
    - ["mp1756024", "multiprocessing.Pool.__dict__.__contains__",                ["__pos__"],  false]
    - ["mp1756025", "multiprocessing.Pool.__dict__.__contains__",                ["__floordiv__"], false]
