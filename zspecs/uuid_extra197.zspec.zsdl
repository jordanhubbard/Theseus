# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant uuid_extra197.uuid1_defaults_classname:
  description: "uuid.uuid1.__defaults__.__class__.__name__ == 'tuple' — uuid1 has two default args so __defaults__ is a tuple; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: function_defaults
  kind: python_call_eq
  function: uuid1.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant uuid_extra197.uuid1_defaults_len:
  description: "uuid.uuid1.__defaults__.__len__() == 2 — uuid1(node=None, clock_seq=None) has two default values; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: function_defaults
  kind: python_call_eq
  function: uuid1.__defaults__.__len__
  args: []
  expected: 2

invariant uuid_extra197.uuid3_defaults_classname:
  description: "uuid.uuid3.__defaults__.__class__.__name__ == 'NoneType' — uuid3(namespace, name) has no default values so __defaults__ is None; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11"
  category: function_defaults
  kind: python_call_eq
  function: uuid3.__defaults__.__class__.__name__.__eq__
