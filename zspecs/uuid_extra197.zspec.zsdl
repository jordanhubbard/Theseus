spec: uuid_extra197
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.uuid1.__defaults__ == (None, None) — uuid1(node=None, clock_seq=None); __defaults__ is a tuple of two None values. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.uuid3.__defaults__ is None — uuid3(namespace, name) has no default values; __defaults__ is None. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.uuid4.__defaults__ is None — uuid4() has no default values; __defaults__ is None. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.uuid5.__defaults__ is None — uuid5(namespace, name) has no default values; __defaults__ is None. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.__init__.__defaults__ == (None, None, None, None, None, None) — UUID.__init__ has 6 keyword args each defaulting to None. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.__init__.__defaults__.__len__() == 6 — the defaults tuple has 6 elements. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.uuid1.__defaults__.__len__() == 2 — the defaults tuple for uuid1 has 2 elements. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid1 __defaults__ — tuple of two Nones
#
# uuid1(node=None, clock_seq=None) has two optional keyword args.
# __defaults__ is (None, None) — a tuple of length 2.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra197.uuid1_defaults:
  description: "uuid.uuid1.__defaults__.__class__.__name__ and __len__() — uuid1 has two default args (node=None, clock_seq=None); __defaults__ is a tuple of length 2; element class names are NoneType"
  kind: python_call_eq
  category: function_defaults
  id_prefix: uuiddefaults197

  columns: [id, function, args, expected, description]
  rows:
    - [uuid1_defaults_classname,   uuid1.__defaults__.__class__.__name__.__eq__,   ["tuple"],   true,  "uuid.uuid1.__defaults__.__class__.__name__ == 'tuple' — defaults is a tuple"]
    - [uuid1_defaults_len,         uuid1.__defaults__.__len__,                     [],          2,     "uuid.uuid1.__defaults__.__len__() == 2 — two default values (node, clock_seq)"]
    - [uuid1_defaults_0_classname, "uuid1.__defaults__[0].__class__.__name__.__eq__", ["NoneType"], true, "uuid.uuid1.__defaults__[0].__class__.__name__ == 'NoneType' — first default (node) is None"]
    - [uuid1_defaults_1_classname, "uuid1.__defaults__[1].__class__.__name__.__eq__", ["NoneType"], true, "uuid.uuid1.__defaults__[1].__class__.__name__ == 'NoneType' — second default (clock_seq) is None"]

# ---------------------------------------------------------------------------
# uuid.uuid3, uuid4, uuid5 __defaults__ — all None
#
# uuid3(namespace, name) — no defaults; __defaults__ is None
# uuid4() — no defaults; __defaults__ is None
# uuid5(namespace, name) — no defaults; __defaults__ is None
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra197.uuid3_uuid4_uuid5_defaults:
  description: "uuid.uuid3, uuid4, uuid5 __defaults__.__class__.__name__ — all three functions have no default values so __defaults__ is None; class name is NoneType"
  kind: python_call_eq
  category: function_defaults
  id_prefix: uuiddefaults197

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_defaults_classname,  uuid3.__defaults__.__class__.__name__.__eq__,  ["NoneType"],  true,  "uuid.uuid3.__defaults__.__class__.__name__ == 'NoneType' — uuid3 has no defaults"]
    - [uuid4_defaults_classname,  uuid4.__defaults__.__class__.__name__.__eq__,  ["NoneType"],  true,  "uuid.uuid4.__defaults__.__class__.__name__ == 'NoneType' — uuid4 has no defaults"]
    - [uuid5_defaults_classname,  uuid5.__defaults__.__class__.__name__.__eq__,  ["NoneType"],  true,  "uuid.uuid5.__defaults__.__class__.__name__ == 'NoneType' — uuid5 has no defaults"]
    - [uuid1_name_eq,             uuid1.__name__.__eq__,                         ["uuid1"],     true,  "uuid.uuid1.__name__ == 'uuid1' — function name identity"]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__ __defaults__ — tuple of 6 Nones
#
# UUID.__init__(self, hex=None, bytes=None, bytes_le=None, fields=None,
#               int=None, version=None) has 6 optional keyword args.
# __defaults__ is (None, None, None, None, None, None) — length 6.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra197.uuid_init_defaults:
  description: "uuid.UUID.__init__.__defaults__.__class__.__name__ and __len__() — UUID.__init__ has 6 keyword args each defaulting to None; __defaults__ is a tuple of length 6"
  kind: python_call_eq
  category: function_defaults
  id_prefix: uuiddefaults197

  columns: [id, function, args, expected, description]
  rows:
    - [uuid_init_defaults_classname,  UUID.__init__.__defaults__.__class__.__name__.__eq__,  ["tuple"],  true,  "uuid.UUID.__init__.__defaults__.__class__.__name__ == 'tuple' — defaults is a tuple"]
    - [uuid_init_defaults_len,        UUID.__init__.__defaults__.__len__,                    [],         6,     "uuid.UUID.__init__.__defaults__.__len__() == 6 — six default values (hex, bytes, bytes_le, fields, int, version)"]
    - [uuid_init_name,                UUID.__init__.__name__.__eq__,                         ["__init__"], true, "uuid.UUID.__init__.__name__ == '__init__' — method name identity"]
    - [uuid_name_eq,                  UUID.__name__.__eq__,                                  ["UUID"],   true,  "uuid.UUID.__name__ == 'UUID' — class name identity"]

