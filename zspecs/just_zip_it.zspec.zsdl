spec: just_zip_it
version: ">=3.2.0"
backend: node(just-zip-it)

docs: https://www.npmjs.com/package/just-zip-it

provenance:
  derived_from:
    - "just-zip-it README — https://www.npmjs.com/package/just-zip-it"
    - "Test vectors verified with just-zip-it via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "just-zip-it source"
  notes:
    - "just-zip-it is an npm package. Install: npm install just-zip-it"
    - "The module exports a single function: zip(arr1, arr2, ...) produces array of pairs."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array of arrays, each containing one element from each input array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table just_zip_it.zip:
  kind: node_module_call_eq
  function: ~
  category: transform
  id_prefix: jzip

  columns: [id, args, expected]
  rows:
    - [strings, [[1, 2], ["a", "b"]],         [[1, "a"], [2, "b"]]]
    - [numbers, [[1, 2, 3], [4, 5, 6]],       [[1, 4], [2, 5], [3, 6]]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T20:11:23Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
