spec: threading_extra212
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading_extra.zspec.zsdl — covers class_modules (BoundedSemaphore, Condition, Semaphore, Event, RLock), local.__name__/__module__, current_thread class_name_is_str, get_ident returns_int, TIMEOUT_MAX is_float, stack_size returns_int"
    - "threading_extra211.zspec.zsdl — covers Thread/Lock/Condition/__name__ and __module__ checks, active_count return type, enumerate return type"
  notes:
    - "threading.Timer.__dict__.__contains__('run') == True — Timer overrides the Thread.run() method; 'run' is defined in Timer's class dict. Verified with Python 3.14.3."
    - "threading.Timer.__dict__.__contains__('cancel') == True — Timer defines 'cancel' in its class dict; it cancels a pending timer before it fires. Verified with Python 3.14.3."
    - "threading.Timer.__dict__.__contains__('__init__') == True — Timer defines __init__ in its class dict to accept interval, function, and optional args/kwargs. Verified with Python 3.14.3."
    - "threading.Timer.__dict__.__contains__('__doc__') == True — Timer has a class-level docstring in its dict. Verified with Python 3.14.3."
    - "threading.Timer.__dict__.__len__() == 7 — the class dict has exactly 7 entries: __module__, __firstlineno__, __doc__, __init__, cancel, run, __static_attributes__. Verified with Python 3.14.3."
    - "threading.local.__dict__.__contains__('__getattribute__') == True — local is a C-level type; __getattribute__ is defined in its class dict. Verified with Python 3.14.3."
    - "threading.local.__dict__.__contains__('__setattr__') == True — threading.local defines __setattr__ in its class dict to store attributes in thread-local storage. Verified with Python 3.14.3."
    - "threading.local.__dict__.__contains__('__delattr__') == True — threading.local defines __delattr__ in its class dict to delete thread-local attributes. Verified with Python 3.14.3."
    - "threading.local.__dict__.__contains__('__doc__') == True — threading.local has a docstring in its class dict. Verified with Python 3.14.3."
    - "threading.local.__dict__.__len__() == 6 — the class dict has exactly 6 entries: __new__, __getattribute__, __setattr__, __delattr__, __doc__, __module__. Verified with Python 3.14.3."
    - "threading.local.__dict__.__contains__('__init__') == False — threading.local does NOT define __init__ in its class dict; initialization is handled via __new__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Timer.__dict__ membership — run, cancel, init, doc
#
# Timer.__dict__.__contains__('run')     == True
# Timer.__dict__.__contains__('cancel')  == True
# Timer.__dict__.__contains__('__init__') == True
# Timer.__dict__.__contains__('__doc__') == True
# ---------------------------------------------------------------------------

table threading_extra212.timer_dict_membership:
  description: "threading.Timer.__dict__ membership checks in threadtimer212td namespace — Timer defines 'run' (overrides Thread.run to execute the timed function), 'cancel' (cancels a pending timer), '__init__' (accepts interval and function arguments), and '__doc__' (class docstring); all four __contains__ checks return True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: threadtimer212td

  columns: [id, function, args, expected, description]
  rows:
    - [timer_dict_has_run,
       "Timer.__dict__.__contains__",
       ["run"],
       true,
       "threading.Timer.__dict__.__contains__('run') == True — Timer overrides Thread.run() to call the timed function after the specified interval; 'run' is defined in Timer's class dict; __contains__('run') returns True; verified with Python 3.14.3"]
    - [timer_dict_has_cancel,
       "Timer.__dict__.__contains__",
       ["cancel"],
       true,
       "threading.Timer.__dict__.__contains__('cancel') == True — Timer defines 'cancel' in its class dict to stop a timer before it fires by setting an internal Event; __contains__('cancel') returns True; verified with Python 3.14.3"]
    - [timer_dict_has_init,
       "Timer.__dict__.__contains__",
       ["__init__"],
       true,
       "threading.Timer.__dict__.__contains__('__init__') == True — Timer defines __init__ in its class dict accepting interval, function, args, and kwargs parameters; __contains__('__init__') returns True; verified with Python 3.14.3"]
    - [timer_dict_has_doc,
       "Timer.__dict__.__contains__",
       ["__doc__"],
       true,
       "threading.Timer.__dict__.__contains__('__doc__') == True — Timer has a class-level docstring stored under '__doc__' in its class dict; __contains__('__doc__') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: threading.Timer.__dict__ — length and absence checks
#
# Timer.__dict__.__len__()                            == 7
# Timer.__dict__.__contains__('start')                == False  (inherited from Thread)
# Timer.__dict__.__contains__('join')                 == False  (inherited from Thread)
# Timer.__dict__.__contains__('__module__')           == True
# ---------------------------------------------------------------------------

table threading_extra212.timer_dict_len_and_absence:
  description: "threading.Timer.__dict__ length and absence checks in threadtimer212tl namespace — the class dict has exactly 7 entries; 'start' is NOT in Timer's class dict (it is inherited from Thread); 'join' is NOT in Timer's class dict (inherited from Thread); '__module__' is present; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: threadtimer212tl

  columns: [id, function, args, expected, description]
  rows:
    - [timer_dict_len,
       "Timer.__dict__.__len__",
       [],
       7,
       "threading.Timer.__dict__.__len__() == 7 — the class dict has exactly 7 entries: __module__, __firstlineno__, __doc__, __init__, cancel, run, __static_attributes__; __len__() returns 7; verified with Python 3.14.3"]
    - [timer_dict_no_start,
       "Timer.__dict__.__contains__",
       ["start"],
       false,
       "threading.Timer.__dict__.__contains__('start') == False — 'start' is NOT in Timer's class dict; it is inherited from the Thread base class; __contains__('start') returns False; verified with Python 3.14.3"]
    - [timer_dict_no_join,
       "Timer.__dict__.__contains__",
       ["join"],
       false,
       "threading.Timer.__dict__.__contains__('join') == False — 'join' is NOT in Timer's class dict; it is inherited from the Thread base class; __contains__('join') returns False; verified with Python 3.14.3"]
    - [timer_dict_has_module,
       "Timer.__dict__.__contains__",
       ["__module__"],
       true,
       "threading.Timer.__dict__.__contains__('__module__') == True — '__module__' is present in Timer's class dict with value 'threading'; __contains__('__module__') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: threading.local.__dict__ membership
#
# local.__dict__.__contains__('__getattribute__') == True
# local.__dict__.__contains__('__setattr__')      == True
# local.__dict__.__contains__('__delattr__')      == True
# local.__dict__.__len__()                        == 6
# ---------------------------------------------------------------------------

table threading_extra212.local_dict_membership:
  description: "threading.local.__dict__ membership and length checks in threadtimer212ld namespace — local is a C-level type; its class dict contains '__getattribute__' (overridden to access thread-local storage), '__setattr__' (stores attributes in thread-local storage), '__delattr__' (deletes thread-local attributes); the dict length is exactly 6; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: threadtimer212ld

  columns: [id, function, args, expected, description]
  rows:
    - [local_dict_has_getattribute,
       "local.__dict__.__contains__",
       ["__getattribute__"],
       true,
       "threading.local.__dict__.__contains__('__getattribute__') == True — threading.local overrides __getattribute__ to retrieve attributes from thread-local storage; '__getattribute__' is in the class dict; __contains__('__getattribute__') returns True; verified with Python 3.14.3"]
    - [local_dict_has_setattr,
       "local.__dict__.__contains__",
       ["__setattr__"],
       true,
       "threading.local.__dict__.__contains__('__setattr__') == True — threading.local defines __setattr__ to store attribute assignments in thread-local storage; '__setattr__' is in the class dict; __contains__('__setattr__') returns True; verified with Python 3.14.3"]
    - [local_dict_has_delattr,
       "local.__dict__.__contains__",
       ["__delattr__"],
       true,
       "threading.local.__dict__.__contains__('__delattr__') == True — threading.local defines __delattr__ to remove attributes from thread-local storage; '__delattr__' is in the class dict; __contains__('__delattr__') returns True; verified with Python 3.14.3"]
    - [local_dict_len,
       "local.__dict__.__len__",
       [],
       6,
       "threading.local.__dict__.__len__() == 6 — the class dict for threading.local has exactly 6 entries: __new__, __getattribute__, __setattr__, __delattr__, __doc__, __module__; __len__() returns 6; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra212
# ---------------------------------------------------------------------------

invariant threading_extra212.timer_dict_has_run:
  description: "threading.Timer.__dict__.__contains__('run') == True — Timer overrides Thread.run() to execute the timed function; new to extra212; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Timer.__dict__.__contains__"
  args: ["run"]
  expected: true

invariant threading_extra212.timer_dict_has_cancel:
  description: "threading.Timer.__dict__.__contains__('cancel') == True — Timer defines 'cancel' to stop the timer before it fires; new to extra212; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Timer.__dict__.__contains__"
  args: ["cancel"]
  expected: true

invariant threading_extra212.local_dict_has_getattribute:
  description: "threading.local.__dict__.__contains__('__getattribute__') == True — threading.local overrides __getattribute__ for thread-local storage access; new to extra212; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "local.__dict__.__contains__"
  args: ["__getattribute__"]
  expected: true

invariant threading_extra212.local_dict_no_init:
  description: "threading.local.__dict__.__contains__('__init__') == False — '__init__' is NOT in threading.local's class dict; initialization is handled by __new__ at the C level; new to extra212; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "local.__dict__.__contains__"
  args: ["__init__"]
  expected: false

invariant threading_extra212.local_dict_len:
  description: "threading.local.__dict__.__len__() == 6 — the class dict for threading.local has exactly 6 entries: __new__, __getattribute__, __setattr__, __delattr__, __doc__, __module__; new to extra212; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "local.__dict__.__len__"
  args: []
  expected: 6

invariant threading_extra212.timer_dict_len:
  description: "threading.Timer.__dict__.__len__() == 7 — the Timer class dict has exactly 7 entries; new to extra212; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Timer.__dict__.__len__"
  args: []
  expected: 7

invariant threading_extra212.local_dict_has_setattr:
  description: "threading.local.__dict__.__contains__('__setattr__') == True — threading.local defines __setattr__ for thread-local attribute storage; new to extra212; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "local.__dict__.__contains__"
  args: ["__setattr__"]
  expected: true

invariant threading_extra212.local_dict_has_delattr:
  description: "threading.local.__dict__.__contains__('__delattr__') == True — threading.local defines __delattr__ for removing thread-local attributes; new to extra212; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "local.__dict__.__contains__"
  args: ["__delattr__"]
  expected: true
