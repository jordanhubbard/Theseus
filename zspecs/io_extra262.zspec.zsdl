spec: io_extra262
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec covers io.BufferedWriter and io.BufferedRandom method identity."
    - "io.BufferedWriter.write.__name__ == 'write' — the main write method; __class__.__name__ is 'method_descriptor' (C-level)."
    - "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write' — qualified name confirms class ownership."
    - "io.BufferedWriter.flush.__name__ == 'flush' — flushes the write buffer to the raw stream."
    - "io.BufferedWriter.seek.__name__ == 'seek' — seeks to a given position in the stream."
    - "io.BufferedWriter.tell.__name__ == 'tell' — returns the current stream position."
    - "io.BufferedRandom.__name__ == 'BufferedRandom' — supports both read and write on seekable raw streams."
    - "io.BufferedRandom.__module__ == '_io' — the class is implemented in the C extension _io."
    - "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — inherits from the C-level _BufferedIOBase."
    - "io.BufferedRandom.read.__name__ == 'read' — reads up to n bytes from the stream."
    - "io.BufferedRandom.write.__name__ == 'write' — writes bytes to the stream."
    - "io.BufferedRandom.seek.__name__ == 'seek' — seeks to position; required since BufferedRandom is seekable."
    - "All methods on both classes are 'method_descriptor' — they are C-level slot wrappers."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.BufferedWriter method identity
#
# BufferedWriter wraps a raw writable stream and buffers writes for
# efficiency. Its core methods — write, flush, seek, tell — are all
# implemented at the C level as method_descriptor objects.
# __name__, __qualname__, and __class__.__name__ are verified for each.
# ---------------------------------------------------------------------------

table io_extra262.buffered_writer_method_identity:
  description: "io.BufferedWriter method identity — __name__, __qualname__, and class kind for write, flush, seek, tell; new to extra262"
  kind: python_call_eq
  category: identity
  id_prefix: ioxbwm262

  columns: [id, function, args, expected, description]
  rows:
    - [write_name,
       "BufferedWriter.write.__name__.__eq__",
       ["write"],
       true,
       "io.BufferedWriter.write.__name__.__eq__('write') == True — write writes bytes to the buffered stream, buffering them until the buffer is full or flush is called; its __name__ is 'write'; str.__eq__('write') returns True; new to extra262"]
    - [write_qualname,
       "BufferedWriter.write.__qualname__.__eq__",
       ["BufferedWriter.write"],
       true,
       "io.BufferedWriter.write.__qualname__.__eq__('BufferedWriter.write') == True — the qualified name is 'BufferedWriter.write', confirming that it is defined in the BufferedWriter class; str.__eq__('BufferedWriter.write') returns True; new to extra262"]
    - [write_class,
       "BufferedWriter.write.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.BufferedWriter.write.__class__.__name__.__eq__('method_descriptor') == True — write is implemented as a C-level method_descriptor in the _io extension; str.__eq__('method_descriptor') returns True; new to extra262"]
    - [flush_name,
       "BufferedWriter.flush.__name__.__eq__",
       ["flush"],
       true,
       "io.BufferedWriter.flush.__name__.__eq__('flush') == True — flush forces any buffered bytes to be written to the underlying raw stream; its __name__ is 'flush'; str.__eq__('flush') returns True; new to extra262"]
    - [flush_qualname,
       "BufferedWriter.flush.__qualname__.__eq__",
       ["BufferedWriter.flush"],
       true,
       "io.BufferedWriter.flush.__qualname__.__eq__('BufferedWriter.flush') == True — the qualified name is 'BufferedWriter.flush'; str.__eq__('BufferedWriter.flush') returns True; new to extra262"]
    - [flush_class,
       "BufferedWriter.flush.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.BufferedWriter.flush.__class__.__name__.__eq__('method_descriptor') == True — flush is implemented as a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra262"]
    - [seek_name,
       "BufferedWriter.seek.__name__.__eq__",
       ["seek"],
       true,
       "io.BufferedWriter.seek.__name__.__eq__('seek') == True — seek changes the stream position to the given byte offset; its __name__ is 'seek'; str.__eq__('seek') returns True; new to extra262"]
    - [seek_qualname,
       "BufferedWriter.seek.__qualname__.__eq__",
       ["BufferedWriter.seek"],
       true,
       "io.BufferedWriter.seek.__qualname__.__eq__('BufferedWriter.seek') == True — the qualified name is 'BufferedWriter.seek'; str.__eq__('BufferedWriter.seek') returns True; new to extra262"]
    - [seek_class,
       "BufferedWriter.seek.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.BufferedWriter.seek.__class__.__name__.__eq__('method_descriptor') == True — seek is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra262"]
    - [tell_name,
       "BufferedWriter.tell.__name__.__eq__",
       ["tell"],
       true,
       "io.BufferedWriter.tell.__name__.__eq__('tell') == True — tell returns the current byte position in the stream; its __name__ is 'tell'; str.__eq__('tell') returns True; new to extra262"]
    - [tell_qualname,
       "BufferedWriter.tell.__qualname__.__eq__",
       ["BufferedWriter.tell"],
       true,
       "io.BufferedWriter.tell.__qualname__.__eq__('BufferedWriter.tell') == True — the qualified name is 'BufferedWriter.tell'; str.__eq__('BufferedWriter.tell') returns True; new to extra262"]

# ---------------------------------------------------------------------------
# Table 2: io.BufferedRandom class and method identity
#
# BufferedRandom is a buffered I/O implementation for seekable raw streams
# that supports both read and write operations. It inherits from _BufferedIOBase
# (the C-level base) and provides read, write, and seek as method_descriptor
# objects. The class itself is defined in the _io C extension.
# ---------------------------------------------------------------------------

table io_extra262.buffered_random_identity:
  description: "io.BufferedRandom class and method identity — __name__, __module__, base class, and read/write/seek; new to extra262"
  kind: python_call_eq
  category: identity
  id_prefix: ioxbrm262

  columns: [id, function, args, expected, description]
  rows:
    - [class_name,
       "BufferedRandom.__name__.__eq__",
       ["BufferedRandom"],
       true,
       "io.BufferedRandom.__name__.__eq__('BufferedRandom') == True — BufferedRandom is the buffered I/O class for seekable streams supporting both reads and writes; its __name__ is 'BufferedRandom'; str.__eq__('BufferedRandom') returns True; new to extra262"]
    - [class_module,
       "BufferedRandom.__module__.__eq__",
       ["_io"],
       true,
       "io.BufferedRandom.__module__.__eq__('_io') == True — BufferedRandom is implemented in the _io C extension, not the pure-Python io wrapper; its __module__ is '_io'; str.__eq__('_io') returns True; new to extra262"]
    - [base_class_name,
       "BufferedRandom.__bases__.__getitem__",
       [0],
       "_BufferedIOBase",
       "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — BufferedRandom inherits from _BufferedIOBase, the C-level abstract base for buffered I/O; __getitem__(0).__name__ is '_BufferedIOBase'; new to extra262"]
    - [read_name,
       "BufferedRandom.read.__name__.__eq__",
       ["read"],
       true,
       "io.BufferedRandom.read.__name__.__eq__('read') == True — read reads and returns up to n bytes; its __name__ is 'read'; str.__eq__('read') returns True; new to extra262"]
    - [read_qualname,
       "BufferedRandom.read.__qualname__.__eq__",
       ["BufferedRandom.read"],
       true,
       "io.BufferedRandom.read.__qualname__.__eq__('BufferedRandom.read') == True — the qualified name is 'BufferedRandom.read'; str.__eq__('BufferedRandom.read') returns True; new to extra262"]
    - [read_class,
       "BufferedRandom.read.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "io.BufferedRandom.read.__class__.__name__.__eq__('method_descriptor') == True — read is a C-level method_descriptor; str.__eq__('method_descriptor') returns True; new to extra262"]
    - [write_name,
       "BufferedRandom.write.__name__.__eq__",
       ["write"],
       true,
       "io.BufferedRandom.write.__name__.__eq__('write') == True — write writes bytes to the stream buffer; its __name__ is 'write'; str.__eq__('write') returns True; new to extra262"]
    - [write_qualname,
       "BufferedRandom.write.__qualname__.__eq__",
       ["BufferedRandom.write"],
       true,
       "io.BufferedRandom.write.__qualname__.__eq__('BufferedRandom.write') == True — the qualified name is 'BufferedRandom.write'; str.__eq__('BufferedRandom.write') returns True; new to extra262"]
    - [seek_name,
       "BufferedRandom.seek.__name__.__eq__",
       ["seek"],
       true,
       "io.BufferedRandom.seek.__name__.__eq__('seek') == True — seek is required for BufferedRandom because the underlying raw stream is seekable; its __name__ is 'seek'; str.__eq__('seek') returns True; new to extra262"]
    - [seek_qualname,
       "BufferedRandom.seek.__qualname__.__eq__",
       ["BufferedRandom.seek"],
       true,
       "io.BufferedRandom.seek.__qualname__.__eq__('BufferedRandom.seek') == True — the qualified name is 'BufferedRandom.seek'; str.__eq__('BufferedRandom.seek') returns True; new to extra262"]

# ---------------------------------------------------------------------------
# Standalone invariants — io_extra262
# ---------------------------------------------------------------------------

invariant io_extra262.buffered_writer_write_name:
  description: "io.BufferedWriter.write.__name__ == 'write' — the main write method for buffered output; new to extra262"
  kind: python_call_eq
  function: BufferedWriter.write.__name__.__eq__
  args: ["write"]
  expected: true

invariant io_extra262.buffered_writer_write_qualname:
  description: "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write' — qualified name includes the class; new to extra262"
  kind: python_call_eq
  function: BufferedWriter.write.__qualname__.__eq__
  args: ["BufferedWriter.write"]
  expected: true

invariant io_extra262.buffered_writer_write_is_method_descriptor:
  description: "io.BufferedWriter.write.__class__.__name__ == 'method_descriptor' — write is a C-level method_descriptor; new to extra262"
  kind: python_call_eq
  function: BufferedWriter.write.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant io_extra262.buffered_writer_flush_name:
  description: "io.BufferedWriter.flush.__name__ == 'flush' — flushes buffered bytes to the raw stream; new to extra262"
  kind: python_call_eq
  function: BufferedWriter.flush.__name__.__eq__
  args: ["flush"]
  expected: true

invariant io_extra262.buffered_writer_seek_name:
  description: "io.BufferedWriter.seek.__name__ == 'seek' — seeks to a given position in the stream; new to extra262"
  kind: python_call_eq
  function: BufferedWriter.seek.__name__.__eq__
  args: ["seek"]
  expected: true

invariant io_extra262.buffered_writer_tell_name:
  description: "io.BufferedWriter.tell.__name__ == 'tell' — returns the current stream position; new to extra262"
  kind: python_call_eq
  function: BufferedWriter.tell.__name__.__eq__
  args: ["tell"]
  expected: true

invariant io_extra262.buffered_random_class_name:
  description: "io.BufferedRandom.__name__ == 'BufferedRandom' — buffered I/O for seekable read-write streams; new to extra262"
  kind: python_call_eq
  function: BufferedRandom.__name__.__eq__
  args: ["BufferedRandom"]
  expected: true

invariant io_extra262.buffered_random_module:
  description: "io.BufferedRandom.__module__ == '_io' — the class is defined in the _io C extension; new to extra262"
  kind: python_call_eq
  function: BufferedRandom.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra262.buffered_random_base_is_bufferediobase:
  description: "io.BufferedRandom.__bases__[0].__name__ == '_BufferedIOBase' — BufferedRandom inherits from _BufferedIOBase; new to extra262"
  kind: python_call_eq
  function: "BufferedRandom.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra262.buffered_random_read_name:
  description: "io.BufferedRandom.read.__name__ == 'read' — reads bytes from the buffered random-access stream; new to extra262"
  kind: python_call_eq
  function: BufferedRandom.read.__name__.__eq__
  args: ["read"]
  expected: true

invariant io_extra262.buffered_random_write_name:
  description: "io.BufferedRandom.write.__name__ == 'write' — writes bytes to the buffered random-access stream; new to extra262"
  kind: python_call_eq
  function: BufferedRandom.write.__name__.__eq__
  args: ["write"]
  expected: true

invariant io_extra262.buffered_random_seek_name:
  description: "io.BufferedRandom.seek.__name__ == 'seek' — seeks to a position in the seekable random-access stream; new to extra262"
  kind: python_call_eq
  function: BufferedRandom.seek.__name__.__eq__
  args: ["seek"]
  expected: true
