spec: reprlib_extra16
version: ">=3.9"
backend: python_module(reprlib)

docs: https://docs.python.org/3/library/reprlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/reprlib.html — Python reprlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/reprlib.py"
  notes:
    - "This spec extends reprlib.zspec.zsdl through reprlib_extra15.zspec.zsdl."
    - "reprlib_extra4 covers: repr.__qualname__=='Repr.repr' (the module-level bound method)."
    - "reprlib_extra3 covers: Repr.repr_list.__func__.__name__=='repr_list' via method_chain (not a __qualname__ invariant)."
    - "No prior spec verifies Repr.repr_int.__qualname__, Repr.repr_str.__qualname__, Repr.repr_list.__qualname__, Repr.repr_tuple.__qualname__, Repr.repr_dict.__qualname__, or Repr.repr_set.__qualname__ as standalone invariants."
    - "No prior spec verifies Repr.repr.__qualname__ (the unbound method on the class) as a standalone invariant distinct from the reprlib_extra4 bound-method check."
    - "This spec covers: Repr.repr.__qualname__=='Repr.repr'; Repr.repr_int.__qualname__=='Repr.repr_int'; Repr.repr_str.__qualname__=='Repr.repr_str'; Repr.repr_list.__qualname__=='Repr.repr_list'; Repr.repr_tuple.__qualname__=='Repr.repr_tuple'; Repr.repr_dict.__qualname__=='Repr.repr_dict'; Repr.repr_set.__qualname__=='Repr.repr_set'."
    - "reprlib.Repr.repr.__qualname__ == 'Repr.repr' — unbound method qualname includes owning class. Verified at runtime."
    - "reprlib.Repr.repr_int.__qualname__ == 'Repr.repr_int' — method qualname includes owning class. Verified at runtime."
    - "reprlib.Repr.repr_str.__qualname__ == 'Repr.repr_str' — method qualname includes owning class. Verified at runtime."
    - "reprlib.Repr.repr_list.__qualname__ == 'Repr.repr_list' — method qualname includes owning class. Verified at runtime."
    - "reprlib.Repr.repr_tuple.__qualname__ == 'Repr.repr_tuple' — method qualname includes owning class. Verified at runtime."
    - "reprlib.Repr.repr_dict.__qualname__ == 'Repr.repr_dict' — method qualname includes owning class. Verified at runtime."
    - "reprlib.Repr.repr_set.__qualname__ == 'Repr.repr_set' — method qualname includes owning class. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Repr.repr method __qualname__
#
# reprlib_extra4 covers reprlib.repr.__qualname__ == 'Repr.repr' for the
# module-level bound method. No prior spec anchors Repr.repr.__qualname__
# (unbound form accessed via the class) as a standalone invariant.
# For methods defined in class Repr, __qualname__ takes the form 'Repr.<name>'.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra16.Repr.repr_qualname:
  description: "reprlib.Repr.repr.__qualname__ == 'Repr.repr' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr.__qualname__.__eq__
  args: ["Repr.repr"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr_int method __qualname__
#
# No prior spec verifies Repr.repr_int.__qualname__ as a standalone invariant.
# repr_int converts a Python int to its repr string, truncated to maxlong chars.
# Verified: Repr.repr_int.__qualname__ == 'Repr.repr_int'.
# ---------------------------------------------------------------------------

invariant reprlib_extra16.Repr.repr_int_qualname:
  description: "reprlib.Repr.repr_int.__qualname__ == 'Repr.repr_int' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_int.__qualname__.__eq__
  args: ["Repr.repr_int"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr_str method __qualname__
#
# No prior spec verifies Repr.repr_str.__qualname__ as a standalone invariant.
# Verified: Repr.repr_str.__qualname__ == 'Repr.repr_str'.
# ---------------------------------------------------------------------------

invariant reprlib_extra16.Repr.repr_str_qualname:
  description: "reprlib.Repr.repr_str.__qualname__ == 'Repr.repr_str' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_str.__qualname__.__eq__
  args: ["Repr.repr_str"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr_list and Repr.repr_tuple method __qualname__
#
# reprlib_extra3 covers repr_list via Repr.repr_list.__func__.__name__ in a
# method_chain context — not a standalone __qualname__ invariant.
# No prior spec verifies Repr.repr_list.__qualname__ or
# Repr.repr_tuple.__qualname__ as standalone invariants.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra16.Repr.repr_list_qualname:
  description: "reprlib.Repr.repr_list.__qualname__ == 'Repr.repr_list' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_list.__qualname__.__eq__
  args: ["Repr.repr_list"]
  expected: true

invariant reprlib_extra16.Repr.repr_tuple_qualname:
  description: "reprlib.Repr.repr_tuple.__qualname__ == 'Repr.repr_tuple' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_tuple.__qualname__.__eq__
  args: ["Repr.repr_tuple"]
  expected: true

# ---------------------------------------------------------------------------
# Repr.repr_dict and Repr.repr_set method __qualname__
#
# No prior spec verifies Repr.repr_dict.__qualname__ or Repr.repr_set.__qualname__
# as standalone invariants.
# Verified at runtime.
# ---------------------------------------------------------------------------

invariant reprlib_extra16.Repr.repr_dict_qualname:
  description: "reprlib.Repr.repr_dict.__qualname__ == 'Repr.repr_dict' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_dict.__qualname__.__eq__
  args: ["Repr.repr_dict"]
  expected: true

invariant reprlib_extra16.Repr.repr_set_qualname:
  description: "reprlib.Repr.repr_set.__qualname__ == 'Repr.repr_set' — method qualname includes owning class"
  category: function_identity
  kind: python_call_eq
  function: Repr.repr_set.__qualname__.__eq__
  args: ["Repr.repr_set"]
  expected: true

# ---------------------------------------------------------------------------
# Table: Repr class method __qualname__ attributes
#
# Groups all seven Repr method qualname checks in one indexed table.
# No prior table covers Repr instance method __qualname__ values.
# All verified at runtime: each __qualname__ takes the form 'Repr.<name>'.
# ---------------------------------------------------------------------------

table reprlib_extra16.Repr_method_qualnames:
  description: "reprlib.Repr method __qualname__ attributes — all include owning class prefix"
  kind: python_call_eq
  category: function_identity
  id_prefix: rl16mq

  columns: [id, function, args, expected]
  rows:
    - [repr,       Repr.repr.__qualname__.__eq__,       ["Repr.repr"],       true]
    - [repr_int,   Repr.repr_int.__qualname__.__eq__,   ["Repr.repr_int"],   true]
    - [repr_str,   Repr.repr_str.__qualname__.__eq__,   ["Repr.repr_str"],   true]
    - [repr_list,  Repr.repr_list.__qualname__.__eq__,  ["Repr.repr_list"],  true]
    - [repr_tuple, Repr.repr_tuple.__qualname__.__eq__, ["Repr.repr_tuple"], true]
    - [repr_dict,  Repr.repr_dict.__qualname__.__eq__,  ["Repr.repr_dict"],  true]
    - [repr_set,   Repr.repr_set.__qualname__.__eq__,   ["Repr.repr_set"],   true]
