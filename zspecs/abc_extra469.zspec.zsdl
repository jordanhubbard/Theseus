spec: abc_extra469
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc.ABCMeta methods and abc.abstractmethod identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers method __name__ identity for ABCMeta.register, __instancecheck__, __subclasscheck__, _dump_registry, _abc_caches_clear, and abc.abstractmethod.__name__"
    - "abc.ABC.__abstractmethods__ is a frozenset; its __class__.__name__ is tested via the class attribute chain"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra469.abcmeta_method_names:
  description: "abc.ABCMeta method __name__ identity"
  kind: python_call_eq
  category: method_identity
  id_prefix: abcm

  columns: [id, function, args, expected]
  rows:
    - [abcm001, abc.ABCMeta.register.__name__.__eq__, ["register"], true]
    - [abcm002, abc.ABCMeta.__instancecheck__.__name__.__eq__, ["__instancecheck__"], true]
    - [abcm003, abc.ABCMeta.__subclasscheck__.__name__.__eq__, ["__subclasscheck__"], true]
    - [abcm004, abc.ABCMeta._dump_registry.__name__.__eq__, ["_dump_registry"], true]
    - [abcm005, abc.ABCMeta._abc_caches_clear.__name__.__eq__, ["_abc_caches_clear"], true]

table abc_extra469.abstractmethod_identity:
  description: "abc.abstractmethod decorator __name__ identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: abst

  columns: [id, function, args, expected]
  rows:
    - [abst001, abc.abstractmethod.__name__.__eq__, ["abstractmethod"], true]

table abc_extra469.abc_abstractmethods_class:
  description: "abc.ABC.__abstractmethods__ is a frozenset"
  kind: python_call_eq
  category: class_identity
  id_prefix: abcset

  columns: [id, function, args, expected]
  rows:
    - [abcset001, abc.ABC.__abstractmethods__.__class__.__name__.__eq__, ["frozenset"], true]
