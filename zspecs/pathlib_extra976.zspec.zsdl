error_model: python_exceptions

table pathlib_extra976.purepath_repr_qualnames:
  description: "pathlib.PurePath string representation method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: pl976r
  columns: [id, function, args, expected]
  rows:
    - [pl976r001, pathlib.PurePath.__str__.__qualname__.__eq__,  ["PurePath.__str__"],  true]
    - [pl976r002, pathlib.PurePath.__repr__.__qualname__.__eq__, ["PurePath.__repr__"], true]
    - [pl976r003, pathlib.PurePath.__hash__.__qualname__.__eq__, ["PurePath.__hash__"], true]

