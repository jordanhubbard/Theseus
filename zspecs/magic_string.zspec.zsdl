spec: magic_string
version: ">=0.30.0"
backend: node(magic-string)

docs: https://github.com/Rich-Harris/magic-string#readme

provenance:
  derived_from:
    - "magic-string README — https://github.com/Rich-Harris/magic-string#readme"
    - "Test vectors verified with magic-string via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "magic-string source"
  notes:
    - "Mutation-tracking string transformer with sourcemap support — used by Vite, Rollup, Astro."
    - "Install: npm install magic-string"
    - "v0.30 ESM with CJS shim; default export is the MagicString class."
    - "Chain steps use {tap: true} for mutators (.replace, .prepend, .append) which return the instance for chaining but the chain helper otherwise reassigns v."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Constructor throws on non-string input."
  stderr: "null"
  stickiness: "Mutations accumulate on the instance; toString() emits the current state."
  codes: {}

invariant magic_string.toString_initial_returns_input:
  description: "Fresh MagicString.toString() returns the input"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: ["hello world"]
  chain:
    - {method: toString, args: []}
  expected: "hello world"

invariant magic_string.original_property:
  description: ".original always returns the input string regardless of mutations"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: ["hello world"]
  chain:
    - {get: original}
  expected: "hello world"

invariant magic_string.replace_then_toString:
  description: "After .replace('hello', 'hi') the toString() reflects the change"
  category: replace
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: ["hello world"]
  chain:
    - {method: replace, args: ["hello", "hi"]}
    - {method: toString, args: []}
  expected: "hi world"

invariant magic_string.prepend_then_toString:
  description: "prepend then toString shows the prepended text"
  category: prepend
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: ["world"]
  chain:
    - {method: prepend, args: ["hello "]}
    - {method: toString, args: []}
  expected: "hello world"

invariant magic_string.append_then_toString:
  description: "append then toString shows the appended text"
  category: append
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: ["hello"]
  chain:
    - {method: append, args: [" world"]}
    - {method: toString, args: []}
  expected: "hello world"

invariant magic_string.length_initial:
  description: "MagicString length matches input length"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: ["hello"]
  chain:
    - {method: length, args: []}
  expected: 5

invariant magic_string.original_unchanged_after_replace:
  description: ".original is preserved after a mutation"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: ["hello world"]
  chain:
    - {method: replace, args: ["hello", "hi"], tap: true}
    - {get: original}
  expected: "hello world"

invariant magic_string.append_left:
  description: "appendLeft(0, 'X') prepends at offset 0"
  category: appendLeft
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: ["abc"]
  chain:
    - {method: appendLeft, args: [0, "X"]}
    - {method: toString, args: []}
  expected: "Xabc"

invariant magic_string.empty_input:
  description: "MagicString('').toString() is ''"
  category: edge
  kind: node_chain_eq
  entry: constructor
  class: default
  entry_args: [""]
  chain:
    - {method: toString, args: []}
  expected: ""
