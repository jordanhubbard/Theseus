spec: os_path_extra17
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py, Lib/genericpath.py"
    - "os_path_extra16.zspec.zsdl — covers __qualname__ equality and __module__ for join/split/exists/isfile/isdir/basename/dirname."
  notes:
    - "This spec extends os_path_extra16.zspec.zsdl."
    - "Focus: __qualname__ string lengths for os.path public functions."
    - "No prior os.path spec covers __qualname__.__len__() for any function."
    - "os.path.join.__qualname__.__len__() == 4 — 'join' has 4 characters."
    - "os.path.split.__qualname__.__len__() == 5 — 'split' has 5 characters."
    - "os.path.basename.__qualname__.__len__() == 8 — 'basename' has 8 characters."
    - "os.path.dirname.__qualname__.__len__() == 7 — 'dirname' has 7 characters."
    - "os.path.exists.__qualname__.__len__() == 6 — 'exists' has 6 characters."
    - "os.path.isfile.__qualname__.__len__() == 6 — 'isfile' has 6 characters."
    - "os.path.isdir.__qualname__.__len__() == 5 — 'isdir' has 5 characters."
    - "os.path.abspath.__qualname__.__len__() == 7 — 'abspath' has 7 characters."
    - "os.path.expanduser.__qualname__.__len__() == 10 — 'expanduser' has 10 characters."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__ length for os.path public functions
#
# os_path_extra16 covers __qualname__ equality for join/split/exists/isfile/
# isdir/basename/dirname. os_path_extra6 covers abspath.__qualname__ equality.
# os_path_extra8 covers expanduser.__qualname__ equality.
# No prior os.path spec covers __qualname__.__len__() for any function.
# This table groups all nine functions in the extra17 namespace.
# ---------------------------------------------------------------------------

table os_path_extra17.function_qualname_lengths:
  description: "__qualname__.__len__() for os.path public functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: fqlen17

  columns: [id, function, args, expected]
  rows:
    - [join,       join.__qualname__.__len__,       [], 4]
    - [split,      split.__qualname__.__len__,      [], 5]
    - [basename,   basename.__qualname__.__len__,   [], 8]
    - [dirname,    dirname.__qualname__.__len__,    [], 7]
    - [exists,     exists.__qualname__.__len__,     [], 6]
    - [isfile,     isfile.__qualname__.__len__,     [], 6]
    - [isdir,      isdir.__qualname__.__len__,      [], 5]
    - [abspath,    abspath.__qualname__.__len__,    [], 7]
    - [expanduser, expanduser.__qualname__.__len__, [], 10]

# ---------------------------------------------------------------------------
# Standalone: join __qualname__ length
#
# 'join' is the shortest qualname in the table (4 chars). Standalone invariant
# anchors it independently for direct lookup in the extra17 namespace.
# ---------------------------------------------------------------------------

invariant os_path_extra17.join.qualname_length:
  description: "os.path.join.__qualname__.__len__() == 4 — 'join' has 4 characters"
  category: function_identity
  kind: python_call_eq
  function: join.__qualname__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Standalone: expanduser __qualname__ length
#
# 'expanduser' is the longest qualname in the table (10 chars). Standalone
# invariant anchors it independently for direct lookup in the extra17 namespace.
# ---------------------------------------------------------------------------

invariant os_path_extra17.expanduser.qualname_length:
  description: "os.path.expanduser.__qualname__.__len__() == 10 — 'expanduser' has 10 characters"
  category: function_identity
  kind: python_call_eq
  function: expanduser.__qualname__.__len__
  args: []
  expected: 10
