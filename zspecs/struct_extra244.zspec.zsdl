spec: struct_extra244
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra.zspec.zsdl — covers calcsize for '>f'/'>d'/'>B'/'4s'/'>BHI' formats / Struct format/size attributes / pack_into method name (table + invariants)."
    - "struct_extra243.zspec.zsdl — covers calcsize B/H/I/Q/f/d/10s / Struct.size for B/>I/>Q / unpack results / struct.error class identity (table + invariants)."
  notes:
    - "Wave 293 theme: struct.Struct class identity / additional Struct.size format strings / module-level function identity."
    - "struct.Struct.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('>I').size == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('<I').size == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('>IH').size == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('4s').size == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('!IH').size == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__name__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__name__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__name__ == 'calcsize'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.__module__ is '_struct' (the C extension module), not 'struct' (the Python wrapper module). This is because the Struct type is implemented in C in Modules/_struct.c. Module-level functions pack/unpack/calcsize also report __module__=='_struct' for the same reason."
    - "Note: Struct('>I').size == Struct('<I').size == 4 because endianness (byte order) affects the byte layout of packed data but not the total byte count for fixed-size types like I (unsigned int)."
    - "Note: Struct('>IH').size == 6: big-endian I (4 bytes) + H (2 bytes) = 6 bytes total. Same as calcsize('>IH')==6. '!' (network byte order) is equivalent to '>' (big-endian) for size purposes: Struct('!IH').size==6."
    - "Note: Struct('4s').size == 4: '4s' is a 4-byte fixed-length string/bytes field. The count prefix gives the field byte width directly."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct class identity: __name__, __module__, __qualname__, __bases__
#
# Wave 293 theme: struct.Struct C-extension class identity attributes.
#
# struct.Struct is the pre-compiled struct class defined in Modules/_struct.c.
# Its __name__ and __qualname__ are both 'Struct'; its __module__ is '_struct'
# (the C extension, not the Python wrapper 'struct'). It inherits directly from
# object. struct_extra100 anchors Struct instance method qualname lengths;
# struct_extra243 anchors calcsize and error class; no prior spec anchors
# Struct.__name__/__module__/__qualname__/__bases__[0].__name__ together as
# a grouped table under structclass293.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra244.Struct_class_identity:
  description: "Struct.__name__.__eq__('Struct')==True / Struct.__module__.__eq__('_struct')==True / Struct.__qualname__.__eq__('Struct')==True / \"struct.Struct.__bases__[0].__name__.__eq__\"('object')==True — Struct is a C-extension type from Modules/_struct.c; __module__=='_struct' (not 'struct'); __name__==__qualname__=='Struct' (top-level C type); inherits directly from object; extra100 anchors method qualname lengths; this spec anchors class-level identity attrs; first structclass293 anchor"
  kind: python_call_eq
  category: class_identity
  id_prefix: structclass293

  columns: [id, function, args, expected, description]
  rows:
    - [struct_name_eq,     "Struct.__name__.__eq__",                       ["Struct"],  true, "struct.Struct.__name__ is 'Struct' (C type name as defined in _struct.c)"]
    - [struct_module_eq,   "Struct.__module__.__eq__",                     ["_struct"], true, "struct.Struct.__module__ is '_struct' (C extension, not Python 'struct' wrapper)"]
    - [struct_qualname_eq, "Struct.__qualname__.__eq__",                   ["Struct"],  true, "struct.Struct.__qualname__ is 'Struct' (same as __name__ for top-level C types)"]
    - [struct_bases_obj,   "struct.Struct.__bases__[0].__name__.__eq__",   ["object"],  true, "struct.Struct.__bases__[0].__name__ is 'object' (inherits directly from object)"]

# ---------------------------------------------------------------------------
# struct.Struct.size for additional format strings: >I, <I, >IH, 4s, !IH
#
# Wave 293 theme: Struct.size for multi-field and fixed-string formats.
#
# struct_extra.zspec anchors Struct('>H').size==2 and Struct('>BHI').size==7;
# struct_extra243 anchors Struct('B').size==1, Struct('>I').size==4,
# Struct('>Q').size==8. This spec anchors: Struct('<I').size==4 (little-endian
# same as big-endian for I), Struct('>IH').size==6 (4+2), Struct('4s').size==4
# (4-byte fixed string), Struct('!IH').size==6 (network byte order, equiv to >).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra244.Struct_size_formats:
  description: "Struct('>I').size.__eq__(4)==True / Struct('<I').size.__eq__(4)==True / Struct('>IH').size.__eq__(6)==True / Struct('4s').size.__eq__(4)==True / Struct('!IH').size.__eq__(6)==True — endianness prefix does not change byte count for fixed-size types; I=4 bytes regardless of '<'/'>'; '>IH'=6 (4+2); '4s'=4 (count prefix=byte width); '!'='>' (network==big-endian) for sizes; extra anchors '>H'==2 and '>BHI'==7; first structclass293 anchor for these format sizes"
  kind: python_call_eq
  category: struct_size
  id_prefix: structclass293

  columns: [id, function, args, expected, description]
  rows:
    - [size_be_I,   "Struct('>I').size.__eq__",  [4], true, "Struct('>I').size is 4 (big-endian unsigned int; 4 bytes)"]
    - [size_le_I,   "Struct('<I').size.__eq__",  [4], true, "Struct('<I').size is 4 (little-endian; same byte count as big-endian)"]
    - [size_be_IH,  "Struct('>IH').size.__eq__", [6], true, "Struct('>IH').size is 6 (I=4 + H=2 bytes; big-endian multi-field)"]
    - [size_4s,     "Struct('4s').size.__eq__",  [4], true, "Struct('4s').size is 4 (fixed-length 4-byte string field)"]
    - [size_net_IH, "Struct('!IH').size.__eq__", [6], true, "Struct('!IH').size is 6 (network byte order '!' == big-endian for sizes)"]

# ---------------------------------------------------------------------------
# struct module-level function identity: pack, unpack, calcsize
#
# Wave 293 theme: struct module-level C function __name__ and __module__.
#
# struct.pack, struct.unpack, and struct.calcsize are builtin_function_or_method
# objects defined in Modules/_struct.c. Their __name__ matches the function name;
# their __module__ is '_struct' (the C extension). struct_extra100 anchors
# method qualname lengths; no prior spec anchors __name__ for pack/unpack/calcsize
# together as a grouped table under structclass293.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra244.module_function_identity:
  description: "pack.__name__.__eq__('pack')==True / pack.__module__.__eq__('_struct')==True / unpack.__name__.__eq__('unpack')==True / unpack.__module__.__eq__('_struct')==True / calcsize.__name__.__eq__('calcsize')==True — pack/unpack/calcsize are C builtins from Modules/_struct.c; __name__ matches function name; __module__=='_struct' (not 'struct'); extra100 anchors method qualnames; first structclass293 anchor for module-level function __name__ and __module__"
  kind: python_call_eq
  category: function_identity
  id_prefix: structclass293

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_eq,      "pack.__name__.__eq__",      ["pack"],    true, "struct.pack.__name__ is 'pack' (C builtin in _struct)"]
    - [pack_module_eq,    "pack.__module__.__eq__",    ["_struct"], true, "struct.pack.__module__ is '_struct' (C extension module)"]
    - [unpack_name_eq,    "unpack.__name__.__eq__",    ["unpack"],  true, "struct.unpack.__name__ is 'unpack' (C builtin in _struct)"]
    - [unpack_module_eq,  "unpack.__module__.__eq__",  ["_struct"], true, "struct.unpack.__module__ is '_struct' (C extension module)"]
    - [calcsize_name_eq,  "calcsize.__name__.__eq__",  ["calcsize"], true, "struct.calcsize.__name__ is 'calcsize' (C builtin in _struct)"]

# ---------------------------------------------------------------------------
# struct.Struct.__name__.__eq__('Struct') — standalone
#
# struct.Struct.__name__ is 'Struct'. The Struct class is a C extension type
# defined in Modules/_struct.c as PyStructType with tp_name 'Struct'. It is
# re-exported through the Python 'struct' wrapper module as struct.Struct.
# Instantiating Struct with a format string pre-compiles the format for
# efficient repeated pack/unpack operations. struct_extra100 anchors Struct
# method qualname lengths; no prior spec anchors Struct.__name__.__eq__ as a
# standalone under structclass293. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra244.Struct_name_eq:
  description: "struct.Struct.__name__.__eq__('Struct') == True — Struct.__name__ is 'Struct' (C type tp_name; re-exported via struct module); pre-compiles format strings for efficient repeated pack/unpack; extra100 anchors method qualname lengths; no prior spec anchors Struct.__name__.__eq__ as standalone; first standalone under structclass293"
  category: class_identity
  kind: python_call_eq
  function: "Struct.__name__.__eq__"
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__module__.__eq__('_struct') — standalone
#
# struct.Struct.__module__ is '_struct'. Although struct.Struct is accessed
# through the 'struct' module, the type itself is defined in the C extension
# '_struct'. This means pickle would look for Struct in '_struct', not 'struct'.
# The distinction is that the Python module 'struct' is a thin wrapper that
# imports from '_struct' and re-exports its contents. struct_extra.zspec
# does not anchor Struct.__module__; no prior spec anchors this as a standalone
# under structclass293. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra244.Struct_module_eq:
  description: "struct.Struct.__module__.__eq__('_struct') == True — Struct.__module__ is '_struct' (the C extension), not 'struct' (the Python wrapper); 'struct' is a thin wrapper that re-exports from '_struct'; pickle would resolve Struct via '_struct'; struct_extra does not anchor __module__; first standalone for Struct.__module__ under structclass293"
  category: class_identity
  kind: python_call_eq
  function: "Struct.__module__.__eq__"
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct('>IH').size == 6 — standalone
#
# struct.Struct('>IH').size is 6. The format '>IH' specifies a big-endian
# unsigned int (I, 4 bytes) followed by a big-endian unsigned short (H, 2 bytes),
# for a total of 6 bytes. This is a common format for protocol headers that
# combine a 32-bit value with a 16-bit value (e.g., length prefix + port number).
# struct_extra.zspec anchors Struct('>BHI').size==7; struct_extra243 anchors
# Struct('>I').size==4; no prior spec anchors Struct('>IH').size as a standalone
# under structclass293. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra244.Struct_IH_size_6:
  description: "struct.Struct('>IH').size.__eq__(6) == True — '>IH' packs big-endian I (4 bytes) + H (2 bytes) = 6 bytes; common protocol header pattern (32-bit length + 16-bit port); struct_extra anchors '>BHI'==7; struct_extra243 anchors '>I'==4; no prior spec anchors '>IH' size as standalone; first standalone under structclass293"
  category: struct_size
  kind: python_call_eq
  function: Struct
  args: [">IH"]
  method: size.__eq__
  method_args: [6]
  expected: true
