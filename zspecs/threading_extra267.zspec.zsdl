spec: threading_extra267
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.Lock is actually the C-level class _thread.lock (lowercase): __name__ == 'lock', __module__ == '_thread'."
    - "threading.RLock is a Python factory function (not a class): __class__.__name__ == 'function', __module__ == 'threading'."
    - "threading.Thread, Event, Condition, Semaphore, Timer, Barrier are all Python classes with __class__.__name__ == 'type'."
    - "All Python threading classes have __module__ == 'threading' (len=9)."
    - "Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread (not object)."
    - "Thread, Condition, Semaphore names tied at lengths: Thread(6), Event(5), Condition(9)==Semaphore(9), Timer(5)==Event(5), Barrier(7)."
    - "Condition.__name__ (9) == Semaphore.__name__ (9) — tied longest Python class names in spec."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading class identity: Thread, Event, Condition, Semaphore, Timer, Barrier
#
# All are Python classes (__class__.__name__ == 'type') in threading (len=9).
# Condition.__name__ (9) == Semaphore.__name__ (9) — tied longest.
# Event.__name__ (5) == Timer.__name__ (5) — tied shortest.
# Timer subclasses Thread; all others subclass object.
# ---------------------------------------------------------------------------

table threading_extra267.class_identity:
  description: "threading.Thread(6), Event(5), Condition(9), Semaphore(9), Timer(5), Barrier(7) identity — all Python classes (type) in threading(9); Condition and Semaphore names(9) tied longest; Event and Timer names(5) tied shortest; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex267ci

  columns: [id, function, args, expected, description]
  rows:
    - [th_name_eq,       Thread.__name__.__eq__,                     ["Thread"],                     true, "threading.Thread.__name__ == 'Thread'; verified with Python 3.14.3"]
    - [th_name_len,      Thread.__name__.__len__,                    [],                             6,    "threading.Thread.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [th_qn_eq,         Thread.__qualname__.__eq__,                 ["Thread"],                     true, "threading.Thread.__qualname__ == 'Thread' — qualname equals name; verified with Python 3.14.3"]
    - [th_mod_eq,        Thread.__module__.__eq__,                   ["threading"],                  true, "threading.Thread.__module__ == 'threading'; verified with Python 3.14.3"]
    - [th_mod_len,       Thread.__module__.__len__,                  [],                             9,    "threading.Thread.__module__.__len__() == 9; verified with Python 3.14.3"]
    - [th_cls_eq,        Thread.__class__.__name__.__eq__,           ["type"],                       true, "threading.Thread.__class__.__name__ == 'type' — Python class; verified with Python 3.14.3"]
    - [ev_name_eq,       Event.__name__.__eq__,                      ["Event"],                      true, "threading.Event.__name__ == 'Event'; verified with Python 3.14.3"]
    - [ev_name_len,      Event.__name__.__len__,                     [],                             5,    "threading.Event.__name__.__len__() == 5 — tied shortest with Timer; verified with Python 3.14.3"]
    - [ev_qn_eq,         Event.__qualname__.__eq__,                  ["Event"],                      true, "threading.Event.__qualname__ == 'Event' — qualname equals name; verified with Python 3.14.3"]
    - [ev_mod_eq,        Event.__module__.__eq__,                    ["threading"],                  true, "threading.Event.__module__ == 'threading'; verified with Python 3.14.3"]
    - [ev_cls_eq,        Event.__class__.__name__.__eq__,            ["type"],                       true, "threading.Event.__class__.__name__ == 'type' — Python class; verified with Python 3.14.3"]
    - [co_name_eq,       Condition.__name__.__eq__,                  ["Condition"],                  true, "threading.Condition.__name__ == 'Condition'; verified with Python 3.14.3"]
    - [co_name_len,      Condition.__name__.__len__,                 [],                             9,    "threading.Condition.__name__.__len__() == 9 — tied longest with Semaphore; equals module name length; verified with Python 3.14.3"]
    - [co_qn_eq,         Condition.__qualname__.__eq__,              ["Condition"],                  true, "threading.Condition.__qualname__ == 'Condition' — qualname equals name; verified with Python 3.14.3"]
    - [co_mod_eq,        Condition.__module__.__eq__,                ["threading"],                  true, "threading.Condition.__module__ == 'threading'; verified with Python 3.14.3"]
    - [co_cls_eq,        Condition.__class__.__name__.__eq__,        ["type"],                       true, "threading.Condition.__class__.__name__ == 'type' — Python class; verified with Python 3.14.3"]
    - [se_name_eq,       Semaphore.__name__.__eq__,                  ["Semaphore"],                  true, "threading.Semaphore.__name__ == 'Semaphore'; verified with Python 3.14.3"]
    - [se_name_len,      Semaphore.__name__.__len__,                 [],                             9,    "threading.Semaphore.__name__.__len__() == 9 — tied longest with Condition; verified with Python 3.14.3"]
    - [se_qn_eq,         Semaphore.__qualname__.__eq__,              ["Semaphore"],                  true, "threading.Semaphore.__qualname__ == 'Semaphore' — qualname equals name; verified with Python 3.14.3"]
    - [se_mod_eq,        Semaphore.__module__.__eq__,                ["threading"],                  true, "threading.Semaphore.__module__ == 'threading'; verified with Python 3.14.3"]
    - [se_cls_eq,        Semaphore.__class__.__name__.__eq__,        ["type"],                       true, "threading.Semaphore.__class__.__name__ == 'type' — Python class; verified with Python 3.14.3"]
    - [ti_name_eq,       Timer.__name__.__eq__,                      ["Timer"],                      true, "threading.Timer.__name__ == 'Timer'; verified with Python 3.14.3"]
    - [ti_name_len,      Timer.__name__.__len__,                     [],                             5,    "threading.Timer.__name__.__len__() == 5 — tied shortest with Event; verified with Python 3.14.3"]
    - [ti_qn_eq,         Timer.__qualname__.__eq__,                  ["Timer"],                      true, "threading.Timer.__qualname__ == 'Timer' — qualname equals name; verified with Python 3.14.3"]
    - [ti_mod_eq,        Timer.__module__.__eq__,                    ["threading"],                  true, "threading.Timer.__module__ == 'threading'; verified with Python 3.14.3"]
    - [ti_cls_eq,        Timer.__class__.__name__.__eq__,            ["type"],                       true, "threading.Timer.__class__.__name__ == 'type' — Python class; verified with Python 3.14.3"]
    - [ba_name_eq,       Barrier.__name__.__eq__,                    ["Barrier"],                    true, "threading.Barrier.__name__ == 'Barrier'; verified with Python 3.14.3"]
    - [ba_name_len,      Barrier.__name__.__len__,                   [],                             7,    "threading.Barrier.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [ba_qn_eq,         Barrier.__qualname__.__eq__,                ["Barrier"],                    true, "threading.Barrier.__qualname__ == 'Barrier' — qualname equals name; verified with Python 3.14.3"]
    - [ba_mod_eq,        Barrier.__module__.__eq__,                  ["threading"],                  true, "threading.Barrier.__module__ == 'threading'; verified with Python 3.14.3"]
    - [ba_cls_eq,        Barrier.__class__.__name__.__eq__,          ["type"],                       true, "threading.Barrier.__class__.__name__ == 'type' — Python class; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading base class checks and special members identity
#
# Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread.
# All other Python classes (Thread, Event, Condition, Semaphore, Barrier)
# have __bases__[0].__name__ == 'object'.
# threading.Lock.__name__ == 'lock' (lowercase C-level type from _thread).
# threading.RLock is a factory function: __class__.__name__ == 'function'.
# ---------------------------------------------------------------------------

table threading_extra267.base_class_and_special_identity:
  description: "threading base classes and special member identity — Timer subclasses Thread; Thread/Event/Condition/Semaphore/Barrier all subclass object; Lock.__name__=='lock'(4, lowercase, C-level from _thread); RLock is a function; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex267bs

  columns: [id, function, args, expected, description]
  rows:
    - [th_base_eq,       "Thread.__bases__[0].__name__.__eq__",      ["object"],                     true, "threading.Thread.__bases__[0].__name__ == 'object' — Thread inherits from object; verified with Python 3.14.3"]
    - [ev_base_eq,       "Event.__bases__[0].__name__.__eq__",       ["object"],                     true, "threading.Event.__bases__[0].__name__ == 'object' — Event inherits from object; verified with Python 3.14.3"]
    - [co_base_eq,       "Condition.__bases__[0].__name__.__eq__",   ["object"],                     true, "threading.Condition.__bases__[0].__name__ == 'object' — Condition inherits from object; verified with Python 3.14.3"]
    - [se_base_eq,       "Semaphore.__bases__[0].__name__.__eq__",   ["object"],                     true, "threading.Semaphore.__bases__[0].__name__ == 'object' — Semaphore inherits from object; verified with Python 3.14.3"]
    - [ti_base_eq,       "Timer.__bases__[0].__name__.__eq__",       ["Thread"],                     true, "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread, not object; verified with Python 3.14.3"]
    - [ti_base_len,      "Timer.__bases__[0].__name__.__len__",      [],                             6,    "threading.Timer.__bases__[0].__name__.__len__() == 6 — 'Thread' has length 6; verified with Python 3.14.3"]
    - [ba_base_eq,       "Barrier.__bases__[0].__name__.__eq__",     ["object"],                     true, "threading.Barrier.__bases__[0].__name__ == 'object' — Barrier inherits from object; verified with Python 3.14.3"]
    - [lk_name_eq,       Lock.__name__.__eq__,                       ["lock"],                       true, "threading.Lock.__name__ == 'lock' (lowercase) — Lock is the C-level _thread.lock class; verified with Python 3.14.3"]
    - [lk_name_len,      Lock.__name__.__len__,                      [],                             4,    "threading.Lock.__name__.__len__() == 4 — 'lock' (lowercase); verified with Python 3.14.3"]
    - [lk_mod_eq,        Lock.__module__.__eq__,                     ["_thread"],                    true, "threading.Lock.__module__ == '_thread' — Lock is implemented in the C extension _thread; verified with Python 3.14.3"]
    - [lk_cls_eq,        Lock.__class__.__name__.__eq__,             ["type"],                       true, "threading.Lock.__class__.__name__ == 'type' — Lock is a C-level class; verified with Python 3.14.3"]
    - [rl_name_eq,       RLock.__name__.__eq__,                      ["RLock"],                      true, "threading.RLock.__name__ == 'RLock'; verified with Python 3.14.3"]
    - [rl_name_len,      RLock.__name__.__len__,                     [],                             5,    "threading.RLock.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [rl_mod_eq,        RLock.__module__.__eq__,                    ["threading"],                  true, "threading.RLock.__module__ == 'threading' — RLock is defined in the Python threading module; verified with Python 3.14.3"]
    - [rl_cls_eq,        RLock.__class__.__name__.__eq__,            ["function"],                   true, "threading.RLock.__class__.__name__ == 'function' — RLock is a factory function, not a class; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra267
# ---------------------------------------------------------------------------

invariant threading_extra267.timer_base_is_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer is the only class in this spec that subclasses Thread rather than object directly; Timer name len=5 is tied shortest with Event"
  category: identity
  kind: python_call_eq
  function: "Timer.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true

invariant threading_extra267.lock_name_is_lowercase:
  description: "threading.Lock.__name__ == 'lock' — Lock.__name__ is lowercase 'lock' (len=4), not 'Lock'; it is the C-level _thread.lock class exposed as threading.Lock"
  category: identity
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra267.rlock_is_function_not_class:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a factory function (not a class), unlike Lock which is a C-level type; RLock.__module__ == 'threading'"
  category: identity
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra267.condition_name_len_equals_semaphore:
  description: "threading.Condition.__name__.__len__() == 9 == threading.Semaphore.__name__.__len__() — both are length 9, tied longest Python class names in spec; also equals module name 'threading' length"
  category: identity
  kind: python_call_eq
  function: Condition.__name__.__len__
  args: []
  expected: 9

invariant threading_extra267.lock_module_is_thread_extension:
  description: "threading.Lock.__module__ == '_thread' (len=7) — Lock comes from the C extension _thread, not from the threading module itself; compare with RLock.__module__ == 'threading' (len=9)"
  category: identity
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true
