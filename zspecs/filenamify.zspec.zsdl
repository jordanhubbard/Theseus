spec: filenamify
version: ">=7.0.0"
backend: node(filenamify)

docs: https://github.com/sindresorhus/filenamify#readme

provenance:
  derived_from:
    - "filenamify README — https://github.com/sindresorhus/filenamify#readme"
    - "Test vectors verified with filenamify via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "filenamify source"
  notes:
    - "Convert any string into a valid filename — replaces invalid chars with '!' by default."
    - "Install: npm install filenamify"
    - "v7 ESM only; default export is filenamify."
    - "Differs from sanitize-filename: replaces with a marker (default '!') rather than dropping characters."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant filenamify.replaces_colon:
  description: "Colon is replaced with '!' by default"
  category: replacement
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["foo:bar.txt"]
  chain: []
  expected: "foo!bar.txt"

invariant filenamify.replaces_path_separator:
  description: "Forward slash is replaced with '!' by default"
  category: replacement
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["foo/bar.txt"]
  chain: []
  expected: "foo!bar.txt"

invariant filenamify.custom_replacement:
  description: "Custom replacement option respected"
  category: options
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["foo:bar", {replacement: "#"}]
  chain: []
  expected: "foo#bar"

invariant filenamify.windows_reserved_appended:
  description: "Windows reserved CON gets the replacement char appended (CON_)"
  category: reserved
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["CON", {replacement: "_"}]
  chain: []
  expected: "CON_"

invariant filenamify.passthrough_valid:
  description: "Already-valid filenames pass through unchanged"
  category: passthrough
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["valid-name.txt"]
  chain: []
  expected: "valid-name.txt"

invariant filenamify.truncates_to_max_length:
  description: "Output is truncated to the platform max-length default (100 chars)"
  category: length
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"]
  chain:
    - {get: length}
  expected: 100

invariant filenamify.preserves_extension:
  description: "Sanitisation preserves '.txt' extension"
  category: passthrough
  kind: node_chain_eq
  entry: factory
  factory: default
  entry_args: ["something.txt"]
  chain:
    - {method: endsWith, args: [".txt"]}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T18:11:16Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
