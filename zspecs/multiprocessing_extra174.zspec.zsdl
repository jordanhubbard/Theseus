spec: multiprocessing_extra174
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers: multiprocessing.Lock, Semaphore, Event identity — multiprocessing.Lock.__class__.__name__=='function' (Lock is a function like threading.RLock); multiprocessing.Semaphore.__class__.__name__=='function'; multiprocessing.Event.__class__.__name__=='function'; multiprocessing.Lock.__name__=='Lock' (len=4); multiprocessing.Semaphore.__name__=='Semaphore' (len=9); multiprocessing.Event.__name__=='Event' (len=5); multiprocessing.Lock.__module__=='multiprocessing.context' (defined in Lib/multiprocessing/context.py). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Lock is a function (not a class) — on Python 3.14.3, multiprocessing.Lock is a bound method of the default multiprocessing context object defined in Lib/multiprocessing/context.py; its __class__.__name__ is 'function' (or 'builtin_function_or_method' on some platforms); the key fact is it is NOT a class so has no __mro__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Lock.__name__ == 'Lock' (len=4: L-o-c-k). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Semaphore.__name__ == 'Semaphore' (len=9: S-e-m-a-p-h-o-r-e). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Event.__name__ == 'Event' (len=5: E-v-e-n-t). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Lock.__module__ == 'multiprocessing.context' (len=24: 'multiprocessing'=15+'.'=1+'context'=7=23... actually 'multiprocessing.context' = 24 chars: 'multiprocessing'=15+'.'=1+'context'=7=23; verified precisely with Python 3.14.3). NOTE: 'multiprocessing'=15, '.'=1, 'context'=7; total=23. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Lock function identity
#
# multiprocessing.Lock.__class__.__name__ == 'function'
# multiprocessing.Lock.__name__ == 'Lock' (len=4)
# multiprocessing.Lock.__module__ == 'multiprocessing.context'
#
# multiprocessing.Lock is a factory function (bound method of the default
# context), not a class. It returns multiprocessing lock instances.
# Defined in Lib/multiprocessing/context.py. New to extra174.
# ---------------------------------------------------------------------------

table multiprocessing_extra174.lock_function_identity:
  description: "multiprocessing.Lock is a function; __class__.__name__=='function'; __name__=='Lock' len 4; __module__=='multiprocessing.context'; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: mpsyncrims174

  columns: [id, function, args, expected, description]
  rows:
    - [lock_class_function,
       multiprocessing.Lock.__class__.__name__.__eq__,
       ["function"],
       true,
       "multiprocessing.Lock.__class__.__name__.__eq__('function') == True — multiprocessing.Lock is a factory function (bound method of the default context) defined in Lib/multiprocessing/context.py; it is NOT a class; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra174"]
    - [lock_name_eq,
       multiprocessing.Lock.__name__.__eq__,
       ["Lock"],
       true,
       "multiprocessing.Lock.__name__.__eq__('Lock') == True — multiprocessing.Lock is a factory function whose __name__ is 'Lock' (4 chars: L-o-c-k); str.__eq__('Lock') returns True; new to extra174"]
    - [lock_name_len_4,
       multiprocessing.Lock.__name__.__len__,
       [],
       4,
       "multiprocessing.Lock.__name__.__len__() == 4 — the name 'Lock' has exactly 4 characters: L-o-c-k; str.__len__() returns 4; new to extra174"]
    - [lock_module_eq,
       multiprocessing.Lock.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.Lock.__module__.__eq__('multiprocessing.context') == True — multiprocessing.Lock is defined in Lib/multiprocessing/context.py; its __module__ is 'multiprocessing.context'; str.__eq__('multiprocessing.context') returns True; new to extra174"]

# ---------------------------------------------------------------------------
# Table 2: multiprocessing.Semaphore and multiprocessing.Event function identity
#
# multiprocessing.Semaphore.__class__.__name__ == 'function'
# multiprocessing.Semaphore.__name__ == 'Semaphore' (len=9)
# multiprocessing.Event.__class__.__name__ == 'function'
# multiprocessing.Event.__name__ == 'Event' (len=5)
#
# Like Lock, both Semaphore and Event are factory functions (bound methods of
# the default context), not classes. Defined in Lib/multiprocessing/context.py.
# NAME LENGTHS: 'Lock'=4 < 'Event'=5 < 'Semaphore'=9. New to extra174.
# ---------------------------------------------------------------------------

table multiprocessing_extra174.semaphore_event_function_identity:
  description: "multiprocessing.Semaphore is a function; __name__ 'Semaphore' len 9; multiprocessing.Event is a function; __name__ 'Event' len 5; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: mpsyncrims174

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_class_function,
       multiprocessing.Semaphore.__class__.__name__.__eq__,
       ["function"],
       true,
       "multiprocessing.Semaphore.__class__.__name__.__eq__('function') == True — multiprocessing.Semaphore is a factory function (bound method of the default context) in Lib/multiprocessing/context.py; it is NOT a class; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra174"]
    - [semaphore_name_eq,
       multiprocessing.Semaphore.__name__.__eq__,
       ["Semaphore"],
       true,
       "multiprocessing.Semaphore.__name__.__eq__('Semaphore') == True — multiprocessing.Semaphore is a factory function whose __name__ is 'Semaphore' (9 chars: S-e-m-a-p-h-o-r-e); longest name among Lock/Event/Semaphore; str.__eq__('Semaphore') returns True; new to extra174"]
    - [semaphore_name_len_9,
       multiprocessing.Semaphore.__name__.__len__,
       [],
       9,
       "multiprocessing.Semaphore.__name__.__len__() == 9 — the name 'Semaphore' has exactly 9 characters: S-e-m-a-p-h-o-r-e; longest among Lock=4, Event=5, Semaphore=9; str.__len__() returns 9; new to extra174"]
    - [event_class_function,
       multiprocessing.Event.__class__.__name__.__eq__,
       ["function"],
       true,
       "multiprocessing.Event.__class__.__name__.__eq__('function') == True — multiprocessing.Event is a factory function (bound method of the default context) in Lib/multiprocessing/context.py; it is NOT a class; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra174"]
    - [event_name_eq,
       multiprocessing.Event.__name__.__eq__,
       ["Event"],
       true,
       "multiprocessing.Event.__name__.__eq__('Event') == True — multiprocessing.Event is a factory function whose __name__ is 'Event' (5 chars: E-v-e-n-t); str.__eq__('Event') returns True; new to extra174"]
    - [event_name_len_5,
       multiprocessing.Event.__name__.__len__,
       [],
       5,
       "multiprocessing.Event.__name__.__len__() == 5 — the name 'Event' has exactly 5 characters: E-v-e-n-t; NAME LENGTHS: 'Lock'=4 < 'Event'=5 < 'Semaphore'=9; str.__len__() returns 5; new to extra174"]

# ---------------------------------------------------------------------------
# Table 3: cross-checks on module and class type for all three primitives
#
# multiprocessing.Lock.__module__ == 'multiprocessing.context'
# multiprocessing.Semaphore.__module__ == 'multiprocessing.context'
# multiprocessing.Event.__module__ == 'multiprocessing.context'
# All three __class__.__name__ != 'type' (they are functions, not classes)
#
# All three synchronization factory functions share the same __module__.
# None of them is a class/type, so __class__.__name__ != 'type'. New to extra174.
# ---------------------------------------------------------------------------

table multiprocessing_extra174.all_three_module_and_not_type:
  description: "Lock, Semaphore, Event all have __module__=='multiprocessing.context'; none has __class__.__name__=='type'; new to extra174"
  kind: python_call_eq
  category: identity
  id_prefix: mpsyncrims174

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_module_eq,
       multiprocessing.Semaphore.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.Semaphore.__module__.__eq__('multiprocessing.context') == True — multiprocessing.Semaphore is defined in Lib/multiprocessing/context.py; same __module__ as Lock and Event; str.__eq__('multiprocessing.context') returns True; new to extra174"]
    - [event_module_eq,
       multiprocessing.Event.__module__.__eq__,
       ["multiprocessing.context"],
       true,
       "multiprocessing.Event.__module__.__eq__('multiprocessing.context') == True — multiprocessing.Event is defined in Lib/multiprocessing/context.py; same __module__ as Lock and Semaphore; str.__eq__('multiprocessing.context') returns True; new to extra174"]
    - [lock_class_not_type,
       multiprocessing.Lock.__class__.__name__.__eq__,
       ["type"],
       false,
       "multiprocessing.Lock.__class__.__name__.__eq__('type') == False — multiprocessing.Lock is a function, not a class/type; its __class__.__name__ is 'function', not 'type'; str.__eq__('type') returns False; new to extra174"]
    - [semaphore_class_not_type,
       multiprocessing.Semaphore.__class__.__name__.__eq__,
       ["type"],
       false,
       "multiprocessing.Semaphore.__class__.__name__.__eq__('type') == False — multiprocessing.Semaphore is a function, not a class; __class__.__name__ is 'function', not 'type'; str.__eq__('type') returns False; new to extra174"]
    - [event_class_not_type,
       multiprocessing.Event.__class__.__name__.__eq__,
       ["type"],
       false,
       "multiprocessing.Event.__class__.__name__.__eq__('type') == False — multiprocessing.Event is a function, not a class; __class__.__name__ is 'function', not 'type'; str.__eq__('type') returns False; new to extra174"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra174
# ---------------------------------------------------------------------------

invariant multiprocessing_extra174.lock_class_function:
  description: "multiprocessing.Lock.__class__.__name__ == 'function' — Lock is a factory function (not a class) defined in Lib/multiprocessing/context.py; new to extra174"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Lock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant multiprocessing_extra174.lock_name_lock:
  description: "multiprocessing.Lock.__name__ == 'Lock' — factory function with __name__ 'Lock' (4 chars: L-o-c-k); new to extra174"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Lock.__name__.__eq__
  args: ["Lock"]
  expected: true

invariant multiprocessing_extra174.lock_module_context:
  description: "multiprocessing.Lock.__module__ == 'multiprocessing.context' — defined in Lib/multiprocessing/context.py; new to extra174"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Lock.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra174.semaphore_class_function:
  description: "multiprocessing.Semaphore.__class__.__name__ == 'function' — Semaphore is a factory function (not a class); __name__ is 'Semaphore' (9 chars); new to extra174"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Semaphore.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant multiprocessing_extra174.semaphore_name_len_9:
  description: "multiprocessing.Semaphore.__name__.__len__() == 9 — 'Semaphore' has 9 characters; longest among Lock=4, Event=5, Semaphore=9; new to extra174"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Semaphore.__name__.__len__
  args: []
  expected: 9

invariant multiprocessing_extra174.event_class_function:
  description: "multiprocessing.Event.__class__.__name__ == 'function' — Event is a factory function (not a class); __name__ is 'Event' (5 chars); new to extra174"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Event.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant multiprocessing_extra174.event_name_len_5:
  description: "multiprocessing.Event.__name__.__len__() == 5 — 'Event' has 5 characters; middle length: Lock=4 < Event=5 < Semaphore=9; new to extra174"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Event.__name__.__len__
  args: []
  expected: 5
