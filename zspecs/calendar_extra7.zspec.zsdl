spec: calendar_extra7
version: ">=3.9"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html — Python calendar module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
  notes:
    - "This spec extends calendar.zspec.zsdl and calendar_extra through calendar_extra6.zspec.zsdl."
    - "calendar_extra5 covers: TUESDAY/THURSDAY/SATURDAY constants; month_name[2/4]; month_abbr[9]; monthrange(2024,2); weekday(2000,1,1)/(2026,4,9); leapdays(2020,2025); isleap(1996)."
    - "calendar_extra6 covers: class_names table; all-day-values table (MONDAY..SUNDAY); Calendar.__module__; FRIDAY standalone; MONDAY.__class__.__name__."
    - "NEW in this spec: month_name/month_abbr for January, June, December; day_name/day_abbr for Monday, Tuesday, Friday, Sunday; isleap(2000)/isleap(1900)/isleap(2024)/isleap(2023); leapdays(2000,2024); monthrange day-count vectors; firstweekday(); module attributes for isleap/leapdays/monthrange/timegm."
    - "calendar.month_name[1] == 'January' — first month name; index 0 is empty string."
    - "calendar.month_name[6] == 'June' — mid-year month name."
    - "calendar.month_name[12] == 'December' — last month name."
    - "calendar.month_abbr[1] == 'Jan', month_abbr[6] == 'Jun', month_abbr[12] == 'Dec'."
    - "calendar.day_name[0] == 'Monday', day_name[4] == 'Friday', day_name[6] == 'Sunday'."
    - "calendar.day_abbr[0] == 'Mon', day_abbr[4] == 'Fri', day_abbr[6] == 'Sun'."
    - "calendar.isleap(2000) == True (century divisible by 400); isleap(1900) == False (century not div by 400); isleap(2024) == True; isleap(2023) == False."
    - "calendar.leapdays(2000, 2024) == 6 — leap years 2000,2004,2008,2012,2016,2020."
    - "calendar.monthrange(2024, 2)[1] == 29 — February 2024 has 29 days (leap year)."
    - "calendar.monthrange(2023, 2)[1] == 28 — February 2023 has 28 days (non-leap)."
    - "calendar.monthrange(2024, 1)[0] == 0 — January 2024 starts on Monday (MONDAY==0)."
    - "calendar.firstweekday() == 0 — default first weekday is Monday."
    - "calendar.timegm.__module__ == 'calendar'; calendar.isleap.__module__ == 'calendar'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# month_name — three representative months (January, June, December)
#
# calendar_extra5 covers month_name[2] and month_name[4]. No prior spec covers
# month_name for January (index 1), June (index 6), or December (index 12).
# ---------------------------------------------------------------------------

table calendar_extra7.month_names:
  kind: python_call_eq
  category: month_names
  id_prefix: mname

  columns: [id, function, args, expected]
  rows:
    - [january,  month_name.__getitem__, [1],  "January"]
    - [june,     month_name.__getitem__, [6],  "June"]
    - [december, month_name.__getitem__, [12], "December"]

# ---------------------------------------------------------------------------
# month_abbr — abbreviated month names (January=Jan, June=Jun, December=Dec)
#
# calendar_extra5 covers month_abbr[9] (Sep). No prior spec covers Jan/Jun/Dec.
# ---------------------------------------------------------------------------

table calendar_extra7.month_abbrs:
  kind: python_call_eq
  category: month_abbrs
  id_prefix: mabbr

  columns: [id, function, args, expected]
  rows:
    - [jan, month_abbr.__getitem__, [1],  "Jan"]
    - [jun, month_abbr.__getitem__, [6],  "Jun"]
    - [dec, month_abbr.__getitem__, [12], "Dec"]

# ---------------------------------------------------------------------------
# day_name and day_abbr — Monday, Friday, Sunday
#
# No prior spec tests day_name or day_abbr at all. Monday is index 0,
# Friday is index 4, Sunday is index 6 (the calendar module uses ISO week order
# Monday..Sunday == 0..6 for indexing day_name/day_abbr).
# ---------------------------------------------------------------------------

table calendar_extra7.day_names:
  kind: python_call_eq
  category: day_names
  id_prefix: dname

  columns: [id, function, args, expected]
  rows:
    - [monday, day_name.__getitem__, [0], "Monday"]
    - [friday, day_name.__getitem__, [4], "Friday"]
    - [sunday, day_name.__getitem__, [6], "Sunday"]

table calendar_extra7.day_abbrs:
  kind: python_call_eq
  category: day_abbrs
  id_prefix: dabbr

  columns: [id, function, args, expected]
  rows:
    - [monday, day_abbr.__getitem__, [0], "Mon"]
    - [friday, day_abbr.__getitem__, [4], "Fri"]
    - [sunday, day_abbr.__getitem__, [6], "Sun"]

# ---------------------------------------------------------------------------
# isleap() — four key cases covering Gregorian leap-year rules
#
# calendar_extra5 covers isleap(1996) only. No prior spec covers the century
# edge cases (2000 is a leap year because it's divisible by 400; 1900 is not).
# ---------------------------------------------------------------------------

table calendar_extra7.isleap_cases:
  kind: python_call_eq
  category: isleap
  id_prefix: leap

  columns: [id, function, args, expected]
  rows:
    - [y2000_leap,     isleap, [2000], true]
    - [y1900_not_leap, isleap, [1900], false]
    - [y2024_leap,     isleap, [2024], true]
    - [y2023_not_leap, isleap, [2023], false]

# ---------------------------------------------------------------------------
# leapdays() — count of leap years in a range
#
# calendar_extra5 covers leapdays(2020, 2025) == 2. This spec covers the
# longer range leapdays(2000, 2024) == 6 (years 2000,2004,2008,2012,2016,2020).
# ---------------------------------------------------------------------------

invariant calendar_extra7.leapdays.range_2000_2024:
  description: "calendar.leapdays(2000, 2024) == 6 — six leap years in [2000, 2024)"
  category: leapdays
  kind: python_call_eq
  function: leapdays
  args: [2000, 2024]
  expected: 6

# ---------------------------------------------------------------------------
# monthrange() — day count and start weekday for February 2024/2023 and Jan 2024
#
# calendar_extra5 covers monthrange(2024,2) as a pair but no prior spec
# extracts individual tuple elements [0] or [1] to verify day counts and
# start weekdays independently. monthrange returns (weekday_of_first_day, ndays).
# ---------------------------------------------------------------------------

invariant calendar_extra7.monthrange.feb2024_ndays:
  description: "calendar.monthrange(2024, 2)[1] == 29 — February 2024 has 29 days (leap year)"
  category: monthrange
  kind: python_call_eq
  function: monthrange
  args: [2024, 2]
  method: __getitem__
  method_args: [1]
  expected: 29

invariant calendar_extra7.monthrange.feb2023_ndays:
  description: "calendar.monthrange(2023, 2)[1] == 28 — February 2023 has 28 days (non-leap)"
  category: monthrange
  kind: python_call_eq
  function: monthrange
  args: [2023, 2]
  method: __getitem__
  method_args: [1]
  expected: 28

invariant calendar_extra7.monthrange.jan2024_start_weekday:
  description: "calendar.monthrange(2024, 1)[0] == 0 — January 2024 starts on Monday (MONDAY==0)"
  category: monthrange
  kind: python_call_eq
  function: monthrange
  args: [2024, 1]
  method: __getitem__
  method_args: [0]
  expected: 0

# ---------------------------------------------------------------------------
# firstweekday() — default first weekday
#
# No prior spec calls firstweekday(). The default is Monday (0) per ISO week
# convention used by the calendar module.
# ---------------------------------------------------------------------------

invariant calendar_extra7.firstweekday.default:
  description: "calendar.firstweekday() == 0 — default first weekday is Monday"
  category: behavioral
  kind: python_call_eq
  function: firstweekday
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# Module membership — isleap and timegm
#
# No prior spec checks isleap.__module__ or timegm.__module__. Both are
# defined in the calendar module at the top level.
# ---------------------------------------------------------------------------

invariant calendar_extra7.isleap.module:
  description: "calendar.isleap.__module__ == 'calendar'"
  category: modules
  kind: python_call_eq
  function: isleap.__module__.__eq__
  args: ["calendar"]
  expected: true

invariant calendar_extra7.timegm.module:
  description: "calendar.timegm.__module__ == 'calendar'"
  category: modules
  kind: python_call_eq
  function: timegm.__module__.__eq__
  args: ["calendar"]
  expected: true
