table concurrent_futures_extra79.ProcessPoolExecutor_dict_membership:
  description: "concurrent.futures ProcessPoolExecutor __dict__ membership checks in cfextra79 namespace — wave 245 theme: ProcessPoolExecutor __dict__ membership; ProcessPoolExecutor.__dict__.__contains__('submit')==True; ProcessPoolExecutor.__dict__.__contains__('shutdown')==True; ProcessPoolExecutor.__dict__.__contains__('__init__')==True; Future.__dict__.__contains__('result')==True (cross-spec preview); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra79a

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_has_submit,   "ProcessPoolExecutor.__dict__.__contains__", ["submit"],   true, "ProcessPoolExecutor.__dict__.__contains__('submit') == True — submit is defined directly on ProcessPoolExecutor; verified with Python 3.14.3"]
    - [ppe_has_shutdown, "ProcessPoolExecutor.__dict__.__contains__", ["shutdown"], true, "ProcessPoolExecutor.__dict__.__contains__('shutdown') == True — shutdown is defined on ProcessPoolExecutor; verified with Python 3.14.3"]
    - [ppe_has_init,     "ProcessPoolExecutor.__dict__.__contains__", ["__init__"], true, "ProcessPoolExecutor.__dict__.__contains__('__init__') == True — __init__ is defined on ProcessPoolExecutor; verified with Python 3.14.3"]
    - [future_has_result, "Future.__dict__.__contains__",             ["result"],   true, "Future.__dict__.__contains__('result') == True — result is defined on Future; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures Executor __dict__ membership — extra79
#
# Executor.__dict__.__contains__('map') == True
# Executor.__dict__.__contains__('submit') == True
# Executor.__dict__.__contains__('__enter__') == True
# Executor.__dict__.__contains__('__exit__') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra79.Executor_dict_membership:
  description: "concurrent.futures Executor __dict__ membership checks in cfextra79 namespace — wave 245 theme: Executor base class __dict__ membership; Executor.__dict__.__contains__('map')==True (map is a concrete method on Executor base); Executor.__dict__.__contains__('submit')==True (abstract method stub); Executor.__dict__.__contains__('__enter__')==True (context manager entry); Executor.__dict__.__contains__('__exit__')==True (context manager exit calls shutdown); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra79b

  columns: [id, function, args, expected, description]
  rows:
    - [exec_has_map,     "Executor.__dict__.__contains__", ["map"],      true, "Executor.__dict__.__contains__('map') == True — map is a concrete method on the Executor base class; verified with Python 3.14.3"]
    - [exec_has_submit,  "Executor.__dict__.__contains__", ["submit"],   true, "Executor.__dict__.__contains__('submit') == True — submit is an abstract method stub on Executor; verified with Python 3.14.3"]
    - [exec_has_enter,   "Executor.__dict__.__contains__", ["__enter__"], true, "Executor.__dict__.__contains__('__enter__') == True — context manager support on Executor; verified with Python 3.14.3"]
    - [exec_has_exit,    "Executor.__dict__.__contains__", ["__exit__"],  true, "Executor.__dict__.__contains__('__exit__') == True — __exit__ calls shutdown; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures Future __dict__ membership — extra79
#
# Future.__dict__.__contains__('result') == True
# Future.__dict__.__contains__('add_done_callback') == True
# Future.__dict__.__contains__('cancel') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra79.Future_dict_membership:
  description: "concurrent.futures Future __dict__ membership checks in cfextra79 namespace — wave 245 theme: Future __dict__ membership; Future.__dict__.__contains__('result')==True; Future.__dict__.__contains__('add_done_callback')==True; Future.__dict__.__contains__('cancel')==True; ThreadPoolExecutor.__dict__.__contains__('map')==False (cross-check: map not on ThreadPoolExecutor); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra79c

  columns: [id, function, args, expected, description]
  rows:
    - [future_has_result,        "Future.__dict__.__contains__",               ["result"],            true,  "Future.__dict__.__contains__('result') == True — result is defined on Future; verified with Python 3.14.3"]
    - [future_has_add_done_cb,   "Future.__dict__.__contains__",               ["add_done_callback"], true,  "Future.__dict__.__contains__('add_done_callback') == True — add_done_callback is defined on Future; verified with Python 3.14.3"]
    - [future_has_cancel,        "Future.__dict__.__contains__",               ["cancel"],            true,  "Future.__dict__.__contains__('cancel') == True — cancel is defined on Future; verified with Python 3.14.3"]
    - [tpe_no_map_cross,         "ThreadPoolExecutor.__dict__.__contains__",   ["map"],               false, "ThreadPoolExecutor.__dict__.__contains__('map') == False — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra79
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra79.ThreadPoolExecutor_has_submit:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit') returns True — submit is defined directly on ThreadPoolExecutor, not inherited from Executor; NEW in extra79: first standalone __dict__.__contains__ invariant for ThreadPoolExecutor.submit in cfextra79 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__dict__.__contains__
  args: ["submit"]
  expected: true

invariant concurrent_futures_extra79.ThreadPoolExecutor_no_map:
  description: "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map') returns False — map is defined on the base Executor class, not on ThreadPoolExecutor; subclasses inherit it via normal MRO lookup; NEW in extra79: first standalone __dict__.__contains__ False invariant for ThreadPoolExecutor.map in cfextra79 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ThreadPoolExecutor.__dict__.__contains__
  args: ["map"]
  expected: false

invariant concurrent_futures_extra79.Executor_has_map:
  description: "concurrent.futures.Executor.__dict__.__contains__('map') returns True — map is a concrete method on the Executor base class that iterates over submit calls; NEW in extra79: first standalone __dict__.__contains__ invariant for Executor.map in cfextra79 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Executor.__dict__.__contains__
  args: ["map"]
  expected: true

invariant concurrent_futures_extra79.Executor_has_enter:
  description: "concurrent.futures.Executor.__dict__.__contains__('__enter__') returns True — Executor implements __enter__ for use as a context manager; NEW in extra79: first standalone __dict__.__contains__ invariant for Executor.__enter__ in cfextra79 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Executor.__dict__.__contains__
  args: ["__enter__"]
  expected: true

invariant concurrent_futures_extra79.Future_has_cancel:
  description: "concurrent.futures.Future.__dict__.__contains__('cancel') returns True — cancel is defined directly on Future to attempt cancellation of a pending future; NEW in extra79: first standalone __dict__.__contains__ invariant for Future.cancel in cfextra79 namespace; wave 245; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Future.__dict__.__contains__
  args: ["cancel"]
  expected: true
