spec: concurrent_futures_extra79
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec extends concurrent_futures_extra78.zspec.zsdl."
    - "This spec covers: wave 245 theme — concurrent.futures ThreadPoolExecutor/ProcessPoolExecutor __dict__ membership. NEW in extra79: ThreadPoolExecutor.__dict__.__contains__('submit')==True; ThreadPoolExecutor.__dict__.__contains__('shutdown')==True; ThreadPoolExecutor.__dict__.__contains__('__init__')==True; ThreadPoolExecutor.__dict__.__contains__('map')==False (map is on Executor not ThreadPoolExecutor); ProcessPoolExecutor.__dict__.__contains__('submit')==True; ProcessPoolExecutor.__dict__.__contains__('shutdown')==True; ProcessPoolExecutor.__dict__.__contains__('__init__')==True; Executor.__dict__.__contains__('map')==True; Executor.__dict__.__contains__('submit')==True (abstract); Executor.__dict__.__contains__('__enter__')==True; Executor.__dict__.__contains__('__exit__')==True; Future.__dict__.__contains__('result')==True; Future.__dict__.__contains__('add_done_callback')==True; Future.__dict__.__contains__('cancel')==True. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit') == True. submit is defined directly on ThreadPoolExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map') == False. map is defined on the base Executor class, not on ThreadPoolExecutor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__dict__.__contains__('map') == True. map is a concrete method on the base Executor class that works with the abstract submit. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__dict__.__contains__('submit') == True. submit is defined as an abstract method stub on Executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__dict__.__contains__('__enter__') == True. __enter__ is defined on Executor for context manager support. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Executor.__dict__.__contains__('__exit__') == True. __exit__ calls shutdown on the executor. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('result') == True. result is defined directly on Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('add_done_callback') == True. add_done_callback is defined directly on Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__dict__.__contains__('cancel') == True. cancel is defined directly on Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures ThreadPoolExecutor __dict__ membership — extra79
#
# Wave 245 theme: ThreadPoolExecutor/ProcessPoolExecutor __dict__ membership.
#
# ThreadPoolExecutor.__dict__.__contains__('submit') == True
# ThreadPoolExecutor.__dict__.__contains__('shutdown') == True
# ThreadPoolExecutor.__dict__.__contains__('__init__') == True
# ThreadPoolExecutor.__dict__.__contains__('map') == False
# ---------------------------------------------------------------------------

table concurrent_futures_extra79.ThreadPoolExecutor_dict_membership:
  description: "concurrent.futures ThreadPoolExecutor __dict__ membership checks in cfextra79 namespace — wave 245 theme: ThreadPoolExecutor/ProcessPoolExecutor __dict__ membership; ThreadPoolExecutor.__dict__.__contains__('submit')==True (submit is defined on ThreadPoolExecutor); ThreadPoolExecutor.__dict__.__contains__('shutdown')==True; ThreadPoolExecutor.__dict__.__contains__('__init__')==True; ThreadPoolExecutor.__dict__.__contains__('map')==False (map is on base Executor class, not ThreadPoolExecutor); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfextra79

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_has_submit,    "ThreadPoolExecutor.__dict__.__contains__", ["submit"],   true,  "ThreadPoolExecutor.__dict__.__contains__('submit') == True — submit is defined directly on ThreadPoolExecutor; verified with Python 3.14.3"]
    - [tpe_has_shutdown,  "ThreadPoolExecutor.__dict__.__contains__", ["shutdown"], true,  "ThreadPoolExecutor.__dict__.__contains__('shutdown') == True — shutdown is defined directly on ThreadPoolExecutor; verified with Python 3.14.3"]
    - [tpe_has_init,      "ThreadPoolExecutor.__dict__.__contains__", ["__init__"], true,  "ThreadPoolExecutor.__dict__.__contains__('__init__') == True — __init__ is defined on ThreadPoolExecutor; verified with Python 3.14.3"]
    - [tpe_no_map,        "ThreadPoolExecutor.__dict__.__contains__", ["map"],      false, "ThreadPoolExecutor.__dict__.__contains__('map') == False — map is on base Executor not ThreadPoolExecutor; verified with Python 3.14.3"]

