spec: threading_extra503
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading.Timer class identity and synchronization primitive names"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.Timer inherits from threading.Thread; __bases__[0].__name__ must be 'Thread'"
    - "__qualname__ matches simple class name for all top-level threading classes"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra503.timer_identity:
  description: "threading.Timer class identity attributes: __name__, __module__, and base class"
  kind: python_call_eq
  category: attributes
  id_prefix: TTI

  columns: [id, function, args, expected]
  rows:
    - [TTI001, threading.Timer.__name__.__eq__, ["Timer"], true]
    - [TTI002, threading.Timer.__module__.__eq__, ["threading"], true]
    - [TTI003, "threading.Timer.__bases__[0].__name__.__eq__", ["Thread"], true]

table threading_extra503.timer_methods:
  description: "threading.Timer method __name__ attributes"
  kind: python_call_eq
  category: attributes
  id_prefix: TTM

  columns: [id, function, args, expected]
  rows:
    - [TTM001, threading.Timer.run.__name__.__eq__, ["run"], true]
    - [TTM002, threading.Timer.cancel.__name__.__eq__, ["cancel"], true]

table threading_extra503.qualname_identity:
  description: "threading synchronization classes have the expected __qualname__ string"
  kind: python_call_eq
  category: attributes
  id_prefix: TQN

  columns: [id, function, args, expected]
  rows:
    - [TQN001, threading.Timer.__qualname__.__eq__, ["Timer"], true]
    - [TQN002, threading.Thread.__qualname__.__eq__, ["Thread"], true]
    - [TQN003, threading.Condition.__qualname__.__eq__, ["Condition"], true]
    - [TQN004, threading.Semaphore.__qualname__.__eq__, ["Semaphore"], true]
    - [TQN005, threading.Event.__qualname__.__eq__, ["Event"], true]
    - [TQN006, threading.Barrier.__qualname__.__eq__, ["Barrier"], true]
    - [TQN007, threading.local.__qualname__.__eq__, ["local"], true]
