spec: trace_extra2
version: ">=3.9"
backend: python_module(trace)

docs: https://docs.python.org/3/library/trace.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/trace.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "trace source: Lib/trace.py (PSF; source inspection permitted)"
  not_derived_from:
    - "trace source: sys.settrace internals"
    - "trace.zspec.zsdl — covers Trace.__name__/__module__, CoverageResults.__name__/__module__, Trace.__bases__[0].__name__=='object', CoverageResults.__bases__[0].__name__=='object', Trace methods (run/runfunc/runctx/results), CoverageResults methods (update/write_results)"
    - "trace_extra.zspec.zsdl — covers Trace.__name__, CoverageResults.__name__, Trace.__module__, Trace.__bases__[0].__name__=='object', PRAGMA_NOCOVER.__class__.__name__=='str'"
  notes:
    - "This spec covers __qualname__ attributes for Trace and CoverageResults, CoverageResults.__module__, and module-level utility function names — not covered in trace.zspec.zsdl or trace_extra.zspec.zsdl."
    - "trace.Trace.__qualname__ == 'Trace' — qualname equals name for a top-level class."
    - "trace.CoverageResults.__qualname__ == 'CoverageResults' — top-level class qualname."
    - "trace.CoverageResults.__module__ == 'trace' — CoverageResults is defined in Lib/trace.py; covered in trace.zspec.zsdl via table, new here as standalone invariant for completeness."
    - "trace.find_lines_from_code is a module-level helper; __name__ == 'find_lines_from_code'."
    - "trace.find_executable_linenos is a module-level helper; __name__ == 'find_executable_linenos'."
    - "trace.find_lines_from_code.__module__ == 'trace' — defined in Lib/trace.py."
    - "trace.find_executable_linenos.__module__ == 'trace' — defined in Lib/trace.py."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Trace raises ValueError on invalid constructor arguments."
  stderr: "null"
  stickiness: "N/A — Trace instances are independent."
  codes: {}

# ---------------------------------------------------------------------------
# __qualname__ checks for Trace and CoverageResults
# (not covered in trace.zspec.zsdl or trace_extra.zspec.zsdl)
# ---------------------------------------------------------------------------

table trace_extra2.class_qualnames:
  kind: python_call_eq
  category: qualname_attrs
  id_prefix: cqname

  columns: [id, function, args, expected]
  rows:
    - [Trace,           Trace.__qualname__.__eq__,           ["Trace"],           true]
    - [CoverageResults, CoverageResults.__qualname__.__eq__, ["CoverageResults"], true]

# ---------------------------------------------------------------------------
# CoverageResults.__module__ — standalone invariant
# (trace.zspec.zsdl covers it only via a table row; here as an explicit invariant)
# ---------------------------------------------------------------------------

invariant trace_extra2.CoverageResults.module:
  description: "trace.CoverageResults.__module__ == 'trace'"
  category: class_attrs
  kind: python_call_eq
  function: CoverageResults.__module__.__eq__
  args: ["trace"]
  expected: true

# ---------------------------------------------------------------------------
# find_lines_from_code — module-level utility function
# (not covered in trace.zspec.zsdl or trace_extra.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant trace_extra2.find_lines_from_code.name:
  description: "trace.find_lines_from_code.__name__ == 'find_lines_from_code'"
  category: function_names
  kind: python_call_eq
  function: find_lines_from_code.__name__.__eq__
  args: ["find_lines_from_code"]
  expected: true

invariant trace_extra2.find_lines_from_code.module:
  description: "trace.find_lines_from_code.__module__ == 'trace'"
  category: function_attrs
  kind: python_call_eq
  function: find_lines_from_code.__module__.__eq__
  args: ["trace"]
  expected: true

# ---------------------------------------------------------------------------
# find_executable_linenos — module-level utility function
# (not covered in trace.zspec.zsdl or trace_extra.zspec.zsdl)
# ---------------------------------------------------------------------------

invariant trace_extra2.find_executable_linenos.name:
  description: "trace.find_executable_linenos.__name__ == 'find_executable_linenos'"
  category: function_names
  kind: python_call_eq
  function: find_executable_linenos.__name__.__eq__
  args: ["find_executable_linenos"]
  expected: true

invariant trace_extra2.find_executable_linenos.module:
  description: "trace.find_executable_linenos.__module__ == 'trace'"
  category: function_attrs
  kind: python_call_eq
  function: find_executable_linenos.__module__.__eq__
  args: ["trace"]
  expected: true

# ---------------------------------------------------------------------------
# find_lines_from_code and find_executable_linenos qualnames
# ---------------------------------------------------------------------------

invariant trace_extra2.find_lines_from_code.qualname:
  description: "trace.find_lines_from_code.__qualname__ == 'find_lines_from_code'"
  category: qualname_attrs
  kind: python_call_eq
  function: find_lines_from_code.__qualname__.__eq__
  args: ["find_lines_from_code"]
  expected: true

invariant trace_extra2.find_executable_linenos.qualname:
  description: "trace.find_executable_linenos.__qualname__ == 'find_executable_linenos'"
  category: qualname_attrs
  kind: python_call_eq
  function: find_executable_linenos.__qualname__.__eq__
  args: ["find_executable_linenos"]
  expected: true
