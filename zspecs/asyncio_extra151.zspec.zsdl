    - [dict_len,        asyncio.__dict__.__len__,                        [],       136,  "asyncio.__dict__.__len__() == 136; verified with Python 3.14.3"]
    - [dict_cls_eq,     asyncio.__dict__.__class__.__name__.__eq__,      ["dict"], true,  "asyncio.__dict__.__class__.__name__ == 'dict' (module __dict__ is plain dict, not mappingproxy); verified with Python 3.14.3"]
    - [dict_cls_len,    asyncio.__dict__.__class__.__name__.__len__,     [],       4,     "asyncio.__dict__.__class__.__name__.__len__() == 4 ('dict'); verified with Python 3.14.3"]
    - [name_eq,         asyncio.__name__.__eq__,                         ["asyncio"], true, "asyncio.__name__ == 'asyncio' (len=7); verified with Python 3.14.3"]
    - [name_len,        asyncio.__name__.__len__,                        [],       7,     "asyncio.__name__.__len__() == 7; verified with Python 3.14.3"]

