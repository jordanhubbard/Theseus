table asyncio_extra151.asyncio_submodule_dict_sizes:
  description: "asyncio submodule __dict__ size checks in asynciodict151 namespace — asyncio.tasks.__dict__.__len__()==81 (largest submodule: tasks.py contains coroutine scheduling functions sleep, gather, wait, shield, create_task, ensure_future, as_completed, and the Task class plus many helpers; len('asyncio.tasks')==13); asyncio.futures.__dict__.__len__()==40 (second-largest: futures.py contains Future, isfuture, wrap_future, and related helpers; len('asyncio.futures')==15); asyncio.locks.__dict__.__len__()==21 (third: locks.py contains Lock, Event, Condition, Semaphore, BoundedSemaphore; len('asyncio.locks')==13); asyncio.queues.__dict__.__len__()==20 (smallest: queues.py contains Queue, PriorityQueue, LifoQueue, QueueEmpty, QueueFull; len('asyncio.queues')==14); all submodule __dict__ are plain dict (not mappingproxy); verified with Python 3.14.3"
  kind: python_call_eq
  category: namespace
  id_prefix: asynciosubdict151

  columns: [id, function, args, expected, description]
  rows:
    - [tasks_len,    asyncio.tasks.__dict__.__len__,    [],  81,  "asyncio.tasks.__dict__.__len__() == 81 (largest submodule); verified with Python 3.14.3"]
    - [futures_len,  asyncio.futures.__dict__.__len__,  [],  40,  "asyncio.futures.__dict__.__len__() == 40; verified with Python 3.14.3"]
    - [locks_len,    asyncio.locks.__dict__.__len__,    [],  21,  "asyncio.locks.__dict__.__len__() == 21; verified with Python 3.14.3"]
    - [queues_len,   asyncio.queues.__dict__.__len__,   [],  20,  "asyncio.queues.__dict__.__len__() == 20 (smallest submodule); verified with Python 3.14.3"]

