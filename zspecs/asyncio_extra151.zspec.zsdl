# Standalone invariants — extra151
# ---------------------------------------------------------------------------

invariant asyncio_extra151.asyncio_dict_len_136:
  description: "asyncio.__dict__.__len__() == 136 — the asyncio package exports 136 names in its module __dict__; asyncio is the aggregating top-level package that re-exports from all submodules (tasks, futures, locks, queues, streams, runners, etc.); compare submodule sizes: tasks(81) > futures(40) > locks(21) > queues(20); the top-level asyncio.__dict__ (136) is larger than any single submodule because it aggregates re-exports from all of them plus module-level dunder attributes (__name__, __doc__, __spec__, etc.); asyncio.__dict__.__class__.__name__=='dict' (not mappingproxy — it is a module, not a class); NEW in extra151: first standalone asyncio.__dict__ length invariant in asynciodict151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: asyncio.__dict__.__len__
  args: []
  expected: 136

invariant asyncio_extra151.asyncio_dict_class_is_dict:
  description: "asyncio.__dict__.__class__.__name__.__eq__('dict') returns True — asyncio.__dict__.__class__.__name__ is 'dict' (4 chars); module-level __dict__ objects are plain dicts, not mappingproxy (which is only used for class __dict__); this distinguishes asyncio.__dict__ from asyncio.Task.__dict__ (mappingproxy, 12 chars) and asyncio.Future.__dict__ (mappingproxy, 12 chars); asyncio.__dict__.__class__.__name__.__len__()==4; asyncio.__dict__.__len__()==136; NEW in extra151: first standalone asyncio.__dict__ class name invariant in asynciodict151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: asyncio.__dict__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant asyncio_extra151.asyncio_tasks_dict_len_81:
  description: "asyncio.tasks.__dict__.__len__() == 81 — asyncio.tasks is the largest of the asyncio submodules with 81 entries in its module __dict__; tasks.py contains the core coroutine scheduling machinery: sleep, gather, wait, wait_for, shield, create_task, ensure_future, as_completed, timeout, timeout_at, current_task, all_tasks, and the Task class itself, along with many internal helpers and constants; compare: futures(40), locks(21), queues(20); asyncio.tasks.__name__=='asyncio.tasks' (len=13); asyncio.tasks.__dict__.__class__.__name__=='dict' (module __dict__); NEW in extra151: first standalone asyncio.tasks.__dict__ length invariant in asynciodict151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: asyncio.tasks.__dict__.__len__
  args: []
  expected: 81

invariant asyncio_extra151.asyncio_futures_dict_len_40:
  description: "asyncio.futures.__dict__.__len__() == 40 — asyncio.futures is the second-largest asyncio submodule with 40 entries; futures.py defines Future (the pure-Python implementation, not to be confused with the C extension _asyncio.Future), isfuture, wrap_future, and related helpers and exceptions; asyncio.futures.__name__=='asyncio.futures' (len=15, the longest submodule name in this spec); compare: tasks(81) > futures(40) > locks(21) > queues(20); asyncio.futures.__dict__.__class__.__name__=='dict'; NEW in extra151: first standalone asyncio.futures.__dict__ length invariant in asynciodict151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: namespace
  kind: python_call_eq
  function: asyncio.futures.__dict__.__len__
  args: []
  expected: 40

invariant asyncio_extra151.asyncio_futures_name_len_15:
  description: "asyncio.futures.__name__.__len__() == 15 — asyncio.futures.__name__ is 'asyncio.futures' (15 chars: 'asyncio'=7+'.'=1+'futures'=7=15); this is the longest submodule name in this spec: futures(15) > queues(14) > tasks(13, tied with locks) = locks(13); asyncio.futures is the submodule containing the Future class implementation; asyncio.futures.__dict__.__len__()==40 (second-largest submodule namespace); NEW in extra151: first standalone asyncio.futures.__name__ length invariant in asynciodict151 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.futures.__name__.__len__
  args: []
  expected: 15

