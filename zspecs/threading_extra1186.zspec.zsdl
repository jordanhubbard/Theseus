spec: threading_extra1186
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks threading.Barrier.__weakref__.__class__.__name__, threading.BoundedSemaphore.__weakref__.__class__.__name__, threading.Semaphore.__weakref__.__class__.__name__, threading.Thread.__weakref__.__class__.__name__, threading.Timer.__weakref__.__class__.__name__, threading.local.__weakref__.__class__.__name__, threading.Condition.__weakref__.__class__.__name__, threading.RLock.__weakref__.__class__.__name__ — not covered in _extra1156/_extra1171"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra1186.barrier_bounded_semaphore_weakref_class_names:
  description: "threading.Barrier and BoundedSemaphore __weakref__.__class__.__name__ identity"
  kind: python_call_eq
  category: barrier_bounded_semaphore_weakref_class_names
  id_prefix: th1186bb
  columns: [id, function, args, expected]
  rows:
    - [th1186bb001, threading.Barrier.__weakref__.__class__.__name__.__eq__,           ["getset_descriptor"],   true]
    - [th1186bb002, threading.Barrier.__weakref__.__qualname__.__eq__,                 ["Barrier.__weakref__"], true]
    - [th1186bb003, threading.Barrier.__module__.__eq__,                               ["threading"],           true]
    - [th1186bb004, threading.BoundedSemaphore.__weakref__.__class__.__name__.__eq__,  ["getset_descriptor"],   true]
    - [th1186bb005, threading.BoundedSemaphore.__weakref__.__qualname__.__eq__,        ["BoundedSemaphore.__weakref__"], true]
    - [th1186bb006, threading.BoundedSemaphore.__module__.__eq__,                      ["threading"],           true]
    - [th1186bb007, threading.Semaphore.__weakref__.__class__.__name__.__eq__,         ["getset_descriptor"],   true]
    - [th1186bb008, threading.Semaphore.__weakref__.__qualname__.__eq__,               ["Semaphore.__weakref__"], true]

