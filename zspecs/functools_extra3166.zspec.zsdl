spec: ft3166
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 658 (ft3166): __add__, __sub__, __mul__ dict-presence checks for functools types."
    - "None of the four functools types define __add__, __sub__, or __mul__ in their own __dict__."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "functools._lru_cache_wrapper is accessed as type(functools.lru_cache(lambda: None)) at runtime; functools._lru_cache_wrapper is the internal C wrapper class."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3166.add:
  description: "functools types __add__ dict-presence checks; wave 658"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft3166
  columns: [id, function, args, expected]
  rows:
    - ["ft3166001", operator.contains, [functools.partial.__dict__,            "__add__"], false]
    - ["ft3166002", operator.contains, [functools.partialmethod.__dict__,      "__add__"], false]
    - ["ft3166003", operator.contains, [functools.cached_property.__dict__,    "__add__"], false]
    - ["ft3166004", operator.contains, [functools._lru_cache_wrapper.__dict__, "__add__"], false]

