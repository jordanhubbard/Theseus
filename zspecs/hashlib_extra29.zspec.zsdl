spec: hashlib_extra29
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra28.zspec.zsdl — covers sha3_256/sha3_512/blake2b/blake2s __qualname__.__eq__ and __qualname__.__len__."
    - "hashlib_extra27.zspec.zsdl — covers HASH instance method qualnames (update/digest/hexdigest/copy) via md5() and sha256(); sha256().block_size/digest_size __class__.__name__."
    - "hashlib_extra26.zspec.zsdl — covers sha224/sha384 __qualname__.__eq__; new.__qualname__.__eq__; algorithms_guaranteed/available __class__.__name__.__eq__."
    - "hashlib_extra25.zspec.zsdl — covers algorithms_guaranteed/__class__/__qualname__; algorithms_guaranteed/__len__()==14; algorithms_guaranteed contains sha3_256; isdisjoint(set())."
    - "hashlib_extra24.zspec.zsdl — covers md5/sha1/sha256/sha512 __qualname__.__eq__ standalone; __qualname__.__len__ for md5/sha1/sha256/sha512/sha224/sha384/new/pbkdf2_hmac."
    - "hashlib_extra20.zspec.zsdl — covers md5/sha1/sha256/sha512/new/pbkdf2_hmac __name__; algorithms_available/__class__/__name__.__eq__; algorithms_guaranteed contains sha256/sha1/md5."
    - "hashlib_extra19.zspec.zsdl — covers algorithms_guaranteed membership table sha256/sha512/sha1/md5/sha3_256; min_count; hexdigest lengths."
    - "hashlib_extra17.zspec.zsdl — covers sha256/md5/sha1 empty-input hexdigest; sha256 block_size/name; new.__qualname__."
    - "hashlib_extra9.zspec.zsdl — covers algorithms_guaranteed len >= 8; blake2s/blake2b/sha3_512 membership."
  notes:
    - "This spec extends hashlib through hashlib_extra28; it does NOT duplicate invariants present in those files."
    - "Focus: __name__ attributes for sha3_256/sha3_512/blake2b/blake2s (extra20 covers md5/sha1/sha256/sha512/new/pbkdf2_hmac but NOT sha3_*/blake2*); new.__module__ (novel — no prior spec checks new.__module__.__eq__ from any namespace); algorithms_guaranteed membership for sha224/sha384/sha3_224/sha3_384 (extra20 covers sha256/sha1/md5; extra25 covers sha3_256; extra9 covers sha3_512/blake2b/blake2s — sha224/sha384/sha3_224/sha3_384 are uncovered)."
    - "hashlib.sha3_256.__name__ == 'openssl_sha3_256': On CPython 3.12, sha3_256 uses the OpenSSL backend; its C-level __name__ is 'openssl_sha3_256'. extra20 covers md5/sha1/sha256/sha512 __name__ but not sha3_256. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512.__name__ == 'openssl_sha3_512': Same OpenSSL-backed naming for sha3_512. Not covered by extra20. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__ == 'blake2b': blake2b uses a dedicated C extension (_blake2), not OpenSSL. Its __name__ matches its Python alias. Not covered by extra20. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__ == 'blake2s': Same for blake2s. Not covered by extra20. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__ == 'hashlib': new is the Python-level wrapper defined in hashlib.py. No prior spec covers new.__module__.__eq__ as a standalone invariant. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed contains sha224 and sha384: extra20 covers sha256/sha1/md5; extra9 covers sha3_512/blake2b/blake2s; extra25 covers sha3_256. sha224 and sha384 are not covered as standalone membership invariants. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed contains sha3_224 and sha3_384: No prior spec covers sha3_224 or sha3_384 membership. Both are present in CPython 3.12. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sha3_256, sha3_512, blake2b, blake2s — __name__ attributes
#
# hashlib_extra20 covers __name__ for md5/sha1/sha256/sha512/new/pbkdf2_hmac.
# No prior spec covers __name__ for sha3_256, sha3_512, blake2b, or blake2s.
# On CPython 3.12: sha3_256 and sha3_512 use OpenSSL ('openssl_sha3_256',
# 'openssl_sha3_512'), while blake2b and blake2s use a dedicated _blake2
# C extension ('blake2b', 'blake2s').
# ---------------------------------------------------------------------------

table hashlib_extra29.sha3_blake2_function_names:
  description: "sha3_256/sha3_512/blake2b/blake2s __name__ values — not covered by hashlib_extra20"
  kind: python_call_eq
  category: function_names
  id_prefix: hlfn29

  columns: [id, function, args, expected]
  rows:
    - [sha3_256, sha3_256.__name__.__eq__, ["openssl_sha3_256"], true]
    - [sha3_512, sha3_512.__name__.__eq__, ["openssl_sha3_512"], true]
    - [blake2b,  blake2b.__name__.__eq__,  ["blake2b"],          true]
    - [blake2s,  blake2s.__name__.__eq__,  ["blake2s"],          true]

# ---------------------------------------------------------------------------
# hashlib.new.__module__ — standalone invariant
#
# hashlib.new is the Python-level wrapper function defined in hashlib.py.
# No prior spec covers new.__module__.__eq__ as a standalone invariant.
# hashlib_extra20 covers new.__name__; hashlib_extra17/26 cover new.__qualname__.
# new.__module__ == 'hashlib' confirms its origin in the pure-Python layer.
# ---------------------------------------------------------------------------

invariant hashlib_extra29.new.module:
  description: "hashlib.new.__module__ == 'hashlib' — wrapper function defined in hashlib module"
  category: module_metadata
  kind: python_call_eq
  function: new.__module__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_guaranteed membership — sha224, sha384
#
# hashlib_extra20 covers sha256/sha1/md5 membership; hashlib_extra25 covers
# sha3_256; hashlib_extra9 covers sha3_512/blake2b/blake2s.
# No prior spec covers sha224 or sha384 as standalone membership invariants.
# Both are guaranteed on all Python 3.6+ implementations per PEP 456.
# ---------------------------------------------------------------------------

invariant hashlib_extra29.algorithms_guaranteed.sha224:
  description: "'sha224' in hashlib.algorithms_guaranteed — SHA-224 is always guaranteed"
  category: algorithms_guaranteed
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha224"]
  expected: true

invariant hashlib_extra29.algorithms_guaranteed.sha384:
  description: "'sha384' in hashlib.algorithms_guaranteed — SHA-384 is always guaranteed"
  category: algorithms_guaranteed
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha384"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_guaranteed membership — sha3_224, sha3_384
#
# No prior spec covers sha3_224 or sha3_384 membership in
# algorithms_guaranteed. hashlib_extra25 covers sha3_256; hashlib_extra9
# covers sha3_512. sha3_224 and sha3_384 complete the SHA-3 family.
# Both are guaranteed on Python 3.6+. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra29.algorithms_guaranteed.sha3_224:
  description: "'sha3_224' in hashlib.algorithms_guaranteed — SHA3-224 is always guaranteed on Python 3.6+"
  category: algorithms_guaranteed
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha3_224"]
  expected: true

invariant hashlib_extra29.algorithms_guaranteed.sha3_384:
  description: "'sha3_384' in hashlib.algorithms_guaranteed — SHA3-384 is always guaranteed on Python 3.6+"
  category: algorithms_guaranteed
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha3_384"]
  expected: true
