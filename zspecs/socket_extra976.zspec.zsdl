spec: socket_extra976
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks socket.socket method __qualname__ attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra976.socket_io_method_qualnames:
  description: "socket.socket I/O method __qualname__ identity"
  kind: python_call_eq
  category: io_method_qualnames
  id_prefix: sk976iq
  columns: [id, function, args, expected]
  rows:
    - [sk976iq001, socket.socket.send.__qualname__.__eq__,      ["socket.send"],      true]
    - [sk976iq002, socket.socket.recv.__qualname__.__eq__,      ["socket.recv"],      true]
    - [sk976iq003, socket.socket.sendall.__qualname__.__eq__,   ["socket.sendall"],   true]
    - [sk976iq004, socket.socket.sendto.__qualname__.__eq__,    ["socket.sendto"],    true]
    - [sk976iq005, socket.socket.recvfrom.__qualname__.__eq__,  ["socket.recvfrom"],  true]
    - [sk976iq006, socket.socket.recvmsg.__qualname__.__eq__,   ["socket.recvmsg"],   true]

