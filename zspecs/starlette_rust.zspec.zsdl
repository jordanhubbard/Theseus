spec: starlette_rust
version: ">=3.9"
backend: rust_module(starlette_rust)

docs: https://www.starlette.io/

provenance:
  derived_from:
    - "https://www.starlette.io/ — Starlette documentation"
  not_derived_from:
    - "starlette source: starlette/applications.py"
  notes:
    - "Starlette is a lightweight ASGI framework."
    - "starlette.routing.Route is available."
    - "starlette.responses.JSONResponse is available."
    - "starlette.responses.Response is available."
    - "starlette.status.HTTP_200_OK == 200."
    - "starlette.status.HTTP_404_NOT_FOUND == 404."
    - "Expose starlette_status_ok() -> int: starlette.status.HTTP_200_OK."
    - "Expose starlette_status_not_found() -> int: starlette.status.HTTP_404_NOT_FOUND."
    - "Expose starlette_has_routing() -> bool: hasattr(starlette, 'routing')."
    - "All test vectors verified against starlette 0.46.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# starlette status constants
invariant starlette_rust.status.ok:
  description: "starlette.status.HTTP_200_OK == 200"
  category: status
  kind: python_call_eq
  function: starlette_status_ok
  args: []
  expected: 200

invariant starlette_rust.status.not_found:
  description: "starlette.status.HTTP_404_NOT_FOUND == 404"
  category: status
  kind: python_call_eq
  function: starlette_status_not_found
  args: []
  expected: 404

# starlette_has_routing — routing module present
invariant starlette_rust.module.has_routing:
  description: "starlette.routing is available"
  category: module
  kind: python_call_eq
  function: starlette_has_routing
  args: []
  expected: true

