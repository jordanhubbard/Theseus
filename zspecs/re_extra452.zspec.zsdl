spec: re_extra452
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module compile flags and RegexFlag enum identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.NOFLAG (value 0) was added in Python 3.11; included here with a version note"
    - "All flag values are confirmed against the documented integer values in the re module"
    - "RegexFlag inherits from IntFlag (enum module)"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra452.module_flag_values:
  description: "re module top-level flag constant values"
  kind: python_call_eq
  category: flag_values
  id_prefix: RFV

  columns: [id, function, args, expected]
  rows:
    - [RFV001, re.ASCII.__eq__,  [256], true]
    - [RFV002, re.LOCALE.__eq__, [4],   true]
    - [RFV003, re.NOFLAG.__eq__, [0],   true]

table re_extra452.regex_flag_class_identity:
  description: "re.RegexFlag class name and module identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: RFC

  columns: [id, function, args, expected]
  rows:
    - [RFC001, re.RegexFlag.__name__.__eq__,   ["RegexFlag"], true]
    - [RFC002, re.RegexFlag.__module__.__eq__, ["re"],        true]

table re_extra452.regex_flag_bases:
  description: "re.RegexFlag base class identity"
  kind: python_call_eq
  category: class_identity
  id_prefix: RFB

  columns: [id, function, args, expected]
  rows:
    - [RFB001, "re.RegexFlag.__bases__[0].__name__.__eq__", ["IntFlag"], true]

table re_extra452.regex_flag_member_values:
  description: "re.RegexFlag enum member integer values"
  kind: python_call_eq
  category: flag_values
  id_prefix: RFM

  columns: [id, function, args, expected]
  rows:
    - [RFM001, re.RegexFlag.IGNORECASE.value.__eq__, [2],  true]
    - [RFM002, re.RegexFlag.MULTILINE.value.__eq__,  [8],  true]
    - [RFM003, re.RegexFlag.DOTALL.value.__eq__,     [16], true]
    - [RFM004, re.RegexFlag.UNICODE.value.__eq__,    [32], true]
    - [RFM005, re.RegexFlag.VERBOSE.value.__eq__,    [64], true]
