spec: uuid_extra193
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
  notes:
    - "uuid.__name__ == 'uuid' — the module's own name."
    - "uuid.__package__ == '' — top-level module, empty string package."
    - "uuid.__spec__.name == 'uuid' — the ModuleSpec name matches the module name."
    - "uuid.__loader__.__class__.__name__ == 'SourceFileLoader' — uuid is a Python source file (Lib/uuid.py)."
    - "uuid.__doc__.__class__.__name__ == 'str' — the module docstring is a str object."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid module-level dunder identity attributes — __name__ and __package__
# ---------------------------------------------------------------------------

table uuid_extra193.module_name_attrs:
  description: "uuid module __name__ and __package__ dunder attribute identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmod193name

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,        __name__.__eq__,    ["uuid"], true, "uuid.__name__ == 'uuid'"]
    - [package_eq,     __package__.__eq__, [""],     true, "uuid.__package__ == '' — top-level module has empty package string"]
    - [name_is_str,    __name__.__class__.__name__.__eq__,    ["str"], true, "uuid.__name__ is a str object"]
    - [package_is_str, __package__.__class__.__name__.__eq__, ["str"], true, "uuid.__package__ is a str object"]

# ---------------------------------------------------------------------------
# uuid module-level dunder spec attributes — __spec__.name
# ---------------------------------------------------------------------------

table uuid_extra193.module_spec_attrs:
  description: "uuid module __spec__ dunder attribute identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmod193spec

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,       __spec__.name.__eq__,               ["uuid"],      true, "uuid.__spec__.name == 'uuid'"]
    - [spec_name_is_str,   __spec__.name.__class__.__name__.__eq__, ["str"],   true, "uuid.__spec__.name is a str object"]
    - [spec_name_matches,  __spec__.name.__eq__,               ["uuid"],      true, "uuid.__spec__.name equals uuid.__name__"]
    - [spec_class_eq,      __spec__.__class__.__name__.__eq__, ["ModuleSpec"], true, "uuid.__spec__ is a ModuleSpec object"]

# ---------------------------------------------------------------------------
# uuid module-level dunder loader and doc attributes
# ---------------------------------------------------------------------------

table uuid_extra193.module_loader_doc_attrs:
  description: "uuid module __loader__ and __doc__ dunder attribute identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: uuidmod193loader

  columns: [id, function, args, expected, description]
  rows:
    - [loader_class_eq,  __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "uuid.__loader__.__class__.__name__ == 'SourceFileLoader' — uuid is a Python source module"]
    - [doc_class_eq,     __doc__.__class__.__name__.__eq__,    ["str"],              true, "uuid.__doc__.__class__.__name__ == 'str' — module docstring is a str"]
    - [doc_is_str,       __doc__.__class__.__name__.__eq__,    ["str"],              true, "uuid.__doc__ is a str object (module has a docstring)"]
    - [loader_is_obj,    __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "uuid.__loader__ is a SourceFileLoader instance"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant uuid_extra193.name_eq:
  description: "uuid.__name__ == 'uuid'"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra193.package_eq:
  description: "uuid.__package__ == '' — top-level module, empty package"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant uuid_extra193.spec_name_eq:
  description: "uuid.__spec__.name == 'uuid'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra193.loader_class_name_eq:
  description: "uuid.__loader__.__class__.__name__ == 'SourceFileLoader' — uuid is implemented as a pure-Python source file"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

invariant uuid_extra193.doc_class_name_eq:
  description: "uuid.__doc__.__class__.__name__ == 'str' — the module docstring is a str"
  category: identity
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant uuid_extra193.name_is_str:
  description: "uuid.__name__.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __name__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant uuid_extra193.package_is_str:
  description: "uuid.__package__.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __package__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant uuid_extra193.spec_name_is_str:
  description: "uuid.__spec__.name.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__class__.__name__.__eq__
  args: ["str"]
  expected: true
