spec: pathlib_extra2791
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 pathlib documentation — https://docs.python.org/3/library/pathlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
    - "pathlib_extra.zspec.zsdl — covers existing pathlib invariants"
    - "pathlib_extra2776.zspec.zsdl — covers __isub__/__imul__/__itruediv__ dict-presence"
    - "pathlib_extra2761.zspec.zsdl — covers __matmul__/__truediv__/__iadd__ dict-presence"
    - "pathlib_extra2746.zspec.zsdl — covers __round__/__divmod__/__pow__ dict-presence"
    - "pathlib_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "pathlib_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 633 (pathlib_extra2791) theme: __iand__, __ior__, and __ixor__ dict-presence checks."
    - "None of the pathlib classes define __iand__, __ior__, or __ixor__ in their own __dict__."
    - "__iand__ supports the &= operator; pathlib path objects do not implement in-place bitwise-AND semantics."
    - "__ior__ supports the |= operator; pathlib path objects do not implement in-place bitwise-OR semantics."
    - "__ixor__ supports the ^= operator; pathlib path objects do not implement in-place bitwise-XOR semantics."
    - "Covers pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, and pathlib.Path."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __iand__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2791.no_iand_in_pathlib_classes:
  description: "__iand__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the &= in-place bitwise-AND protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2791

  columns: [id, function, args, expected]
  rows:
    - ["pp2791001", "pathlib.PurePath.__dict__.__contains__",        ["__iand__"], false]
    - ["pp2791002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__iand__"], false]
    - ["pp2791003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__iand__"], false]
    - ["pp2791004", "pathlib.Path.__dict__.__contains__",            ["__iand__"], false]

# ---------------------------------------------------------------------------
# __ior__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2791.no_ior_in_pathlib_classes:
  description: "__ior__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the |= in-place bitwise-OR protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2791

  columns: [id, function, args, expected]
  rows:
    - ["pp2791005", "pathlib.PurePath.__dict__.__contains__",        ["__ior__"], false]
    - ["pp2791006", "pathlib.PurePosixPath.__dict__.__contains__",   ["__ior__"], false]
    - ["pp2791007", "pathlib.PureWindowsPath.__dict__.__contains__", ["__ior__"], false]
    - ["pp2791008", "pathlib.Path.__dict__.__contains__",            ["__ior__"], false]

# ---------------------------------------------------------------------------
# __ixor__ dict-presence — pathlib path classes
# ---------------------------------------------------------------------------

table pathlib_extra2791.no_ixor_in_pathlib_classes:
  description: "__ixor__ is absent from all pathlib class __dict__s — pathlib path objects do not implement the ^= in-place bitwise-XOR protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2791

  columns: [id, function, args, expected]
  rows:
    - ["pp2791009",  "pathlib.PurePath.__dict__.__contains__",        ["__ixor__"], false]
    - ["pp2791010", "pathlib.PurePosixPath.__dict__.__contains__",   ["__ixor__"], false]
    - ["pp2791011", "pathlib.PureWindowsPath.__dict__.__contains__", ["__ixor__"], false]
    - ["pp2791012", "pathlib.Path.__dict__.__contains__",            ["__ixor__"], false]

# ---------------------------------------------------------------------------
# Complementary: PurePath has __truediv__ but not __iand__, __ior__, or __ixor__
# Distinguishes the path-joining / operator from unsupported in-place bitwise operations
# ---------------------------------------------------------------------------

table pathlib_extra2791.pathlib_truediv_but_not_inplace_bitwise:
  description: "pathlib.PurePath defines __truediv__/__rtruediv__ for path joining but NOT __iand__/__ior__/__ixor__; pathlib.Path defines stat/exists/open but none of the in-place bitwise hooks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2791

  columns: [id, function, args, expected]
  rows:
    - ["pp2791013", "pathlib.PurePath.__dict__.__contains__", ["__truediv__"],  true]
    - ["pp2791014", "pathlib.PurePath.__dict__.__contains__", ["__rtruediv__"], true]
    - ["pp2791015", "pathlib.PurePath.__dict__.__contains__", ["__iand__"],     false]
    - ["pp2791016", "pathlib.PurePath.__dict__.__contains__", ["__ior__"],      false]
    - ["pp2791017", "pathlib.PurePath.__dict__.__contains__", ["__ixor__"],     false]
    - ["pp2791018", "pathlib.Path.__dict__.__contains__",     ["stat"],         true]
    - ["pp2791019", "pathlib.Path.__dict__.__contains__",     ["exists"],       true]
    - ["pp2791020", "pathlib.Path.__dict__.__contains__",     ["open"],         true]
    - ["pp2791021", "pathlib.Path.__dict__.__contains__",     ["__iand__"],     false]
    - ["pp2791022", "pathlib.Path.__dict__.__contains__",     ["__ior__"],      false]
    - ["pp2791023", "pathlib.Path.__dict__.__contains__",     ["__ixor__"],     false]
