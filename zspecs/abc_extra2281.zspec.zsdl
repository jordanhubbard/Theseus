    - ["ab2281006", "abc.abstractmethod.__class__.__mro__.__len__", [], 2]
    - ["ab2281007", "abc.abstractmethod.__class__.__bases__.__len__", [], 1]

table abc_extra2281.dict_presence:
  description: "abc module class __dict__ key presence checks for hierarchy-related attributes"
