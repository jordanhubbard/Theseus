  category: dict_contains
  id_prefix: ab2281

  columns: [id, function, args, expected]
  rows:
    - ["ab2281008", "abc.ABCMeta.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ab2281009", "abc.ABC.__dict__.__contains__", ["__abstractmethods__"], true]
    - ["ab2281010", "abc.ABCMeta.__dict__.__contains__", ["__mro__"], false]
    - ["ab2281011", "abc.ABC.__dict__.__contains__", ["__mro__"], false]
    - ["ab2281012", "abc.ABCMeta.__dict__.__contains__", ["__bases__"], false]
    - ["ab2281013", "abc.ABC.__dict__.__contains__", ["__bases__"], false]
    - ["ab2281014", "abc.ABCMeta.__dict__.__contains__", ["register"], true]
    - ["ab2281015", "abc.ABCMeta.__dict__.__contains__", ["__subclasshook__"], false]
    - ["ab2281016", "abc.ABCMeta.__dict__.__contains__", ["__instancecheck__"], true]
    - ["ab2281017", "abc.ABCMeta.__dict__.__contains__", ["__subclasscheck__"], true]
    - ["ab2281018", "abc.ABC.__dict__.__contains__", ["__subclasshook__"], false]
    - ["ab2281019", "abc.abstractmethod.__dict__.__contains__", ["__isabstractmethod__"], false]
