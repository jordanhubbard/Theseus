spec: abc_extra2281
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 599 (_extra2281): class hierarchy metrics — MRO depth, base count."
    - "abc.ABCMeta.__mro__ == (ABCMeta, type, object) => len 3."
    - "abc.ABC.__mro__ == (ABC, object) => len 2."
    - "abc.abstractmethod is a function (not a class); its type (function) has __mro__ len 2."
    - "abc.ABC.__abstractmethods__ exists as a frozenset with len 0 (no abstract methods defined on ABC itself)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table abc_extra2281.abcmeta_mro:
  description: "abc.ABCMeta MRO and base class metrics — ABCMeta -> type -> object"
  kind: python_call_eq
  category: mro_depth
  id_prefix: ab2281

  columns: [id, function, args, expected]
  rows:
    - ["ab2281001", "abc.ABCMeta.__mro__.__len__", [], 3]
    - ["ab2281002", "abc.ABCMeta.__bases__.__len__", [], 1]

table abc_extra2281.abc_class_mro:
  description: "abc.ABC MRO and base class metrics — ABC -> object"
