spec: concurrent_futures_extra331
version: ">=3.2"
backend: python_module(concurrent.futures._base)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "concurrent.futures._base exposes internal state string constants PENDING, RUNNING, CANCELLED, FINISHED."
    - "Each state constant is a plain str; __class__.__name__ == 'str' and __eq__ with the matching string returns True."
    - "Future qualnames in _base follow the 'Future.<method>' pattern."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Internal state string constants — PENDING, RUNNING, CANCELLED, FINISHED
#
# These are module-level str constants used internally by the Future state
# machine. Each is a plain str whose value matches its name.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra331.states.PENDING_is_str:
  description: "concurrent.futures._base.PENDING.__class__.__name__ == 'str'"
  category: states
  kind: python_call_eq
  function: PENDING.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant concurrent_futures_extra331.states.PENDING_value:
  description: "concurrent.futures._base.PENDING.__eq__('PENDING') == True"
  category: states
  kind: python_call_eq
  function: PENDING.__eq__
  args: ["PENDING"]
  expected: true

invariant concurrent_futures_extra331.states.RUNNING_value:
  description: "concurrent.futures._base.RUNNING.__eq__('RUNNING') == True"
  category: states
  kind: python_call_eq
  function: RUNNING.__eq__
  args: ["RUNNING"]
  expected: true

invariant concurrent_futures_extra331.states.CANCELLED_value:
  description: "concurrent.futures._base.CANCELLED.__eq__('CANCELLED') == True"
  category: states
  kind: python_call_eq
  function: CANCELLED.__eq__
  args: ["CANCELLED"]
  expected: true

invariant concurrent_futures_extra331.states.FINISHED_value:
  description: "concurrent.futures._base.FINISHED.__eq__('FINISHED') == True"
  category: states
  kind: python_call_eq
  function: FINISHED.__eq__
  args: ["FINISHED"]
  expected: true

# ---------------------------------------------------------------------------
# Future qualnames — methods on the Future class in _base
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra331.future.qualname:
  description: "concurrent.futures._base.Future.__qualname__ == 'Future'"
  category: future
  kind: python_call_eq
  function: Future.__qualname__.__eq__
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra331.future.cancel_qualname:
  description: "concurrent.futures._base.Future.cancel.__qualname__ == 'Future.cancel'"
  category: future
  kind: python_call_eq
  function: Future.cancel.__qualname__.__eq__
  args: ["Future.cancel"]
  expected: true

invariant concurrent_futures_extra331.future.result_qualname:
  description: "concurrent.futures._base.Future.result.__qualname__ == 'Future.result'"
  category: future
  kind: python_call_eq
  function: Future.result.__qualname__.__eq__
  args: ["Future.result"]
  expected: true

invariant concurrent_futures_extra331.future.exception_qualname:
  description: "concurrent.futures._base.Future.exception.__qualname__ == 'Future.exception'"
  category: future
  kind: python_call_eq
  function: Future.exception.__qualname__.__eq__
  args: ["Future.exception"]
  expected: true

invariant concurrent_futures_extra331.future.running_qualname:
  description: "concurrent.futures._base.Future.running.__qualname__ == 'Future.running'"
  category: future
  kind: python_call_eq
  function: Future.running.__qualname__.__eq__
  args: ["Future.running"]
  expected: true
