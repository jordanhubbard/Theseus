spec: hl3331
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 669 (hl3331): __iand__, __ior__, __ixor__ dict-presence checks for hashlib types."
    - "Theme: __iand__/__ior__/__ixor__ dict-presence (in-place &=, |=, ^=)."
    - "All values False — hash objects do not define in-place bitwise AND, OR, or XOR protocol methods in their own __dict__."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "None of the hashlib types define __iand__, __ior__, or __ixor__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3331.iand:
  description: "hashlib types __iand__ dict-presence checks; wave 669"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3331
  columns: [id, function, args, expected]
  rows:
    - ["hl3331001", operator.contains, [type(hashlib.md5()).__dict__,        "__iand__"], false]
    - ["hl3331002", operator.contains, [type(hashlib.sha1()).__dict__,       "__iand__"], false]
    - ["hl3331003", operator.contains, [type(hashlib.sha256()).__dict__,     "__iand__"], false]
    - ["hl3331004", operator.contains, [type(hashlib.sha512()).__dict__,     "__iand__"], false]
    - ["hl3331005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__iand__"], false]

