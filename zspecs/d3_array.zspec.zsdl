spec: d3_array
version: ">=3.0.0"
backend: node(d3-array)

docs: https://d3js.org/d3-array

provenance:
  derived_from:
    - "d3-array docs — https://d3js.org/d3-array"
    - "Test vectors verified with d3-array via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "d3-array source"
  notes:
    - "Statistical and array helpers — min, max, sum, mean, median, extent, range, group, etc."
    - "Install: npm install d3-array"
    - "v3 ESM only; named exports per helper."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; min/max/etc return undefined on empty arrays."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant d3_array.min_simple:
  description: "min([3,1,4,1,5,9,2,6]) is 1"
  category: stats
  kind: node_chain_eq
  entry: named
  function: min
  entry_args: [[3, 1, 4, 1, 5, 9, 2, 6]]
  chain: []
  expected: 1

invariant d3_array.max_simple:
  description: "max([3,1,4,1,5,9,2,6]) is 9"
  category: stats
  kind: node_chain_eq
  entry: named
  function: max
  entry_args: [[3, 1, 4, 1, 5, 9, 2, 6]]
  chain: []
  expected: 9

invariant d3_array.sum_simple:
  description: "sum([1,2,3,4]) is 10"
  category: stats
  kind: node_chain_eq
  entry: named
  function: sum
  entry_args: [[1, 2, 3, 4]]
  chain: []
  expected: 10

invariant d3_array.mean_simple:
  description: "mean([1,2,3,4,5]) is 3"
  category: stats
  kind: node_chain_eq
  entry: named
  function: mean
  entry_args: [[1, 2, 3, 4, 5]]
  chain: []
  expected: 3

invariant d3_array.median_simple:
  description: "median([1,2,3,4,5]) is 3"
  category: stats
  kind: node_chain_eq
  entry: named
  function: median
  entry_args: [[1, 2, 3, 4, 5]]
  chain: []
  expected: 3

invariant d3_array.extent_simple:
  description: "extent([3,1,4]) is [1,4]"
  category: stats
  kind: node_chain_eq
  entry: named
  function: extent
  entry_args: [[3, 1, 4]]
  chain: []
  expected: [1, 4]

invariant d3_array.range_basic:
  description: "range(0, 5) is [0,1,2,3,4]"
  category: range
  kind: node_chain_eq
  entry: named
  function: range
  entry_args: [0, 5]
  chain: []
  expected: [0, 1, 2, 3, 4]

invariant d3_array.range_step:
  description: "range(0, 10, 2) is [0,2,4,6,8]"
  category: range
  kind: node_chain_eq
  entry: named
  function: range
  entry_args: [0, 10, 2]
  chain: []
  expected: [0, 2, 4, 6, 8]

invariant d3_array.empty_min_undefined:
  description: "min([]) returns undefined (null in JSON)"
  category: edge
  kind: node_chain_eq
  entry: named
  function: min
  entry_args: [[]]
  chain: []
  expected: ~

invariant d3_array.median_even_count:
  description: "median([1,2,3,4]) is 2.5 (average of two middle values)"
  category: stats
  kind: node_chain_eq
  entry: named
  function: median
  entry_args: [[1, 2, 3, 4]]
  chain: []
  expected: 2.5
