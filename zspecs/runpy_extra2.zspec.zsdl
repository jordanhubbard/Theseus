spec: runpy_extra2
version: ">=3.9"
backend: python_module(runpy)

docs: https://docs.python.org/3/library/runpy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/runpy.html — Python runpy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/runpy.py"
  notes:
    - "Covers run_path.__name__, run_module.__name__, run_path.__module__, and internal _run_code existence."
    - "run_path.__module__ == 'runpy' confirms the function is defined in the runpy package."
    - "runpy._run_code is an internal helper that exists in CPython 3.9+ (not public API, but stable)."
    - "runpy has exactly two public functions: run_module and run_path."
    - "run_path.__qualname__ == 'run_path' — top-level function, qualname equals name."
    - "run_module.__qualname__ == 'run_module' — top-level function, qualname equals name."
    - "These invariants extend runpy.zspec.zsdl and runpy_extra.zspec.zsdl without repeating their checks."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# run_path — __name__ and __module__
# ---------------------------------------------------------------------------

invariant runpy_extra2.run_path.name:
  description: "runpy.run_path.__name__ == 'run_path'"
  category: functions
  kind: python_call_eq
  function: run_path.__name__.__eq__
  args: ["run_path"]
  expected: true

invariant runpy_extra2.run_path.module:
  description: "runpy.run_path.__module__ == 'runpy'"
  category: functions
  kind: python_call_eq
  function: run_path.__module__.__eq__
  args: ["runpy"]
  expected: true

# ---------------------------------------------------------------------------
# run_module — __name__ and __module__
# ---------------------------------------------------------------------------

invariant runpy_extra2.run_module.name:
  description: "runpy.run_module.__name__ == 'run_module'"
  category: functions
  kind: python_call_eq
  function: run_module.__name__.__eq__
  args: ["run_module"]
  expected: true

invariant runpy_extra2.run_module.module:
  description: "runpy.run_module.__module__ == 'runpy'"
  category: functions
  kind: python_call_eq
  function: run_module.__module__.__eq__
  args: ["runpy"]
  expected: true

# ---------------------------------------------------------------------------
# Qualified name checks — top-level functions have qualname == name
# ---------------------------------------------------------------------------

invariant runpy_extra2.run_path.qualname:
  description: "runpy.run_path.__qualname__ == 'run_path' — not nested, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: run_path.__qualname__.__eq__
  args: ["run_path"]
  expected: true

invariant runpy_extra2.run_module.qualname:
  description: "runpy.run_module.__qualname__ == 'run_module' — not nested, qualname equals name"
  category: qualnames
  kind: python_call_eq
  function: run_module.__qualname__.__eq__
  args: ["run_module"]
  expected: true

# ---------------------------------------------------------------------------
# Internal _run_code — exists as a callable in the runpy module
# (CPython 3.9+ internal helper; not public API but stable across versions)
# ---------------------------------------------------------------------------

invariant runpy_extra2.internals._run_code_exists:
  description: "_run_code.__class__.__name__ == 'function' — runpy._run_code is a callable function"
  category: internals
  kind: python_call_eq
  function: _run_code.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant runpy_extra2.internals._run_code_name:
  description: "runpy._run_code.__name__ == '_run_code'"
  category: internals
  kind: python_call_eq
  function: _run_code.__name__.__eq__
  args: ["_run_code"]
  expected: true

invariant runpy_extra2.internals._run_code_module:
  description: "runpy._run_code.__module__ == 'runpy'"
  category: internals
  kind: python_call_eq
  function: _run_code.__module__.__eq__
  args: ["runpy"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level type checks — run_path and run_module are Python functions
# ---------------------------------------------------------------------------

invariant runpy_extra2.types.run_path_is_function:
  description: "runpy.run_path.__class__.__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: run_path.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant runpy_extra2.types.run_module_is_function:
  description: "runpy.run_module.__class__.__name__ == 'function'"
  category: types
  kind: python_call_eq
  function: run_module.__class__.__name__.__eq__
  args: ["function"]
  expected: true
