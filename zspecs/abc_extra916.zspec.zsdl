spec: abc_extra916
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module ABC, ABCMeta, abstractmethod documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.ABC, abc.ABCMeta, abc.abstractmethod doc class names, method qualnames, and module loader class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra916.doc_class_names:
  description: "abc.ABC, abc.ABCMeta, abc.abstractmethod __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: doc_class_names
  id_prefix: ab916dc
  columns: [id, function, args, expected]
  rows:
    - [ab916dc001, abc.ABCMeta.__doc__.__class__.__name__.__eq__,            ["str"],     true]
    - [ab916dc002, abc.abstractmethod.__doc__.__class__.__name__.__eq__,     ["str"],     true]
    - [ab916dc003, abc.ABC.__doc__.__class__.__name__.__eq__,                ["str"],     true]
    - [ab916dc004, abc.ABCMeta.__doc__.__class__.__name__.__len__.__eq__,    [3],         true]
    - [ab916dc005, abc.abstractmethod.__doc__.__class__.__name__.__len__.__eq__, [3],     true]
    - [ab916dc006, abc.ABC.__doc__.__class__.__name__.__len__.__eq__,        [3],         true]
    - [ab916dc007, abc.ABCMeta.__doc__.__class__.__qualname__.__eq__,        ["str"],     true]

table abc_extra916.abcmeta_method_qualnames:
  description: "abc.ABCMeta method __qualname__ identity"
  kind: python_call_eq
  category: abcmeta_method_qualnames
  id_prefix: ab916mq
  columns: [id, function, args, expected]
  rows:
    - [ab916mq001, abc.ABCMeta.__init__.__qualname__.__eq__,                 ["ABCMeta.__init__"],          true]
    - [ab916mq002, abc.ABCMeta.__subclasshook__.__qualname__.__eq__,         ["ABCMeta.__subclasshook__"],  true]
    - [ab916mq003, abc.ABCMeta.register.__qualname__.__eq__,                 ["ABCMeta.register"],          true]
    - [ab916mq004, abc.ABCMeta.__instancecheck__.__qualname__.__eq__,        ["ABCMeta.__instancecheck__"], true]
    - [ab916mq005, abc.ABCMeta.__subclasscheck__.__qualname__.__eq__,        ["ABCMeta.__subclasscheck__"], true]
    - [ab916mq006, abc.ABCMeta.__init__.__qualname__.__class__.__name__.__eq__, ["str"],                    true]
    - [ab916mq007, abc.ABCMeta.__subclasshook__.__qualname__.__class__.__name__.__eq__, ["str"],            true]

table abc_extra916.module_loader_identity:
  description: "abc module __loader__ class identity and name"
  kind: python_call_eq
  category: module_loader_identity
  id_prefix: ab916ml
  columns: [id, function, args, expected]
  rows:
    - [ab916ml001, abc.__loader__.__class__.__name__.__eq__,                 ["SourceFileLoader"],          true]
    - [ab916ml002, abc.__loader__.__class__.__qualname__.__eq__,             ["SourceFileLoader"],          true]
    - [ab916ml003, abc.__loader__.__class__.__module__.__eq__,               ["importlib._bootstrap_external"], true]
    - [ab916ml004, abc.__spec__.__class__.__name__.__eq__,                   ["ModuleSpec"],                 true]
    - [ab916ml005, abc.__spec__.__class__.__qualname__.__eq__,               ["ModuleSpec"],                 true]
    - [ab916ml006, abc.__name__.__eq__,                                      ["abc"],                        true]
    - [ab916ml007, abc.__package__.__eq__,                                   ["abc"],                        true]
