spec: theseus_statistics
version: ">=3.9"
backend: python_cleanroom(theseus_statistics)
blocks: statistics

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html"
  notes:
    - "Clean-room statistics functions. Do NOT import statistics, numpy, or scipy."
    - "mean(data): arithmetic mean; mean([1,2,3,4,5]) == 3.0."
    - "median(data): middle value; median([1,2,3,4,5]) == 3."
    - "stdev(data): sample standard deviation; stdev([2,4,4,4,5,5,7,9]) == 2.0."
    - "Export: mean(data) -> float, median(data), stdev(data) -> float."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_statistics.mean:
  description: "mean([1,2,3,4,5]) == 3.0"
  category: mean
  kind: python_call_eq
  function: stats_mean
  args: []
  expected: 3.0

invariant theseus_statistics.median:
  description: "median([1,2,3,4,5]) == 3"
  category: median
  kind: python_call_eq
  function: stats_median
  args: []
  expected: 3

invariant theseus_statistics.stdev:
  description: "stdev([2,4,4,4,5,5,7,9]) == 2.0"
  category: stdev
  kind: python_call_eq
  function: stats_stdev
  args: []
  expected: 2.0
