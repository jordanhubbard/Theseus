spec: io_extra2131
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase class metadata"
    - "_io_extra.zspec.zsdl — covers _io C-module class names and modules"
  notes:
    - "Wave 2131, theme: exception protocol dict-presence."
    - "Checks whether __cause__, __context__, __traceback__, __suppress_context__, __notes__, args, and with_traceback appear in the __dict__ of io classes."
    - "__cause__, __context__, __traceback__, __suppress_context__ are instance attributes set by CPython exception machinery — they are NOT in any class __dict__."
    - "args is an instance attribute of BaseException instances — not in any class __dict__."
    - "with_traceback is a BaseException method defined on the C type; it does NOT appear in the __dict__ of io classes or io.UnsupportedOperation."
    - "__notes__ was introduced in Python 3.11 (PEP 678); it is an instance attribute, not a class-level attr."
    - "io.UnsupportedOperation is an exception subclassing OSError and ValueError; its __dict__ contains only __module__, __weakref__, and __doc__."
    - "io.IOBase, RawIOBase, BufferedIOBase, TextIOBase are abstract base classes for I/O streams; none are exceptions."
    - "io.StringIO, BytesIO, FileIO are concrete I/O classes; none define any exception protocol attrs."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __cause__ dict-presence — io types
# __cause__ is set by 'raise X from Y'; it lives on instances, not classes.
# ---------------------------------------------------------------------------

table io_extra2131.cause_protocol:
  description: "io type __dict__.__contains__('__cause__') — all False (instance attribute, not class-level)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2131

  columns: [id, function, args, expected]
  rows:
    - ["io2131001", "io.IOBase.__dict__.__contains__",             ["__cause__"], false]
    - ["io2131002", "io.RawIOBase.__dict__.__contains__",          ["__cause__"], false]
    - ["io2131003", "io.BufferedIOBase.__dict__.__contains__",     ["__cause__"], false]
    - ["io2131004", "io.TextIOBase.__dict__.__contains__",         ["__cause__"], false]
    - ["io2131005", "io.StringIO.__dict__.__contains__",           ["__cause__"], false]
    - ["io2131006", "io.BytesIO.__dict__.__contains__",            ["__cause__"], false]
    - ["io2131007", "io.FileIO.__dict__.__contains__",             ["__cause__"], false]
    - ["io2131008", "io.UnsupportedOperation.__dict__.__contains__", ["__cause__"], false]

# ---------------------------------------------------------------------------
# __context__ dict-presence — io types
# __context__ is the implicit exception context; lives on instances, not classes.
# ---------------------------------------------------------------------------

table io_extra2131.context_protocol:
  description: "io type __dict__.__contains__('__context__') — all False (instance attribute)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2131

  columns: [id, function, args, expected]
  rows:
    - ["io2131009", "io.IOBase.__dict__.__contains__",             ["__context__"], false]
    - ["io2131010", "io.RawIOBase.__dict__.__contains__",          ["__context__"], false]
    - ["io2131011", "io.BufferedIOBase.__dict__.__contains__",     ["__context__"], false]
    - ["io2131012", "io.TextIOBase.__dict__.__contains__",         ["__context__"], false]
    - ["io2131013", "io.StringIO.__dict__.__contains__",           ["__context__"], false]
    - ["io2131014", "io.BytesIO.__dict__.__contains__",            ["__context__"], false]
    - ["io2131015", "io.FileIO.__dict__.__contains__",             ["__context__"], false]
    - ["io2131016", "io.UnsupportedOperation.__dict__.__contains__", ["__context__"], false]

# ---------------------------------------------------------------------------
# __traceback__ dict-presence — io types
# __traceback__ is the traceback object attached to exception instances.
# ---------------------------------------------------------------------------

table io_extra2131.traceback_protocol:
  description: "io type __dict__.__contains__('__traceback__') — all False (instance attribute)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2131

  columns: [id, function, args, expected]
  rows:
    - ["io2131017", "io.IOBase.__dict__.__contains__",               ["__traceback__"], false]
    - ["io2131018", "io.RawIOBase.__dict__.__contains__",            ["__traceback__"], false]
    - ["io2131019", "io.UnsupportedOperation.__dict__.__contains__", ["__traceback__"], false]

# ---------------------------------------------------------------------------
# __suppress_context__ dict-presence — io types
