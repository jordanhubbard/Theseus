    - ["io2131022", "io.TextIOBase.__dict__.__contains__",           ["__suppress_context__"], false]
    - ["io2131023", "io.StringIO.__dict__.__contains__",             ["__suppress_context__"], false]
    - ["io2131024", "io.BytesIO.__dict__.__contains__",              ["__suppress_context__"], false]
    - ["io2131025", "io.UnsupportedOperation.__dict__.__contains__", ["__suppress_context__"], false]

# ---------------------------------------------------------------------------
# __notes__ dict-presence — io types
# __notes__ (PEP 678, Python 3.11+) is an instance attribute; not class-level.
# ---------------------------------------------------------------------------

table io_extra2131.notes_protocol:
  description: "io type __dict__.__contains__('__notes__') — all False (instance attribute, PEP 678)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2131

  columns: [id, function, args, expected]
  rows:
    - ["io2131026", "io.IOBase.__dict__.__contains__",               ["__notes__"], false]
    - ["io2131027", "io.UnsupportedOperation.__dict__.__contains__", ["__notes__"], false]
    - ["io2131028", "io.FileIO.__dict__.__contains__",               ["__notes__"], false]

# ---------------------------------------------------------------------------
# args dict-presence — io types
# args is a BaseException instance attribute (set in __init__); not class-level.
# ---------------------------------------------------------------------------

table io_extra2131.args_protocol:
  description: "io type __dict__.__contains__('args') — all False (instance attribute of BaseException)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2131

  columns: [id, function, args, expected]
  rows:
    - ["io2131029", "io.IOBase.__dict__.__contains__",               ["args"], false]
    - ["io2131030", "io.RawIOBase.__dict__.__contains__",            ["args"], false]
    - ["io2131031", "io.BufferedIOBase.__dict__.__contains__",       ["args"], false]
    - ["io2131032", "io.TextIOBase.__dict__.__contains__",           ["args"], false]
    - ["io2131033", "io.StringIO.__dict__.__contains__",             ["args"], false]
    - ["io2131034", "io.BytesIO.__dict__.__contains__",              ["args"], false]
    - ["io2131035", "io.FileIO.__dict__.__contains__",               ["args"], false]
    - ["io2131036", "io.UnsupportedOperation.__dict__.__contains__", ["args"], false]

# ---------------------------------------------------------------------------
# with_traceback dict-presence — io types
# with_traceback is a method of BaseException defined in the C implementation.
# It does NOT appear in subclass __dict__ entries; only BaseException owns it.
# ---------------------------------------------------------------------------

table io_extra2131.with_traceback_protocol:
  description: "io type __dict__.__contains__('with_traceback') — all False (owned by BaseException C type)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2131

  columns: [id, function, args, expected]
  rows:
    - ["io2131037", "io.IOBase.__dict__.__contains__",               ["with_traceback"], false]
    - ["io2131038", "io.StringIO.__dict__.__contains__",             ["with_traceback"], false]
    - ["io2131039", "io.BytesIO.__dict__.__contains__",              ["with_traceback"], false]
    - ["io2131040", "io.UnsupportedOperation.__dict__.__contains__", ["with_traceback"], false]
