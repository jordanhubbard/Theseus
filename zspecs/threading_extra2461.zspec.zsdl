spec: threading_extra2461
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Theme: __len__ and __length_hint__ dict-presence — checking whether threading classes define the length protocol in their class __dict__."
    - "threading.WeakSet.__dict__.__contains__('__len__') == True — WeakSet (imported from weakref) is a set-like container tracking objects via weak references; it defines __len__ to return the number of live (unreferenced) members. Verified with Python 3.14.3."
    - "threading.WeakSet.__dict__.__contains__('__length_hint__') == False — WeakSet is not an iterator and does not define __length_hint__. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('__len__') == False — Thread is a synchronization object representing an OS thread; it is not a container. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('__length_hint__') == False — Thread is not an iterator. Verified with Python 3.14.3."
    - "threading.Barrier.__dict__.__contains__('__len__') == False — Barrier coordinates a fixed number of threads but does not define __len__ despite knowing the party count. Verified with Python 3.14.3."
    - "threading.Semaphore.__dict__.__contains__('__len__') == False — Semaphore is a counting synchronization primitive; it does not define __len__ in its class dict. Verified with Python 3.14.3."
    - "threading.Condition.__dict__.__contains__('__len__') == False — Condition provides wait/notify; it is not a container. Verified with Python 3.14.3."
    - "threading.Event.__dict__.__contains__('__len__') == False — Event is a simple flag; it is not a container. Verified with Python 3.14.3."
    - "threading.Lock.__dict__.__contains__('__len__') == False — Lock is a mutual exclusion primitive; not a container. Verified with Python 3.14.3."
    - "threading.Timer.__dict__.__contains__('__len__') == False — Timer is a Thread subclass; not a container. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __len__ dict-presence for threading classes
#
# Theme: which threading classes define __len__ in their class __dict__?
#
# threading.Thread.__dict__.__contains__('__len__') == False
# threading.Lock.__dict__.__contains__('__len__') == False
# threading.Event.__dict__.__contains__('__len__') == False
# threading.Condition.__dict__.__contains__('__len__') == False
# threading.Semaphore.__dict__.__contains__('__len__') == False
# threading.BoundedSemaphore.__dict__.__contains__('__len__') == False
# threading.Barrier.__dict__.__contains__('__len__') == False
# threading.Timer.__dict__.__contains__('__len__') == False
# threading.local.__dict__.__contains__('__len__') == False
# threading.WeakSet.__dict__.__contains__('__len__') == True
#
# Synchronization primitives (Thread, Lock, Event, Condition, Semaphore,
# Barrier, Timer, local) are not containers and define no __len__.
# WeakSet is the exception: it is a set-like container and defines __len__.
# ---------------------------------------------------------------------------

table threading_extra2461.len_dict_presence:
  description: "__len__ in class __dict__ for threading types; only WeakSet defines it"
  kind: python_call_eq
  category: identity
  id_prefix: th2461

  columns: [id, function, args, expected]
  rows:
    - ["th2461001", Thread.__dict__.__contains__, ["__len__"], false]
    - ["th2461002", Lock.__dict__.__contains__, ["__len__"], false]
    - ["th2461003", Event.__dict__.__contains__, ["__len__"], false]
    - ["th2461004", Condition.__dict__.__contains__, ["__len__"], false]
    - ["th2461005", Semaphore.__dict__.__contains__, ["__len__"], false]
    - ["th2461006", BoundedSemaphore.__dict__.__contains__, ["__len__"], false]
    - ["th2461007", Barrier.__dict__.__contains__, ["__len__"], false]
    - ["th2461008", Timer.__dict__.__contains__, ["__len__"], false]
    - ["th2461009", local.__dict__.__contains__, ["__len__"], false]
    - ["th2461010", WeakSet.__dict__.__contains__, ["__len__"], true]

# ---------------------------------------------------------------------------
# Table 2: __length_hint__ dict-presence for threading classes
#
# Theme: which threading classes define __length_hint__ in their class __dict__?
#
# threading.Thread.__dict__.__contains__('__length_hint__') == False
# threading.Lock.__dict__.__contains__('__length_hint__') == False
# threading.Event.__dict__.__contains__('__length_hint__') == False
# threading.Condition.__dict__.__contains__('__length_hint__') == False
# threading.Semaphore.__dict__.__contains__('__length_hint__') == False
# threading.BoundedSemaphore.__dict__.__contains__('__length_hint__') == False
# threading.Barrier.__dict__.__contains__('__length_hint__') == False
# threading.Timer.__dict__.__contains__('__length_hint__') == False
# threading.local.__dict__.__contains__('__length_hint__') == False
# threading.WeakSet.__dict__.__contains__('__length_hint__') == False
#
# No threading class defines __length_hint__. Synchronization primitives
# are not iterators and have no need to estimate remaining iteration items.
# WeakSet, while a sized container, does not define __length_hint__ either.
# ---------------------------------------------------------------------------

table threading_extra2461.length_hint_dict_presence:
  description: "__length_hint__ in class __dict__ for threading types; none define it"
  kind: python_call_eq
  category: identity
  id_prefix: th2461

  columns: [id, function, args, expected]
  rows:
    - ["th2461011", Thread.__dict__.__contains__, ["__length_hint__"], false]
    - ["th2461012", Lock.__dict__.__contains__, ["__length_hint__"], false]
    - ["th2461013", Event.__dict__.__contains__, ["__length_hint__"], false]
    - ["th2461014", Condition.__dict__.__contains__, ["__length_hint__"], false]
    - ["th2461015", Semaphore.__dict__.__contains__, ["__length_hint__"], false]
    - ["th2461016", BoundedSemaphore.__dict__.__contains__, ["__length_hint__"], false]
    - ["th2461017", Barrier.__dict__.__contains__, ["__length_hint__"], false]
    - ["th2461018", Timer.__dict__.__contains__, ["__length_hint__"], false]
    - ["th2461019", local.__dict__.__contains__, ["__length_hint__"], false]
    - ["th2461020", WeakSet.__dict__.__contains__, ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# Table 3: WeakSet defines __len__ but synchronization primitives do not;
# cross-checks with domain attributes
#
# threading.WeakSet.__dict__.__contains__('__len__') == True
# threading.WeakSet.__dict__.__contains__('__length_hint__') == False
# threading.WeakSet.__dict__.__contains__('__iter__') == True
# threading.WeakSet.__dict__.__contains__('add') == True
# threading.Barrier.__dict__.__contains__('parties') == True
# threading.Barrier.__dict__.__contains__('__len__') == False
# threading.Semaphore.__dict__.__contains__('acquire') == True
# threading.Semaphore.__dict__.__contains__('__len__') == False
#
# WeakSet behaves as a sized iterable container (True for __len__, __iter__,
# add, discard), while synchronization classes like Barrier and Semaphore
# define domain attributes (parties, acquire) but no length protocol.
# ---------------------------------------------------------------------------

table threading_extra2461.weakset_vs_sync_primitives:
  description: "WeakSet has __len__ and __iter__; Barrier and Semaphore have domain attrs but not __len__"
  kind: python_call_eq
  category: identity
  id_prefix: th2461

  columns: [id, function, args, expected]
  rows:
    - ["th2461021", WeakSet.__dict__.__contains__, ["__len__"], true]
    - ["th2461022", WeakSet.__dict__.__contains__, ["__length_hint__"], false]
    - ["th2461023", WeakSet.__dict__.__contains__, ["__iter__"], true]
    - ["th2461024", WeakSet.__dict__.__contains__, ["add"], true]
    - ["th2461025", Barrier.__dict__.__contains__, ["parties"], true]
    - ["th2461026", Barrier.__dict__.__contains__, ["__len__"], false]
    - ["th2461027", Semaphore.__dict__.__contains__, ["acquire"], true]
    - ["th2461028", Semaphore.__dict__.__contains__, ["__len__"], false]
