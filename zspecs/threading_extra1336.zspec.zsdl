spec: threading_extra1336
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "Wave 536 (_extra1336): focuses on __hash__ and __eq__ method class checks for threading classes."
    - "threading.Thread.__hash__.__class__.__name__ == 'wrapper_descriptor' — Thread inherits __hash__ from object; no override defined."
    - "threading.Thread.__hash__.__qualname__ == 'object.__hash__' — directly from object."
    - "threading.Thread.__eq__.__class__.__name__ == 'wrapper_descriptor' — Thread does not define __eq__; inherits from object."
    - "threading.Lock.__hash__.__class__.__name__ == 'wrapper_descriptor' — Lock is a C type that inherits __hash__ from object."
    - "threading.Event.__hash__.__class__.__name__ == 'wrapper_descriptor' — Event is a pure Python class inheriting __hash__ from object."
    - "threading.Condition.__hash__.__class__.__name__ == 'wrapper_descriptor' — Condition inherits __hash__ from object."
    - "threading.Semaphore.__hash__.__class__.__name__ == 'wrapper_descriptor' — Semaphore inherits __hash__ from object."
    - "threading.Barrier.__hash__.__class__.__name__ == 'wrapper_descriptor' — Barrier inherits __hash__ from object."
    - "threading.Timer.__hash__.__class__.__name__ == 'wrapper_descriptor' — Timer (subclass of Thread) inherits __hash__ from object."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra1336.thread_lock_hash_eq_checks:
  description: "threading.Thread and Lock __hash__ and __eq__ class name and qualname; both inherit from object as wrapper_descriptors"
  kind: python_call_eq
  category: hash_eq_class_checks
  id_prefix: th1336tl
  columns: [id, function, args, expected]
  rows:
    - [th1336tl001, threading.Thread.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"],  true]
    - [th1336tl002, threading.Thread.__hash__.__qualname__.__eq__,       ["object.__hash__"],     true]
    - [th1336tl003, threading.Thread.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"],  true]
    - [th1336tl004, threading.Thread.__eq__.__qualname__.__eq__,         ["object.__eq__"],       true]
    - [th1336tl005, threading.Lock.__hash__.__class__.__name__.__eq__,   ["wrapper_descriptor"],  true]
    - [th1336tl006, threading.Lock.__hash__.__qualname__.__eq__,         ["object.__hash__"],     true]
    - [th1336tl007, threading.Lock.__eq__.__class__.__name__.__eq__,     ["wrapper_descriptor"],  true]
    - [th1336tl008, threading.Lock.__eq__.__qualname__.__eq__,           ["object.__eq__"],       true]

