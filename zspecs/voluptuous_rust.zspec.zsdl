spec: voluptuous_rust
version: ">=3.9"
backend: rust_module(voluptuous_rust)

docs: https://github.com/alecthomas/voluptuous

provenance:
  derived_from:
    - "https://github.com/alecthomas/voluptuous — voluptuous validation"
  notes:
    - "voluptuous provides schema-based data validation."
    - "voluptuous.Schema({'name': str})({'name': 'Alice'}) == {'name': 'Alice'}."
    - "voluptuous.Required is a marker class."
    - "voluptuous.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant voluptuous_rust.schema_passthrough:
  description: "Schema({'name': str})({'name': 'Alice'}) == {'name': 'Alice'}"
  category: schema
  kind: python_call_eq
  function: voluptuous_schema_passthrough
  args: []
  expected: true

invariant voluptuous_rust.has_required:
  description: "voluptuous.Required is a class"
  category: presence
  kind: python_call_eq
  function: voluptuous_has_required
  args: []
  expected: true

invariant voluptuous_rust.version_nonempty:
  description: "voluptuous.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: voluptuous_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:42:14Z
  iterations: 2
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 2 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
