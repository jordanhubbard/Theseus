spec: statistics_extra23
version: ">=3.9"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics_extra through statistics_extra22."
    - "statistics_extra22 covers NormalDist property fget qualnames and StatisticsError base/module."
    - "No prior spec covers __qualname__ for module-level functions mean, median, mode, stdev, variance, pstdev, pvariance."
    - "No prior spec covers __module__ for mean, median, or mode."
    - "No prior spec covers NormalDist.__bases__[0].__name__."
    - "No prior spec covers NormalDist.__init__.__qualname__."
    - "No prior spec covers NormalDist.pdf.__qualname__ or NormalDist.cdf.__qualname__."
    - "Module-level statistical functions have __qualname__ equal to their simple name (no enclosing class)."
    - "NormalDist.__bases__[0].__name__ == 'object' — NormalDist does not subclass any numeric ABC."
    - "NormalDist.__init__ is defined directly on NormalDist; its __qualname__ == 'NormalDist.__init__'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level function __qualname__ values
#
# No prior spec records __qualname__ for mean, median, mode, stdev,
# variance, pstdev, or pvariance.  All are module-level functions; their
# __qualname__ equals the simple function name.
# ---------------------------------------------------------------------------

table statistics_extra23.function_qualnames:
  kind: python_call_eq
  category: function_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [mean,      mean.__qualname__.__eq__,      ["mean"],      true, "statistics.mean.__qualname__ == 'mean'"]
    - [median,    median.__qualname__.__eq__,    ["median"],    true, "statistics.median.__qualname__ == 'median'"]
    - [mode,      mode.__qualname__.__eq__,      ["mode"],      true, "statistics.mode.__qualname__ == 'mode'"]
    - [stdev,     stdev.__qualname__.__eq__,     ["stdev"],     true, "statistics.stdev.__qualname__ == 'stdev'"]
    - [variance,  variance.__qualname__.__eq__,  ["variance"],  true, "statistics.variance.__qualname__ == 'variance'"]
    - [pstdev,    pstdev.__qualname__.__eq__,    ["pstdev"],    true, "statistics.pstdev.__qualname__ == 'pstdev'"]
    - [pvariance, pvariance.__qualname__.__eq__, ["pvariance"], true, "statistics.pvariance.__qualname__ == 'pvariance'"]

# ---------------------------------------------------------------------------
# Module-level function __qualname__ length invariants
# ---------------------------------------------------------------------------

invariant statistics_extra23.mean.qualname_len:
  description: "len(statistics.mean.__qualname__) == 4 — 'mean' is 4 chars"
  category: function_identity
  kind: python_call_eq
  function: mean.__qualname__.__len__
  args: []
  expected: 4

invariant statistics_extra23.median.qualname_len:
  description: "len(statistics.median.__qualname__) == 6 — 'median' is 6 chars"
  category: function_identity
  kind: python_call_eq
  function: median.__qualname__.__len__
  args: []
  expected: 6

invariant statistics_extra23.stdev.qualname_len:
  description: "len(statistics.stdev.__qualname__) == 5 — 'stdev' is 5 chars"
  category: function_identity
  kind: python_call_eq
  function: stdev.__qualname__.__len__
  args: []
  expected: 5

invariant statistics_extra23.variance.qualname_len:
  description: "len(statistics.variance.__qualname__) == 8 — 'variance' is 8 chars"
  category: function_identity
  kind: python_call_eq
  function: variance.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Module-level function __module__ values
#
# No prior spec records __module__ for mean, median, or mode.
# All module-level statistical functions have __module__ == 'statistics'.
# ---------------------------------------------------------------------------

table statistics_extra23.function_modules:
  kind: python_call_eq
  category: function_identity
  id_prefix: module

  columns: [id, function, args, expected, description]
  rows:
    - [mean,   mean.__module__.__eq__,   ["statistics"], true, "statistics.mean.__module__ == 'statistics'"]
    - [median, median.__module__.__eq__, ["statistics"], true, "statistics.median.__module__ == 'statistics'"]
    - [mode,   mode.__module__.__eq__,   ["statistics"], true, "statistics.mode.__module__ == 'statistics'"]

# ---------------------------------------------------------------------------
# NormalDist base class name
#
# No prior spec records NormalDist.__bases__[0].__name__.
# NormalDist inherits directly from object.
# ---------------------------------------------------------------------------

invariant statistics_extra23.NormalDist.base_name:
  description: "statistics.NormalDist.__bases__[0].__name__ == 'object' — NormalDist inherits directly from object"
  category: class_identity
  kind: python_call_eq
  function: "NormalDist.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# NormalDist.__init__.__qualname__
#
# No prior spec records NormalDist.__init__.__qualname__.
# NormalDist defines its own __init__; qualname == 'NormalDist.__init__'.
# ---------------------------------------------------------------------------

invariant statistics_extra23.NormalDist.init_qualname:
  description: "statistics.NormalDist.__init__.__qualname__ == 'NormalDist.__init__'"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.__init__.__qualname__.__eq__
  args: ["NormalDist.__init__"]
  expected: true

invariant statistics_extra23.NormalDist.init_qualname_len:
  description: "len(statistics.NormalDist.__init__.__qualname__) == 19 — 'NormalDist.__init__' is 19 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.__init__.__qualname__.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# NormalDist.pdf and NormalDist.cdf __qualname__ values
#
# No prior spec records __qualname__ for pdf or cdf.
# Both are defined directly on NormalDist.
# ---------------------------------------------------------------------------

table statistics_extra23.normaldist_pdf_cdf_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [pdf, NormalDist.pdf.__qualname__.__eq__, ["NormalDist.pdf"], true, "NormalDist.pdf.__qualname__ == 'NormalDist.pdf'"]
    - [cdf, NormalDist.cdf.__qualname__.__eq__, ["NormalDist.cdf"], true, "NormalDist.cdf.__qualname__ == 'NormalDist.cdf'"]

# ---------------------------------------------------------------------------
# NormalDist.pdf and NormalDist.cdf __qualname__ length invariants
# ---------------------------------------------------------------------------

invariant statistics_extra23.NormalDist.pdf_qualname_len:
  description: "len(statistics.NormalDist.pdf.__qualname__) == 14 — 'NormalDist.pdf' is 14 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.pdf.__qualname__.__len__
  args: []
  expected: 14

invariant statistics_extra23.NormalDist.cdf_qualname_len:
  description: "len(statistics.NormalDist.cdf.__qualname__) == 14 — 'NormalDist.cdf' is 14 chars"
  category: method_identity
  kind: python_call_eq
  function: NormalDist.cdf.__qualname__.__len__
  args: []
  expected: 14
