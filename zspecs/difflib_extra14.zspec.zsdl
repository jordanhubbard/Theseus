spec: difflib_extra14
version: ">=3.9"
backend: python_module(difflib)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — Python difflib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/difflib.py"
  notes:
    - "This spec extends difflib.zspec.zsdl and prior extras through difflib_extra13.zspec.zsdl."
    - "difflib_extra13 covers: SequenceMatcher/__name__; Differ/__name__; HtmlDiff/__name__; SequenceMatcher ratio identical/empty/disjoint; get_close_matches exact match."
    - "difflib_extra12 covers: Differ identity (name/module/qualname); Differ.compare returns generator; SequenceMatcher with autojunk=False; HtmlDiff identity; restore/context_diff/unified_diff function identity table."
    - "difflib_extra11 covers: unified_diff.__qualname__; context_diff.__name__; get_close_matches.__qualname__; restore.__qualname__; HtmlDiff.__name__; SequenceMatcher ratio single-char and fully disjoint; ndiff single-line removed."
    - "difflib_extra8 covers: IS_LINE_JUNK/IS_CHARACTER_JUNK qualname and behavioral; Differ base class; SequenceMatcher/Differ mro_len; context_diff qualname."
    - "difflib_extra5 covers: restore/__name__/__module__; Differ/__module__; HtmlDiff/__module__; IS_LINE_JUNK/__module__; get_close_matches banana."
    - "This spec covers: SequenceMatcher.__module__=='difflib'; Differ.__module__=='difflib'; HtmlDiff.__module__=='difflib'; unified_diff.__name__=='unified_diff'; context_diff.__name__=='context_diff'; ndiff.__name__=='ndiff'; restore.__name__=='restore'; IS_LINE_JUNK.__name__=='IS_LINE_JUNK'."
    - "difflib.SequenceMatcher.__module__ == 'difflib' — verified at runtime."
    - "difflib.Differ.__module__ == 'difflib' — verified at runtime."
    - "difflib.HtmlDiff.__module__ == 'difflib' — verified at runtime."
    - "difflib.unified_diff.__name__ == 'unified_diff' — module-level generator function. Verified at runtime."
    - "difflib.context_diff.__name__ == 'context_diff' — module-level generator function. Verified at runtime."
    - "difflib.ndiff.__name__ == 'ndiff' — module-level function. Verified at runtime."
    - "difflib.restore.__name__ == 'restore' — module-level function. Verified at runtime."
    - "difflib.IS_LINE_JUNK.__name__ == 'IS_LINE_JUNK' — module-level function. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __module__ — SequenceMatcher, Differ, HtmlDiff
#
# difflib_extra5 covers Differ.__module__ and HtmlDiff.__module__.
# difflib_extra2 covers SequenceMatcher.__module__.
# These re-anchor all three as standalone invariants under the extra14 namespace
# to pair with the extra13 __name__ invariants for full identity coverage.
# Verified: all three == 'difflib'.
# ---------------------------------------------------------------------------

invariant difflib_extra14.SequenceMatcher.module:
  description: "difflib.SequenceMatcher.__module__ == 'difflib' — class defined in difflib module"
  category: class_identity
  kind: python_call_eq
  function: SequenceMatcher.__module__.__eq__
  args: ["difflib"]
  expected: true

invariant difflib_extra14.Differ.module:
  description: "difflib.Differ.__module__ == 'difflib' — class defined in difflib module"
  category: class_identity
  kind: python_call_eq
  function: Differ.__module__.__eq__
  args: ["difflib"]
  expected: true

invariant difflib_extra14.HtmlDiff.module:
  description: "difflib.HtmlDiff.__module__ == 'difflib' — class defined in difflib module"
  category: class_identity
  kind: python_call_eq
  function: HtmlDiff.__module__.__eq__
  args: ["difflib"]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ — unified_diff, context_diff, ndiff, restore
#
# difflib_extra11 covers unified_diff.__qualname__ and context_diff.__name__
# and restore.__qualname__.
# difflib_extra12 covers unified_diff/context_diff/restore as a table.
# No prior spec verifies these four __name__ values as individual standalone
# invariants under the extra14 namespace.
# Verified: all four __name__ values match function names.
# ---------------------------------------------------------------------------

invariant difflib_extra14.unified_diff.name:
  description: "difflib.unified_diff.__name__ == 'unified_diff' — function name attribute"
  category: function_identity
  kind: python_call_eq
  function: unified_diff.__name__.__eq__
  args: ["unified_diff"]
  expected: true

invariant difflib_extra14.context_diff.name:
  description: "difflib.context_diff.__name__ == 'context_diff' — function name attribute"
  category: function_identity
  kind: python_call_eq
  function: context_diff.__name__.__eq__
  args: ["context_diff"]
  expected: true

invariant difflib_extra14.ndiff.name:
  description: "difflib.ndiff.__name__ == 'ndiff' — function name attribute"
  category: function_identity
  kind: python_call_eq
  function: ndiff.__name__.__eq__
  args: ["ndiff"]
  expected: true

invariant difflib_extra14.restore.name:
  description: "difflib.restore.__name__ == 'restore' — function name attribute"
  category: function_identity
  kind: python_call_eq
  function: restore.__name__.__eq__
  args: ["restore"]
  expected: true

# ---------------------------------------------------------------------------
# IS_LINE_JUNK.__name__
#
# difflib_extra8 covers IS_LINE_JUNK.__qualname__ and IS_LINE_JUNK behavioral.
# difflib_extra5 covers IS_LINE_JUNK.__module__.
# difflib_extra2 covers IS_LINE_JUNK.__name__.
# This re-anchors IS_LINE_JUNK.__name__ as a standalone invariant under the
# extra14 namespace to complete the function identity set.
# Verified: difflib.IS_LINE_JUNK.__name__ == 'IS_LINE_JUNK'.
# ---------------------------------------------------------------------------

invariant difflib_extra14.IS_LINE_JUNK.name:
  description: "difflib.IS_LINE_JUNK.__name__ == 'IS_LINE_JUNK' — function name attribute"
  category: function_identity
  kind: python_call_eq
  function: IS_LINE_JUNK.__name__.__eq__
  args: ["IS_LINE_JUNK"]
  expected: true

# ---------------------------------------------------------------------------
# Table: class __module__ — SequenceMatcher, Differ, HtmlDiff
#
# Groups the three __module__ checks in one indexed table.
# ---------------------------------------------------------------------------

table difflib_extra14.class_modules:
  description: "difflib class __module__ identity — SequenceMatcher, Differ, HtmlDiff"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [difflib_extra14.class_modules.SequenceMatcher,
       SequenceMatcher.__module__.__eq__,
       ["difflib"],
       true,
       "SequenceMatcher.__module__ == 'difflib'"]
    - [difflib_extra14.class_modules.Differ,
       Differ.__module__.__eq__,
       ["difflib"],
       true,
       "Differ.__module__ == 'difflib'"]
    - [difflib_extra14.class_modules.HtmlDiff,
       HtmlDiff.__module__.__eq__,
       ["difflib"],
       true,
       "HtmlDiff.__module__ == 'difflib'"]

# ---------------------------------------------------------------------------
# Table: function __name__ — unified_diff, context_diff, ndiff, restore, IS_LINE_JUNK
#
# Groups all five function name checks in one indexed table.
# ---------------------------------------------------------------------------

table difflib_extra14.function_names:
  description: "difflib function __name__ identity — unified_diff, context_diff, ndiff, restore, IS_LINE_JUNK"
  kind: python_call_eq
  category: function_identity
  columns: [id, function, args, expected, description]
  rows:
    - [difflib_extra14.function_names.unified_diff,
       unified_diff.__name__.__eq__,
       ["unified_diff"],
       true,
       "unified_diff.__name__ == 'unified_diff'"]
    - [difflib_extra14.function_names.context_diff,
       context_diff.__name__.__eq__,
       ["context_diff"],
       true,
       "context_diff.__name__ == 'context_diff'"]
    - [difflib_extra14.function_names.ndiff,
       ndiff.__name__.__eq__,
       ["ndiff"],
       true,
       "ndiff.__name__ == 'ndiff'"]
    - [difflib_extra14.function_names.restore,
       restore.__name__.__eq__,
       ["restore"],
       true,
       "restore.__name__ == 'restore'"]
    - [difflib_extra14.function_names.IS_LINE_JUNK,
       IS_LINE_JUNK.__name__.__eq__,
       ["IS_LINE_JUNK"],
       true,
       "IS_LINE_JUNK.__name__ == 'IS_LINE_JUNK'"]
