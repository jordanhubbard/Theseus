spec: abc_extra194
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc module __name__.__len__() and class/function __name__.__len__() and __module__.__len__() for ABC, ABCMeta, abstractmethod, get_cache_token."
    - "abc.__name__.__len__() == 3 — 'abc' has 3 characters. Verified with Python 3.14.3."
    - "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters. Verified with Python 3.14.3."
    - "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters. Verified with Python 3.14.3."
    - "abc.abstractmethod.__name__.__len__() == 14 — 'abstractmethod' has 14 characters. Verified with Python 3.14.3."
    - "abc.get_cache_token.__name__.__len__() == 15 — 'get_cache_token' has 15 characters. Verified with Python 3.14.3."
    - "abc.ABCMeta.__module__.__len__() == 3 — ABCMeta.__module__ is 'abc', which has 3 characters. Verified with Python 3.14.3."
    - "abc.ABC.__module__.__len__() == 3 — ABC.__module__ is 'abc', which has 3 characters. Verified with Python 3.14.3."
    - "abc.abstractmethod.__module__.__len__() == 3 — abstractmethod.__module__ is 'abc', which has 3 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: abc module name length and ABC / ABCMeta name lengths
#
# abc.__name__.__len__() == 3
# abc.ABC.__name__.__len__() == 3
# abc.ABCMeta.__name__.__len__() == 7
#
# abc is the abstract base class support module. 'abc' is 3 chars,
# 'ABC' is 3 chars, 'ABCMeta' is 7 chars. New to extra194.
# ---------------------------------------------------------------------------

table abc_extra194.module_and_meta_name_lens:
  description: "abc.__name__ len==3; ABC.__name__ len==3; ABCMeta.__name__ len==7; module and metaclass name lengths; new to extra194"
  kind: python_call_eq
  category: string_identity
  id_prefix: abcnamelens194

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_len_eq_3,
       "__name__.__len__",
       [],
       3,
       "abc.__name__.__len__() == 3 — 'abc' has 3 characters; int.__eq__(3) is True; new to extra194"]
    - [abc_class_name_len_eq_3,
       "ABC.__name__.__len__",
       [],
       3,
       "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters; int.__eq__(3) is True; new to extra194"]
    - [abcmeta_name_len_eq_7,
       "ABCMeta.__name__.__len__",
       [],
       7,
       "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters; int.__eq__(7) is True; new to extra194"]

# ---------------------------------------------------------------------------
# Table 2: abc.abstractmethod and get_cache_token name lengths
#
# abc.abstractmethod.__name__.__len__() == 14
# abc.get_cache_token.__name__.__len__() == 15
#
# abstractmethod is the decorator class; get_cache_token is a module-level
# function. New to extra194.
# ---------------------------------------------------------------------------

table abc_extra194.decorator_and_function_name_lens:
  description: "abc.abstractmethod len==14; get_cache_token len==15; decorator class and module function name lengths; new to extra194"
  kind: python_call_eq
  category: string_identity
  id_prefix: abcnamelens194

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod_name_len_eq_14,
       "abstractmethod.__name__.__len__",
       [],
       14,
       "abc.abstractmethod.__name__.__len__() == 14 — 'abstractmethod' has 14 characters; int.__eq__(14) is True; new to extra194"]
    - [get_cache_token_name_len_eq_15,
       "get_cache_token.__name__.__len__",
       [],
       15,
       "abc.get_cache_token.__name__.__len__() == 15 — 'get_cache_token' has 15 characters; int.__eq__(15) is True; new to extra194"]

# ---------------------------------------------------------------------------
# Table 3: abc class __module__ lengths
#
# abc.ABCMeta.__module__.__len__() == 3
# abc.ABC.__module__.__len__() == 3
# abc.abstractmethod.__module__.__len__() == 3
#
# ABCMeta, ABC, and abstractmethod are all defined in Lib/abc.py; their
# __module__ is 'abc' which has 3 characters. New to extra194.
# ---------------------------------------------------------------------------

table abc_extra194.module_attr_lens:
  description: "abc.ABCMeta, ABC, abstractmethod __module__.__len__()==3; all defined in 'abc' module; new to extra194"
  kind: python_call_eq
  category: string_identity
  id_prefix: abcnamelens194

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_module_len_eq_3,
       "ABCMeta.__module__.__len__",
       [],
       3,
       "abc.ABCMeta.__module__.__len__() == 3 — ABCMeta.__module__ is 'abc' which has 3 characters; int.__eq__(3) is True; new to extra194"]
    - [abc_class_module_len_eq_3,
       "ABC.__module__.__len__",
       [],
       3,
       "abc.ABC.__module__.__len__() == 3 — ABC.__module__ is 'abc' which has 3 characters; int.__eq__(3) is True; new to extra194"]
    - [abstractmethod_module_len_eq_3,
       "abstractmethod.__module__.__len__",
       [],
       3,
       "abc.abstractmethod.__module__.__len__() == 3 — abstractmethod.__module__ is 'abc' which has 3 characters; int.__eq__(3) is True; new to extra194"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra194
# ---------------------------------------------------------------------------

invariant abc_extra194.module_name_len:
  description: "abc.__name__.__len__() == 3 — 'abc' has 3 characters; new to extra194"
  kind: python_call_eq
  function: "__name__.__len__"
  args: []
  expected: 3

invariant abc_extra194.abc_class_name_len:
  description: "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters; new to extra194"
  kind: python_call_eq
  function: "ABC.__name__.__len__"
  args: []
  expected: 3

invariant abc_extra194.abcmeta_name_len:
  description: "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters; new to extra194"
  kind: python_call_eq
  function: "ABCMeta.__name__.__len__"
  args: []
  expected: 7

invariant abc_extra194.abstractmethod_name_len:
  description: "abc.abstractmethod.__name__.__len__() == 14 — 'abstractmethod' has 14 characters; new to extra194"
  kind: python_call_eq
  function: "abstractmethod.__name__.__len__"
  args: []
  expected: 14

invariant abc_extra194.get_cache_token_name_len:
  description: "abc.get_cache_token.__name__.__len__() == 15 — 'get_cache_token' has 15 characters; new to extra194"
  kind: python_call_eq
  function: "get_cache_token.__name__.__len__"
  args: []
  expected: 15

invariant abc_extra194.abcmeta_module_len:
  description: "abc.ABCMeta.__module__.__len__() == 3 — ABCMeta.__module__ is 'abc'; 3 characters; new to extra194"
  kind: python_call_eq
  function: "ABCMeta.__module__.__len__"
  args: []
  expected: 3

invariant abc_extra194.abc_class_module_len:
  description: "abc.ABC.__module__.__len__() == 3 — ABC.__module__ is 'abc'; 3 characters; new to extra194"
  kind: python_call_eq
  function: "ABC.__module__.__len__"
  args: []
  expected: 3

invariant abc_extra194.abstractmethod_module_len:
  description: "abc.abstractmethod.__module__.__len__() == 3 — abstractmethod.__module__ is 'abc'; 3 characters; new to extra194"
  kind: python_call_eq
  function: "abstractmethod.__module__.__len__"
  args: []
  expected: 3
