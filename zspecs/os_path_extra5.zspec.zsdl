spec: os_path_extra5
version: ">=3.9"
backend: python_module(os.path)

docs: https://docs.python.org/3/library/os.path.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.path.html — Python os.path documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/posixpath.py"
  notes:
    - "This spec extends prior os_path specs."
    - "Focus: os.path function names and module attributes not yet covered."
    - "os.path.lexists.__name__ == 'lexists'."
    - "os.path.realpath.__name__ == 'realpath'."
    - "os.path.relpath.__name__ == 'relpath'."
    - "os.path.sameopenfile.__name__ == 'sameopenfile'."
    - "os.path.samestat.__name__ == 'samestat'."
    - "os.path.getsize.__name__ == 'getsize'."
    - "os.path.getatime.__name__ == 'getatime'."
    - "os.path.getmtime.__name__ == 'getmtime'."
    - "os.path.getctime.__name__ == 'getctime'."
    - "os.path.realpath('/').__class__.__name__ == 'str'."
    - "os.path.relpath('/a/b', '/a') == 'b'."
    - "os.path.commonpath(['/a/b', '/a/c']) == '/a'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table os_path_extra5.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [lexists,      lexists.__name__.__eq__,      ["lexists"],      true]
    - [realpath,     realpath.__name__.__eq__,     ["realpath"],     true]
    - [relpath,      relpath.__name__.__eq__,      ["relpath"],      true]
    - [sameopenfile, sameopenfile.__name__.__eq__, ["sameopenfile"], true]
    - [samestat,     samestat.__name__.__eq__,     ["samestat"],     true]
    - [getsize,      getsize.__name__.__eq__,      ["getsize"],      true]
    - [getatime,     getatime.__name__.__eq__,     ["getatime"],     true]
    - [getmtime,     getmtime.__name__.__eq__,     ["getmtime"],     true]
    - [getctime,     getctime.__name__.__eq__,     ["getctime"],     true]

invariant os_path_extra5.realpath.returns_str:
  description: "os.path.realpath('/').__class__.__name__ == 'str'"
  category: realpath
  kind: python_call_eq
  function: realpath
  args: ["/"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant os_path_extra5.relpath.basic:
  description: "os.path.relpath('/a/b', '/a') == 'b'"
  category: relpath
  kind: python_call_eq
  function: relpath
  args: ["/a/b", "/a"]
  expected: "b"

invariant os_path_extra5.relpath.same_dir:
  description: "os.path.relpath('/a/b', '/a/b') == '.'"
  category: relpath
  kind: python_call_eq
  function: relpath
  args: ["/a/b", "/a/b"]
  expected: "."

invariant os_path_extra5.commonpath.two_paths:
  description: "os.path.commonpath(['/a/b', '/a/c']) == '/a'"
  category: commonpath
  kind: python_call_eq
  function: commonpath
  args: [["/a/b", "/a/c"]]
  expected: "/a"

invariant os_path_extra5.realpath.root:
  description: "os.path.realpath('/') == '/' on POSIX"
  category: realpath
  kind: python_call_eq
  function: realpath
  args: ["/"]
  expected: "/"

invariant os_path_extra5.lexists.module:
  description: "os.path.lexists.__module__ == 'posixpath'"
  category: module
  kind: python_call_eq
  function: lexists.__module__.__eq__
  args: ["posixpath"]
  expected: true
