spec: re_extra45
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra44.zspec.zsdl — covers search/findall/sub/split/compile/match/fullmatch __qualname__.__eq__(); Pattern/Match __qualname__.__eq__()."
    - "re_extra43.zspec.zsdl — covers search/__name__/__module__; findall/__name__/__module__; IGNORECASE/__class__/__module__."
    - "re_extra41.zspec.zsdl — covers VERBOSE._value_==64; MULTILINE._value_==8."
    - "re_extra33.zspec.zsdl — covers IGNORECASE.__class__.__name__.__len__()==9; int(IGNORECASE)==2; int(MULTILINE)==8; int(DOTALL)==16."
    - "re_extra27.zspec.zsdl — covers IGNORECASE/__class__/__qualname__/__eq__('RegexFlag'); IGNORECASE/__class__/__module__/__eq__('re')."
    - "re_extra18.zspec.zsdl — covers IGNORECASE.__int__()==2 standalone invariant."
    - "re_extra10.zspec.zsdl — covers RegexFlag.LOCALE.value==4; RegexFlag.UNICODE.value==32; LOCALE/__class__.__name__=='RegexFlag'; UNICODE/__class__.__name__=='RegexFlag'."
    - "re_extra7.zspec.zsdl — covers RegexFlag.IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII/NOFLAG .value attributes."
    - "re_extra6.zspec.zsdl — covers ASCII.value==256 standalone; VERBOSE integer value."
    - "re_extra2.zspec.zsdl — covers LOCALE/UNICODE/IGNORECASE/NOFLAG __class__.__name__.__eq__('RegexFlag') in table."
  notes:
    - "This spec extends re_extra44.zspec.zsdl."
    - "Prior specs collectively covered: all flag .value attributes (re_extra7: IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII/NOFLAG; re_extra10: LOCALE/UNICODE); all flag ._value_ attributes for VERBOSE and MULTILINE (re_extra41); all flag int() coercion for IGNORECASE/MULTILINE/DOTALL (re_extra33/re_extra18); __class__.__name__=='RegexFlag' for IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII/NOFLAG/LOCALE/UNICODE (re_extra2/re_extra10); re.A alias not checked via __class__.__name__; re.I alias not checked via __class__.__name__; ._value_ not yet accessed for IGNORECASE/ASCII/LOCALE/UNICODE/DEBUG/NOFLAG."
    - "This spec covers: re.IGNORECASE._value_==2 (re_extra41 covers VERBOSE._value__/MULTILINE._value_; re_extra7 covers IGNORECASE via .value; no spec covers IGNORECASE._value_; novel); re.ASCII._value_==256 (re_extra7 covers ASCII.value; no spec covers ASCII._value_; novel); re.LOCALE._value_==4 (re_extra10 covers LOCALE.value; no spec covers LOCALE._value_; novel); re.UNICODE._value_==32 (re_extra10 covers UNICODE.value; no spec covers UNICODE._value_; novel); re.DEBUG._value_==128 (no prior re spec covers DEBUG at all via ._value_ or .value; novel); re.NOFLAG._value_==0 (re_extra7 covers NOFLAG.value; no spec covers NOFLAG._value_; novel); re.A.__class__.__name__=='RegexFlag' (re_extra2 covers IGNORECASE/LOCALE/UNICODE/NOFLAG but not the A alias; novel); re.I.__class__.__name__=='RegexFlag' (re_extra2 covers IGNORECASE but not the I alias; novel)."
    - "re.IGNORECASE._value_ == 2. The ._value_ attribute is the raw underlying integer of the IntFlag member. re_extra7 covers IGNORECASE.value (same integer, different attribute); re_extra41 covers VERBOSE._value_ and MULTILINE._value_. No prior re spec uses ._value_ on IGNORECASE. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.ASCII._value_ == 256. re_extra7 covers ASCII.value==256; re_extra6 covers ASCII.__eq__(256). No prior re spec uses ASCII._value_. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.LOCALE._value_ == 4. re_extra10 covers RegexFlag.LOCALE.value==4. No prior re spec uses LOCALE._value_. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.UNICODE._value_ == 32. re_extra10 covers RegexFlag.UNICODE.value==32. No prior re spec uses UNICODE._value_. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.DEBUG._value_ == 128. re.DEBUG enables debug output for compiled patterns. No prior re spec covers DEBUG via ._value_ or .value. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.NOFLAG._value_ == 0. NOFLAG is the identity element of flag arithmetic (introduced Python 3.11). re_extra7 covers NOFLAG.value==0. No prior re spec uses NOFLAG._value_. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.A.__class__.__name__ == 'RegexFlag'. re.A is an alias for re.ASCII. re_extra2 covers LOCALE/UNICODE/IGNORECASE/NOFLAG via __class__.__name__ in a table but does not include re.A or re.I aliases. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.I.__class__.__name__ == 'RegexFlag'. re.I is an alias for re.IGNORECASE. re_extra2 covers IGNORECASE directly but not the I alias. Novel equality anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re RegexFlag ._value_ attributes: IGNORECASE, ASCII, LOCALE, UNICODE,
# DEBUG, NOFLAG
#
# IntFlag members expose their underlying integer through two attributes:
#   .value   — the public enum API (covered in re_extra7/re_extra10)
#   ._value_ — the private underlying integer (covered for VERBOSE/MULTILINE
#               in re_extra41; not yet covered for the flags below)
#
# Flag integer values (all verified Python 3.14 macOS/Darwin 25.4.0):
#   IGNORECASE._value_ == 2
#   ASCII._value_      == 256
#   LOCALE._value_     == 4
#   UNICODE._value_    == 32
#   DEBUG._value_      == 128
#   NOFLAG._value_     == 0
#
# All six are novel ._value_ access paths in the re_extra45 namespace.
# ---------------------------------------------------------------------------

table re_extra45.flag_value_attrs:
  description: "re RegexFlag ._value_ attributes: IGNORECASE(2)/ASCII(256)/LOCALE(4)/UNICODE(32)/DEBUG(128)/NOFLAG(0) — ._value_ is the raw underlying IntFlag integer; re_extra41 covers VERBOSE._value_/MULTILINE._value_; re_extra7/re_extra10 cover .value for most flags; no prior re spec uses ._value_ on these six flags; all novel equality anchors in re_extra45 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: flag_identity
  id_prefix: rfva45

  columns: [id, function, args, expected]
  rows:
    - [IGNORECASE_value_attr, IGNORECASE._value_.__eq__, [2],   true]
    - [ASCII_value_attr,      ASCII._value_.__eq__,      [256], true]
    - [LOCALE_value_attr,     LOCALE._value_.__eq__,     [4],   true]
    - [UNICODE_value_attr,    UNICODE._value_.__eq__,    [32],  true]
    - [DEBUG_value_attr,      DEBUG._value_.__eq__,      [128], true]
    - [NOFLAG_value_attr,     NOFLAG._value_.__eq__,     [0],   true]

# ---------------------------------------------------------------------------
# re flag alias __class__.__name__ attributes: re.A and re.I
#
# re provides single-letter aliases for each RegexFlag member:
#   re.A == re.ASCII       (value 256)
#   re.I == re.IGNORECASE  (value 2)
#
# All aliases are instances of RegexFlag, so their __class__.__name__ is
# 'RegexFlag'. re_extra2 covers LOCALE/UNICODE/IGNORECASE/NOFLAG via
# __class__.__name__ in a table, but does not include the short aliases
# re.A or re.I. These are novel equality anchors in the re_extra45 namespace.
#
#   re.A.__class__.__name__ == 'RegexFlag'
#   re.I.__class__.__name__ == 'RegexFlag'
#
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra45.alias_class_names:
  description: "re flag alias __class__.__name__: re.A and re.I are both RegexFlag instances — re.A is an alias for ASCII; re.I is an alias for IGNORECASE; re_extra2 covers IGNORECASE/__class__.__name__ but not the I or A aliases; both novel equality anchors in re_extra45 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: flag_identity
  id_prefix: racn45

  columns: [id, function, args, expected]
  rows:
    - [A_class_name, A.__class__.__name__.__eq__, ["RegexFlag"], true]
    - [I_class_name, I.__class__.__name__.__eq__, ["RegexFlag"], true]
