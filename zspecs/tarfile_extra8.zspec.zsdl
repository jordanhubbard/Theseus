spec: tarfile_extra8
version: ">=3.9"
backend: python_module(tarfile)

docs: https://docs.python.org/3/library/tarfile.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tarfile.html — Python tarfile documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tarfile.py"
  notes:
    - "This spec extends tarfile.zspec.zsdl through tarfile_extra7.zspec.zsdl."
    - "tarfile (base) covers: USTAR/GNU/PAX/DEFAULT_FORMAT values, BLOCKSIZE, RECORDSIZE, ENCODING value, type-flag decode, TarFile/TarInfo/TarError/ReadError __name__, exception hierarchy, TarInfo construction, is_tarfile."
    - "tarfile_extra covers: class __name__ table, open/__name__, is_tarfile/__name__, TarError base, ENCODING class name."
    - "tarfile_extra2 covers: TarFile/__name__/__module__, TarInfo/__name__/__module__, CompressionError/__name__/base, ENCODING class, REGULAR_TYPES/SUPPORTED_TYPES, TarFile/TarInfo is_type, type-set membership, open/__name__ standalone."
    - "tarfile_extra3 covers: class __name__ table, function names, TarFile __module__, TarError/ReadError bases, REGTYPE/DIRTYPE/SYMTYPE eq values, TarInfo instance class."
    - "tarfile_extra4 covers: __qualname__ for TarFile/TarInfo/exceptions/functions, format constant types as int."
    - "tarfile_extra5 covers: TarInfo/__module__, TarError/__module__, ReadError/__module__, TarFile/TarInfo __bases__[0].__name__ == 'object', tarfile.__name__ == 'tarfile'."
    - "tarfile_extra6 covers: CONTTYPE/GNUTYPE_LONGNAME/GNUTYPE_LONGLINK/GNUTYPE_SPARSE decode, ExFileObject class metadata, ExtractError/CompressionError/HeaderError/StreamError __module__ and bases."
    - "tarfile_extra7 covers: LNKTYPE/CHRTYPE/BLKTYPE/FIFOTYPE __eq__ bool form, ENCODING bool form, BLOCKSIZE/RECORDSIZE __class__.__name__, TarFile/TarInfo/TarError/ReadError/CompressionError __class__.__name__, StreamError __name__, TarInfo('readme.md').name."
    - "No prior spec covers: TarInfo.uid == 0 — default uid on a freshly constructed TarInfo."
    - "No prior spec covers: TarInfo.gid == 0 — default gid on a freshly constructed TarInfo."
    - "No prior spec covers: TarInfo.mode == 420 — default mode (0o644) on a freshly constructed TarInfo."
    - "No prior spec covers: GNUTYPE_LONGNAME/__class__.__name__ == 'bytes' — tarfile_extra6 only decodes it; no spec checks its type."
    - "No prior spec covers: GNUTYPE_LONGLINK/__class__.__name__ == 'bytes'."
    - "No prior spec covers: CONTTYPE/__class__.__name__ == 'bytes'."
    - "No prior spec covers: GNUTYPE_SPARSE/__class__.__name__ == 'bytes'."
    - "No prior spec covers: tarfile.is_tarfile.__module__ == 'tarfile'."
    - "No prior spec covers: tarfile.is_tarfile.__class__.__name__ == 'function'."
    - "No prior spec covers: tarfile.open.__class__.__name__ == 'method' — open is a classmethod, so it reports as 'method'."
    - "tarfile.TarInfo uid=0, gid=0, mode=420 (0o644) are CPython defaults for newly constructed TarInfo objects."
    - "tarfile.open is exposed at module level via tarfile.open = TarFile.open; it is a bound method of the TarFile class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TarInfo default field values — uid, gid, mode
# tarfile (base) covers name, size, mtime defaults via TarInfo construction.
# tarfile_extra7 covers TarInfo('readme.md').name.
# uid, gid, and mode defaults have never been checked in any prior tarfile spec.
# Default values: uid=0, gid=0, mode=0o644 (decimal 420).
# ---------------------------------------------------------------------------

table tarfile_extra8.TarInfo_defaults:
  description: "TarInfo() default field values: uid=0, gid=0, mode=420"
  kind: python_call_eq
  category: tarinfo
  id_prefix: tidef8

  columns: [id, function, args, expected, method]
  rows:
    - [uid,  TarInfo, ["test.txt"], 0,   uid]
    - [gid,  TarInfo, ["test.txt"], 0,   gid]
    - [mode, TarInfo, ["test.txt"], 420, mode]

# ---------------------------------------------------------------------------
# GNU extension type flag __class__.__name__ == 'bytes'
# tarfile_extra6 covers CONTTYPE/GNUTYPE_LONGNAME/GNUTYPE_LONGLINK/GNUTYPE_SPARSE
# via .decode('ascii') — verifying their string representation.
# No prior spec checks __class__.__name__ for any of these GNU flags.
# All four are single-byte b-strings, so __class__.__name__ == 'bytes'.
# ---------------------------------------------------------------------------

table tarfile_extra8.gnu_flag_class_names:
  description: "tarfile GNU-extension type flags are bytes objects"
  kind: python_call_eq
  category: type_flags
  id_prefix: gnucls8

  columns: [id, function, args, expected]
  rows:
    - [CONTTYPE,         CONTTYPE.__class__.__name__.__eq__,         ["bytes"], true]
    - [GNUTYPE_LONGNAME, GNUTYPE_LONGNAME.__class__.__name__.__eq__, ["bytes"], true]
    - [GNUTYPE_LONGLINK, GNUTYPE_LONGLINK.__class__.__name__.__eq__, ["bytes"], true]
    - [GNUTYPE_SPARSE,   GNUTYPE_SPARSE.__class__.__name__.__eq__,   ["bytes"], true]

# ---------------------------------------------------------------------------
# tarfile.is_tarfile function identity
# tarfile_extra covers is_tarfile/__name__; tarfile_extra4 covers
# is_tarfile/__qualname__. Neither __module__ nor __class__.__name__
# appears in any prior tarfile spec for is_tarfile.
# ---------------------------------------------------------------------------

invariant tarfile_extra8.is_tarfile.module:
  description: "tarfile.is_tarfile.__module__ == 'tarfile'"
  category: module
  kind: python_call_eq
  function: is_tarfile.__module__.__eq__
  args: ["tarfile"]
  expected: true

invariant tarfile_extra8.is_tarfile.class_is_function:
  description: "tarfile.is_tarfile.__class__.__name__ == 'function' — is_tarfile is a plain Python function"
  category: type_identity
  kind: python_call_eq
  function: is_tarfile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# tarfile.open __class__.__name__ == 'method'
# tarfile_extra covers open/__name__; tarfile_extra4 covers open/__qualname__
# ('TarFile.open'). No prior spec checks open/__class__.__name__. Because
# tarfile.open is tarfile.TarFile.open — a classmethod — its __class__.__name__
# is 'method', not 'function'.
# ---------------------------------------------------------------------------

invariant tarfile_extra8.open.class_is_method:
  description: "tarfile.open.__class__.__name__ == 'method' — open is a classmethod, not a plain function"
  category: type_identity
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["method"]
  expected: true
