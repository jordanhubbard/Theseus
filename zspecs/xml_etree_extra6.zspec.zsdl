spec: xml_etree_extra6
version: ">=3.9"
backend: python_module(xml.etree.ElementTree)

docs: https://docs.python.org/3/library/xml.etree.elementtree.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xml.etree.elementtree.html — Python xml.etree.ElementTree documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/xml/etree/ElementTree.py"
    - "elementtree.zspec.zsdl — covers fromstring tag/text/attrib/get/findtext, Element constructor, tostring, SubElement, ParseError raise behavior"
    - "xml_parse.zspec.zsdl — covers ElementTree/XMLParser/ParseError __module__, ParseError base, XMLParser feed/close, ElementTree __name__/bases"
    - "xml_extra.zspec.zsdl — covers Element/ElementTree/SubElement/ParseError/parse/fromstring/tostring __name__; ParseError base; fromstring result class"
    - "xml_extra2.zspec.zsdl — covers fromstring tag/attrib; Element tag/attrib; tostring result class; ParseError class_name; VERSION/XML_VERSION"
    - "xml_extra3.zspec.zsdl — covers Element/ElementTree/XMLParser/ParseError __qualname__; function __qualname__ (tostring/indent/iterparse/parse); Element/XMLParser base == 'object'; function type checks; ParseError/Element is_type; Element.__module__; XMLParser.__module__"
    - "xml_etree_extra.zspec.zsdl — covers Element/__name__, SubElement/__name__, parse/fromstring/tostring/indent/iterparse/register_namespace __name__, Comment/ProcessingInstruction __name__, ParseError name/base, fromstring result class, Element.__module__ is str"
    - "xml_etree_extra2.zspec.zsdl — covers SubElement/__qualname__, fromstring/__qualname__, SubElement/fromstring/tostring/parse/indent/iterparse __module__, ParseError.__module__, SubElement callable check"
    - "xml_etree_extra3.zspec.zsdl — covers register_namespace/__qualname__/__module__, Comment/__qualname__/__module__, ProcessingInstruction/__qualname__/__module__, fromstring text/tag with text, ElementTree is_type, fromstring class_name, register_namespace class_name"
    - "xml_etree_extra4.zspec.zsdl — covers Element instance method __name__ and __qualname__ (get/set/find/findall/append/remove/iter/keys/items)"
    - "xml_etree_extra5.zspec.zsdl — covers ElementTree instance method __name__ and __qualname__ (write/find/findall/findtext/getroot/iter); XMLParser feed/close __name__/__qualname__"
  notes:
    - "This spec extends all prior xml.etree.ElementTree specs."
    - "Focus: class __dict__.__class__.__name__.__len__(); __mro__ depths; __bases__[0].__name__ lengths; function __qualname__.__len__() for key functions; ET.__all__.__len__()."
    - "xml.etree.ElementTree has __all__ with 26 entries — no prior spec checks __all__.__len__()."
    - "Element/ElementTree/ParseError/XMLParser all have __dict__.__class__.__name__ == 'mappingproxy' (len 12) — no prior spec checks __dict__.__class__.__name__.__len__() on any ET class."
    - "ParseError.__mro__ == [ParseError, SyntaxError, Exception, BaseException, object] (len 5) — no prior ET spec checks ParseError.__mro__.__len__()."
    - "ParseError.__bases__[0].__name__ == 'SyntaxError' (len 11) — ParseError is a direct subclass of SyntaxError; no prior ET spec checks __bases__[0].__name__.__len__()."
    - "ElementTree.__mro__ len == 2 (ElementTree, object) — covered via __qualname__ in xml_extra3 but __mro__.__len__() not checked in any prior ET spec."
    - "XMLParser.__mro__ len == 2 (XMLParser, object) — same pattern; no prior ET spec checks XMLParser.__mro__.__len__()."
    - "ET.parse.__qualname__ == 'parse' (len 5); ET.tostring.__qualname__ == 'tostring' (len 8); ET.indent.__qualname__ == 'indent' (len 6); ET.SubElement.__qualname__ == 'SubElement' (len 10) — no prior ET spec checks __qualname__.__len__() for these functions."
    - "ET.fromstring.__qualname__ == 'XML' (len 3) — fromstring is an alias for the C-implemented XML(); qualname is 'XML', not 'fromstring'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# xml.etree.ElementTree.__all__ length and class
#
# The module exposes 26 public names. No prior ET spec checks __all__.__len__()
# or __all__.__class__.__name__.__len__().
# ---------------------------------------------------------------------------

invariant xml_etree_extra6.all_len:
  description: "xml.etree.ElementTree.__all__.__len__() == 26 — module exports 26 public names; no prior ET spec checks __all__.__len__()"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 26

invariant xml_etree_extra6.all_class_name_len:
  description: "xml.etree.ElementTree.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list' (len 4); no prior ET spec checks __all__.__class__.__name__.__len__()"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Class __dict__.__class__.__name__.__len__() for key ET classes
#
# Element, ElementTree, ParseError, XMLParser all have mappingproxy __dict__s.
# 'mappingproxy' has length 12. No prior ET spec checks __dict__.__class__.__name__.__len__()
# on any ET class.
# ---------------------------------------------------------------------------

table xml_etree_extra6.class_dict_class_name_len:
  description: "ET class __dict__.__class__.__name__.__len__() — all equal 12 ('mappingproxy'); no prior ET spec checks this on any ET class"
  kind: python_call_eq
  category: class_dict
  id_prefix: etdcnlen6

  columns: [id, function, args, expected]
  rows:
    - [Element,     Element.__dict__.__class__.__name__.__len__,     [], 12]
    - [ElementTree, ElementTree.__dict__.__class__.__name__.__len__, [], 12]
    - [ParseError,  ParseError.__dict__.__class__.__name__.__len__,  [], 12]
    - [XMLParser,   XMLParser.__dict__.__class__.__name__.__len__,   [], 12]

# ---------------------------------------------------------------------------
# ParseError.__mro__ depth and __bases__[0].__name__ length
#
# ParseError inherits from SyntaxError, making its MRO:
#   ParseError -> SyntaxError -> Exception -> BaseException -> object (len 5).
# No prior ET spec checks ParseError.__mro__.__len__() or
# ParseError.__bases__[0].__name__.__len__().
# ---------------------------------------------------------------------------

invariant xml_etree_extra6.ParseError.mro_len:
  description: "xml.etree.ElementTree.ParseError.__mro__.__len__() == 5 — MRO: ParseError->SyntaxError->Exception->BaseException->object; no prior ET spec checks ParseError.__mro__.__len__()"
  category: class_hierarchy
  kind: python_call_eq
  function: ParseError.__mro__.__len__
  args: []
  expected: 5

invariant xml_etree_extra6.ParseError.base_name_len:
  description: "xml.etree.ElementTree.ParseError.__bases__[0].__name__.__len__() == 11 — direct base is 'SyntaxError' (len 11); no prior ET spec checks __bases__[0].__name__.__len__() on ParseError"
  category: class_hierarchy
  kind: python_call_eq
  function: "ParseError.__bases__[0].__name__.__len__"
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# ElementTree and XMLParser __mro__ depths
#
# Both ElementTree and XMLParser inherit directly from object (MRO len 2).
# xml_extra3 confirms base == 'object' via __qualname__ but no prior ET spec
# checks __mro__.__len__() on either class.
# ---------------------------------------------------------------------------

invariant xml_etree_extra6.ElementTree.mro_len:
  description: "xml.etree.ElementTree.ElementTree.__mro__.__len__() == 2 — MRO: [ElementTree, object]; no prior ET spec checks ElementTree.__mro__.__len__()"
  category: class_hierarchy
  kind: python_call_eq
  function: ElementTree.__mro__.__len__
  args: []
  expected: 2

invariant xml_etree_extra6.XMLParser.mro_len:
  description: "xml.etree.ElementTree.XMLParser.__mro__.__len__() == 2 — MRO: [XMLParser, object]; no prior ET spec checks XMLParser.__mro__.__len__()"
  category: class_hierarchy
  kind: python_call_eq
  function: XMLParser.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# Function __qualname__.__len__() for key ET module-level functions
#
# xml_etree_extra5 covers ElementTree method qualnames. No prior ET spec
# checks __qualname__.__len__() for module-level functions parse/tostring/
# indent/SubElement/fromstring. Note: fromstring.__qualname__ == 'XML' (len 3)
# because fromstring is an alias for the XML() C function.
# ---------------------------------------------------------------------------

table xml_etree_extra6.function_qualname_lens:
  description: "ET module-level function __qualname__.__len__() — no prior ET spec checks these as __len__() values"
  kind: python_call_eq
  category: function_identity
  id_prefix: etfqlen6

  columns: [id, function, args, expected, description]
  rows:
    - [parse,      parse.__qualname__.__len__,      [], 5,  "len('parse') == 5"]
    - [tostring,   tostring.__qualname__.__len__,   [], 8,  "len('tostring') == 8"]
    - [indent,     indent.__qualname__.__len__,     [], 6,  "len('indent') == 6"]
    - [SubElement, SubElement.__qualname__.__len__, [], 10, "len('SubElement') == 10"]
    - [fromstring, fromstring.__qualname__.__len__, [], 3,  "fromstring.__qualname__ == 'XML' (len 3); fromstring is an alias for XML()"]
