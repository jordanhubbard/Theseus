spec: itertools_extra1606
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "All itertools types are C extension types; they never expose __slots__ in their __dict__"
    - "C extension types do not create per-instance __dict__ slots; __dict__ is absent from their type dict"
    - "itertools.chain is unique in exposing a from_iterable classmethod descriptor"
    - "itertools.repeat exposes __length_hint__ and __repr__; itertools.count exposes __repr__"
  created_at: "2026-04-12"
error_model: python_exceptions

table itertools_extra1606.c_types_no_slots:
  description: "All itertools C extension types lack __slots__ in their __dict__; Python __slots__ is a pure-Python mechanism not applicable to C types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1606ns

  columns: [id, function, args, expected]
  rows:
    - ["it1606ns001", "itertools.chain.__dict__.__contains__",                      ["__slots__"], false]
    - ["it1606ns002", "itertools.islice.__dict__.__contains__",                     ["__slots__"], false]
    - ["it1606ns003", "itertools.product.__dict__.__contains__",                    ["__slots__"], false]
    - ["it1606ns004", "itertools.combinations.__dict__.__contains__",               ["__slots__"], false]
    - ["it1606ns005", "itertools.permutations.__dict__.__contains__",               ["__slots__"], false]
    - ["it1606ns006", "itertools.groupby.__dict__.__contains__",                    ["__slots__"], false]
    - ["it1606ns007", "itertools.cycle.__dict__.__contains__",                      ["__slots__"], false]
    - ["it1606ns008", "itertools.repeat.__dict__.__contains__",                     ["__slots__"], false]
    - ["it1606ns009", "itertools.count.__dict__.__contains__",                      ["__slots__"], false]
    - ["it1606ns010", "itertools.zip_longest.__dict__.__contains__",                ["__slots__"], false]
    - ["it1606ns011", "itertools.combinations_with_replacement.__dict__.__contains__", ["__slots__"], false]
    - ["it1606ns012", "itertools.compress.__dict__.__contains__",                   ["__slots__"], false]
    - ["it1606ns013", "itertools.dropwhile.__dict__.__contains__",                  ["__slots__"], false]
    - ["it1606ns014", "itertools.filterfalse.__dict__.__contains__",                ["__slots__"], false]
    - ["it1606ns015", "itertools.starmap.__dict__.__contains__",                    ["__slots__"], false]
    - ["it1606ns016", "itertools.takewhile.__dict__.__contains__",                  ["__slots__"], false]
    - ["it1606ns017", "itertools.accumulate.__dict__.__contains__",                 ["__slots__"], false]
    - ["it1606ns018", "itertools.pairwise.__dict__.__contains__",                   ["__slots__"], false]
    - ["it1606ns019", "itertools.chain.__dict__.__contains__",                      ["__iter__"],  true]
    - ["it1606ns020", "itertools.chain.__dict__.__contains__",                      ["__next__"],  true]
    - ["it1606ns021", "itertools.chain.__dict__.__contains__",                      ["from_iterable"], true]
    - ["it1606ns022", "itertools.chain.__dict__.__contains__",                      ["__class_getitem__"], true]
    - ["it1606ns023", "itertools.repeat.__dict__.__contains__",                     ["__length_hint__"], true]
    - ["it1606ns024", "itertools.repeat.__dict__.__contains__",                     ["__repr__"],  true]
    - ["it1606ns025", "itertools.count.__dict__.__contains__",                      ["__repr__"],  true]
    - ["it1606ns026", "itertools.combinations_with_replacement.__dict__.__contains__", ["__sizeof__"], true]
    - ["it1606ns027", "itertools.product.__dict__.__contains__",                    ["__sizeof__"], true]
    - ["it1606ns028", "itertools.chain.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["it1606ns029", "itertools.islice.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["it1606ns030", "itertools.repeat.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]

table itertools_extra1606.c_types_no_instance_dict:
  description: "C extension itertools types have no per-instance __dict__ slot; __dict__ is absent from each type's own __dict__, confirming fixed-layout C structs"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1606id

  columns: [id, function, args, expected]
  rows:
    - ["it1606id001", "itertools.chain.__dict__.__contains__",                      ["__dict__"],  false]
    - ["it1606id002", "itertools.islice.__dict__.__contains__",                     ["__dict__"],  false]
    - ["it1606id003", "itertools.product.__dict__.__contains__",                    ["__dict__"],  false]
    - ["it1606id004", "itertools.combinations.__dict__.__contains__",               ["__dict__"],  false]
    - ["it1606id005", "itertools.permutations.__dict__.__contains__",               ["__dict__"],  false]
    - ["it1606id006", "itertools.groupby.__dict__.__contains__",                    ["__dict__"],  false]
    - ["it1606id007", "itertools.cycle.__dict__.__contains__",                      ["__dict__"],  false]
    - ["it1606id008", "itertools.repeat.__dict__.__contains__",                     ["__dict__"],  false]
    - ["it1606id009", "itertools.count.__dict__.__contains__",                      ["__dict__"],  false]
    - ["it1606id010", "itertools.zip_longest.__dict__.__contains__",                ["__dict__"],  false]
    - ["it1606id011", "itertools.combinations_with_replacement.__dict__.__contains__", ["__dict__"], false]
    - ["it1606id012", "itertools.compress.__dict__.__contains__",                   ["__dict__"],  false]
    - ["it1606id013", "itertools.dropwhile.__dict__.__contains__",                  ["__dict__"],  false]
    - ["it1606id014", "itertools.filterfalse.__dict__.__contains__",                ["__dict__"],  false]
    - ["it1606id015", "itertools.starmap.__dict__.__contains__",                    ["__dict__"],  false]
    - ["it1606id016", "itertools.takewhile.__dict__.__contains__",                  ["__dict__"],  false]
    - ["it1606id017", "itertools.accumulate.__dict__.__contains__",                 ["__dict__"],  false]
    - ["it1606id018", "itertools.pairwise.__dict__.__contains__",                   ["__dict__"],  false]
    - ["it1606id019", "itertools.chain.__dict__.__contains__",                      ["__weakref__"], false]
    - ["it1606id020", "itertools.islice.__dict__.__contains__",                     ["__weakref__"], false]
    - ["it1606id021", "itertools.cycle.__dict__.__contains__",                      ["__weakref__"], false]
    - ["it1606id022", "itertools.repeat.__dict__.__contains__",                     ["__weakref__"], false]
    - ["it1606id023", "itertools.combinations.__dict__.__contains__",               ["__weakref__"], false]
    - ["it1606id024", "itertools.permutations.__dict__.__contains__",               ["__weakref__"], false]
    - ["it1606id025", "itertools.groupby.__dict__.__contains__",                    ["__weakref__"], false]
    - ["it1606id026", "itertools.chain.__dict__.__contains__",                      ["__new__"],   true]
    - ["it1606id027", "itertools.islice.__dict__.__contains__",                     ["__new__"],   true]
    - ["it1606id028", "itertools.repeat.__dict__.__contains__",                     ["__new__"],   true]
    - ["it1606id029", "itertools.chain.__module__.__eq__", ["itertools"], true]
    - ["it1606id030", "itertools.repeat.__module__.__eq__", ["itertools"], true]
