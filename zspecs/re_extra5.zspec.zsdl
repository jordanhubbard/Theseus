spec: re_extra5
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends prior re specs."
    - "Focus: __module__ and __name__ for re functions; re flag constants; Pattern and Match class names."
    - "re.IGNORECASE == re.I == 2."
    - "re.MULTILINE == re.M == 8."
    - "re.DOTALL == re.S == 16."
    - "re.compile().__class__.__name__ == 'Pattern' (or 're.Pattern')."
    - "re.match().__class__.__name__ == 'Match' (or 're.Match')."
    - "re.fullmatch, re.search, re.sub, re.subn, re.split, re.findall are all functions."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table re_extra5.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [fullmatch, fullmatch.__name__.__eq__, ["fullmatch"], true]
    - [sub,       sub.__name__.__eq__,       ["sub"],       true]
    - [subn,      subn.__name__.__eq__,      ["subn"],      true]
    - [split,     split.__name__.__eq__,     ["split"],     true]
    - [findall,   findall.__name__.__eq__,   ["findall"],   true]
    - [finditer,  finditer.__name__.__eq__,  ["finditer"],  true]
    - [escape,    escape.__name__.__eq__,    ["escape"],    true]
    - [purge,     purge.__name__.__eq__,     ["purge"],     true]

table re_extra5.flag_values:
  kind: python_call_eq
  category: flags
  id_prefix: flag

  columns: [id, function, args, expected]
  rows:
    - [IGNORECASE, IGNORECASE.__eq__, [2],  true]
    - [MULTILINE,  MULTILINE.__eq__,  [8],  true]
    - [DOTALL,     DOTALL.__eq__,     [16], true]
    - [VERBOSE,    VERBOSE.__eq__,    [64], true]

invariant re_extra5.compile.pattern_class_name:
  description: "re.compile('.*').__class__.__name__ == 'Pattern'"
  category: compile
  kind: python_call_eq
  function: compile
  args: [".*"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Pattern"]
  expected: true

invariant re_extra5.match.match_class_name:
  description: "re.match('a', 'abc').__class__.__name__ == 'Match'"
  category: match
  kind: python_call_eq
  function: match
  args: ["a", "abc"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Match"]
  expected: true

invariant re_extra5.sub.basic:
  description: "re.sub('a', 'b', 'aaa') == 'bbb'"
  category: sub
  kind: python_call_eq
  function: sub
  args: ["a", "b", "aaa"]
  expected: "bbb"

invariant re_extra5.subn.count:
  description: "re.subn('a', 'b', 'aaa')[1] == 3"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["a", "b", "aaa"]
  method: __getitem__
  method_args: [1]
  expected: 3

invariant re_extra5.split.basic:
  description: "re.split(',', 'a,b,c') == ['a', 'b', 'c']"
  category: split
  kind: python_call_eq
  function: split
  args: [",", "a,b,c"]
  expected: ["a", "b", "c"]

invariant re_extra5.findall.basic:
  description: "re.findall('[0-9]+', 'abc123def456') == ['123', '456']"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["[0-9]+", "abc123def456"]
  expected: ["123", "456"]

invariant re_extra5.escape.basic:
  description: "re.escape('1+1') == '1\\+1'"
  category: escape
  kind: python_call_eq
  function: escape
  args: ["1+1"]
  expected: "1\\+1"

invariant re_extra5.error.class_name:
  description: "re.error.__name__ == 'error'"
  category: exceptions
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true
