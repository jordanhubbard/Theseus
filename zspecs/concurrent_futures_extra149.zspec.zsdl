spec: concurrent_futures_extra149
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures exception class identity. CancelledError.__name__=='CancelledError' (len=14); CancelledError.__module__=='concurrent.futures._base' (defined in _base.py, not in builtins); CancelledError.__bases__[0].__name__=='Error' (CancelledError inherits from concurrent.futures._base.Error, the base exception class for the futures package); TimeoutError.__name__=='TimeoutError' (len=12); TimeoutError.__module__=='builtins' (concurrent.futures.TimeoutError IS the builtin TimeoutError, re-exported); TimeoutError.__bases__[0].__name__=='OSError'; InvalidStateError.__name__=='InvalidStateError' (len=16); InvalidStateError.__module__=='concurrent.futures._base'; BrokenExecutor.__name__=='BrokenExecutor' (len=14); BrokenExecutor.__bases__[0].__name__=='RuntimeError'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.CancelledError.__module__=='concurrent.futures._base' — unlike TimeoutError (which is the builtin), CancelledError is defined in concurrent.futures._base and is distinct from asyncio.CancelledError; CancelledError.__bases__[0].__name__=='Error' where Error is concurrent.futures._base.Error, the package-specific base exception. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.TimeoutError.__module__=='builtins' — concurrent.futures.TimeoutError IS the Python builtin TimeoutError (not a custom subclass); TimeoutError.__bases__[0].__name__=='OSError' confirms it is the builtin. Compare: CancelledError.__module__=='concurrent.futures._base' (a custom class). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.InvalidStateError exists in Python 3.14.3 — it is defined in concurrent.futures._base and inherits from concurrent.futures._base.Error. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures CancelledError and InvalidStateError identity — extra149
#
# concurrent.futures.CancelledError.__name__.__eq__('CancelledError')   == True
# concurrent.futures.CancelledError.__module__.__eq__('concurrent.futures._base') == True
# concurrent.futures.CancelledError.__bases__[0].__name__.__eq__('Error') == True
# concurrent.futures.InvalidStateError.__name__.__eq__('InvalidStateError') == True
# concurrent.futures.InvalidStateError.__module__.__eq__('concurrent.futures._base') == True
# concurrent.futures.InvalidStateError.__bases__[0].__name__.__eq__('Error') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra149.cf_cancelled_invalidstate_identity:
  description: "concurrent.futures CancelledError and InvalidStateError class identity checks in cfexc149 namespace — concurrent.futures.CancelledError.__name__=='CancelledError' (len=14; defined in _base.py, NOT the builtin CancelledError from asyncio/builtins); concurrent.futures.CancelledError.__module__=='concurrent.futures._base' (len=24; confirms it is a custom exception not from builtins); concurrent.futures.CancelledError.__bases__[0].__name__=='Error' (inherits from concurrent.futures._base.Error, the futures package base exception class; len('Error')==5); concurrent.futures.InvalidStateError.__name__=='InvalidStateError' (len=16; defined in _base.py alongside CancelledError); concurrent.futures.InvalidStateError.__module__=='concurrent.futures._base' (same module as CancelledError); concurrent.futures.InvalidStateError.__bases__[0].__name__=='Error' (same base class as CancelledError — both are direct subclasses of concurrent.futures._base.Error); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexc149

  columns: [id, function, args, expected, description]
  rows:
    - [cancel_name_eq,    "concurrent.futures.CancelledError.__name__.__eq__",                     ["CancelledError"],             true,  "concurrent.futures.CancelledError.__name__ == 'CancelledError' (len=14); verified with Python 3.14.3"]
    - [cancel_mod_eq,     "concurrent.futures.CancelledError.__module__.__eq__",                   ["concurrent.futures._base"],   true,  "concurrent.futures.CancelledError.__module__ == 'concurrent.futures._base' (len=24; custom exception, not builtin); verified with Python 3.14.3"]
    - [cancel_base_eq,  "concurrent.futures.CancelledError.__bases__[0].__name__.__eq__",           ["Error"],                      true,  "concurrent.futures.CancelledError.__bases__[0].__name__ == 'Error' (inherits from concurrent.futures._base.Error); verified with Python 3.14.3"]
    - [invstate_name_eq,  "concurrent.futures.InvalidStateError.__name__.__eq__",                  ["InvalidStateError"],          true,  "concurrent.futures.InvalidStateError.__name__ == 'InvalidStateError' (len=16); verified with Python 3.14.3"]
    - [invstate_mod_eq,   "concurrent.futures.InvalidStateError.__module__.__eq__",                ["concurrent.futures._base"],   true,  "concurrent.futures.InvalidStateError.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [invstate_base_eq,  "concurrent.futures.InvalidStateError.__bases__[0].__name__.__eq__",      ["Error"],                      true,  "concurrent.futures.InvalidStateError.__bases__[0].__name__ == 'Error' (same base as CancelledError); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures TimeoutError identity — extra149
#
# concurrent.futures.TimeoutError.__name__.__eq__('TimeoutError')  == True
# concurrent.futures.TimeoutError.__module__.__eq__('builtins')    == True
# concurrent.futures.TimeoutError.__bases__[0].__name__.__eq__('OSError') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra149.cf_timeout_identity:
  description: "concurrent.futures TimeoutError class identity checks in cftimeout149 namespace — concurrent.futures.TimeoutError.__name__=='TimeoutError' (len=12; note: concurrent.futures.TimeoutError IS the Python builtin TimeoutError, re-exported — unlike CancelledError which is a custom class in _base.py); concurrent.futures.TimeoutError.__module__=='builtins' (this confirms TimeoutError is the exact same object as the Python builtin TimeoutError, not a subclass); concurrent.futures.TimeoutError.__bases__[0].__name__=='OSError' (the builtin TimeoutError inherits from OSError; compare: CancelledError.__bases__[0].__name__=='Error' from concurrent.futures._base); the key contrast: CancelledError is in 'concurrent.futures._base' while TimeoutError is in 'builtins' — they are different kinds of exceptions despite both being in concurrent.futures; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftimeout149

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_name_eq,   "concurrent.futures.TimeoutError.__name__.__eq__",                       ["TimeoutError"],  true,  "concurrent.futures.TimeoutError.__name__ == 'TimeoutError' (len=12; is the Python builtin); verified with Python 3.14.3"]
    - [timeout_mod_eq,    "concurrent.futures.TimeoutError.__module__.__eq__",                     ["builtins"],      true,  "concurrent.futures.TimeoutError.__module__ == 'builtins' (IS the builtin TimeoutError, not a custom subclass); verified with Python 3.14.3"]
    - [timeout_base_eq,  "concurrent.futures.TimeoutError.__bases__[0].__name__.__eq__",           ["OSError"],       true,  "concurrent.futures.TimeoutError.__bases__[0].__name__ == 'OSError' (builtin TimeoutError inherits from OSError); verified with Python 3.14.3"]
    - [timeout_name_len,  "concurrent.futures.TimeoutError.__name__.__len__",                      [],                12,    "concurrent.futures.TimeoutError.__name__.__len__() == 12 ('TimeoutError'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures BrokenExecutor identity — extra149
#
# concurrent.futures.BrokenExecutor.__name__.__eq__('BrokenExecutor')      == True
# concurrent.futures.BrokenExecutor.__module__.__eq__('concurrent.futures._base') == True
# concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError') == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra149.cf_broken_executor_identity:
  description: "concurrent.futures BrokenExecutor class identity checks in cfbroken149 namespace — concurrent.futures.BrokenExecutor.__name__=='BrokenExecutor' (len=14; note: same len as CancelledError which is also 14 chars); concurrent.futures.BrokenExecutor.__module__=='concurrent.futures._base' (len=24; defined in _base.py like CancelledError and InvalidStateError); concurrent.futures.BrokenExecutor.__bases__[0].__name__=='RuntimeError' (BrokenExecutor inherits from RuntimeError, NOT from concurrent.futures._base.Error — unlike CancelledError and InvalidStateError which both inherit from Error; this reflects that a broken executor is a different kind of failure: a RuntimeError not a futures-specific error); BrokenExecutor is raised when an executor becomes unusable (e.g. a thread or process dies unexpectedly); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfbroken149

  columns: [id, function, args, expected, description]
  rows:
    - [broken_name_eq,    "concurrent.futures.BrokenExecutor.__name__.__eq__",                     ["BrokenExecutor"],             true,  "concurrent.futures.BrokenExecutor.__name__ == 'BrokenExecutor' (len=14); verified with Python 3.14.3"]
    - [broken_mod_eq,     "concurrent.futures.BrokenExecutor.__module__.__eq__",                   ["concurrent.futures._base"],   true,  "concurrent.futures.BrokenExecutor.__module__ == 'concurrent.futures._base' (len=24); verified with Python 3.14.3"]
    - [broken_base_eq,  "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__",          ["RuntimeError"],               true,  "concurrent.futures.BrokenExecutor.__bases__[0].__name__ == 'RuntimeError' (inherits from RuntimeError, not from Error); verified with Python 3.14.3"]
    - [broken_name_len,   "concurrent.futures.BrokenExecutor.__name__.__len__",                    [],                             14,    "concurrent.futures.BrokenExecutor.__name__.__len__() == 14 ('BrokenExecutor'; same len as 'CancelledError'=14); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra149
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra149.cf_CancelledError_module_is_base:
  description: "concurrent.futures.CancelledError.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures.CancelledError is defined in Lib/concurrent/futures/_base.py, NOT in builtins; this distinguishes it from concurrent.futures.TimeoutError which IS the builtin TimeoutError (TimeoutError.__module__=='builtins'); CancelledError.__module__=='concurrent.futures._base' (len=24); CancelledError inherits from concurrent.futures._base.Error (CancelledError.__bases__[0].__name__=='Error'); compare to asyncio.CancelledError (a different class also named CancelledError but in asyncio's namespace); NEW in extra149: first standalone concurrent.futures.CancelledError.__module__ identity invariant in cfexc149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.CancelledError.__module__.__eq__"
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra149.cf_TimeoutError_module_is_builtins:
  description: "concurrent.futures.TimeoutError.__module__.__eq__('builtins') returns True — concurrent.futures.TimeoutError IS the Python builtin TimeoutError object; it is re-exported from concurrent.futures._base which imports it from builtins; TimeoutError.__module__=='builtins' confirms this is the identical object; TimeoutError.__bases__[0].__name__=='OSError' (builtin inheritance); this is a notable asymmetry: CancelledError is a custom class in concurrent.futures._base (module='concurrent.futures._base') while TimeoutError is the unmodified builtin (module='builtins'); both are accessible as concurrent.futures.CancelledError and concurrent.futures.TimeoutError; NEW in extra149: first standalone concurrent.futures.TimeoutError.__module__ identity invariant in cftimeout149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.TimeoutError.__module__.__eq__"
  args: ["builtins"]
  expected: true

invariant concurrent_futures_extra149.cf_BrokenExecutor_bases0_RuntimeError:
  description: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__('RuntimeError') returns True — BrokenExecutor inherits from RuntimeError (not from concurrent.futures._base.Error); this contrasts with CancelledError and InvalidStateError which both inherit from concurrent.futures._base.Error; the design choice reflects that a broken executor is a programming/runtime error (RuntimeError) rather than a futures-specific exception type (Error); BrokenExecutor is raised when an executor's internal state becomes invalid, e.g. after a thread or worker process dies abnormally; BrokenExecutor subclasses include BrokenThreadPool (from thread.py) and BrokenProcessPool (from process.py); NEW in extra149: first standalone concurrent.futures.BrokenExecutor.__bases__[0] name identity invariant in cfbroken149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__"
  args: ["RuntimeError"]
  expected: true

invariant concurrent_futures_extra149.cf_InvalidStateError_name_eq:
  description: "concurrent.futures.InvalidStateError.__name__.__eq__('InvalidStateError') returns True — concurrent.futures.InvalidStateError is defined in Lib/concurrent/futures/_base.py; it is raised when a Future is in an invalid state for the operation being performed (e.g. calling result() on a cancelled future, or calling set_result() on an already-resolved future); InvalidStateError.__module__=='concurrent.futures._base' (len=24); InvalidStateError.__bases__[0].__name__=='Error' (inherits from concurrent.futures._base.Error, same base as CancelledError); InvalidStateError.__name__=='InvalidStateError' (len=16); NEW in extra149: first standalone concurrent.futures.InvalidStateError.__name__ identity invariant in cfexc149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.InvalidStateError.__name__.__eq__"
  args: ["InvalidStateError"]
  expected: true

invariant concurrent_futures_extra149.cf_CancelledError_bases0_name_is_Error:
  description: "concurrent.futures.CancelledError.__bases__[0].__name__.__eq__('Error') returns True — concurrent.futures.CancelledError directly inherits from concurrent.futures._base.Error; Error is the base exception class for the concurrent.futures package (Error.__bases__[0].__name__=='Exception'); the inheritance chain is: CancelledError > Error > Exception > BaseException; both CancelledError and InvalidStateError share the same base class (Error), while BrokenExecutor diverges by inheriting from RuntimeError instead; 'Error'.__len__()==5; CancelledError.__name__.__len__()==14; CancelledError.__module__.__len__()==24; NEW in extra149: first standalone concurrent.futures.CancelledError.__bases__[0] name identity invariant in cfexc149 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.CancelledError.__bases__[0].__name__.__eq__"
  args: ["Error"]
  expected: true
