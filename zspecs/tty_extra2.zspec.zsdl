spec: tty_extra2
version: ">=3.9"
backend: python_module(tty)

docs: https://docs.python.org/3/library/tty.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tty.html — Python tty module documentation"
    - "POSIX.1-2017 — termios(3) terminal I/O interface specification"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tty.py"
  notes:
    - "This spec extends tty.zspec.zsdl and tty_extra.zspec.zsdl."
    - "tty is a POSIX-only module (available on macOS and Linux; not available on Windows)."
    - "tty_extra covers IFLAG/OFLAG/CFLAG/LFLAG/CC class checks; ISPEED and OSPEED class checks are new here."
    - "Function __qualname__ checks are new here (tty and tty_extra do not cover __qualname__)."
    - "Function class type ('function') checks are new here."
    - "setraw and setcbreak are pure Python functions wrapping termios; __class__.__name__ == 'function'."
    - "All expected values verified by running Python 3.12 tty module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# ISPEED and OSPEED class checks — new here; tty_extra covers IFLAG/OFLAG/CFLAG/LFLAG/CC
# ---------------------------------------------------------------------------

invariant tty_extra2.ISPEED.class_is_int:
  description: "tty.ISPEED.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: ISPEED.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant tty_extra2.OSPEED.class_is_int:
  description: "tty.OSPEED.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: OSPEED.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# Function __qualname__ checks — not present in tty.zspec.zsdl or tty_extra.zspec.zsdl
# ---------------------------------------------------------------------------

invariant tty_extra2.setraw.qualname:
  description: "tty.setraw.__qualname__ == 'setraw' — top-level function, qualname matches name"
  category: function_names
  kind: python_call_eq
  function: setraw.__qualname__.__eq__
  args: ["setraw"]
  expected: true

invariant tty_extra2.setcbreak.qualname:
  description: "tty.setcbreak.__qualname__ == 'setcbreak' — top-level function, qualname matches name"
  category: function_names
  kind: python_call_eq
  function: setcbreak.__qualname__.__eq__
  args: ["setcbreak"]
  expected: true

# ---------------------------------------------------------------------------
# Function class type — setraw and setcbreak are Python-level functions
# ---------------------------------------------------------------------------

table tty_extra2.function_types:
  kind: python_call_eq
  category: function_types
  id_prefix: ftype

  columns: [id, function, args, expected]
  rows:
    - [setraw,    setraw.__class__.__name__.__eq__,    ["function"], true]
    - [setcbreak, setcbreak.__class__.__name__.__eq__, ["function"], true]

# ---------------------------------------------------------------------------
# All index constants as a compact class-check table
# (tty_extra has individual invariants; this table form is new)
# ---------------------------------------------------------------------------

table tty_extra2.constant_class_checks:
  kind: python_call_eq
  category: constants
  id_prefix: const_class

  columns: [id, function, args, expected]
  rows:
    - [IFLAG,  IFLAG.__class__.__name__.__eq__,  ["int"], true]
    - [OFLAG,  OFLAG.__class__.__name__.__eq__,  ["int"], true]
    - [CFLAG,  CFLAG.__class__.__name__.__eq__,  ["int"], true]
    - [LFLAG,  LFLAG.__class__.__name__.__eq__,  ["int"], true]
    - [ISPEED, ISPEED.__class__.__name__.__eq__, ["int"], true]
    - [OSPEED, OSPEED.__class__.__name__.__eq__, ["int"], true]
    - [CC,     CC.__class__.__name__.__eq__,     ["int"], true]

# ---------------------------------------------------------------------------
# Constant ordering sanity checks — indices must be strictly increasing
# ---------------------------------------------------------------------------

invariant tty_extra2.IFLAG.less_than_OFLAG:
  description: "tty.IFLAG < tty.OFLAG — IFLAG(0) precedes OFLAG(1) in the termios list"
  category: constants
  kind: python_call_eq
  function: IFLAG.__lt__
  args: [1]
  expected: true

invariant tty_extra2.CC.greater_than_OSPEED:
  description: "tty.CC > tty.OSPEED — CC(6) follows OSPEED(5) in the termios list"
  category: constants
  kind: python_call_eq
  function: CC.__gt__
  args: [5]
  expected: true
