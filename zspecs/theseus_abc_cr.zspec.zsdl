spec: theseus_abc_cr
version: ">=3.8"
backend: python_cleanroom(theseus_abc_cr)
blocks: abc

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "CPython source: Lib/abc.py (internal implementation)"
  notes:
    - "Clean-room abc module. Do NOT import abc."
    - "ABCMeta: metaclass for abstract base classes."
    - "abstractmethod: decorator to declare abstract methods."
    - "ABC: convenience base class using ABCMeta."

error_model: python_exceptions

invariant theseus_abc_cr.abc2_abstract:
  description: "instantiating class with unimplemented abstractmethod raises TypeError"
  category: abstractmethod
  kind: python_call_eq
  function: abc2_abstract
  args: []
  expected: true

invariant theseus_abc_cr.abc2_concrete:
  description: "class implementing all abstract methods can be instantiated"
  category: abstractmethod
  kind: python_call_eq
  function: abc2_concrete
  args: []
  expected: true

invariant theseus_abc_cr.abc2_isinstance:
  description: "ABC subclass registration makes isinstance return True"
  category: ABCMeta
  kind: python_call_eq
  function: abc2_isinstance
  args: []
  expected: true
