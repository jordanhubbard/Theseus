spec: itertools_extra222
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools module-level __name__ identity and C-type __module__ attribute contracts."
    - "itertools.__name__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.chain.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.cycle.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.count.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.repeat.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.product.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.combinations.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.permutations.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.accumulate.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.compress.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.takewhile.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.islice.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.starmap.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "itertools.groupby.__module__ == 'itertools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools module __name__ identity
#
# Verified with Python 3.14.3:
#   itertools.__name__ == 'itertools'
# ---------------------------------------------------------------------------

table itertools_extra222.module_name:
  description: "itertools module __name__ identity check; new to extra222"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra222modname

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_eq,
       __name__.__eq__,
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — itertools is a top-level built-in C extension module; __name__ attribute is the string 'itertools'; str.__eq__('itertools') returns True; new to extra222"]

# ---------------------------------------------------------------------------
# Table 2: itertools C-type __module__ attribute checks (chain through groupby)
#
# Verified with Python 3.14.3: all C-types have __module__ == 'itertools'
#   chain, cycle, count, repeat, product, combinations, permutations,
#   accumulate, compress, dropwhile, takewhile, islice, starmap, groupby
# ---------------------------------------------------------------------------

