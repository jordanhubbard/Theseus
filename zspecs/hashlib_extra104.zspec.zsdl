spec: hashlib_extra104
version: ">=3.9"
backend: python_module(hashlib)
extends: hashlib_extra99

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra99.zspec.zsdl — covers hashlib.md5/sha1/sha224/sha256/sha384/sha512 __class__.__name__=='builtin_function_or_method' and __name__ equality / blake2b/blake2s __class__.__name__=='type' and __module__=='_blake2' and __qualname__ equality / new __class__.__name__=='function' / algorithms_guaranteed.__len__()==14 (tables + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers hashlib.sha3_*/shake_* constructor __qualname__ and __module__ equality / sha3_*/shake_* __class__.__name__=='builtin_function_or_method' / file_digest function identity / hashlib.__all__ class name and length (table + invariants)."
    - "hashlib_extra97.zspec.zsdl — covers hashlib.algorithms_guaranteed membership for 14 algorithms / algorithms_available membership / new/__qualname__/__len__() (table + invariants)."
    - "hashlib_extra96.zspec.zsdl — covers hashlib.__name__/__package__/__spec__/__loader__/__doc__ module identity equality / sha256/sha512/sha1/md5 __module__ cross-checks (table + invariants)."
    - "hashlib_extra95.zspec.zsdl — covers hashlib.new/__qualname__ / sha256/sha512/sha1/md5/sha224/sha384/sha3_256/sha3_512 __qualname__ and __module__ (table + invariants)."
  notes:
    - "This spec extends hashlib through hashlib_extra99; it does NOT duplicate invariants present in those files."
    - "Wave 264 theme: hashlib module __spec__ and __loader__ attribute lengths + sub-component __module__ lengths."
    - "hashlib.__name__.__len__() == 7 ('hashlib'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.name.__len__() == 7 ('hashlib'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.__class__.__name__.__len__() == 10 ('ModuleSpec'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__loader__.__class__.__name__.__len__() == 16 ('SourceFileLoader'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.has_location == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.name.__eq__('hashlib') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__.__len__() == 8 ('_hashlib'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__.__len__() == 7 ('_blake2'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__.__len__() == 7 ('hashlib'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.__spec__.has_location is True because hashlib is a source file (Lib/hashlib.py) and the spec tracks its origin file path."
    - "Note: hashlib.__spec__.name equals hashlib.__name__ ('hashlib') — both identify the module by its canonical dotted name."
    - "Note: md5.__module__.__len__()==8 ('_hashlib') is longer than blake2b.__module__.__len__()==7 ('_blake2') by 1 char."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__name__.__len__()==7
# hashlib.__spec__.name.__len__()==7
# hashlib.__spec__.__class__.__name__.__len__()==10
# hashlib.__loader__.__class__.__name__.__len__()==16
#
# Wave 264 theme: hashlib module attribute name lengths.
#
# hashlib.__name__ is 'hashlib' (7 chars). __spec__.name is also 'hashlib' (7),
# confirming the spec's canonical module name matches __name__. __spec__.__class__.__name__
# is 'ModuleSpec' (10 chars) — the importlib machinery spec class. __loader__.__class__.__name__
# is 'SourceFileLoader' (16 chars). hashlib_extra96 anchors equality checks for
# __name__/__package__/__spec__/__loader__; no prior spec anchors __len__() for
# these under hashlibmodlen104. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra104.hashlib_module_attr_name_lengths:
  description: "hashlib.__name__/__len__()==7 / __spec__.name/__len__()==7 / __spec__/__class__.__name__/__len__()==10 / __loader__/__class__.__name__/__len__()==16 — __name__ and __spec__.name share length 7; 'ModuleSpec' is 10 chars; 'SourceFileLoader' is 16 chars; extra96 anchors equality; first hashlibmodlen104 anchor for module attribute name lengths"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashlibmodlen104

  columns: [id, function, args, expected, description]
  rows:
    - [name_len,              __name__.__len__,                            [], 7,  "'hashlib' is 7 chars"]
    - [spec_name_len,         __spec__.name.__len__,                       [], 7,  "__spec__.name is 'hashlib', also 7 chars"]
    - [spec_class_name_len,   __spec__.__class__.__name__.__len__,         [], 10, "'ModuleSpec' is 10 chars"]
    - [loader_class_name_len, __loader__.__class__.__name__.__len__,       [], 16, "'SourceFileLoader' is 16 chars"]

# ---------------------------------------------------------------------------
# hashlib.__spec__.has_location == True
# hashlib.__spec__.name.__eq__('hashlib')
#
# Wave 264 theme: hashlib __spec__ location and name equality.
#
# hashlib.__spec__.has_location is True because hashlib.py is a source file
# with a known file-system path. __spec__.name is 'hashlib', matching __name__.
# Together these confirm the module is a regular source file with a known origin.
# hashlib_extra96 anchors __spec__.__class__.__name__.__eq__('ModuleSpec');
# no prior spec anchors has_location or __spec__.name equality under hashlibmodlen104.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra104.hashlib_spec_location_and_name:
  description: "hashlib.__spec__.has_location==True / __spec__.name/__eq__('hashlib')==True — has_location is True because hashlib.py is a source file with a known path; __spec__.name equals __name__ (both 'hashlib'); extra96 anchors __spec__.__class__.__name__; first hashlibmodlen104 anchor for has_location and __spec__.name equality"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashlibmodlen104

  columns: [id, function, args, expected, description]
  rows:
    - [spec_has_location, __spec__.has_location.__eq__, [true],      true, "has_location is True: hashlib.py has a known file-system path"]
    - [spec_name_eq,      __spec__.name.__eq__,         ["hashlib"], true, "__spec__.name is 'hashlib', equal to __name__"]

# ---------------------------------------------------------------------------
# hashlib.md5.__module__.__len__()==8
# hashlib.blake2b.__module__.__len__()==7
# hashlib.new.__module__.__len__()==7
#
# Wave 264 theme: hashlib sub-component __module__ string lengths.
#
# md5.__module__ is '_hashlib' (8 chars): the underscore + 'hashlib' = 8.
# blake2b.__module__ is '_blake2' (7 chars): underscore + 'blake2' = 7.
# new.__module__ is 'hashlib' (7 chars): the pure-Python module name itself.
# blake2b.__module__.__len__() and new.__module__.__len__() both equal 7 but for
# different reasons — one is a C extension name, the other is the module name.
# hashlib_extra96 anchors __module__.__eq__('_hashlib') for md5/sha256/sha1/sha512;
# hashlib_extra99 anchors blake2b.__module__.__eq__('_blake2') and new.__module__
# __eq__('hashlib'); no prior spec anchors __module__.__len__() for these
# sub-components under hashlibmodlen104. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra104.hashlib_subcomponent_module_lengths:
  description: "hashlib.md5/__module__/__len__()==8 / blake2b/__module__/__len__()==7 / new/__module__/__len__()==7 — '_hashlib' is 8 chars; '_blake2' is 7 chars; 'hashlib' is 7 chars; blake2b and new share __module__.__len__()==7 for different reasons; extra96 anchors md5.__module__.__eq__('_hashlib'); extra99 anchors blake2b/new __module__ equality; first hashlibmodlen104 anchor for sub-component __module__ lengths"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashlibmodlen104

  columns: [id, function, args, expected, description]
  rows:
    - [md5_module_len,    md5.__module__.__len__,    [], 8, "'_hashlib' is 8 chars (OpenSSL C extension)"]
    - [blake2b_module_len, blake2b.__module__.__len__, [], 7, "'_blake2' is 7 chars (BLAKE2 C extension)"]
    - [new_module_len,    new.__module__.__len__,    [], 7, "'hashlib' is 7 chars (pure-Python wrapper)"]

# ---------------------------------------------------------------------------
# hashlib.__spec__.name.__len__()==7 — standalone
#
# hashlib.__spec__.name.__len__() is 7. __spec__.name is 'hashlib', the canonical
# dotted name used by importlib to identify the module. For top-level modules this
# equals __name__; both are 7 chars. The ModuleSpec.name attribute is set when
# the module is imported and remains the authoritative identifier for the module
# in the import system. hashlib_extra96 anchors __spec__.__class__.__name__.__eq__
# ('ModuleSpec'); no prior spec anchors __spec__.name.__len__()==7 as a standalone
# under hashlibmodlen104. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra104.spec_name_len_7:
  description: "hashlib.__spec__.name.__len__() == 7 — __spec__.name is 'hashlib' (7 chars); the canonical dotted name used by importlib; for top-level modules equals __name__; extra96 anchors __spec__.__class__.__name__.__eq__('ModuleSpec'); first standalone for __spec__.name.__len__() under hashlibmodlen104"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# hashlib.__spec__.has_location == True — standalone
#
# hashlib.__spec__.has_location is True. The has_location property on a ModuleSpec
# returns True when the spec's origin is a real file-system path (i.e., the module
# has a __file__ attribute pointing to a source or bytecode file). For hashlib,
# which is a pure-Python source module (Lib/hashlib.py), this is True. Contrast
# with C extension modules built into the interpreter, which may return False.
# hashlib_extra96 anchors __spec__.__class__.__name__.__eq__('ModuleSpec');
# no prior spec anchors has_location as a standalone under hashlibmodlen104.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra104.spec_has_location_true:
  description: "hashlib.__spec__.has_location.__eq__(True) == True — has_location is True because hashlib.py is a source file with a known file-system path; contrasts with built-in C modules that may lack a file path; extra96 anchors __spec__.__class__.__name__.__eq__('ModuleSpec'); first standalone for has_location under hashlibmodlen104"
  category: module_identity
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5.__module__.__len__()==8 — standalone
#
# hashlib.md5.__module__.__len__() is 8. md5.__module__ is '_hashlib': the
# leading underscore plus 'hashlib' gives 8 characters. This naming convention
# (_hashlib) marks it as a private C extension implementing the public-facing
# hashlib API. By contrast, blake2b.__module__ is '_blake2' (7 chars) and
# new.__module__ is 'hashlib' (7 chars). hashlib_extra96 anchors md5.__module__
# .__eq__('_hashlib'); no prior spec anchors md5.__module__.__len__()==8
# as a standalone under hashlibmodlen104. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra104.md5_module_len_8:
  description: "hashlib.md5.__module__.__len__() == 8 — md5.__module__ is '_hashlib' (8 chars): underscore + 'hashlib'; longer than blake2b.__module__ '_blake2' (7) by 1 char; extra96 anchors md5.__module__.__eq__('_hashlib'); first standalone for md5.__module__.__len__() under hashlibmodlen104"
  category: module_identity
  kind: python_call_eq
  function: md5.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# hashlib.__loader__.__class__.__name__.__len__()==16 — standalone
#
# hashlib.__loader__.__class__.__name__.__len__() is 16. The class name is
# 'SourceFileLoader' — 16 characters. This is the importlib machinery class
# responsible for loading Python source files (.py) from the filesystem.
# hashlib_extra96 anchors __loader__.__class__.__name__.__eq__('SourceFileLoader');
# no prior spec anchors __loader__.__class__.__name__.__len__()==16 as a
# standalone under hashlibmodlen104. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra104.loader_class_name_len_16:
  description: "hashlib.__loader__.__class__.__name__.__len__() == 16 — 'SourceFileLoader' is 16 chars; the importlib class that loads .py source files; extra96 anchors __loader__.__class__.__name__.__eq__('SourceFileLoader'); first standalone for __loader__.__class__.__name__.__len__() under hashlibmodlen104"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__len__
  args: []
  expected: 16
