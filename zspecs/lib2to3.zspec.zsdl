spec: lib2to3
version: ">=3.3,<3.13"
backend: python_module(lib2to3.refactor)

docs: https://docs.python.org/3/library/2to3.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/2to3.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "lib2to3.refactor source: Lib/lib2to3/refactor.py (PSF; source inspection permitted)"
  not_derived_from:
    - "lib2to3 source: internal fixer implementations"
  notes:
    - "lib2to3 is the Python 2-to-3 automated refactoring framework, deprecated in 3.11 and removed in 3.13."
    - "lib2to3.refactor provides RefactoringTool and MultiprocessRefactoringTool as the primary public classes."
    - "RefactoringTool orchestrates the loading of fixers and the traversal/rewriting of source trees."
    - "MultiprocessRefactoringTool extends RefactoringTool to parallelize refactoring across multiple processes."
    - "RefactoringTool exposes: get_fixers, refactor, refactor_file, refactor_string, refactor_tree, write_file."
    - "lib2to3.pygram exposes python_grammar, python_grammar_no_print_statement, and pattern_grammar."
    - "All expected values verified by running Python 3.12 lib2to3.refactor module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "RefactoringTool raises lib2to3.refactor.RefactoringError on unrecoverable parse failures."
  stderr: "null"
  stickiness: "N/A — class construction and method lookup are stateless checks."
  codes: {}

# ---------------------------------------------------------------------------
# Class name checks — RefactoringTool
# ---------------------------------------------------------------------------

invariant lib2to3.RefactoringTool_name:
  description: "RefactoringTool.__name__ == 'RefactoringTool'"
  category: classnames
  kind: python_call_eq
  function: RefactoringTool.__name__.__eq__
  args: ["RefactoringTool"]
  expected: true

invariant lib2to3.RefactoringTool_module:
  description: "RefactoringTool.__module__ == 'lib2to3.refactor'"
  category: classnames
  kind: python_call_eq
  function: RefactoringTool.__module__.__eq__
  args: ["lib2to3.refactor"]
  expected: true

# ---------------------------------------------------------------------------
# Class name checks — MultiprocessRefactoringTool
# ---------------------------------------------------------------------------

invariant lib2to3.MultiprocessRefactoringTool_name:
  description: "MultiprocessRefactoringTool.__name__ == 'MultiprocessRefactoringTool'"
  category: classnames
  kind: python_call_eq
  function: MultiprocessRefactoringTool.__name__.__eq__
  args: ["MultiprocessRefactoringTool"]
  expected: true

invariant lib2to3.MultiprocessRefactoringTool_module:
  description: "MultiprocessRefactoringTool.__module__ == 'lib2to3.refactor'"
  category: classnames
  kind: python_call_eq
  function: MultiprocessRefactoringTool.__module__.__eq__
  args: ["lib2to3.refactor"]
  expected: true

# ---------------------------------------------------------------------------
# Class hierarchy
# ---------------------------------------------------------------------------

invariant lib2to3.MultiprocessRefactoringTool_base:
  description: "MultiprocessRefactoringTool.__bases__[0].__name__ == 'RefactoringTool'"
  category: hierarchy
  kind: python_call_eq
  function: MultiprocessRefactoringTool.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "RefactoringTool"

# ---------------------------------------------------------------------------
# Method name checks on RefactoringTool
# ---------------------------------------------------------------------------

table lib2to3.RefactoringTool.method_names:
  kind: python_call_eq
  category: methods
  id_prefix: method_name

  columns: [id, function, args, expected]
  rows:
    - [get_fixers,     RefactoringTool.get_fixers.__name__.__eq__,     ["get_fixers"],     true]
    - [refactor,       RefactoringTool.refactor.__name__.__eq__,       ["refactor"],       true]
    - [refactor_file,  RefactoringTool.refactor_file.__name__.__eq__,  ["refactor_file"],  true]
    - [refactor_string,RefactoringTool.refactor_string.__name__.__eq__,["refactor_string"],true]
    - [refactor_tree,  RefactoringTool.refactor_tree.__name__.__eq__,  ["refactor_tree"],  true]
    - [write_file,     RefactoringTool.write_file.__name__.__eq__,     ["write_file"],     true]

