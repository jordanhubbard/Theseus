spec: html_extra9
version: ">=3.9"
backend: python_module(html)

docs: https://docs.python.org/3/library/html.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/html.html — Python html module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/html/__init__.py"
    - "html.zspec.zsdl — covers escape/unescape with <, >, &, dquote, squote, compound, numeric entities, edge cases"
    - "html_extra.zspec.zsdl — covers escape.__name__, unescape.__name__, escape.__module__, unescape.__module__"
    - "html_extra2.zspec.zsdl — covers escape('<div>'), unescape('&lt;div&gt;'), quote=False/True, apos entity, hex numeric ref"
    - "html_extra3.zspec.zsdl — covers name2codepoint/codepoint2name entity values, CDATA_CONTENT_ELEMENTS type, unescape(&amp;/&lt;/&gt;), escape('<>&')"
    - "html_extra4.zspec.zsdl — covers escape.__qualname__, unescape.__qualname__, escape('<script>'), escape positional bool args, unescape('&lt;b&gt;'), unescape('&quot;')"
    - "html_extra5.zspec.zsdl — covers HTMLParser.__qualname__, HTMLParser method __qualname__ (feed/reset/close/getpos/handle_starttag/handle_endtag/handle_data/handle_comment), HTMLParser.__class__.__name__, HTMLParser.__bases__[0].__name__"
    - "html_extra6.zspec.zsdl — covers escape/unescape __class__.__name__, return types, non-ASCII passthrough, mixed entity/text unescape, numeric char refs, codepoint2name lt/gt/quot/nbsp"
    - "html_extra7.zspec.zsdl — covers escape.__name__, unescape.__name__, escape.__module__, unescape.__module__, escape('<b>hello</b>'), escape('\"hello\"' quote=True), unescape('&lt;b&gt;'), unescape('&amp;')"
    - "html_extra8.zspec.zsdl — covers HTMLParser.__bases__[0].__name__=='ParserBase', HTMLParser.__bases__[0].__module__=='_markupbase', escape plain-text no-op, unescape &copy; named/decimal, function __module__ table"
    - "html_entities.zspec.zsdl — covers html5.__class__.__name__=='dict', html5['amp;']/'lt;'/'gt;'/'quot;', name2codepoint/codepoint2name lookups, entitydefs lookups"
  notes:
    - "This spec extends all prior html specs through html_extra8.zspec.zsdl."
    - "Focus: HTMLParser method __qualname__ not yet in any prior spec (handle_entityref, handle_charref, handle_decl, unknown_decl); html.entities.html5 length check."
    - "HTMLParser.handle_entityref.__qualname__ == 'HTMLParser.handle_entityref' — stub method for named entities without semicolons."
    - "HTMLParser.handle_charref.__qualname__ == 'HTMLParser.handle_charref' — stub for numeric character references."
    - "HTMLParser.handle_decl.__qualname__ == 'HTMLParser.handle_decl' — stub for DOCTYPE declarations."
    - "HTMLParser.unknown_decl.__qualname__ == 'HTMLParser.unknown_decl' — stub for unknown SGML declarations."
    - "len(html.entities.html5) == 2231 — total number of HTML5 named character references; exact count verified on Python 3.12."
    - "len(html.entities.html5) >= 2000 — lower-bound check for forward-compatibility with future Python releases."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTMLParser method __qualname__ — stub handler methods not in html_extra5
#
# html_extra5 covers: feed, reset, close, getpos, handle_starttag,
# handle_endtag, handle_data, handle_comment.
# Not yet covered: handle_entityref, handle_charref, handle_decl, unknown_decl.
# Verified at runtime with Python 3.12.
# ---------------------------------------------------------------------------

table html_extra9.HTMLParser.stub_method_qualnames:
  description: "__qualname__ for HTMLParser stub handler methods not in html_extra5"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mqname9

  columns: [id, function, args, expected]
  rows:
    - [handle_entityref,  "parser.HTMLParser.handle_entityref.__qualname__.__eq__",  ["HTMLParser.handle_entityref"],  true]
    - [handle_charref,    "parser.HTMLParser.handle_charref.__qualname__.__eq__",    ["HTMLParser.handle_charref"],    true]
    - [handle_decl,       "parser.HTMLParser.handle_decl.__qualname__.__eq__",       ["HTMLParser.handle_decl"],       true]
    - [unknown_decl,      "parser.HTMLParser.unknown_decl.__qualname__.__eq__",      ["HTMLParser.unknown_decl"],      true]

# ---------------------------------------------------------------------------
# html.entities.html5 — length check
#
# html_entities.zspec.zsdl covers html5.__class__.__name__ == 'dict' and
# spot-checks specific key lookups (amp;, lt;, gt;, quot;, nbsp;).
# No prior spec verifies the total number of entries in the html5 mapping.
# Python 3.12 contains exactly 2231 HTML5 named character references.
# The __ge__ check provides a forward-compatible lower bound.
# ---------------------------------------------------------------------------

invariant html_extra9.html5.len_exact:
  description: "len(html.entities.html5) == 2231 — total HTML5 named character references in Python 3.12"
  category: entities
  kind: python_call_eq
  function: entities.html5.__len__
  args: []
  expected: 2231

invariant html_extra9.html5.len_ge_2000:
  description: "len(html.entities.html5) >= 2000 — lower bound; html5 mapping has at least 2000 entries"
  category: entities
  kind: python_call_eq
  function: entities.html5.__len__
  args: []
  method: __ge__
  method_args: [2000]
  expected: true
