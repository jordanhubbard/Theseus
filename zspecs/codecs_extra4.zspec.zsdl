spec: codecs_extra4
version: ">=3.9"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codecs.html — Python codecs module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_codecsmodule.c"
    - "CPython source: Lib/codecs.py"
  notes:
    - "This spec extends prior codecs specs."
    - "Focus: __module__ and __name__ for codecs functions; encode/decode behavior for common codecs."
    - "codecs.encode(b'hello', 'hex') == b'68656c6c6f'."
    - "codecs.decode(b'68656c6c6f', 'hex') == b'hello'."
    - "codecs.encode('hello', 'utf-8') == b'hello'."
    - "codecs.lookup('utf-8').__class__.__name__ == 'CodecInfo'."
    - "CodecInfo.__name__ == 'CodecInfo'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

table codecs_extra4.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: fname

  columns: [id, function, args, expected]
  rows:
    - [encode,   encode.__name__.__eq__,   ["encode"],   true]
    - [decode,   decode.__name__.__eq__,   ["decode"],   true]
    - [lookup,   lookup.__name__.__eq__,   ["lookup"],   true]
    - [register, register.__name__.__eq__, ["register"], true]
    - [open,     open.__name__.__eq__,     ["open"],     true]

invariant codecs_extra4.encode.utf8_bytes_type:
  description: "codecs.encode('hello', 'utf-8').__class__.__name__ == 'bytes'"
  category: encode
  kind: python_call_eq
  function: encode
  args: ["hello", "utf-8"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["bytes"]
  expected: true

invariant codecs_extra4.decode.utf8_string_type:
  description: "codecs.decode(b'hello', 'utf-8').__class__.__name__ == 'str'"
  category: decode
  kind: python_call_eq
  function: decode
  args: [!hex 68656c6c6f, "utf-8"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant codecs_extra4.lookup.codec_info_class:
  description: "codecs.lookup('utf-8').__class__.__name__ == 'CodecInfo'"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["utf-8"]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["CodecInfo"]
  expected: true

invariant codecs_extra4.lookup.utf8_name:
  description: "codecs.lookup('utf-8').name == 'utf-8'"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["utf-8"]
  method: name.__eq__
  method_args: ["utf-8"]
  expected: true

invariant codecs_extra4.lookup.ascii_name:
  description: "codecs.lookup('ascii').name == 'ascii'"
  category: lookup
  kind: python_call_eq
  function: lookup
  args: ["ascii"]
  method: name.__eq__
  method_args: ["ascii"]
  expected: true

invariant codecs_extra4.CodecInfo.class_name:
  description: "codecs.CodecInfo.__name__ == 'CodecInfo'"
  category: class_names
  kind: python_call_eq
  function: CodecInfo.__name__.__eq__
  args: ["CodecInfo"]
  expected: true

invariant codecs_extra4.CodecInfo.module:
  description: "codecs.CodecInfo.__module__ == 'codecs'"
  category: module
  kind: python_call_eq
  function: CodecInfo.__module__.__eq__
  args: ["codecs"]
  expected: true
