  id_prefix: ab2251

  columns: [id, function, args, expected]
  rows:
    - ["ab2251010", "abc.ABCMeta.__dict__.__contains__", ["__defaults__"], false]
    - ["ab2251011", "abc.ABC.__dict__.__contains__", ["__defaults__"], false]
    - ["ab2251012", "abc.abstractmethod.__dict__.__contains__", ["__defaults__"], false]

# ---------------------------------------------------------------------------
# Table 5: __kwdefaults__ dict-presence — abc.ABCMeta, abc.ABC, abc.abstractmethod
#
# __kwdefaults__ is NOT in the __dict__ of any abc construct. __kwdefaults__
# is a function-object attribute holding keyword-only parameter defaults.
# Class and metaclass objects do not carry this entry. All 3 return False.
# ---------------------------------------------------------------------------

table abc_extra2251.kwdefaults_dict_presence:
