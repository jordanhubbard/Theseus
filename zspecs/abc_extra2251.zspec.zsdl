  rows:
    - ["ab2251019", "abc.ABCMeta.__dict__.__contains__", ["__builtins__"], false]
    - ["ab2251020", "abc.ABC.__dict__.__contains__", ["__builtins__"], false]
    - ["ab2251021", "abc.abstractmethod.__dict__.__contains__", ["__builtins__"], false]

