spec: abc_extra2251
version: ">=3.9"
backend: python_module(abc)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py, Modules/_abc.c"
  notes:
    - "Wave 2251 (_extra2251): callable protocol and function-attribute dict-presence — __call__, __code__, __globals__, __defaults__, __kwdefaults__, __annotations__, __builtins__ checks."
    - "Classes checked: abc.ABCMeta, abc.ABC, abc.abstractmethod."
    - "abc.ABCMeta is a metaclass (type subclass); abc.ABC is a helper base class; abc.abstractmethod is a decorator function/class."
    - "__call__ is NOT in __dict__ for ABCMeta or ABC — neither defines a __call__ in its own class body. __call__ is also NOT in abstractmethod.__dict__ (abstractmethod defines __call__ via inheritance from type, not its own body)."
    - "__code__ is NOT in __dict__ for any of these — __code__ is a function-object attribute, not stored in class __dict__."
    - "__globals__ is NOT in __dict__ for any of these — __globals__ is a function-object attribute referencing module globals."
    - "__defaults__ is NOT in __dict__ for any of these — __defaults__ is a function-object attribute for positional-parameter defaults."
    - "__kwdefaults__ is NOT in __dict__ for any of these — __kwdefaults__ is a function-object attribute for keyword-only defaults."
    - "__annotations__ is NOT in __dict__ for any of these — none of the three class bodies declare annotated class-level variables."
    - "__builtins__ is NOT in __dict__ for any of these — __builtins__ is a module-level name, never a class __dict__ entry."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __call__ dict-presence — abc.ABCMeta, abc.ABC, abc.abstractmethod
#
# __call__ is NOT in the __dict__ of any of the three abc constructs.
# ABCMeta inherits __call__ from type (the metaclass of all metaclasses)
# but does not define it in its own class body. ABC and abstractmethod
# likewise do not carry __call__ in their own __dict__. All 3 return False.
# ---------------------------------------------------------------------------

table abc_extra2251.call_dict_presence:
  description: "__call__ dict-presence for abc.ABCMeta, abc.ABC, abc.abstractmethod — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2251

  columns: [id, function, args, expected]
  rows:
    - ["ab2251001", "abc.ABCMeta.__dict__.__contains__", ["__call__"], false]
    - ["ab2251002", "abc.ABC.__dict__.__contains__", ["__call__"], false]
    - ["ab2251003", "abc.abstractmethod.__dict__.__contains__", ["__call__"], false]

# ---------------------------------------------------------------------------
# Table 2: __code__ dict-presence — abc.ABCMeta, abc.ABC, abc.abstractmethod
#
# __code__ is NOT in the __dict__ of any abc construct. __code__ is an
# attribute of plain function objects (holding the code object). Class
# objects and metaclasses do not store this in their __dict__. All 3 False.
# ---------------------------------------------------------------------------

table abc_extra2251.code_dict_presence:
  description: "__code__ dict-presence for abc.ABCMeta, abc.ABC, abc.abstractmethod — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2251

  columns: [id, function, args, expected]
  rows:
    - ["ab2251004", "abc.ABCMeta.__dict__.__contains__", ["__code__"], false]
    - ["ab2251005", "abc.ABC.__dict__.__contains__", ["__code__"], false]
    - ["ab2251006", "abc.abstractmethod.__dict__.__contains__", ["__code__"], false]

# ---------------------------------------------------------------------------
# Table 3: __globals__ dict-presence — abc.ABCMeta, abc.ABC, abc.abstractmethod
#
# __globals__ is NOT in the __dict__ of any abc construct. __globals__ is a
# function-object attribute that references the global namespace of the module
# where the function was defined. Class objects do not store this. All 3 False.
# ---------------------------------------------------------------------------

table abc_extra2251.globals_dict_presence:
  description: "__globals__ dict-presence for abc.ABCMeta, abc.ABC, abc.abstractmethod — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab2251

  columns: [id, function, args, expected]
  rows:
    - ["ab2251007", "abc.ABCMeta.__dict__.__contains__", ["__globals__"], false]
    - ["ab2251008", "abc.ABC.__dict__.__contains__", ["__globals__"], false]
    - ["ab2251009", "abc.abstractmethod.__dict__.__contains__", ["__globals__"], false]

# ---------------------------------------------------------------------------
# Table 4: __defaults__ dict-presence — abc.ABCMeta, abc.ABC, abc.abstractmethod
#
# __defaults__ is NOT in the __dict__ of any abc construct. __defaults__ is a
# function-object attribute holding a tuple of default values for positional
# parameters. Class and metaclass objects do not carry this. All 3 return False.
# ---------------------------------------------------------------------------

table abc_extra2251.defaults_dict_presence:
  description: "__defaults__ dict-presence for abc.ABCMeta, abc.ABC, abc.abstractmethod — all False"
