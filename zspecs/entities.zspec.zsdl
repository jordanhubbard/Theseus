spec: entities
version: ">=4.0.0"
backend: node(entities)

docs: https://www.npmjs.com/package/entities

provenance:
  derived_from:
    - "entities README — https://www.npmjs.com/package/entities"
    - "Test vectors verified with entities via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "entities source"
  notes:
    - "entities is an npm package. Install: npm install entities"
    - "decodeHTML(str) decodes HTML entities to their character equivalents."
    - "encodeHTML(str) encodes special characters as HTML entities."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns encoded or decoded string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table entities.decodeHTML:
  kind: node_module_call_eq
  function: decodeHTML
  category: decode
  id_prefix: entd

  columns: [id, args, expected]
  rows:
    - [basic,   ["&amp; &lt; &gt;"],   "& < >"]
    - [plain,   ["hello world"],       "hello world"]
    - [quot,    ["&quot;hello&quot;"], "\"hello\""]

table entities.encodeHTML:
  kind: node_module_call_eq
  function: encodeHTML
  category: encode
  id_prefix: ente

  columns: [id, args, expected]
  rows:
    - [basic,   ["& < >"],     "&amp; &lt; &gt;"]
    - [plain,   ["hello"],     "hello"]
    - [quotes,  ["\"hello\""], "&quot;hello&quot;"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:39:14Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
