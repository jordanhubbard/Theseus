spec: itertools_extra410
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.chain.__doc__.__len__() == 190 — chain is a C type with a 190-character docstring. Verified with Python 3.14.0."
    - "itertools.count.__doc__.__len__() == 205 — count is a C type with a 205-character docstring. Verified with Python 3.14.0."
    - "itertools.product.__doc__.__len__() == 681 — product is a C type with a 681-character docstring. Verified with Python 3.14.0."
    - "itertools.permutations.__doc__.__len__() == 140 — permutations is a C type with a 140-character docstring. Verified with Python 3.14.0."
    - "itertools.combinations.__doc__.__len__() == 134 — combinations is a C type with a 134-character docstring. Verified with Python 3.14.0."
    - "itertools.islice.__doc__.__len__() == 453 — islice is a C type with a 453-character docstring. Verified with Python 3.14.0."
    - "itertools.repeat.__doc__.__len__() == 154 — repeat is a C type with a 154-character docstring. Verified with Python 3.14.0."
    - "All expected values verified by running Python 3.14.0 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C type docstring lengths
#
# itertools.chain, count, product, permutations, combinations, islice, and
# repeat are all C types that carry non-empty docstrings. The __len__()
# method on the str docstring returns the exact character count. All values
# verified with Python 3.14.0 on macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table itertools_extra410.type_doc_len:
  description: "itertools C type __doc__.__len__() values — non-empty docstrings on chain, count, product, permutations, combinations, islice, repeat; new to extra410"
  kind: python_call_eq
  category: introspection
  id_prefix: itertoolsdl410

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_len_eq,
       "chain.__doc__.__len__",
       [],
       190,
       "itertools.chain.__doc__.__len__() == 190 — chain is a C type with a 190-character docstring; __len__() returns 190; new to extra410"]
    - [count_doc_len_eq,
       "count.__doc__.__len__",
       [],
       205,
       "itertools.count.__doc__.__len__() == 205 — count is a C type with a 205-character docstring; __len__() returns 205; new to extra410"]
    - [product_doc_len_eq,
       "product.__doc__.__len__",
       [],
       681,
       "itertools.product.__doc__.__len__() == 681 — product is a C type with a 681-character docstring; __len__() returns 681; new to extra410"]
    - [permutations_doc_len_eq,
       "permutations.__doc__.__len__",
       [],
       140,
       "itertools.permutations.__doc__.__len__() == 140 — permutations is a C type with a 140-character docstring; __len__() returns 140; new to extra410"]
    - [combinations_doc_len_eq,
       "combinations.__doc__.__len__",
       [],
       134,
       "itertools.combinations.__doc__.__len__() == 134 — combinations is a C type with a 134-character docstring; __len__() returns 134; new to extra410"]
    - [islice_doc_len_eq,
       "islice.__doc__.__len__",
       [],
       453,
       "itertools.islice.__doc__.__len__() == 453 — islice is a C type with a 453-character docstring; __len__() returns 453; new to extra410"]
    - [repeat_doc_len_eq,
       "repeat.__doc__.__len__",
       [],
       154,
       "itertools.repeat.__doc__.__len__() == 154 — repeat is a C type with a 154-character docstring; __len__() returns 154; new to extra410"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra410
# ---------------------------------------------------------------------------

invariant itertools_extra410.chain_doc_len:
  description: "itertools.chain.__doc__.__len__() == 190 — non-empty docstring on C type chain; new to extra410"
  kind: python_call_eq
  function: chain.__doc__.__len__
  args: []
  expected: 190

invariant itertools_extra410.count_doc_len:
  description: "itertools.count.__doc__.__len__() == 205 — non-empty docstring on C type count; new to extra410"
  kind: python_call_eq
  function: count.__doc__.__len__
  args: []
