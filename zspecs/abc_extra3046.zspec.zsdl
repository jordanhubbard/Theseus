spec: ab3046
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 650 (ab3046): __enter__, __exit__, __aenter__ dict-presence for abc module types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: abc.ABC, abc.ABCMeta, and type(abc.abstractmethod(lambda: None)) — the built-in function type."
    - "None of the three abc subjects define __enter__, __exit__, or __aenter__ in their own __dict__; all results are false."
    - "abc.ABC is a plain convenience base class; it has no context manager protocol."
    - "abc.ABCMeta is a metaclass for tracking abstract methods; it has no context manager protocol."
    - "type(abc.abstractmethod(lambda: None)) is the built-in <class 'function'> type; function objects are not context managers."
    - "Note: abc.abstractproperty was removed in Python 3.13 and is NOT used here."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __enter__ dict-presence — operator.contains(Cls.__dict__, '__enter__')
#
# No abc class defines __enter__ in its own __dict__; all results are false.
# abc types are metaclass machinery and decorator helpers, not context managers.
# The function type (type(abstractmethod(lambda: None))) is <class 'function'>;
# function objects do not implement the context manager protocol.
# ---------------------------------------------------------------------------

table ab3046.enter:
  description: "abc types __enter__ dict-presence checks; wave 650"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3046

  columns: [id, function, args, expected]
  rows:
    - ["ab3046001", operator.contains, [abc.ABC.__dict__,                                 "__enter__"], false]
    - ["ab3046002", operator.contains, [abc.ABCMeta.__dict__,                             "__enter__"], false]
    - ["ab3046003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__enter__"], false]

# ---------------------------------------------------------------------------
# __exit__ dict-presence — operator.contains(Cls.__dict__, '__exit__')
#
# No abc class defines __exit__ in its own __dict__; all results are false.
# Mirrors the __enter__ findings: none implement the synchronous context manager
# protocol.
# ---------------------------------------------------------------------------

table ab3046.exit:
  description: "abc types __exit__ dict-presence checks; wave 650"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3046

  columns: [id, function, args, expected]
  rows:
    - ["ab3046004", operator.contains, [abc.ABC.__dict__,                                 "__exit__"], false]
    - ["ab3046005", operator.contains, [abc.ABCMeta.__dict__,                             "__exit__"], false]
    - ["ab3046006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__exit__"], false]

# ---------------------------------------------------------------------------
# __aenter__ dict-presence — operator.contains(Cls.__dict__, '__aenter__')
#
# No abc class defines __aenter__ in its own __dict__; all results are false.
# abc machinery has no async context manager support.
# ---------------------------------------------------------------------------

table ab3046.aenter:
  description: "abc types __aenter__ dict-presence checks; wave 650"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3046

  columns: [id, function, args, expected]
  rows:
    - ["ab3046007", operator.contains, [abc.ABC.__dict__,                                 "__aenter__"], false]
    - ["ab3046008", operator.contains, [abc.ABCMeta.__dict__,                             "__aenter__"], false]
    - ["ab3046009", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__aenter__"], false]

# ---------------------------------------------------------------------------
# combined — __enter__, __exit__, __aenter__ across all 3 abc subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __enter__: all false.
# __exit__:  all false.
# __aenter__: all false.
# abc module types serve as abstract base class infrastructure and decorator
# helpers; none participate in the context manager protocol.
# ---------------------------------------------------------------------------

table ab3046.combined:
