spec: string_extra30
version: ">=3.9"
backend: python_module(string)

docs: https://docs.python.org/3/library/string.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/string.html — Python string module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/string.py"
    - "string_extra29.zspec.zsdl — covers __all__ len (12), __all__ class name len (4), Template.pattern class name len (7), Template.delimiter len (1) and class name len (3), Template.idpattern len (21) and class name len (3), Formatter/Template __dict__.__class__.__name__.__len__()==12, ascii_letters/digits __class__.__name__.__len__()==3, capwords.__name__.__len__()==8."
    - "string_extra28.zspec.zsdl — covers __mro__.__len__() for Formatter (2) and Template (2); __bases__[0].__name__.__len__() (6 for both); string constant __len__() for printable/digits/hexdigits/ascii_letters/ascii_lowercase/ascii_uppercase/octdigits/punctuation/whitespace; printable.__class__.__name__.__len__()==3; Template.__init__.__qualname__.__len__()==17."
    - "string_extra27.zspec.zsdl — covers Formatter method qualname lens for format/vformat/format_field/get_field/parse; Template.substitute (19), safe_substitute (24), capwords (8)."
  notes:
    - "This spec extends string_extra29.zspec.zsdl."
    - "Prior specs covered: all string constant __len__() values; all major Template/Formatter method __qualname__.__len__() for format/vformat/format_field/get_field/parse/substitute/safe_substitute; Template/__init__ (17), __mro__/__bases__[0]/__dict__ sizes; __all__ len (12); delimiter/idpattern/pattern attributes; capwords name len (8)."
    - "This spec covers NEW angles: Formatter.check_unused_args.__qualname__.__len__()==27 (longest Formatter method); Formatter.convert_field.__qualname__.__len__()==23; Formatter._vformat.__qualname__.__len__()==18; Formatter.get_value.__qualname__.__len__()==19; Template.get_identifiers.__qualname__.__len__()==24; Template.is_valid.__qualname__.__len__()==17; Template._invalid.__qualname__.__len__()==17; Template.flags.__class__.__name__.__len__()==8 ('NoneType'); string.__name__.__len__()==6; string.Formatter.__qualname__.__len__()==9; string.Template.__qualname__.__len__()==8."
    - "Formatter.check_unused_args (27) is the longest qualname of any Formatter method in this spec series."
    - "Template.get_identifiers (24) is the longest qualname of any Template method except safe_substitute (also 24 — a tie)."
    - "Template.flags and Template.braceidpattern are both None in Python 3.14; Template.flags.__class__.__name__ == 'NoneType' (len 8)."
    - "string.__name__ == 'string' (len 6) — module name equals the module's own string."
    - "Formatter.__qualname__ == 'Formatter' (len 9); Template.__qualname__ == 'Template' (len 8)."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Formatter method __qualname__.__len__() — previously uncovered methods
#
# The methods format/vformat/format_field/get_field/parse were covered in
# string_extra27. Three additional public methods and one private helper
# have not been recorded in any prior spec:
#   check_unused_args -> 'Formatter.check_unused_args' (27) — longest
#   convert_field     -> 'Formatter.convert_field'     (23)
#   get_value         -> 'Formatter.get_value'         (19)
#   _vformat          -> 'Formatter._vformat'          (18)
# ---------------------------------------------------------------------------

table string_extra30.Formatter_remaining_method_qualname_lens:
  description: "__qualname__.__len__() for Formatter.check_unused_args (27), convert_field (23), get_value (19), _vformat (18)"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: Fmt_qlen

  columns: [id, function, args, expected]
  rows:
    - [check_unused_args, Formatter.check_unused_args.__qualname__.__len__, [], 27]
    - [convert_field,     Formatter.convert_field.__qualname__.__len__,     [], 23]
    - [get_value,         Formatter.get_value.__qualname__.__len__,          [], 19]
    - [vformat_private,   Formatter._vformat.__qualname__.__len__,           [], 18]

# ---------------------------------------------------------------------------
# Template method __qualname__.__len__() — previously uncovered methods
#
# The methods substitute/safe_substitute/__init__ were covered in prior specs.
# Three additional methods have not been recorded:
#   get_identifiers -> 'Template.get_identifiers' (24) — ties safe_substitute
#   is_valid        -> 'Template.is_valid'         (17)
#   _invalid        -> 'Template._invalid'         (17)
# ---------------------------------------------------------------------------

table string_extra30.Template_remaining_method_qualname_lens:
  description: "__qualname__.__len__() for Template.get_identifiers (24), is_valid (17), _invalid (17)"
  kind: python_call_eq
  category: method_qualname_lengths
  id_prefix: Tmpl_qlen

  columns: [id, function, args, expected]
  rows:
    - [get_identifiers, Template.get_identifiers.__qualname__.__len__, [], 24]
    - [is_valid,        Template.is_valid.__qualname__.__len__,        [], 17]
    - [invalid,         Template._invalid.__qualname__.__len__,        [], 17]

# ---------------------------------------------------------------------------
# Module-level identity attributes — string.__name__ and class __qualname__s
#
# No prior string spec records these identity lengths:
#   string.__name__ == 'string' (len 6)
#   Formatter.__qualname__ == 'Formatter' (len 9) — class itself
#   Template.__qualname__ == 'Template' (len 8) — class itself
# ---------------------------------------------------------------------------

invariant string_extra30.module_name_len:
  description: "string.__name__.__len__() == 6 — module name 'string' has 6 characters"
  category: module_identity
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 6

invariant string_extra30.Formatter.qualname_len:
  description: "string.Formatter.__qualname__.__len__() == 9 — class qualname 'Formatter' has 9 characters"
  category: class_identity
  kind: python_call_eq
  function: Formatter.__qualname__.__len__
  args: []
  expected: 9

invariant string_extra30.Template.qualname_len:
  description: "string.Template.__qualname__.__len__() == 8 — class qualname 'Template' has 8 characters"
  category: class_identity
  kind: python_call_eq
  function: Template.__qualname__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Template.flags class name — NoneType (extra30 namespace)
#
# Template.flags is None in Python 3.14 (the per-pattern re.flags override
# defaults to None meaning "inherit from the pattern"). The class of None is
# NoneType (8 characters). No prior string spec records this.
# ---------------------------------------------------------------------------

invariant string_extra30.Template.flags.class.name.len:
  description: "string.Template.flags.__class__.__name__.__len__() == 8 — flags is None, class is 'NoneType' (8 chars)"
  category: module_constants
  kind: python_call_eq
  function: Template.flags.__class__.__name__.__len__
  args: []
  expected: 8
