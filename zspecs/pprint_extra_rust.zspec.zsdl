spec: pprint_extra_rust
version: ">=3.9"
backend: rust_module(pprint_extra_rust)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — pprint stdlib"
  notes:
    - "pprint provides pretty-printing of Python data structures."
    - "pprint.pformat({'a': 1}) == \"{'a': 1}\"."
    - "pprint.PrettyPrinter is a class."
    - "pprint.pprint is callable."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant pprint_extra_rust.pformat_simple:
  description: "pprint.pformat(42) == '42'"
  category: pformat
  kind: python_call_eq
  function: pprint_extra_pformat_42
  args: []
  expected: "42"

invariant pprint_extra_rust.has_pretty_printer:
  description: "pprint.PrettyPrinter is a class"
  category: presence
  kind: python_call_eq
  function: pprint_extra_has_pretty_printer
  args: []
  expected: true

invariant pprint_extra_rust.has_pprint:
  description: "pprint.pprint is callable"
  category: presence
  kind: python_call_eq
  function: pprint_extra_has_pprint
  args: []
  expected: true

