spec: theseus_collections_cr5
version: ">=3.9"
backend: python_cleanroom(theseus_collections_cr5)
blocks: collections

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html"
  notes:
    - "Clean-room extended collections utilities. Do NOT import collections."
    - "ChainMap(*maps): a view of multiple dicts as a single mapping."
    - "UserDict: dict subclass for easier dict subclassing."
    - "UserList: list subclass for easier list subclassing."
    - "collections5_chainmap(): ChainMap({'a':1},{'b':2})['a'] == 1 and ['b'] == 2."
    - "collections5_chainmap_update(): ChainMap({'a':1},{'a':2})['a'] == 1 (first wins)."
    - "collections5_userdict(): UserDict({'x':42})['x'] == 42."
    - "Zero-arg invariant signatures — def collections5_chainmap(): return bool"
    - "ChainMap: lookup traverses maps in order; first map that has key wins."
    - "ChainMap.maps: list of underlying dicts; can be updated."
    - "UserDict: wraps a dict in self.data; __getitem__, __setitem__, __delitem__ delegate."
    - "Export: ChainMap, UserDict, UserList, UserString, Counter, OrderedDict, defaultdict, deque."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_collections_cr5.chainmap:
  description: "ChainMap({'a':1},{'b':2}) looks up from both maps"
  category: ChainMap
  kind: python_call_eq
  function: collections5_chainmap
  args: []
  expected: true

invariant theseus_collections_cr5.chainmap_update:
  description: "ChainMap({'a':1},{'a':2})['a'] == 1 (first map wins)"
  category: ChainMap
  kind: python_call_eq
  function: collections5_chainmap_update
  args: []
  expected: 1

invariant theseus_collections_cr5.userdict:
  description: "UserDict({'x':42})['x'] == 42"
  category: UserDict
  kind: python_call_eq
  function: collections5_userdict
  args: []
  expected: 42
