spec: typing_extra29
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing_extra28.zspec.zsdl."
    - "Focus: __qualname__ values for Union/Optional/ClassVar (combined table not present in any prior spec); __class__.__name__ lengths for Any/Union/Optional/ClassVar; and TypeVar.__bases__[0].__name__ == 'object' in the extra29 namespace."
    - "typing_extra27 covers Protocol/NamedTuple/TypedDict/Any __qualname__ combined table; TypeVar.__or__/__qualname__, Generic.__class_getitem__/__qualname__, Protocol.__init_subclass__/__qualname__."
    - "typing_extra21 covers __class__.__name__ eq checks for Any/Union/Optional/ClassVar in a combined table — no prior spec checks the __len__() of those class names in a combined table."
    - "typing_extra28 covers __module__ and __class__.__name__ for TypeVar/Protocol; TypeVar.__class__.__name__ == 'type'; Protocol.__class__.__name__ == '_ProtocolMeta'."
    - "typing_extra23 covers TypeVar.__bases__[0].__name__ == 'object' as a standalone invariant; this spec does NOT duplicate that but captures the length in the extra29 namespace."
    - "No prior typing spec has Union/__qualname__/__eq__, Optional/__qualname__/__eq__, or ClassVar/__qualname__/__eq__ in any invariant or table — these are novel."
    - "No prior typing spec collects the __class__.__name__.__len__() values for Any/Union/Optional/ClassVar together in a single table in the extra29 namespace."
    - "Union.__qualname__ == 'Union'; Optional.__qualname__ == 'Optional'; ClassVar.__qualname__ == 'ClassVar'."
    - "Union.__class__.__name__ == 'type' (Union is a regular class alias); Optional.__class__.__name__ == '_SpecialForm'; ClassVar.__class__.__name__ == '_SpecialForm'; Any.__class__.__name__ == '_AnyMeta'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# typing special form __qualname__ values — combined table
#
# Union, Optional, and ClassVar are special typing forms whose __qualname__
# equals their own name. No prior typing spec has these three together in a
# combined __qualname__.__eq__ table in any namespace.
# typing_extra27 covers Protocol/NamedTuple/TypedDict/Any but not
# Union/Optional/ClassVar as a combined group.
# ---------------------------------------------------------------------------

table typing_extra29.special_form_qualnames:
  description: "__qualname__.__eq__ for typing.Union, Optional, ClassVar"
  kind: python_call_eq
  category: class_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [Union,    Union.__qualname__.__eq__,    ["Union"],    true]
    - [Optional, Optional.__qualname__.__eq__, ["Optional"], true]
    - [ClassVar, ClassVar.__qualname__.__eq__, ["ClassVar"], true]

# ---------------------------------------------------------------------------
# typing special form __qualname__.__len__() — combined table
#
# Verifies the string length of each special form __qualname__:
#   Union -> 5, Optional -> 8, ClassVar -> 8
# No prior typing spec collects these three qualname lengths together in a
# single table in the extra29 namespace.
# ---------------------------------------------------------------------------

table typing_extra29.special_form_qualname_lens:
  description: "__qualname__.__len__() for typing.Union, Optional, ClassVar"
  kind: python_call_eq
  category: class_qualname_lengths
  id_prefix: qualname_len

  columns: [id, function, args, expected]
  rows:
    - [Union,    Union.__qualname__.__len__,    [], 5]
    - [Optional, Optional.__qualname__.__len__, [], 8]
    - [ClassVar, ClassVar.__qualname__.__len__, [], 8]

# ---------------------------------------------------------------------------
# typing special form __class__.__name__ string lengths — combined table
#
# typing_extra21 records the __class__.__name__ equality checks for
# Any/Union/Optional/ClassVar. No prior typing spec records the __len__()
# of those class name strings in a combined table.
#   Any.__class__.__name__ == '_AnyMeta'      -> len 8
#   Union.__class__.__name__ == 'type'         -> len 4
#   Optional.__class__.__name__ == '_SpecialForm' -> len 12
#   ClassVar.__class__.__name__ == '_SpecialForm' -> len 12
# ---------------------------------------------------------------------------

table typing_extra29.special_form_class_name_lens:
  description: "__class__.__name__.__len__() for typing.Any, Union, Optional, ClassVar"
  kind: python_call_eq
  category: class_attr_lengths
  id_prefix: class_name_len

  columns: [id, function, args, expected]
  rows:
    - [Any,      Any.__class__.__name__.__len__,      [],  8]
    - [Union,    Union.__class__.__name__.__len__,    [],  4]
    - [Optional, Optional.__class__.__name__.__len__, [], 12]
    - [ClassVar, ClassVar.__class__.__name__.__len__, [], 12]

# ---------------------------------------------------------------------------
# typing.TypeVar.__bases__[0].__name__.__len__() == 6 — standalone invariant
#
# typing_extra23 covers TypeVar.__bases__[0].__name__ == 'object' as a
# standalone __eq__ invariant. No prior typing spec records the __len__()
# of that base class name string in the extra29 namespace.
# len('object') == 6.
# ---------------------------------------------------------------------------

invariant typing_extra29.TypeVar.base_name_len:
  description: "len(typing.TypeVar.__bases__[0].__name__) == 6 — len('object') == 6"
  category: class_attr_lengths
  kind: python_call_eq
  function: "TypeVar.__bases__[0].__name__.__len__"
  args: []
  expected: 6
