spec: json_extra18
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl and prior extras through json_extra17.zspec.zsdl."
    - "json_extra17 covers: JSONEncoder.encode/__qualname__; JSONEncoder.iterencode/__qualname__; JSONEncoder.default/__qualname__; JSONDecoder.decode/__qualname__; JSONDecoder.raw_decode/__qualname__."
    - "json_extra16 covers: JSONEncoder/__qualname__; JSONDecoder/__qualname__; JSONDecodeError/__qualname__; class __qualname__.__class__.__name__ table."
    - "json_extra15 covers: JSONDecodeError/__module__; JSONEncoder/__module__; JSONDecoder/__module__; load/__qualname__; dump/__qualname__."
    - "json_extra14 covers: loads/__qualname__/__module__; dumps/__qualname__/__module__."
    - "Focus: __module__ for JSONEncoder and JSONDecoder instance methods — encode, iterencode, default, decode, raw_decode."
    - "No prior json spec checks JSONEncoder.encode.__module__."
    - "No prior json spec checks JSONEncoder.iterencode.__module__."
    - "No prior json spec checks JSONEncoder.default.__module__."
    - "No prior json spec checks JSONDecoder.decode.__module__."
    - "No prior json spec checks JSONDecoder.raw_decode.__module__."
    - "json.JSONEncoder.encode.__module__ == 'json.encoder' — method lives in the json.encoder submodule."
    - "json.JSONEncoder.iterencode.__module__ == 'json.encoder' — method lives in the json.encoder submodule."
    - "json.JSONEncoder.default.__module__ == 'json.encoder' — method lives in the json.encoder submodule."
    - "json.JSONDecoder.decode.__module__ == 'json.decoder' — method lives in the json.decoder submodule."
    - "json.JSONDecoder.raw_decode.__module__ == 'json.decoder' — method lives in the json.decoder submodule."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# JSONEncoder method __module__ values
#
# json_extra15 checks JSONEncoder.__module__ == 'json.encoder' for the class.
# No prior json spec checks __module__ for any instance method of JSONEncoder.
# Methods defined in a class carry the module of the defining class.
# For JSONEncoder (defined in json/encoder.py), all methods have
# __module__ == 'json.encoder'.
# ---------------------------------------------------------------------------

invariant json_extra18.JSONEncoder.encode.module:
  description: "json.JSONEncoder.encode.__module__ == 'json.encoder' — method module matches defining submodule"
  category: method_attrs
  kind: python_call_eq
  function: "JSONEncoder.encode.__module__.__eq__"
  args: ["json.encoder"]
  expected: true

invariant json_extra18.JSONEncoder.iterencode.module:
  description: "json.JSONEncoder.iterencode.__module__ == 'json.encoder' — method module matches defining submodule"
  category: method_attrs
  kind: python_call_eq
  function: "JSONEncoder.iterencode.__module__.__eq__"
  args: ["json.encoder"]
  expected: true

invariant json_extra18.JSONEncoder.default.module:
  description: "json.JSONEncoder.default.__module__ == 'json.encoder' — method module matches defining submodule"
  category: method_attrs
  kind: python_call_eq
  function: "JSONEncoder.default.__module__.__eq__"
  args: ["json.encoder"]
  expected: true

# ---------------------------------------------------------------------------
# JSONDecoder method __module__ values
#
# json_extra15 checks JSONDecoder.__module__ == 'json.decoder' for the class.
# No prior json spec checks __module__ for any instance method of JSONDecoder.
# For JSONDecoder (defined in json/decoder.py), all methods have
# __module__ == 'json.decoder'.
# ---------------------------------------------------------------------------

invariant json_extra18.JSONDecoder.decode.module:
  description: "json.JSONDecoder.decode.__module__ == 'json.decoder' — method module matches defining submodule"
  category: method_attrs
  kind: python_call_eq
  function: "JSONDecoder.decode.__module__.__eq__"
  args: ["json.decoder"]
  expected: true

invariant json_extra18.JSONDecoder.raw_decode.module:
  description: "json.JSONDecoder.raw_decode.__module__ == 'json.decoder' — method module matches defining submodule"
  category: method_attrs
  kind: python_call_eq
  function: "JSONDecoder.raw_decode.__module__.__eq__"
  args: ["json.decoder"]
  expected: true

# ---------------------------------------------------------------------------
# JSONEncoder and JSONDecoder method __module__ table
#
# Consolidates all five method __module__ checks into a single table.
# All five are first covered in this spec (json_extra18).
# ---------------------------------------------------------------------------

table json_extra18.method_modules:
  description: "json encoder/decoder method __module__ — submodule where each method is defined"
  kind: python_call_eq
  category: method_attrs
  id_prefix: jmm18

  columns: [id, function, args, expected]
  rows:
    - [encode_mod,      "JSONEncoder.encode.__module__.__eq__",      ["json.encoder"], true]
    - [iterencode_mod,  "JSONEncoder.iterencode.__module__.__eq__",  ["json.encoder"], true]
    - [default_mod,     "JSONEncoder.default.__module__.__eq__",     ["json.encoder"], true]
    - [decode_mod,      "JSONDecoder.decode.__module__.__eq__",      ["json.decoder"], true]
    - [raw_decode_mod,  "JSONDecoder.raw_decode.__module__.__eq__",  ["json.decoder"], true]
