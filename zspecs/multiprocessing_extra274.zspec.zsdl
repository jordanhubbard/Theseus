spec: multiprocessing_extra274
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — pool and manager class hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py, Lib/multiprocessing/managers.py"
  notes:
    - "multiprocessing.pool.AsyncResult is an alias for ApplyResult; AsyncResult.__name__ == 'ApplyResult'"
    - "MapResult.__bases__[0].__name__ == 'ApplyResult' (inherits from ApplyResult/AsyncResult)"
    - "ApplyResult.__bases__[0].__name__ == 'object'"
    - "IMapIterator.__bases__[0].__name__ == 'object'"
    - "SyncManager.__bases__[0].__name__ == 'BaseManager'"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra274.pool_class_names:
  description: "multiprocessing.pool class __name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: mp274n

  columns: [id, function, args, expected, description]
  rows:
    - [mp274n001, multiprocessing.pool.Pool.__name__.__eq__, ["Pool"], true, "Pool __name__"]
    - [mp274n002, multiprocessing.pool.AsyncResult.__name__.__eq__, ["ApplyResult"], true, "AsyncResult __name__ is ApplyResult (alias)"]
    - [mp274n003, multiprocessing.pool.MapResult.__name__.__eq__, ["MapResult"], true, "MapResult __name__"]
    - [mp274n004, multiprocessing.pool.IMapIterator.__name__.__eq__, ["IMapIterator"], true, "IMapIterator __name__"]

table multiprocessing_extra274.pool_class_modules:
  description: "multiprocessing.pool class __module__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: mp274m

  columns: [id, function, args, expected, description]
  rows:
    - [mp274m001, multiprocessing.pool.Pool.__module__.__eq__, ["multiprocessing.pool"], true, "Pool __module__"]
    - [mp274m002, multiprocessing.pool.AsyncResult.__module__.__eq__, ["multiprocessing.pool"], true, "AsyncResult __module__"]
    - [mp274m003, multiprocessing.pool.MapResult.__module__.__eq__, ["multiprocessing.pool"], true, "MapResult __module__"]
    - [mp274m004, multiprocessing.pool.IMapIterator.__module__.__eq__, ["multiprocessing.pool"], true, "IMapIterator __module__"]

invariant multiprocessing_extra274.pool_base:
  description: "Pool base class is object"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.Pool.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant multiprocessing_extra274.apply_result_base:
  description: "ApplyResult base class is object"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.ApplyResult.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant multiprocessing_extra274.map_result_base:
  description: "MapResult base class is ApplyResult"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.MapResult.__bases__[0].__name__.__eq__
  args: ["ApplyResult"]
  expected: true

invariant multiprocessing_extra274.imap_iterator_base:
  description: "IMapIterator base class is object"
  category: identity
  kind: python_call_eq
  function: multiprocessing.pool.IMapIterator.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant multiprocessing_extra274.base_manager_name:
  description: "BaseManager __name__ is BaseManager"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__name__.__eq__
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra274.base_manager_module:
  description: "BaseManager __module__ is multiprocessing.managers"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__module__.__eq__
  args: ["multiprocessing.managers"]
  expected: true

invariant multiprocessing_extra274.base_manager_base:
  description: "BaseManager base class is object"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

invariant multiprocessing_extra274.sync_manager_name:
  description: "SyncManager __name__ is SyncManager"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.SyncManager.__name__.__eq__
  args: ["SyncManager"]
  expected: true

invariant multiprocessing_extra274.sync_manager_base:
  description: "SyncManager base class is BaseManager"
  category: identity
  kind: python_call_eq
  function: multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__
  args: ["BaseManager"]
  expected: true
