spec: inspect_extra62
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra61.zspec.zsdl."
    - "Wave 228 theme: __doc__ string content checks, __annotations__ class identity, __globals__ keys presence checks."
    - "inspect.isfunction and inspect.signature are both pure-Python functions (Lib/inspect.py). Both have __annotations__ == {} (empty dict). Their __annotations__.__class__.__name__ == 'dict'. No prior inspect spec checks __annotations__.__class__.__name__ for any function."
    - "inspect.isfunction.__globals__ is the inspect module namespace dict. It contains 'isfunction', 'signature', 'Parameter', and many other inspect module names. __globals__.__class__.__name__ == 'dict'. No prior inspect spec checks __globals__.__class__.__name__ or __globals__.__contains__ for any function."
    - "inspect.Parameter is a pure-Python class (Lib/inspect.py). Its __doc__ begins 'Represents a parameter in a function signature.' The word 'Parameter' (capital P) does NOT appear in the docstring — it says 'Represents a parameter' (lowercase p). The word 'signature' DOES appear ('in a function signature'). The word 'Represents' DOES appear."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "No prior inspect spec checks __annotations__.__class__.__name__, __globals__.__class__.__name__, __globals__.__contains__, or Parameter.__doc__.__contains__ for any object. All checks in this spec are new to extra62."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# isfunction / signature __annotations__.__class__.__name__ — extra62
#
# Wave 228 theme: __annotations__ class identity.
#
# inspect.isfunction and inspect.signature are pure-Python functions.
# Both have __annotations__ == {} (empty dict).
# Therefore:
#   isfunction.__annotations__.__class__.__name__ == 'dict'
#   signature.__annotations__.__class__.__name__ == 'dict'
#
# No prior inspect spec checks __annotations__.__class__.__name__ for any
# module-level function. New to extra62.
# ---------------------------------------------------------------------------

table inspect_extra62.function_annotations_class_name:
  description: "isfunction/signature __annotations__.__class__.__name__.__eq__('dict')==true — Python functions always have a dict annotations container; wave 228 __annotations__ class identity; new to extra62"
  kind: python_call_eq
  category: annotations_type
  id_prefix: inspann62

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_annotations_class_name_eq_dict,
       isfunction.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "inspect.isfunction.__annotations__.__class__.__name__.__eq__('dict') == True — isfunction is a pure-Python function (Lib/inspect.py) that returns True if the object is a Python function; it has no annotated parameters so __annotations__ == {} (empty dict); as a dict object, __annotations__.__class__ is the built-in dict type and dict.__name__ == 'dict' (4 chars); no prior inspect spec checks __annotations__.__class__.__name__ for isfunction; new to extra62"]
    - [signature_annotations_class_name_eq_dict,
       signature.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "inspect.signature.__annotations__.__class__.__name__.__eq__('dict') == True — signature is a pure-Python function (Lib/inspect.py) that returns a Signature object for the given callable; it has no annotated parameters so __annotations__ == {} (empty dict); as a dict object, __annotations__.__class__ is the built-in dict type and dict.__name__ == 'dict' (4 chars); no prior inspect spec checks __annotations__.__class__.__name__ for signature; new to extra62"]

# ---------------------------------------------------------------------------
# isfunction.__globals__ class name and key presence — extra62
#
# Wave 228 theme: __globals__ keys presence checks.
#
# inspect.isfunction.__globals__ is the inspect module namespace dict —
# the global namespace shared by all pure-Python functions in Lib/inspect.py.
#
# isfunction.__globals__.__class__.__name__ == 'dict'
# 'isfunction' in isfunction.__globals__ == True
# 'signature' in isfunction.__globals__ == True  (both defined at module level)
# 'Parameter' in isfunction.__globals__ == True  (Parameter class is in inspect)
#
# No prior inspect spec checks __globals__.__class__.__name__ or
# __globals__.__contains__ for any function. New to extra62.
# ---------------------------------------------------------------------------

table inspect_extra62.isfunction_globals_checks:
  description: "isfunction.__globals__.__class__.__name__ and __contains__ checks — module namespace is a dict containing inspect module names; wave 228 __globals__ keys presence; new to extra62"
  kind: python_call_eq
  category: globals_checks
  id_prefix: inspann62

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_globals_class_name_eq_dict,
       isfunction.__globals__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "inspect.isfunction.__globals__.__class__.__name__.__eq__('dict') == True — isfunction is a pure-Python function (Lib/inspect.py); its __globals__ attribute is the inspect module namespace dict (the same object as inspect.__dict__ for module-level names); every module namespace is a plain Python dict; therefore __globals__.__class__.__name__ == 'dict' (4 chars); no prior inspect spec checks __globals__.__class__.__name__ for any function; new to extra62"]
    - [isfunction_globals_contains_isfunction,
       isfunction.__globals__.__contains__,
       ["isfunction"],
       true,
       "inspect.isfunction.__globals__.__contains__('isfunction') == True — isfunction.__globals__ is the inspect module namespace dict; 'isfunction' is a key because isfunction is a module-level name in Lib/inspect.py; for any top-level function f, f.__globals__.__contains__(f.__name__) is True; __contains__ on a dict returns True when the key exists; no prior inspect spec checks __globals__.__contains__ for any key; new to extra62"]
    - [isfunction_globals_contains_signature,
       isfunction.__globals__.__contains__,
       ["signature"],
       true,
       "inspect.isfunction.__globals__.__contains__('signature') == True — isfunction.__globals__ is the inspect module namespace dict shared by all pure-Python functions in Lib/inspect.py; 'signature' is a key in this dict because inspect.signature is also a module-level function defined in Lib/inspect.py; both isfunction and signature share the same __globals__ dict; __contains__ returns True; new to extra62"]
    - [isfunction_globals_contains_Parameter,
       isfunction.__globals__.__contains__,
       ["Parameter"],
       true,
       "inspect.isfunction.__globals__.__contains__('Parameter') == True — 'Parameter' is a key in the inspect module namespace dict because inspect.Parameter is a class defined at module scope in Lib/inspect.py; isfunction.__globals__ includes class names as well as function names from the same module; __contains__ returns True; new to extra62"]

# ---------------------------------------------------------------------------
# Parameter.__doc__.__contains__ checks — extra62
#
# Wave 228 theme: __doc__ string content checks.
#
# inspect.Parameter is a pure-Python class (Lib/inspect.py).
# Its __doc__ begins:
#   'Represents a parameter in a function signature.\n\nHas the following
#    public attributes:\n\n* name : str\n...'
#
# Key findings:
#   Parameter.__doc__.__contains__('Parameter') == False  (capital P — not in docstring)
#   Parameter.__doc__.__contains__('parameter') == True   (lowercase p — 'a parameter')
#   Parameter.__doc__.__contains__('signature') == True   ('in a function signature')
#   Parameter.__doc__.__contains__('Represents') == True  (opening word)
#
# No prior inspect spec checks Parameter.__doc__.__contains__. New to extra62.
# ---------------------------------------------------------------------------

table inspect_extra62.parameter_doc_contains:
  description: "Parameter.__doc__.__contains__ checks — docstring mentions 'signature' and 'Represents' but NOT 'Parameter' (capital); wave 228 __doc__ content; new to extra62"
  kind: python_call_eq
  category: doc_content
  id_prefix: inspann62

  columns: [id, function, args, expected, description]
  rows:
    - [parameter_doc_contains_signature,
       Parameter.__doc__.__contains__,
       ["signature"],
       true,
       "inspect.Parameter.__doc__.__contains__('signature') == True — Parameter is a pure-Python class (Lib/inspect.py); its docstring begins 'Represents a parameter in a function signature.'; the word 'signature' appears in the opening sentence; __contains__ on a str returns True when the substring is found; no prior inspect spec checks Parameter.__doc__.__contains__; new to extra62"]
    - [parameter_doc_contains_Represents,
       Parameter.__doc__.__contains__,
       ["Represents"],
       true,
       "inspect.Parameter.__doc__.__contains__('Represents') == True — Parameter.__doc__ opens with 'Represents a parameter in a function signature.'; 'Represents' (capital R) is the very first word of the docstring; __contains__ returns True; new to extra62"]
    - [parameter_doc_not_contains_Parameter,
       Parameter.__doc__.__contains__,
       ["Parameter"],
       false,
       "inspect.Parameter.__doc__.__contains__('Parameter') == False — Parameter.__doc__ reads 'Represents a parameter in a function signature.\\n\\nHas the following public attributes:...'; the class name 'Parameter' (capital P) does NOT appear in the docstring — the text uses lowercase 'parameter'; this is a notable fact: the class docstring does not self-reference the class name with its canonical capitalization; __contains__ returns False; no prior inspect spec checks Parameter.__doc__.__contains__('Parameter'); new to extra62"]
    - [parameter_doc_contains_parameter_lower,
       Parameter.__doc__.__contains__,
       ["parameter"],
       true,
       "inspect.Parameter.__doc__.__contains__('parameter') == True — Parameter.__doc__ contains 'a parameter' (lowercase p) in the opening sentence 'Represents a parameter in a function signature.'; the lowercase form 'parameter' IS present even though the capitalized 'Parameter' is not; __contains__ is case-sensitive and returns True for the lowercase form; new to extra62"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra62
# ---------------------------------------------------------------------------

invariant inspect_extra62.isfunction_annotations_is_dict:
  description: "inspect.isfunction.__annotations__.__class__.__name__.__eq__('dict') == True — Python function __annotations__ is always a dict; isfunction has no annotated params; wave 228 __annotations__ class identity; new to extra62"
  kind: python_call_eq
  function: isfunction.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant inspect_extra62.isfunction_globals_contains_signature:
  description: "inspect.isfunction.__globals__.__contains__('signature') == True — inspect module namespace contains 'signature' as a module-level name; wave 228 __globals__ keys presence; new to extra62"
  kind: python_call_eq
  function: isfunction.__globals__.__contains__
  args: ["signature"]
  expected: true

invariant inspect_extra62.parameter_doc_not_contains_Parameter:
  description: "inspect.Parameter.__doc__.__contains__('Parameter') == False — Parameter docstring uses lowercase 'parameter', not the class name 'Parameter'; wave 228 __doc__ content; new to extra62"
  kind: python_call_eq
  function: Parameter.__doc__.__contains__
  args: ["Parameter"]
  expected: false
