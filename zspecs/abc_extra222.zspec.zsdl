spec: abc_extra222
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "abc.get_cache_token().__gt__(0) == True — cache token is a monotonically increasing integer always > 0 after any ABC class definitions during import; verified with Python 3.14.3."
    - "abc.get_cache_token().__class__.__name__ == 'int' — get_cache_token() returns an int; verified with Python 3.14.3."
    - "abc.ABC.__name__ == 'ABC' — len is 3; verified with Python 3.14.3."
    - "abc.ABCMeta.__name__ == 'ABCMeta' — len is 7; verified with Python 3.14.3."
    - "abc.abstractmethod.__name__ == 'abstractmethod' — len is 14; verified with Python 3.14.3."
    - "abc.ABC.__module__ == 'abc' — __module__.__eq__('abc') is True; verified with Python 3.14.3."
    - "abc.ABCMeta.__module__ == 'abc' — __module__.__eq__('abc') is True; verified with Python 3.14.3."
    - "abc.abstractmethod.__module__ == 'abc' — __module__.__eq__('abc') is True; verified with Python 3.14.3."
    - "abc.ABC.__name__.__startswith__('ABC') == True — verified with Python 3.14.3."
    - "abc.ABCMeta.__name__.__startswith__('ABC') == True — verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc cache token behavioral output contracts — extra222 namespace
#
# get_cache_token() returns an int > 0 after imports; verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant abc_extra222.cache_token_gt_zero:
  description: "abc.get_cache_token().__gt__(0) == True — cache token is always > 0 after any ABC class definitions at import time; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: behavioral
  kind: python_call_eq
  function: get_cache_token()
  args: []
  method: __gt__
  method_args: [0]
  expected: true

invariant abc_extra222.cache_token_class_name:
  description: "abc.get_cache_token().__class__.__name__ == 'int' — get_cache_token() returns an integer; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: type_identity
  kind: python_call_eq
  function: get_cache_token()
  args: []
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# abc class name length contracts — extra222 namespace
#
# ABC=3 chars, ABCMeta=7 chars, abstractmethod=14 chars; verified Python 3.14.3.
# ---------------------------------------------------------------------------

table abc_extra222.name_lengths:
  description: "abc class __name__.__len__() contracts in abc222nl namespace"
  kind: python_call_eq
  category: string_length
  id_prefix: abc222nl

  columns: [id, function, args, expected, description]
  rows:
    - [ABC_name_len_3,            ABC.__name__.__len__,            [], 3,  "abc.ABC.__name__.__len__() == 3 — 'ABC' has 3 characters; verified with Python 3.14.3"]
    - [ABCMeta_name_len_7,        ABCMeta.__name__.__len__,        [], 7,  "abc.ABCMeta.__name__.__len__() == 7 — 'ABCMeta' has 7 characters; verified with Python 3.14.3"]
    - [abstractmethod_name_len_14, abstractmethod.__name__.__len__, [], 14, "abc.abstractmethod.__name__.__len__() == 14 — 'abstractmethod' has 14 characters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc class __module__ equality and __name__ startswith contracts — extra222 namespace
#
# ABC, ABCMeta, abstractmethod all have __module__ == 'abc'; verified Python 3.14.3.
# ABC and ABCMeta both have __name__ starting with 'ABC'; verified Python 3.14.3.
# ---------------------------------------------------------------------------

table abc_extra222.module_and_name_checks:
  description: "abc class __module__ and __name__ string contracts in abc222mod namespace"
  kind: python_call_eq
  category: module_identity
  id_prefix: abc222mod

  columns: [id, function, args, expected, description]
  rows:
    - [ABC_module_eq_abc,            ABC.__module__.__eq__,            ["abc"], true, "abc.ABC.__module__.__eq__('abc') == True — verified with Python 3.14.3"]
    - [ABCMeta_module_eq_abc,        ABCMeta.__module__.__eq__,        ["abc"], true, "abc.ABCMeta.__module__.__eq__('abc') == True — verified with Python 3.14.3"]
    - [abstractmethod_module_eq_abc, abstractmethod.__module__.__eq__, ["abc"], true, "abc.abstractmethod.__module__.__eq__('abc') == True — verified with Python 3.14.3"]
    - [ABC_name_sw_ABC,              ABC.__name__.__startswith__,      ["ABC"], true, "abc.ABC.__name__.__startswith__('ABC') == True — verified with Python 3.14.3"]
    - [ABCMeta_name_sw_ABC,          ABCMeta.__name__.__startswith__,  ["ABC"], true, "abc.ABCMeta.__name__.__startswith__('ABC') == True — verified with Python 3.14.3"]
