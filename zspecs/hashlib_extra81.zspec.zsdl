spec: hashlib_extra81
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra80.zspec.zsdl — covers blake2b/blake2s class-level size constants (__dict__.__contains__('MAX_DIGEST_SIZE'/'MAX_KEY_SIZE'/'PERSON_SIZE')) + constant __class__.__name__=='int' + blake2b/blake2s hexdigest.__class__.__name__=='method_descriptor' (table + invariants)."
    - "hashlib_extra79.zspec.zsdl — covers blake2b/__dict__.__contains__('copy'/'update'/'digest'/'hexdigest'/'SALT_SIZE') / blake2s/__dict__.__contains__('copy'/'update'/'digest') / blake2b.copy/update/digest.__class__.__name__=='method_descriptor' (table + invariants)."
    - "hashlib_extra77.zspec.zsdl — covers blake2b/__name__/__module__/__bases__[0]/__mro__.__len__() / blake2s/__name__/__module__/__bases__[0]/__mro__.__len__() (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra80; it does NOT duplicate invariants present in those files."
    - "Wave 245 theme: hashlib module-level function/class __name__, __qualname__, and __module__ identity."
    - "hashlib.sha256.__name__ == 'openssl_sha256' — the hashlib.sha256 constructor is actually the openssl_sha256 C type from _hashlib. No prior hashlib spec checks sha256.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__qualname__ == 'openssl_sha256' — same as __name__ for C extension types. No prior hashlib spec checks sha256.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__ == '_hashlib' — sha256 is defined in the C extension _hashlib. No prior hashlib spec checks sha256.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__name__ == 'openssl_md5' — the hashlib.md5 constructor is the openssl_md5 C type from _hashlib. No prior hashlib spec checks md5.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__qualname__ == 'openssl_md5' — same as __name__. No prior hashlib spec checks md5.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__ == '_hashlib' — md5 is from the C extension. No prior hashlib spec checks md5.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__module__ == '_hashlib' — sha512 shares the same C extension origin. No prior hashlib spec checks sha512.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__class__.__name__ == 'set' — algorithms_available is a plain Python set. No prior hashlib spec checks algorithms_available.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__name__ == 'function' — hashlib.new is a Python-level wrapper function (not a builtin). No prior hashlib spec checks new.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__module__ == 'hashlib' — new is defined in the hashlib Python module. No prior hashlib spec checks new.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__qualname__ == '__hash_new' — the internal name of the hashlib.new wrapper is '__hash_new'. No prior hashlib spec checks new.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__name__ == 'openssl_sha512' — sha512 constructor is the openssl_sha512 C type. No prior hashlib spec checks sha512.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256.__name__ and __qualname__ identity
#
# Wave 245 theme: hashlib sha256/md5 constructor name/qualname.
#
# hashlib.sha256 is actually the openssl_sha256 C extension type from _hashlib.
# Its __name__ and __qualname__ are both 'openssl_sha256'. No prior hashlib spec
# checks sha256.__name__ or sha256.__qualname__. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra81.sha256_name_qualname:
  description: "hashlib.sha256/__name__.__eq__('openssl_sha256')==True / sha256/__qualname__.__eq__('openssl_sha256')==True — sha256 is the openssl_sha256 C type from _hashlib; __name__ and __qualname__ are both 'openssl_sha256'; no prior hashlib spec checks sha256.__name__ or sha256.__qualname__; first __name__/__qualname__ anchor for hashlib.sha256"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra81

  columns: [id, function, args, expected]
  rows:
    - [sha256_name_openssl_sha256,     sha256.__name__.__eq__,     ["openssl_sha256"], true]
    - [sha256_qualname_openssl_sha256, sha256.__qualname__.__eq__,  ["openssl_sha256"], true]

# ---------------------------------------------------------------------------
# hashlib.md5.__name__, __qualname__, and __module__ identity
#
# Wave 245 theme: hashlib md5 constructor identity.
#
# hashlib.md5 is the openssl_md5 C extension type from _hashlib. Its __name__
# and __qualname__ are both 'openssl_md5' and its __module__ is '_hashlib'.
# No prior hashlib spec checks md5.__name__, md5.__qualname__, or md5.__module__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra81.md5_name_qualname_module:
  description: "hashlib.md5/__name__.__eq__('openssl_md5')==True / md5/__qualname__.__eq__('openssl_md5')==True / md5/__module__.__eq__('_hashlib')==True — md5 is the openssl_md5 C type from _hashlib; no prior hashlib spec checks md5.__name__/__qualname__/__module__; first __name__/__qualname__/__module__ anchor for hashlib.md5"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra81

  columns: [id, function, args, expected]
  rows:
    - [md5_name_openssl_md5,     md5.__name__.__eq__,     ["openssl_md5"], true]
    - [md5_qualname_openssl_md5, md5.__qualname__.__eq__,  ["openssl_md5"], true]
    - [md5_module_hashlib,       md5.__module__.__eq__,    ["_hashlib"],    true]

# ---------------------------------------------------------------------------
# hashlib module-level __module__ cross-check: sha256, sha512, md5
#
# Wave 245 theme: hashlib hash constructor __module__ identity.
#
# hashlib.sha256, sha512, and md5 are all C extension types from _hashlib.
# Their __module__ is '_hashlib'. No prior hashlib spec checks sha256.__module__,
# sha512.__module__ (as a standalone), or pairs them together.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra81.sha256_sha512_module_hashlib:
  description: "hashlib.sha256/__module__.__eq__('_hashlib')==True / sha512/__module__.__eq__('_hashlib')==True — sha256 and sha512 are both C extension types from _hashlib; no prior hashlib spec checks sha256.__module__ or sha512.__module__ paired together; first paired __module__ cross-check for sha256/sha512"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra81

  columns: [id, function, args, expected]
  rows:
    - [sha256_module_hashlib, sha256.__module__.__eq__, ["_hashlib"], true]
    - [sha512_module_hashlib, sha512.__module__.__eq__, ["_hashlib"], true]

# ---------------------------------------------------------------------------
# hashlib.new __class__.__name__, __module__, and __qualname__
#
# Wave 245 theme: hashlib.new function identity.
#
# hashlib.new is a Python-level function (class 'function') that wraps the
# underlying C hash constructors. Its __module__ is 'hashlib' and its
# internal __qualname__ is '__hash_new'. No prior hashlib spec checks
# new.__class__.__name__, new.__module__, or new.__qualname__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra81.new_class_module_qualname:
  description: "hashlib.new/__class__/__name__.__eq__('function')==True / new/__module__.__eq__('hashlib')==True / new/__qualname__.__eq__('__hash_new')==True — new is a Python wrapper function; its internal qualname is '__hash_new'; no prior hashlib spec checks new.__class__.__name__/__module__/__qualname__; first identity anchor for hashlib.new"
  kind: python_call_eq
  category: class_attrs
  id_prefix: hashlibextra81

  columns: [id, function, args, expected]
  rows:
    - [new_class_function,       new.__class__.__name__.__eq__, ["function"],   true]
    - [new_module_hashlib,       new.__module__.__eq__,         ["hashlib"],    true]
    - [new_qualname_hash_new,    new.__qualname__.__eq__,        ["__hash_new"], true]

# ---------------------------------------------------------------------------
# hashlib.sha256.__name__.__eq__('openssl_sha256') — standalone
#
# sha256 is the openssl_sha256 C type. No prior hashlib spec checks
# sha256.__name__. First __name__ standalone for hashlib.sha256.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra81.sha256_name_openssl_sha256:
  description: "hashlib.sha256.__name__.__eq__('openssl_sha256') == True — sha256 is the openssl_sha256 C extension type from _hashlib; no prior hashlib spec checks sha256.__name__; first __name__ standalone for hashlib.sha256"
  category: class_attrs
  kind: python_call_eq
  function: sha256.__name__.__eq__
  args: ["openssl_sha256"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha256.__module__.__eq__('_hashlib') — standalone
#
# sha256.__module__ is '_hashlib' (the C extension providing the openssl types).
# No prior hashlib spec checks sha256.__module__. First __module__ standalone
# for hashlib.sha256. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra81.sha256_module_hashlib:
  description: "hashlib.sha256.__module__.__eq__('_hashlib') == True — sha256 is defined in the _hashlib C extension; no prior hashlib spec checks sha256.__module__; first __module__ standalone for hashlib.sha256"
  category: class_attrs
  kind: python_call_eq
  function: sha256.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__class__.__name__.__eq__('set') — standalone
#
# algorithms_available is a plain Python set. No prior hashlib spec checks
# algorithms_available.__class__.__name__. First type identity standalone
# for algorithms_available. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra81.algorithms_available_class_set:
  description: "hashlib.algorithms_available.__class__.__name__.__eq__('set') == True — algorithms_available is a plain Python set; no prior hashlib spec checks algorithms_available.__class__.__name__; first type identity standalone for algorithms_available"
  category: class_attrs
  kind: python_call_eq
  function: algorithms_available.__class__.__name__.__eq__
  args: ["set"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__qualname__.__eq__('__hash_new') — standalone
#
# hashlib.new is the public alias for the internal __hash_new wrapper function.
# Its __qualname__ is '__hash_new'. No prior hashlib spec checks new.__qualname__.
# First __qualname__ standalone for hashlib.new.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra81.new_qualname_hash_new:
  description: "hashlib.new.__qualname__.__eq__('__hash_new') == True — hashlib.new is an alias for the internal __hash_new function; no prior hashlib spec checks new.__qualname__; first __qualname__ standalone for hashlib.new"
  category: class_attrs
  kind: python_call_eq
  function: new.__qualname__.__eq__
  args: ["__hash_new"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha512.__name__.__eq__('openssl_sha512') — standalone
#
# sha512 is the openssl_sha512 C extension type from _hashlib. No prior hashlib
# spec checks sha512.__name__. First __name__ standalone for hashlib.sha512.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra81.sha512_name_openssl_sha512:
  description: "hashlib.sha512.__name__.__eq__('openssl_sha512') == True — sha512 is the openssl_sha512 C extension type from _hashlib; no prior hashlib spec checks sha512.__name__; first __name__ standalone for hashlib.sha512"
  category: class_attrs
  kind: python_call_eq
  function: sha512.__name__.__eq__
  args: ["openssl_sha512"]
  expected: true
