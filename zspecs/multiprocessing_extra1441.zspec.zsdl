spec: multiprocessing_extra1441
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 543 (_extra1441): focuses on __subclasshook__ and __instancecheck__ checks for multiprocessing classes."
    - "multiprocessing.Process, multiprocessing.pool.Pool, and multiprocessing.queues.Queue all use plain 'type' as metaclass."
    - "Therefore __subclasshook__ is inherited; its __class__.__name__ is 'builtin_function_or_method'."
    - "__instancecheck__ is inherited from 'type'; its __class__.__name__ is 'builtin_function_or_method'."
    - "None of the multiprocessing classes define __subclasshook__ or __instancecheck__ in their own __dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table multiprocessing_extra1441.subclasshook_class_name:
  description: "multiprocessing class __subclasshook__.__class__.__name__ identity — Process, pool.Pool, and queues.Queue all use plain 'type' as metaclass so __subclasshook__ is inherited and has __class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"
  kind: python_call_eq
  category: subclasshook_class_name
  id_prefix: mp1441sh
  columns: [id, function, args, expected]
  rows:
    - [mp1441sh001, multiprocessing.Process.__subclasshook__.__class__.__name__.__eq__,             ["builtin_function_or_method"], true]
    - [mp1441sh002, multiprocessing.pool.Pool.__subclasshook__.__class__.__name__.__eq__,           ["builtin_function_or_method"], true]
    - [mp1441sh003, multiprocessing.queues.Queue.__subclasshook__.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]
    - [mp1441sh004, multiprocessing.Process.__subclasshook__.__class__.__name__.__eq__,             ["builtin_function_or_method"], true]
    - [mp1441sh005, multiprocessing.pool.Pool.__subclasshook__.__class__.__name__.__eq__,           ["builtin_function_or_method"], true]
    - [mp1441sh006, multiprocessing.queues.Queue.__subclasshook__.__class__.__name__.__eq__,        ["builtin_function_or_method"], true]

table multiprocessing_extra1441.subclasshook_not_in_dict:
  description: "multiprocessing class __subclasshook__ absence from own __dict__ — Process, pool.Pool, and queues.Queue do not define __subclasshook__ in their own __dict__; all inherit it; verified with Python 3.14.3"
  kind: python_call_eq
  category: subclasshook_dict_membership
  id_prefix: mp1441sd
  columns: [id, function, args, expected]
  rows:
    - [mp1441sd001, multiprocessing.Process.__dict__.__contains__,             ["__subclasshook__"], false]
    - [mp1441sd002, multiprocessing.pool.Pool.__dict__.__contains__,           ["__subclasshook__"], false]
    - [mp1441sd003, multiprocessing.queues.Queue.__dict__.__contains__,        ["__subclasshook__"], false]
    - [mp1441sd004, multiprocessing.Process.__dict__.__contains__,             ["__instancecheck__"], false]
    - [mp1441sd005, multiprocessing.pool.Pool.__dict__.__contains__,           ["__instancecheck__"], false]
    - [mp1441sd006, multiprocessing.queues.Queue.__dict__.__contains__,        ["__instancecheck__"], false]

table multiprocessing_extra1441.instancecheck_class_name:
  description: "multiprocessing class __instancecheck__.__class__.__name__ identity — Process, pool.Pool, and queues.Queue all inherit __instancecheck__ from 'type'; its __class__.__name__ is 'builtin_function_or_method'; none define it in their own __dict__; verified with Python 3.14.3"
  kind: python_call_eq
  category: instancecheck_class_name
  id_prefix: mp1441ic
  columns: [id, function, args, expected]
  rows:
    - [mp1441ic001, multiprocessing.Process.__instancecheck__.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [mp1441ic002, multiprocessing.pool.Pool.__instancecheck__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [mp1441ic003, multiprocessing.queues.Queue.__instancecheck__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [mp1441ic004, multiprocessing.Process.__instancecheck__.__class__.__name__.__eq__,      ["builtin_function_or_method"], true]
    - [mp1441ic005, multiprocessing.pool.Pool.__instancecheck__.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [mp1441ic006, multiprocessing.queues.Queue.__instancecheck__.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
