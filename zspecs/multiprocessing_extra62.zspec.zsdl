spec: multiprocessing_extra62
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/reference/datamodel.html#inspect — Python code object co_name and co_argcount documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "This spec extends multiprocessing_extra61.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__.__class__.__name__/__len__() tables, Process/__class__.__name__=='type', cpu_count/__class__.__name__=='method', current_process/__class__.__name__=='function', ProcessError/AuthenticationError/__class__.__name__=='type' (extra45), Process/__class__.__module__=='builtins', current_process/__class__.__module__=='builtins', cpu_count/__class__.__module__=='builtins' (extra46), Pool/__doc__/__class__/__module__=='builtins' (extra50), Pool/__class__.__name__=='type', Pool/active_children/ProcessError/AuthenticationError __class__.__module__.__eq__('builtins') (extra53), Process/__init__.__class__.__name__.__eq__('function') (extra53), Process/Pool __repr__.__class__.__name__ (extra54), Process __weakref__.__class__.__name__ (extra54), ProcessError/AuthenticationError exception __repr__.__class__.__name__ (extra54), mp.__all__.__class__.__name__.__eq__('list') (extra55), mp.__all__.__len__()==37 (extra55), Process/ProcessError/AuthenticationError __eq__.__class__.__name__.__eq__('wrapper_descriptor') (extra55), mp.__all__.__contains__ membership checks (extra56), mp.__package__.__eq__('multiprocessing') (extra56), Queue/Pool __doc__.__class__.__name__.__eq__('str') (extra56), __loader__/__spec__/__file__/__cached__ __class__.__name__ (extra57), __spec__.origin/__spec__.submodule_search_locations/__spec__.has_location/__loader__.__class__.__name__.__len__() (extra58), Process method __qualname__ string equality for start/run/join/terminate/kill/is_alive/close/interrupt (extra59), Process.__init__/__annotations__/__globals__ class identity + current_process __annotations__ class identity and len (extra60), Process.__init__/__defaults__/__code__/__class__.__name__ checks, current_process/__defaults__/__code__/__class__.__name__ checks (extra61)."
    - "This spec covers (mpcode2_62 namespace): wave 230 theme — __code__.co_name equality + co_argcount values + co_name __class__.__name__ checks. NEW in extra62: Process.__init__.__code__.co_name.__eq__('__init__') — Process inherits __init__ from BaseProcess; co_name is the string name of the code object matching the definition name '__init__'; no prior mp spec has checked Process.__init__.__code__.co_name via __eq__; Process.start.__code__.co_name.__eq__('start') — co_name of Process.start is 'start'; current_process.__code__.co_name.__eq__('current_process') — co_name equals the definition name 'current_process'; Process.__init__.__code__.co_argcount.__eq__(6) — BaseProcess.__init__(self, group, target, name, args, kwargs, *, daemon=None) has 6 positional-or-keyword params (daemon is keyword-only); Process.start.__code__.co_argcount.__eq__(1) — Process.start(self) has 1; current_process.__code__.co_argcount.__eq__(0) — current_process() has no parameters."
    - "multiprocessing.Process.__init__.__code__.co_name == '__init__'. Process inherits __init__ from BaseProcess. BaseProcess.__init__ is defined as 'def __init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None)' in Lib/multiprocessing/process.py. co_name is '__init__'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.start.__code__.co_name == 'start'. Process.start is defined as 'def start(self)' in Lib/multiprocessing/process.py. co_name is 'start'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.current_process.__code__.co_name == 'current_process'. current_process is defined as 'def current_process()' in Lib/multiprocessing/process.py. co_name is 'current_process'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__init__.__code__.co_argcount == 6. BaseProcess.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None) has six positional-or-keyword parameters: self, group, target, name, args, kwargs. daemon is keyword-only and is NOT counted by co_argcount. co_argcount is 6. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.start.__code__.co_argcount == 1. Process.start(self) has one positional-or-keyword parameter: self. co_argcount is 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.current_process.__code__.co_argcount == 0. current_process() takes no parameters. co_argcount is 0. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "co_name.__class__.__name__ == 'str'. The co_name attribute on all code objects is a str. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "co_argcount.__class__.__name__ == 'int'. The co_argcount attribute on all code objects is an int. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing __code__.co_name.__eq__ checks — extra62
#
# Wave 230 theme: __code__.co_name equality checks.
#
# co_name is the string name stored in the code object, matching the function's
# definition name. For Process.__init__, Process.start, and current_process
# the co_name equals the function's definition name.
#
# NEW: no prior mp spec has checked __code__.co_name via __eq__ for any of
# these functions.
# ---------------------------------------------------------------------------

table multiprocessing_extra62.function_code_co_name_eq:
  description: "multiprocessing __code__.co_name.__eq__ checks in mpcode2_62 namespace — wave 230 theme: co_name equality; Process.__init__.__code__.co_name=='__init__', Process.start.__code__.co_name=='start', current_process.__code__.co_name=='current_process'; co_name is the string name stored in the code object matching the function definition name; NEW in extra62: no prior mp spec has checked __code__.co_name via __eq__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode2_62

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_co_name_eq,    Process.__init__.__code__.co_name.__eq__,    ["__init__"],       true, "Process.__init__.__code__.co_name == '__init__' — Process inherits __init__ from BaseProcess defined in Lib/multiprocessing/process.py as 'def __init__(self, group=None, ...)'; co_name stores the definition name; __eq__('__init__') returns True; NEW in extra62: first __code__.co_name.__eq__ check for Process.__init__ in any mp spec; verified with Python 3.14.3"]
    - [process_start_co_name_eq,   Process.start.__code__.co_name.__eq__,       ["start"],          true, "Process.start.__code__.co_name == 'start' — Process.start is defined as 'def start(self)' in Lib/multiprocessing/process.py; co_name stores the definition name; __eq__('start') returns True; NEW in extra62: first __code__.co_name.__eq__ check for Process.start in any mp spec; verified with Python 3.14.3"]
    - [current_process_co_name_eq, current_process.__code__.co_name.__eq__,     ["current_process"], true, "current_process.__code__.co_name == 'current_process' — current_process is defined as 'def current_process()' in Lib/multiprocessing/process.py; co_name stores the definition name; __eq__('current_process') returns True; NEW in extra62: first __code__.co_name.__eq__ check for current_process in any mp spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing __code__.co_argcount.__eq__ checks — extra62
#
# Wave 230 theme: co_argcount values.
#
# co_argcount counts positional-or-keyword parameters only. *args, **kwargs,
# and keyword-only parameters do NOT contribute to co_argcount.
#
# Process.__init__(self, group=None, target=None, name=None, args=(), kwargs={},
#   *, daemon=None): daemon is keyword-only, so co_argcount == 6 (self through kwargs)
# Process.start(self): co_argcount == 1
# current_process(): co_argcount == 0
# ---------------------------------------------------------------------------

table multiprocessing_extra62.function_code_co_argcount_eq:
  description: "multiprocessing __code__.co_argcount.__eq__ checks in mpcode2_62 namespace — wave 230 theme: co_argcount values; co_argcount counts positional-or-keyword parameters only (keyword-only excluded); Process.__init__==6 (self+group+target+name+args+kwargs; daemon is keyword-only), Process.start==1 (self), current_process==0; NEW in extra62: no prior mp spec has checked __code__.co_argcount via __eq__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode2_62a

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_co_argcount_eq,    Process.__init__.__code__.co_argcount.__eq__,    [6], true, "Process.__init__.__code__.co_argcount == 6 — BaseProcess.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None) has six positional-or-keyword parameters: self, group, target, name, args, kwargs; daemon is keyword-only and not counted by co_argcount; co_argcount is 6; NEW in extra62: first __code__.co_argcount.__eq__ check for Process.__init__ in any mp spec; verified with Python 3.14.3"]
    - [process_start_co_argcount_eq,   Process.start.__code__.co_argcount.__eq__,       [1], true, "Process.start.__code__.co_argcount == 1 — Process.start(self) has one positional-or-keyword parameter: self; co_argcount is 1; NEW in extra62: first __code__.co_argcount.__eq__ check for Process.start in any mp spec; verified with Python 3.14.3"]
    - [current_process_co_argcount_eq, current_process.__code__.co_argcount.__eq__,     [0], true, "current_process.__code__.co_argcount == 0 — current_process() takes no parameters; co_argcount is 0; NEW in extra62: first __code__.co_argcount.__eq__ check for current_process in any mp spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing __code__.co_name.__class__.__name__.__eq__ checks — extra62
#
# Wave 230 theme: co_name __class__.__name__ checks.
#
# co_name is always a str on all code objects. str.__class__.__name__ == 'str'.
# ---------------------------------------------------------------------------

table multiprocessing_extra62.function_code_co_name_class_name_eq:
  description: "multiprocessing __code__.co_name.__class__.__name__.__eq__('str') checks in mpcode2_62 namespace — wave 230 theme: co_name type identity; co_name is always a str on all code objects; Process.__init__/Process.start/current_process all have co_name.__class__.__name__=='str'; NEW in extra62: no prior mp spec has checked __code__.co_name.__class__.__name__ via __eq__ for any of these; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: mpcode2_62c

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_co_name_class_eq,    Process.__init__.__code__.co_name.__class__.__name__.__eq__,    ["str"], true, "Process.__init__.__code__.co_name.__class__.__name__ == 'str' — the co_name attribute of any code object is a str; Process.__init__.__code__.co_name is '__init__', a str; str.__class__.__name__ is 'str'; NEW in extra62: first __code__.co_name.__class__.__name__.__eq__ check for Process.__init__ in any mp spec; verified with Python 3.14.3"]
    - [process_start_co_name_class_eq,   Process.start.__code__.co_name.__class__.__name__.__eq__,      ["str"], true, "Process.start.__code__.co_name.__class__.__name__ == 'str' — Process.start.__code__.co_name is 'start', a str; str.__class__.__name__ is 'str'; NEW in extra62: first __code__.co_name.__class__.__name__.__eq__ check for Process.start in any mp spec; verified with Python 3.14.3"]
    - [current_process_co_name_class_eq, current_process.__code__.co_name.__class__.__name__.__eq__,    ["str"], true, "current_process.__code__.co_name.__class__.__name__ == 'str' — current_process.__code__.co_name is 'current_process', a str; str.__class__.__name__ is 'str'; NEW in extra62: first __code__.co_name.__class__.__name__.__eq__ check for current_process in any mp spec; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra62
# ---------------------------------------------------------------------------

invariant multiprocessing_extra62.process_init_co_name_eq:
  description: "multiprocessing.Process.__init__.__code__.co_name.__eq__('__init__') returns True — Process inherits __init__ from BaseProcess (Lib/multiprocessing/process.py); co_name stores the definition name '__init__'; __eq__('__init__') returns True; NEW in extra62: no prior mp spec has checked Process.__init__.__code__.co_name via __eq__; wave 230 first co_name equality invariant for Process.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant multiprocessing_extra62.process_start_co_name_eq:
  description: "multiprocessing.Process.start.__code__.co_name.__eq__('start') returns True — Process.start is defined as 'def start(self)' in Lib/multiprocessing/process.py; co_name is 'start'; __eq__('start') returns True; NEW in extra62: no prior mp spec has checked Process.start.__code__.co_name via __eq__; wave 230 first co_name equality invariant for Process.start; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.start.__code__.co_name.__eq__
  args: ["start"]
  expected: true

invariant multiprocessing_extra62.current_process_co_name_eq:
  description: "multiprocessing.current_process.__code__.co_name.__eq__('current_process') returns True — current_process is defined as 'def current_process()' in Lib/multiprocessing/process.py; co_name is 'current_process'; __eq__('current_process') returns True; NEW in extra62: no prior mp spec has checked current_process.__code__.co_name via __eq__; wave 230 first co_name equality invariant for current_process; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: current_process.__code__.co_name.__eq__
  args: ["current_process"]
  expected: true

invariant multiprocessing_extra62.process_init_co_argcount_eq:
  description: "multiprocessing.Process.__init__.__code__.co_argcount.__eq__(6) returns True — BaseProcess.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, *, daemon=None) has six positional-or-keyword parameters (self, group, target, name, args, kwargs); daemon is keyword-only and not counted; co_argcount is 6; NEW in extra62: no prior mp spec has checked Process.__init__.__code__.co_argcount via __eq__; wave 230 first co_argcount value invariant for Process.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.__init__.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant multiprocessing_extra62.process_start_co_argcount_eq:
  description: "multiprocessing.Process.start.__code__.co_argcount.__eq__(1) returns True — Process.start(self) has one positional-or-keyword parameter: self; co_argcount is 1; NEW in extra62: no prior mp spec has checked Process.start.__code__.co_argcount via __eq__; wave 230 first co_argcount value invariant for Process.start; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.start.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant multiprocessing_extra62.current_process_co_argcount_eq:
  description: "multiprocessing.current_process.__code__.co_argcount.__eq__(0) returns True — current_process() takes no parameters; co_argcount is 0; NEW in extra62: no prior mp spec has checked current_process.__code__.co_argcount via __eq__; wave 230 first co_argcount value invariant for current_process; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: current_process.__code__.co_argcount.__eq__
  args: [0]
  expected: true

invariant multiprocessing_extra62.process_init_co_name_class_name_eq:
  description: "multiprocessing.Process.__init__.__code__.co_name.__class__.__name__.__eq__('str') returns True — co_name on any code object is always a str; Process.__init__.__code__.co_name is '__init__', a str; str.__class__.__name__ is 'str'; NEW in extra62: no prior mp spec has checked Process.__init__.__code__.co_name.__class__.__name__ via __eq__; wave 230 co_name type identity invariant for Process.__init__; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Process.__init__.__code__.co_name.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant multiprocessing_extra62.current_process_co_name_class_name_eq:
  description: "multiprocessing.current_process.__code__.co_name.__class__.__name__.__eq__('str') returns True — current_process.__code__.co_name is 'current_process', a str; str.__class__.__name__ is 'str'; NEW in extra62: no prior mp spec has checked current_process.__code__.co_name.__class__.__name__ via __eq__; wave 230 co_name type identity invariant for current_process; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: current_process.__code__.co_name.__class__.__name__.__eq__
  args: ["str"]
  expected: true
