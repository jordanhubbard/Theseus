spec: lodash_isnil
version: ">=4.0.0"
backend: node(lodash.isnil)

docs: https://lodash.com/docs/#isNil

provenance:
  derived_from:
    - "lodash.isnil README — https://www.npmjs.com/package/lodash.isnil"
    - "Test vectors verified with lodash.isnil@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isnil exports the _.isNil function directly as module.exports."
    - "isNil checks if value is null or undefined."
    - "JSON null maps to JS null; undefined cannot appear in JSON input."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isnil.isnil:
  kind: node_module_call_eq
  function: ~
  category: isnil
  id_prefix: lisnl

  columns: [id, args, expected]
  rows:
    - [null_val,  [null],         true]
    - [zero,      [0],            false]
    - [empty_str, [""],           false]
    - [false_val, [false],        false]
    - [object,    [{"a": 1}],    false]

