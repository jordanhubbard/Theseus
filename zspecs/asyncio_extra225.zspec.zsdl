spec: asyncio_extra225
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
  notes:
    - "asyncio.Queue.__doc__.__contains__('queue') == True — Queue.__doc__ starts with 'A queue, useful for coordinating producer and consumer coroutines.'; 'queue' (lowercase) is present; verified with Python 3.14.3."
    - "asyncio.Lock.__doc__.__contains__('lock') == True — Lock.__doc__ starts with 'Primitive lock objects.'; 'lock' (lowercase) is present in 'lock objects'; verified with Python 3.14.3."
    - "asyncio.Event.__doc__.__contains__('event') == True — Event.__doc__ starts with 'Asynchronous equivalent to threading.Event.'; 'event' is present as part of 'threading.Event'; verified with Python 3.14.3."
    - "asyncio.Semaphore.__doc__.__contains__('semaphore') == True — Semaphore.__doc__ starts with 'A Semaphore implementation.'; 'semaphore' is present in 'Semaphore manages an internal counter'; verified with Python 3.14.3."
    - "asyncio.Condition.__doc__.__contains__('condition') == True — Condition.__doc__ starts with 'Asynchronous equivalent to threading.Condition.'; 'condition' is present as part of 'threading.Condition'; verified with Python 3.14.3."
    - "asyncio.Task.__doc__.__contains__('coroutine') == True — Task.__doc__ is 'A coroutine wrapped in a Future.'; 'coroutine' is present; verified with Python 3.14.3."
    - "asyncio.Future.__doc__.__contains__('Future') == True — Future.__doc__ starts with 'This class is *almost* compatible with concurrent.futures.Future.'; 'Future' (uppercase) is present; verified with Python 3.14.3."
    - "asyncio.sleep.__doc__.__contains__('Coroutine') == True — sleep.__doc__ is 'Coroutine that completes after a given time (in seconds).'; 'Coroutine' is present (uppercase C); 'sleep' (lowercase) is NOT in the docstring; verified with Python 3.14.3."
    - "asyncio.CancelledError.__doc__.__contains__('cancelled') == True — CancelledError.__doc__ is 'The Future or Task was cancelled.'; 'cancelled' (lowercase) is present; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Queue, Lock, Event __doc__ contains checks — extra225 namespace
#
# Queue.__doc__ contains 'queue' (lowercase); verified Python 3.14.3.
# Lock.__doc__ contains 'lock' (lowercase); verified Python 3.14.3.
# Event.__doc__ contains 'event' (lowercase); verified Python 3.14.3.
# ---------------------------------------------------------------------------

table asyncio_extra225.queue_lock_event_doc:
  description: "asyncio Queue, Lock, Event __doc__.__contains__ checks in aio225doc namespace"
  kind: python_call_eq
  category: doc_contains
  id_prefix: aio225doc

  columns: [id, function, args, expected, description]
  rows:
    - [queue_doc_has_queue, Queue.__doc__.__contains__, ["queue"], true, "asyncio.Queue.__doc__.__contains__('queue') == True — Queue.__doc__ is 'A queue, useful for coordinating producer and consumer coroutines.'; 'queue' is present; verified with Python 3.14.3"]
    - [lock_doc_has_lock,   Lock.__doc__.__contains__,  ["lock"],  true, "asyncio.Lock.__doc__.__contains__('lock') == True — Lock.__doc__ starts with 'Primitive lock objects.'; 'lock' is present in 'lock objects'; verified with Python 3.14.3"]
    - [event_doc_has_event, Event.__doc__.__contains__, ["event"], true, "asyncio.Event.__doc__.__contains__('event') == True — Event.__doc__ contains 'threading.Event'; 'event' is present as part of that reference; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Semaphore, Condition __doc__ contains checks — extra225 namespace
#
# Semaphore.__doc__ contains 'semaphore'; verified Python 3.14.3.
# Condition.__doc__ contains 'condition'; verified Python 3.14.3.
# ---------------------------------------------------------------------------

table asyncio_extra225.semaphore_condition_doc:
  description: "asyncio Semaphore and Condition __doc__.__contains__ checks in aio225doc namespace"
  kind: python_call_eq
  category: doc_contains
  id_prefix: aio225doca

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_doc_has_semaphore, Semaphore.__doc__.__contains__, ["semaphore"], true, "asyncio.Semaphore.__doc__.__contains__('semaphore') == True — Semaphore.__doc__ starts with 'A Semaphore implementation.'; 'semaphore' appears in 'A semaphore manages an internal counter'; verified with Python 3.14.3"]
    - [condition_doc_has_condition, Condition.__doc__.__contains__, ["condition"], true, "asyncio.Condition.__doc__.__contains__('condition') == True — Condition.__doc__ starts with 'Asynchronous equivalent to threading.Condition.'; 'condition' appears in that reference; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio Task and Future __doc__ contains checks — extra225 namespace
#
# Task.__doc__ contains 'coroutine'; Future.__doc__ contains 'Future'.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table asyncio_extra225.task_future_doc:
  description: "asyncio Task and Future __doc__.__contains__ checks in aio225doc namespace"
  kind: python_call_eq
  category: doc_contains
  id_prefix: aio225docb

  columns: [id, function, args, expected, description]
  rows:
    - [task_doc_has_coroutine, Task.__doc__.__contains__,   ["coroutine"], true, "asyncio.Task.__doc__.__contains__('coroutine') == True — Task.__doc__ is 'A coroutine wrapped in a Future.'; 'coroutine' is present; verified with Python 3.14.3"]
    - [future_doc_has_Future,  Future.__doc__.__contains__,  ["Future"],   true, "asyncio.Future.__doc__.__contains__('Future') == True — Future.__doc__ starts with 'This class is *almost* compatible with concurrent.futures.Future.'; 'Future' (uppercase) is present; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio sleep and CancelledError __doc__ contains checks — extra225 namespace
#
# sleep.__doc__ contains 'Coroutine' (NOT 'sleep'); verified Python 3.14.3.
# CancelledError.__doc__ contains 'cancelled'; verified Python 3.14.3.
# ---------------------------------------------------------------------------

invariant asyncio_extra225.sleep_doc_has_Coroutine:
  description: "asyncio.sleep.__doc__.__contains__('Coroutine') == True — sleep.__doc__ is 'Coroutine that completes after a given time (in seconds).'; 'Coroutine' (uppercase C) is present; note: 'sleep' (lowercase) does NOT appear in the docstring; NEW in extra225: first sleep.__doc__ contains check; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: sleep.__doc__.__contains__
  args: ["Coroutine"]
  expected: true

invariant asyncio_extra225.cancelled_error_doc_has_cancelled:
  description: "asyncio.CancelledError.__doc__.__contains__('cancelled') == True — CancelledError.__doc__ is 'The Future or Task was cancelled.'; 'cancelled' (lowercase) is present; NEW in extra225: first CancelledError.__doc__ contains check; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: doc_contains
  kind: python_call_eq
  function: CancelledError.__doc__.__contains__
  args: ["cancelled"]
  expected: true
