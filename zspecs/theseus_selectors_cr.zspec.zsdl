spec: theseus_selectors_cr
version: ">=3.8"
backend: python_cleanroom(theseus_selectors_cr)
blocks: selectors

docs: https://docs.python.org/3/library/selectors.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/selectors.html"
  not_derived_from:
    - "CPython source: Lib/selectors.py"
  notes:
    - "Clean-room selectors module. Do NOT import selectors."

error_model: python_exceptions

invariant theseus_selectors_cr.selectors2_create:
  description: "DefaultSelector() can be created and closed"
  category: behavior
  kind: python_call_eq
  function: selectors2_create
  args: []
  expected: true

invariant theseus_selectors_cr.selectors2_register:
  description: "register/unregister a pipe read end works"
  category: behavior
  kind: python_call_eq
  function: selectors2_register
  args: []
  expected: true

invariant theseus_selectors_cr.selectors2_select_timeout:
  description: "select() with timeout=0 returns quickly on empty set"
  category: behavior
  kind: python_call_eq
  function: selectors2_select_timeout
  args: []
  expected: true
