spec: decimal_extra188
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra187.zspec.zsdl."
    - "This spec covers decimal.Context class identity — __name__, __module__, __bases__[0].__name__, __class__.__name__, __init__.__qualname__, __repr__.__qualname__, copy.__qualname__, and __str__.__qualname__."
    - "decimal.Context.__name__ == 'Context' (len=7); confirmed Python 3.14.3 macOS."
    - "decimal.Context.__module__ == 'decimal' (len=7); the public module name, not '_decimal'; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__bases__[0].__name__ == 'object' — Context inherits directly from object; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS."
    - "decimal.Context.__init__.__qualname__ == 'Context.__init__' (len=16: 'Context.'=8+'__init__'=8=16); confirmed Python 3.14.3 macOS."
    - "decimal.Context.__repr__.__qualname__ == 'Context.__repr__' (len=16: 'Context.'=8+'__repr__'=8=16); same length as __init__; confirmed Python 3.14.3 macOS."
    - "decimal.Context.copy.__qualname__ == 'Context.copy' (len=12: 'Context.'=8+'copy'=4=12); confirmed Python 3.14.3 macOS."
    - "decimal.Context.__str__.__qualname__ == 'object.__str__' (len=14) — Context does not define its own __str__; it inherits __str__ from object; confirmed Python 3.14.3 macOS."
    - "Qualname length ordering: copy(12) < object.__str__(14) < __init__(16)==__repr__(16); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: decimal.Context method __qualname__ equality
# copy(12), object.__str__(14), __init__(16), __repr__(16)
# ---------------------------------------------------------------------------

table decimal_extra188.context_method_qualnames:
  description: "decimal.Context method __qualname__ values: copy='Context.copy'(12), __str__='object.__str__'(14, inherited), __init__='Context.__init__'(16), __repr__='Context.__repr__'(16)"
  kind: python_call_eq
  category: identity
  id_prefix: decimalcontext188

  columns: [id, function, args, expected, description]
  rows:
    - [copy_qn_eq,   decimal.Context.copy.__qualname__.__eq__,     ["Context.copy"],     true, "decimal.Context.copy.__qualname__ == 'Context.copy' (len=12); confirmed Python 3.14.3 macOS"]
    - [str_qn_eq,    decimal.Context.__str__.__qualname__.__eq__,  ["object.__str__"],   true, "decimal.Context.__str__.__qualname__ == 'object.__str__' (len=14); Context inherits __str__ from object; confirmed Python 3.14.3 macOS"]
    - [init_qn_eq,   decimal.Context.__init__.__qualname__.__eq__, ["Context.__init__"], true, "decimal.Context.__init__.__qualname__ == 'Context.__init__' (len=16); confirmed Python 3.14.3 macOS"]
    - [repr_qn_eq,   decimal.Context.__repr__.__qualname__.__eq__, ["Context.__repr__"], true, "decimal.Context.__repr__.__qualname__ == 'Context.__repr__' (len=16, same as __init__); confirmed Python 3.14.3 macOS"]
    - [copy_qn_len,  decimal.Context.copy.__qualname__.__len__,    [],                   12,   "decimal.Context.copy.__qualname__.__len__() == 12 ('Context.'=8+'copy'=4); shortest qualname in spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: decimal.Context method __qualname__ lengths
# copy(12) < __str__(14) < __init__(16) == __repr__(16)
# ---------------------------------------------------------------------------

table decimal_extra188.context_method_qualname_lengths:
  description: "decimal.Context method __qualname__ lengths: copy=12, __str__=14, __init__=16, __repr__=16; length ordering copy < __str__ < __init__==__repr__"
  kind: python_call_eq
  category: identity
  id_prefix: decimalcontext188

  columns: [id, function, args, expected, description]
  rows:
    - [copy_qn_len,  decimal.Context.copy.__qualname__.__len__,    [], 12, "decimal.Context.copy.__qualname__.__len__() == 12 ('Context.'=8+'copy'=4); shortest in spec; confirmed Python 3.14.3 macOS"]
    - [str_qn_len,   decimal.Context.__str__.__qualname__.__len__, [], 14, "decimal.Context.__str__.__qualname__.__len__() == 14 ('object.__str__': 'object.'=7+'__str__'=7=14); inherited from object; confirmed Python 3.14.3 macOS"]
    - [init_qn_len,  decimal.Context.__init__.__qualname__.__len__, [], 16, "decimal.Context.__init__.__qualname__.__len__() == 16 ('Context.__init__': 'Context.'=8+'__init__'=8=16); confirmed Python 3.14.3 macOS"]
    - [repr_qn_len,  decimal.Context.__repr__.__qualname__.__len__, [], 16, "decimal.Context.__repr__.__qualname__.__len__() == 16 ('Context.__repr__': 'Context.'=8+'__repr__'=8=16); same length as __init__; confirmed Python 3.14.3 macOS"]
    - [name_len,     decimal.Context.__name__.__len__,              [], 7,  "decimal.Context.__name__.__len__() == 7 — C(1)o(2)n(3)t(4)e(5)x(6)t(7); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: decimal.Context class-level identity attributes
# __name__(Context,7), __module__(decimal,7), __bases__[0].__name__(object), __class__(type)
# ---------------------------------------------------------------------------

table decimal_extra188.context_class_identity:
  description: "decimal.Context class-level identity: __name__='Context'(7), __module__='decimal'(7), __bases__[0].__name__='object', __class__.__name__='type'"
  kind: python_call_eq
  category: identity
  id_prefix: decimalcontext188

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,       decimal.Context.__name__.__eq__,                          ["Context"], true, "decimal.Context.__name__ == 'Context' (len=7); confirmed Python 3.14.3 macOS"]
    - [module_eq,     decimal.Context.__module__.__eq__,                        ["decimal"], true, "decimal.Context.__module__ == 'decimal' (len=7, public module name not '_decimal'); confirmed Python 3.14.3 macOS"]
    - [base_eq,       "decimal.Context.__bases__[0].__name__.__eq__",           ["object"],  true, "decimal.Context.__bases__[0].__name__ == 'object'; Context directly subclasses object; confirmed Python 3.14.3 macOS"]
    - [class_name_eq, decimal.Context.__class__.__name__.__eq__,                ["type"],    true, "decimal.Context.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS"]
    - [module_len,    decimal.Context.__module__.__len__,                        [],          7,    "decimal.Context.__module__.__len__() == 7 — d(1)e(2)c(3)i(4)m(5)a(6)l(7); same length as __name__ 'Context'=7; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra188.context_name_eq:
  description: "decimal.Context.__name__ == 'Context' — class name string length 7 ('Context'); decimal.Context is the class that encapsulates the decimal arithmetic context (precision, rounding mode, enabled traps, etc.); its __name__ is the plain class name; note __name__ length (7) equals __module__ length ('decimal'=7); confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra188.context_module_eq:
  description: "decimal.Context.__module__ == 'decimal' — the public module name is used (len=7), not '_decimal'; CPython's C-accelerated decimal module deliberately sets __module__ to 'decimal' so that instances pickle and repr correctly against the high-level API; this parallels decimal.Decimal which also reports __module__=='decimal'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra188.context_base_eq:
  description: "decimal.Context.__bases__[0].__name__ == 'object' — Context directly inherits from object (the root of all Python classes); Context does not inherit from any numeric tower or context abstract base class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "decimal.Context.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra188.context_class_name_type:
  description: "decimal.Context.__class__.__name__ == 'type' — Context's metaclass is the plain 'type'; Context is a C-level extension type but its metaclass is the standard 'type', not a custom metaclass; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant decimal_extra188.context_init_qualname_eq:
  description: "decimal.Context.__init__.__qualname__ == 'Context.__init__' — Context defines its own __init__; the qualname is 'Context.__init__' (len=16: 'Context.'=8 + '__init__'=8 = 16); this contrasts with decimal.Decimal which inherits __init__ from object; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__init__.__qualname__.__eq__
  args: ["Context.__init__"]
  expected: true

invariant decimal_extra188.context_repr_qualname_eq:
  description: "decimal.Context.__repr__.__qualname__ == 'Context.__repr__' — the qualified name of the __repr__ method is 'Context.__repr__' (len=16: 'Context.'=8 + '__repr__'=8 = 16); same length as __init__.__qualname__; __repr__ produces the developer-friendly string representation of the context; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__repr__.__qualname__.__eq__
  args: ["Context.__repr__"]
  expected: true

invariant decimal_extra188.context_copy_qualname_eq:
  description: "decimal.Context.copy.__qualname__ == 'Context.copy' — the qualified name of the copy method is 'Context.copy' (len=12: 'Context.'=8 + 'copy'=4 = 12); this is the shortest qualname in the spec; copy() returns a duplicate of the context; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.copy.__qualname__.__eq__
  args: ["Context.copy"]
  expected: true

invariant decimal_extra188.context_str_qualname_eq:
  description: "decimal.Context.__str__.__qualname__ == 'object.__str__' — Context does not define its own __str__ method; it inherits __str__ from object; as a result the qualname reflects object's __str__ rather than 'Context.__str__'; the qualname length is 14 ('object.__str__': 'object.'=7+'__str__'=7=14); this contrasts with __init__ and __repr__ which Context does define; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__str__.__qualname__.__eq__
  args: ["object.__str__"]
  expected: true

