spec: io_extra362
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "io.UnsupportedOperation has two bases: OSError and ValueError (multiple inheritance); __bases__[0].__name__ == 'OSError'"
    - "io.RawIOBase, io.BufferedIOBase, io.TextIOBase, and io.IOBase all report __module__ == 'io'"
    - "The abstract base classes' __bases__[0].__name__ values are the C-level private types: _RawIOBase, _BufferedIOBase, _TextIOBase, _IOBase"
    - "All class __name__, __module__, __bases__[0].__name__ values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io exception class identity — UnsupportedOperation
# ---------------------------------------------------------------------------

invariant io_extra362.unsupported_operation_name:
  description: "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' — the exception raised when an I/O operation is not supported on a stream; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: io.UnsupportedOperation.__name__.__eq__
  args: ["UnsupportedOperation"]
  expected: true

invariant io_extra362.unsupported_operation_module:
  description: "io.UnsupportedOperation.__module__ == 'io' — despite being backed by the _io C extension, UnsupportedOperation reports its module as 'io'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: io.UnsupportedOperation.__module__.__eq__
  args: ["io"]
  expected: true

invariant io_extra362.unsupported_operation_base0:
  description: "io.UnsupportedOperation.__bases__[0].__name__ == 'OSError' — UnsupportedOperation uses multiple inheritance from OSError and ValueError; __bases__[0] is OSError; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "io.UnsupportedOperation.__bases__[0].__name__.__eq__"
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# io abstract base class identity — class names
# ---------------------------------------------------------------------------

table io_extra362.abc_class_names:
  description: "io abstract base class __name__ identity checks — RawIOBase, BufferedIOBase, TextIOBase, IOBase; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ioabcname362

  columns: [id, function, args, expected]
  rows:
    - [rawiobase_name,      io.RawIOBase.__name__.__eq__,      ["RawIOBase"],      true]
    - [bufferediobase_name, io.BufferedIOBase.__name__.__eq__, ["BufferedIOBase"], true]
    - [textiobase_name,     io.TextIOBase.__name__.__eq__,     ["TextIOBase"],     true]
    - [iobase_name,         io.IOBase.__name__.__eq__,         ["IOBase"],         true]

# ---------------------------------------------------------------------------
# io abstract base class identity — module attributes
# ---------------------------------------------------------------------------

table io_extra362.abc_class_modules:
  description: "io abstract base class __module__ identity checks — RawIOBase, BufferedIOBase, TextIOBase, IOBase all report __module__ as 'io'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ioabcmod362

  columns: [id, function, args, expected]
  rows:
    - [rawiobase_module,      io.RawIOBase.__module__.__eq__,      ["io"], true]
    - [bufferediobase_module, io.BufferedIOBase.__module__.__eq__, ["io"], true]
    - [textiobase_module,     io.TextIOBase.__module__.__eq__,     ["io"], true]
    - [iobase_module,         io.IOBase.__module__.__eq__,         ["io"], true]

# ---------------------------------------------------------------------------
# io abstract base class identity — base class names
# ---------------------------------------------------------------------------

table io_extra362.abc_class_bases:
  description: "io abstract base class __bases__[0].__name__ identity checks — RawIOBase extends _RawIOBase; BufferedIOBase extends _BufferedIOBase; TextIOBase extends _TextIOBase; IOBase extends _IOBase (C-level private types); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ioabcbase362

  columns: [id, function, args, expected]
  rows:
    - [rawiobase_base,      "io.RawIOBase.__bases__[0].__name__.__eq__",      ["_RawIOBase"],      true]
    - [bufferediobase_base, "io.BufferedIOBase.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true]
    - [textiobase_base,     "io.TextIOBase.__bases__[0].__name__.__eq__",     ["_TextIOBase"],     true]
    - [iobase_base,         "io.IOBase.__bases__[0].__name__.__eq__",         ["_IOBase"],         true]
