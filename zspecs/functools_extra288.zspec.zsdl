spec: functools_extra288
version: ">=3.2"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools.partial behavioral contracts — partial objects with keyword args, the partial class identity, and __module__ / __doc__ attributes."
    - "functools.partial(int, base=16)('ff') == 255 — partial pre-applies base=16 keyword arg to int(); calling with 'ff' decodes hex to 255. Verified with Python 3.14.3."
    - "functools.partial(sorted, key=len)(['bb','a','ccc']) == ['a','bb','ccc'] — partial pre-applies key=len; sorted by string length ascending yields ['a','bb','ccc']. Verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial'; __module__ == 'functools'; __class__.__name__ == 'type' — partial is a C-level type defined in _functoolsmodule.c. Verified with Python 3.14.3."
    - "functools.partial.__doc__ is not None — partial ships with a docstring that starts 'Create a new function with partial application of the given ...'. Verified with Python 3.14.3."
    - "functools.partial(int).__module__ == 'functools' — a partial *instance* has __module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.partial(int).__class__.__name__ == 'partial' — partial instances are of type partial (lowercase), not of type 'type'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial class identity
#
# partial.__name__ == 'partial'
# partial.__module__ == 'functools'
# partial.__class__.__name__ == 'type'  (partial is a C-level type)
# partial.__doc__.__eq__(None) == False  (has docstring)
# ---------------------------------------------------------------------------

table functools_extra288.partial_class_identity:
  description: "functools.partial class identity: __name__, __module__, __class__.__name__, __doc__ not None; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftpci288

  columns: [id, function, args, expected, description]
  rows:
    - [pci_name_eq,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__ == 'partial' — the class name; verified with Python 3.14.3"]
    - [pci_mod_eq,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__ == 'functools' — partial is exposed via the functools module; verified with Python 3.14.3"]
    - [pci_cls_eq,
       partial.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partial.__class__.__name__ == 'type' — partial is a C-level type object; verified with Python 3.14.3"]
    - [pci_doc_not_none,
       partial.__doc__.__eq__,
       [null],
       false,
       "functools.partial.__doc__.__eq__(None) == False — partial ships with a non-None docstring; verified with Python 3.14.3"]
    - [pci_name_len,
       partial.__name__.__len__,
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — the string 'partial' has 7 characters; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial instance properties
#
# partial(int).__class__.__name__ == 'partial'  (instance is of type partial)
# partial(int).__module__ == 'functools'
# These are tested via dotted attribute access on module-level names.
# ---------------------------------------------------------------------------

table functools_extra288.partial_instance_identity:
  description: "functools.partial instance: __class__.__name__ == 'partial', __module__ == 'functools'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftpii288

  columns: [id, function, args, expected, description]
  rows:
    - [pii_inst_cls_eq,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__ == 'partial' — instances are instances of class 'partial'; verified with Python 3.14.3"]
    - [pii_inst_mod_eq,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__ == 'functools' — partial is in the functools namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra288
# ---------------------------------------------------------------------------

invariant functools_extra288.partial_class_name_is_partial:
  description: "functools.partial.__name__ == 'partial' — the class name attribute; new to extra288"
  category: identity
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra288.partial_class_module_is_functools:
  description: "functools.partial.__module__ == 'functools' — partial is exposed in the functools namespace; new to extra288"
  category: identity
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra288.partial_class_is_type:
  description: "functools.partial.__class__.__name__ == 'type' — partial is a C-level type object; new to extra288"
  category: identity
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra288.partial_doc_is_not_none:
  description: "functools.partial.__doc__.__eq__(None) == False — the partial class ships with a docstring; new to extra288"
  category: identity
  kind: python_call_eq
  function: partial.__doc__.__eq__
  args: [null]
  expected: false

invariant functools_extra288.partial_name_len_is_7:
  description: "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters; new to extra288"
  category: identity
  kind: python_call_eq
  function: partial.__name__.__len__
  args: []
  expected: 7

invariant functools_extra288.partial_name_starts_p:
  description: "functools.partial.__name__.__startswith__('p') == True — 'partial' begins with 'p'; new to extra288"
  category: identity
  kind: python_call_eq
  function: partial.__name__.__startswith__
  args: ["p"]
  expected: true

invariant functools_extra288.partial_module_len_is_9:
  description: "functools.partial.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra288"
  category: identity
  kind: python_call_eq
  function: partial.__module__.__len__
  args: []
  expected: 9

invariant functools_extra288.partial_name_contains_a:
  description: "functools.partial.__name__.__contains__('a') == True — 'partial' contains the letter 'a'; new to extra288"
  category: identity
  kind: python_call_eq
  function: partial.__name__.__contains__
  args: ["a"]
  expected: true
