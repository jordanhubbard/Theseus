table concurrent_futures_extra198.exception_class_names:
  description: "cf.BrokenExecutor/InvalidStateError/CancelledError/TimeoutError __class__.__name__ == 'type'; all exception classes use built-in type as metaclass; new to concurrent_futures_extra198"
  kind: python_call_eq
  category: metaclass_identity
  id_prefix: cfclasses198

  columns: [id, function, args, expected, description]
  rows:
    - [broken_executor_class_name_eq_type,
       "BrokenExecutor.__class__.__name__.__eq__",
       ["type"],
       true,
       "cf.BrokenExecutor.__class__.__name__.__eq__('type') == True — BrokenExecutor is a plain class; __class__ is the built-in type; new to concurrent_futures_extra198"]
    - [invalid_state_class_name_eq_type,
