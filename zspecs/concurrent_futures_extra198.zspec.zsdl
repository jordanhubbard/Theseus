       ["type"],
       true,
       "cf.ThreadPoolExecutor.__class__.__name__.__eq__('type') == True — ThreadPoolExecutor is a plain class; __class__ is the built-in type; new to concurrent_futures_extra198"]
    - [threadpool_class_name_len_eq_4,
       "ThreadPoolExecutor.__class__.__name__.__len__",
       [],
       4,
       "cf.ThreadPoolExecutor.__class__.__name__.__len__() == 4 — 'type' has 4 characters; new to concurrent_futures_extra198"]
    - [processpool_class_name_eq_type,
       "ProcessPoolExecutor.__class__.__name__.__eq__",
       ["type"],
       true,
       "cf.ProcessPoolExecutor.__class__.__name__.__eq__('type') == True — ProcessPoolExecutor is a plain class; __class__ is the built-in type; new to concurrent_futures_extra198"]
    - [processpool_class_name_len_eq_4,
       "ProcessPoolExecutor.__class__.__name__.__len__",
       [],
       4,
       "cf.ProcessPoolExecutor.__class__.__name__.__len__() == 4 — 'type' has 4 characters; new to concurrent_futures_extra198"]

# ---------------------------------------------------------------------------
# Table 3: BrokenExecutor, InvalidStateError, CancelledError, TimeoutError __class__.__name__
#
# concurrent.futures.BrokenExecutor.__class__.__name__ == 'type'
