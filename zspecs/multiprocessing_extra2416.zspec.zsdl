spec: multiprocessing_extra2416
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/multiprocessing.html"
    - "CPython source — Lib/multiprocessing/pool.py, queues.py, process.py, managers.py"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 608 (_extra2416): __iter__ and __next__ dict-presence and type classification."
    - "multiprocessing.pool.IMapIterator defines both __iter__ and __next__ in its __dict__ (pure Python, so function type)."
    - "multiprocessing.pool.IMapUnorderedIterator inherits from IMapIterator but does NOT override __iter__ or __next__."
    - "multiprocessing.queues.Queue, pool.Pool, pool.ApplyResult, Process, and managers.SyncManager are NOT iterable."
    - "The pool iterator classes are pure Python, so __iter__ and __next__ are plain function objects, not wrapper_descriptors."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ===
# Table 1: __iter__ presence in class __dict__ — pool iterator types vs non-iterators
# ===

table multiprocessing_extra2416.iter_in_dict:
  description: "Only multiprocessing.pool.IMapIterator defines __iter__ in its own __dict__; other types do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2416
  columns: [id, function, args, expected]
  rows:
    - ["mp2416001", "multiprocessing.pool.IMapIterator.__dict__.__contains__", ["__iter__"], true]
    - ["mp2416002", "multiprocessing.pool.IMapUnorderedIterator.__dict__.__contains__", ["__iter__"], false]
    - ["mp2416003", "multiprocessing.queues.Queue.__dict__.__contains__", ["__iter__"], false]
    - ["mp2416004", "multiprocessing.pool.Pool.__dict__.__contains__", ["__iter__"], false]
    - ["mp2416005", "multiprocessing.pool.ApplyResult.__dict__.__contains__", ["__iter__"], false]
    - ["mp2416006", "multiprocessing.Process.__dict__.__contains__", ["__iter__"], false]
    - ["mp2416007", "multiprocessing.managers.SyncManager.__dict__.__contains__", ["__iter__"], false]

# ===
# Table 2: __next__ presence in class __dict__ — IMapIterator only
# ===

table multiprocessing_extra2416.next_in_dict:
  description: "Only multiprocessing.pool.IMapIterator defines __next__ in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2416
  columns: [id, function, args, expected]
  rows:
    - ["mp2416008", "multiprocessing.pool.IMapIterator.__dict__.__contains__", ["__next__"], true]
    - ["mp2416009", "multiprocessing.pool.IMapUnorderedIterator.__dict__.__contains__", ["__next__"], false]
    - ["mp2416010", "multiprocessing.queues.Queue.__dict__.__contains__", ["__next__"], false]
    - ["mp2416011", "multiprocessing.pool.Pool.__dict__.__contains__", ["__next__"], false]
    - ["mp2416012", "multiprocessing.pool.ApplyResult.__dict__.__contains__", ["__next__"], false]
    - ["mp2416013", "multiprocessing.Process.__dict__.__contains__", ["__next__"], false]
    - ["mp2416014", "multiprocessing.managers.SyncManager.__dict__.__contains__", ["__next__"], false]

# ===
# Table 3: descriptor type — IMapIterator uses pure Python functions (not C slots)
# ===

table multiprocessing_extra2416.iter_descriptor_class:
  description: "IMapIterator.__iter__ and __next__ are plain Python function objects, unlike C-extension itertools types"
  kind: python_call_eq
  category: type_identity
  id_prefix: mp2416
  columns: [id, function, args, expected]
  rows:
    - ["mp2416015", "multiprocessing.pool.IMapIterator.__iter__.__class__.__name__", [], "function"]
    - ["mp2416016", "multiprocessing.pool.IMapIterator.__next__.__class__.__name__", [], "function"]

# ===
# Table 4: full matrix — IMapIterator vs IMapUnorderedIterator iter/next presence
# ===

table multiprocessing_extra2416.imap_iterator_matrix:
  description: "IMapIterator defines both __iter__ and __next__; IMapUnorderedIterator inherits them without overriding"
  kind: python_call_eq
  category: dict_contains
  id_prefix: mp2416
  columns: [id, function, args, expected]
  rows:
    - ["mp2416017", "multiprocessing.pool.IMapIterator.__dict__.__contains__", ["__iter__"], true]
    - ["mp2416018", "multiprocessing.pool.IMapIterator.__dict__.__contains__", ["__next__"], true]
    - ["mp2416019", "multiprocessing.pool.IMapUnorderedIterator.__dict__.__contains__", ["__iter__"], false]
    - ["mp2416020", "multiprocessing.pool.IMapUnorderedIterator.__dict__.__contains__", ["__next__"], false]
    - ["mp2416021", "multiprocessing.queues.Queue.__dict__.__contains__", ["__iter__"], false]
    - ["mp2416022", "multiprocessing.queues.Queue.__dict__.__contains__", ["__next__"], false]
    - ["mp2416023", "multiprocessing.pool.Pool.__dict__.__contains__", ["__iter__"], false]
    - ["mp2416024", "multiprocessing.pool.Pool.__dict__.__contains__", ["__next__"], false]
