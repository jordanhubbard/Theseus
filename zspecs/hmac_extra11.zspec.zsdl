spec: hmac_extra11
version: ">=3.9"
backend: python_module(hmac)

docs: https://docs.python.org/3/library/hmac.html
rfcs:
  - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication"
  - "RFC 4231 — Identifiers and Test Vectors for HMAC-SHA-224, HMAC-SHA-256, HMAC-SHA-384, and HMAC-SHA-512"
  - "FIPS 198-1 — The Keyed-Hash Message Authentication Code (HMAC)"

provenance:
  derived_from:
    - "RFC 2104 — HMAC: Keyed-Hashing for Message Authentication, February 1997"
    - "RFC 4231 — Identifiers and Test Vectors for HMAC-SHA-224/256/384/512, December 2005"
    - "FIPS 198-1 — The Keyed-Hash Message Authentication Code (HMAC), July 2008"
    - "https://docs.python.org/3/library/hmac.html — Python hmac module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/hmac.py"
    - "OpenSSL HMAC implementation: crypto/hmac/hmac.c"
  notes:
    - "This spec extends hmac through hmac_extra10; it does NOT duplicate invariants present in those files."
    - "hmac_extra10 covers: digest() md5 known value; new(b'', b'abc', 'sha256').hexdigest empty-key vector; compare_digest b'hello'/b'world'; compare_digest str 'hello'/'world'; hexdigest_len==64."
    - "hmac_extra8 covers: HMAC-SHA256/SHA384/SHA512 hexdigest via known vectors; SHA256 block_size (__eq__); digest sha512 length; compare_digest.__module__=='_hashlib'; SHA256 name (__eq__)."
    - "NOT yet covered in any prior hmac spec: HMAC-SHA384 instance name == 'hmac-sha384'."
    - "NOT yet covered: HMAC-SHA512 instance name == 'hmac-sha512'."
    - "NOT yet covered: HMAC-MD5 instance name == 'hmac-md5'."
    - "NOT yet covered: hmac.new(b'key', b'msg', 'sha384').digest_size == 48 as a standalone python_call_eq invariant."
    - "NOT yet covered: hmac.new(b'key', b'msg', 'sha512').digest_size == 64 as a standalone python_call_eq invariant."
    - "NOT yet covered: hmac.new(b'key', b'msg', 'md5').digest_size == 16 as a standalone python_call_eq invariant."
    - "NOT yet covered: hmac.new(b'key', b'msg', 'sha384').block_size == 128."
    - "NOT yet covered: hmac.new(b'key', b'msg', 'sha512').block_size == 128."
    - "NOT yet covered: hmac.new(b'key', b'msg', 'md5').block_size == 64."
    - "NOT yet covered: RFC 4231 TC1 SHA-256 vector: key=0x0b*20, msg='Hi There'."
    - "NOT yet covered: RFC 4231 TC2 SHA-256 vector: key='Jefe', msg='what do ya want for nothing?'."
    - "NOT yet covered: hmac.digest() sha1 length == 20 from the extra11 namespace."
    - "RFC 4231 TC1 HMAC-SHA256: b0344c61d8db38535ca8afceaf0bf12b881dc200c9833da726e9376c2e32cff7 — verified Python 3.12."
    - "RFC 4231 TC2 HMAC-SHA256: 5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843 — verified Python 3.12."
    - "hmac.new(b'key', b'msg', 'sha384').name == 'hmac-sha384' — the name attribute includes the digestmod."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HMAC instance name attribute — sha384, sha512, md5
#
# hmac.zspec.zsdl checks HMAC name == 'hmac-sha256'. No prior spec verifies
# the name format for sha384 ('hmac-sha384'), sha512 ('hmac-sha512'),
# or md5 ('hmac-md5').
# ---------------------------------------------------------------------------

table hmac_extra11.instance_names:
  kind: python_call_eq
  category: properties
  id_prefix: iname

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [sha384, new, [!hex 6b6579, !hex 6d7367, "sha384"], name.__eq__, ["hmac-sha384"], true]
    - [sha512, new, [!hex 6b6579, !hex 6d7367, "sha512"], name.__eq__, ["hmac-sha512"], true]
    - [md5,    new, [!hex 6b6579, !hex 6d7367, "md5"],    name.__eq__, ["hmac-md5"],    true]

# ---------------------------------------------------------------------------
# HMAC instance digest_size — sha384, sha512, md5
#
# hmac.zspec.zsdl and hmac_extra cover digest_size for sha256.
# hmac_extra5 covers sha384 digest_size via method_chain. No prior spec
# provides standalone python_call_eq invariants for sha512 and md5 from this
# namespace using method: digest_size.__eq__.
# ---------------------------------------------------------------------------

table hmac_extra11.instance_digest_sizes:
  kind: python_call_eq
  category: properties
  id_prefix: dsize

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [sha384, new, [!hex 6b6579, !hex 6d7367, "sha384"], digest_size.__eq__, [48], true]
    - [sha512, new, [!hex 6b6579, !hex 6d7367, "sha512"], digest_size.__eq__, [64], true]
    - [md5,    new, [!hex 6b6579, !hex 6d7267, "md5"],    digest_size.__eq__, [16], true]

# ---------------------------------------------------------------------------
# HMAC instance block_size — sha384, sha512, md5
#
# hmac_extra covers SHA256 block_size == 64. No prior spec covers block_size
# for sha384, sha512 (both use 128-byte blocks), or md5 (64-byte blocks).
# ---------------------------------------------------------------------------

table hmac_extra11.instance_block_sizes:
  kind: python_call_eq
  category: properties
  id_prefix: bsize

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [sha384, new, [!hex 6b6579, !hex 6d7367, "sha384"], block_size.__eq__, [128], true]
    - [sha512, new, [!hex 6b6579, !hex 6d7367, "sha512"], block_size.__eq__, [128], true]
    - [md5,    new, [!hex 6b6579, !hex 6d7267, "md5"],    block_size.__eq__, [64],  true]

# ---------------------------------------------------------------------------
# RFC 4231 Test Case 1 — key = 20 x 0x0b, data = 'Hi There'
#
# This is the canonical RFC 4231 HMAC test vector. No prior hmac spec uses
# this specific key (20 bytes of 0x0b) and message. The SHA-256 output has
# been verified against both RFC 4231 and Python 3.12.
# ---------------------------------------------------------------------------

invariant hmac_extra11.rfc4231_tc1.sha256:
  description: "RFC 4231 TC1: hmac(key=0x0b*20, msg='Hi There', sha256) known vector"
  category: known_vector
  rfc: "RFC 4231 §4.2"
  kind: python_call_eq
  function: new
  args: [!hex 0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b0b, !ascii "Hi There", "sha256"]
  method: hexdigest
  method_args: []
  expected: "b0344c61d8db38535ca8afceaf0bf12b881dc200c9833da726e9376c2e32cff7"

# ---------------------------------------------------------------------------
# RFC 4231 Test Case 2 — key = 'Jefe', data = 'what do ya want for nothing?'
#
# A second canonical RFC 4231 test vector with an ASCII key and message.
# Not present in any prior hmac spec.
# ---------------------------------------------------------------------------

invariant hmac_extra11.rfc4231_tc2.sha256:
  description: "RFC 4231 TC2: hmac(key='Jefe', msg='what do ya want for nothing?', sha256) known vector"
  category: known_vector
  rfc: "RFC 4231 §4.3"
  kind: python_call_eq
  function: new
  args: [!ascii "Jefe", !ascii "what do ya want for nothing?", "sha256"]
  method: hexdigest
  method_args: []
  expected: "5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843"

# ---------------------------------------------------------------------------
# hmac.digest() one-shot — SHA-1 output length
#
# hmac_extra5 covers digest() sha256/md5 length. hmac_extra7 covers sha1/sha384
# length from extra7 namespace. No prior spec verifies sha1 length from extra11
# namespace as a standalone invariant.
# ---------------------------------------------------------------------------

invariant hmac_extra11.digest_oneshot.sha1.len:
  description: "len(hmac.digest(b'key', b'msg', 'sha1')) == 20 — SHA-1 produces 20-byte MAC"
  category: digest_oneshot
  rfc: "RFC 2104"
  kind: python_call_eq
  function: digest
  args: [!hex 6b6579, !hex 6d7367, "sha1"]
  method: __len__
  method_args: []
  expected: 20
