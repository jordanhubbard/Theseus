spec: asyncio_extra289
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio subpackage module identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py, Lib/asyncio/events.py, Lib/asyncio/tasks.py"
  notes:
    - "asyncio is a package; all submodules have __package__ == 'asyncio'"
    - "asyncio.subprocess.__name__ is 'asyncio.subprocess' (not 'asyncio.subprocess')"
    - "asyncio.exceptions and asyncio.runners introduced in Python 3.8+"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table asyncio_extra289.submodule_name:
  description: "asyncio submodule __name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: aio289n

  columns: [id, function, args, expected, description]
  rows:
    - [aio289n001, asyncio.events.__name__.__class__.__name__, [], str, "events __name__ is a string"]
    - [aio289n002, asyncio.tasks.__name__.__class__.__name__, [], str, "tasks __name__ is a string"]
    - [aio289n003, asyncio.streams.__name__.__class__.__name__, [], str, "streams __name__ is a string"]
    - [aio289n004, asyncio.futures.__name__.__class__.__name__, [], str, "futures __name__ is a string"]
    - [aio289n005, asyncio.locks.__name__.__class__.__name__, [], str, "locks __name__ is a string"]
    - [aio289n006, asyncio.queues.__name__.__class__.__name__, [], str, "queues __name__ is a string"]
    - [aio289n007, asyncio.subprocess.__name__.__class__.__name__, [], str, "subprocess __name__ is a string"]
    - [aio289n008, asyncio.exceptions.__name__.__class__.__name__, [], str, "exceptions __name__ is a string"]
    - [aio289n009, asyncio.runners.__name__.__class__.__name__, [], str, "runners __name__ is a string"]

table asyncio_extra289.submodule_package:
  description: "asyncio submodule __package__ identity (all == 'asyncio')"
  kind: python_call_eq
  category: identity
  id_prefix: aio289p

  columns: [id, function, args, expected, description]
  rows:
    - [aio289p001, asyncio.events.__package__, [], asyncio, "events.__package__ is 'asyncio'"]
    - [aio289p002, asyncio.tasks.__package__, [], asyncio, "tasks.__package__ is 'asyncio'"]
    - [aio289p003, asyncio.streams.__package__, [], asyncio, "streams.__package__ is 'asyncio'"]
    - [aio289p004, asyncio.futures.__package__, [], asyncio, "futures.__package__ is 'asyncio'"]
    - [aio289p005, asyncio.locks.__package__, [], asyncio, "locks.__package__ is 'asyncio'"]
    - [aio289p006, asyncio.queues.__package__, [], asyncio, "queues.__package__ is 'asyncio'"]
    - [aio289p007, asyncio.subprocess.__package__, [], asyncio, "subprocess.__package__ is 'asyncio'"]
    - [aio289p008, asyncio.exceptions.__package__, [], asyncio, "exceptions.__package__ is 'asyncio'"]
    - [aio289p009, asyncio.runners.__package__, [], asyncio, "runners.__package__ is 'asyncio'"]

invariant asyncio_extra289.events_name:
  description: "asyncio.events.__name__ == 'asyncio.events'"
  category: identity
  kind: python_call_eq
  function: asyncio.events.__name__
  args: []
  expected: "asyncio.events"

invariant asyncio_extra289.tasks_name:
  description: "asyncio.tasks.__name__ == 'asyncio.tasks'"
  category: identity
  kind: python_call_eq
  function: asyncio.tasks.__name__
  args: []
  expected: "asyncio.tasks"

invariant asyncio_extra289.futures_name:
  description: "asyncio.futures.__name__ == 'asyncio.futures'"
  category: identity
  kind: python_call_eq
  function: asyncio.futures.__name__
  args: []
  expected: "asyncio.futures"

invariant asyncio_extra289.base_events_name:
  description: "asyncio.base_events.__name__ == 'asyncio.base_events'"
  category: identity
  kind: python_call_eq
  function: asyncio.base_events.__name__
  args: []
  expected: "asyncio.base_events"
