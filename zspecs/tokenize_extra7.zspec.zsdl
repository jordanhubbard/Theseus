spec: tokenize_extra7
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tokenize.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize.zspec.zsdl — covers NAME/NUMBER/STRING/NEWLINE/INDENT/DEDENT/OP/COMMENT/ENCODING/NL int type checks; tokenize/__name__, generate_tokens/__name__, detect_encoding/__name__"
    - "tokenize_extra.zspec.zsdl — covers TokenInfo/__name__/__module__, TokenError/__name__/bases, function __name__ for tokenize/generate_tokens/detect_encoding/open/untokenize, ENCODING/COMMENT/NAME/NUMBER/STRING/NEWLINE/OP/ENDMARKER int type checks"
    - "tokenize_extra2.zspec.zsdl — covers TokenInfo/__name__, TokenInfo/_fields/__len__()==5, _fields membership, _fields[0]=='type', _fields[1]=='string', function __name__ table, COMMENT is_int"
    - "tokenize_extra3.zspec.zsdl — covers function __module__ table, TokenError/__name__/__module__/bases, TokenInfo/__name__/__module__/bases/bases_len, COMMENT/STRING/NUMBER/NAME/ENCODING int checks, untokenize/__name__, TokenInfo bases_len"
    - "tokenize_extra4.zspec.zsdl — covers _fields[2-4], open/__module__, TokenError/__bases__/__len__()==1, TokenInfo/__qualname__, TokenError/__qualname__, function __qualname__ table"
    - "tokenize_extra5.zspec.zsdl — covers open/__qualname__, ERRORTOKEN/__class__/__name__, TYPE_COMMENT/__class__/__name__"
    - "tokenize_extra6.zspec.zsdl — covers TokenInfo/_make/__name__, TokenInfo/_asdict/__name__, TokenInfo/_replace/__name__, TokenInfo/_fields is_tuple, token constant exact values (ENDMARKER=0, TYPE_COMMENT=57, COMMENT=65, NL=66, ERRORTOKEN=67)"
  notes:
    - "This spec adds invariants not covered in any prior tokenize spec."
    - "tokenize re-exports NAME=1, NUMBER=2, STRING=3, NEWLINE=4 from the token module — exact value checks not covered in any tokenize spec."
    - "tokenize.INDENT == 5 and tokenize.DEDENT == 6 — re-exported from token; exact values not tested in any tokenize spec."
    - "tokenize.OP == 55 — re-exported from token; exact value not tested in any tokenize spec."
    - "tokenize.ENCODING == 68 — exact value not tested in any tokenize spec (extra6 covers COMMENT/NL/ERRORTOKEN/TYPE_COMMENT/ENDMARKER)."
    - "tokenize.STRING == 3 and tokenize.NEWLINE == 4 — re-exported exact values new to this spec."
    - "tokenize.TokenError.__class__.__name__ == 'type' — TokenError is a class object; this class-identity check is not in any prior tokenize spec."
    - "tokenize.TokenInfo.__class__.__name__ == 'type' — TokenInfo is a class object; not in any prior tokenize spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exact values for re-exported token constants NAME, NUMBER, STRING, NEWLINE
# tokenize re-exports these from token; no prior tokenize spec checks exact values.
# tokenize_extra6 only covers ENDMARKER=0, TYPE_COMMENT=57, COMMENT=65, NL=66, ERRORTOKEN=67.
# ---------------------------------------------------------------------------

table tokenize_extra7.core_token_exact_values:
  kind: python_call_eq
  category: constants
  id_prefix: tokval

  columns: [id, function, args, expected]
  rows:
    - [name,    NAME.__eq__,    [1], true]
    - [number,  NUMBER.__eq__,  [2], true]
    - [string,  STRING.__eq__,  [3], true]
    - [newline, NEWLINE.__eq__,  [4], true]

# ---------------------------------------------------------------------------
# Exact values for INDENT, DEDENT, OP, ENCODING
# Re-exported from token; exact values not checked in any prior tokenize spec.
# ---------------------------------------------------------------------------

table tokenize_extra7.extended_token_exact_values:
  kind: python_call_eq
  category: constants
  id_prefix: tokval2

  columns: [id, function, args, expected]
  rows:
    - [indent,    INDENT.__eq__,    [5],  true]
    - [dedent,    DEDENT.__eq__,    [6],  true]
    - [op,        OP.__eq__,        [55], true]
    - [encoding,  ENCODING.__eq__,  [68], true]

# ---------------------------------------------------------------------------
# TokenError and TokenInfo class identity
# No prior tokenize spec checks __class__.__name__ for these types.
# TokenError and TokenInfo are class objects, so their __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

invariant tokenize_extra7.TokenError.class_identity:
  description: "tokenize.TokenError.__class__.__name__ == 'type' — TokenError is a class object"
  category: token_error
  kind: python_call_eq
  function: TokenError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant tokenize_extra7.TokenInfo.class_identity:
  description: "tokenize.TokenInfo.__class__.__name__ == 'type' — TokenInfo is a class object"
  category: token_info
  kind: python_call_eq
  function: TokenInfo.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# open.__class__.__name__ == 'function'
# Prior specs check open.__name__ and open.__module__ and open.__qualname__.
# No prior spec checks the class of the open callable.
# ---------------------------------------------------------------------------

invariant tokenize_extra7.open.class_is_function:
  description: "tokenize.open.__class__.__name__ == 'function' — open is a plain Python function"
  category: function_types
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# generate_tokens and tokenize function class identity
# No prior tokenize spec checks the __class__.__name__ of these callables.
# ---------------------------------------------------------------------------

table tokenize_extra7.function_class_types:
  kind: python_call_eq
  category: function_types
  id_prefix: fnclass

  columns: [id, function, args, expected]
  rows:
    - [tokenize,        tokenize.__class__.__name__.__eq__,        ["function"], true]
    - [generate_tokens, generate_tokens.__class__.__name__.__eq__, ["function"], true]
    - [detect_encoding, detect_encoding.__class__.__name__.__eq__, ["function"], true]
    - [untokenize,      untokenize.__class__.__name__.__eq__,      ["function"], true]
