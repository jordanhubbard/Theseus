spec: enum_rust
version: ">=3.9"
backend: rust_module(enum_rust)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum documentation"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "Clean-room Rust reimplementation of Python IntEnum, exposed via PyO3."
    - "Exposes Color (IntEnum) with members RED=1, GREEN=2, BLUE=3."
    - "Color['RED'] accesses member by name; Color(1) accesses member by value."
    - "Color['RED'].value == 1 — integer value of enum member."
    - "Color['RED'].name == 'RED' — string name of enum member."
    - "int(Color['RED']) == 1 — IntEnum members are also ints."
    - "Color(2).name == 'GREEN' — reverse lookup by value."
    - "All test vectors verified against Python 3.14.3 enum module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# Color.__getitem__ — access member by name, then .value
table enum_rust.Color.value_by_name:
  kind: python_call_eq
  category: Color
  id_prefix: color_val
  function: Color.__getitem__
  method: value

  columns: [id, args, expected]
  rows:
    - [red,   ["RED"],   1]
    - [green, ["GREEN"], 2]
    - [blue,  ["BLUE"],  3]

# Color.__getitem__ — access member by name, then .name
table enum_rust.Color.name_by_name:
  kind: python_call_eq
  category: Color
  id_prefix: color_name
  function: Color.__getitem__
  method: name

  columns: [id, args, expected]
  rows:
    - [red,   ["RED"],   "RED"]
    - [green, ["GREEN"], "GREEN"]
    - [blue,  ["BLUE"],  "BLUE"]

# Color.__getitem__ — int value (IntEnum members are ints)
table enum_rust.Color.int_value:
  kind: python_call_eq
  category: Color
  id_prefix: color_int
  function: Color.__getitem__
  method: __int__

  columns: [id, args, expected]
  rows:
    - [red,   ["RED"],   1]
    - [green, ["GREEN"], 2]
    - [blue,  ["BLUE"],  3]

# Color.__call__ — access member by int value, then .name
table enum_rust.Color.name_by_value:
  kind: python_call_eq
  category: Color
  id_prefix: color_byval
  function: Color
  method: name

  columns: [id, args, expected]
  rows:
    - [one,   [1], "RED"]
    - [two,   [2], "GREEN"]
    - [three, [3], "BLUE"]

