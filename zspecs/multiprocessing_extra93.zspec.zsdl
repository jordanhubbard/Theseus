spec: multiprocessing_extra93
version: ">=3.9"
backend: python_module(multiprocessing)
extends: multiprocessing_extra92

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec extends multiprocessing_extra92.zspec.zsdl."
    - "This spec covers: wave 254 theme — multiprocessing.pool.Pool method __qualname__ lengths and Pool class identity. NEW in extra93: Pool.apply.__qualname__ len==10; Pool.map.__qualname__ len==8; Pool.starmap.__qualname__ len==12; Pool.apply_async.__qualname__ len==16; Pool.map_async.__qualname__ len==14; Pool.starmap_async.__qualname__ len==18; Pool.imap.__qualname__ len==9; Pool.imap_unordered.__qualname__ len==19; Pool.close.__qualname__ len==10; Pool.terminate.__qualname__ len==14; Pool.join.__qualname__ len==9; Pool.__name__=='Pool'; Pool.__module__=='multiprocessing.pool'; Pool.__bases__[0].__name__=='object'; Pool.__mro__.__len__()==2. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.apply.__qualname__ == 'Pool.apply' (len=10). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.map.__qualname__ == 'Pool.map' (len=8). Pool.map is the shortest qualname among Pool methods. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.starmap.__qualname__ == 'Pool.starmap' (len=12). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.apply_async.__qualname__ == 'Pool.apply_async' (len=16). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.map_async.__qualname__ == 'Pool.map_async' (len=14). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.starmap_async.__qualname__ == 'Pool.starmap_async' (len=18). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.imap.__qualname__ == 'Pool.imap' (len=9). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.imap_unordered.__qualname__ == 'Pool.imap_unordered' (len=19). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.close.__qualname__ == 'Pool.close' (len=10). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.terminate.__qualname__ == 'Pool.terminate' (len=14). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.join.__qualname__ == 'Pool.join' (len=9). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.__name__ == 'Pool'. Pool is defined as a class named Pool. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.__module__ == 'multiprocessing.pool'. Pool is defined in Lib/multiprocessing/pool.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.__bases__[0].__name__ == 'object'. Pool inherits directly from object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "Pool.__mro__.__len__() == 2. MRO is [Pool, object]. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pool synchronous method __qualname__ lengths — extra93
#
# Wave 254 theme: multiprocessing.pool.Pool method __qualname__ lengths.
#
# Pool.apply.__qualname__.__len__() == 10
# Pool.map.__qualname__.__len__() == 8
# Pool.starmap.__qualname__.__len__() == 12
# ---------------------------------------------------------------------------

table multiprocessing_extra93.pool_sync_method_qualname_lengths:
  description: "Pool synchronous method __qualname__ length checks in mppoolmethods93 namespace — wave 254 theme: multiprocessing.pool.Pool method qualnames; Pool.apply.__qualname__.__len__()==10 ('Pool.apply'); Pool.map.__qualname__.__len__()==8 ('Pool.map'); Pool.starmap.__qualname__.__len__()==12 ('Pool.starmap'); these are the blocking (synchronous) variants; Pool.map is the shortest method qualname (len=8) in the Pool interface; backend uses multiprocessing.pool.Pool (imported via multiprocessing.pool); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolmethods93

  columns: [id, function, args, expected, description]
  rows:
    - [pool_apply_len,   "Pool.apply.__qualname__.__len__",   [], 10, "Pool.apply.__qualname__.__len__() == 10 — qualname is 'Pool.apply'; verified with Python 3.14.3"]
    - [pool_map_len,     "Pool.map.__qualname__.__len__",     [], 8,  "Pool.map.__qualname__.__len__() == 8 — qualname is 'Pool.map'; shortest Pool method qualname; verified with Python 3.14.3"]
    - [pool_starmap_len, "Pool.starmap.__qualname__.__len__", [], 12, "Pool.starmap.__qualname__.__len__() == 12 — qualname is 'Pool.starmap'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Pool async method __qualname__ lengths — extra93
#
# Pool.apply_async.__qualname__.__len__() == 16
# Pool.map_async.__qualname__.__len__() == 14
# Pool.starmap_async.__qualname__.__len__() == 18
# ---------------------------------------------------------------------------

table multiprocessing_extra93.pool_async_method_qualname_lengths:
  description: "Pool async-variant method __qualname__ length checks in mppoolmethods93 namespace — wave 254 theme: multiprocessing.pool.Pool method qualnames; Pool.apply_async.__qualname__.__len__()==16 ('Pool.apply_async'); Pool.map_async.__qualname__.__len__()==14 ('Pool.map_async'); Pool.starmap_async.__qualname__.__len__()==18 ('Pool.starmap_async'); async variants are exactly 6 chars longer than their synchronous counterparts (the '_async' suffix has 6 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolmethods93a

  columns: [id, function, args, expected, description]
  rows:
    - [pool_apply_async_len,   "Pool.apply_async.__qualname__.__len__",   [], 16, "Pool.apply_async.__qualname__.__len__() == 16 — qualname is 'Pool.apply_async'; verified with Python 3.14.3"]
    - [pool_map_async_len,     "Pool.map_async.__qualname__.__len__",     [], 14, "Pool.map_async.__qualname__.__len__() == 14 — qualname is 'Pool.map_async'; verified with Python 3.14.3"]
    - [pool_starmap_async_len, "Pool.starmap_async.__qualname__.__len__", [], 18, "Pool.starmap_async.__qualname__.__len__() == 18 — qualname is 'Pool.starmap_async'; longest Pool method qualname; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Pool lifecycle and iterator method __qualname__ lengths — extra93
#
# Pool.imap.__qualname__.__len__() == 9
# Pool.imap_unordered.__qualname__.__len__() == 19
# Pool.close.__qualname__.__len__() == 10
# Pool.terminate.__qualname__.__len__() == 14
# Pool.join.__qualname__.__len__() == 9
# ---------------------------------------------------------------------------

table multiprocessing_extra93.pool_lifecycle_method_qualname_lengths:
  description: "Pool lifecycle and iterator method __qualname__ length checks in mppoolmethods93 namespace — wave 254 theme: multiprocessing.pool.Pool method qualnames; Pool.imap.__qualname__.__len__()==9 ('Pool.imap'); Pool.imap_unordered.__qualname__.__len__()==19 ('Pool.imap_unordered'); Pool.close.__qualname__.__len__()==10 ('Pool.close'); Pool.terminate.__qualname__.__len__()==14 ('Pool.terminate'); Pool.join.__qualname__.__len__()==9 ('Pool.join'); Pool.imap and Pool.join share the same qualname length (9); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolmethods93b

  columns: [id, function, args, expected, description]
  rows:
    - [pool_imap_len,          "Pool.imap.__qualname__.__len__",          [], 9,  "Pool.imap.__qualname__.__len__() == 9 — qualname is 'Pool.imap'; verified with Python 3.14.3"]
    - [pool_imap_unord_len,    "Pool.imap_unordered.__qualname__.__len__", [], 19, "Pool.imap_unordered.__qualname__.__len__() == 19 — qualname is 'Pool.imap_unordered'; verified with Python 3.14.3"]
    - [pool_close_len,         "Pool.close.__qualname__.__len__",         [], 10, "Pool.close.__qualname__.__len__() == 10 — qualname is 'Pool.close'; verified with Python 3.14.3"]
    - [pool_terminate_len,     "Pool.terminate.__qualname__.__len__",     [], 14, "Pool.terminate.__qualname__.__len__() == 14 — qualname is 'Pool.terminate'; verified with Python 3.14.3"]
    - [pool_join_len,          "Pool.join.__qualname__.__len__",          [], 9,  "Pool.join.__qualname__.__len__() == 9 — qualname is 'Pool.join'; same length as Pool.imap; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Pool class identity — extra93
#
# Pool.__name__ == 'Pool'
# Pool.__module__ == 'multiprocessing.pool'
# Pool.__bases__[0].__name__ == 'object'
# Pool.__mro__.__len__() == 2
# ---------------------------------------------------------------------------

table multiprocessing_extra93.pool_class_identity:
  description: "Pool class identity checks in mppoolmethods93 namespace — wave 254 theme: multiprocessing.pool.Pool class identity; Pool.__name__.__eq__('Pool')==True; Pool.__module__.__eq__('multiprocessing.pool')==True (defined in Lib/multiprocessing/pool.py); Pool.__bases__[0].__name__.__eq__('object')==True (Pool inherits directly from object, no intermediate base class); Pool.__mro__.__len__()==2 (MRO is [Pool, object]); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mppoolmethods93c

  columns: [id, function, args, expected, description]
  rows:
    - [pool_name,      Pool.__name__.__eq__,                 ["Pool"],                  true, "Pool.__name__ == 'Pool' — class name; verified with Python 3.14.3"]
    - [pool_module,    Pool.__module__.__eq__,               ["multiprocessing.pool"],  true, "Pool.__module__ == 'multiprocessing.pool' — defined in Lib/multiprocessing/pool.py; verified with Python 3.14.3"]
    - [pool_bases0,    "Pool.__bases__[0].__name__.__eq__",  ["object"],                true, "Pool.__bases__[0].__name__ == 'object' — Pool inherits directly from object; verified with Python 3.14.3"]
    - [pool_mro_len,   Pool.__mro__.__len__,                 [],                        2,    "Pool.__mro__.__len__() == 2 — MRO is [Pool, object]; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra93
# ---------------------------------------------------------------------------

invariant multiprocessing_extra93.Pool_map_qualname_eq:
  description: "multiprocessing.pool.Pool.map.__qualname__.__eq__('Pool.map') returns True — Pool.map is the shortest qualname among Pool's public methods (len=8); it consists of the 'Pool.' prefix (5 chars) and 'map' (3 chars); the async variant Pool.map_async has qualname 'Pool.map_async' (len=14, 6 chars longer); NEW in extra93: first standalone __qualname__.__eq__ invariant for Pool.map in mppoolmethods93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Pool.map.__qualname__.__eq__"
  args: ["Pool.map"]
  expected: true

invariant multiprocessing_extra93.Pool_starmap_async_qualname_eq:
  description: "multiprocessing.pool.Pool.starmap_async.__qualname__.__eq__('Pool.starmap_async') returns True — Pool.starmap_async has the longest qualname of all Pool public methods (len=18); it is 6 chars longer than Pool.starmap (len=12) due to the '_async' suffix; NEW in extra93: first standalone __qualname__.__eq__ invariant for Pool.starmap_async in mppoolmethods93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Pool.starmap_async.__qualname__.__eq__"
  args: ["Pool.starmap_async"]
  expected: true

invariant multiprocessing_extra93.Pool_imap_unordered_qualname_eq:
  description: "multiprocessing.pool.Pool.imap_unordered.__qualname__.__eq__('Pool.imap_unordered') returns True — Pool.imap_unordered has qualname length 19, the second longest after Pool.starmap_async (18) — wait, 19 > 18 so imap_unordered is actually the longest; Pool.imap_unordered yields results as they complete, without ordering guarantees; its qualname length of 19 exceeds Pool.starmap_async at 18; NEW in extra93: first standalone __qualname__.__eq__ invariant for Pool.imap_unordered in mppoolmethods93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "Pool.imap_unordered.__qualname__.__eq__"
  args: ["Pool.imap_unordered"]
  expected: true

invariant multiprocessing_extra93.Pool_module_is_pool:
  description: "multiprocessing.pool.Pool.__module__.__eq__('multiprocessing.pool') returns True — Pool is defined in Lib/multiprocessing/pool.py and its __module__ is 'multiprocessing.pool'; this is the Pool class used by the multiprocessing module (multiprocessing.Pool is actually the same class exposed via the context mechanism); Pool.__mro__.__len__() is 2, indicating no intermediate base classes; NEW in extra93: first standalone __module__ invariant for Pool in mppoolmethods93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Pool.__module__.__eq__
  args: ["multiprocessing.pool"]
  expected: true

invariant multiprocessing_extra93.Pool_mro_len_two:
  description: "multiprocessing.pool.Pool.__mro__.__len__() == 2 — Pool's MRO is [Pool, object]; Pool inherits directly from object with no intermediate base class; this is notably simpler than multiprocessing.Process whose MRO is [Process, BaseProcess, object] (length 3); Pool manages worker processes internally without using a shared base class; NEW in extra93: first standalone __mro__.__len__ invariant for Pool in mppoolmethods93 namespace; wave 254; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Pool.__mro__.__len__
  args: []
  expected: 2
