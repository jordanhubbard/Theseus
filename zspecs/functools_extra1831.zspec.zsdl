    - ["fu1831003", "functools.partial.__dict__.__contains__", ["__delete__"], false]
    - ["fu1831004", "functools.partial.__dict__.__contains__", ["__set_name__"], false]
    - ["fu1831005", "functools.cached_property.__dict__.__contains__", ["__get__"], true]
    - ["fu1831006", "functools.cached_property.__dict__.__contains__", ["__set__"], false]
    - ["fu1831007", "functools.cached_property.__dict__.__contains__", ["__delete__"], false]
    - ["fu1831008", "functools.cached_property.__dict__.__contains__", ["__set_name__"], true]
    - ["fu1831009", "functools.partialmethod.__dict__.__contains__", ["__get__"], true]
    - ["fu1831010", "functools.partialmethod.__dict__.__contains__", ["__set__"], false]

