spec: functools_extra1831
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 569 (_extra1831): descriptor protocol (__get__/__set__/__delete__/__set_name__); __call__ callable protocol; arithmetic operator presence (__add__/__mul__/__sub__) for functools types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table functools_extra1831.descriptor_protocol:
  description: "functools types descriptor protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1831

  columns: [id, function, args, expected]
