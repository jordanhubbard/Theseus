  function: IncrementalNewlineDecoder.__name__.__len__
  args: []
  expected: 25

invariant io_extra190.incrementalnewlinedecoder_module_eq:
  description: "io.IncrementalNewlineDecoder.__module__ == '_io' — implemented in the _io C extension; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra190.unsupportedoperation_name_eq:
  description: "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' — raised when an I/O operation is not supported; confirmed Python 3.14.3 macOS"
  category: identity
