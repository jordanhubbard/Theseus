spec: io_extra190
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/io.py"
  notes:
    - "io.TextIOWrapper.__name__=='TextIOWrapper' (len=13); __module__=='_io'; __qualname__=='TextIOWrapper'."
    - "io.TextIOWrapper.__bases__[0].__name__=='_TextIOBase' — TextIOWrapper inherits from _TextIOBase in _io C extension."
    - "io.IncrementalNewlineDecoder.__name__=='IncrementalNewlineDecoder' (len=25); __module__=='_io'."
    - "io.UnsupportedOperation.__name__=='UnsupportedOperation' (len=20); __module__=='io'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.TextIOWrapper class identity
# __name__=='TextIOWrapper' (len=13); __module__=='_io'; __qualname__=='TextIOWrapper'
# ---------------------------------------------------------------------------

table io_extra190.textiowrapper_identity:
  description: "io.TextIOWrapper class identity: __name__=='TextIOWrapper' (len=13); __module__=='_io'; __qualname__=='TextIOWrapper'; __bases__[0].__name__=='_TextIOBase'"
  kind: python_call_eq
  category: identity
  id_prefix: iotextiowrap190

  columns: [id, function, args, expected, description]
  rows:
    - [tiow_name,     TextIOWrapper.__name__.__eq__,     ["TextIOWrapper"],  true,  "io.TextIOWrapper.__name__ == 'TextIOWrapper' — the buffered text I/O class; confirmed Python 3.14.3 macOS"]
    - [tiow_name_len, TextIOWrapper.__name__.__len__,    [],                 13,    "io.TextIOWrapper.__name__.__len__() == 13 — T(1)e(2)x(3)t(4)I(5)O(6)W(7)r(8)a(9)p(10)p(11)e(12)r(13); confirmed Python 3.14.3 macOS"]
    - [tiow_module,   TextIOWrapper.__module__.__eq__,   ["_io"],            true,  "io.TextIOWrapper.__module__ == '_io' — implemented in the _io C extension; confirmed Python 3.14.3 macOS"]
    - [tiow_qualname, TextIOWrapper.__qualname__.__eq__, ["TextIOWrapper"],  true,  "io.TextIOWrapper.__qualname__ == 'TextIOWrapper' — simple unqualified class name; confirmed Python 3.14.3 macOS"]
    - [tiow_base,     "TextIOWrapper.__bases__[0].__name__.__eq__", ["_TextIOBase"], true, "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — inherits from _TextIOBase in _io; confirmed Python 3.14.3 macOS"]

