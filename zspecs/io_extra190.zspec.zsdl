    - [unsop_name,     UnsupportedOperation.__name__.__eq__,    ["UnsupportedOperation"], true,  "io.UnsupportedOperation.__name__ == 'UnsupportedOperation' — raised for unsupported I/O operations; confirmed Python 3.14.3 macOS"]
    - [unsop_name_len, UnsupportedOperation.__name__.__len__,   [],                       20,    "io.UnsupportedOperation.__name__.__len__() == 20 — U(1)n(2)s(3)u(4)p(5)p(6)o(7)r(8)t(9)e(10)d(11)O(12)p(13)e(14)r(15)a(16)t(17)i(18)o(19)n(20); confirmed Python 3.14.3 macOS"]
