  columns: [id, function, args, expected, description]
  rows:
    - [inld_name,     IncrementalNewlineDecoder.__name__.__eq__,   ["IncrementalNewlineDecoder"], true, "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' — translates universal newlines; confirmed Python 3.14.3 macOS"]
    - [inld_name_len, IncrementalNewlineDecoder.__name__.__len__,  [],                            25,   "io.IncrementalNewlineDecoder.__name__.__len__() == 25 — I(1)n(2)c(3)r(4)e(5)m(6)e(7)n(8)t(9)a(10)l(11)N(12)e(13)w(14)l(15)i(16)n(17)e(18)D(19)e(20)c(21)o(22)d(23)e(24)r(25); confirmed Python 3.14.3 macOS"]
    - [inld_module,   IncrementalNewlineDecoder.__module__.__eq__,  ["_io"],                      true, "io.IncrementalNewlineDecoder.__module__ == '_io' — implemented in the _io C extension; confirmed Python 3.14.3 macOS"]
