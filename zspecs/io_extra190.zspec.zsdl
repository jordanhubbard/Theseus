# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra190.textiowrapper_name_eq:
  description: "io.TextIOWrapper.__name__ == 'TextIOWrapper' — the primary buffered text I/O class; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__name__.__eq__
  args: ["TextIOWrapper"]
  expected: true

invariant io_extra190.textiowrapper_name_len_13:
  description: "io.TextIOWrapper.__name__.__len__() == 13 — 'TextIOWrapper' has 13 characters; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__name__.__len__
  args: []
  expected: 13

invariant io_extra190.textiowrapper_module_eq:
  description: "io.TextIOWrapper.__module__ == '_io' — implemented in the _io C extension module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: TextIOWrapper.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra190.textiowrapper_base_eq:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — inherits from _TextIOBase in _io C extension; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "TextIOWrapper.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra190.incrementalnewlinedecoder_name_eq:
  description: "io.IncrementalNewlineDecoder.__name__ == 'IncrementalNewlineDecoder' — translates universal newlines during incremental decode; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: IncrementalNewlineDecoder.__name__.__eq__
  args: ["IncrementalNewlineDecoder"]
  expected: true

invariant io_extra190.incrementalnewlinedecoder_name_len_25:
  description: "io.IncrementalNewlineDecoder.__name__.__len__() == 25 — 'IncrementalNewlineDecoder' has 25 characters; confirmed Python 3.14.3 macOS"
  category: identity
