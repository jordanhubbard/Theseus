  description: "inspect.isbuiltin.__name__.__len__() == 9 — 'isbuiltin' has 9 characters; new to extra221"
  kind: python_call_eq
  function: isbuiltin.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra221.isroutine_name_len:
  description: "inspect.isroutine.__name__.__len__() == 9 — 'isroutine' has 9 characters; new to extra221"
  kind: python_call_eq
