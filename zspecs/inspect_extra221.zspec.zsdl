invariant inspect_extra221.getmembers_name_len:
  description: "inspect.getmembers.__name__.__len__() == 10 — 'getmembers' has 10 characters; new to extra221"
  kind: python_call_eq
  function: getmembers.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra221.getsource_name_len:
  description: "inspect.getsource.__name__.__len__() == 9 — 'getsource' has 9 characters; new to extra221"
  kind: python_call_eq
  function: getsource.__name__.__len__
  args: []
  expected: 9

invariant inspect_extra221.parameter_name_len:
  description: "inspect.Parameter.__name__.__len__() == 9 — 'Parameter' has 9 characters; new to extra221"
  kind: python_call_eq
