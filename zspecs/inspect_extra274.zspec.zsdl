spec: inspect_extra274
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.Parameter is a pure-Python class; __module__ == 'inspect', __bases__[0].__name__ == 'object'."
    - "inspect.Parameter.POSITIONAL_ONLY == 0 (IntEnum); POSITIONAL_OR_KEYWORD==1, VAR_POSITIONAL==2, KEYWORD_ONLY==3, VAR_KEYWORD==4."
    - "The kind values are _ParameterKind instances (IntEnum subclass); they compare equal to their integer ordinals."
    - "inspect.Signature is a pure-Python class; __module__ == 'inspect', __bases__[0].__name__ == 'object'."
    - "inspect.Signature.empty and inspect.Parameter.empty are the same object: _empty class."
    - "Signature.empty.__name__ == '_empty'; Signature.empty.__module__ == 'inspect'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect.Parameter — class identity
#
# Parameter is a pure-Python class in inspect.
# __name__ == 'Parameter'; __module__ == 'inspect'; __bases__[0].__name__ == 'object'.
# __class__.__name__ == 'type' (it is a class, not a function).
# ---------------------------------------------------------------------------

table inspect_extra274.parameter_class_identity:
  description: "inspect.Parameter class identity — __name__, __module__, __qualname__, __bases__[0].__name__, __class__.__name__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex274pci

  columns: [id, function, args, expected, description]
  rows:
    - [pa_name_eq,    Parameter.__name__.__eq__,                       ["Parameter"], true,      "inspect.Parameter.__name__ == 'Parameter'; verified with Python 3.14.3"]
    - [pa_mod_eq,     Parameter.__module__.__eq__,                     ["inspect"],   true,      "inspect.Parameter.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [pa_qn_eq,      Parameter.__qualname__.__eq__,                   ["Parameter"], true,      "inspect.Parameter.__qualname__ == 'Parameter'; verified with Python 3.14.3"]
    - [pa_cls_eq,     Parameter.__class__.__name__.__eq__,             ["type"],      true,      "inspect.Parameter.__class__.__name__ == 'type' (pure-Python class); verified with Python 3.14.3"]
    - [pa_base_name,  Parameter.__bases__.__getitem__(0).__name__.__eq__, ["object"],  true,      "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter directly subclasses object; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect.Parameter kind constants — POSITIONAL_ONLY through VAR_KEYWORD
#
# All are _ParameterKind IntEnum members.
# POSITIONAL_ONLY == 0, POSITIONAL_OR_KEYWORD == 1, VAR_POSITIONAL == 2,
# KEYWORD_ONLY == 3, VAR_KEYWORD == 4.
# ---------------------------------------------------------------------------

table inspect_extra274.parameter_kind_values:
  description: "inspect.Parameter kind constants — integer values 0-4; IntEnum members compare equal to int; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: inex274pk

  columns: [id, function, args, expected, description]
  rows:
    - [po_eq_zero,   Parameter.POSITIONAL_ONLY.__eq__,       [0], true, "inspect.Parameter.POSITIONAL_ONLY == 0 (IntEnum ordinal); verified with Python 3.14.3"]
    - [pk_eq_one,    Parameter.POSITIONAL_OR_KEYWORD.__eq__,  [1], true, "inspect.Parameter.POSITIONAL_OR_KEYWORD == 1; verified with Python 3.14.3"]
    - [vp_eq_two,    Parameter.VAR_POSITIONAL.__eq__,         [2], true, "inspect.Parameter.VAR_POSITIONAL == 2; verified with Python 3.14.3"]
    - [ko_eq_three,  Parameter.KEYWORD_ONLY.__eq__,           [3], true, "inspect.Parameter.KEYWORD_ONLY == 3; verified with Python 3.14.3"]
    - [vk_eq_four,   Parameter.VAR_KEYWORD.__eq__,            [4], true, "inspect.Parameter.VAR_KEYWORD == 4; verified with Python 3.14.3"]
    - [pk_cls_name,  Parameter.POSITIONAL_ONLY.__class__.__name__.__eq__, ["_ParameterKind"], true, "inspect.Parameter.POSITIONAL_ONLY.__class__.__name__ == '_ParameterKind' (IntEnum subclass); verified with Python 3.14.3"]
    - [pk_base_name, Parameter.POSITIONAL_ONLY.__class__.__bases__.__getitem__(0).__name__.__eq__, ["IntEnum"], true, "inspect.Parameter.POSITIONAL_ONLY.__class__.__bases__[0].__name__ == 'IntEnum'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra274
# ---------------------------------------------------------------------------

invariant inspect_extra274.parameter_name_is_Parameter:
  description: "inspect.Parameter.__name__ == 'Parameter' — the class name matches its export symbol"
  category: identity
  kind: python_call_eq
  function: Parameter.__name__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra274.parameter_module_is_inspect:
  description: "inspect.Parameter.__module__ == 'inspect' — Parameter is defined in the pure-Python inspect module"
  category: identity
  kind: python_call_eq
  function: Parameter.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra274.parameter_base_is_object:
  description: "inspect.Parameter.__bases__[0].__name__ == 'object' — Parameter directly subclasses object"
  category: identity
  kind: python_call_eq
  function: Parameter.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

invariant inspect_extra274.positional_only_equals_zero:
  description: "inspect.Parameter.POSITIONAL_ONLY == 0 — the POSITIONAL_ONLY kind has integer ordinal 0 as an IntEnum member"
  category: constants
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__eq__
  args: [0]
  expected: true

invariant inspect_extra274.var_keyword_equals_four:
  description: "inspect.Parameter.VAR_KEYWORD == 4 — the VAR_KEYWORD kind has integer ordinal 4, the highest in the enum"
  category: constants
  kind: python_call_eq
  function: Parameter.VAR_KEYWORD.__eq__
  args: [4]
  expected: true

invariant inspect_extra274.signature_name_is_Signature:
  description: "inspect.Signature.__name__ == 'Signature'"
  category: identity
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra274.signature_module_is_inspect:
  description: "inspect.Signature.__module__ == 'inspect' — Signature is defined in the pure-Python inspect module"
  category: identity
  kind: python_call_eq
  function: Signature.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra274.signature_base_is_object:
  description: "inspect.Signature.__bases__[0].__name__ == 'object' — Signature directly subclasses object"
  category: identity
  kind: python_call_eq
  function: Signature.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

invariant inspect_extra274.parameter_empty_name_is__empty:
  description: "inspect.Parameter.empty.__name__ == '_empty' — the sentinel for missing defaults is named _empty"
  category: identity
  kind: python_call_eq
  function: Parameter.empty.__name__.__eq__
  args: ["_empty"]
  expected: true

invariant inspect_extra274.parameter_kind_class_is_IntEnum_subclass:
  description: "inspect.Parameter.POSITIONAL_ONLY.__class__.__bases__[0].__name__ == 'IntEnum' — _ParameterKind is an IntEnum subclass"
  category: constants
  kind: python_call_eq
  function: Parameter.POSITIONAL_ONLY.__class__.__bases__.__getitem__(0).__name__.__eq__
  args: ["IntEnum"]
  expected: true
