spec: concurrent_futures_extra1681
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 559 (_extra1681): __call__ callable protocol dict-presence checks."
    - "concurrent.futures.Future: pure Python, does not define __call__ in own dict."
    - "concurrent.futures.ThreadPoolExecutor: no __call__ in own dict."
    - "concurrent.futures.ProcessPoolExecutor: no __call__ in own dict."
    - "Related method presence checks: submit, map, shutdown on executors."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# concurrent.futures __call__ callable protocol — Future, executors — extra1681
#
# concurrent.futures.Future.__dict__.__contains__("__call__")              == False
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__("__call__")  == False
# concurrent.futures.ProcessPoolExecutor.__dict__.__contains__("__call__") == False
# concurrent.futures.Executor.__dict__.__contains__("__call__")            == False
# ---------------------------------------------------------------------------

table concurrent_futures_extra1681.callable_protocol:
  description: "concurrent.futures types __call__ dict-presence checks (wave 559 _extra1681) — concurrent.futures.Future.__dict__.__contains__('__call__')==False (cf.Future is a pure-Python class representing the result of an asynchronous computation; it does not define __call__ in its own dict; Future instances are not callable); concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__call__')==False (TPE is a concrete Executor subclass; it does not define __call__ in its own dict; it is not meant to be called as a function — use TPE.submit() instead); concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__call__')==False (PPE is a concrete Executor subclass; same reasoning — no __call__ in own dict); concurrent.futures.Executor.__dict__.__contains__('__call__')==False (Executor is the abstract base class; it does not define __call__; executor objects serve as context managers via __enter__/__exit__, not as callables); verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1681

  columns: [id, function, args, expected]
  rows:
    - ["cf1681001", "concurrent.futures.Future.__dict__.__contains__",              ["__call__"], false]
    - ["cf1681002", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__call__"], false]
    - ["cf1681003", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__call__"], false]
    - ["cf1681004", "concurrent.futures.Executor.__dict__.__contains__",            ["__call__"], false]

# ---------------------------------------------------------------------------
# concurrent.futures executor method presence — submit, map, shutdown — extra1681
#
# concurrent.futures.Executor.__dict__.__contains__("submit")   == True  (abstract)
# concurrent.futures.Executor.__dict__.__contains__("map")      == True
# concurrent.futures.Executor.__dict__.__contains__("shutdown") == True
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__("submit")   == True
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__("map")      == True
# concurrent.futures.ThreadPoolExecutor.__dict__.__contains__("shutdown") == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra1681.executor_method_presence:
  description: "concurrent.futures.Executor and ThreadPoolExecutor own-dict method presence checks (wave 559 _extra1681) — concurrent.futures.Executor.__dict__.__contains__('submit')==True (Executor defines submit() as an abstract method that raises NotImplementedError; all concrete Executor subclasses must override it; submit is in Executor.__dict__); concurrent.futures.Executor.__dict__.__contains__('map')==True (Executor defines map() in its own dict; the default map() implementation calls submit() repeatedly; subclasses do not normally override map); concurrent.futures.Executor.__dict__.__contains__('shutdown')==True (Executor defines shutdown() in its own dict; the default raises NotImplementedError — subclasses override it); concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('submit')==True (TPE overrides submit() in its own dict; TPE.submit() pickles nothing — it passes callables directly to threads via a queue); concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('map')==True (TPE overrides map() in own dict with a thread-optimized version that includes a cancel-on-exception path); concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('shutdown')==True (TPE overrides shutdown() to drain the thread pool); verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1681

  columns: [id, function, args, expected]
  rows:
    - ["cf1681005", "concurrent.futures.Executor.__dict__.__contains__",           ["submit"],   true]
    - ["cf1681006", "concurrent.futures.Executor.__dict__.__contains__",           ["map"],      true]
    - ["cf1681007", "concurrent.futures.Executor.__dict__.__contains__",           ["shutdown"], true]
    - ["cf1681008", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["submit"],   true]
    - ["cf1681009", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["map"],      true]
    - ["cf1681010", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["shutdown"], true]

# ---------------------------------------------------------------------------
# concurrent.futures.Future own-dict method presence — result, cancel, done — extra1681
#
# concurrent.futures.Future.__dict__.__contains__("result") == True
# concurrent.futures.Future.__dict__.__contains__("cancel") == True
# concurrent.futures.Future.__dict__.__contains__("done")   == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra1681.future_method_presence:
  description: "concurrent.futures.Future own-dict method presence checks (wave 559 _extra1681) — concurrent.futures.Future.__dict__.__contains__('result')==True (Future.result(timeout=None) blocks until the future is resolved; if the future raised an exception it re-raises it; result() is in Future.__dict__); concurrent.futures.Future.__dict__.__contains__('cancel')==True (Future.cancel() attempts to cancel the future; returns True if successfully cancelled; cancel() is in Future.__dict__); concurrent.futures.Future.__dict__.__contains__('done')==True (Future.done() returns True if the future is done (completed, cancelled, or raised an exception); done() is in Future.__dict__); concurrent.futures.Future.__dict__.__contains__('add_done_callback')==True (Future.add_done_callback(fn) registers a callback to be called when the future is done; in Future.__dict__); concurrent.futures.Future.__dict__.__contains__('set_result')==True (Future.set_result(result) sets the future result; in Future.__dict__; called by the executor after the submitted callable returns); concurrent.futures.Future.__dict__.__contains__('exception')==True (Future.exception() returns the exception raised by the call; in Future.__dict__); verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1681

  columns: [id, function, args, expected]
  rows:
    - ["cf1681011", "concurrent.futures.Future.__dict__.__contains__", ["result"],           true]
    - ["cf1681012", "concurrent.futures.Future.__dict__.__contains__", ["cancel"],           true]
    - ["cf1681013", "concurrent.futures.Future.__dict__.__contains__", ["done"],             true]
    - ["cf1681014", "concurrent.futures.Future.__dict__.__contains__", ["add_done_callback"], true]
    - ["cf1681015", "concurrent.futures.Future.__dict__.__contains__", ["set_result"],       true]
    - ["cf1681016", "concurrent.futures.Future.__dict__.__contains__", ["exception"],        true]
    - ["cf1681017", "concurrent.futures.Future.__dict__.__contains__", ["__call__"],         false]
