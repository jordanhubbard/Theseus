spec: re_extra208
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: __defaults__ attributes of re module functions."
    - "re.compile.__defaults__ == (0,) — one default: flags=0. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 1."
    - "re.match.__defaults__ == (0,) — one default: flags=0. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 1."
    - "re.search.__defaults__ == (0,) — one default: flags=0. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 1."
    - "re.fullmatch.__defaults__ == (0,) — one default: flags=0. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 1."
    - "re.findall.__defaults__ == (0,) — one default: flags=0. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 1."
    - "re.finditer.__defaults__ == (0,) — one default: flags=0. __defaults__.__class__.__name__ == 'tuple'. __defaults__.__len__() == 1."
    - "re.sub.__defaults__ == None — sub(pattern, repl, string, count=0, flags=0) has count and flags as keyword-only or no positional defaults in this Python version. __defaults__.__class__.__name__ == 'NoneType'."
    - "re.split.__defaults__ == None — split(pattern, string, maxsplit=0, flags=0) — __defaults__ is None in this Python version. __defaults__.__class__.__name__ == 'NoneType'."
    - "The pattern for re functions: functions taking only (pattern, string[, flags]) have __defaults__ == (0,) (one default: flags=0). Functions with additional positional params (count, maxsplit) have __defaults__ == None in Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile and re.match __defaults__ — class name and length
#
# re.compile(pattern, flags=0)  →  __defaults__ == (0,), len == 1
# re.match(pattern, string, flags=0)  →  __defaults__ == (0,), len == 1
# Both have __defaults__.__class__.__name__ == 'tuple'
# The single default is the integer 0 (no flags).
# ---------------------------------------------------------------------------

table re_extra208.compile_match_defaults:
  description: "re.compile and re.match __defaults__ class name and length — both have (0,) for flags=0; __class__.__name__=='tuple'; __len__()==1; verified Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: redefaults208

  columns: [id, function, args, expected, description]
  rows:
    - [compile_defs_cls,     re.compile.__defaults__.__class__.__name__.__eq__, ["tuple"],    true,  "re.compile.__defaults__.__class__.__name__ == 'tuple' — one default: flags=0; re.compile(pattern, flags=0); verified Python 3.14.3"]
    - [compile_defs_len,     re.compile.__defaults__.__len__,                   [],           1,     "re.compile.__defaults__.__len__() == 1 — single default: flags=0; verified Python 3.14.3"]
    - [match_defs_cls,       re.match.__defaults__.__class__.__name__.__eq__,   ["tuple"],    true,  "re.match.__defaults__.__class__.__name__ == 'tuple' — one default: flags=0; re.match(pattern, string, flags=0); verified Python 3.14.3"]
    - [match_defs_len,       re.match.__defaults__.__len__,                     [],           1,     "re.match.__defaults__.__len__() == 1 — single default: flags=0; verified Python 3.14.3"]
    - [compile_not_nonetype, re.compile.__defaults__.__class__.__name__.__eq__, ["NoneType"], false, "re.compile.__defaults__.__class__.__name__ != 'NoneType' — compile has a default (flags=0); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# re.sub and re.split __defaults__ — NoneType
#
# re.sub(pattern, repl, string, count=0, flags=0)
#   __defaults__ == None  →  __class__.__name__ == 'NoneType'
# re.split(pattern, string, maxsplit=0, flags=0)
#   __defaults__ == None  →  __class__.__name__ == 'NoneType'
# These have additional positional params but __defaults__ is None in Python 3.14.3,
# because the Python-level wrappers in re/__init__.py do not expose positional defaults
# the same way as compile/match.
# ---------------------------------------------------------------------------

table re_extra208.sub_split_defaults:
  description: "re.sub and re.split __defaults__.__class__.__name__ == 'NoneType' — both return None for __defaults__ in Python 3.14.3; contrast with compile/match/search which have (0,); verified Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: redefaults208

  columns: [id, function, args, expected, description]
  rows:
    - [sub_defs_cls,        re.sub.__defaults__.__class__.__name__.__eq__,   ["NoneType"], true,  "re.sub.__defaults__.__class__.__name__ == 'NoneType' — __defaults__ is None in Python 3.14.3 for re.sub; verified Python 3.14.3"]
    - [sub_not_tuple,       re.sub.__defaults__.__class__.__name__.__eq__,   ["tuple"],    false, "re.sub.__defaults__.__class__.__name__ != 'tuple' — contrast with compile/match which have (0,) for flags; verified Python 3.14.3"]
    - [split_defs_cls,      re.split.__defaults__.__class__.__name__.__eq__, ["NoneType"], true,  "re.split.__defaults__.__class__.__name__ == 'NoneType' — __defaults__ is None in Python 3.14.3 for re.split; verified Python 3.14.3"]
    - [split_not_tuple,     re.split.__defaults__.__class__.__name__.__eq__, ["tuple"],    false, "re.split.__defaults__.__class__.__name__ != 'tuple' — contrast with compile/match which have (0,) for flags; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# re.search, re.findall, re.finditer __defaults__ — class name and length
#
# re.search(pattern, string, flags=0)  →  __defaults__ == (0,), len == 1
# re.findall(pattern, string, flags=0)  →  __defaults__ == (0,), len == 1
# re.finditer(pattern, string, flags=0)  →  __defaults__ == (0,), len == 1
# All three have __defaults__.__class__.__name__ == 'tuple'
# ---------------------------------------------------------------------------

table re_extra208.search_findall_finditer_defaults:
  description: "re.search, re.findall, re.finditer __defaults__ class name and length — all have (0,) for flags=0; __class__.__name__=='tuple'; __len__()==1; verified Python 3.14.3"
  kind: python_call_eq
  category: defaults
  id_prefix: redefaults208

  columns: [id, function, args, expected, description]
  rows:
    - [search_defs_cls,   re.search.__defaults__.__class__.__name__.__eq__,   ["tuple"], true, "re.search.__defaults__.__class__.__name__ == 'tuple' — one default: flags=0; re.search(pattern, string, flags=0); verified Python 3.14.3"]
    - [search_defs_len,   re.search.__defaults__.__len__,                     [],        1,    "re.search.__defaults__.__len__() == 1 — single default: flags=0; same pattern as compile and match; verified Python 3.14.3"]
    - [findall_defs_cls,  re.findall.__defaults__.__class__.__name__.__eq__,  ["tuple"], true, "re.findall.__defaults__.__class__.__name__ == 'tuple' — one default: flags=0; re.findall(pattern, string, flags=0); verified Python 3.14.3"]
    - [findall_defs_len,  re.findall.__defaults__.__len__,                    [],        1,    "re.findall.__defaults__.__len__() == 1 — single default: flags=0; verified Python 3.14.3"]
    - [finditer_defs_cls, re.finditer.__defaults__.__class__.__name__.__eq__, ["tuple"], true, "re.finditer.__defaults__.__class__.__name__ == 'tuple' — one default: flags=0; re.finditer(pattern, string, flags=0); verified Python 3.14.3"]
    - [finditer_defs_len, re.finditer.__defaults__.__len__,                   [],        1,    "re.finditer.__defaults__.__len__() == 1 — single default: flags=0; same as search and findall; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — re_extra208
# ---------------------------------------------------------------------------

invariant re_extra208.compile_defaults_class_name:
  description: "re.compile.__defaults__.__class__.__name__ == 'tuple' — re.compile(pattern, flags=0) has one default: flags=0; __defaults__ == (0,); __defaults__.__class__.__name__ == 'tuple'; the integer 0 represents no flags (re.compile.__defaults__[0] == 0 == re.NOFLAG); verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: re.compile.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant re_extra208.compile_defaults_len_1:
  description: "re.compile.__defaults__.__len__() == 1 — single default: flags=0; re.compile has exactly one optional parameter (flags); verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: re.compile.__defaults__.__len__
  args: []
  expected: 1

invariant re_extra208.match_defaults_class_name:
  description: "re.match.__defaults__.__class__.__name__ == 'tuple' — re.match(pattern, string, flags=0) has one default: flags=0; __defaults__ == (0,); __defaults__.__class__.__name__ == 'tuple'; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: re.match.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant re_extra208.sub_defaults_NoneType:
  description: "re.sub.__defaults__.__class__.__name__ == 'NoneType' — re.sub.__defaults__ is None in Python 3.14.3; contrast with re.compile/match/search/findall/finditer which all have __defaults__ == (0,); re.sub has a different wrapper structure in re/__init__.py; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: re.sub.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant re_extra208.split_defaults_NoneType:
  description: "re.split.__defaults__.__class__.__name__ == 'NoneType' — re.split.__defaults__ is None in Python 3.14.3; like re.sub, re.split does not expose positional defaults via __defaults__; contrast with re.compile which has __defaults__ == (0,); verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: re.split.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant re_extra208.search_defaults_len_1:
  description: "re.search.__defaults__.__len__() == 1 — single default: flags=0; re.search(pattern, string, flags=0); same __defaults__ length as compile, match, findall, finditer; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: re.search.__defaults__.__len__
  args: []
  expected: 1

invariant re_extra208.findall_defaults_class_name:
  description: "re.findall.__defaults__.__class__.__name__ == 'tuple' — re.findall(pattern, string, flags=0) has one default: flags=0; __defaults__ == (0,); __defaults__.__class__.__name__ == 'tuple'; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: re.findall.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant re_extra208.finditer_defaults_len_1:
  description: "re.finditer.__defaults__.__len__() == 1 — single default: flags=0; re.finditer(pattern, string, flags=0); all six re search/match functions (compile, match, search, fullmatch, findall, finditer) have __defaults__ == (0,) with __len__() == 1; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: defaults
  kind: python_call_eq
  function: re.finditer.__defaults__.__len__
  args: []
  expected: 1
