spec: threading_extra291
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading.local, threading.excepthook, and threading.ExceptHookArgs identity"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py, Modules/_threadmodule.c"
  notes:
    - "threading.local is actually _thread._local at the C level; its __name__ is '_local' and __module__ is '_thread'"
    - "threading.excepthook wraps _thread._excepthook; its __name__ is '_excepthook' and __module__ is '_thread'"
    - "threading.ExceptHookArgs is a namedtuple; its __bases__[0] is tuple, but its __name__ is '_ExceptHookArgs' and __module__ is '_thread'"
    - "threading.TIMEOUT_MAX is a float constant"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table threading_extra291.class_identity:
  description: "Identity attributes of threading.local and threading.ExceptHookArgs"
  kind: python_call_eq
  category: identity
  id_prefix: thex291a

  columns: [id, function, args, expected, description]
  rows:
    - [thex291a01, threading.local.__name__.__eq__, ["_local"], true, "threading.local C-level name is _local"]
    - [thex291a02, threading.local.__module__.__eq__, ["_thread"], true, "threading.local module is _thread (C extension)"]
    - [thex291a03, "threading.local.__bases__[0].__name__.__eq__", ["object"], true, "threading.local base class is object"]
    - [thex291a04, threading.ExceptHookArgs.__name__.__eq__, ["_ExceptHookArgs"], true, "ExceptHookArgs C-level name is _ExceptHookArgs"]
    - [thex291a05, threading.ExceptHookArgs.__module__.__eq__, ["_thread"], true, "ExceptHookArgs module is _thread"]

table threading_extra291.constants_and_hook:
  description: "Identity of threading.TIMEOUT_MAX constant and threading.excepthook function"
  kind: python_call_eq
  category: identity
  id_prefix: thex291b

  columns: [id, function, args, expected, description]
  rows:
    - [thex291b01, threading.TIMEOUT_MAX.__class__.__name__.__eq__, ["float"], true, "TIMEOUT_MAX is a float"]
    - [thex291b02, threading.excepthook.__name__.__eq__, ["_excepthook"], true, "threading.excepthook C-level name is _excepthook"]
    - [thex291b03, threading.excepthook.__module__.__eq__, ["_thread"], true, "threading.excepthook module is _thread"]
    - [thex291b04, threading.local.__class__.__name__.__eq__, ["type"], true, "threading.local metaclass is type"]
    - [thex291b05, threading.ExceptHookArgs.__class__.__name__.__eq__, ["type"], true, "ExceptHookArgs metaclass is type"]

invariant threading_extra291.inv_local_module:
  description: "threading.local __module__ is '_thread' (C extension)"
  category: identity
  kind: python_call_eq
  function: threading.local.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra291.inv_excepthook_module:
  description: "threading.excepthook __module__ is '_thread' (C extension)"
  category: identity
  kind: python_call_eq
  function: threading.excepthook.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra291.inv_excepthookargs_bases:
  description: "threading.ExceptHookArgs base class is tuple (namedtuple)"
  category: identity
  kind: python_call_eq
  function: "threading.ExceptHookArgs.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true
