spec: inspect_extra601
version: ">=3.9"
backend: python_module(inspect)
docs: "inspect module top-level function __qualname__ and __module__ identity checks"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module reference"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__ and __module__ identity for key inspect module functions"
  created_at: "2026-04-12T00:00:00Z"

table inspect_extra601.in601fn:
  id_prefix: in601fn

  columns: [id, function, args, expected]
  rows:
    - [in601fn01, inspect.ismodule.__qualname__.__eq__, ["ismodule"], true]
    - [in601fn02, inspect.isclass.__qualname__.__eq__, ["isclass"], true]
    - [in601fn03, inspect.ismethod.__qualname__.__eq__, ["ismethod"], true]
    - [in601fn04, inspect.isfunction.__qualname__.__eq__, ["isfunction"], true]
    - [in601fn05, inspect.isgeneratorfunction.__qualname__.__eq__, ["isgeneratorfunction"], true]
    - [in601fn06, inspect.iscoroutinefunction.__qualname__.__eq__, ["iscoroutinefunction"], true]
    - [in601fn07, inspect.getmembers.__qualname__.__eq__, ["getmembers"], true]
    - [in601fn08, inspect.getdoc.__qualname__.__eq__, ["getdoc"], true]
    - [in601fn09, inspect.getsource.__qualname__.__eq__, ["getsource"], true]
    - [in601fn10, inspect.signature.__qualname__.__eq__, ["signature"], true]

table inspect_extra601.in601md:
  id_prefix: in601md

  columns: [id, function, args, expected]
  rows:
    - [in601md01, inspect.ismodule.__module__.__eq__, ["inspect"], true]
    - [in601md02, inspect.isclass.__module__.__eq__, ["inspect"], true]
    - [in601md03, inspect.signature.__module__.__eq__, ["inspect"], true]
