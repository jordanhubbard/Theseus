spec: itertools_extra183
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/itertools.py"
  notes:
    - "This spec covers: itertools.compress and itertools.permutations identity — itertools.compress.__name__=='compress' (len=8); itertools.compress.__module__=='itertools'; itertools.compress.__qualname__=='compress'; itertools.permutations.__name__=='permutations' (len=12); itertools.permutations.__module__=='itertools'; itertools.permutations.__qualname__=='permutations'; itertools.combinations.__name__=='combinations' (len=12); itertools.combinations.__module__=='itertools'. All three are C-implemented iterator types in the itertools module."
    - "itertools.compress.__name__ == 'compress' — compress is a C-implemented iterator type in the itertools module that filters elements of a data iterable using a corresponding Boolean selector iterable; its __name__ is 'compress', 8 characters. Verified with Python 3.14.3."
    - "itertools.compress.__module__ == 'itertools' — compress is defined in the C extension module itertools (Modules/itertoolsmodule.c), and its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.compress.__qualname__ == 'compress' — compress is a module-level type (not nested), so its __qualname__ equals its __name__ 'compress' (8 chars). Verified with Python 3.14.3."
    - "itertools.permutations.__name__ == 'permutations' — permutations is a C-implemented iterator type in the itertools module that produces all permutations of an input iterable, optionally of length r; its __name__ is 'permutations', 12 characters. Verified with Python 3.14.3."
    - "itertools.permutations.__module__ == 'itertools' — permutations is defined in the C extension module itertools; its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.permutations.__qualname__ == 'permutations' — permutations is a module-level type, so __qualname__ equals __name__ 'permutations' (12 chars). Verified with Python 3.14.3."
    - "itertools.combinations.__name__ == 'combinations' — combinations is a C-implemented iterator type that produces r-length subsequences of elements from the input iterable without replacement; its __name__ is 'combinations', 12 characters. Verified with Python 3.14.3."
    - "itertools.combinations.__module__ == 'itertools' — combinations is defined in the C extension module itertools; its __module__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.compress __name__, __module__, __qualname__
#
# itertools.compress.__name__ == 'compress'
# itertools.compress.__name__.__len__() == 8
# itertools.compress.__module__ == 'itertools'
# itertools.compress.__qualname__ == 'compress'
#
# itertools.compress is a C-implemented iterator type (Modules/itertoolsmodule.c)
# that filters an iterable using a Boolean selector iterable, yielding only
# elements where the selector is truthy. Its __name__ is 'compress' (8 chars).
# New to extra183.
# ---------------------------------------------------------------------------

table itertools_extra183.compress_identity:
  description: "itertools.compress.__name__ 'compress' len 8; __module__ 'itertools'; __qualname__ 'compress' equals __name__; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: itercompress183

  columns: [id, function, args, expected, description]
  rows:
    - [compress_name_eq,
       compress.__name__.__eq__,
       ["compress"],
       true,
       "itertools.compress.__name__.__eq__('compress') == True — compress is a C-implemented iterator type (Modules/itertoolsmodule.c) that filters an iterable using a Boolean selector iterable, yielding only elements where the selector is truthy; its __name__ is 'compress'; str.__eq__('compress') returns True; new to extra183"]
    - [compress_name_len_8,
       compress.__name__.__len__,
       [],
       8,
       "itertools.compress.__name__.__len__() == 8 — the name 'compress' has exactly 8 characters: c-o-m-p-r-e-s-s; str.__len__() returns 8; new to extra183"]
    - [compress_module_eq,
       compress.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.compress.__module__.__eq__('itertools') == True — compress is defined in the C extension module itertools (Modules/itertoolsmodule.c); its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra183"]
    - [compress_qualname_eq,
       compress.__qualname__.__eq__,
       ["compress"],
       true,
       "itertools.compress.__qualname__.__eq__('compress') == True — compress is a module-level type (not nested), so its __qualname__ equals its __name__ 'compress' (8 chars); str.__eq__('compress') returns True; new to extra183"]

# ---------------------------------------------------------------------------
# Table 2: itertools.permutations __name__, __module__, __qualname__
#
# itertools.permutations.__name__ == 'permutations'
# itertools.permutations.__name__.__len__() == 12
# itertools.permutations.__module__ == 'itertools'
# itertools.permutations.__qualname__ == 'permutations'
#
# itertools.permutations is a C-implemented iterator type that produces all
# permutations of an input iterable, optionally of a given length r.
# Its __name__ is 'permutations' (12 chars). New to extra183.
# ---------------------------------------------------------------------------

table itertools_extra183.permutations_identity:
  description: "itertools.permutations.__name__ 'permutations' len 12; __module__ 'itertools'; __qualname__ 'permutations' equals __name__; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: itercompress183

  columns: [id, function, args, expected, description]
  rows:
    - [perms_name_eq,
       permutations.__name__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__name__.__eq__('permutations') == True — permutations is a C-implemented iterator type that produces all permutations of an input iterable, optionally of length r, without repeated elements; its __name__ is 'permutations'; str.__eq__('permutations') returns True; new to extra183"]
    - [perms_name_len_12,
       permutations.__name__.__len__,
       [],
       12,
       "itertools.permutations.__name__.__len__() == 12 — the name 'permutations' has exactly 12 characters: p-e-r-m-u-t-a-t-i-o-n-s; str.__len__() returns 12; new to extra183"]
    - [perms_module_eq,
       permutations.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.permutations.__module__.__eq__('itertools') == True — permutations is defined in the C extension module itertools; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra183"]
    - [perms_qualname_eq,
       permutations.__qualname__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__qualname__.__eq__('permutations') == True — permutations is a module-level type (not nested), so its __qualname__ equals its __name__ 'permutations' (12 chars); str.__eq__('permutations') returns True; new to extra183"]

# ---------------------------------------------------------------------------
# Table 3: itertools.combinations __name__ and __module__
#
# itertools.combinations.__name__ == 'combinations'
# itertools.combinations.__name__.__len__() == 12
# itertools.combinations.__module__ == 'itertools'
# itertools.combinations.__qualname__ == 'combinations'
#
# itertools.combinations is a C-implemented iterator type that produces
# r-length subsequences of elements from an input iterable without replacement.
# Its __name__ is 'combinations' (12 chars, same length as 'permutations').
# New to extra183.
# ---------------------------------------------------------------------------

table itertools_extra183.combinations_identity:
  description: "itertools.combinations.__name__ 'combinations' len 12; __module__ 'itertools'; __qualname__ 'combinations' equals __name__; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: itercompress183

  columns: [id, function, args, expected, description]
  rows:
    - [combos_name_eq,
       combinations.__name__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — combinations is a C-implemented iterator type that produces r-length subsequences of elements from an input iterable without replacement (order does not matter); its __name__ is 'combinations'; str.__eq__('combinations') returns True; new to extra183"]
    - [combos_name_len_12,
       combinations.__name__.__len__,
       [],
       12,
       "itertools.combinations.__name__.__len__() == 12 — the name 'combinations' has exactly 12 characters: c-o-m-b-i-n-a-t-i-o-n-s; str.__len__() returns 12; same length as 'permutations'; new to extra183"]
    - [combos_module_eq,
       combinations.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.combinations.__module__.__eq__('itertools') == True — combinations is defined in the C extension module itertools; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra183"]
    - [combos_qualname_eq,
       combinations.__qualname__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__qualname__.__eq__('combinations') == True — combinations is a module-level type (not nested), so its __qualname__ equals its __name__ 'combinations' (12 chars); str.__eq__('combinations') returns True; new to extra183"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra183
# ---------------------------------------------------------------------------

invariant itertools_extra183.compress_name_is_compress:
  description: "itertools.compress.__name__ == 'compress' — C-implemented iterator type filtering an iterable by a Boolean selector; __name__ is 'compress' (8 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: compress.__name__.__eq__
  args: ["compress"]
  expected: true

invariant itertools_extra183.compress_module_is_itertools:
  description: "itertools.compress.__module__ == 'itertools' — compress is defined in the C extension module itertools (Modules/itertoolsmodule.c); its __module__ is 'itertools'; new to extra183"
  category: identity
  kind: python_call_eq
  function: compress.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra183.compress_qualname_equals_name:
  description: "itertools.compress.__qualname__ == 'compress' — module-level type has __qualname__ == __name__ == 'compress' (8 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: compress.__qualname__.__eq__
  args: ["compress"]
  expected: true

invariant itertools_extra183.permutations_name_is_permutations:
  description: "itertools.permutations.__name__ == 'permutations' — C-implemented iterator type producing all permutations of an input iterable; __name__ is 'permutations' (12 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: permutations.__name__.__eq__
  args: ["permutations"]
  expected: true

invariant itertools_extra183.permutations_module_is_itertools:
  description: "itertools.permutations.__module__ == 'itertools' — permutations is defined in the C extension module itertools; its __module__ is 'itertools'; new to extra183"
  category: identity
  kind: python_call_eq
  function: permutations.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra183.permutations_qualname_equals_name:
  description: "itertools.permutations.__qualname__ == 'permutations' — module-level type has __qualname__ == __name__ == 'permutations' (12 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: permutations.__qualname__.__eq__
  args: ["permutations"]
  expected: true

invariant itertools_extra183.combinations_name_is_combinations:
  description: "itertools.combinations.__name__ == 'combinations' — C-implemented iterator type producing r-length subsequences without replacement; __name__ is 'combinations' (12 chars); new to extra183"
  category: identity
  kind: python_call_eq
  function: combinations.__name__.__eq__
  args: ["combinations"]
  expected: true

invariant itertools_extra183.combinations_module_is_itertools:
  description: "itertools.combinations.__module__ == 'itertools' — combinations is defined in the C extension module itertools; its __module__ is 'itertools'; new to extra183"
  category: identity
  kind: python_call_eq
  function: combinations.__module__.__eq__
  args: ["itertools"]
  expected: true
