spec: random_extra15
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html — Python random module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
  notes:
    - "This spec extends random.zspec.zsdl and prior extras through random_extra14.zspec.zsdl."
    - "random_extra5 covers gammavariate/lognormvariate/normalvariate __module__."
    - "random_extra6 covers distribution __qualname__ for gammavariate/lognormvariate/triangular/vonmisesvariate/paretovariate/weibullvariate."
    - "random_extra13 covers randint/uniform/shuffle/sample/choices __module__ and __name__; also Random/SystemRandom __qualname__ and __module__."
    - "random_extra14 covers Random/__name__ and SystemRandom/__name__ and vonmisesvariate/paretovariate/weibullvariate __name__."
    - "No prior spec covers Random.__bases__[0].__module__ == '_random'."
    - "No prior spec covers SystemRandom.__bases__[0].__module__ == 'random'."
    - "No prior spec covers triangular/__module__, betavariate/__module__, expovariate/__module__, gauss/__module__, randrange/__module__, vonmisesvariate/__module__, paretovariate/__module__, weibullvariate/__module__, or seed/__module__."
    - "No prior spec covers shuffle/__qualname__, choices/__qualname__, randint/__qualname__, or sample/__qualname__ via __eq__ invariant."
    - "random.Random.__bases__[0].__module__ == '_random' — the pure-Python Random class extends the C-extension _random.Random."
    - "random.SystemRandom.__bases__[0].__module__ == 'random' — SystemRandom extends random.Random (the pure-Python class)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Random class hierarchy — base class module attributes
#
# random.Random.__bases__[0] is _random.Random (the C extension base class).
# Its __module__ is '_random', confirming the C-level ancestry.
# random.SystemRandom.__bases__[0] is random.Random (the pure-Python class).
# Its __module__ is 'random'.
# No prior spec covers these module attributes on the base class objects.
# ---------------------------------------------------------------------------

invariant random_extra15.Random.bases0.module:
  description: "random.Random.__bases__[0].__module__ == '_random' — C extension base class"
  category: class_hierarchy
  kind: python_call_eq
  function: "Random.__bases__[0].__module__.__eq__"
  args: ["_random"]
  expected: true

invariant random_extra15.SystemRandom.bases0.module:
  description: "random.SystemRandom.__bases__[0].__module__ == 'random' — pure-Python Random is the base"
  category: class_hierarchy
  kind: python_call_eq
  function: "SystemRandom.__bases__[0].__module__.__eq__"
  args: ["random"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function __qualname__ attributes
#
# random module-level convenience functions are actually bound methods of the
# module's global Random instance. Their __qualname__ is 'Random.<method>',
# not just the bare function name. random_extra6 covers __qualname__ for
# betavariate/expovariate/gauss/gammavariate/lognormvariate/triangular/
# vonmisesvariate/paretovariate/weibullvariate. No prior spec covers
# shuffle/choices/randint/sample __qualname__ as standalone invariants.
# ---------------------------------------------------------------------------

invariant random_extra15.shuffle.qualname:
  description: "random.shuffle.__qualname__ == 'Random.shuffle' — bound method qualname"
  category: function_identity
  kind: python_call_eq
  function: shuffle.__qualname__.__eq__
  args: ["Random.shuffle"]
  expected: true

invariant random_extra15.choices.qualname:
  description: "random.choices.__qualname__ == 'Random.choices' — bound method qualname"
  category: function_identity
  kind: python_call_eq
  function: choices.__qualname__.__eq__
  args: ["Random.choices"]
  expected: true

# ---------------------------------------------------------------------------
# Distribution function __module__ table
#
# random_extra5 covers gammavariate/lognormvariate/normalvariate __module__.
# random_extra13 covers randint/uniform/shuffle/sample/choices __module__.
# No prior spec covers triangular/betavariate/expovariate/gauss/randrange/
# vonmisesvariate/paretovariate/weibullvariate/seed __module__.
# All module-level random functions have __module__ == 'random'.
# ---------------------------------------------------------------------------

table random_extra15.distribution_modules:
  description: "__module__ for distribution and utility functions not covered in prior specs"
  kind: python_call_eq
  category: function_metadata
  id_prefix: dmod

  columns: [id, function, args, expected]
  rows:
    - [triangular,     triangular.__module__.__eq__,     ["random"], true]
    - [betavariate,    betavariate.__module__.__eq__,    ["random"], true]
    - [expovariate,    expovariate.__module__.__eq__,    ["random"], true]
    - [gauss,          gauss.__module__.__eq__,          ["random"], true]
    - [randrange,      randrange.__module__.__eq__,      ["random"], true]
    - [vonmisesvariate, vonmisesvariate.__module__.__eq__, ["random"], true]
    - [paretovariate,  paretovariate.__module__.__eq__,  ["random"], true]
    - [weibullvariate, weibullvariate.__module__.__eq__,  ["random"], true]
    - [seed,           seed.__module__.__eq__,           ["random"], true]
