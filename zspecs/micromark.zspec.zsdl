spec: micromark
version: ">=4.0.0"
backend: node(micromark)

docs: https://github.com/micromark/micromark#readme

provenance:
  derived_from:
    - "Micromark README — https://github.com/micromark/micromark#readme"
    - "CommonMark Spec — https://spec.commonmark.org/"
    - "Test vectors verified with micromark via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "micromark source"
  notes:
    - "Micromark is the small, streaming CommonMark parser underlying remark/MDX."
    - "Install: npm install micromark"
    - "v4 ESM with CJS shim; named export 'micromark' is the parser function."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws on string input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

table micromark.render:
  kind: node_module_call_eq
  category: render
  function: micromark
  id_prefix: render

  columns: [id, args, expected]
  rows:
    - [h1,            ["# Hello"],          "<h1>Hello</h1>"]
    - [bold,          ["**bold**"],         "<p><strong>bold</strong></p>"]
    - [italic,        ["*em*"],             "<p><em>em</em></p>"]
    - [inline_code,   ["`code`"],           "<p><code>code</code></p>"]
    - [link,          ["[x](u)"],           "<p><a href=\"u\">x</a></p>"]
    - [unordered_list,
       ["- a\n- b"],
       "<ul>\n<li>a</li>\n<li>b</li>\n</ul>"]
    - [ordered_list,
       ["1. one\n2. two"],
       "<ol>\n<li>one</li>\n<li>two</li>\n</ol>"]
    - [empty_input,   [""],                  ""]
    - [plain_text,    ["plain"],             "<p>plain</p>"]
