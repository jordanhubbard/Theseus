spec: decimal_extra213
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "Decimal method __name__ values for __add__, __sub__, __mul__, __truediv__, sqrt, normalize etc. verified with Python 3.14.3."
    - "Decimal arithmetic: Decimal('1')+Decimal('2')==Decimal('3'), str result '3'; verified with Python 3.14.3."
    - "is_zero, is_finite, is_infinite, is_signed predicates verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal arithmetic operator method __name__ checks
# ---------------------------------------------------------------------------

table decimal_extra213.decimal_operator_method_names:
  description: "decimal.Decimal arithmetic operator method __name__ checks — __add__, __sub__, __mul__, __truediv__, __abs__, __neg__, __pos__ all return their dunder name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: decimalextra213a

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_add_name,      decimal.Decimal.__add__.__name__.__eq__,      ["__add__"],      true, "decimal.Decimal.__add__.__name__ == '__add__'; verified with Python 3.14.3"]
    - [decimal_sub_name,      decimal.Decimal.__sub__.__name__.__eq__,      ["__sub__"],      true, "decimal.Decimal.__sub__.__name__ == '__sub__'; verified with Python 3.14.3"]
    - [decimal_mul_name,      decimal.Decimal.__mul__.__name__.__eq__,      ["__mul__"],      true, "decimal.Decimal.__mul__.__name__ == '__mul__'; verified with Python 3.14.3"]
    - [decimal_truediv_name,  decimal.Decimal.__truediv__.__name__.__eq__,  ["__truediv__"],  true, "decimal.Decimal.__truediv__.__name__ == '__truediv__'; verified with Python 3.14.3"]
    - [decimal_abs_name,      decimal.Decimal.__abs__.__name__.__eq__,      ["__abs__"],      true, "decimal.Decimal.__abs__.__name__ == '__abs__'; verified with Python 3.14.3"]
    - [decimal_neg_name,      decimal.Decimal.__neg__.__name__.__eq__,      ["__neg__"],      true, "decimal.Decimal.__neg__.__name__ == '__neg__'; verified with Python 3.14.3"]
    - [decimal_pos_name,      decimal.Decimal.__pos__.__name__.__eq__,      ["__pos__"],      true, "decimal.Decimal.__pos__.__name__ == '__pos__'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Decimal math method __name__ and __qualname__ checks
# ---------------------------------------------------------------------------

table decimal_extra213.decimal_math_method_names:
  description: "decimal.Decimal math method __name__ and __qualname__ checks — sqrt, log10, ln, normalize, is_nan, is_finite, is_infinite, is_zero; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: decimalextra213b

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_sqrt_name,       decimal.Decimal.sqrt.__name__.__eq__,        ["sqrt"],             true, "decimal.Decimal.sqrt.__name__ == 'sqrt'; verified with Python 3.14.3"]
    - [decimal_log10_name,      decimal.Decimal.log10.__name__.__eq__,       ["log10"],            true, "decimal.Decimal.log10.__name__ == 'log10'; verified with Python 3.14.3"]
    - [decimal_ln_name,         decimal.Decimal.ln.__name__.__eq__,          ["ln"],               true, "decimal.Decimal.ln.__name__ == 'ln'; verified with Python 3.14.3"]
    - [decimal_normalize_name,  decimal.Decimal.normalize.__name__.__eq__,   ["normalize"],        true, "decimal.Decimal.normalize.__name__ == 'normalize'; verified with Python 3.14.3"]
    - [decimal_is_nan_name,     decimal.Decimal.is_nan.__name__.__eq__,      ["is_nan"],           true, "decimal.Decimal.is_nan.__name__ == 'is_nan'; verified with Python 3.14.3"]
    - [decimal_is_finite_name,  decimal.Decimal.is_finite.__name__.__eq__,   ["is_finite"],        true, "decimal.Decimal.is_finite.__name__ == 'is_finite'; verified with Python 3.14.3"]
    - [decimal_sqrt_qualname,   decimal.Decimal.sqrt.__qualname__.__eq__,    ["Decimal.sqrt"],     true, "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt'; verified with Python 3.14.3"]
    - [decimal_add_qualname,    decimal.Decimal.__add__.__qualname__.__eq__, ["Decimal.__add__"],  true, "decimal.Decimal.__add__.__qualname__ == 'Decimal.__add__'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Decimal arithmetic behavior checks
# ---------------------------------------------------------------------------

table decimal_extra213.decimal_arithmetic_behavior:
  description: "decimal.Decimal arithmetic behavioral contracts — addition, division result types and values; is_zero, is_finite, is_infinite predicates; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: decimalextra213c

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_add_type,      "decimal.Decimal.__add__(decimal.Decimal('1'), decimal.Decimal('2')).__class__.__name__.__eq__",    ["Decimal"], true,  "type(Decimal('1') + Decimal('2')).__name__ == 'Decimal'; verified with Python 3.14.3"]
    - [decimal_add_str,       "decimal.Decimal.__add__(decimal.Decimal('1'), decimal.Decimal('2')).__str__",                      [],          "3",   "str(Decimal('1') + Decimal('2')) == '3'; verified with Python 3.14.3"]
    - [decimal_div_type,      "decimal.Decimal.__truediv__(decimal.Decimal('10'), decimal.Decimal('4')).__class__.__name__.__eq__", ["Decimal"], true, "type(Decimal('10') / Decimal('4')).__name__ == 'Decimal'; verified with Python 3.14.3"]
    - [decimal_zero_is_zero,  "decimal.Decimal.is_zero(decimal.Decimal('0'))",                                                    [],          true,  "Decimal('0').is_zero() == True; verified with Python 3.14.3"]
    - [decimal_one_is_finite, "decimal.Decimal.is_finite(decimal.Decimal('1'))",                                                  [],          true,  "Decimal('1').is_finite() == True; verified with Python 3.14.3"]
    - [decimal_inf_is_inf,    "decimal.Decimal.is_infinite(decimal.Decimal('Inf'))",                                              [],          true,  "Decimal('Inf').is_infinite() == True; verified with Python 3.14.3"]
    - [decimal_neg_is_signed, "decimal.Decimal.is_signed(decimal.Decimal('-1'))",                                                 [],          true,  "Decimal('-1').is_signed() == True; verified with Python 3.14.3"]
    - [decimal_pos_not_signed,"decimal.Decimal.is_signed(decimal.Decimal('5'))",                                                  [],          false, "Decimal('5').is_signed() == False; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra213.decimal_normalize_qualname:
  description: "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize' — normalize removes trailing zeros; qualname encodes class context; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.normalize.__qualname__.__eq__
  args: ["Decimal.normalize"]
  expected: true

invariant decimal_extra213.decimal_is_zero_qualname:
  description: "decimal.Decimal.is_zero.__qualname__ == 'Decimal.is_zero' — qualname encodes class context for the is_zero predicate; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.is_zero.__qualname__.__eq__
  args: ["Decimal.is_zero"]
  expected: true

invariant decimal_extra213.decimal_truediv_qualname:
  description: "decimal.Decimal.__truediv__.__qualname__ == 'Decimal.__truediv__' — verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__truediv__.__qualname__.__eq__
  args: ["Decimal.__truediv__"]
  expected: true

invariant decimal_extra213.decimal_add_result_str:
  description: "str(decimal.Decimal('1') + decimal.Decimal('2')) == '3' — Decimal arithmetic preserves exact values and str() produces clean output without trailing zeros or scientific notation for small integers; verified with Python 3.14.3"
  category: behavior
  kind: python_call_eq
  function: "decimal.Decimal.__add__(decimal.Decimal('1'), decimal.Decimal('2')).__str__"
  args: []
  expected: "3"

