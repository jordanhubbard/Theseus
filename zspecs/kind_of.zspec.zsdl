spec: kind_of
version: ">=6.0.3"
backend: node(kind-of)

docs: https://www.npmjs.com/package/kind-of

provenance:
  derived_from:
    - "kind-of README — https://www.npmjs.com/package/kind-of"
    - "Test vectors verified with kind-of via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "kind-of source"
  notes:
    - "kind-of is an npm package. Install: npm install kind-of"
    - "Returns a precise type string: number, string, array, object, null, boolean, etc."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a type string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table kind_of.kindOf:
  kind: node_module_call_eq
  function: ~
  category: classify
  id_prefix: kindof

  columns: [id, args, expected]
  rows:
    - [number,  [1],          "number"]
    - [string,  ["foo"],      "string"]
    - [array,   [[1, 2]],     "array"]
    - [object,  [{"a": 1}],  "object"]
    - [null,    [null],       "null"]
