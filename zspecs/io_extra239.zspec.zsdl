spec: io_extra239
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bufferedio.c"
  notes:
    - "This spec covers: io.BufferedReader/BufferedWriter class identity contracts."
    - "io.BufferedReader.__name__ == 'BufferedReader' — BufferedReader class name; length 14; verified Python 3.14.3 macOS."
    - "io.BufferedWriter.__name__ == 'BufferedWriter' — BufferedWriter class name; length 14; verified Python 3.14.3 macOS."
    - "io.BufferedRandom.__name__ == 'BufferedRandom' — BufferedRandom class name; length 14; verified Python 3.14.3 macOS."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' — TextIOWrapper class name; length 13; verified Python 3.14.3 macOS."
    - "io.BufferedReader.__module__ == '_io' — BufferedReader is implemented in _io C extension; verified Python 3.14.3 macOS."
    - "io.BufferedWriter.__module__ == '_io' — BufferedWriter is implemented in _io C extension; verified Python 3.14.3 macOS."
    - "io.BufferedReader.__qualname__ == 'BufferedReader' — qualname matches name (no nesting); verified Python 3.14.3 macOS."
    - "io.BufferedWriter.__qualname__ == 'BufferedWriter' — qualname matches name (no nesting); verified Python 3.14.3 macOS."
    - "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — direct base is _BufferedIOBase; verified Python 3.14.3 macOS."
    - "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — direct base is _BufferedIOBase; verified Python 3.14.3 macOS."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — direct base is _TextIOBase; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedReader/BufferedWriter class __name__ contracts
# All standard buffered IO classes carry their canonical name as __name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra239.Buffered_class_names:
  description: "io.BufferedReader/BufferedWriter class __name__ contracts — BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobufclsname239

  columns: [id, function, args, expected]
  rows:
    - [bufrd_name,    BufferedReader.__name__.__eq__,  ["BufferedReader"],  true]
    - [bufwr_name,    BufferedWriter.__name__.__eq__,  ["BufferedWriter"],  true]
    - [bufrand_name,  BufferedRandom.__name__.__eq__,  ["BufferedRandom"],  true]
    - [textwrap_name, TextIOWrapper.__name__.__eq__,   ["TextIOWrapper"],   true]

# ---------------------------------------------------------------------------
# io.BufferedReader/BufferedWriter __module__ contracts
# Both classes live in the _io C extension despite being accessed via io.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table io_extra239.Buffered_class_modules:
  description: "io.BufferedReader/BufferedWriter __module__ == '_io' contracts — both implemented in _io C extension; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobufmodule239

  columns: [id, function, args, expected]
  rows:
    - [bufrd_module,   BufferedReader.__module__.__eq__,  ["_io"],  true]
    - [bufwr_module,   BufferedWriter.__module__.__eq__,  ["_io"],  true]
    - [bufrand_module, BufferedRandom.__module__.__eq__,  ["_io"],  true]
    - [textwrap_mod,   TextIOWrapper.__module__.__eq__,   ["_io"],  true]

# ---------------------------------------------------------------------------
# io.BufferedReader/BufferedWriter __qualname__ contracts
# qualname equals name because these are top-level classes (no nesting).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra239.BufferedReader.qualname:
  description: "io.BufferedReader.__qualname__ == 'BufferedReader' — qualname matches name for top-level class; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__qualname__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra239.BufferedWriter.qualname:
  description: "io.BufferedWriter.__qualname__ == 'BufferedWriter' — qualname matches name for top-level class; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedWriter.__qualname__.__eq__
  args: ["BufferedWriter"]
  expected: true

# ---------------------------------------------------------------------------
# io.BufferedReader/BufferedWriter __bases__ contracts
# Direct base class is _BufferedIOBase (the C-level base).
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra239.BufferedReader.base_name:
  description: "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' — direct base is _BufferedIOBase; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "BufferedReader.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra239.BufferedWriter.base_name:
  description: "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — direct base is _BufferedIOBase; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "BufferedWriter.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra239.TextIOWrapper.base_name:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — direct base is _TextIOBase; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: "TextIOWrapper.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

# ---------------------------------------------------------------------------
# io.BufferedReader/BufferedWriter class name length contracts
# Spot-check name lengths for BufferedReader, BufferedWriter, TextIOWrapper.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant io_extra239.BufferedReader.name_length:
  description: "io.BufferedReader.__name__.__len__() == 14 — 'BufferedReader' has 14 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__name__.__len__
  args: []
  expected: 14

invariant io_extra239.BufferedWriter.name_length:
  description: "io.BufferedWriter.__name__.__len__() == 14 — 'BufferedWriter' has 14 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: BufferedWriter.__name__.__len__
  args: []
  expected: 14

invariant io_extra239.TextIOWrapper.name_length:
  description: "io.TextIOWrapper.__name__.__len__() == 13 — 'TextIOWrapper' has 13 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: TextIOWrapper.__name__.__len__
  args: []
  expected: 13
