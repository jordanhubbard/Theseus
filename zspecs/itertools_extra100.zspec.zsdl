# ---------------------------------------------------------------------------
# Table 1: itertools module __name__ identity and C-type __name__ string values
#
# Wave 257 theme: itertools module __name__ and C-type __name__ string equality.
#
# itertools.__name__ == 'itertools'
# itertools.chain.__name__ == 'chain'
# itertools.cycle.__name__ == 'cycle'
# itertools.repeat.__name__ == 'repeat'
# itertools.count.__name__ == 'count'
# itertools.product.__name__ == 'product'
# itertools.combinations.__name__ == 'combinations'
# itertools.accumulate.__name__ == 'accumulate'
#
# The __name__ attributes for module-level symbols confirm module identity.
# All C extension types have __name__ matching their simple class name.
# New to extra100.
# ---------------------------------------------------------------------------

table itertools_extra100.module_and_type_name_strings:
  description: "itertools.__name__ identity and C-type __name__ string equality for chain/cycle/repeat/count/product/combinations/accumulate; wave 257; new to extra100"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsname100

  columns: [id, function, args, expected, description]
  rows:
    - [itertools_name_eq_itertools,
       "__name__.__eq__",
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the itertools module's __name__ attribute reflects its dotted module name; for a top-level C extension module like itertools it is just 'itertools'; str.__eq__('itertools') returns True; new to extra100"]
    - [itertools_name_len_eq_9,
       "__name__.__len__",
       [],
       9,
       "itertools.__name__.__len__() == 9 — the module name 'itertools' has 9 characters (i-t-e-r-t-o-o-l-s); new to extra100"]
    - [chain_name_len_eq_5,
       "chain.__name__.__len__",
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — itertools.chain is a C extension type; its __name__ is 'chain'; len('chain') == 5 (c-h-a-i-n); new to extra100"]
    - [cycle_name_len_eq_5,
       "cycle.__name__.__len__",
       [],
       5,
       "itertools.cycle.__name__.__len__() == 5 — itertools.cycle is a C extension type; its __name__ is 'cycle'; len('cycle') == 5 (c-y-c-l-e); new to extra100"]
    - [repeat_name_len_eq_6,
       "repeat.__name__.__len__",
       [],
       6,
       "itertools.repeat.__name__.__len__() == 6 — itertools.repeat is a C extension type; its __name__ is 'repeat'; len('repeat') == 6 (r-e-p-e-a-t); new to extra100"]
    - [count_name_len_eq_5,
       "count.__name__.__len__",
       [],
       5,
       "itertools.count.__name__.__len__() == 5 — itertools.count is a C extension type; its __name__ is 'count'; len('count') == 5 (c-o-u-n-t); new to extra100"]
    - [product_name_len_eq_7,
       "product.__name__.__len__",
       [],
       7,
       "itertools.product.__name__.__len__() == 7 — itertools.product is a C extension type; its __name__ is 'product'; len('product') == 7 (p-r-o-d-u-c-t); new to extra100"]
    - [combinations_name_len_eq_12,
       "combinations.__name__.__len__",
       [],
       12,
       "itertools.combinations.__name__.__len__() == 12 — itertools.combinations is a C extension type; its __name__ is 'combinations'; len('combinations') == 12 (c-o-m-b-i-n-a-t-i-o-n-s); new to extra100"]

