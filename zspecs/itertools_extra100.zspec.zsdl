table itertools_extra100.remaining_name_equality:
  description: "itertools.groupby/__name__ eq 'groupby'; accumulate eq 'accumulate'; combinations eq 'combinations'; confirms C-type __name__; wave 257; new to extra100"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsname100

  columns: [id, function, args, expected, description]
  rows:
    - [groupby_name_eq,
       "groupby.__name__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__name__.__eq__('groupby') == True — itertools.groupby is a C extension type that makes an iterator returning consecutive keys and groups from the iterable; its __name__ attribute is 'groupby'; str.__eq__('groupby') returns True; new to extra100"]
    - [accumulate_name_eq,
       "accumulate.__name__.__eq__",
       ["accumulate"],
       true,
       "itertools.accumulate.__name__.__eq__('accumulate') == True — itertools.accumulate is a C extension type that makes an iterator returning accumulated sums or other binary function results; its __name__ is 'accumulate'; str.__eq__('accumulate') returns True; new to extra100"]
    - [combinations_name_eq,
       "combinations.__name__.__eq__",
       ["combinations"],
       true,
       "itertools.combinations.__name__.__eq__('combinations') == True — itertools.combinations is a C extension type; it returns r-length tuples in sorted order with no repeated elements; its __name__ is 'combinations'; str.__eq__('combinations') returns True; new to extra100"]

