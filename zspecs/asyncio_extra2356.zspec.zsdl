spec: asyncio_extra2356
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes:
    - "Checks .__init__.__class__.__name__ and .__new__.__class__.__name__ for asyncio classes"
    - "C-accelerated types (Task, Future) have wrapper_descriptor __init__; Python types have function"
    - "All classes share builtin_function_or_method for __new__ (inherited from object)"
  created_at: "2026-04-12"
error_model: python_exceptions

table asyncio_extra2356.task_init_type:
  description: "__init__ and __new__ implementation type for asyncio.Task (C type via _asyncio)"
  kind: python_call_eq
  category: init_type
  id_prefix: as2356
  columns: [id, function, args, expected]
  rows:
    - ["as2356001", asyncio.Task.__init__.__class__.__name__.__eq__,  ["wrapper_descriptor"],       true]
    - ["as2356002", asyncio.Task.__new__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true]

