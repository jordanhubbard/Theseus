table asyncio_extra2356.init_type_contrast:
  description: "Cross-class contrast: C types (wrapper_descriptor) vs Python types (function) for __init__"
  kind: python_call_eq
  category: init_type
  id_prefix: as2356
  columns: [id, function, args, expected]
  rows:
    - ["as2356019", asyncio.Task.__init__.__class__.__name__.__eq__,   ["function"], false]
    - ["as2356020", asyncio.Event.__init__.__class__.__name__.__eq__,  ["wrapper_descriptor"], false]
    - ["as2356021", asyncio.Future.__init__.__class__.__name__.__eq__, ["function"], false]
    - ["as2356022", asyncio.Lock.__init__.__class__.__name__.__eq__,   ["wrapper_descriptor"], false]
