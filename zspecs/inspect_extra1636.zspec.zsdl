spec: inspect_extra1636
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __subclasshook__/__instancecheck__/__subclasscheck__"
    - "inspect.Parameter, Signature, and BoundArguments are plain Python classes without ABCMeta as metaclass"
    - "None of the inspect classes define __subclasshook__, __instancecheck__, or __subclasscheck__ in their own __dict__"
    - "inspect.Parameter defines __slots__; its metaclass is the default 'type', not ABCMeta"
    - "inspect.Signature defines __slots__; its metaclass is the default 'type', not ABCMeta"
    - "inspect.BoundArguments defines __slots__; its metaclass is the default 'type', not ABCMeta"
    - "inspect._ParameterKind is an IntEnum subclass; IntEnum's metaclass is EnumMeta (a subclass of type but NOT ABCMeta)"
    - "inspect.isclass(functools.partial) is True — partial is a C extension type (class object)"
    - "inspect.isclass(int) is True; inspect.isclass(42) is False; inspect.isclass(type) is True"
    - "inspect.isabstract(int) is False — int has no abstract methods"
    - "inspect.isabstract(collections.abc.Iterator) is True — Iterator defines __next__ as @abstractmethod"
    - "inspect.getmro(functools.partial) has length 2: (partial, object)"
    - "inspect.getmro returns a tuple; its __class__.__name__ is 'tuple'"
  created_at: "2026-04-12"
error_model: python_exceptions

table inspect_extra1636.inspect_classes_no_virtual_subclassing:
  description: "inspect.Parameter, Signature, and BoundArguments do not define __subclasshook__, __instancecheck__, or __subclasscheck__; they use the default type metaclass with no ABC virtual subclassing"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1636nv

  columns: [id, function, args, expected]
  rows:
    - ["in1636nv001", "inspect.Parameter.__dict__.__contains__",      ["__subclasshook__"],   false]
    - ["in1636nv002", "inspect.Parameter.__dict__.__contains__",      ["__instancecheck__"],  false]
    - ["in1636nv003", "inspect.Parameter.__dict__.__contains__",      ["__subclasscheck__"],  false]
    - ["in1636nv004", "inspect.Signature.__dict__.__contains__",      ["__subclasshook__"],   false]
    - ["in1636nv005", "inspect.Signature.__dict__.__contains__",      ["__instancecheck__"],  false]
    - ["in1636nv006", "inspect.Signature.__dict__.__contains__",      ["__subclasscheck__"],  false]
    - ["in1636nv007", "inspect.BoundArguments.__dict__.__contains__", ["__subclasshook__"],   false]
    - ["in1636nv008", "inspect.BoundArguments.__dict__.__contains__", ["__instancecheck__"],  false]
    - ["in1636nv009", "inspect.BoundArguments.__dict__.__contains__", ["__subclasscheck__"],  false]
    - ["in1636nv010", "inspect.Parameter.__dict__.__contains__",      ["__abstractmethods__"], false]
    - ["in1636nv011", "inspect.Signature.__dict__.__contains__",      ["__abstractmethods__"], false]
    - ["in1636nv012", "inspect.BoundArguments.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["in1636nv013", "inspect.Parameter.__class__.__name__.__eq__",      ["type"],    true]
    - ["in1636nv014", "inspect.Signature.__class__.__name__.__eq__",      ["type"],    true]
    - ["in1636nv015", "inspect.BoundArguments.__class__.__name__.__eq__", ["type"],    true]
    - ["in1636nv016", "inspect.Parameter.__class__.__name__.__eq__",      ["ABCMeta"], false]
    - ["in1636nv017", "inspect.Signature.__class__.__name__.__eq__",      ["ABCMeta"], false]
    - ["in1636nv018", "inspect.BoundArguments.__class__.__name__.__eq__", ["ABCMeta"], false]
    - ["in1636nv019", "inspect.Parameter.__name__.__eq__",      ["Parameter"],      true]
    - ["in1636nv020", "inspect.Signature.__name__.__eq__",      ["Signature"],      true]
    - ["in1636nv021", "inspect.BoundArguments.__name__.__eq__", ["BoundArguments"], true]
    - ["in1636nv022", "inspect.Parameter.__module__.__eq__",      ["inspect"],       true]
    - ["in1636nv023", "inspect.Signature.__module__.__eq__",      ["inspect"],       true]
    - ["in1636nv024", "inspect.BoundArguments.__module__.__eq__", ["inspect"],       true]
    - ["in1636nv025", "inspect.Parameter.__dict__.__class__.__name__.__eq__",      ["mappingproxy"], true]
    - ["in1636nv026", "inspect.Signature.__dict__.__class__.__name__.__eq__",      ["mappingproxy"], true]
    - ["in1636nv027", "inspect.BoundArguments.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["in1636nv028", "inspect.Parameter.__dict__.__contains__",      ["__slots__"], true]
    - ["in1636nv029", "inspect.Signature.__dict__.__contains__",      ["__slots__"], true]
    - ["in1636nv030", "inspect.BoundArguments.__dict__.__contains__", ["__slots__"], true]

table inspect_extra1636.inspect_class_checks:
  description: "inspect module predicates for class identity (isclass, isabstract) tested against well-known objects; isabstract uses __abstractmethods__ frozenset, not ABC virtual subclassing hooks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1636ic

  columns: [id, function, args, expected]
  rows:
    - ["in1636ic001", "inspect.isclass.__name__.__eq__",    ["isclass"],    true]
    - ["in1636ic002", "inspect.isabstract.__name__.__eq__", ["isabstract"], true]
    - ["in1636ic003", "inspect.getmro.__name__.__eq__",     ["getmro"],     true]
    - ["in1636ic004", "inspect.isclass.__module__.__eq__",    ["inspect"],  true]
    - ["in1636ic005", "inspect.isabstract.__module__.__eq__", ["inspect"],  true]
    - ["in1636ic006", "inspect.getmro.__module__.__eq__",     ["inspect"],  true]
    - ["in1636ic007", "inspect.isclass.__class__.__name__.__eq__",    ["function"], true]
    - ["in1636ic008", "inspect.isabstract.__class__.__name__.__eq__", ["function"], true]
    - ["in1636ic009", "inspect.getmro.__class__.__name__.__eq__",     ["function"], true]
    - ["in1636ic010", "inspect.Parameter.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["in1636ic011", "inspect.Signature.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["in1636ic012", "inspect.Parameter.__bases__.__len__",  [],             1]
    - ["in1636ic013", "inspect.Signature.__bases__.__len__",  [],             1]
    - ["in1636ic014", "inspect.BoundArguments.__bases__.__len__", [],         1]
    - ["in1636ic015", "inspect.Parameter.__mro__.__len__",     [],            2]
    - ["in1636ic016", "inspect.Signature.__mro__.__len__",     [],            2]
    - ["in1636ic017", "inspect.BoundArguments.__mro__.__len__", [],           2]
    - ["in1636ic018", "inspect.Parameter.__mro__.__getitem__",  [0],          "Parameter"]
    - ["in1636ic019", "inspect.Parameter.__mro__.__getitem__",  [1],          "object"]
    - ["in1636ic020", "inspect.Signature.__mro__.__getitem__",  [0],          "Signature"]
    - ["in1636ic021", "inspect.Signature.__mro__.__getitem__",  [1],          "object"]
    - ["in1636ic022", "inspect.BoundArguments.__mro__.__getitem__", [0],      "BoundArguments"]
    - ["in1636ic023", "inspect.BoundArguments.__mro__.__getitem__", [1],      "object"]
    - ["in1636ic024", "inspect.Parameter.__dict__.__contains__",  ["name"],      true]
    - ["in1636ic025", "inspect.Parameter.__dict__.__contains__",  ["kind"],      true]
    - ["in1636ic026", "inspect.Signature.__dict__.__contains__",  ["parameters"], true]
    - ["in1636ic027", "inspect.Signature.__dict__.__contains__",  ["bind"],       true]
    - ["in1636ic028", "inspect.BoundArguments.__dict__.__contains__", ["arguments"], true]
    - ["in1636ic029", "inspect.BoundArguments.__dict__.__contains__", ["apply_defaults"], true]
    - ["in1636ic030", "inspect.Parameter.__bases__.__getitem__", [0],           "object"]

table inspect_extra1636.inspect_mro_checks:
  description: "inspect.getmro returns a tuple of the MRO for a class; for inspect.Parameter the MRO is (Parameter, object); also verify getmro length and class name for well-known types"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1636mr

  columns: [id, function, args, expected]
  rows:
    - ["in1636mr001", "inspect.Parameter.__dict__.__contains__",      ["__subclasshook__"],  false]
    - ["in1636mr002", "inspect.Signature.__dict__.__contains__",      ["__subclasshook__"],  false]
    - ["in1636mr003", "inspect.BoundArguments.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["in1636mr004", "inspect.Parameter.__dict__.__contains__",      ["__instancecheck__"], false]
    - ["in1636mr005", "inspect.Signature.__dict__.__contains__",      ["__instancecheck__"], false]
    - ["in1636mr006", "inspect.BoundArguments.__dict__.__contains__", ["__instancecheck__"], false]
    - ["in1636mr007", "inspect.Parameter.__dict__.__contains__",      ["__subclasscheck__"], false]
    - ["in1636mr008", "inspect.Signature.__dict__.__contains__",      ["__subclasscheck__"], false]
    - ["in1636mr009", "inspect.BoundArguments.__dict__.__contains__", ["__subclasscheck__"], false]
    - ["in1636mr010", "inspect.getmro.__class__.__name__.__eq__",  ["function"],             true]
    - ["in1636mr011", "inspect.Parameter.__mro__.__class__.__name__.__eq__",      ["tuple"], true]
    - ["in1636mr012", "inspect.Signature.__mro__.__class__.__name__.__eq__",      ["tuple"], true]
    - ["in1636mr013", "inspect.BoundArguments.__mro__.__class__.__name__.__eq__", ["tuple"], true]
    - ["in1636mr014", "inspect.Parameter.__mro__.__len__",      [],                          2]
    - ["in1636mr015", "inspect.Signature.__mro__.__len__",      [],                          2]
    - ["in1636mr016", "inspect.BoundArguments.__mro__.__len__", [],                          2]
    - ["in1636mr017", "inspect.Parameter.__mro__.__getitem__",      [0],          "Parameter"]
    - ["in1636mr018", "inspect.Parameter.__mro__.__getitem__",      [1],          "object"]
    - ["in1636mr019", "inspect.Signature.__mro__.__getitem__",      [0],          "Signature"]
    - ["in1636mr020", "inspect.Signature.__mro__.__getitem__",      [1],          "object"]
    - ["in1636mr021", "inspect.BoundArguments.__mro__.__getitem__", [0],          "BoundArguments"]
    - ["in1636mr022", "inspect.BoundArguments.__mro__.__getitem__", [1],          "object"]
    - ["in1636mr023", "inspect.Parameter.__bases__.__class__.__name__.__eq__",      ["tuple"], true]
    - ["in1636mr024", "inspect.Signature.__bases__.__class__.__name__.__eq__",      ["tuple"], true]
    - ["in1636mr025", "inspect.BoundArguments.__bases__.__class__.__name__.__eq__", ["tuple"], true]
    - ["in1636mr026", "inspect.Parameter.__class__.__name__.__eq__",      ["type"], true]
    - ["in1636mr027", "inspect.Signature.__class__.__name__.__eq__",      ["type"], true]
    - ["in1636mr028", "inspect.BoundArguments.__class__.__name__.__eq__", ["type"], true]
    - ["in1636mr029", "inspect.Parameter.__name__.__eq__",      ["Parameter"],      true]
    - ["in1636mr030", "inspect.BoundArguments.__name__.__eq__", ["BoundArguments"], true]
