spec: theseus_netrc_cr
version: ">=3.9"
backend: python_cleanroom(theseus_netrc_cr)
blocks: netrc

docs: https://docs.python.org/3/library/netrc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/netrc.html"
  notes:
    - "Clean-room netrc file parser. Do NOT import netrc."
    - "netrc(file=None): parse netrc format from file or string."
    - "netrc.authenticators(host): return (login, account, password) tuple for host."
    - "netrc.hosts: dict mapping machine name to (login, account, password)."
    - "netrc format: 'machine <host> login <user> password <pass>'."
    - "parse_netrc(text): parse netrc format text string, return dict of host → (login, account, password)."
    - "netrc_parse_host(): parse 'machine example.com login user password secret'; hosts['example.com'][0] == 'user'."
    - "netrc_parse_password(): hosts['example.com'][2] == 'secret'."
    - "netrc_parse_two_hosts(): parse two machine entries; len(hosts) == 2."
    - "Export: parse_netrc."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_netrc_cr.parse_host:
  description: "parse host login from netrc text"
  category: parse
  kind: python_call_eq
  function: netrc_parse_host
  args: []
  expected: "user"

invariant theseus_netrc_cr.parse_password:
  description: "parse host password from netrc text"
  category: parse
  kind: python_call_eq
  function: netrc_parse_password
  args: []
  expected: "secret"

invariant theseus_netrc_cr.parse_two_hosts:
  description: "parse two machine entries; len(hosts) == 2"
  category: parse
  kind: python_call_eq
  function: netrc_parse_two_hosts
  args: []
  expected: 2
