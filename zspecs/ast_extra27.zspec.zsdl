spec: ast_extra27
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "ast_extra26.zspec.zsdl — covers parse/dump/literal_eval __module__.__len__(); NodeVisitor/__init__.__name__; NodeTransformer/__init__.__name__; NodeVisitor.visit/__name__/__qualname__; NodeVisitor/NodeTransformer generic_visit/__name__/__qualname__"
    - "ast_extra25.zspec.zsdl — covers Expression/Interactive __qualname__/__module__; abstract category class __qualname__ and __bases__[0].__name__ (table)"
    - "ast_extra24.zspec.zsdl — covers parse/dump/literal_eval/fix_missing_locations/walk/unparse __module__; AST/Module/NodeVisitor/NodeTransformer __module__; NodeVisitor/NodeTransformer __bases__[0].__name__"
    - "ast_extra22.zspec.zsdl — covers NodeVisitor.visit/__qualname__.__eq__ and NodeTransformer.generic_visit/__qualname__.__eq__; qualname __len__() for parse/dump/literal_eval and various methods"
  notes:
    - "This spec extends ast_extra26.zspec.zsdl."
    - "Prior specs covered: ast.__name__/__package__, parse/dump/literal_eval/__name__/__module__/__qualname__, NodeVisitor/NodeTransformer __name__/__module__/__qualname__/__bases__[0].__name__, AST/__name__/__module__/__bases__[0].__name__, NodeVisitor/NodeTransformer __init__.__name__, NodeVisitor.visit/__name__/__qualname__, NodeVisitor/NodeTransformer generic_visit/__name__/__qualname__, module length checks (all 3 = 'ast')."
    - "This spec covers: ast.parse.__module__.__len__(), ast.dump.__module__.__len__(), ast.literal_eval.__module__.__len__() (all == 3); ast.NodeVisitor.__module__.__len__(), ast.NodeTransformer.__module__.__len__() (all == 3); ast.parse.__name__.__len__(), ast.dump.__name__.__len__(), ast.literal_eval.__name__.__len__(); ast.NodeVisitor.__name__.__len__(), ast.NodeTransformer.__name__.__len__(); ast.NodeVisitor.visit.__name__.__len__(); ast.NodeVisitor.generic_visit.__name__.__len__()."
    - "ast.parse.__module__.__len__() == 3 — 'ast' has 3 characters; ast_extra26 covers this in a table, distinct standalone invariant in ast_extra27 namespace."
    - "ast.dump.__module__.__len__() == 3 — same; ast_extra26 covers this in a table, distinct standalone invariant in ast_extra27 namespace."
    - "ast.literal_eval.__module__.__len__() == 3 — same; ast_extra26 covers this in a table, distinct standalone invariant in ast_extra27 namespace."
    - "ast.NodeVisitor.__module__.__len__() == 3 — 'ast' has 3 characters; no prior ast spec covers this as a standalone __eq__ invariant."
    - "ast.NodeTransformer.__module__.__len__() == 3 — same; no prior ast spec covers this as a standalone __eq__ invariant."
    - "ast.parse.__name__.__len__() == 5 — 'parse' has 5 characters; no prior ast spec covers __name__.__len__() for parse."
    - "ast.dump.__name__.__len__() == 4 — 'dump' has 4 characters; no prior ast spec covers __name__.__len__() for dump."
    - "ast.literal_eval.__name__.__len__() == 12 — 'literal_eval' has 12 characters; no prior ast spec covers __name__.__len__() for literal_eval."
    - "ast.NodeVisitor.__name__.__len__() == 11 — 'NodeVisitor' has 11 characters; no prior ast spec covers __name__.__len__() for NodeVisitor."
    - "ast.NodeTransformer.__name__.__len__() == 15 — 'NodeTransformer' has 15 characters; no prior ast spec covers __name__.__len__() for NodeTransformer."
    - "ast.NodeVisitor.visit.__name__.__len__() == 5 — 'visit' has 5 characters; no prior ast spec covers this as a standalone __eq__ invariant."
    - "ast.NodeVisitor.generic_visit.__name__.__len__() == 13 — 'generic_visit' has 13 characters; no prior ast spec covers this as a standalone __eq__ invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# parse/dump/literal_eval __module__.__len__() — standalone invariants
# (ast_extra27 namespace)
#
# 'ast' has 3 characters. ast_extra26 covers these in a table.
# These are distinct standalone invariants in the ast_extra27 namespace.
# ---------------------------------------------------------------------------

invariant ast_extra27.parse.module_len:
  description: "ast.parse.__module__.__len__() == 3 — module name 'ast' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: parse.__module__.__len__
  args: []
  expected: 3

invariant ast_extra27.dump.module_len:
  description: "ast.dump.__module__.__len__() == 3 — module name 'ast' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: dump.__module__.__len__
  args: []
  expected: 3

invariant ast_extra27.literal_eval.module_len:
  description: "ast.literal_eval.__module__.__len__() == 3 — module name 'ast' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: literal_eval.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# NodeVisitor/NodeTransformer __module__.__len__() — standalone invariants
# (ast_extra27 namespace)
#
# 'ast' has 3 characters. ast_extra24 covers __module__.__eq__ for these
# classes. No prior ast spec covers __module__.__len__() for NodeVisitor or
# NodeTransformer as a standalone __eq__ invariant.
# ---------------------------------------------------------------------------

invariant ast_extra27.NodeVisitor.module_len:
  description: "ast.NodeVisitor.__module__.__len__() == 3 — module name 'ast' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: NodeVisitor.__module__.__len__
  args: []
  expected: 3

invariant ast_extra27.NodeTransformer.module_len:
  description: "ast.NodeTransformer.__module__.__len__() == 3 — module name 'ast' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: NodeTransformer.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# parse/dump/literal_eval __name__.__len__() — standalone invariants
# (ast_extra27 namespace)
#
# parse == 'parse' (5), dump == 'dump' (4), literal_eval == 'literal_eval' (12).
# No prior ast spec covers __name__.__len__() for any of these functions.
# ---------------------------------------------------------------------------

invariant ast_extra27.parse.name_len:
  description: "ast.parse.__name__.__len__() == 5 — 'parse' has 5 characters"
  category: string_lengths
  kind: python_call_eq
  function: parse.__name__.__len__
  args: []
  expected: 5

invariant ast_extra27.dump.name_len:
  description: "ast.dump.__name__.__len__() == 4 — 'dump' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: dump.__name__.__len__
  args: []
  expected: 4

invariant ast_extra27.literal_eval.name_len:
  description: "ast.literal_eval.__name__.__len__() == 12 — 'literal_eval' has 12 characters"
  category: string_lengths
  kind: python_call_eq
  function: literal_eval.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# NodeVisitor/NodeTransformer __name__.__len__() — standalone invariants
# (ast_extra27 namespace)
#
# NodeVisitor == 'NodeVisitor' (11), NodeTransformer == 'NodeTransformer' (15).
# No prior ast spec covers __name__.__len__() for either class.
# ---------------------------------------------------------------------------

invariant ast_extra27.NodeVisitor.name_len:
  description: "ast.NodeVisitor.__name__.__len__() == 11 — 'NodeVisitor' has 11 characters"
  category: string_lengths
  kind: python_call_eq
  function: NodeVisitor.__name__.__len__
  args: []
  expected: 11

invariant ast_extra27.NodeTransformer.name_len:
  description: "ast.NodeTransformer.__name__.__len__() == 15 — 'NodeTransformer' has 15 characters"
  category: string_lengths
  kind: python_call_eq
  function: NodeTransformer.__name__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# NodeVisitor.visit and NodeVisitor.generic_visit __name__.__len__()
# — standalone invariants
# (ast_extra27 namespace)
#
# visit == 'visit' (5), generic_visit == 'generic_visit' (13).
# No prior ast spec covers __name__.__len__() for either of these methods.
# ---------------------------------------------------------------------------

invariant ast_extra27.NodeVisitor_visit.name_len:
  description: "ast.NodeVisitor.visit.__name__.__len__() == 5 — 'visit' has 5 characters"
  category: string_lengths
  kind: python_call_eq
  function: NodeVisitor.visit.__name__.__len__
  args: []
  expected: 5

invariant ast_extra27.NodeVisitor_generic_visit.name_len:
  description: "ast.NodeVisitor.generic_visit.__name__.__len__() == 13 — 'generic_visit' has 13 characters"
  category: string_lengths
  kind: python_call_eq
  function: NodeVisitor.generic_visit.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# __module__.__len__() table — functions and classes
# (ast_extra27 namespace)
#
# Groups all five __module__.__len__() checks into a single table.
# All belong to the 'ast' module (length 3).
# ---------------------------------------------------------------------------

table ast_extra27.module_lengths:
  description: "__module__.__len__() for ast functions and classes — all equal 3 ('ast')"
  kind: python_call_eq
  category: string_lengths
  id_prefix: modlen

  columns: [id, function, args, expected]
  rows:
    - [parse,           parse.__module__.__len__,           [], 3]
    - [dump,            dump.__module__.__len__,            [], 3]
    - [literal_eval,    literal_eval.__module__.__len__,    [], 3]
    - [NodeVisitor,     NodeVisitor.__module__.__len__,     [], 3]
    - [NodeTransformer, NodeTransformer.__module__.__len__, [], 3]

# ---------------------------------------------------------------------------
# __name__.__len__() table — functions and classes
# (ast_extra27 namespace)
#
# Groups all seven __name__.__len__() checks into a single table.
# ---------------------------------------------------------------------------

table ast_extra27.name_lengths:
  description: "__name__.__len__() for ast functions, classes, and methods"
  kind: python_call_eq
  category: string_lengths
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [parse,                parse.__name__.__len__,                       [], 5]
    - [dump,                 dump.__name__.__len__,                        [], 4]
    - [literal_eval,         literal_eval.__name__.__len__,                [], 12]
    - [NodeVisitor,          NodeVisitor.__name__.__len__,                 [], 11]
    - [NodeTransformer,      NodeTransformer.__name__.__len__,             [], 15]
    - [visit,                NodeVisitor.visit.__name__.__len__,           [], 5]
    - [generic_visit,        NodeVisitor.generic_visit.__name__.__len__,   [], 13]
