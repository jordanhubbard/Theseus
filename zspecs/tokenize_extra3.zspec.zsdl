spec: tokenize_extra3
version: ">=3.9"
backend: python_module(tokenize)

docs: https://docs.python.org/3/library/tokenize.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tokenize.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tokenize.py"
    - "tokenize.zspec.zsdl — covers core token type constants (NAME/NUMBER/STRING/NEWLINE/INDENT/DEDENT/OP/COMMENT/ENCODING/NL all as int class checks), and function __name__ checks for tokenize/generate_tokens/detect_encoding"
    - "tokenize_extra.zspec.zsdl — covers TokenInfo.__name__, TokenInfo.__module__, TokenError.__name__, TokenError.__bases__[0].__name__, function __name__ for tokenize/generate_tokens/detect_encoding/open/untokenize, and token constant int type checks for ENCODING/COMMENT/NAME/NUMBER/STRING/NEWLINE/OP/ENDMARKER"
    - "tokenize_extra2.zspec.zsdl — covers TokenInfo.__name__, TokenInfo._fields.__len__() == 5, TokenInfo._fields field name membership checks, TokenInfo._fields positional access at [0] and [1], function __name__ for tokenize/generate_tokens/detect_encoding/open, COMMENT is_int"
  notes:
    - "This spec covers __module__ attributes for tokenize functions and classes — not previously covered."
    - "tokenize.tokenize.__module__ == 'tokenize' — the tokenize function is defined in the tokenize module."
    - "tokenize.generate_tokens.__module__ == 'tokenize' — generate_tokens is defined in the tokenize module."
    - "tokenize.untokenize.__module__ == 'tokenize' — untokenize is defined in the tokenize module."
    - "tokenize.detect_encoding.__module__ == 'tokenize' — detect_encoding is defined in the tokenize module."
    - "tokenize.TokenError.__module__ == 'tokenize' — TokenError is defined in the tokenize module."
    - "tokenize.TokenInfo.__module__ == 'tokenize' — TokenInfo is defined in the tokenize module."
    - "tokenize.TokenInfo.__name__ == 'TokenInfo' — also confirmed in tokenize_extra; included here per task spec."
    - "tokenize.TokenError.__name__ == 'TokenError' — also confirmed in tokenize_extra; included here per task spec."
    - "tokenize.TokenError.__bases__[0].__name__ == 'Exception' — also confirmed in tokenize_extra; included here per task spec."
    - "tokenize.TokenInfo.__bases__[0].__name__ == 'tuple' — TokenInfo is a named tuple backed by tuple."
    - "tokenize.COMMENT.__class__.__name__ == 'int' — covered in tokenize_extra2; also required here per task spec."
    - "tokenize.STRING.__class__.__name__ == 'int' — covered in tokenize.zspec.zsdl; also required here per task spec."
    - "tokenize.NUMBER.__class__.__name__ == 'int' — covered in tokenize.zspec.zsdl; also required here per task spec."
    - "tokenize.NAME.__class__.__name__ == 'int' — covered in tokenize.zspec.zsdl; also required here per task spec."
    - "tokenize.ENCODING.__class__.__name__ == 'int' — covered in tokenize.zspec.zsdl; also required here per task spec."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks for tokenize functions
# ---------------------------------------------------------------------------

table tokenize_extra3.function_modules:
  kind: python_call_eq
  category: module_attrs
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [tokenize,        tokenize.__module__.__eq__,        ["tokenize"], true]
    - [generate_tokens, generate_tokens.__module__.__eq__, ["tokenize"], true]
    - [untokenize,      untokenize.__module__.__eq__,      ["tokenize"], true]
    - [detect_encoding, detect_encoding.__module__.__eq__, ["tokenize"], true]

# ---------------------------------------------------------------------------
# TokenError — __name__, __module__, and base class
# ---------------------------------------------------------------------------

invariant tokenize_extra3.TokenError.name:
  description: "tokenize.TokenError.__name__ == 'TokenError'"
  category: token_error
  kind: python_call_eq
  function: TokenError.__name__.__eq__
  args: ["TokenError"]
  expected: true

invariant tokenize_extra3.TokenError.module:
  description: "tokenize.TokenError.__module__ == 'tokenize'"
  category: token_error
  kind: python_call_eq
  function: TokenError.__module__.__eq__
  args: ["tokenize"]
  expected: true

invariant tokenize_extra3.TokenError.base_is_Exception:
  description: "tokenize.TokenError.__bases__[0].__name__ == 'Exception'"
  category: hierarchy
  kind: python_call_eq
  function: TokenError.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# TokenInfo — __name__, __module__, and base class
# ---------------------------------------------------------------------------

invariant tokenize_extra3.TokenInfo.name:
  description: "tokenize.TokenInfo.__name__ == 'TokenInfo'"
  category: token_info
  kind: python_call_eq
  function: TokenInfo.__name__.__eq__
  args: ["TokenInfo"]
  expected: true

invariant tokenize_extra3.TokenInfo.module:
  description: "tokenize.TokenInfo.__module__ == 'tokenize'"
  category: token_info
  kind: python_call_eq
  function: TokenInfo.__module__.__eq__
  args: ["tokenize"]
  expected: true

invariant tokenize_extra3.TokenInfo.base_is_tuple:
  description: "tokenize.TokenInfo.__bases__[0].__name__ == 'tuple' — TokenInfo is a named tuple backed by tuple"
  category: hierarchy
  kind: python_call_eq
  function: TokenInfo.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# Token constant type checks — all are plain Python ints
# ---------------------------------------------------------------------------

table tokenize_extra3.token_constant_types:
  kind: python_call_eq
  category: constants
  id_prefix: toktype

  columns: [id, function, args, expected]
  rows:
    - [comment,  COMMENT.__class__.__name__.__eq__,  ["int"], true]
    - [string,   STRING.__class__.__name__.__eq__,   ["int"], true]
    - [number,   NUMBER.__class__.__name__.__eq__,   ["int"], true]
    - [name,     NAME.__class__.__name__.__eq__,     ["int"], true]
    - [encoding, ENCODING.__class__.__name__.__eq__, ["int"], true]

# ---------------------------------------------------------------------------
# untokenize — function name check (complementing the __module__ check above)
# ---------------------------------------------------------------------------

invariant tokenize_extra3.untokenize.name:
  description: "tokenize.untokenize.__name__ == 'untokenize'"
  category: function_names
  kind: python_call_eq
  function: untokenize.__name__.__eq__
  args: ["untokenize"]
  expected: true

# ---------------------------------------------------------------------------
# TokenInfo — is a subclass of tuple (class check via __bases__ length)
# ---------------------------------------------------------------------------

invariant tokenize_extra3.TokenInfo.bases_len:
  description: "len(tokenize.TokenInfo.__bases__) == 1 — TokenInfo has exactly one base class"
  category: token_info
  kind: python_call_eq
  function: TokenInfo.__bases__.__len__
  args: []
  expected: 1
