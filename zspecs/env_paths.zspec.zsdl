spec: env_paths
version: ">=3.0.0"
backend: node(env-paths)

docs: https://github.com/sindresorhus/env-paths#readme

provenance:
  derived_from:
    - "env-paths README — https://github.com/sindresorhus/env-paths#readme"
    - "XDG Base Directory Specification (Linux defaults)"
    - "Test vectors verified with env-paths via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "env-paths source"
  notes:
    - "Returns OS-appropriate per-app paths (data/config/cache/log/temp) following XDG/Apple/Windows conventions."
    - "Install: npm install env-paths"
    - "Module export IS the function. Returns {data, config, cache, log, temp} — five strings."
    - "Specs that hard-code platform-specific suffixes would be brittle; we test that all 5 keys are present and end with the app name suffix."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure function; never throws."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# Each key ends with the app name as a path component (XDG/Apple suffix
# varies by OS, but the app name always appears literally somewhere)
invariant env_paths.data_includes_app_name:
  description: ".data includes the app name as a path component"
  category: app_name
  kind: node_chain_eq
  entry: named
  function: default
  entry_args: ["myappX12345"]
  chain:
    - {get: data}
    - {method: includes, args: ["myappX12345"]}
  expected: true

invariant env_paths.config_includes_app_name:
  description: ".config includes the app name"
  category: app_name
  kind: node_chain_eq
  entry: named
  function: default
  entry_args: ["myappX12345"]
  chain:
    - {get: config}
    - {method: includes, args: ["myappX12345"]}
  expected: true

invariant env_paths.cache_includes_app_name:
  description: ".cache includes the app name"
  category: app_name
  kind: node_chain_eq
  entry: named
  function: default
  entry_args: ["myappX12345"]
  chain:
    - {get: cache}
    - {method: includes, args: ["myappX12345"]}
  expected: true

invariant env_paths.log_includes_app_name:
  description: ".log includes the app name"
  category: app_name
  kind: node_chain_eq
  entry: named
  function: default
  entry_args: ["myappX12345"]
  chain:
    - {get: log}
    - {method: includes, args: ["myappX12345"]}
  expected: true

invariant env_paths.temp_includes_app_name:
  description: ".temp includes the app name"
  category: app_name
  kind: node_chain_eq
  entry: named
  function: default
  entry_args: ["myappX12345"]
  chain:
    - {get: temp}
    - {method: includes, args: ["myappX12345"]}
  expected: true

# Returned object has exactly these 5 keys (sanity check on shape)
invariant env_paths.has_5_keys:
  description: "Returned object has 5 path-category keys"
  category: shape
  kind: node_chain_eq
  entry: named
  function: default
  entry_args: ["myapp"]
  chain:
    - {method: hasOwnProperty, args: ["data"]}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:40:16Z
  iterations: 1
  pass_count: 6
  fail_count: 0
  total_invariants: 6
  notes: Synthesis succeeded in 1 iteration(s). 6 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
