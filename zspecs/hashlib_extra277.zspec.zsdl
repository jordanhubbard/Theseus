spec: hashlib_extra277
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra276.zspec.zsdl — covers sha512/sha224 empty-input hexdigest test vectors and digest_size/block_size attributes."
    - "hashlib_extra275.zspec.zsdl — covers sha256/md5/sha1 empty-input hexdigest test vectors and digest_size/block_size attributes."
    - "hashlib_extra274.zspec.zsdl — covers BLAKE2 constructor identity and hmac.HMAC method identity."
    - "hashlib_extra273.zspec.zsdl — covers hmac module identity and HMAC class/function identity."
  notes:
    - "hashlib.sha3_256(b'').hexdigest() == 'a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a' — well-known SHA3-256 digest of the empty byte string (64 hex chars / 32 bytes). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha3_512(b'').hexdigest() == 'a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a615b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26' — well-known SHA3-512 digest of the empty byte string (128 hex chars / 64 bytes). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha3_256(b'').digest_size == 32 — SHA3-256 output is 256 bits / 32 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha3_256(b'').block_size == 136 — SHA3-256 uses a 1088-bit / 136-byte Keccak rate (capacity 512 bits). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha3_512(b'').digest_size == 64 — SHA3-512 output is 512 bits / 64 bytes. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha3_512(b'').block_size == 72 — SHA3-512 uses a 576-bit / 72-byte Keccak rate (capacity 1024 bits). Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha3_256(b'').name == 'sha3_256' — .name attribute returns the algorithm name string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "hashlib.sha3_512(b'').name == 'sha3_512' — .name attribute returns the algorithm name string. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "'sha3_256' in hashlib.algorithms_guaranteed — SHA3-256 is in the guaranteed algorithm set on Python 3.9+. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Empty-input hexdigest values for SHA3-256 and SHA3-512
# SHA3 (Keccak sponge construction) produces different digests than SHA-2
# for the same input, even with matching output lengths.
# SHA3-256 produces 64 hex chars (32 bytes); SHA3-512 produces 128 hex chars
# (64 bytes). These are canonical NIST FIPS 202 test vectors for empty input.
# ---------------------------------------------------------------------------

table hashlib_extra277.sha3_256_sha3_512_empty_hexdigest:
  description: "hashlib SHA3-256 and SHA3-512 empty-input hexdigest test vectors — sha3_256(b'')/sha3_512(b'') produce well-known fixed hex strings per NIST FIPS 202; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: emptydig277

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_hex,  sha3_256_hexdigest_of_empty.__eq__,  ["a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a"],                                                                    true, "hashlib.sha3_256(b'').hexdigest() == known SHA3-256 of empty bytes (64 hex chars / 32 bytes)"]
    - [sha3_512_hex,  sha3_512_hexdigest_of_empty.__eq__,  ["a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a615b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26"], true, "hashlib.sha3_512(b'').hexdigest() == known SHA3-512 of empty bytes (128 hex chars / 64 bytes)"]
    - [sha3_256_name, sha3_256_name_attr.__eq__,           ["sha3_256"],                                                                                                                            true, "hashlib.sha3_256(b'').name == 'sha3_256' — algorithm name attribute"]
    - [sha3_512_name, sha3_512_name_attr.__eq__,           ["sha3_512"],                                                                                                                            true, "hashlib.sha3_512(b'').name == 'sha3_512' — algorithm name attribute"]

# ---------------------------------------------------------------------------
# digest_size and block_size for SHA3-256 and SHA3-512
# SHA3 uses a Keccak sponge with rate r and capacity c = 1600 - r bits.
# SHA3-256: rate=1088 bits → block_size=136 bytes; capacity=512 bits.
# SHA3-512: rate=576 bits → block_size=72 bytes; capacity=1024 bits.
# These block sizes differ markedly from SHA-2 (64/128 bytes) because the
# Keccak sponge rate depends on the security level, not output length alone.
# ---------------------------------------------------------------------------

table hashlib_extra277.sha3_256_sha3_512_sizes:
  description: "hashlib SHA3-256/SHA3-512 digest_size and block_size — sha3_256: 32/136; sha3_512: 64/72; Keccak sponge rates differ from SHA-2; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: sizes277

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_dsize,  sha3_256_digest_size.__eq__,  [32],  true, "hashlib.sha3_256(b'').digest_size == 32 — SHA3-256 output is 32 bytes"]
    - [sha3_512_dsize,  sha3_512_digest_size.__eq__,  [64],  true, "hashlib.sha3_512(b'').digest_size == 64 — SHA3-512 output is 64 bytes"]
    - [sha3_256_bsize,  sha3_256_block_size.__eq__,   [136], true, "hashlib.sha3_256(b'').block_size == 136 — Keccak rate 1088 bits / 136 bytes"]
    - [sha3_512_bsize,  sha3_512_block_size.__eq__,   [72],  true, "hashlib.sha3_512(b'').block_size == 72 — Keccak rate 576 bits / 72 bytes"]

# ---------------------------------------------------------------------------
# Standalone invariants — SHA3-256/SHA3-512 test vectors and size attributes
# ---------------------------------------------------------------------------

invariant hashlib_extra277.sha3_256_empty_hexdigest_eq:
  description: "hashlib.sha3_256(b'').hexdigest() == 'a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a' — canonical NIST FIPS 202 SHA3-256 test vector for the empty byte string (64 hex chars / 32 bytes); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: sha3_256_hexdigest_of_empty.__eq__
  args: ["a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a"]
  expected: true

invariant hashlib_extra277.sha3_512_empty_hexdigest_eq:
  description: "hashlib.sha3_512(b'').hexdigest() == 'a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a615b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26' — canonical NIST FIPS 202 SHA3-512 test vector for the empty byte string (128 hex chars / 64 bytes); verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: behavior
  kind: python_call_eq
  function: sha3_512_hexdigest_of_empty.__eq__
  args: ["a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a615b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26"]
  expected: true

invariant hashlib_extra277.sha3_256_digest_size_eq:
  description: "hashlib.sha3_256(b'').digest_size == 32 — SHA3-256 produces a 256-bit / 32-byte digest; same output length as SHA-256 but via Keccak sponge construction; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha3_256_digest_size.__eq__
  args: [32]
  expected: true

invariant hashlib_extra277.sha3_512_digest_size_eq:
  description: "hashlib.sha3_512(b'').digest_size == 64 — SHA3-512 produces a 512-bit / 64-byte digest; same output length as SHA-512 but via Keccak sponge construction; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha3_512_digest_size.__eq__
  args: [64]
  expected: true

invariant hashlib_extra277.sha3_256_block_size_eq:
  description: "hashlib.sha3_256(b'').block_size == 136 — SHA3-256 Keccak sponge rate is 1088 bits / 136 bytes (capacity 512 bits); notably larger than SHA-256's 64-byte block; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha3_256_block_size.__eq__
  args: [136]
  expected: true

invariant hashlib_extra277.sha3_512_block_size_eq:
  description: "hashlib.sha3_512(b'').block_size == 72 — SHA3-512 Keccak sponge rate is 576 bits / 72 bytes (capacity 1024 bits); smaller than SHA-512's 128-byte block because higher security requires lower rate; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha3_512_block_size.__eq__
  args: [72]
  expected: true

invariant hashlib_extra277.sha3_256_name_eq:
  description: "hashlib.sha3_256(b'').name == 'sha3_256' — the .name attribute of a SHA3-256 hash object is the lowercase algorithm name string with underscore; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha3_256_name_attr.__eq__
  args: ["sha3_256"]
  expected: true

invariant hashlib_extra277.sha3_512_name_eq:
  description: "hashlib.sha3_512(b'').name == 'sha3_512' — the .name attribute of a SHA3-512 hash object is the lowercase algorithm name string with underscore; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  category: identity
  kind: python_call_eq
  function: sha3_512_name_attr.__eq__
  args: ["sha3_512"]
  expected: true
