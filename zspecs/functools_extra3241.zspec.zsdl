spec: ft3241
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 663 (ft3241): __rtruediv__, __rfloordiv__, __rmod__ dict-presence checks for functools types."
    - "Theme: __rtruediv__, __rfloordiv__, __rmod__ dict-presence (reflected division/modulo)."
    - "Reflected operators are called when the left operand doesn't support the operation."
    - "All values False — these types have no reflected division/modulo protocol."
    - "None of the four functools types define __rtruediv__, __rfloordiv__, or __rmod__ in their own __dict__."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "type(functools.lru_cache(lambda: None)) accesses the internal _lru_cache_wrapper C type at runtime."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3241.rtruediv:
  description: "functools types __rtruediv__ dict-presence checks; wave 663"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3241
  columns: [id, function, args, expected]
  rows:
    - ["ft3241001", operator.contains, [functools.partial.__dict__,                              "__rtruediv__"], false]
    - ["ft3241002", operator.contains, [functools.partialmethod.__dict__,                        "__rtruediv__"], false]
    - ["ft3241003", operator.contains, [functools.cached_property.__dict__,                      "__rtruediv__"], false]
    - ["ft3241004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__,        "__rtruediv__"], false]

