spec: varint
version: ">=5.0.0"
backend: node(varint)

docs: https://www.npmjs.com/package/varint

provenance:
  derived_from:
    - "varint README — https://www.npmjs.com/package/varint"
    - "Test vectors verified with varint via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "varint source"
  notes:
    - "varint is an npm package. Install: npm install varint"
    - "varint.encode(n) encodes an integer as a variable-length byte array."
    - "varint.decode(bytes) decodes a variable-length byte array to an integer."
    - "varint.encodingLength(n) returns the number of bytes needed to encode n."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns byte array or integer."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table varint.encode:
  kind: node_module_call_eq
  function: encode
  category: encode
  id_prefix: varenc

  columns: [id, args, expected]
  rows:
    - [one,     [1],   [1]]
    - [max_7bit,[127], [127]]
    - [multi,   [300], [172, 2]]

table varint.decode:
  kind: node_module_call_eq
  function: decode
  category: decode
  id_prefix: vardec

  columns: [id, args, expected]
  rows:
    - [one,   [[1]],       1]
    - [multi, [[172, 2]],  300]

table varint.encodingLength:
  kind: node_module_call_eq
  function: encodingLength
  category: length
  id_prefix: varlen

  columns: [id, args, expected]
  rows:
    - [one_byte,  [1],   1]
    - [two_bytes, [300], 2]
