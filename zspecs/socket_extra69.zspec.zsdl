spec: socket_extra69
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra68.zspec.zsdl — covers socket.connect/bind/sendall/recv __class__/__name__=='method_descriptor' / __qualname__ eq and len (table) / socket.__doc__/__class__/__name__=='str' / socket.__doc__.__contains__('socket') (table + invariants)."
    - "socket_extra67.zspec.zsdl — covers accept/__kwdefaults__/__class__/__name__=='NoneType' / gethostname/gethostbyname/__class__/__name__=='builtin_function_or_method' / getfqdn/__class__/__name__=='function' / getfqdn/__qualname__/__defaults__ (table + invariants)."
    - "socket_extra66.zspec.zsdl — covers socket.socket/__name__/__module__/__qualname__=='socket' / socket.socket/__bases__[0].__name__=='object' / accept/__defaults__/__class__/__name__=='NoneType' / makefile/__defaults__ (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra68; it does NOT duplicate invariants present in those files."
    - "Wave 236 theme: socket module __spec__ identity + socket.socket class __dict__ contents."
    - "In python_module(socket), 'socket' in the module namespace refers to the socket.socket class. Module-level attributes like __name__, __spec__, __loader__, __file__ are the MODULE's own attributes, not the socket.socket class's attributes."
    - "socket module __name__.__eq__('socket') — the module's own __name__ attribute. No prior socket spec checks the module-level __name__ attribute directly (socket.zspec checks socket.__name__ == 'socket' but that accesses the socket.socket class __name__, not the module). In python_module(socket), __name__ at module scope is 'socket' (the module name). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.name.__eq__('socket') — ModuleSpec.name for the socket module. No prior socket spec checks __spec__.name in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.__class__.__name__.__eq__('ModuleSpec') — the type of the socket module's spec. No prior socket spec checks __spec__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') — socket is a pure-Python module (Lib/socket.py) wrapping the _socket C extension; it is loaded by SourceFileLoader. No prior socket spec checks __loader__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__file__.__contains__('socket') — the file path to socket.py contains 'socket'. No prior socket spec checks __file__.__contains__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__file__.__contains__('.py') — socket.py is a .py file. No prior socket spec checks __file__.__contains__('.py'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') — the __dict__ of the socket.socket class is a mappingproxy. No prior socket spec checks socket.__dict__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('accept') — accept is defined in socket.py as a Python method on socket.socket (not inherited from _socket.socket); it is present in socket.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('makefile') — makefile is a Python method defined in socket.py on socket.socket; present in socket.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('setblocking') — setblocking is a Python method defined in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('settimeout') — settimeout is a Python method defined in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket module __spec__ and loader identity
#
# Wave 236 theme: module spec, spec class name, and loader class name.
#
# No prior socket spec checks __spec__.name, __spec__.__class__.__name__, or
# __loader__.__class__.__name__ in any form. These establish the module identity
# of the socket module at the spec level.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra69.socket_module_spec:
  description: "socket module __name__.__eq__('socket')==True / __spec__.name.__eq__('socket')==True / __spec__.__class__.__name__.__eq__('ModuleSpec')==True / __loader__.__class__.__name__.__eq__('SourceFileLoader')==True — module __name__/spec.name/spec class/loader class identity for the socket module; no prior socket spec checks __spec__.name/__spec__.__class__.__name__/__loader__.__class__.__name__; first module spec identity anchor for socket module"
  kind: python_call_eq
  category: module_spec
  id_prefix: socketspec69

  columns: [id, function, args, expected]
  rows:
    - [module_name_eq_socket,         __name__.__eq__,                      ["socket"],           true]
    - [spec_name_eq_socket,           __spec__.name.__eq__,                 ["socket"],           true]
    - [spec_class_name_ModuleSpec,    __spec__.__class__.__name__.__eq__,   ["ModuleSpec"],       true]
    - [loader_class_SourceFileLoader, __loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true]

# ---------------------------------------------------------------------------
# socket.__file__ content checks
#
# Wave 236 theme: module file path content.
#
# socket is a pure-Python module loaded from Lib/socket.py. Its __file__
# attribute is the path to socket.py and contains 'socket' and '.py'.
# No prior socket spec checks __file__.__contains__ in any form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra69.socket_file_contains:
  description: "socket.__file__.__contains__('socket')==True / socket.__file__.__contains__('.py')==True — socket is loaded from Lib/socket.py; __file__ contains 'socket' and '.py'; no prior socket spec checks __file__.__contains__; first file path content anchor for socket module"
  kind: python_call_eq
  category: module_spec
  id_prefix: socketspec69

  columns: [id, function, args, expected]
  rows:
    - [file_contains_socket, __file__.__contains__, ["socket"], true]
    - [file_contains_dot_py, __file__.__contains__, [".py"],    true]

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__class__.__name__ == 'mappingproxy'
#
# Wave 236 theme: socket.socket class __dict__ type identity.
#
# socket.socket is a Python class defined in Lib/socket.py. Its __dict__
# is a mappingproxy. No prior socket spec checks socket.__dict__.__class__.__name__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra69.socket_class_dict_mappingproxy:
  description: "socket.socket.__dict__.__class__.__name__.__eq__('mappingproxy') == True — socket.socket is a Python class in socket.py; its __dict__ is a mappingproxy; no prior socket spec checks socket.__dict__.__class__.__name__; first mappingproxy type anchor for socket.socket.__dict__"
  category: class_dict
  kind: python_call_eq
  function: socket.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__ checks for Python-defined methods
#
# Wave 236 theme: socket.socket defines Python methods in its __dict__.
#
# socket.socket (in Lib/socket.py) defines accept, makefile, setblocking,
# and settimeout as pure-Python methods. These methods are NOT inherited from
# _socket.socket; they are defined directly on socket.socket and are present
# in socket.__dict__. No prior socket spec checks socket.__dict__.__contains__
# for any of these methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra69.socket_class_dict_contains:
  description: "socket.socket.__dict__.__contains__('accept')==True / __contains__('makefile')==True / __contains__('setblocking')==True / __contains__('settimeout')==True — accept/makefile/setblocking/settimeout are Python methods defined in socket.py on socket.socket (not inherited from _socket.socket); they are present in socket.__dict__; no prior socket spec checks socket.__dict__.__contains__ for any method; first socket.socket.__dict__ method content anchor"
  kind: python_call_eq
  category: class_dict
  id_prefix: socketspec69

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_has_accept,      socket.__dict__.__contains__, ["accept"],      true]
    - [socket_dict_has_makefile,    socket.__dict__.__contains__, ["makefile"],    true]
    - [socket_dict_has_setblocking, socket.__dict__.__contains__, ["setblocking"], true]
    - [socket_dict_has_settimeout,  socket.__dict__.__contains__, ["settimeout"],  true]

# ---------------------------------------------------------------------------
# socket module __name__.__eq__('socket') — standalone
#
# The module-level __name__ attribute of the socket module equals 'socket'.
# In python_module(socket), __name__ at module scope is the module name.
# No prior socket spec checks the module-level __name__ in this form.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra69.socket_module_name_socket:
  description: "socket module __name__.__eq__('socket') == True — the module's own __name__ attribute is 'socket'; no prior socket spec checks the module-level __name__ attribute directly; first module __name__ equality standalone for socket module"
  category: module_spec
  kind: python_call_eq
  function: __name__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# socket is a pure-Python module loaded from Lib/socket.py by SourceFileLoader.
# No prior socket spec checks __loader__.__class__.__name__. First loader class
# standalone for socket module.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra69.socket_module_loader_SourceFileLoader:
  description: "socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — socket is a pure-Python module (Lib/socket.py) loaded by SourceFileLoader; no prior socket spec checks __loader__.__class__.__name__; first loader class standalone for socket module"
  category: module_spec
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('accept') — standalone
#
# socket.socket.accept is a Python method defined in socket.py. It is present
# in socket.__dict__. No prior socket spec checks socket.__dict__.__contains__.
# First socket.socket.__dict__ content standalone for 'accept'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra69.socket_class_dict_has_accept:
  description: "socket.socket.__dict__.__contains__('accept') == True — accept is a Python method defined in socket.py on socket.socket; it is in socket.__dict__; no prior socket spec checks socket.__dict__.__contains__; first socket.socket.__dict__ content standalone for 'accept'"
  category: class_dict
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["accept"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__dict__.__contains__('makefile') — standalone
#
# socket.socket.makefile is a Python method defined in socket.py. It is
# present in socket.__dict__. No prior socket spec checks
# socket.__dict__.__contains__('makefile').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra69.socket_class_dict_has_makefile:
  description: "socket.socket.__dict__.__contains__('makefile') == True — makefile is a Python method defined in socket.py on socket.socket; it is in socket.__dict__; no prior socket spec checks socket.__dict__.__contains__('makefile'); first makefile content standalone for socket.socket.__dict__"
  category: class_dict
  kind: python_call_eq
  function: socket.__dict__.__contains__
  args: ["makefile"]
  expected: true
