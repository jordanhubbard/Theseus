spec: config_rust
version: ">=3.9"
backend: rust_module(config_rust)

docs: https://github.com/rochacbruno/dynaconf

provenance:
  derived_from:
    - "https://docs.python.org/3/library/configparser.html — configparser documentation"
  not_derived_from:
    - "configparser source: Lib/configparser.py"
  notes:
    - "configparser provides configuration file parsing."
    - "import configparser; c = configparser.ConfigParser()."
    - "c.read_string('[section]\\nkey=value'); c['section']['key'] == 'value'."
    - "c.sections() == ['section']."
    - "c.has_section('section') == True."
    - "c.has_section('missing') == False."
    - "Expose cp_get_value(ini, section, key) -> str: ConfigParser().read_string(ini)['section']['key']."
    - "Expose cp_has_section(ini, section) -> bool: parser.has_section(section)."
    - "Expose cp_sections_count(ini) -> int: len(parser.sections())."
    - "All test vectors verified against Python 3.12."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# cp_get_value — get value from INI string
table config_rust.configparser.get_value:
  kind: python_call_eq
  category: get_value
  id_prefix: cp_gv
  function: cp_get_value

  columns: [id, args, expected]
  rows:
    - [simple, ["[s]\nkey=value", "s", "key"],  "value"]
    - [number, ["[s]\nnum=42",    "s", "num"],   "42"]

# cp_has_section — section presence check
table config_rust.configparser.has_section:
  kind: python_call_eq
  category: has_section
  id_prefix: cp_hs
  function: cp_has_section

  columns: [id, args, expected]
  rows:
    - [present, ["[s]\nkey=v", "s"],       true]
    - [missing, ["[s]\nkey=v", "missing"], false]

# cp_sections_count — count sections
invariant config_rust.configparser.sections_count:
  description: "one section in INI"
  category: sections
  kind: python_call_eq
  function: cp_sections_count
  args: ["[s]\nkey=v"]
  expected: 1

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T01:46:17Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
