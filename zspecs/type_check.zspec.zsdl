spec: type_check
version: ">=0.4.0"
backend: node(type-check)

docs: https://www.npmjs.com/package/type-check

provenance:
  derived_from:
    - "type-check README — https://www.npmjs.com/package/type-check"
    - "Test vectors verified with type-check via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "type-check source"
  notes:
    - "type-check is an npm package. Install: npm install type-check"
    - "Checks whether a value matches a type specification string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table type_check.typeCheck:
  kind: node_module_call_eq
  function: typeCheck
  category: type
  id_prefix: tcheck

  columns: [id, args, expected]
  rows:
    - [num_match,    ["Number", 42],       true]
    - [str_match,    ["String", "hello"],  true]
    - [num_fail,     ["Number", "hello"],  false]
    - [bool_match,   ["Boolean", true],    true]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:58:04Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
