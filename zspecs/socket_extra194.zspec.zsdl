spec: socket_extra194
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "socket.__name__ == 'socket' and socket.__package__ == '' — socket is a top-level stdlib module with no package prefix."
    - "socket.__spec__.name == 'socket' — the ModuleSpec name attribute matches the module's __name__."
    - "socket.socket.__name__.__len__() == 6 ('socket' has 6 characters) — the socket class has the same name as the module."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily' (len=13) — AF_INET is an instance of the AddressFamily IntEnum."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' (len=10) — SOCK_STREAM is an instance of the SocketKind IntEnum."
    - "socket.gethostname.__name__.__len__() == 11 ('gethostname' has 11 characters); socket.getaddrinfo.__name__.__len__() == 11 ('getaddrinfo' has 11 characters)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket module identity — __name__, __package__, __spec__.name
# ---------------------------------------------------------------------------

table socketmodule194.module_identity:
  kind: python_call_eq
  category: module_identity
  id_prefix: socketmodule194

  columns: [id, function, args, expected, description]
  rows:
    - [module_name,    __name__.__eq__,      ["socket"], true, "socket.__name__ == 'socket' (top-level stdlib module name)"]
    - [module_package, __package__.__eq__,   [""],       true, "socket.__package__ == '' (empty string — socket is a top-level module, no package prefix)"]
    - [spec_name,      __spec__.name.__eq__,  ["socket"], true, "socket.__spec__.name == 'socket' (ModuleSpec.name matches the module's __name__)"]

# ---------------------------------------------------------------------------
# socket class and function name length checks
# AF_INET.__class__.__name__ and SOCK_STREAM.__class__.__name__ contain '[' in
# the dotted chain (subscript), so those function values are double-quoted.
# ---------------------------------------------------------------------------

table socketmodule194.name_lengths:
  kind: python_call_eq
  category: name_lengths
  id_prefix: socketmodule194

  columns: [id, function, args, expected, description]
  rows:
    - [socket_class_name_len,     socket.__name__.__len__,                              [],  6, "len(socket.socket.__name__) == 6 ('socket' has 6 characters — class name matches module name)"]
    - [af_inet_class_name_len,    AF_INET.__class__.__name__.__len__,                   [], 13, "len(socket.AF_INET.__class__.__name__) == 13 ('AddressFamily' has 13 characters)"]
    - [sock_stream_class_name_len,SOCK_STREAM.__class__.__name__.__len__,               [], 10, "len(socket.SOCK_STREAM.__class__.__name__) == 10 ('SocketKind' has 10 characters)"]
    - [gethostname_name_len,      gethostname.__name__.__len__,                         [], 11, "len(socket.gethostname.__name__) == 11 ('gethostname' has 11 characters)"]
    - [getaddrinfo_name_len,      getaddrinfo.__name__.__len__,                         [], 11, "len(socket.getaddrinfo.__name__) == 11 ('getaddrinfo' has 11 characters)"]

# ---------------------------------------------------------------------------
# socket class and function name equality checks
# ---------------------------------------------------------------------------

table socketmodule194.name_equality:
  kind: python_call_eq
  category: name_equality
  id_prefix: socketmodule194

  columns: [id, function, args, expected, description]
  rows:
    - [socket_class_name_eq,      socket.__name__.__eq__,             ["socket"],        true, "socket.socket.__name__ == 'socket' (class name equals module name)"]
    - [af_inet_class_name_eq,     AF_INET.__class__.__name__.__eq__,  ["AddressFamily"], true, "socket.AF_INET.__class__.__name__ == 'AddressFamily' (AF_INET is an AddressFamily IntEnum member)"]
    - [sock_stream_class_name_eq, SOCK_STREAM.__class__.__name__.__eq__, ["SocketKind"], true, "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind' (SOCK_STREAM is a SocketKind IntEnum member)"]
    - [gethostname_name_eq,       gethostname.__name__.__eq__,        ["gethostname"],   true, "socket.gethostname.__name__ == 'gethostname'"]
    - [getaddrinfo_name_eq,       getaddrinfo.__name__.__eq__,        ["getaddrinfo"],   true, "socket.getaddrinfo.__name__ == 'getaddrinfo'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant socketmodule194.module.name:
  description: "socket.__name__ == 'socket' (top-level stdlib module name)"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["socket"]
  expected: true

invariant socketmodule194.module.package:
  description: "socket.__package__ == '' (top-level stdlib module, no package prefix)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant socketmodule194.module.spec_name:
  description: "socket.__spec__.name == 'socket' (ModuleSpec.name matches socket.__name__)"
  category: module_identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["socket"]
  expected: true

invariant socketmodule194.socket.name_len:
  description: "len(socket.socket.__name__) == 6 ('socket' has 6 characters)"
  category: name_lengths
  kind: python_call_eq
  function: socket.__name__.__len__
  args: []
  expected: 6

invariant socketmodule194.AF_INET.class_name_len:
  description: "len(socket.AF_INET.__class__.__name__) == 13 ('AddressFamily' has 13 characters)"
  category: name_lengths
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__len__
  args: []
  expected: 13

invariant socketmodule194.SOCK_STREAM.class_name_len:
  description: "len(socket.SOCK_STREAM.__class__.__name__) == 10 ('SocketKind' has 10 characters)"
  category: name_lengths
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__len__
  args: []
  expected: 10

invariant socketmodule194.gethostname.name_len:
  description: "len(socket.gethostname.__name__) == 11 ('gethostname' has 11 characters)"
  category: name_lengths
  kind: python_call_eq
  function: gethostname.__name__.__len__
  args: []
  expected: 11

invariant socketmodule194.getaddrinfo.name_len:
  description: "len(socket.getaddrinfo.__name__) == 11 ('getaddrinfo' has 11 characters)"
  category: name_lengths
  kind: python_call_eq
  function: getaddrinfo.__name__.__len__
  args: []
  expected: 11
