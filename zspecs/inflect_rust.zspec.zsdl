spec: inflect_rust
version: ">=3.9"
backend: rust_module(inflect_rust)

docs: https://pypi.org/project/inflect/

provenance:
  derived_from:
    - "https://pypi.org/project/inflect/ — inflect library documentation"
  not_derived_from:
    - "inflect source: inflect/__init__.py"
  notes:
    - "inflect correctly generates plurals, singular nouns, ordinals, indefinite articles."
    - "p = inflect.engine(); p.plural('dog') == 'dogs'."
    - "p.plural('cat') == 'cats', p.plural('box') == 'boxes', p.plural('mouse') == 'mice'."
    - "p.singular_noun('dogs') == 'dog', p.singular_noun('mice') == 'mouse'."
    - "p.a('apple') == 'an apple', p.a('banana') == 'a banana'."
    - "p.a('egg') == 'an egg', p.a('hour') == 'an hour'."
    - "Expose plural(word) -> str: inflect.engine().plural(word)."
    - "Expose singular_noun(word) -> str: inflect.engine().singular_noun(word)."
    - "Expose indefinite_article(word) -> str: inflect.engine().a(word)."
    - "All test vectors verified against inflect 7.5.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# plural — pluralize English nouns
table inflect_rust.plural.vectors:
  kind: python_call_eq
  category: plural
  id_prefix: inf_pl
  function: plural

  columns: [id, args, expected]
  rows:
    - [dog,   ["dog"],   "dogs"]
    - [cat,   ["cat"],   "cats"]
    - [box,   ["box"],   "boxes"]
    - [mouse, ["mouse"], "mice"]
    - [child, ["child"], "children"]
    - [man,   ["man"],   "men"]

# singular_noun — singularize plural nouns
table inflect_rust.singular.vectors:
  kind: python_call_eq
  category: singular
  id_prefix: inf_sg
  function: singular_noun

  columns: [id, args, expected]
  rows:
    - [dogs,  ["dogs"],  "dog"]
    - [cats,  ["cats"],  "cat"]
    - [mice,  ["mice"],  "mouse"]
    - [men,   ["men"],   "man"]

# indefinite article — a vs an
table inflect_rust.article.vectors:
  kind: python_call_eq
  category: article
  id_prefix: inf_art
  function: indefinite_article

  columns: [id, args, expected]
  rows:
    - [apple,  ["apple"],  "an apple"]
    - [banana, ["banana"], "a banana"]
    - [egg,    ["egg"],    "an egg"]
    - [dog,    ["dog"],    "a dog"]

