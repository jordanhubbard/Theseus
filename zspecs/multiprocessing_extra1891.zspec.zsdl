spec: multiprocessing_extra1891
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "multiprocessing module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party multiprocessing extensions"
  notes:
    - "Tests unary arithmetic protocol and async iteration protocol membership in multiprocessing types"
    - "None of the multiprocessing types implement unary arithmetic dunder methods"
    - "multiprocessing types are synchronous and do not implement async iteration protocol"
    - "AsyncResult (also aliased as ApplyResult) provides get/wait/ready/successful interface"
  created_at: "2026-04-12"

table multiprocessing_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["mp1891-ua-001", "multiprocessing.Process.__dict__.__contains__", ["__abs__"], false]
    - ["mp1891-ua-002", "multiprocessing.Process.__dict__.__contains__", ["__neg__"], false]
    - ["mp1891-ua-003", "multiprocessing.pool.Pool.__dict__.__contains__", ["__abs__"], false]
    - ["mp1891-ua-004", "multiprocessing.pool.Pool.__dict__.__contains__", ["__neg__"], false]
    - ["mp1891-ua-005", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["__abs__"], false]
    - ["mp1891-ua-006", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__abs__"], false]
    - ["mp1891-ua-007", "multiprocessing.Process.__dict__.__contains__", ["__round__"], false]
    - ["mp1891-ua-008", "multiprocessing.pool.Pool.__dict__.__contains__", ["__round__"], false]

table multiprocessing_extra1891.async_iteration_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["mp1891-ai-001", "multiprocessing.Process.__dict__.__contains__", ["__aiter__"], false]
    - ["mp1891-ai-002", "multiprocessing.Process.__dict__.__contains__", ["__anext__"], false]
    - ["mp1891-ai-003", "multiprocessing.pool.Pool.__dict__.__contains__", ["__aiter__"], false]
    - ["mp1891-ai-004", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__aiter__"], false]
    - ["mp1891-ai-005", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["__aiter__"], false]
    - ["mp1891-ai-006", "multiprocessing.Process.__dict__.__contains__", ["__length_hint__"], false]
    - ["mp1891-ai-007", "multiprocessing.pool.Pool.__dict__.__contains__", ["__length_hint__"], false]
    - ["mp1891-ai-008", "multiprocessing.Process.__dict__.__contains__", ["__fspath__"], false]

table multiprocessing_extra1891.mp_asyncresult_attrs:
  columns: [id, function, args, expected]
  rows:
    - ["mp1891-ar-001", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["get"], true]
    - ["mp1891-ar-002", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["wait"], true]
    - ["mp1891-ar-003", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["ready"], true]
    - ["mp1891-ar-004", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["successful"], true]
    - ["mp1891-ar-005", "multiprocessing.pool.Pool.__dict__.__contains__", ["apply"], true]
    - ["mp1891-ar-006", "multiprocessing.pool.Pool.__dict__.__contains__", ["apply_async"], true]
    - ["mp1891-ar-007", "multiprocessing.pool.Pool.__dict__.__contains__", ["map"], true]
    - ["mp1891-ar-008", "multiprocessing.pool.Pool.__dict__.__contains__", ["map_async"], true]
    - ["mp1891-ar-009", "multiprocessing.pool.Pool.__dict__.__contains__", ["imap"], true]
    - ["mp1891-ar-010", "multiprocessing.pool.Pool.__dict__.__contains__", ["starmap"], true]
