spec: socket_extra185
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra184.zspec.zsdl — prior extras."
  notes:
    - "socket.__name__ == 'socket' — len=6; module identity."
    - "socket.IPPROTO_TCP.__class__.__name__ == 'int' — IANA TCP protocol number 6; stored as plain int on Darwin."
    - "socket.IPPROTO_UDP.__class__.__name__ == 'int' — IANA UDP protocol number 17; stored as plain int on Darwin."
    - "socket.IPPROTO_ICMP.__class__.__name__ == 'int' — IANA ICMP protocol number 1; stored as plain int on Darwin."
    - "socket.IPPROTO_TCP == 6 — IANA-assigned protocol number for TCP."
    - "socket.IPPROTO_UDP == 17 — IANA-assigned protocol number for UDP."
    - "socket.IPPROTO_ICMP == 1 — IANA-assigned protocol number for ICMP."
    - "socket.SOL_SOCKET == 65535 (0xFFFF) — Darwin-specific socket-level option value."
    - "socket.SO_REUSEADDR == 4 on Darwin; __class__.__name__ == 'int'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: socket module __name__ identity and length
#
# socket.__name__ == 'socket' (len=6)
#
# The __name__ attribute of the socket module equals its canonical name.
# ---------------------------------------------------------------------------

table socket_extra185.socket_module_name:
  description: "socket module __name__ identity and length; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: socketipproto185

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,
       socket.__name__.__eq__,
       ["socket"],
       true,
       "socket.__name__.__eq__('socket') == True — module is named 'socket'; len=6; new to extra185"]
    - [name_len,
       socket.__name__.__len__,
       [],
       6,
       "socket.__name__.__len__() == 6 — 'socket' has 6 characters; new to extra185"]

# ---------------------------------------------------------------------------
# Table 2: IPPROTO constants — class names and IANA protocol numbers
#
# socket.IPPROTO_TCP.__class__.__name__  == 'int'  value == 6
# socket.IPPROTO_UDP.__class__.__name__  == 'int'  value == 17
# socket.IPPROTO_ICMP.__class__.__name__ == 'int'  value == 1
#
# All IPPROTO_* constants are plain Python int values on Darwin.
# The numeric values are assigned by IANA.
# ---------------------------------------------------------------------------

table socket_extra185.ipproto_constants:
  description: "socket IPPROTO constant class names and IANA protocol number values; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: socketipproto185

  columns: [id, function, args, expected, description]
  rows:
    - [tcp_class_eq,
       socket.IPPROTO_TCP.__class__.__name__.__eq__,
       ["int"],
       true,
       "socket.IPPROTO_TCP.__class__.__name__.__eq__('int') == True — IPPROTO_TCP is a plain int on Darwin; new to extra185"]
    - [tcp_value_eq,
       socket.IPPROTO_TCP.__eq__,
       [6],
       true,
       "socket.IPPROTO_TCP.__eq__(6) == True — TCP protocol number is 6 per IANA; new to extra185"]
    - [udp_class_eq,
       socket.IPPROTO_UDP.__class__.__name__.__eq__,
       ["int"],
       true,
       "socket.IPPROTO_UDP.__class__.__name__.__eq__('int') == True — IPPROTO_UDP is a plain int on Darwin; new to extra185"]
    - [udp_value_eq,
       socket.IPPROTO_UDP.__eq__,
       [17],
       true,
       "socket.IPPROTO_UDP.__eq__(17) == True — UDP protocol number is 17 per IANA; new to extra185"]
    - [icmp_class_eq,
       socket.IPPROTO_ICMP.__class__.__name__.__eq__,
       ["int"],
       true,
       "socket.IPPROTO_ICMP.__class__.__name__.__eq__('int') == True — IPPROTO_ICMP is a plain int on Darwin; new to extra185"]
    - [icmp_value_eq,
       socket.IPPROTO_ICMP.__eq__,
       [1],
       true,
       "socket.IPPROTO_ICMP.__eq__(1) == True — ICMP protocol number is 1 per IANA; new to extra185"]

# ---------------------------------------------------------------------------
# Table 3: SOL_SOCKET and SO_REUSEADDR constants on Darwin
#
# socket.SOL_SOCKET.__eq__(65535) == True  — 0xFFFF; Darwin-specific value
# socket.SO_REUSEADDR.__eq__(4)   == True  — Darwin SO_REUSEADDR value
# socket.SO_REUSEADDR.__class__.__name__ == 'int'
# socket.SOL_SOCKET.__class__.__name__   == 'int'
#
# SOL_SOCKET is 0xFFFF (65535) on Darwin/macOS, unlike Linux where it is 1.
# SO_REUSEADDR is 4 on Darwin.
# ---------------------------------------------------------------------------

table socket_extra185.sol_socket_and_so_reuseaddr:
  description: "socket SOL_SOCKET and SO_REUSEADDR constant values on Darwin; new to extra185"
  kind: python_call_eq
  category: identity
  id_prefix: socketipproto185

  columns: [id, function, args, expected, description]
  rows:
    - [sol_socket_value_eq,
       socket.SOL_SOCKET.__eq__,
       [65535],
       true,
       "socket.SOL_SOCKET.__eq__(65535) == True — SOL_SOCKET is 0xFFFF on Darwin/macOS; new to extra185"]
    - [sol_socket_class_eq,
       socket.SOL_SOCKET.__class__.__name__.__eq__,
       ["int"],
       true,
       "socket.SOL_SOCKET.__class__.__name__.__eq__('int') == True — SOL_SOCKET is a plain int on Darwin; new to extra185"]
    - [so_reuseaddr_value_eq,
       socket.SO_REUSEADDR.__eq__,
       [4],
       true,
       "socket.SO_REUSEADDR.__eq__(4) == True — SO_REUSEADDR is 4 on Darwin/macOS; new to extra185"]
    - [so_reuseaddr_class_eq,
       socket.SO_REUSEADDR.__class__.__name__.__eq__,
       ["int"],
       true,
       "socket.SO_REUSEADDR.__class__.__name__.__eq__('int') == True — SO_REUSEADDR is a plain int on Darwin; new to extra185"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra185
# ---------------------------------------------------------------------------

invariant socket_extra185.module_name_is_socket:
  description: "socket.__name__ == 'socket' — module identity; len=6; new to extra185"
  category: identity
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

invariant socket_extra185.module_name_len_is_6:
  description: "socket.__name__.__len__() == 6 — 'socket' has 6 characters; new to extra185"
  category: identity
  kind: python_call_eq
  function: socket.__name__.__len__
  args: []
  expected: 6

invariant socket_extra185.ipproto_tcp_is_6:
  description: "socket.IPPROTO_TCP == 6 — IANA TCP protocol number; new to extra185"
  category: identity
  kind: python_call_eq
  function: socket.IPPROTO_TCP.__eq__
  args: [6]
  expected: true

invariant socket_extra185.ipproto_udp_is_17:
  description: "socket.IPPROTO_UDP == 17 — IANA UDP protocol number; new to extra185"
  category: identity
  kind: python_call_eq
  function: socket.IPPROTO_UDP.__eq__
  args: [17]
  expected: true

invariant socket_extra185.ipproto_icmp_is_1:
  description: "socket.IPPROTO_ICMP == 1 — IANA ICMP protocol number; new to extra185"
  category: identity
  kind: python_call_eq
  function: socket.IPPROTO_ICMP.__eq__
  args: [1]
  expected: true

invariant socket_extra185.tcp_class_is_int:
  description: "socket.IPPROTO_TCP.__class__.__name__ == 'int' — IPPROTO_TCP is a plain int on Darwin; new to extra185"
  category: identity
  kind: python_call_eq
  function: socket.IPPROTO_TCP.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant socket_extra185.sol_socket_is_65535:
  description: "socket.SOL_SOCKET == 65535 (0xFFFF) — Darwin-specific socket-level option value; new to extra185"
  category: identity
  kind: python_call_eq
  function: socket.SOL_SOCKET.__eq__
  args: [65535]
  expected: true

invariant socket_extra185.so_reuseaddr_is_4:
  description: "socket.SO_REUSEADDR == 4 — Darwin SO_REUSEADDR socket option value; new to extra185"
  category: identity
  kind: python_call_eq
  function: socket.SO_REUSEADDR.__eq__
  args: [4]
  expected: true
