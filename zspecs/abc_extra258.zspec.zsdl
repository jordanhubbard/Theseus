spec: abc_extra258
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc documentation"
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "abc.get_cache_token is a C-level built-in (type.__name__ == 'builtin_function_or_method')."
    - "get_cache_token.__module__ == '_abc' (the C extension module that backs abc)."
    - "collections.abc.Collection.__bases__ == (Sized, Iterable, Container) in that order."
    - "Collection.__abstractmethods__ == frozenset({'__contains__', '__iter__', '__len__'})."
    - "collections.abc.Awaitable.__bases__ == (object,); abstract method is __await__."
    - "collections.abc.Coroutine.__bases__ == (Awaitable,); abstract methods are __await__, send, throw."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.get_cache_token — function identity
#
# get_cache_token() returns the current ABC cache token, which changes each
# time a new ABC is registered. It is implemented in the _abc C extension.
# ---------------------------------------------------------------------------

invariant abc_extra258.get_cache_token.name:
  description: "abc.get_cache_token.__name__ == 'get_cache_token'"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__name__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra258.get_cache_token.qualname:
  description: "abc.get_cache_token.__qualname__ == 'get_cache_token'"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__qualname__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra258.get_cache_token.module:
  description: "abc.get_cache_token.__module__ == '_abc' — implemented in C extension"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__module__.__eq__
  args: ["_abc"]
  expected: true

invariant abc_extra258.get_cache_token.type:
  description: "type(abc.get_cache_token).__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# collections.abc.Collection — class identity and abstract methods
#
# Collection inherits from Sized, Iterable, and Container (three bases).
# Its abstract methods are __contains__, __iter__, and __len__.
# ---------------------------------------------------------------------------

invariant abc_extra258.collection.name:
  description: "collections.abc.Collection.__name__ == 'Collection'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__name__.__eq__
  args: ["Collection"]
  expected: true

invariant abc_extra258.collection.module:
  description: "collections.abc.Collection.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra258.collection.base0:
  description: "collections.abc.Collection.__bases__[0].__name__ == 'Sized'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Sized"

invariant abc_extra258.collection.base1:
  description: "collections.abc.Collection.__bases__[1].__name__ == 'Iterable'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__bases__.__getitem__
  args: [1]
  method: __name__
  expected: "Iterable"

invariant abc_extra258.collection.base2:
  description: "collections.abc.Collection.__bases__[2].__name__ == 'Container'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__bases__.__getitem__
  args: [2]
  method: __name__
  expected: "Container"

invariant abc_extra258.collection.abstractmethods_contains:
  description: "collections.abc.Collection.__abstractmethods__ contains '__contains__'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__abstractmethods__.__contains__
  args: ["__contains__"]
  expected: true

invariant abc_extra258.collection.abstractmethods_iter:
  description: "collections.abc.Collection.__abstractmethods__ contains '__iter__'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__abstractmethods__.__contains__
  args: ["__iter__"]
  expected: true

invariant abc_extra258.collection.abstractmethods_len:
  description: "collections.abc.Collection.__abstractmethods__ contains '__len__'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__abstractmethods__.__contains__
  args: ["__len__"]
  expected: true

invariant abc_extra258.collection.abstractmethods_count:
  description: "len(collections.abc.Collection.__abstractmethods__) == 3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Collection.__abstractmethods__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# collections.abc.Awaitable — class identity and abstract methods
#
# Awaitable inherits from object and has exactly one abstract method: __await__.
# ---------------------------------------------------------------------------

invariant abc_extra258.awaitable.name:
  description: "collections.abc.Awaitable.__name__ == 'Awaitable'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Awaitable.__name__.__eq__
  args: ["Awaitable"]
  expected: true

invariant abc_extra258.awaitable.module:
  description: "collections.abc.Awaitable.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Awaitable.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra258.awaitable.base:
  description: "collections.abc.Awaitable.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Awaitable.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

invariant abc_extra258.awaitable.abstractmethods_await:
  description: "collections.abc.Awaitable.__abstractmethods__ contains '__await__'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Awaitable.__abstractmethods__.__contains__
  args: ["__await__"]
  expected: true

invariant abc_extra258.awaitable.abstractmethods_count:
  description: "len(collections.abc.Awaitable.__abstractmethods__) == 1"
  category: identity
  kind: python_call_eq
  function: collections.abc.Awaitable.__abstractmethods__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# collections.abc.Coroutine — class identity and abstract methods
#
# Coroutine inherits from Awaitable. Its abstract methods are __await__,
# send, and throw (3 total).
# ---------------------------------------------------------------------------

invariant abc_extra258.coroutine.name:
  description: "collections.abc.Coroutine.__name__ == 'Coroutine'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Coroutine.__name__.__eq__
  args: ["Coroutine"]
  expected: true

invariant abc_extra258.coroutine.module:
  description: "collections.abc.Coroutine.__module__ == 'collections.abc'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Coroutine.__module__.__eq__
  args: ["collections.abc"]
  expected: true

invariant abc_extra258.coroutine.base:
  description: "collections.abc.Coroutine.__bases__[0].__name__ == 'Awaitable'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Coroutine.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Awaitable"

invariant abc_extra258.coroutine.abstractmethods_await:
  description: "collections.abc.Coroutine.__abstractmethods__ contains '__await__'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Coroutine.__abstractmethods__.__contains__
  args: ["__await__"]
  expected: true

invariant abc_extra258.coroutine.abstractmethods_send:
  description: "collections.abc.Coroutine.__abstractmethods__ contains 'send'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Coroutine.__abstractmethods__.__contains__
  args: ["send"]
  expected: true

invariant abc_extra258.coroutine.abstractmethods_throw:
  description: "collections.abc.Coroutine.__abstractmethods__ contains 'throw'"
  category: identity
  kind: python_call_eq
  function: collections.abc.Coroutine.__abstractmethods__.__contains__
  args: ["throw"]
  expected: true

invariant abc_extra258.coroutine.abstractmethods_count:
  description: "len(collections.abc.Coroutine.__abstractmethods__) == 3"
  category: identity
  kind: python_call_eq
  function: collections.abc.Coroutine.__abstractmethods__.__len__
  args: []
  expected: 3
