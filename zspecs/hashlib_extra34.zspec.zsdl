spec: hashlib_extra34
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra33.zspec.zsdl — covers HASH.update/digest/hexdigest/copy __qualname__.__len__(); HASH.__mro__.__len__(); HASH.__bases__[0].__name__; sha3_512/shake_128/shake_256 __name__.__len__(); algorithms_guaranteed/__class__/__name__.__len__()==3; algorithms_available.__class__.__name__.__len__()==3; algorithms_guaranteed exact count 14."
    - "hashlib_extra32.zspec.zsdl — covers sha1/sha512/sha224/sha384 __module__.__len__(); blake2b/blake2s __module__.__len__(); new.__module__.__len__(); new.__name__.__len__(); sha3_256 __name__/__module__.__len__()."
    - "hashlib_extra31.zspec.zsdl — covers md5/sha1/sha256/sha512/sha224/sha384 __name__.__len__(); md5/sha1/sha256/sha512 __module__.__eq__('_hashlib')."
    - "hashlib_extra20.zspec.zsdl — covers md5/sha1/sha256/sha512/new pbkdf2_hmac __name__.__eq__(); algorithms_available/guaranteed __class__.__name__.__eq__('set')."
  notes:
    - "This spec extends hashlib through hashlib_extra33; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: all major constructor __name__/__qualname__/__module__ equality and length checks; HASH instance method __qualname__.__len__(); algorithms_guaranteed/__available__ class name and exact count; sha3_256/sha3_512/shake_128/shake_256 __name__/__module__ checks."
    - "This spec covers: hashlib.__all__.__class__.__name__ == 'tuple' (NOVEL — __all__ is a tuple, not a list; no prior spec checks this); hashlib.__all__.__len__() == 19 (NOVEL); hashlib.__all__.__class__.__name__.__len__() == 5 (NOVEL); pbkdf2_hmac.__qualname__.__len__() == 11 (NOVEL — extra20 checks __name__.__eq__ only); pbkdf2_hmac.__module__.__len__() == 8 (NOVEL); hashlib.new.__class__.__name__.__len__() == 8 ('function', NOVEL); algorithms_available.__len__() == 19 (NOVEL — no prior spec checks exact count for algorithms_available); sha224.__qualname__.__len__() == 14 (NOVEL — extra31 covers __name__.__len__ not __qualname__.__len__); sha384.__qualname__.__len__() == 14 (NOVEL)."
    - "hashlib.__all__ is a tuple (not a list): In CPython 3.12, hashlib defines __all__ as a tuple literal. len(hashlib.__all__) == 19. This is surprising — most stdlib modules use lists for __all__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.__all__.__class__.__name__ == 'tuple'; len('tuple') == 5. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac'; len == 11. pbkdf2_hmac is a builtin_function_or_method backed by _hashlib C extension. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib'; len == 8. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.new.__class__.__name__ == 'function'; len('function') == 8. new is a pure-Python wrapper (__hash_new), so its class is 'function'. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_available.__len__() == 19: On CPython 3.12 macOS with the system OpenSSL, exactly 19 algorithms are available. This value is platform/OpenSSL-version dependent and may vary. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha224.__qualname__ == 'openssl_sha224'; len == 14. extra31 covers __name__.__len__()==14 for sha224 but not __qualname__.__len__(). Since __qualname__ == __name__ for OpenSSL-backed constructors, the length is the same 14. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "hashlib.sha384.__qualname__ == 'openssl_sha384'; len == 14. Same pattern as sha224. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.__all__ — type identity (tuple, not list)
#
# hashlib defines __all__ as a tuple in CPython 3.12. No prior hashlib spec
# checks the type of hashlib.__all__. The value is surprising since most
# stdlib modules use lists. All three invariants below are novel.
# ---------------------------------------------------------------------------

invariant hashlib_extra34.all.class_name:
  description: "hashlib.__all__.__class__.__name__ == 'tuple' — __all__ is a tuple, not a list"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant hashlib_extra34.all.len:
  description: "hashlib.__all__.__len__() == 19 — exactly 19 public names exported by hashlib"
  category: module_identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 19

invariant hashlib_extra34.all.class_name_len:
  description: "hashlib.__all__.__class__.__name__.__len__() == 5 — len('tuple') == 5"
  category: module_identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# hashlib.pbkdf2_hmac — __qualname__.__len__() and __module__.__len__()
#
# extra20 checks pbkdf2_hmac.__name__.__eq__('pbkdf2_hmac'). No prior spec
# checks __qualname__.__len__() or __module__.__len__() for pbkdf2_hmac.
# pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac' (len 11);
# pbkdf2_hmac.__module__ == '_hashlib' (len 8).
# ---------------------------------------------------------------------------

invariant hashlib_extra34.pbkdf2_hmac.qualname_len:
  description: "hashlib.pbkdf2_hmac.__qualname__.__len__() == 11 — 'pbkdf2_hmac' has 11 characters"
  category: function_names
  kind: python_call_eq
  function: pbkdf2_hmac.__qualname__.__len__
  args: []
  expected: 11

invariant hashlib_extra34.pbkdf2_hmac.module_len:
  description: "hashlib.pbkdf2_hmac.__module__.__len__() == 8 — '_hashlib' has 8 characters"
  category: module_metadata
  kind: python_call_eq
  function: pbkdf2_hmac.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# hashlib.new.__class__.__name__.__len__() — wrapper function class name
#
# hashlib.new is a pure-Python function (the __hash_new dispatch wrapper).
# Its __class__.__name__ == 'function'; len('function') == 8. No prior spec
# checks __class__.__name__.__len__() for hashlib.new. Novel invariant.
# ---------------------------------------------------------------------------

invariant hashlib_extra34.new.class_name_len:
  description: "hashlib.new.__class__.__name__.__len__() == 8 — len('function') == 8, novel invariant"
  category: function_names
  kind: python_call_eq
  function: new.__class__.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# hashlib.algorithms_available.__len__() — exact count on CPython 3.12 macOS
#
# No prior spec checks the exact cardinality of algorithms_available. On
# CPython 3.12 macOS/Darwin 25.4.0 with system OpenSSL, exactly 19 algorithms
# are available. This value may differ across platforms/OpenSSL versions.
# ---------------------------------------------------------------------------

invariant hashlib_extra34.algorithms_available.len:
  description: "hashlib.algorithms_available.__len__() == 19 — 19 algorithms available on CPython 3.12 macOS"
  category: algorithms_available
  kind: python_call_eq
  function: algorithms_available.__len__
  args: []
  expected: 19

# ---------------------------------------------------------------------------
# sha224 and sha384 __qualname__.__len__() — novel complement to extra31
#
# extra31 checks sha224.__name__.__len__()==14 and sha384.__name__.__len__()==14.
# For OpenSSL-backed constructors, __qualname__ == __name__. No prior spec
# checks __qualname__.__len__() for sha224 or sha384 specifically.
# sha224.__qualname__ == 'openssl_sha224' (len 14);
# sha384.__qualname__ == 'openssl_sha384' (len 14).
# ---------------------------------------------------------------------------

table hashlib_extra34.sha224_sha384_qualname_lengths:
  description: "sha224 and sha384 __qualname__.__len__() — novel complement to extra31 __name__.__len__() checks"
  kind: python_call_eq
  category: function_names
  id_prefix: hlqn34

  columns: [id, function, args, expected]
  rows:
    - [sha224_qualname_len, sha224.__qualname__.__len__, [], 14]
    - [sha384_qualname_len, sha384.__qualname__.__len__, [], 14]
    - [pbkdf2_qualname_len, pbkdf2_hmac.__qualname__.__len__, [], 11]
    - [pbkdf2_module_len,   pbkdf2_hmac.__module__.__len__,   [], 8]
