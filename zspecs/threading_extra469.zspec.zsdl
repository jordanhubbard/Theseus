spec: threading_extra469
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "threading.Lock is a factory function returning _thread.lock instances, not a class"
    - "threading.RLock is also a factory function returning _RLock instances"
    - "threading.TIMEOUT_MAX is a float constant (sys.maxsize equivalent in seconds)"
    - "get_native_id was added in Python 3.8"
    - "threading.Thread is a genuine class defined in threading module"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table threading_extra469.function_names:
  description: "Name attribute identity for threading functions"
  kind: python_call_eq
  category: identity
  id_prefix: TH469N

  columns: [id, function, args, expected]
  rows:
    - [TH469N001, threading.stack_size.__name__.__eq__, ["stack_size"], true]
    - [TH469N002, threading.excepthook.__name__.__eq__, ["excepthook"], true]
    - [TH469N003, threading.get_ident.__name__.__eq__, ["get_ident"], true]
    - [TH469N004, threading.get_native_id.__name__.__eq__, ["get_native_id"], true]
    - [TH469N005, threading.active_count.__name__.__eq__, ["active_count"], true]
    - [TH469N006, threading.current_thread.__name__.__eq__, ["current_thread"], true]
    - [TH469N007, threading.main_thread.__name__.__eq__, ["main_thread"], true]
    - [TH469N008, threading.enumerate.__name__.__eq__, ["enumerate"], true]
    - [TH469N009, threading.settrace.__name__.__eq__, ["settrace"], true]
    - [TH469N010, threading.setprofile.__name__.__eq__, ["setprofile"], true]

table threading_extra469.function_modules:
  description: "Module attribute identity for threading functions"
  kind: python_call_eq
  category: identity
  id_prefix: TH469M

  columns: [id, function, args, expected]
  rows:
    - [TH469M001, threading.stack_size.__module__.__eq__, ["threading"], true]
    - [TH469M002, threading.excepthook.__module__.__eq__, ["threading"], true]
    - [TH469M003, threading.active_count.__module__.__eq__, ["threading"], true]
    - [TH469M004, threading.current_thread.__module__.__eq__, ["threading"], true]
    - [TH469M005, threading.main_thread.__module__.__eq__, ["threading"], true]
    - [TH469M006, threading.enumerate.__module__.__eq__, ["threading"], true]
    - [TH469M007, threading.settrace.__module__.__eq__, ["threading"], true]
    - [TH469M008, threading.setprofile.__module__.__eq__, ["threading"], true]

table threading_extra469.thread_class_identity:
  description: "Thread class name and module identity"
  kind: python_call_eq
  category: identity
  id_prefix: TH469T

  columns: [id, function, args, expected]
  rows:
    - [TH469T001, threading.Thread.__name__.__eq__, ["Thread"], true]
    - [TH469T002, threading.Thread.__module__.__eq__, ["threading"], true]
    - [TH469T003, "threading.Thread.__bases__[0].__name__.__eq__", ["object"], true]
    - [TH469T004, threading.Timer.__name__.__eq__, ["Timer"], true]
    - [TH469T005, threading.Timer.__module__.__eq__, ["threading"], true]
    - [TH469T006, threading.Barrier.__name__.__eq__, ["Barrier"], true]
    - [TH469T007, threading.Barrier.__module__.__eq__, ["threading"], true]
    - [TH469T008, threading.Semaphore.__name__.__eq__, ["Semaphore"], true]
    - [TH469T009, threading.Semaphore.__module__.__eq__, ["threading"], true]
    - [TH469T010, threading.Event.__name__.__eq__, ["Event"], true]

table threading_extra469.timeout_max_identity:
  description: "TIMEOUT_MAX constant type identity"
  kind: python_call_eq
  category: identity
  id_prefix: TH469C

  columns: [id, function, args, expected]
  rows:
    - [TH469C001, threading.TIMEOUT_MAX.__class__.__name__.__eq__, ["float"], true]

table threading_extra469.lock_factory_names:
  description: "Lock and RLock are factory functions; verify their __name__ attributes"
  kind: python_call_eq
  category: identity
  id_prefix: TH469L

  columns: [id, function, args, expected]
  rows:
    - [TH469L001, threading.RLock.__name__.__eq__, ["RLock"], true]
    - [TH469L002, threading.Condition.__name__.__eq__, ["Condition"], true]
    - [TH469L003, threading.Condition.__module__.__eq__, ["threading"], true]
