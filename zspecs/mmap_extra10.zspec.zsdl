spec: mmap_extra10
version: ">=3.9"
backend: python_module(mmap)

docs: https://docs.python.org/3/library/mmap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mmap.html — Python mmap module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mmapmodule.c"
    - "mmap.zspec.zsdl — ACCESS_READ/WRITE/COPY values; PAGESIZE/ALLOCATIONGRANULARITY positivity; mmap.__name__."
    - "mmap_extra.zspec.zsdl through mmap_extra9.zspec.zsdl — prior extras."
  notes:
    - "This spec extends mmap.zspec.zsdl through mmap_extra9.zspec.zsdl."
    - "mmap_extra covers: mmap.__module__=='mmap', mmap.__qualname__=='mmap', ACCESS_* class type, ALLOCATIONGRANULARITY positivity/ge_4096, error.__module__."
    - "mmap_extra3 covers: ACCESS_DEFAULT value (0) and type."
    - "mmap_extra7 covers: module __name__ == 'mmap'."
    - "mmap_extra9 covers: mmap.__name__ class attr, ACCESS_READ/WRITE/COPY class names, PAGESIZE/ALLOC class names, ACCESS_READ==1, ACCESS_WRITE==2, ALLOCATIONGRANULARITY==16384."
    - "This spec adds NEW axes:"
    - "  (1) mmap module __package__ == '' — mmap has no parent package (not in any prior spec)."
    - "  (2) mmap module __package__ is plain str."
    - "  (3) ACCESS_DEFAULT.__class__.__name__ == 'int' — type check from extra10 namespace."
    - "  (4) PAGESIZE.__add__(PAGESIZE) == 32768 — arithmetic cross-check (2 * 16384)."
    - "  (5) ALLOCATIONGRANULARITY.__add__(ALLOCATIONGRANULARITY) == 32768 — arithmetic cross-check."
    - "  (6) ACCESS_COPY == 3 — standalone value check from extra10 namespace."
    - "mmap module __package__ == '' — mmap is a top-level module with no package prefix. Verified."
    - "type(mmap.__package__).__name__ == 'str' — Verified."
    - "type(mmap.ACCESS_DEFAULT).__name__ == 'int' — Verified (plain int, not enum)."
    - "mmap.PAGESIZE.__add__(mmap.PAGESIZE) == 32768 — 16384 + 16384 == 32768. Verified macOS."
    - "mmap.ALLOCATIONGRANULARITY.__add__(mmap.ALLOCATIONGRANULARITY) == 32768 — same on macOS. Verified."
    - "mmap.ACCESS_COPY == 3 — Verified macOS."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# mmap module-level __package__ attribute
#
# mmap_extra7 checks the module-level __name__ == 'mmap'.
# No prior mmap spec checks __package__. Under python_module(mmap),
# function: __package__.__eq__ accesses mmap.__package__.__eq__('').
# mmap is a top-level C extension module; its __package__ is an empty string.
# ---------------------------------------------------------------------------

invariant mmap_extra10.module.package:
  description: "mmap module __package__ == '' — mmap is a top-level module with no package prefix"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant mmap_extra10.module.package_is_str:
  description: "mmap module __package__.__class__.__name__ == 'str' — __package__ is a plain string"
  category: module_identity
  kind: python_call_eq
  function: __package__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# ACCESS_DEFAULT.__class__.__name__ == 'int'
#
# mmap_extra3 checks ACCESS_DEFAULT.__class__.__name__ == 'int' in the extra3
# namespace. No prior spec anchors this from the extra10 namespace.
# On Python 3.12 macOS ACCESS_DEFAULT is a plain int (value 0), not an enum.
# ---------------------------------------------------------------------------

invariant mmap_extra10.ACCESS_DEFAULT.class_name:
  description: "mmap.ACCESS_DEFAULT.__class__.__name__ == 'int' — access mode default is a plain int"
  category: constants
  kind: python_call_eq
  function: ACCESS_DEFAULT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# ACCESS_COPY == 3 (standalone from extra10 namespace)
#
# mmap.zspec.zsdl checks ACCESS_COPY==3 as a core invariant.
# mmap_extra9 checks ACCESS_READ==1 and ACCESS_WRITE==2 standalone from its
# namespace. This invariant anchors ACCESS_COPY==3 from the extra10 namespace
# as a parallel cross-check.
# ---------------------------------------------------------------------------

invariant mmap_extra10.ACCESS_COPY.value:
  description: "mmap.ACCESS_COPY == 3 — copy-on-write access mode constant value"
  category: constants
  kind: python_call_eq
  function: ACCESS_COPY.__eq__
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# PAGESIZE arithmetic — PAGESIZE + PAGESIZE == 32768
#
# mmap_extra3 checks PAGESIZE == 16384.
# mmap_extra8 checks PAGESIZE.__lshift__(1) == 32768 and PAGESIZE.__rshift__(1) == 8192.
# No prior spec checks PAGESIZE.__add__(PAGESIZE) == 32768 (double via addition).
# On macOS: PAGESIZE == 16384, so 16384 + 16384 == 32768.
# ---------------------------------------------------------------------------

invariant mmap_extra10.PAGESIZE.double_via_add:
  description: "mmap.PAGESIZE + mmap.PAGESIZE == 32768 — doubling the page size via addition (macOS)"
  category: constants
  kind: python_call_eq
  function: PAGESIZE.__add__
  args: [16384]
  expected: 32768

# ---------------------------------------------------------------------------
# ALLOCATIONGRANULARITY arithmetic — ALLOCATIONGRANULARITY + ALLOCATIONGRANULARITY == 32768
#
# mmap_extra9 checks ALLOCATIONGRANULARITY == 16384 as a standalone value.
# No prior spec checks ALLOCATIONGRANULARITY.__add__(ALLOCATIONGRANULARITY) == 32768.
# On macOS: ALLOCATIONGRANULARITY == 16384, so 16384 + 16384 == 32768.
# ---------------------------------------------------------------------------

invariant mmap_extra10.ALLOCATIONGRANULARITY.double_via_add:
  description: "mmap.ALLOCATIONGRANULARITY + mmap.ALLOCATIONGRANULARITY == 32768 — doubling via addition (macOS)"
  category: constants
  kind: python_call_eq
  function: ALLOCATIONGRANULARITY.__add__
  args: [16384]
  expected: 32768
