spec: detect_libc
version: ">=2.0.0"
backend: node(detect-libc)

docs: https://github.com/lovell/detect-libc#readme

provenance:
  derived_from:
    - "detect-libc README — https://github.com/lovell/detect-libc#readme"
    - "Test vectors verified with detect-libc via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "detect-libc source"
  notes:
    - "Detects glibc vs musl on Linux — used by sharp, native-module installers."
    - "Install: npm install detect-libc"
    - "v2 CJS; named exports GLIBC / MUSL / family / familySync / version / versionSync / isNonGlibcLinux / isNonGlibcLinuxSync."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw."
  stderr: "null"
  stickiness: "Detection is cached after first call."
  codes: {}

invariant detect_libc.GLIBC_constant:
  description: "GLIBC constant is the string 'glibc'"
  category: constants
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: GLIBC}
  expected: "glibc"

invariant detect_libc.MUSL_constant:
  description: "MUSL constant is the string 'musl'"
  category: constants
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: MUSL}
  expected: "musl"

invariant detect_libc.has_familySync:
  description: "familySync is exported (sync detection)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "familySync.constructor.name"}
  expected: "Function"

invariant detect_libc.has_versionSync:
  description: "versionSync is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "versionSync.constructor.name"}
  expected: "Function"

invariant detect_libc.has_isNonGlibcLinuxSync:
  description: "isNonGlibcLinuxSync is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "isNonGlibcLinuxSync.constructor.name"}
  expected: "Function"

invariant detect_libc.has_async_family:
  description: "Async family() variant is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "family.constructor.name"}
  expected: "AsyncFunction"

invariant detect_libc.has_async_version:
  description: "Async version() variant is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "version.constructor.name"}
  expected: "AsyncFunction"

invariant detect_libc.familySync_returns_string_or_null:
  description: "familySync() returns a string or null (depending on detection)"
  category: detect
  kind: node_chain_eq
  entry: named
  function: isNonGlibcLinuxSync
  entry_args: []
  chain:
    - {get: "constructor.name"}
  expected: "Boolean"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:15:48Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
