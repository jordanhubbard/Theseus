spec: decimal_extra153
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal.Decimal is_* predicate method __qualname__ values."
    - "All eight is_* predicate methods on Decimal use the 'Decimal.<method>' qualname pattern: is_nan, is_infinite, is_finite, is_zero, is_signed, is_normal, is_subnormal, is_canonical."
    - "decimal.Decimal.is_nan.__qualname__ == 'Decimal.is_nan' (len=14; 'Decimal.' (8) + 'is_nan' (6) = 14)."
    - "decimal.Decimal.is_infinite.__qualname__ == 'Decimal.is_infinite' (len=19; 'Decimal.' (8) + 'is_infinite' (11) = 19; the longest is_* predicate qualname)."
    - "decimal.Decimal.is_finite.__qualname__ == 'Decimal.is_finite' (len=17; 'Decimal.' (8) + 'is_finite' (9) = 17)."
    - "decimal.Decimal.is_zero.__qualname__ == 'Decimal.is_zero' (len=15; 'Decimal.' (8) + 'is_zero' (7) = 15)."
    - "decimal.Decimal.is_signed.__qualname__ == 'Decimal.is_signed' (len=17; 'Decimal.' (8) + 'is_signed' (9) = 17; tied with is_finite at 17)."
    - "decimal.Decimal.is_normal.__qualname__ == 'Decimal.is_normal' (len=17; 'Decimal.' (8) + 'is_normal' (9) = 17; three-way tie with is_finite and is_signed at 17)."
    - "decimal.Decimal.is_subnormal.__qualname__ == 'Decimal.is_subnormal' (len=20; 'Decimal.' (8) + 'is_subnormal' (12) = 20; second longest)."
    - "decimal.Decimal.is_canonical.__qualname__ == 'Decimal.is_canonical' (len=20; 'Decimal.' (8) + 'is_canonical' (12) = 20; tied with is_subnormal at 20)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal is_* predicate __qualname__ values (group 1)
# is_nan, is_infinite, is_finite, is_zero
# Lengths: is_nan=14, is_zero=15, is_finite=17, is_infinite=19
# All use 'Decimal.' prefix (8 characters).
# ---------------------------------------------------------------------------

table decimal_extra153.Decimal_isX_qualnames_group1:
  description: "decimal.Decimal is_* predicate __qualname__ values: is_nan='Decimal.is_nan', is_infinite='Decimal.is_infinite', is_finite='Decimal.is_finite', is_zero='Decimal.is_zero'; all 'Decimal.<method>' pattern"
  kind: python_call_eq
  category: qualname
  id_prefix: decispredq153

  columns: [id, function, args, expected, description]
  rows:
    - [is_nan_qeq,      Decimal.is_nan.__qualname__.__eq__,      ["Decimal.is_nan"],      true, "decimal.Decimal.is_nan.__qualname__ == 'Decimal.is_nan' (is_nan() returns True if the Decimal is a NaN (quiet or signaling); 'Decimal.is_nan' has 14 characters: 'Decimal.' (8) + 'is_nan' (6) = 14; NaN stands for 'Not a Number'; a quiet NaN propagates silently through arithmetic while a signaling NaN (sNaN) raises InvalidOperation; the shortest is_* predicate qualname of the four in this group)"]
    - [is_infinite_qeq, Decimal.is_infinite.__qualname__.__eq__, ["Decimal.is_infinite"], true, "decimal.Decimal.is_infinite.__qualname__ == 'Decimal.is_infinite' (is_infinite() returns True if the Decimal is positive or negative Infinity; 'Decimal.is_infinite' has 19 characters: 'Decimal.' (8) + 'is_infinite' (11) = 19; is_infinite() is used to test if a computation produced Infinity (e.g., division by zero with DivisionByZero trapped); 'is_infinite' (11 chars) is the longest method name in this group)"]
    - [is_finite_qeq,   Decimal.is_finite.__qualname__.__eq__,   ["Decimal.is_finite"],   true, "decimal.Decimal.is_finite.__qualname__ == 'Decimal.is_finite' (is_finite() returns True if the Decimal is neither Infinite nor NaN; in other words, is_finite() is True for all 'normal' decimal numbers including subnormals and zero; 'Decimal.is_finite' has 17 characters: 'Decimal.' (8) + 'is_finite' (9) = 17; is_finite() can be seen as the complement of is_nan() OR is_infinite(); tied in length with is_signed and is_normal at 17)"]
    - [is_zero_qeq,     Decimal.is_zero.__qualname__.__eq__,     ["Decimal.is_zero"],     true, "decimal.Decimal.is_zero.__qualname__ == 'Decimal.is_zero' (is_zero() returns True if the Decimal is a zero (positive or negative zero); 'Decimal.is_zero' has 15 characters: 'Decimal.' (8) + 'is_zero' (7) = 15; note that Decimal has both positive zero Decimal('0') and negative zero Decimal('-0') — is_zero() returns True for both; 'Decimal.is_zero' (15) falls between is_nan (14) and is_finite/is_signed/is_normal (17))"]

# ---------------------------------------------------------------------------
# decimal.Decimal is_* predicate __qualname__ values (group 2)
# is_signed, is_normal, is_subnormal, is_canonical
# Lengths: is_signed=17, is_normal=17, is_subnormal=20, is_canonical=20
# is_signed and is_normal are tied at 17; is_subnormal and is_canonical at 20.
# ---------------------------------------------------------------------------

table decimal_extra153.Decimal_isX_qualnames_group2:
  description: "decimal.Decimal is_* predicate __qualname__ values: is_signed='Decimal.is_signed', is_normal='Decimal.is_normal', is_subnormal='Decimal.is_subnormal', is_canonical='Decimal.is_canonical'"
  kind: python_call_eq
  category: qualname
  id_prefix: decispredq153

  columns: [id, function, args, expected, description]
  rows:
    - [is_signed_qeq,    Decimal.is_signed.__qualname__.__eq__,    ["Decimal.is_signed"],    true, "decimal.Decimal.is_signed.__qualname__ == 'Decimal.is_signed' (is_signed() returns True if the Decimal has a negative sign bit; this includes negative numbers, negative zero, and negative NaN; 'Decimal.is_signed' has 17 characters: 'Decimal.' (8) + 'is_signed' (9) = 17; the sign bit in decimal arithmetic is explicit — negative zero exists and is distinct from positive zero; tied with is_finite and is_normal at qualname length 17)"]
    - [is_normal_qeq,    Decimal.is_normal.__qualname__.__eq__,    ["Decimal.is_normal"],    true, "decimal.Decimal.is_normal.__qualname__ == 'Decimal.is_normal' (is_normal() returns True if the Decimal is a normal finite number — not zero, subnormal, infinite, or NaN; a subnormal number has an exponent below the minimum but nonzero coefficient; 'Decimal.is_normal' has 17 characters: 'Decimal.' (8) + 'is_normal' (9) = 17; is_normal() is the complement of is_subnormal() for finite nonzero numbers; three-way tie with is_finite and is_signed at 17)"]
    - [is_subnormal_qeq, Decimal.is_subnormal.__qualname__.__eq__, ["Decimal.is_subnormal"], true, "decimal.Decimal.is_subnormal.__qualname__ == 'Decimal.is_subnormal' (is_subnormal() returns True if the Decimal is subnormal: a finite nonzero number with an adjusted exponent less than the minimum; subnormal numbers trade precision for extended range near zero; 'Decimal.is_subnormal' has 20 characters: 'Decimal.' (8) + 'is_subnormal' (12) = 20; tied with is_canonical at 20 — both have 12-character method names)"]
    - [is_canonical_qeq, Decimal.is_canonical.__qualname__.__eq__, ["Decimal.is_canonical"], true, "decimal.Decimal.is_canonical.__qualname__ == 'Decimal.is_canonical' (is_canonical() returns True if the Decimal has its canonical encoding; for Python's decimal.Decimal, all values are canonical, so is_canonical() always returns True; 'Decimal.is_canonical' has 20 characters: 'Decimal.' (8) + 'is_canonical' (12) = 20; tied with is_subnormal at 20 — the longest is_* predicate qualnames; 'is_canonical' (12 chars) equals 'is_subnormal' (12 chars) in length)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra153.Decimal_is_nan_qualname_eq:
  description: "decimal.Decimal.is_nan.__qualname__ == 'Decimal.is_nan' — is_nan() is the first is_* predicate and checks for NaN values (both quiet NaN and signaling sNaN); its qualname uses the public class name 'Decimal' consistent with all other Decimal method qualnames established in earlier decimal specs; 'Decimal.is_nan' has 14 characters: 'Decimal.' (8) + 'is_nan' (6) = 14; the shortest is_* predicate qualname; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Decimal.is_nan.__qualname__.__eq__
  args: ["Decimal.is_nan"]
  expected: true

invariant decimal_extra153.Decimal_is_infinite_is_longest_group1:
  description: "decimal.Decimal.is_infinite.__qualname__.__len__() == 19 — 'Decimal.is_infinite' has 19 characters: 'Decimal.' (8) + 'is_infinite' (11) = 19; it is the longest qualname in group 1 (is_nan=14, is_zero=15, is_finite=17, is_infinite=19); 'is_infinite' (11 chars) is the longest method name in group 1; is_infinite() returns True for Decimal('Inf') and Decimal('-Inf') but False for NaN and finite numbers; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Decimal.is_infinite.__qualname__.__len__
  args: []
  expected: 19

invariant decimal_extra153.Decimal_is_subnormal_is_canonical_tied_at_20:
  description: "decimal.Decimal.is_subnormal.__qualname__.__len__() == 20 — 'Decimal.is_subnormal' has 20 characters, tied with 'Decimal.is_canonical' (also 20); both have 12-character method names ('is_subnormal' and 'is_canonical') plus the 8-character 'Decimal.' prefix; the two-way tie at qualname length 20 makes is_subnormal and is_canonical the longest is_* predicate qualnames covered in this spec; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Decimal.is_subnormal.__qualname__.__len__
  args: []
  expected: 20

invariant decimal_extra153.Decimal_is_finite_is_signed_is_normal_tied_at_17:
  description: "decimal.Decimal.is_finite.__qualname__.__len__() == 17 — 'Decimal.is_finite' has 17 characters; it is tied with 'Decimal.is_signed' (17) and 'Decimal.is_normal' (17) — all three have 9-character method names ('is_finite', 'is_signed', 'is_normal') plus the 8-character 'Decimal.' prefix; this three-way tie at 17 is the dominant qualname length among the eight is_* predicates: the complete length ranking is is_nan=14, is_zero=15, is_finite=is_signed=is_normal=17, is_infinite=19, is_subnormal=is_canonical=20; confirmed Python 3.14.3 macOS"
  category: qualname
  kind: python_call_eq
  function: Decimal.is_finite.__qualname__.__len__
  args: []
  expected: 17

