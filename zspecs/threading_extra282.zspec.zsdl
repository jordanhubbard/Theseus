spec: threading_extra282
version: ">=3.2"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.__all__ is a list with exactly 28 elements on Python 3.14.3/macOS."
    - "threading.__all__ contains all 9 primary public classes: Thread, Lock, RLock, Condition, Semaphore, BoundedSemaphore, Event, Timer, Barrier."
    - "threading.__all__.__class__.__name__ == 'list'."
    - "threading.Thread.__name__ == 'Thread'; __module__ == 'threading'."
    - "threading.Barrier.__name__ == 'Barrier'; __module__ == 'threading'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.__all__ — type and length
#
# threading.__all__ is a list with exactly 28 elements on Python 3.14.3.
# threading.__all__.__class__.__name__ == 'list'.
# ---------------------------------------------------------------------------

table threading_extra282.all_type_and_length:
  description: "threading.__all__ type and length — list with 28 elements on Python 3.14.3; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex282al

  columns: [id, function, args, expected, description]
  rows:
    - [al_cls_eq,  __all__.__class__.__name__.__eq__, ["list"], true, "threading.__all__.__class__.__name__ == 'list'; verified with Python 3.14.3"]
    - [al_len_eq,  __all__.__len__,                   [],       28,   "threading.__all__.__len__() == 28 on Python 3.14.3/macOS; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading.__all__ — membership for primary public classes and constants
#
# Thread, Lock, RLock, Condition, Semaphore, BoundedSemaphore, Event, Timer, Barrier
# are all present in threading.__all__.
# ---------------------------------------------------------------------------

table threading_extra282.all_contains_primary_names:
  description: "threading.__all__ membership — Thread, Lock, RLock, Condition, Semaphore, BoundedSemaphore, Event, Timer, Barrier all present; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex282ac

  columns: [id, function, args, expected, description]
  rows:
    - [ac_thread,    "__all__.__contains__",  ["Thread"],           true, "threading.__all__ contains 'Thread'; verified with Python 3.14.3"]
    - [ac_lock,      "__all__.__contains__",  ["Lock"],             true, "threading.__all__ contains 'Lock'; verified with Python 3.14.3"]
    - [ac_rlock,     "__all__.__contains__",  ["RLock"],            true, "threading.__all__ contains 'RLock'; verified with Python 3.14.3"]
    - [ac_condition, "__all__.__contains__",  ["Condition"],        true, "threading.__all__ contains 'Condition'; verified with Python 3.14.3"]
    - [ac_semaphore, "__all__.__contains__",  ["Semaphore"],        true, "threading.__all__ contains 'Semaphore'; verified with Python 3.14.3"]
    - [ac_bsem,      "__all__.__contains__",  ["BoundedSemaphore"], true, "threading.__all__ contains 'BoundedSemaphore'; verified with Python 3.14.3"]
    - [ac_event,     "__all__.__contains__",  ["Event"],            true, "threading.__all__ contains 'Event'; verified with Python 3.14.3"]
    - [ac_timer,     "__all__.__contains__",  ["Timer"],            true, "threading.__all__ contains 'Timer'; verified with Python 3.14.3"]
    - [ac_barrier,   "__all__.__contains__",  ["Barrier"],          true, "threading.__all__ contains 'Barrier'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra282
# ---------------------------------------------------------------------------

invariant threading_extra282.all_is_list:
  description: "threading.__all__.__class__.__name__ == 'list' — __all__ is a plain Python list"
  category: identity
  kind: python_call_eq
  function: __all__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant threading_extra282.all_length_is_28:
  description: "threading.__all__.__len__() == 28 — __all__ has exactly 28 entries on Python 3.14.3/macOS"
  category: identity
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 28

invariant threading_extra282.all_contains_thread:
  description: "threading.__all__ contains 'Thread' — Thread is part of the public threading API"
  category: identity
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["Thread"]
  expected: true

invariant threading_extra282.all_contains_lock:
  description: "threading.__all__ contains 'Lock' — Lock is part of the public threading API"
  category: identity
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["Lock"]
  expected: true

invariant threading_extra282.all_contains_rlock:
  description: "threading.__all__ contains 'RLock' — RLock is part of the public threading API"
  category: identity
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["RLock"]
  expected: true

invariant threading_extra282.all_contains_barrier:
  description: "threading.__all__ contains 'Barrier' — Barrier is part of the public threading API"
  category: identity
  kind: python_call_eq
  function: "__all__.__contains__"
  args: ["Barrier"]
  expected: true

invariant threading_extra282.thread_name_is_thread:
  description: "threading.Thread.__name__ == 'Thread' — the Thread class __name__ matches the public API name"
  category: identity
  kind: python_call_eq
  function: Thread.__name__.__eq__
  args: ["Thread"]
  expected: true

invariant threading_extra282.thread_module_is_threading:
  description: "threading.Thread.__module__ == 'threading' — Thread is defined in the threading module"
  category: identity
  kind: python_call_eq
  function: Thread.__module__.__eq__
  args: ["threading"]
  expected: true
