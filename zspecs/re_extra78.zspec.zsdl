spec: re_extra78
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends all prior re specs through re_extra77."
    - "Prior specs covered: Pattern/Match class identity; Pattern/Match __dict__ membership; Pattern/Match method qualnames; re.error.__name__ == 'PatternError'; re module-level function __code__ co_name and co_argcount; Pattern/Match method __qualname__ string lengths and values."
    - "re_extra77 covers Pattern/Match method __qualname__ string lengths; re.error and re.PatternError identity."
    - "This spec covers: Pattern.__dict__.__contains__ for match/search/findall/sub/split; Match.__dict__.__contains__ for group/groups/span; re.PatternError.__mro__.__len__() == 4; re.PatternError.__bases__[0].__name__ == 'Exception'; re.PatternError.__module__ == 're'."
    - "re.Pattern.__dict__.__contains__('match') == True — Pattern defines match() as a C method_descriptor."
    - "re.Pattern.__dict__.__contains__('search') == True — Pattern defines search() as a C method_descriptor."
    - "re.Pattern.__dict__.__contains__('findall') == True — Pattern defines findall() as a C method_descriptor."
    - "re.Pattern.__dict__.__contains__('sub') == True — Pattern defines sub() as a C method_descriptor."
    - "re.Pattern.__dict__.__contains__('split') == True — Pattern defines split() as a C method_descriptor."
    - "re.Match.__dict__.__contains__('group') == True — Match defines group() as a C method_descriptor."
    - "re.Match.__dict__.__contains__('groups') == True — Match defines groups() as a C method_descriptor."
    - "re.Match.__dict__.__contains__('span') == True — Match defines span() as a C method_descriptor."
    - "re.PatternError.__mro__.__len__() == 4 — MRO is [PatternError, Exception, BaseException, object]."
    - "re.PatternError.__bases__[0].__name__ == 'Exception' — PatternError directly subclasses Exception."
    - "re.PatternError.__module__ == 're' — PatternError is defined in the re module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Pattern.__dict__ membership for key methods
# Pattern is a C type in _sre. match, search, findall, sub, split are all
# defined as C method_descriptors directly on the Pattern type.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra78.Pattern_dict_contains:
  description: "Pattern.__dict__ contains match, search, findall, sub, split"
  kind: python_call_eq
  category: class_dict
  id_prefix: remore78

  columns: [id, function, args, expected]
  rows:
    - [pat_has_match,   "Pattern.__dict__.__contains__", ["match"],   true]
    - [pat_has_search,  "Pattern.__dict__.__contains__", ["search"],  true]
    - [pat_has_findall, "Pattern.__dict__.__contains__", ["findall"], true]
    - [pat_has_sub,     "Pattern.__dict__.__contains__", ["sub"],     true]
    - [pat_has_split,   "Pattern.__dict__.__contains__", ["split"],   true]

# ---------------------------------------------------------------------------
# Match.__dict__ membership for key methods
# Match is a C type in _sre. group, groups, span are all C method_descriptors.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra78.Match_dict_contains:
  description: "Match.__dict__ contains group, groups, span"
  kind: python_call_eq
  category: class_dict
  id_prefix: remore78

  columns: [id, function, args, expected]
  rows:
    - [mat_has_group,  "Match.__dict__.__contains__", ["group"],  true]
    - [mat_has_groups, "Match.__dict__.__contains__", ["groups"], true]
    - [mat_has_span,   "Match.__dict__.__contains__", ["span"],   true]

# ---------------------------------------------------------------------------
# re.PatternError MRO length and base class
# PatternError.__mro__ == [PatternError, Exception, BaseException, object]
# so __mro__.__len__() == 4.
# PatternError directly subclasses Exception: __bases__[0].__name__ == 'Exception'.
# Function values with [ must be double-quoted.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra78.PatternError_hierarchy:
  description: "re.PatternError MRO length and direct base class"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: remore78

  columns: [id, function, args, expected]
  rows:
    - [pe_mro_len, PatternError.__mro__.__len__,               [], 4]
    - [pe_base,    "PatternError.__bases__[0].__name__.__eq__", ["Exception"], true]

# ---------------------------------------------------------------------------
# re.PatternError module attribute
# PatternError.__module__ == 're' — it is defined in the re package.
# Not covered in any prior re spec.
# ---------------------------------------------------------------------------

table re_extra78.PatternError_module:
  description: "re.PatternError.__module__ == 're'"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: remore78

  columns: [id, function, args, expected]
  rows:
    - [pe_module, PatternError.__module__.__eq__, ["re"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra78.Pattern_dict.has_match:
  description: "re.Pattern.__dict__.__contains__('match') == True"
  category: class_dict
  kind: python_call_eq
  function: "Pattern.__dict__.__contains__"
  args: ["match"]
  expected: true

invariant re_extra78.Pattern_dict.has_split:
  description: "re.Pattern.__dict__.__contains__('split') == True"
  category: class_dict
  kind: python_call_eq
  function: "Pattern.__dict__.__contains__"
  args: ["split"]
  expected: true

invariant re_extra78.Match_dict.has_group:
  description: "re.Match.__dict__.__contains__('group') == True"
  category: class_dict
  kind: python_call_eq
  function: "Match.__dict__.__contains__"
  args: ["group"]
  expected: true

invariant re_extra78.PatternError.mro_len:
  description: "re.PatternError.__mro__.__len__() == 4 (PatternError, Exception, BaseException, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: PatternError.__mro__.__len__
  args: []
  expected: 4

invariant re_extra78.PatternError.module:
  description: "re.PatternError.__module__ == 're'"
  category: class_hierarchy
  kind: python_call_eq
  function: PatternError.__module__.__eq__
  args: ["re"]
  expected: true
