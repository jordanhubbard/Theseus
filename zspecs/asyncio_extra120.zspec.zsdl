spec: asyncio_extra120
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-eventloop.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-eventloop.html — Python asyncio BaseEventLoop documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/base_events.py"
  notes:
    - "This spec extends asyncio_extra119.zspec.zsdl."
    - "This spec covers: wave 260 theme — asyncio.BaseEventLoop class method __qualname__ lengths and co_varnames not previously covered. Prior specs covered: asyncio_extra2/7/9/38/85 covered BaseEventLoop.__name__, __module__, __qualname__, __mro__.__len__(), __bases__[0].__name__; extra119 covered AbstractEventLoop method qualnames. NOT previously covered as BaseEventLoop method qualname/co_varnames checks: BaseEventLoop.run_forever.__qualname__ (len=25), BaseEventLoop.run_until_complete.__qualname__ (len=32), BaseEventLoop.close.__qualname__ (len=19), BaseEventLoop.stop.__qualname__ (len=18), BaseEventLoop.call_soon.__qualname__ (len=23), BaseEventLoop.call_later.__qualname__ (len=24), BaseEventLoop.call_at.__qualname__ (len=21), BaseEventLoop.shutdown_asyncgens.__qualname__ (len=32), BaseEventLoop.shutdown_default_executor.__qualname__ (len=39). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.BaseEventLoop is the concrete base implementation of AbstractEventLoop. It is defined in Lib/asyncio/base_events.py and __module__=='asyncio.base_events' (len=19). __mro__.__len__()==3 ([BaseEventLoop, AbstractEventLoop, object]). __bases__[0].__name__=='AbstractEventLoop'. 'BaseEventLoop.'=14 is the common prefix for all method qualnames (len=14: 'BaseEventLoop'=13+dot=1=14). Shortest method qualname: stop (len=18: 'BaseEventLoop.'=14+'stop'=4=18). Longest: shutdown_default_executor (len=39: 'BaseEventLoop.'=14+'shutdown_default_executor'=25=39). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "BaseEventLoop.run_forever co_varnames.__len__()==1 (only 'self'). BaseEventLoop.stop co_varnames.__len__()==1 (only 'self'). BaseEventLoop.run_until_complete co_varnames.__len__()==3 ('self','future','new_task'). BaseEventLoop.close co_varnames.__len__()==2 ('self','executor'). BaseEventLoop.call_soon co_varnames.__len__()==5. BaseEventLoop.call_later co_varnames.__len__()==6. BaseEventLoop.call_at co_varnames.__len__()==6 (tied with call_later). BaseEventLoop.shutdown_asyncgens co_varnames.__len__()==6 (tied with call_later and call_at). BaseEventLoop.shutdown_default_executor co_varnames.__len__()==4. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.BaseEventLoop lifecycle method __qualname__ lengths — extra120
#
# Wave 260 theme: stop, close, call_at, run_forever, call_soon qualname lengths.
#
# BaseEventLoop.stop.__qualname__        == 'BaseEventLoop.stop'        (len=18, shortest)
# BaseEventLoop.close.__qualname__       == 'BaseEventLoop.close'       (len=19)
# BaseEventLoop.call_at.__qualname__     == 'BaseEventLoop.call_at'     (len=21)
# BaseEventLoop.call_soon.__qualname__   == 'BaseEventLoop.call_soon'   (len=23)
# BaseEventLoop.call_later.__qualname__  == 'BaseEventLoop.call_later'  (len=24)
# BaseEventLoop.run_forever.__qualname__ == 'BaseEventLoop.run_forever' (len=25)
# ---------------------------------------------------------------------------

table asyncio_extra120.bel_lifecycle_qualname_len:
  description: "asyncio.BaseEventLoop lifecycle method __qualname__ length checks in bel120 namespace — wave 260 theme: stop, close, call_at, call_soon, call_later, run_forever qualname lengths; BaseEventLoop.stop.__qualname__.__eq__('BaseEventLoop.stop')==True (len=18: 'BaseEventLoop.'=14+'stop'=4=18; shortest BaseEventLoop method qualname in spec; stop() sets the _stopping flag which causes run_forever to exit at the next iteration); BaseEventLoop.stop.__qualname__.__len__()==18; BaseEventLoop.close.__qualname__.__eq__('BaseEventLoop.close')==True (len=19: 'BaseEventLoop.'=14+'close'=5=19; 1 more than stop=18; close() closes the event loop, executor, and all associated resources); BaseEventLoop.close.__qualname__.__len__()==19; BaseEventLoop.call_at.__qualname__.__eq__('BaseEventLoop.call_at')==True (len=21: 'BaseEventLoop.'=14+'call_at'=7=21; call_at() schedules a callback at absolute time 'when'; 2 more than close=19); BaseEventLoop.call_at.__qualname__.__len__()==21; BaseEventLoop.call_soon.__qualname__.__eq__('BaseEventLoop.call_soon')==True (len=23: 'BaseEventLoop.'=14+'call_soon'=9=23; call_soon() schedules callback to be called in the next iteration); BaseEventLoop.call_soon.__qualname__.__len__()==23; BaseEventLoop.call_later.__qualname__.__eq__('BaseEventLoop.call_later')==True (len=24: 'BaseEventLoop.'=14+'call_later'=10=24; 1 more than call_soon=23); BaseEventLoop.call_later.__qualname__.__len__()==24; BaseEventLoop.run_forever.__qualname__.__eq__('BaseEventLoop.run_forever')==True (len=25: 'BaseEventLoop.'=14+'run_forever'=11=25; run_forever() blocks the thread running the event loop until stop() is called); BaseEventLoop.run_forever.__qualname__.__len__()==25; ordering: stop=18 < close=19 < call_at=21 < call_soon=23 < call_later=24 < run_forever=25; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: bel120

  columns: [id, function, args, expected, description]
  rows:
    - [stop_eq,    BaseEventLoop.stop.__qualname__.__eq__,       ["BaseEventLoop.stop"],       true, "BaseEventLoop.stop.__qualname__ == 'BaseEventLoop.stop' (len=18, shortest in spec); verified with Python 3.14.3"]
    - [stop_len,   BaseEventLoop.stop.__qualname__.__len__,      [],                           18,   "BaseEventLoop.stop.__qualname__.__len__() == 18 ('BaseEventLoop.'=14+'stop'=4=18, shortest); verified with Python 3.14.3"]
    - [close_eq,   BaseEventLoop.close.__qualname__.__eq__,      ["BaseEventLoop.close"],      true, "BaseEventLoop.close.__qualname__ == 'BaseEventLoop.close' (len=19); verified with Python 3.14.3"]
    - [close_len,  BaseEventLoop.close.__qualname__.__len__,     [],                           19,   "BaseEventLoop.close.__qualname__.__len__() == 19 ('BaseEventLoop.'=14+'close'=5=19); verified with Python 3.14.3"]
    - [callat_eq,  BaseEventLoop.call_at.__qualname__.__eq__,    ["BaseEventLoop.call_at"],    true, "BaseEventLoop.call_at.__qualname__ == 'BaseEventLoop.call_at' (len=21); verified with Python 3.14.3"]
    - [callat_len, BaseEventLoop.call_at.__qualname__.__len__,   [],                           21,   "BaseEventLoop.call_at.__qualname__.__len__() == 21 ('BaseEventLoop.'=14+'call_at'=7=21); verified with Python 3.14.3"]
    - [cs_eq,      BaseEventLoop.call_soon.__qualname__.__eq__,  ["BaseEventLoop.call_soon"],  true, "BaseEventLoop.call_soon.__qualname__ == 'BaseEventLoop.call_soon' (len=23); verified with Python 3.14.3"]
    - [cs_len,     BaseEventLoop.call_soon.__qualname__.__len__, [],                           23,   "BaseEventLoop.call_soon.__qualname__.__len__() == 23 ('BaseEventLoop.'=14+'call_soon'=9=23); verified with Python 3.14.3"]
    - [cl_eq,      BaseEventLoop.call_later.__qualname__.__eq__, ["BaseEventLoop.call_later"], true, "BaseEventLoop.call_later.__qualname__ == 'BaseEventLoop.call_later' (len=24); verified with Python 3.14.3"]
    - [cl_len,     BaseEventLoop.call_later.__qualname__.__len__, [],                          24,   "BaseEventLoop.call_later.__qualname__.__len__() == 24 ('BaseEventLoop.'=14+'call_later'=10=24); verified with Python 3.14.3"]
    - [rf_eq,      BaseEventLoop.run_forever.__qualname__.__eq__, ["BaseEventLoop.run_forever"], true, "BaseEventLoop.run_forever.__qualname__ == 'BaseEventLoop.run_forever' (len=25); verified with Python 3.14.3"]
    - [rf_len,     BaseEventLoop.run_forever.__qualname__.__len__, [],                          25,   "BaseEventLoop.run_forever.__qualname__.__len__() == 25 ('BaseEventLoop.'=14+'run_forever'=11=25); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.BaseEventLoop run and shutdown method qualname lengths — extra120
#
# Wave 260 theme: run_until_complete, shutdown_asyncgens, shutdown_default_executor.
#
# BaseEventLoop.run_until_complete.__qualname__       == 'BaseEventLoop.run_until_complete'       (len=32, tied)
# BaseEventLoop.shutdown_asyncgens.__qualname__       == 'BaseEventLoop.shutdown_asyncgens'       (len=32, tied)
# BaseEventLoop.shutdown_default_executor.__qualname__ == 'BaseEventLoop.shutdown_default_executor' (len=39, longest)
# ---------------------------------------------------------------------------

table asyncio_extra120.bel_run_shutdown_qualname_len:
  description: "asyncio.BaseEventLoop run and shutdown method __qualname__ length checks in bel120 namespace — wave 260 theme: run_until_complete, shutdown_asyncgens, shutdown_default_executor qualname lengths; BaseEventLoop.run_until_complete.__qualname__.__eq__('BaseEventLoop.run_until_complete')==True (len=32: 'BaseEventLoop.'=14+'run_until_complete'=18=32; run_until_complete() wraps a coroutine into a Task if needed, then runs the loop until that Task finishes; tied with shutdown_asyncgens=32); BaseEventLoop.run_until_complete.__qualname__.__len__()==32; BaseEventLoop.shutdown_asyncgens.__qualname__.__eq__('BaseEventLoop.shutdown_asyncgens')==True (len=32: 'BaseEventLoop.'=14+'shutdown_asyncgens'=18=32; tied with run_until_complete=32; 'shutdown_asyncgens'=18 chars == 'run_until_complete'=18 chars, same suffix length despite completely different names); BaseEventLoop.shutdown_asyncgens.__qualname__.__len__()==32; BaseEventLoop.shutdown_default_executor.__qualname__.__eq__('BaseEventLoop.shutdown_default_executor')==True (len=39: 'BaseEventLoop.'=14+'shutdown_default_executor'=25=39; longest BaseEventLoop method qualname in this spec; shutdown_default_executor() waits for the default executor to finish all pending futures); BaseEventLoop.shutdown_default_executor.__qualname__.__len__()==39; ordering: run_until_complete==shutdown_asyncgens=32 (tied) < shutdown_default_executor=39 (7 more than the tied pair: 'shutdown_default_executor'=25 vs 'run_until_complete'/'shutdown_asyncgens'=18, diff=7); all are pure-Python async/sync methods; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: bel120a

  columns: [id, function, args, expected, description]
  rows:
    - [ruc_eq,   BaseEventLoop.run_until_complete.__qualname__.__eq__,         ["BaseEventLoop.run_until_complete"],         true, "BaseEventLoop.run_until_complete.__qualname__ == 'BaseEventLoop.run_until_complete' (len=32); verified with Python 3.14.3"]
    - [ruc_len,  BaseEventLoop.run_until_complete.__qualname__.__len__,        [],                                           32,   "BaseEventLoop.run_until_complete.__qualname__.__len__() == 32 (tied with shutdown_asyncgens=32); verified with Python 3.14.3"]
    - [sa_eq,    BaseEventLoop.shutdown_asyncgens.__qualname__.__eq__,         ["BaseEventLoop.shutdown_asyncgens"],         true, "BaseEventLoop.shutdown_asyncgens.__qualname__ == 'BaseEventLoop.shutdown_asyncgens' (len=32, tied with run_until_complete); verified with Python 3.14.3"]
    - [sa_len,   BaseEventLoop.shutdown_asyncgens.__qualname__.__len__,        [],                                           32,   "BaseEventLoop.shutdown_asyncgens.__qualname__.__len__() == 32 (tied with run_until_complete=32); verified with Python 3.14.3"]
    - [sde_eq,   BaseEventLoop.shutdown_default_executor.__qualname__.__eq__,  ["BaseEventLoop.shutdown_default_executor"],  true, "BaseEventLoop.shutdown_default_executor.__qualname__ == 'BaseEventLoop.shutdown_default_executor' (len=39, longest); verified with Python 3.14.3"]
    - [sde_len,  BaseEventLoop.shutdown_default_executor.__qualname__.__len__, [],                                           39,   "BaseEventLoop.shutdown_default_executor.__qualname__.__len__() == 39 (longest in spec; 'shutdown_default_executor'=25 chars); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.BaseEventLoop method co_varnames lengths — extra120
#
# Wave 260 theme: co_varnames lengths for run_forever, stop, run_until_complete,
#                 close, shutdown_default_executor, call_soon.
#
# BaseEventLoop.run_forever.__code__.co_varnames.__len__()        == 1  (only 'self')
# BaseEventLoop.stop.__code__.co_varnames.__len__()               == 1  (only 'self', tied)
# BaseEventLoop.close.__code__.co_varnames.__len__()              == 2  ('self','executor')
# BaseEventLoop.run_until_complete.__code__.co_varnames.__len__() == 3  ('self','future','new_task')
# BaseEventLoop.shutdown_default_executor.__code__.co_varnames.__len__() == 4
# BaseEventLoop.call_soon.__code__.co_varnames.__len__()          == 5
# ---------------------------------------------------------------------------

table asyncio_extra120.bel_co_varnames_lengths:
  description: "asyncio.BaseEventLoop method co_varnames length checks in bel120 namespace — wave 260 theme: run_forever, stop, close, run_until_complete, shutdown_default_executor, call_soon co_varnames lengths; BaseEventLoop.run_forever.__code__.co_varnames.__len__()==1 (only 'self': run_forever takes no params; it just loops until stop() sets the _stopping flag; co_argcount==1); BaseEventLoop.stop.__code__.co_varnames.__len__()==1 (only 'self': stop() takes no params; it simply sets self._stopping=True; tied with run_forever=1); BaseEventLoop.close.__code__.co_varnames.__len__()==2 (('self','executor'): executor is a local variable used to shut down the default executor); BaseEventLoop.run_until_complete.__code__.co_varnames.__len__()==3 (('self','future','new_task'): future is the coroutine/future to await; new_task tracks whether a Task was created; co_argcount==2 because new_task is a local variable not a parameter); BaseEventLoop.shutdown_default_executor.__code__.co_varnames.__len__()==4 (('self','timeout','future','thread'): timeout is the optional wait duration; future and thread are locals for the async shutdown machinery; co_argcount==2: self and timeout); BaseEventLoop.call_soon.__code__.co_varnames.__len__()==5 (('self','callback','context','args','handle'): callback is required; context and args are locals; handle is the returned Handle); co_varnames length ordering: run_forever==stop=1 (tied, fewest: self only) < close=2 < run_until_complete=3 < shutdown_default_executor=4 < call_soon=5; all are pure-Python methods with __code__ attribute; verified with Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: bel120b

  columns: [id, function, args, expected, description]
  rows:
    - [rf_var_len,  BaseEventLoop.run_forever.__code__.co_varnames.__len__,              [], 1, "BaseEventLoop.run_forever co_varnames.__len__() == 1 (only 'self'; no params); verified with Python 3.14.3"]
    - [st_var_len,  BaseEventLoop.stop.__code__.co_varnames.__len__,                     [], 1, "BaseEventLoop.stop co_varnames.__len__() == 1 (only 'self'; tied with run_forever=1); verified with Python 3.14.3"]
    - [cl_var_len,  BaseEventLoop.close.__code__.co_varnames.__len__,                    [], 2, "BaseEventLoop.close co_varnames.__len__() == 2 ('self','executor'); verified with Python 3.14.3"]
    - [ruc_var_len, BaseEventLoop.run_until_complete.__code__.co_varnames.__len__,       [], 3, "BaseEventLoop.run_until_complete co_varnames.__len__() == 3 ('self','future','new_task'); verified with Python 3.14.3"]
    - [sde_var_len, BaseEventLoop.shutdown_default_executor.__code__.co_varnames.__len__, [], 4, "BaseEventLoop.shutdown_default_executor co_varnames.__len__() == 4 ('self','timeout','future','thread'); verified with Python 3.14.3"]
    - [cs_var_len,  BaseEventLoop.call_soon.__code__.co_varnames.__len__,                [], 5, "BaseEventLoop.call_soon co_varnames.__len__() == 5 ('self','callback','context','args','handle'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra120
# ---------------------------------------------------------------------------

invariant asyncio_extra120.bel_stop_qualname_eq:
  description: "asyncio.BaseEventLoop.stop.__qualname__.__eq__('BaseEventLoop.stop') returns True — 'BaseEventLoop.stop' has len=18: 'BaseEventLoop.'=14+'stop'=4=18; this is the shortest __qualname__ of any BaseEventLoop method in this spec; BaseEventLoop.stop() sets self._stopping=True which causes run_forever to exit at the top of the next iteration; BaseEventLoop.stop.__code__.co_argcount==1 (self only); co_varnames.__len__()==1 (fewest possible: ('self',)); compare: AbstractEventLoop.stop.__qualname__=='AbstractEventLoop.stop' (len=22: 4 more than BaseEventLoop.stop=18 because 'AbstractEventLoop'=17 vs 'BaseEventLoop'=13, diff=4); BaseEventLoop.__name__.__len__()==13; BaseEventLoop.__module__=='asyncio.base_events' (len=19); BaseEventLoop.__mro__.__len__()==3; first standalone BaseEventLoop.stop qualname equality invariant in bel120 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: BaseEventLoop.stop.__qualname__.__eq__
  args: ["BaseEventLoop.stop"]
  expected: true

invariant asyncio_extra120.bel_run_until_complete_qualname_len_32:
  description: "asyncio.BaseEventLoop.run_until_complete.__qualname__.__len__() == 32 — 'BaseEventLoop.run_until_complete' = 'BaseEventLoop.'=14+'run_until_complete'=18=32; BaseEventLoop.run_until_complete.__qualname__.__eq__('BaseEventLoop.run_until_complete')==True; run_until_complete() runs the event loop until the given Future/coroutine is done; if the argument is a coroutine, it is wrapped in a Task; after completion the Future result is returned; tied with shutdown_asyncgens=32 (both have 18-char suffixes); co_varnames.__len__()==3 ('self','future','new_task'); compare: AbstractEventLoop.run_until_complete.__qualname__.__len__()==36 (4 more: 'AbstractEventLoop'=17 vs 'BaseEventLoop'=13, diff=4 propagates to qualname diff); run_forever=25 (7 shorter: 'run_forever'=11 vs 'run_until_complete'=18, diff=7); shutdown_default_executor=39 (7 more: 'shutdown_default_executor'=25 vs 'run_until_complete'=18, diff=7); first standalone BaseEventLoop.run_until_complete qualname length invariant in bel120 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: BaseEventLoop.run_until_complete.__qualname__.__len__
  args: []
  expected: 32

invariant asyncio_extra120.bel_shutdown_default_executor_qualname_len_39:
  description: "asyncio.BaseEventLoop.shutdown_default_executor.__qualname__.__len__() == 39 — 'BaseEventLoop.shutdown_default_executor' = 'BaseEventLoop.'=14+'shutdown_default_executor'=25=39; longest BaseEventLoop method qualname in this spec; shutdown_default_executor() sends a shutdown request to the default executor and waits for it to drain (with optional timeout); it is an async method (coroutine); 'shutdown_default_executor'=25 is the longest method-name segment in spec; compare: shutdown_asyncgens=32 (7 shorter: 'shutdown_asyncgens'=18 vs 'shutdown_default_executor'=25, diff=7); run_until_complete=32 (7 shorter, tied with shutdown_asyncgens); co_varnames.__len__()==4 ('self','timeout','future','thread'); co_argcount==2 (self and timeout); BaseEventLoop.__name__.__len__()==13; BaseEventLoop.__module__=='asyncio.base_events' (len=19); first standalone BaseEventLoop.shutdown_default_executor qualname length invariant in bel120 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: BaseEventLoop.shutdown_default_executor.__qualname__.__len__
  args: []
  expected: 39

invariant asyncio_extra120.bel_run_forever_co_varnames_len_1:
  description: "asyncio.BaseEventLoop.run_forever.__code__.co_varnames.__len__() == 1 — co_varnames==('self',): run_forever takes no arguments other than self; it runs until stop() is called; co_argcount==1; co_varnames len=1 is the minimum possible for a bound method; BaseEventLoop.run_forever.__qualname__=='BaseEventLoop.run_forever' (len=25); compare: AbstractEventLoop.run_forever.__code__.co_varnames.__len__()==1 (same: both abstract and concrete run_forever have only 'self' in co_varnames); BaseEventLoop.stop also has co_varnames.__len__()==1 (tied with run_forever); BaseEventLoop.close has co_varnames.__len__()==2 (1 more: 'executor' is a local variable); BaseEventLoop.run_until_complete has co_varnames.__len__()==3; BaseEventLoop.__module__=='asyncio.base_events'; first standalone BaseEventLoop.run_forever co_varnames length invariant in bel120 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: BaseEventLoop.run_forever.__code__.co_varnames.__len__
  args: []
  expected: 1

invariant asyncio_extra120.bel_shutdown_asyncgens_qualname_eq:
  description: "asyncio.BaseEventLoop.shutdown_asyncgens.__qualname__.__eq__('BaseEventLoop.shutdown_asyncgens') returns True — 'BaseEventLoop.shutdown_asyncgens' has len=32: 'BaseEventLoop.'=14+'shutdown_asyncgens'=18=32; tied with run_until_complete=32 (both have 18-char method names); shutdown_asyncgens() is an async method that finalizes all asynchronous generators that are currently running in the event loop; it is called automatically when the event loop is closed if the loop has been running; BaseEventLoop.shutdown_asyncgens.__qualname__.__len__()==32; co_varnames.__len__()==6 ('self','closing_agens','ag','results','result','agen'): the most co_varnames in this spec (tied with call_later=6 and call_at=6); compare: shutdown_default_executor=39 (7 more than shutdown_asyncgens=32); run_forever=25 (7 fewer); BaseEventLoop.__name__.__len__()==13; BaseEventLoop.__module__=='asyncio.base_events' (len=19); first standalone BaseEventLoop.shutdown_asyncgens qualname equality invariant in bel120 namespace; wave 260; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: BaseEventLoop.shutdown_asyncgens.__qualname__.__eq__
  args: ["BaseEventLoop.shutdown_asyncgens"]
  expected: true
