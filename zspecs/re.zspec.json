  "functions": {
    "re.sub": {
      "description": "Return the string obtained by replacing the leftmost non-overlapping occurrences of pattern in string by repl. repl can be a string with backreferences (\\1, \\g<name>) or a callable.",
      "parameters": [
        {
          "name": "pattern",
          "ctype": "str|Pattern",
          "direction": "in",
          "description": "Regular expression pattern"
        },
        {
          "name": "repl",
          "ctype": "str|callable",
          "direction": "in",
          "description": "Replacement string or callable"
        },
        {
          "name": "string",
          "ctype": "str",
          "direction": "in",
          "description": "Input string to search"
        },
        {
          "name": "count",
          "ctype": "int",
          "direction": "in",
          "description": "Maximum number of substitutions. 0 means replace all (default)."
        },
        {
          "name": "flags",
          "ctype": "int",
          "direction": "in",
          "description": "Combination of re.* flag constants."
        }
      ],
      "return_type": "str"
    },
    "re.findall": {
      "description": "Return all non-overlapping matches of pattern in string, as a list of strings. If the pattern has groups, return a list of groups; if multiple groups, return a list of tuples of groups.",
      "parameters": [
        {
          "name": "pattern",
          "ctype": "str|Pattern",
          "direction": "in",
          "description": "Regular expression pattern"
        },
        {
          "name": "string",
          "ctype": "str",
          "direction": "in",
          "description": "Input string to search"
        },
        {
          "name": "flags",
          "ctype": "int",
          "direction": "in",
          "description": "Combination of re.* flag constants."
        }
      ],
      "return_type": "list"
    },
    "re.split": {
      "description": "Split string by the occurrences of pattern. If capturing groups are present in the pattern, the text of all groups in the pattern are also returned as part of the resulting list.",
      "parameters": [
        {
          "name": "pattern",
          "ctype": "str|Pattern",
          "direction": "in",
          "description": "Regular expression pattern to split on"
        },
        {
          "name": "string",
          "ctype": "str",
          "direction": "in",
          "description": "Input string to split"
        },
        {
          "name": "maxsplit",
          "ctype": "int",
          "direction": "in",
          "description": "Maximum number of splits. 0 means no limit (default)."
        },
        {
          "name": "flags",
          "ctype": "int",
          "direction": "in",
          "description": "Combination of re.* flag constants."
        }
      ],
      "return_type": "list"
    },
    "re.escape": {
      "description": "Return pattern with all ASCII non-alphanumeric characters backslashed. This is useful to match an arbitrary literal string that may have regular expression metacharacters in it.",
      "parameters": [
        {
          "name": "pattern",
          "ctype": "str",
          "direction": "in",
          "description": "String to escape"
        }
      ],
      "return_type": "str"
    },
    "re.compile": {
      "description": "Compile a regular expression pattern into a Pattern object. Raises re.error if the pattern is invalid.",
      "parameters": [
        {
          "name": "pattern",
          "ctype": "str",
          "direction": "in",
          "description": "Regular expression pattern"
        },
        {
          "name": "flags",
          "ctype": "int",
          "direction": "in",
          "description": "Combination of re.* flag constants."
        }
      ],
      "return_type": "Pattern"
    }
