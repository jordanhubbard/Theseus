spec: socket_extra83
version: ">=3.9"
extends: socket_extra82
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra82.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX/AF_UNSPEC/__class__/__qualname__=='AddressFamily' / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/__class__/__qualname__=='SocketKind' / AddressFamily/SocketKind __qualname__/__bases__[0].__name__/__mro__.__len__()/__qualname__.__len__() (table + invariants)."
    - "socket_extra81.zspec.zsdl — covers IPPROTO_TCP/UDP/IP/IPV6/SOL_SOCKET/__class__.__name__=='int' / AF_UNSPEC/__class__/__name__=='AddressFamily' / SOMAXCONN identity (table + invariants)."
    - "socket_extra80.zspec.zsdl — covers AF_INET/AF_INET6/AF_UNIX/__class__.__name__=='AddressFamily' / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW/__class__.__name__=='SocketKind' / AF_INET/__eq__(2)/AF_INET6/__eq__(30)/SOCK_STREAM/__eq__(1)/SOCK_DGRAM/__eq__(2) (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra82; it does NOT duplicate invariants present in those files."
    - "Wave 250 theme: socket gethostname/gethostbyname/getaddrinfo/getnameinfo/setdefaulttimeout/getdefaulttimeout/inet_aton/inet_ntoa/htons/htonl/ntohs __qualname__ identity and __doc__.__class__.__name__ identity."
    - "socket.gethostname.__qualname__ == 'gethostname' — gethostname is a builtin_function_or_method; its __qualname__ equals its function name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__qualname__ == 'gethostbyname' — 13 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__qualname__ == 'getaddrinfo' — getaddrinfo is a Python wrapper function. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getnameinfo.__qualname__ == 'getnameinfo' — getnameinfo is a builtin_function_or_method. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__qualname__ == 'setdefaulttimeout' — 17 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getdefaulttimeout.__qualname__ == 'getdefaulttimeout' — 17 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.inet_aton.__qualname__ == 'inet_aton' — 9 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.inet_ntoa.__qualname__ == 'inet_ntoa' — 9 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.htons.__qualname__ == 'htons' — 5 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.htonl.__qualname__ == 'htonl' — 5 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.ntohs.__qualname__ == 'ntohs' — 5 characters. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__doc__.__class__.__name__ == 'str' — gethostname has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__doc__.__class__.__name__ == 'str' — gethostbyname has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__doc__.__class__.__name__ == 'str' — getaddrinfo is a Python function with a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getnameinfo.__doc__.__class__.__name__ == 'str' — getnameinfo has a str docstring. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.gethostname/__qualname__/__len__() / gethostbyname/__qualname__/__len__()
# socket.getaddrinfo/__qualname__/__len__() / getnameinfo/__qualname__/__len__()
#
# Wave 250 theme: hostname-related function __qualname__.__len__() identity.
#
# gethostname.__qualname__ is 'gethostname' (11 chars).
# gethostbyname.__qualname__ is 'gethostbyname' (13 chars).
# getaddrinfo.__qualname__ is 'getaddrinfo' (11 chars).
# getnameinfo.__qualname__ is 'getnameinfo' (11 chars).
# No prior socket spec checks __qualname__.__len__() for any of these functions.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra83.hostname_qualname_lengths:
  description: "socket.gethostname/__qualname__/__len__()==11 / gethostbyname/__qualname__/__len__()==13 / getaddrinfo/__qualname__/__len__()==11 / getnameinfo/__qualname__/__len__()==11 — 'gethostname'/'getaddrinfo'/'getnameinfo' are 11 chars each; 'gethostbyname' is 13 chars; no prior socket spec checks __qualname__.__len__() for gethostname/gethostbyname/getaddrinfo/getnameinfo; first __qualname__.__len__ anchor for these four socket functions"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra83

  columns: [id, function, args, expected]
  rows:
    - [gethostname_qualname_len_11,   gethostname.__qualname__.__len__,   [], 11]
    - [gethostbyname_qualname_len_13, gethostbyname.__qualname__.__len__, [], 13]
    - [getaddrinfo_qualname_len_11,   getaddrinfo.__qualname__.__len__,   [], 11]
    - [getnameinfo_qualname_len_11,   getnameinfo.__qualname__.__len__,   [], 11]

# ---------------------------------------------------------------------------
# socket.gethostname/__doc__/__class__/__name__ / gethostbyname/__doc__/__class__/__name__
# socket.getaddrinfo/__doc__/__class__/__name__ / getnameinfo/__doc__/__class__/__name__
#
# Wave 250 theme: hostname-related function __doc__.__class__.__name__ identity.
#
# All four functions have str docstrings.
# No prior socket spec checks __doc__.__class__.__name__ for any socket function.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra83.hostname_doc_class_names:
  description: "socket.gethostname/__doc__/__class__/__name__.__eq__('str')==True / gethostbyname/__doc__/__class__/__name__.__eq__('str')==True / getaddrinfo/__doc__/__class__/__name__.__eq__('str')==True / getnameinfo/__doc__/__class__/__name__.__eq__('str')==True — all four socket hostname/address functions have str docstrings; no prior socket spec checks __doc__.__class__.__name__ for any socket function; first __doc__.__class__.__name__ identity anchor for gethostname/gethostbyname/getaddrinfo/getnameinfo"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketextra83

  columns: [id, function, args, expected]
  rows:
    - [gethostname_doc_class_str,   gethostname.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [gethostbyname_doc_class_str, gethostbyname.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [getaddrinfo_doc_class_str,   getaddrinfo.__doc__.__class__.__name__.__eq__,   ["str"], true]
    - [getnameinfo_doc_class_str,   getnameinfo.__doc__.__class__.__name__.__eq__,   ["str"], true]

# ---------------------------------------------------------------------------
