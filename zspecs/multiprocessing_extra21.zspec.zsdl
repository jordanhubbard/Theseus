spec: multiprocessing_extra21
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/__init__.py"
  notes:
    - "This spec extends multiprocessing.zspec.zsdl and prior extras through multiprocessing_extra20.zspec.zsdl."
    - "multiprocessing_extra16 covers: Process/Queue/Pool/Lock/Event __qualname__ table (BaseContext.* for context-bound names)."
    - "multiprocessing_extra20 covers: context method qualname table for Value/Array/Manager/Pipe; Process.__qualname__ standalone invariant."
    - "NOT yet covered in any prior spec: Process method __qualname__ table (start/run/join/is_alive/terminate/kill/close) in extra21 namespace."
    - "NOT yet covered: Process method __qualname__ length table in extra21 namespace."
    - "NOT yet covered: multiprocessing.Process.__module__ == 'multiprocessing.context' as standalone extra21 invariant."
    - "IMPORTANT: multiprocessing.Process methods have __qualname__ 'BaseProcess.<method>', not 'Process.<method>'."
    - "  Process inherits from BaseProcess defined in Lib/multiprocessing/process.py; the method __qualname__ reflects the defining class."
    - "Process.start.__qualname__ == 'BaseProcess.start' — inherited from BaseProcess."
    - "Process.run.__qualname__ == 'BaseProcess.run' — inherited from BaseProcess."
    - "Process.join.__qualname__ == 'BaseProcess.join' — inherited from BaseProcess."
    - "Process.is_alive.__qualname__ == 'BaseProcess.is_alive' — inherited from BaseProcess."
    - "Process.terminate.__qualname__ == 'BaseProcess.terminate' — inherited from BaseProcess."
    - "Process.kill.__qualname__ == 'BaseProcess.kill' — inherited from BaseProcess (Python 3.7+)."
    - "Process.close.__qualname__ == 'BaseProcess.close' — inherited from BaseProcess (Python 3.7+)."
    - "multiprocessing.Process.__module__ == 'multiprocessing.context' — because Process is exposed via the context machinery."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Process method __qualname__ table — extra21 namespace
#
# multiprocessing_extra16 checks Process class __qualname__ == 'Process'
# (the class itself, which is a true class). No prior spec provides a table
# of Process *method* __qualname__ values. Because Process inherits all its
# lifecycle methods from BaseProcess (Lib/multiprocessing/process.py), the
# method __qualname__ values use 'BaseProcess.' as the prefix, not 'Process.'.
# ---------------------------------------------------------------------------

table multiprocessing_extra21.process_method_qualnames:
  description: "multiprocessing.Process method __qualname__ values reflect BaseProcess inheritance"
  kind: python_call_eq
  category: method_names
  id_prefix: pmqn21

  columns: [id, function, args, expected]
  rows:
    - [start,     Process.start.__qualname__.__eq__,     ["BaseProcess.start"],     true]
    - [run,       Process.run.__qualname__.__eq__,       ["BaseProcess.run"],       true]
    - [join,      Process.join.__qualname__.__eq__,      ["BaseProcess.join"],      true]
    - [is_alive,  Process.is_alive.__qualname__.__eq__,  ["BaseProcess.is_alive"],  true]
    - [terminate, Process.terminate.__qualname__.__eq__, ["BaseProcess.terminate"], true]
    - [kill,      Process.kill.__qualname__.__eq__,      ["BaseProcess.kill"],      true]
    - [close,     Process.close.__qualname__.__eq__,     ["BaseProcess.close"],     true]

# ---------------------------------------------------------------------------
# Process method __qualname__ length table — extra21 namespace
#
# Lengths (with 'BaseProcess.' prefix of 12 chars):
# BaseProcess.start(17), BaseProcess.run(15), BaseProcess.join(16),
# BaseProcess.is_alive(20), BaseProcess.terminate(21),
# BaseProcess.kill(16), BaseProcess.close(17).
# ---------------------------------------------------------------------------

table multiprocessing_extra21.process_method_qualname_lengths:
  description: "multiprocessing.Process method __qualname__ lengths including 'BaseProcess.' prefix"
  kind: python_call_eq
  category: method_names
  id_prefix: pmqnlen21

  columns: [id, function, args, expected]
  rows:
    - [start,     Process.start.__qualname__.__len__,     [], 17]
    - [run,       Process.run.__qualname__.__len__,       [], 15]
    - [join,      Process.join.__qualname__.__len__,      [], 16]
    - [is_alive,  Process.is_alive.__qualname__.__len__,  [], 20]
    - [terminate, Process.terminate.__qualname__.__len__, [], 21]
    - [kill,      Process.kill.__qualname__.__len__,      [], 16]
    - [close,     Process.close.__qualname__.__len__,     [], 17]

# ---------------------------------------------------------------------------
# Process.__module__ == 'multiprocessing.context' — standalone extra21 invariant
#
# multiprocessing.Process is the public class, but it is created via the
# context machinery. Its __module__ attribute reports 'multiprocessing.context'
# (not 'multiprocessing.process' where BaseProcess is defined). No prior spec
# checks this as a standalone extra21-namespace invariant.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra21.Process.module_eq:
  description: "multiprocessing.Process.__module__ == 'multiprocessing.context' — class exposed via context machinery"
  category: class_modules
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true
