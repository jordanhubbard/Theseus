spec: traceback_extra9
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback.zspec.zsdl through traceback_extra8.zspec.zsdl."
    - "traceback_extra8 covers class __name__/__module__ via __eq__ predicate form; function __name__ via __eq__ predicate form for print_exc/print_tb/print_stack/format_exc/format_tb/format_stack/clear_frames."
    - "traceback_extra7 covers function __module__ for all public functions; StackSummary.from_list.__func__.__qualname__; traceback.__spec__.name; traceback.__file__.__class__.__name__."
    - "traceback_extra6 covers function __qualname__ for format_exception/print_exception/print_stack/walk_tb/walk_stack/clear_frames/format_exception_only/format_list/print_list; StackSummary/__bases__ and FrameSummary/__bases__."
    - "NOT yet covered: TracebackException.format.__qualname__ == 'TracebackException.format'."
    - "NOT yet covered: TracebackException.format_exception_only.__qualname__ == 'TracebackException.format_exception_only'."
    - "NOT yet covered: TracebackException.from_exception.__qualname__ == 'TracebackException.from_exception'."
    - "NOT yet covered: TracebackException.print.__qualname__ == 'TracebackException.print'."
    - "NOT yet covered: StackSummary.extract.__qualname__ == 'StackSummary.extract'."
    - "NOT yet covered: FrameSummary.__init__.__qualname__ == 'FrameSummary.__init__'."
    - "NOT yet covered: FrameSummary.__repr__.__qualname__ == 'FrameSummary.__repr__'."
    - "NOT yet covered: MRO lengths for TracebackException/StackSummary/FrameSummary."
    - "TracebackException.format.__qualname__ == 'TracebackException.format' — instance method of TracebackException."
    - "TracebackException.from_exception.__qualname__ == 'TracebackException.from_exception' — classmethod underlying function."
    - "StackSummary.extract.__qualname__ == 'StackSummary.extract' — classmethod underlying function."
    - "FrameSummary.__init__.__qualname__ == 'FrameSummary.__init__' — constructor of FrameSummary."
    - "TracebackException.mro() has 2 entries: [TracebackException, object]."
    - "StackSummary.mro() has 3 entries: [StackSummary, list, object]."
    - "FrameSummary.mro() has 2 entries: [FrameSummary, object]."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TracebackException method __qualname__ checks
#
# No prior traceback spec records __qualname__ for any TracebackException
# instance method or class method. These methods have qualnames of the form
# 'TracebackException.<method>'.
# ---------------------------------------------------------------------------

table traceback_extra9.TracebackException_method_qualnames:
  description: "TracebackException methods have __qualname__ == 'TracebackException.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: temqname

  columns: [id, function, args, expected]
  rows:
    - [format,               TracebackException.format.__qualname__.__eq__,               ["TracebackException.format"],               true]
    - [format_exception_only, TracebackException.format_exception_only.__qualname__.__eq__, ["TracebackException.format_exception_only"], true]
    - [print,                TracebackException.print.__qualname__.__eq__,                ["TracebackException.print"],                true]

# ---------------------------------------------------------------------------
# TracebackException.from_exception — classmethod __qualname__
#
# from_exception is a classmethod. The underlying function's __qualname__
# is 'TracebackException.from_exception'. This adds a standalone invariant
# for this classmethod's qualname, consistent with the pattern used for
# StackSummary.from_list in traceback_extra7.
# ---------------------------------------------------------------------------

invariant traceback_extra9.TracebackException.from_exception_qualname:
  description: "traceback.TracebackException.from_exception.__func__.__qualname__ == 'TracebackException.from_exception'"
  category: method_qualnames
  kind: python_call_eq
  function: TracebackException.from_exception.__func__.__qualname__.__eq__
  args: ["TracebackException.from_exception"]
  expected: true

# ---------------------------------------------------------------------------
# StackSummary.extract — classmethod __qualname__
#
# extract is a classmethod on StackSummary. No prior spec records its
# underlying __func__.__qualname__. The value is 'StackSummary.extract'.
# ---------------------------------------------------------------------------

invariant traceback_extra9.StackSummary.extract_qualname:
  description: "traceback.StackSummary.extract.__func__.__qualname__ == 'StackSummary.extract'"
  category: method_qualnames
  kind: python_call_eq
  function: StackSummary.extract.__func__.__qualname__.__eq__
  args: ["StackSummary.extract"]
  expected: true

# ---------------------------------------------------------------------------
# FrameSummary method __qualname__ checks
#
# No prior traceback spec records __qualname__ for FrameSummary methods.
# __init__ and __repr__ are plain instance methods with the expected
# 'FrameSummary.<method>' qualname pattern.
# ---------------------------------------------------------------------------

invariant traceback_extra9.FrameSummary.init_qualname:
  description: "traceback.FrameSummary.__init__.__qualname__ == 'FrameSummary.__init__'"
  category: method_qualnames
  kind: python_call_eq
  function: FrameSummary.__init__.__qualname__.__eq__
  args: ["FrameSummary.__init__"]
  expected: true

invariant traceback_extra9.FrameSummary.repr_qualname:
  description: "traceback.FrameSummary.__repr__.__qualname__ == 'FrameSummary.__repr__'"
  category: method_qualnames
  kind: python_call_eq
  function: FrameSummary.__repr__.__qualname__.__eq__
  args: ["FrameSummary.__repr__"]
  expected: true

# ---------------------------------------------------------------------------
# MRO lengths — TracebackException, StackSummary, FrameSummary
#
# No prior traceback spec records the MRO length for any class via mro().
# TracebackException inherits directly from object (length 2).
# StackSummary subclasses list, so MRO is [StackSummary, list, object] (length 3).
# FrameSummary inherits from object directly (length 2).
# ---------------------------------------------------------------------------

invariant traceback_extra9.TracebackException.mro_len:
  description: "traceback.TracebackException.mro() has 2 entries: [TracebackException, object]"
  category: mro
  kind: python_call_eq
  function: TracebackException.mro
  args: []
  method: __len__
  expected: 2

invariant traceback_extra9.StackSummary.mro_len:
  description: "traceback.StackSummary.mro() has 3 entries: [StackSummary, list, object]"
  category: mro
  kind: python_call_eq
  function: StackSummary.mro
  args: []
  method: __len__
  expected: 3

invariant traceback_extra9.FrameSummary.mro_len:
  description: "traceback.FrameSummary.mro() has 2 entries: [FrameSummary, object]"
  category: mro
  kind: python_call_eq
  function: FrameSummary.mro
  args: []
  method: __len__
  expected: 2
