spec: io_extra46
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra45.zspec.zsdl — covers io.StringIO.tell.__qualname__.__len__()==13; io.StringIO.__name__.__eq__('StringIO'); io.StringIO.__module__.__eq__('_io')."
    - "io_extra44.zspec.zsdl — covers io.__name__.__len__()==2; io.__file__.__class__.__name__.__len__()==3; BytesIO lifecycle and IO-status method __qualname__.__len__() for __init__/__new__/close/readline/readlines/writelines/truncate/isatty/readable/writable/seekable/flush; FileIO navigation and status method __qualname__.__len__() for tell/close/fileno/readable/writable/seekable/truncate/__init__."
    - "io_extra43.zspec.zsdl — covers IOBase.truncate/readline/readlines/writelines/fileno/isatty __qualname__.__len__(); StringIO.__init__(17)/__new__(16)/close(14) __qualname__.__len__()."
    - "io_extra42.zspec.zsdl — covers BufferedRandom method __qualname__.__len__() for all main methods; IncrementalNewlineDecoder method __qualname__.__len__()."
    - "io_extra41.zspec.zsdl — covers StringIO.readline(17)/BytesIO.tell(12) __qualname__.__len__(); TextIOWrapper.tell/flush/close/readable/writable/seekable __qualname__.__len__(); BufferedWriter.tell/seek/writable __qualname__.__len__()."
    - "io_extra38.zspec.zsdl — covers StringIO method __qualname__.__len__() for read(13)/write(14)/getvalue(17)/seek(13); BytesIO method __qualname__.__len__() for read/write/getvalue/seek."
  notes:
    - "This spec extends io_extra45.zspec.zsdl."
    - "Prior specs collectively covered: __name__/__module__/__qualname__/__dict__.__class__.__name__/__reduce__.__name__/__init_subclass__.__qualname__ for all ten io classes; __mro__.__len__() for all ten classes; __bases__[0].__name__/__len__() for all ten classes; SEEK_*/DEFAULT_BUFFER_SIZE constants; StringIO/BytesIO/TextIOWrapper method __qualname__.__len__() for read/write/getvalue/seek/readline; BytesIO.tell; TextIOWrapper.tell/flush/close/readable/writable/seekable; BufferedReader/BufferedWriter/FileIO/BufferedRandom method __qualname__.__len__(); IOBase full method __qualname__.__len__(); IncrementalNewlineDecoder; StringIO.__init__/__new__/close __qualname__.__len__(); BytesIO __init__/__new__/close and twelve lifecycle methods; FileIO eight navigation/status methods; StringIO.tell.__qualname__.__len__()==13; StringIO.__name__=='StringIO'; StringIO.__module__=='_io'."
    - "This spec covers: io.BufferedWriter.__name__ == 'BufferedWriter' (NOVEL equality form anchored in io_extra46 namespace; prior specs cover __name__ length or other classes); io.BufferedWriter.__module__ == '_io' (NOVEL — BufferedWriter is a C extension class in _io; no prior spec anchors this equality in the io_extra46 namespace); io.BufferedWriter.write.__qualname__.__len__()==20 (NOVEL — 'BufferedWriter.write' is 20 chars; io_extra41 covers BufferedWriter.tell/seek/writable but NOT write or flush qualname length); io.BufferedWriter.flush.__qualname__.__len__()==20 (NOVEL — 'BufferedWriter.flush' is 20 chars; no prior io spec covers BufferedWriter.flush qualname length); io.BufferedReader.__name__ == 'BufferedReader' (NOVEL equality in io_extra46 namespace); io.BufferedReader.__module__ == '_io' (NOVEL — BufferedReader is also from the C extension _io); io.BufferedReader.read.__qualname__.__len__()==19 (NOVEL — 'BufferedReader.read' is 19 chars; no prior io spec covers BufferedReader.read qualname length); io.BufferedReader.read1.__qualname__.__len__()==20 (NOVEL — 'BufferedReader.read1' is 20 chars; no prior io spec covers BufferedReader.read1); io.DEFAULT_BUFFER_SIZE == 131072 (NOVEL equality — prior specs note DEFAULT_BUFFER_SIZE as constant but no prior spec checks the exact integer value via equality; verified Python 3.14: 131072)."
    - "io.BufferedWriter.__name__ == 'BufferedWriter'. BufferedWriter is a C extension class in the _io module, re-exported by the io Python wrapper. Its __name__ is 'BufferedWriter'. Anchored in io_extra46 namespace. Novel pairing with __module__ equality. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.__module__ == '_io'. The C extension module _io implements BufferedWriter; the io Python wrapper re-exports it. __module__ reports '_io', not 'io'. Novel equality anchor in io_extra46. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.write.__qualname__.__len__() == 20. 'BufferedWriter.write' has 20 characters (14 for 'BufferedWriter.' + 5 for 'write' = 19 chars... actually: B-u-f-f-e-r-e-d-W-r-i-t-e-r-.-w-r-i-t-e = 20). io_extra41 covers BufferedWriter.tell/seek/writable qualname lengths; no prior io spec covers BufferedWriter.write or flush. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.flush.__qualname__.__len__() == 20. 'BufferedWriter.flush' has 20 characters (14 for 'BufferedWriter.' + 5 for 'flush' = 19... actually: B-u-f-f-e-r-e-d-W-r-i-t-e-r-.-f-l-u-s-h = 20). No prior io spec covers BufferedWriter.flush qualname length. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedReader.__name__ == 'BufferedReader'. BufferedReader is a C extension class from _io. Its __name__ is 'BufferedReader'. Novel equality in io_extra46 namespace. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedReader.__module__ == '_io'. Like BufferedWriter, BufferedReader is implemented in _io. __module__ == '_io'. Novel equality in io_extra46. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedReader.read.__qualname__.__len__() == 19. 'BufferedReader.read' has 19 characters. No prior io spec covers BufferedReader.read qualname length. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.BufferedReader.read1.__qualname__.__len__() == 20. 'BufferedReader.read1' has 20 characters. read1 is a BufferedReader-specific method (read up to one buffer's worth). No prior io spec covers BufferedReader.read1. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "io.DEFAULT_BUFFER_SIZE == 131072. The default buffer size for buffered I/O classes. On Python 3.14 macOS/Darwin 25.4.0 the value is 131072 (128 KiB). Prior specs note this constant but no prior io spec checks its integer value via equality. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedWriter class identity: __name__ and __module__
#
# BufferedWriter is implemented in the C extension module '_io' and
# re-exported by the pure-Python 'io' wrapper. Its class identity attributes:
#   BufferedWriter.__name__   == 'BufferedWriter'  (the class name)
#   BufferedWriter.__module__ == '_io'             (C extension, not 'io')
#
# Novel equality anchors in io_extra46 namespace. Both verified Python 3.14.
# ---------------------------------------------------------------------------

invariant io_extra46.BufferedWriter_name_eq:
  description: "io.BufferedWriter.__name__ == 'BufferedWriter' — C extension class from _io re-exported by io; novel equality anchor in io_extra46 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BufferedWriter.__name__.__eq__
  args: ["BufferedWriter"]
  expected: true

invariant io_extra46.BufferedWriter_module_eq:
  description: "io.BufferedWriter.__module__ == '_io' — BufferedWriter is implemented in the C extension '_io', not the pure-Python 'io' wrapper; novel equality in io_extra46 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BufferedWriter.__module__.__eq__
  args: ["_io"]
  expected: true

# ---------------------------------------------------------------------------
# io.BufferedWriter method qualname lengths: write and flush
#
# io_extra41 covers BufferedWriter.tell/seek/writable __qualname__.__len__().
# No prior io spec covers BufferedWriter.write or BufferedWriter.flush.
#
#   BufferedWriter.write.__qualname__ == 'BufferedWriter.write'  -> len 20
#   BufferedWriter.flush.__qualname__ == 'BufferedWriter.flush'  -> len 20
#
# Both are 20 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra46.BufferedWriter_method_qualname_lens:
  description: "io.BufferedWriter method __qualname__.__len__(): write(20)/flush(20) — io_extra41 covers tell/seek/writable but not write or flush; both are 20 chars ('BufferedWriter.write'/'BufferedWriter.flush'); novel"
  kind: python_call_eq
  category: method_identity
  id_prefix: bwmql46

  columns: [id, function, args, expected]
  rows:
    - [write_qualname_len, BufferedWriter.write.__qualname__.__len__, [], 20]
    - [flush_qualname_len, BufferedWriter.flush.__qualname__.__len__, [], 20]

# ---------------------------------------------------------------------------
# io.BufferedReader class identity: __name__ and __module__
#
# BufferedReader is also implemented in the C extension '_io'. Its identity:
#   BufferedReader.__name__   == 'BufferedReader'  (the class name)
#   BufferedReader.__module__ == '_io'             (C extension)
#
# Novel equality anchors in io_extra46 namespace. Both verified Python 3.14.
# ---------------------------------------------------------------------------

invariant io_extra46.BufferedReader_name_eq:
  description: "io.BufferedReader.__name__ == 'BufferedReader' — C extension class from _io re-exported by io; novel equality anchor in io_extra46 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__name__.__eq__
  args: ["BufferedReader"]
  expected: true

invariant io_extra46.BufferedReader_module_eq:
  description: "io.BufferedReader.__module__ == '_io' — BufferedReader is implemented in the C extension '_io', not the pure-Python 'io' wrapper; novel equality in io_extra46 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__module__.__eq__
  args: ["_io"]
  expected: true

# ---------------------------------------------------------------------------
# io.BufferedReader method qualname lengths: read and read1
#
# No prior io spec covers BufferedReader.read or BufferedReader.read1
# __qualname__.__len__(). read is the primary read method; read1 reads
# up to one buffer's worth without blocking for more.
#
#   BufferedReader.read.__qualname__  == 'BufferedReader.read'  -> len 19
#   BufferedReader.read1.__qualname__ == 'BufferedReader.read1' -> len 20
#
# read is 19 chars, read1 is 20. Novel. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra46.BufferedReader_method_qualname_lens:
  description: "io.BufferedReader method __qualname__.__len__(): read(19)/read1(20) — no prior io spec covers BufferedReader method qualname lengths; 'BufferedReader.read'==19, 'BufferedReader.read1'==20; novel"
  kind: python_call_eq
  category: method_identity
  id_prefix: brmql46

  columns: [id, function, args, expected]
  rows:
    - [read_qualname_len,  BufferedReader.read.__qualname__.__len__,  [], 19]
    - [read1_qualname_len, BufferedReader.read1.__qualname__.__len__, [], 20]

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE
#
# The default buffer size used by BufferedReader, BufferedWriter, etc.
# On Python 3.14 macOS/Darwin 25.4.0, DEFAULT_BUFFER_SIZE == 131072 (128 KiB).
#
# Prior specs note this constant exists but no prior io spec checks its
# integer value via equality. Novel direct equality check.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant io_extra46.DEFAULT_BUFFER_SIZE_eq:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 — the default buffer size (128 KiB) for buffered I/O classes on Python 3.14 macOS/Darwin 25.4.0; prior specs note this constant but no prior io spec checks its exact value via equality; novel"
  category: module_constant
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true
