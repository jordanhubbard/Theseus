spec: shelve_extra
version: ">=3.0"
backend: python_module(shelve)

docs: https://docs.python.org/3/library/shelve.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/shelve.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "shelve source: internal dbm backend implementation details"
  notes:
    - "This spec extends shelve.zspec.zsdl with additional identity invariants."
    - "Shelf.__name__ == 'Shelf' and Shelf.__module__ == 'shelve'."
    - "BsdDbShelf.__name__ == 'BsdDbShelf' — present in the shelve namespace even without bsddb3 installed."
    - "DbfilenameShelf.__name__ == 'DbfilenameShelf' — the default shelf returned by shelve.open()."
    - "open.__name__ == 'open' — the module-level factory function."
    - "All expected values verified by running Python 3.12 shelve module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class name metadata
# ---------------------------------------------------------------------------

invariant shelve_extra.classes.Shelf_name:
  description: "shelve.Shelf.__name__ == 'Shelf'"
  category: classes
  kind: python_call_eq
  function: Shelf.__name__.__eq__
  args: ["Shelf"]
  expected: true

invariant shelve_extra.classes.Shelf_module:
  description: "shelve.Shelf.__module__ == 'shelve'"
  category: classes
  kind: python_call_eq
  function: Shelf.__module__.__eq__
  args: ["shelve"]
  expected: true

invariant shelve_extra.classes.BsdDbShelf_name:
  description: "shelve.BsdDbShelf.__name__ == 'BsdDbShelf'"
  category: classes
  kind: python_call_eq
  function: BsdDbShelf.__name__.__eq__
  args: ["BsdDbShelf"]
  expected: true

invariant shelve_extra.classes.DbfilenameShelf_name:
  description: "shelve.DbfilenameShelf.__name__ == 'DbfilenameShelf'"
  category: classes
  kind: python_call_eq
  function: DbfilenameShelf.__name__.__eq__
  args: ["DbfilenameShelf"]
  expected: true

# ---------------------------------------------------------------------------
# Module-level function name metadata
# ---------------------------------------------------------------------------

invariant shelve_extra.functions.open_name:
  description: "shelve.open.__name__ == 'open'"
  category: functions
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true
