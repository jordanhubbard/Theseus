spec: functools_extra1861
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module reference"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, and callable type checks"
    - "functools_extra.zspec.zsdl — covers __name__, __module__ for public functools symbols"
  notes:
    - "Wave 571 theme: bitwise operators (__or__/__and__/__xor__/__lshift__/__rshift__/__invert__) and in-place operators (__iadd__/__imul__/__ior__/__iand__) and reflected operators (__radd__/__rmul__/__rsub__/__ror__/__rand__)."
    - "functools.partial.__dict__.__contains__('__or__') == False — partial is a C-level type; no bitwise protocol in its own __dict__."
    - "functools.cached_property.__dict__.__contains__('__or__') == False — cached_property is a Python class; no bitwise protocol."
    - "functools.partialmethod.__dict__.__contains__('__or__') == False — partialmethod is a Python class; no bitwise protocol."
    - "All functools types lack in-place and reflected operator dunders in their own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: bitwise operators for functools types
#
# functools.partial is a C-level type; functools.cached_property and
# functools.partialmethod are Python classes. None define bitwise dunder
# methods in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra1861.bitwise_operators:
  description: "Bitwise operator dunder methods absent from functools type own __dict__"
  kind: python_call_eq
  category: bitwise_operators
  id_prefix: fu1861

  columns: [id, function, args, expected]
  rows:
    - ["fu1861001", functools.partial.__dict__.__contains__,          ["__or__"],      false]
    - ["fu1861002", functools.partial.__dict__.__contains__,          ["__and__"],     false]
    - ["fu1861003", functools.partial.__dict__.__contains__,          ["__xor__"],     false]
    - ["fu1861004", functools.partial.__dict__.__contains__,          ["__lshift__"],  false]
    - ["fu1861005", functools.partial.__dict__.__contains__,          ["__rshift__"],  false]
    - ["fu1861006", functools.partial.__dict__.__contains__,          ["__invert__"],  false]
    - ["fu1861007", functools.cached_property.__dict__.__contains__,  ["__or__"],      false]
    - ["fu1861008", functools.partialmethod.__dict__.__contains__,    ["__or__"],      false]

# ---------------------------------------------------------------------------
# Table 2: in-place operators for functools types
#
# None of the functools types define in-place operator dunder methods in
# their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra1861.inplace_operators:
  description: "In-place operator dunder methods absent from functools type own __dict__"
  kind: python_call_eq
  category: inplace_operators
  id_prefix: fu1861

  columns: [id, function, args, expected]
  rows:
    - ["fu1861009", functools.partial.__dict__.__contains__,          ["__iadd__"], false]
    - ["fu1861010", functools.partial.__dict__.__contains__,          ["__imul__"], false]
    - ["fu1861011", functools.partial.__dict__.__contains__,          ["__isub__"], false]
    - ["fu1861012", functools.partial.__dict__.__contains__,          ["__ior__"],  false]
    - ["fu1861013", functools.partial.__dict__.__contains__,          ["__iand__"], false]
    - ["fu1861014", functools.cached_property.__dict__.__contains__,  ["__iadd__"], false]
    - ["fu1861015", functools.partialmethod.__dict__.__contains__,    ["__iadd__"], false]
    - ["fu1861016", functools.lru_cache.__dict__.__contains__,        ["__iadd__"], false]

# ---------------------------------------------------------------------------
# Table 3: reflected arithmetic operators for functools types
#
# None of the functools types define reflected operator dunder methods in
# their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra1861.reflected_operators:
  description: "Reflected arithmetic operator dunder methods absent from functools type own __dict__"
