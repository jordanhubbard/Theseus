  category: reflected_operators
  id_prefix: fu1861

  columns: [id, function, args, expected]
  rows:
    - ["fu1861017", functools.partial.__dict__.__contains__,          ["__radd__"], false]
    - ["fu1861018", functools.partial.__dict__.__contains__,          ["__rmul__"], false]
    - ["fu1861019", functools.partial.__dict__.__contains__,          ["__rsub__"], false]
    - ["fu1861020", functools.partial.__dict__.__contains__,          ["__ror__"],  false]
    - ["fu1861021", functools.partial.__dict__.__contains__,          ["__rand__"], false]
    - ["fu1861022", functools.cached_property.__dict__.__contains__,  ["__radd__"], false]
    - ["fu1861023", functools.partialmethod.__dict__.__contains__,    ["__radd__"], false]
