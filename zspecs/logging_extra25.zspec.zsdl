spec: logging_extra25
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging_extra22.zspec.zsdl — covers __mro__[-1].__name__ for nine major logging classes."
    - "logging_extra23.zspec.zsdl — covers __qualname__ for Logger.debug/info/warning/error/critical/exception, Handler.emit/handle, Formatter.format."
    - "logging_extra24.zspec.zsdl — covers __qualname__ for StreamHandler.emit, FileHandler.emit, NullHandler.emit, Filter.filter, LogRecord class and getMessage method, getLogger/basicConfig/makeLogRecord module-level functions."
  notes:
    - "This spec extends the logging chain through logging_extra24; it does NOT duplicate invariants in any prior spec."
    - "Focus: (1) logging.Handler.__qualname__ and __module__ — extra23 covers Handler.emit/handle method qualnames but not the Handler class __qualname__ or __module__; (2) logging.Handler.setLevel and Handler.format method __qualname__ values — no prior spec checks these; (3) logging.Formatter.__qualname__ and __module__ — no prior spec checks Formatter class-level attributes; (4) logging.Formatter.formatTime method __qualname__ — no prior spec checks this; (5) logging.StreamHandler and FileHandler __qualname__ and __bases__[0].__name__ — no prior spec checks these class-level attributes; (6) logging.LogRecord.__module__ — extra24 covers LogRecord.__qualname__.__eq__ but not __module__."
    - "logging.Handler.__qualname__ == 'Handler' — len 7. No prior spec checks Handler class __qualname__ as a standalone. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Handler.__module__ == 'logging' — len 7. No prior spec checks Handler.__module__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Handler.setLevel.__qualname__ == 'Handler.setLevel' — len 16. No prior spec checks this method. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Handler.format.__qualname__ == 'Handler.format' — len 14. No prior spec checks this method. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Formatter.__qualname__ == 'Formatter' — len 9. No prior spec checks Formatter class __qualname__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Formatter.__module__ == 'logging' — len 7. No prior spec checks Formatter.__module__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.Formatter.formatTime.__qualname__ == 'Formatter.formatTime' — len 20. No prior spec checks this method. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.StreamHandler.__qualname__ == 'StreamHandler' — len 13. No prior spec checks StreamHandler class __qualname__ as a standalone. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.StreamHandler.__bases__[0].__name__ == 'Handler' — StreamHandler inherits from Handler. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.FileHandler.__qualname__ == 'FileHandler' — len 11. No prior spec checks FileHandler class __qualname__ as a standalone. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.FileHandler.__bases__[0].__name__ == 'StreamHandler' — FileHandler inherits from StreamHandler. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "logging.LogRecord.__module__ == 'logging' — len 7. extra24 covers LogRecord.__qualname__.__eq__; no prior spec checks LogRecord.__module__. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# logging.Handler class __qualname__ and __module__
#
# logging_extra23 covers Handler.emit.__qualname__ and Handler.handle.__qualname__
# as method qualnames on the Handler class. No prior spec checks the Handler
# class itself for __qualname__ or __module__.
# Handler.__qualname__ == 'Handler' (len 7).
# Handler.__module__ == 'logging' (len 7).
# ---------------------------------------------------------------------------

invariant logging_extra25.Handler.qualname_eq:
  description: "logging.Handler.__qualname__ == 'Handler' — no prior spec checks Handler class __qualname__ as a standalone invariant"
  category: class_qualname
  kind: python_call_eq
  function: "Handler.__qualname__.__eq__"
  args: ["Handler"]
  expected: true

invariant logging_extra25.Handler.qualname_len:
  description: "len(logging.Handler.__qualname__) == 7 — len('Handler') == 7"
  category: class_qualname
  kind: python_call_eq
  function: "Handler.__qualname__.__len__"
  args: []
  expected: 7

invariant logging_extra25.Handler.module_eq:
  description: "logging.Handler.__module__ == 'logging' — no prior spec checks Handler.__module__"
  category: class_module
  kind: python_call_eq
  function: "Handler.__module__.__eq__"
  args: ["logging"]
  expected: true

# ---------------------------------------------------------------------------
# logging.Handler.setLevel and Handler.format method __qualname__ values
#
# logging_extra23 covers Handler.emit and Handler.handle. No prior spec checks
# Handler.setLevel or Handler.format.
# Handler.setLevel.__qualname__ == 'Handler.setLevel' (len 16).
# Handler.format.__qualname__ == 'Handler.format' (len 14).
# ---------------------------------------------------------------------------

invariant logging_extra25.Handler.setLevel.qualname_eq:
  description: "logging.Handler.setLevel.__qualname__ == 'Handler.setLevel' — no prior spec checks this method"
  category: method_qualname
  kind: python_call_eq
  function: "Handler.setLevel.__qualname__.__eq__"
  args: ["Handler.setLevel"]
  expected: true

invariant logging_extra25.Handler.setLevel.qualname_len:
  description: "len(logging.Handler.setLevel.__qualname__) == 16 — len('Handler.setLevel') == 16"
  category: method_qualname
  kind: python_call_eq
  function: "Handler.setLevel.__qualname__.__len__"
  args: []
  expected: 16

invariant logging_extra25.Handler.format.qualname_eq:
  description: "logging.Handler.format.__qualname__ == 'Handler.format' — no prior spec checks this method"
  category: method_qualname
  kind: python_call_eq
  function: "Handler.format.__qualname__.__eq__"
  args: ["Handler.format"]
  expected: true

invariant logging_extra25.Handler.format.qualname_len:
  description: "len(logging.Handler.format.__qualname__) == 14 — len('Handler.format') == 14"
  category: method_qualname
  kind: python_call_eq
  function: "Handler.format.__qualname__.__len__"
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# logging.Formatter class __qualname__, __module__, and formatTime method
#
# logging_extra23 covers Formatter.format.__qualname__ as a method qualname.
# No prior spec checks Formatter class __qualname__, __module__, or the
# Formatter.formatTime method.
# Formatter.__qualname__ == 'Formatter' (len 9).
# Formatter.__module__ == 'logging' (len 7).
# Formatter.formatTime.__qualname__ == 'Formatter.formatTime' (len 20).
# ---------------------------------------------------------------------------

invariant logging_extra25.Formatter.qualname_eq:
  description: "logging.Formatter.__qualname__ == 'Formatter' — no prior spec checks Formatter class __qualname__ as a standalone invariant"
  category: class_qualname
  kind: python_call_eq
  function: "Formatter.__qualname__.__eq__"
  args: ["Formatter"]
  expected: true

invariant logging_extra25.Formatter.qualname_len:
  description: "len(logging.Formatter.__qualname__) == 9 — len('Formatter') == 9"
  category: class_qualname
  kind: python_call_eq
  function: "Formatter.__qualname__.__len__"
  args: []
  expected: 9

invariant logging_extra25.Formatter.module_eq:
  description: "logging.Formatter.__module__ == 'logging' — no prior spec checks Formatter.__module__"
  category: class_module
  kind: python_call_eq
  function: "Formatter.__module__.__eq__"
  args: ["logging"]
  expected: true

invariant logging_extra25.Formatter.formatTime.qualname_eq:
  description: "logging.Formatter.formatTime.__qualname__ == 'Formatter.formatTime' — no prior spec checks this method"
  category: method_qualname
  kind: python_call_eq
  function: "Formatter.formatTime.__qualname__.__eq__"
  args: ["Formatter.formatTime"]
  expected: true

invariant logging_extra25.Formatter.formatTime.qualname_len:
  description: "len(logging.Formatter.formatTime.__qualname__) == 20 — len('Formatter.formatTime') == 20"
  category: method_qualname
  kind: python_call_eq
  function: "Formatter.formatTime.__qualname__.__len__"
  args: []
  expected: 20

# ---------------------------------------------------------------------------
# logging.StreamHandler and FileHandler class __qualname__ and
# __bases__[0].__name__
#
# logging_extra24 covers StreamHandler.emit.__qualname__ and
# FileHandler.emit.__qualname__ as method qualnames. No prior spec checks
# the class-level __qualname__ or inheritance chain for StreamHandler or
# FileHandler.
# StreamHandler.__qualname__ == 'StreamHandler' (len 13).
# StreamHandler.__bases__[0].__name__ == 'Handler' (inherits from Handler).
# FileHandler.__qualname__ == 'FileHandler' (len 11).
# FileHandler.__bases__[0].__name__ == 'StreamHandler' (inherits from StreamHandler).
# ---------------------------------------------------------------------------

table logging_extra25.handler_subclass_qualnames:
  description: "__qualname__.__eq__ for StreamHandler and FileHandler — no prior spec checks these class-level attributes"
  kind: python_call_eq
  category: class_qualname
  id_prefix: hscqn25

  columns: [id, function, args, expected]
  rows:
    - [StreamHandler, "StreamHandler.__qualname__.__eq__", ["StreamHandler"], true]
    - [FileHandler,   "FileHandler.__qualname__.__eq__",   ["FileHandler"],   true]

table logging_extra25.handler_subclass_qualname_lengths:
  description: "__qualname__.__len__() for StreamHandler and FileHandler"
  kind: python_call_eq
  category: class_qualname
  id_prefix: hscqlen25

  columns: [id, function, args, expected]
  rows:
    - [StreamHandler, "StreamHandler.__qualname__.__len__", [], 13]
    - [FileHandler,   "FileHandler.__qualname__.__len__",   [], 11]

invariant logging_extra25.StreamHandler.bases0_name_eq:
  description: "logging.StreamHandler.__bases__[0].__name__ == 'Handler' — StreamHandler inherits directly from Handler"
  category: class_hierarchy
  kind: python_call_eq
  "function": "StreamHandler.__bases__[0].__name__.__eq__"
  args: ["Handler"]
  expected: true

invariant logging_extra25.FileHandler.bases0_name_eq:
  description: "logging.FileHandler.__bases__[0].__name__ == 'StreamHandler' — FileHandler inherits from StreamHandler"
  category: class_hierarchy
  kind: python_call_eq
  "function": "FileHandler.__bases__[0].__name__.__eq__"
  args: ["StreamHandler"]
  expected: true

# ---------------------------------------------------------------------------
# logging.LogRecord.__module__
#
# logging_extra24 covers LogRecord.__qualname__.__eq__ == 'LogRecord' and
# LogRecord.getMessage.__qualname__. No prior spec checks LogRecord.__module__.
# LogRecord.__module__ == 'logging' (len 7).
# ---------------------------------------------------------------------------

invariant logging_extra25.LogRecord.module_eq:
  description: "logging.LogRecord.__module__ == 'logging' — extra24 covers LogRecord.__qualname__; no prior spec checks LogRecord.__module__"
  category: class_module
  kind: python_call_eq
  function: "LogRecord.__module__.__eq__"
  args: ["logging"]
  expected: true
