spec: io_extra28
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra9.zspec.zsdl — covers __qualname__ equality for all io classes (table rows); abstract base qualname lengths not covered there."
    - "io_extra26.zspec.zsdl — covers __qualname__ equality table for seven concrete classes."
    - "io_extra27.zspec.zsdl — covers UnsupportedOperation.__bases__, MRO, SEEK_* constants."
  notes:
    - "This spec extends io_extra27.zspec.zsdl."
    - "Focus: __qualname__ string lengths for io abstract base classes and concrete I/O classes."
    - "No prior io spec covers __qualname__.__len__() for any of these classes."
    - "io.IOBase.__qualname__.__len__() == 6 — 'IOBase' has 6 characters."
    - "io.RawIOBase.__qualname__.__len__() == 9 — 'RawIOBase' has 9 characters."
    - "io.BufferedIOBase.__qualname__.__len__() == 14 — 'BufferedIOBase' has 14 characters."
    - "io.TextIOBase.__qualname__.__len__() == 10 — 'TextIOBase' has 10 characters."
    - "io.FileIO.__qualname__.__len__() == 6 — 'FileIO' has 6 characters."
    - "io.BytesIO.__qualname__.__len__() == 7 — 'BytesIO' has 7 characters."
    - "io.StringIO.__qualname__.__len__() == 8 — 'StringIO' has 8 characters."
    - "io.BufferedReader.__qualname__.__len__() == 14 — 'BufferedReader' has 14 characters."
    - "io.BufferedWriter.__qualname__.__len__() == 14 — 'BufferedWriter' has 14 characters."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__ length for io abstract base classes
#
# io_extra9 covers __qualname__ equality for IOBase/RawIOBase/BufferedIOBase/
# TextIOBase but does not check __qualname__ lengths. This table anchors the
# character count for each abstract base qualname in the extra28 namespace.
# Verified: IOBase=6, RawIOBase=9, BufferedIOBase=14, TextIOBase=10.
# ---------------------------------------------------------------------------

table io_extra28.abstract_base_qualname_lengths:
  description: "__qualname__.__len__() for io abstract base classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: abql28

  columns: [id, function, args, expected]
  rows:
    - [IOBase,         IOBase.__qualname__.__len__,         [], 6]
    - [RawIOBase,      RawIOBase.__qualname__.__len__,      [], 9]
    - [BufferedIOBase, BufferedIOBase.__qualname__.__len__, [], 14]
    - [TextIOBase,     TextIOBase.__qualname__.__len__,     [], 10]

# ---------------------------------------------------------------------------
# Table: __qualname__ length for io concrete I/O classes
#
# io_extra26 covers __qualname__ equality for FileIO/BytesIO/StringIO/
# BufferedReader/BufferedWriter but does not check lengths. This table
# anchors the character count for each concrete class qualname.
# Verified: FileIO=6, BytesIO=7, StringIO=8, BufferedReader=14,
#           BufferedWriter=14.
# ---------------------------------------------------------------------------

table io_extra28.concrete_class_qualname_lengths:
  description: "__qualname__.__len__() for io concrete I/O classes"
  kind: python_call_eq
  category: class_identity
  id_prefix: ccql28

  columns: [id, function, args, expected]
  rows:
    - [FileIO,         FileIO.__qualname__.__len__,         [], 6]
    - [BytesIO,        BytesIO.__qualname__.__len__,        [], 7]
    - [StringIO,       StringIO.__qualname__.__len__,       [], 8]
    - [BufferedReader, BufferedReader.__qualname__.__len__, [], 14]
    - [BufferedWriter, BufferedWriter.__qualname__.__len__, [], 14]

# ---------------------------------------------------------------------------
# Standalone: IOBase __qualname__ length
#
# Standalone invariant anchors IOBase qualname length independently of the
# table above, for direct lookup in the extra28 namespace.
# ---------------------------------------------------------------------------

invariant io_extra28.IOBase.qualname_length:
  description: "io.IOBase.__qualname__.__len__() == 6 — 'IOBase' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: IOBase.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Standalone: BufferedIOBase __qualname__ length
#
# BufferedIOBase has the longest qualname among abstract bases (14 chars).
# Standalone invariant for independent lookup.
# ---------------------------------------------------------------------------

invariant io_extra28.BufferedIOBase.qualname_length:
  description: "io.BufferedIOBase.__qualname__.__len__() == 14 — 'BufferedIOBase' has 14 characters"
  category: class_identity
  kind: python_call_eq
  function: BufferedIOBase.__qualname__.__len__
  args: []
  expected: 14
