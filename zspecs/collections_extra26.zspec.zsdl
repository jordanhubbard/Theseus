spec: collections_extra26
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections_extra25.zspec.zsdl."
    - "collections_extra25 covers: __qualname__.__len__() for nine core collections classes."
    - "collections_extra24 covers: __qualname__.__eq__ for eight collections classes; __mro__.__len__() for six classes."
    - "No prior collections spec records __qualname__.__eq__ for class instance methods (OrderedDict.__setitem__, move_to_end, Counter.update, most_common, deque.append, appendleft, rotate, ChainMap.new_child) together in the extra26 namespace."
    - "Focus: __qualname__ values for eight instance methods across four collections classes."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — OrderedDict instance methods
#
# Verifies that OrderedDict.__setitem__ and move_to_end have nested qualnames
# of the form 'OrderedDict.<method>'. These are Python-level methods defined
# in Lib/collections/__init__.py.
# No prior collections spec records these method qualnames in the extra26 namespace.
# ---------------------------------------------------------------------------

table collections_extra26.ordereddict_method_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra26.ordereddict_method_qualnames.setitem,
       "OrderedDict.__setitem__.__qualname__.__eq__",
       ["OrderedDict.__setitem__"],
       true,
       "collections.OrderedDict.__setitem__.__qualname__ == 'OrderedDict.__setitem__'"]
    - [collections_extra26.ordereddict_method_qualnames.move_to_end,
       OrderedDict.move_to_end.__qualname__.__eq__,
       ["OrderedDict.move_to_end"],
       true,
       "collections.OrderedDict.move_to_end.__qualname__ == 'OrderedDict.move_to_end'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — Counter instance methods
#
# Verifies that Counter.update and Counter.most_common have nested qualnames
# of the form 'Counter.<method>'.
# No prior collections spec records these method qualnames in the extra26 namespace.
# ---------------------------------------------------------------------------

table collections_extra26.counter_method_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra26.counter_method_qualnames.update,
       Counter.update.__qualname__.__eq__,
       ["Counter.update"],
       true,
       "collections.Counter.update.__qualname__ == 'Counter.update'"]
    - [collections_extra26.counter_method_qualnames.most_common,
       Counter.most_common.__qualname__.__eq__,
       ["Counter.most_common"],
       true,
       "collections.Counter.most_common.__qualname__ == 'Counter.most_common'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ table — deque instance methods
#
# Verifies that deque.append, appendleft, and rotate have nested qualnames
# of the form 'deque.<method>'. These are C-level methods on the deque type.
# No prior collections spec records these method qualnames in the extra26 namespace.
# ---------------------------------------------------------------------------

table collections_extra26.deque_method_qualnames:
  kind: python_call_eq
  category: qualnames
  columns: [id, function, args, expected, description]
  rows:
    - [collections_extra26.deque_method_qualnames.append,
       deque.append.__qualname__.__eq__,
       ["deque.append"],
       true,
       "collections.deque.append.__qualname__ == 'deque.append'"]
    - [collections_extra26.deque_method_qualnames.appendleft,
       deque.appendleft.__qualname__.__eq__,
       ["deque.appendleft"],
       true,
       "collections.deque.appendleft.__qualname__ == 'deque.appendleft'"]
    - [collections_extra26.deque_method_qualnames.rotate,
       deque.rotate.__qualname__.__eq__,
       ["deque.rotate"],
       true,
       "collections.deque.rotate.__qualname__ == 'deque.rotate'"]

# ---------------------------------------------------------------------------
# ChainMap.new_child.__qualname__.__eq__ — standalone method qualname
#
# collections.ChainMap.new_child is a Python-level method. Its qualname is
# 'ChainMap.new_child', confirming it is defined directly within the ChainMap
# class scope.
# No prior collections spec records this in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra26.ChainMap.new_child.qualname:
  description: "collections.ChainMap.new_child.__qualname__ == 'ChainMap.new_child'"
  category: qualnames
  kind: python_call_eq
  function: ChainMap.new_child.__qualname__.__eq__
  args: ["ChainMap.new_child"]
  expected: true

# ---------------------------------------------------------------------------
# OrderedDict.__setitem__.__qualname__.__eq__ — standalone method qualname
#
# collections.OrderedDict.__setitem__ overrides the dict method at the
# Python level. Its qualname 'OrderedDict.__setitem__' confirms it belongs to
# OrderedDict's class scope.
# No prior collections spec records this standalone in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra26.OrderedDict.setitem.qualname:
  description: "collections.OrderedDict.__setitem__.__qualname__ == 'OrderedDict.__setitem__'"
  category: qualnames
  kind: python_call_eq
  function: "OrderedDict.__setitem__.__qualname__.__eq__"
  args: ["OrderedDict.__setitem__"]
  expected: true

# ---------------------------------------------------------------------------
# deque.rotate.__qualname__.__eq__ — standalone method qualname
#
# collections.deque.rotate is a C-level method on the deque type.
# Its qualname 'deque.rotate' reflects the enclosing C type name.
# No prior collections spec records this standalone in the extra26 namespace.
# ---------------------------------------------------------------------------

invariant collections_extra26.deque.rotate.qualname:
  description: "collections.deque.rotate.__qualname__ == 'deque.rotate'"
  category: qualnames
  kind: python_call_eq
  function: deque.rotate.__qualname__.__eq__
  args: ["deque.rotate"]
  expected: true
