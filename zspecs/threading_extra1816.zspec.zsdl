spec: threading_extra1816
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 568 (_extra1816): __format__ string formatting protocol; copy/pickle protocol; RLock/Timer/Thread method dict-presence checks for threading types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table threading_extra1816.format_protocol:
  description: "threading types __format__/__repr__/__str__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1816

  columns: [id, function, args, expected]
  rows:
    - ["th1816001", "threading.Thread.__dict__.__contains__", ["__format__"], false]
    - ["th1816002", "threading.Thread.__dict__.__contains__", ["__repr__"], true]
    - ["th1816003", "threading.Thread.__dict__.__contains__", ["__str__"], false]
    - ["th1816004", "threading.Event.__dict__.__contains__", ["__repr__"], false]
    - ["th1816005", "threading.Condition.__dict__.__contains__", ["__repr__"], true]
    - ["th1816006", "threading.Semaphore.__dict__.__contains__", ["__repr__"], false]
    - ["th1816007", "threading.Barrier.__dict__.__contains__", ["__repr__"], true]

table threading_extra1816.copy_protocol:
  description: "threading types __reduce__/__copy__/__deepcopy__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1816

  columns: [id, function, args, expected]
  rows:
    - ["th1816101", "threading.Thread.__dict__.__contains__", ["__reduce__"], false]
    - ["th1816102", "threading.Thread.__dict__.__contains__", ["__copy__"], false]
    - ["th1816103", "threading.Thread.__dict__.__contains__", ["__deepcopy__"], false]
    - ["th1816104", "threading.Lock.__class__.__dict__.__contains__", ["__reduce__"], false]
    - ["th1816105", "threading.Event.__dict__.__contains__", ["__reduce__"], false]
    - ["th1816106", "threading.Condition.__dict__.__contains__", ["__reduce__"], false]
    - ["th1816107", "threading.Semaphore.__dict__.__contains__", ["__reduce__"], false]
    - ["th1816108", "threading.Barrier.__dict__.__contains__", ["__reduce__"], false]

table threading_extra1816.rlock_attrs:
  description: "threading.Timer and threading.Thread method dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1816

  columns: [id, function, args, expected]
  rows:
    - ["th1816201", "threading.Timer.__dict__.__contains__", ["cancel"], true]
    - ["th1816202", "threading.Timer.__dict__.__contains__", ["run"], true]
    - ["th1816203", "threading.Timer.__dict__.__contains__", ["__init__"], true]
    - ["th1816204", "threading.Thread.__dict__.__contains__", ["__init__"], true]
    - ["th1816205", "threading.Thread.__dict__.__contains__", ["start"], true]
    - ["th1816206", "threading.Thread.__dict__.__contains__", ["run"], true]
    - ["th1816207", "threading.Thread.__dict__.__contains__", ["join"], true]
    - ["th1816208", "threading.Thread.__dict__.__contains__", ["is_alive"], true]
    - ["th1816209", "threading.Thread.__dict__.__contains__", ["isDaemon"], true]
    - ["th1816210", "threading.Thread.__dict__.__contains__", ["getName"], true]
