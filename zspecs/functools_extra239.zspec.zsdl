spec: functools_extra239
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools.cached_property identity and behavioral contracts."
    - "functools.cached_property.__name__ == 'cached_property' (len=15) — the class name. Verified with Python 3.14.3."
    - "functools.cached_property.__module__ == 'functools' — cached_property is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.cached_property.__qualname__ == 'cached_property' — top-level class with unqualified qualname. Verified with Python 3.14.3."
    - "functools.cached_property.__class__.__name__ == 'type' — cached_property is a Python class; its metaclass is the built-in type. Verified with Python 3.14.3."
    - "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits directly from object. Verified with Python 3.14.3."
    - "functools.cached_property.__set_name__.__name__ == '__set_name__' — __set_name__ is a method on cached_property. Verified with Python 3.14.3."
    - "functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__' — __set_name__ qualname carries the class prefix. Verified with Python 3.14.3."
    - "functools.cached_property.__get__.__name__ == '__get__' — __get__ is a descriptor protocol method on cached_property. Verified with Python 3.14.3."
    - "functools.cached_property.__get__.__qualname__ == 'cached_property.__get__' — __get__ qualname carries the class prefix. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.cached_property class identity contracts
#
# functools.cached_property.__name__ == 'cached_property' (len=15)
# functools.cached_property.__module__ == 'functools'
# functools.cached_property.__qualname__ == 'cached_property'
# functools.cached_property.__class__.__name__ == 'type'
# functools.cached_property.__bases__[0].__name__ == 'object'
#
# cached_property is a Python class in Lib/functools.py that is a non-data
# descriptor that computes and caches a property value on first access.
# New to extra239.
# ---------------------------------------------------------------------------

table functools_extra239.cached_property_class_identity:
  description: "functools.cached_property class identity contracts: name, module, qualname, metaclass, base; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra239cpclassid

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_name_eq,
       cached_property.__name__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__name__.__eq__('cached_property') == True — cached_property is the class in Lib/functools.py that computes and caches a property on first access; __name__ is 'cached_property' (len=15); new to extra239"]
    - [cached_property_name_len_15,
       cached_property.__name__.__len__,
       [],
       15,
       "functools.cached_property.__name__.__len__() == 15 — 'cached_property' has exactly 15 characters (c-a-c-h-e-d-_-p-r-o-p-e-r-t-y); str.__len__() returns 15; new to extra239"]
    - [cached_property_module_eq,
       cached_property.__module__.__eq__,
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — cached_property is defined in Lib/functools.py; __module__ is 'functools' (len=9); new to extra239"]
    - [cached_property_qualname_eq,
       cached_property.__qualname__.__eq__,
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__.__eq__('cached_property') == True — cached_property is a top-level class with unqualified qualname 'cached_property'; new to extra239"]
    - [cached_property_class_is_type,
       cached_property.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a Python class; its metaclass is the built-in type; __class__.__name__ is 'type'; new to extra239"]

# ---------------------------------------------------------------------------
# Table 2: functools.cached_property base and __set_name__ method contracts
#
# functools.cached_property.__bases__[0].__name__ == 'object'
# functools.cached_property.__set_name__.__name__ == '__set_name__'
# functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__'
# functools.cached_property.__get__.__name__ == '__get__'
# functools.cached_property.__get__.__qualname__ == 'cached_property.__get__'
#
# cached_property inherits from object and implements descriptor protocol
# via __get__ and __set_name__. New to extra239.
# ---------------------------------------------------------------------------

table functools_extra239.cached_property_descriptor_methods:
  description: "functools.cached_property base is object; __set_name__ and __get__ method name and qualname contracts; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra239cpdescid

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_base_is_object,
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property inherits directly from object with no intermediate base; __bases__[0].__name__ is 'object'; new to extra239"]
    - [set_name_name_eq,
       cached_property.__set_name__.__name__.__eq__,
       ["__set_name__"],
       true,
       "functools.cached_property.__set_name__.__name__.__eq__('__set_name__') == True — __set_name__ is a method called when cached_property is assigned to a class attribute; __name__ is '__set_name__'; new to extra239"]
    - [set_name_qualname_eq,
       cached_property.__set_name__.__qualname__.__eq__,
       ["cached_property.__set_name__"],
       true,
       "functools.cached_property.__set_name__.__qualname__.__eq__('cached_property.__set_name__') == True — __set_name__ is a method of the cached_property class; its __qualname__ carries the class prefix; new to extra239"]
    - [get_name_eq,
       cached_property.__get__.__name__.__eq__,
       ["__get__"],
       true,
       "functools.cached_property.__get__.__name__.__eq__('__get__') == True — __get__ implements the descriptor protocol for cached_property, computing and caching the value; __name__ is '__get__'; new to extra239"]
    - [get_qualname_eq,
       cached_property.__get__.__qualname__.__eq__,
       ["cached_property.__get__"],
       true,
       "functools.cached_property.__get__.__qualname__.__eq__('cached_property.__get__') == True — __get__ is a method of the cached_property class; its __qualname__ carries the class prefix; new to extra239"]

# ---------------------------------------------------------------------------
# Table 3: functools.cached_property module length and mro contracts
#
# functools.cached_property.__module__.__len__() == 9
# functools.cached_property.__name__.__len__() == 15
# functools.cached_property.__mro__[0].__name__ == 'cached_property'
# functools.cached_property.__mro__[1].__name__ == 'object'
# functools.cached_property.__qualname__.__len__() == 15
#
# cached_property has a two-element MRO: itself and object. New to extra239.
# ---------------------------------------------------------------------------

table functools_extra239.cached_property_mro_lens:
  description: "functools.cached_property module length, name length, and MRO slot name contracts; new to extra239"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra239cpmroid

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_module_len_9,
       cached_property.__module__.__len__,
       [],
       9,
       "functools.cached_property.__module__.__len__() == 9 — 'functools' has exactly 9 characters (f-u-n-c-t-o-o-l-s); str.__len__() returns 9; new to extra239"]
    - [cached_property_qualname_len_15,
       cached_property.__qualname__.__len__,
       [],
       15,
       "functools.cached_property.__qualname__.__len__() == 15 — 'cached_property' has exactly 15 characters; str.__len__() returns 15; new to extra239"]
    - [cached_property_mro0_eq,
       "cached_property.__mro__[0].__name__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__mro__[0].__name__.__eq__('cached_property') == True — cached_property MRO slot 0 is the class itself; __mro__[0].__name__ is 'cached_property'; new to extra239"]
    - [cached_property_mro1_eq,
       "cached_property.__mro__[1].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__mro__[1].__name__.__eq__('object') == True — cached_property MRO slot 1 is object; __mro__[1].__name__ is 'object'; new to extra239"]
    - [cached_property_class_name_is_type,
       cached_property.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property metaclass is the built-in type (repeated in mro table for coverage); new to extra239"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra239
# ---------------------------------------------------------------------------

invariant functools_extra239.cached_property_name_eq:
  description: "functools.cached_property.__name__ == 'cached_property' (len=15); new to extra239"
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra239.cached_property_name_len_15:
  description: "functools.cached_property.__name__.__len__() == 15 — 'cached_property' has 15 characters; new to extra239"
  kind: python_call_eq
  function: cached_property.__name__.__len__
  args: []
  expected: 15

invariant functools_extra239.cached_property_module_eq:
  description: "functools.cached_property.__module__ == 'functools'; new to extra239"
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra239.cached_property_qualname_eq:
  description: "functools.cached_property.__qualname__ == 'cached_property'; new to extra239"
  kind: python_call_eq
  function: cached_property.__qualname__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra239.cached_property_class_is_type:
  description: "functools.cached_property.__class__.__name__ == 'type'; new to extra239"
  kind: python_call_eq
  function: cached_property.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra239.cached_property_base_is_object:
  description: "functools.cached_property.__bases__[0].__name__ == 'object'; new to extra239"
  kind: python_call_eq
  function: "cached_property.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra239.set_name_name_eq:
  description: "functools.cached_property.__set_name__.__name__ == '__set_name__'; new to extra239"
  kind: python_call_eq
  function: cached_property.__set_name__.__name__.__eq__
  args: ["__set_name__"]
  expected: true

invariant functools_extra239.set_name_qualname_eq:
  description: "functools.cached_property.__set_name__.__qualname__ == 'cached_property.__set_name__'; new to extra239"
  kind: python_call_eq
  function: cached_property.__set_name__.__qualname__.__eq__
  args: ["cached_property.__set_name__"]
  expected: true

invariant functools_extra239.get_name_eq:
  description: "functools.cached_property.__get__.__name__ == '__get__'; new to extra239"
  kind: python_call_eq
  function: cached_property.__get__.__name__.__eq__
  args: ["__get__"]
  expected: true

invariant functools_extra239.get_qualname_eq:
  description: "functools.cached_property.__get__.__qualname__ == 'cached_property.__get__'; new to extra239"
  kind: python_call_eq
  function: cached_property.__get__.__qualname__.__eq__
  args: ["cached_property.__get__"]
  expected: true

invariant functools_extra239.cached_property_module_len_9:
  description: "functools.cached_property.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra239"
  kind: python_call_eq
  function: cached_property.__module__.__len__
  args: []
  expected: 9

invariant functools_extra239.cached_property_mro0_eq:
  description: "functools.cached_property.__mro__[0].__name__ == 'cached_property'; new to extra239"
  kind: python_call_eq
  function: "cached_property.__mro__[0].__name__.__eq__"
  args: ["cached_property"]
  expected: true

invariant functools_extra239.cached_property_mro1_eq:
  description: "functools.cached_property.__mro__[1].__name__ == 'object'; new to extra239"
  kind: python_call_eq
  function: "cached_property.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true
