spec: struct_extra2491
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra.zspec.zsdl — covers Struct format/size attrs, calcsize extra formats, pack_into, unpack_from, iter_unpack, error class"
  notes:
    - "Wave extra2491, theme: __setitem__, __delitem__, and __missing__ dict-presence."
    - "Checks whether struct.Struct defines mutable item access or missing-key protocol in its class __dict__."
    - "struct.Struct is an immutable compiled struct object; it defines __setattr__ and __delattr__ to block attribute mutation but has no item-access protocol."
    - "struct.Struct.__dict__ contains: __delattr__, __doc__, __getattribute__, __init__, __module__, __new__, __repr__, __setattr__, __sizeof__, format, iter_unpack, pack, pack_into, size, unpack, unpack_from."
    - "__setattr__ and __delattr__ ARE in Struct.__dict__ (blocking attribute changes), but __setitem__ and __delitem__ are NOT — these are subscript-access protocols distinct from attribute protocols."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct — __setitem__ absent from class __dict__
# Struct is not a mutable mapping; no subscript-assignment protocol is defined.
# (Struct defines __setattr__ for attribute access, not __setitem__ for subscript.)
# ---------------------------------------------------------------------------

table struct_extra2491.Struct_setitem_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2491

  columns: [id, function, args, expected]
  rows:
    - ["st2491001", Struct.__dict__.__contains__, ["__setitem__"], false]

# ---------------------------------------------------------------------------
# struct.Struct — __delitem__ absent from class __dict__
# Subscript deletion protocol is not defined on struct.Struct.
# (Struct defines __delattr__ for attribute deletion, not __delitem__ for subscript.)
# ---------------------------------------------------------------------------

table struct_extra2491.Struct_delitem_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2491

  columns: [id, function, args, expected]
  rows:
    - ["st2491002", Struct.__dict__.__contains__, ["__delitem__"], false]

# ---------------------------------------------------------------------------
# struct.Struct — __missing__ absent from class __dict__
# Missing-key fallback protocol is not defined on struct.Struct.
# ---------------------------------------------------------------------------

table struct_extra2491.Struct_missing_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2491

  columns: [id, function, args, expected]
  rows:
    - ["st2491003", Struct.__dict__.__contains__, ["__missing__"], false]

# ---------------------------------------------------------------------------
# struct.Struct — __getitem__ also absent (related sanity check)
# Confirms Struct defines no subscript read protocol either.
# ---------------------------------------------------------------------------

table struct_extra2491.Struct_getitem_absent:
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2491

  columns: [id, function, args, expected]
  rows:
    - ["st2491004", Struct.__dict__.__contains__, ["__getitem__"], false]

# ---------------------------------------------------------------------------
# struct.Struct — attribute-level protocols present vs absent
# __setattr__ and __delattr__ ARE present (blocking attribute mutation);
# confirms distinction between attribute and item protocols.
# ---------------------------------------------------------------------------

table struct_extra2491.Struct_attr_protocols:
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2491

  columns: [id, function, args, expected]
  rows:
    - ["st2491005", Struct.__dict__.__contains__, ["__setattr__"],      true]
    - ["st2491006", Struct.__dict__.__contains__, ["__delattr__"],      true]
    - ["st2491007", Struct.__dict__.__contains__, ["__getattribute__"], true]

# ---------------------------------------------------------------------------
# struct.Struct — real packing methods present in __dict__ (positive anchors)
# Verifies that __dict__.__contains__ works correctly for Struct.
# ---------------------------------------------------------------------------

table struct_extra2491.Struct_real_methods_present:
  kind: python_call_eq
  category: dict_presence
  id_prefix: st2491

  columns: [id, function, args, expected]
  rows:
    - ["st2491008", Struct.__dict__.__contains__, ["pack"],        true]
    - ["st2491009", Struct.__dict__.__contains__, ["unpack"],      true]
    - ["st2491010", Struct.__dict__.__contains__, ["pack_into"],   true]
    - ["st2491011", Struct.__dict__.__contains__, ["unpack_from"], true]
    - ["st2491012", Struct.__dict__.__contains__, ["iter_unpack"], true]
    - ["st2491013", Struct.__dict__.__contains__, ["format"],      true]
    - ["st2491014", Struct.__dict__.__contains__, ["size"],        true]
    - ["st2491015", Struct.__dict__.__contains__, ["__init__"],    true]
    - ["st2491016", Struct.__dict__.__contains__, ["__new__"],     true]
    - ["st2491017", Struct.__dict__.__contains__, ["__repr__"],    true]
