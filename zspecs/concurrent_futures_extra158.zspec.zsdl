# concurrent.futures._base.Executor.__module__.__eq__('concurrent.futures._base') == True
# concurrent.futures._base.Executor.__bases__[0].__name__.__eq__('object')  == True
# ---------------------------------------------------------------------------

table concurrent_futures_extra158.cf_executor_class_identity:
  description: "concurrent.futures._base.Executor class identity checks in cfexid158 namespace — concurrent.futures._base.Executor.__name__=='Executor' (len=8: 'E'+'x'+'e'+'c'+'u'+'t'+'o'+'r'=8; the abstract base class for concurrent task executors; defines submit(), map(), shutdown(), __enter__(), __exit__(); concrete subclasses must implement submit()); concurrent.futures._base.Executor.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24; accessing via the private _base submodule gives the actual implementation module name); concurrent.futures._base.Executor.__bases__[0].__name__=='object' (len=6; Executor inherits directly from object — it is the abstract root, not a subclass of any asyncio or other framework class); Executor.__name__.__len__()==8; compare: ThreadPoolExecutor.__name__.__len__()==18 (10 longer: 'Thread'=6+'Pool'=4=10 prefix added); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexid158

  columns: [id, function, args, expected, description]
  rows:
    - [exec_name_eq,   concurrent.futures._base.Executor.__name__.__eq__,                ["Executor"],                  true,  "cf._base.Executor.__name__ == 'Executor' (len=8; abstract base class for executors); verified with Python 3.14.3"]
    - [exec_mod_eq,    concurrent.futures._base.Executor.__module__.__eq__,               ["concurrent.futures._base"],  true,  "cf._base.Executor.__module__ == 'concurrent.futures._base' (len=24; private implementation submodule); verified with Python 3.14.3"]
    - [exec_base_eq,   "concurrent.futures._base.Executor.__bases__[0].__name__.__eq__",  ["object"],                    true,  "cf._base.Executor.__bases__[0].__name__ == 'object' (Executor inherits from object directly); verified with Python 3.14.3"]
    - [exec_name_len,  concurrent.futures._base.Executor.__name__.__len__,                [],                            8,     "cf._base.Executor.__name__.__len__() == 8 ('Executor'; 10 shorter than ThreadPoolExecutor=18); verified with Python 3.14.3"]

