invariant concurrent_futures_extra158.cf_Executor_name_eq:
  description: "concurrent.futures._base.Executor.__name__.__eq__('Executor') returns True — concurrent.futures._base.Executor is the abstract base class for the concurrent.futures executor hierarchy; Executor.__name__=='Executor' (len=8: 'E'+'x'+'e'+'c'+'u'+'t'+'o'+'r'=8); Executor is the root class — all executor classes (ThreadPoolExecutor, ProcessPoolExecutor) inherit from it; Executor.__module__=='concurrent.futures._base' (len=24; private _base submodule); Executor.__bases__[0].__name__=='object' (inherits from object directly); Executor.__dict__ contains: submit, map, __enter__, __exit__, shutdown (all defined on Executor); compare: ThreadPoolExecutor.__name__.__len__()==18 (10 longer: 'ThreadPool'=10 prefix); ProcessPoolExecutor.__name__.__len__()==19 (11 longer: 'ProcessPool'=11 prefix); NEW in extra158: first standalone cf._base.Executor.__name__ identity invariant in cfexid158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Executor.__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra158.cf_Executor_module_eq:
  description: "concurrent.futures._base.Executor.__module__.__eq__('concurrent.futures._base') returns True — Executor is defined in Lib/concurrent/futures/_base.py; accessing the class via the private _base submodule directly gives __module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24); this is the same module string that concurrent.futures.wait.__module__ returns (established in extra157) because wait() and Executor are both defined in _base.py; the public API re-exports Executor as concurrent.futures.Executor but the class's own __module__ always reflects its defining module 'concurrent.futures._base'; NEW in extra158: first standalone cf._base.Executor.__module__ identity invariant via _base submodule access in cfexid158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Executor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra158.cf_Executor_base_is_object:
  description: "concurrent.futures._base.Executor.__bases__[0].__name__.__eq__('object') returns True — Executor inherits directly from object; __bases__[0].__name__=='object' (len=6); Executor does NOT inherit from any asyncio class, threading class, or other framework; it is a standalone pure Python abstract base class that defines the executor protocol; although Executor provides submit() as an abstract method (raises NotImplementedError), it does NOT use abc.ABCMeta — the abstractness is conventional rather than enforced; compare: abc.ABC.__bases__[0].__name__=='object' (abc.ABC also inherits from object — same pattern for abstract base helpers); Executor.__bases__[0].__name__=='object' confirms Executor is the root of the concurrent.futures class hierarchy; NEW in extra158: first standalone cf._base.Executor.__bases__[0].__name__ identity invariant in cfexid158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures._base.Executor.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra158.cf_Executor_dict_has_submit:
  description: "concurrent.futures._base.Executor.__dict__.__contains__('submit') returns True — submit is defined directly on Executor (in Executor.__dict__); Executor.submit raises NotImplementedError when called directly — it is the abstract method that concrete executors must override; submit.__qualname__=='Executor.submit' (len=15: established in extra156); Executor.__dict__.__contains__('submit')==True confirms submit is a directly-defined method (not inherited from object or any other class); compare: concurrent.futures._base.Executor.__dict__.__contains__('map')==True (map is also directly defined on Executor); Executor.__dict__.__contains__('__enter__')==True and Executor.__dict__.__contains__('__exit__')==True (context manager methods are also directly on Executor); NEW in extra158: first standalone Executor.__dict__.__contains__('submit') invariant in cfexdict158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Executor.__dict__.__contains__
  args: ["submit"]
  expected: true

invariant concurrent_futures_extra158.cf_Executor_dict_has_map:
  description: "concurrent.futures._base.Executor.__dict__.__contains__('map') returns True — map is defined directly on Executor (in Executor.__dict__); Executor.map is a concrete implementation that uses submit() internally to apply a function to each item of an iterable and returns a lazy iterator of results; map.__qualname__=='Executor.map' (len=12: established in extra156); the fact that map is in Executor.__dict__ means it is defined on Executor itself — NOT inherited from object; ThreadPoolExecutor does NOT override map (TPE.map.__qualname__=='Executor.map') while ProcessPoolExecutor DOES override map (PPE.map.__qualname__=='ProcessPoolExecutor.map' — established in extra156); Executor.__dict__.__contains__('map')==True confirms map is available directly on the abstract base; NEW in extra158: first standalone Executor.__dict__.__contains__('map') invariant in cfexdict158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures._base.Executor.__dict__.__contains__
  args: ["map"]
  expected: true

