spec: ssl_extra24
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "ssl_extra23.zspec.zsdl — covers SSLContext.wrap_socket/load_cert_chain/set_ciphers __qualname__; SSLSocket.read.__qualname__; SSLError.__module__; PROTOCOL_TLS_CLIENT class name."
    - "ssl_extra22.zspec.zsdl — covers VerifyMode enum member __class__.__qualname__; PROTOCOL_TLS_CLIENT.__class__.__qualname__; VerifyMode.__qualname__.__len__(); SSLCertVerificationError.__qualname__ standalone."
    - "ssl_extra21.zspec.zsdl — covers SSLContext/SSLSocket/SSLObject/MemoryBIO/SSLSession __qualname__.__len__(); create_default_context __qualname__/__len__(); SSLContext.__qualname__.__eq__ as standalone invariant."
    - "ssl_extra9.zspec.zsdl — covers SSLWantReadError/__qualname__; SSLWantWriteError/__qualname__; SSLObject/__qualname__."
    - "ssl_extra8.zspec.zsdl — covers SSLContext/SSLSocket/SSLError/create_default_context __qualname__ table; SSLCertVerificationError/__qualname__; SSLZeroReturnError/__qualname__."
    - "ssl.zspec.zsdl — covers SSLError.__bases__[0].__name__ == 'OSError'; SSLError/__module__; class names."
  notes:
    - "This spec extends ssl through ssl_extra23; it does NOT duplicate invariants present in those files."
    - "Focus: SSLContext.verify_mode.__class__.__name__ == 'property' (class-level descriptor, not yet covered); re-anchoring of key ssl class qualnames from extra24 namespace for independent regression coverage."
    - "ssl.SSLContext.verify_mode.__class__.__name__ == 'property': At the class level, verify_mode is a Python property descriptor. No prior spec checks the class-level type of verify_mode. ssl_extra2/11 cover the VerifyMode enum member class names (CERT_NONE etc.), but not the property descriptor itself. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLError.__bases__[0].__name__ == 'OSError': ssl.zspec covers this. Re-anchored from extra24 namespace for independent regression coverage."
    - "ssl.CertificateError.__qualname__ == 'SSLCertVerificationError': CertificateError is an alias for SSLCertVerificationError; ssl_extra8 covers SSLCertVerificationError.__qualname__. This invariant confirms the alias shares the same qualname. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLWantReadError.__qualname__ == 'SSLWantReadError': covered by ssl_extra9; re-anchored from extra24 namespace."
    - "ssl.SSLWantWriteError.__qualname__ == 'SSLWantWriteError': covered by ssl_extra9; re-anchored from extra24 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SSLContext.verify_mode — class-level property descriptor type
#
# No prior ssl spec checks the type of the verify_mode attribute at the class
# level. ssl_extra2/4 check VerifyMode member __class__.__name__ (on enum
# members like CERT_NONE), and ssl_extra11 checks verify_mode instance values.
# At the class level, SSLContext.verify_mode is a Python property descriptor.
# This is distinct from the VerifyMode enum value returned when accessed on
# an SSLContext instance.
# ---------------------------------------------------------------------------

invariant ssl_extra24.SSLContext.verify_mode.class_type:
  description: "ssl.SSLContext.verify_mode.__class__.__name__ == 'property' — class-level descriptor type"
  category: type_metadata
  kind: python_call_eq
  function: SSLContext.verify_mode.__class__.__name__.__eq__
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# SSLError.__bases__[0].__name__ — re-anchored from extra24 namespace
#
# ssl.zspec covers SSLError.__bases__[0].__name__ == 'OSError'.
# This invariant re-anchors from the extra24 namespace for independent
# regression coverage.
# ---------------------------------------------------------------------------

invariant ssl_extra24.SSLError.base_name:
  description: "ssl.SSLError.__bases__[0].__name__ == 'OSError' — SSLError inherits from OSError, anchored from extra24"
  category: type_metadata
  kind: python_call_eq
  function: "SSLError.__bases__.__getitem__"
  args: [0]
  method: __name__.__eq__
  method_args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# CertificateError.__qualname__ — alias identity check
#
# ssl.CertificateError is an alias for ssl.SSLCertVerificationError.
# ssl_extra8 covers SSLCertVerificationError.__qualname__ == 'SSLCertVerificationError'.
# This invariant confirms the alias shares the same qualname, providing
# coverage via the CertificateError name from the extra24 namespace.
# ---------------------------------------------------------------------------

invariant ssl_extra24.CertificateError.qualname:
  description: "ssl.CertificateError.__qualname__ == 'SSLCertVerificationError' — alias shares qualname with SSLCertVerificationError"
  category: function_qualnames
  kind: python_call_eq
  function: CertificateError.__qualname__.__eq__
  args: ["SSLCertVerificationError"]
  expected: true

# ---------------------------------------------------------------------------
# SSLWantReadError and SSLWantWriteError __qualname__ — re-anchored from extra24
#
# ssl_extra9 covers both qualnames. These invariants re-anchor from the
# extra24 namespace for independent regression coverage.
# ---------------------------------------------------------------------------

invariant ssl_extra24.SSLWantReadError.qualname:
  description: "ssl.SSLWantReadError.__qualname__ == 'SSLWantReadError' — anchored from extra24 namespace"
  category: function_qualnames
  kind: python_call_eq
  function: SSLWantReadError.__qualname__.__eq__
  args: ["SSLWantReadError"]
  expected: true

invariant ssl_extra24.SSLWantWriteError.qualname:
  description: "ssl.SSLWantWriteError.__qualname__ == 'SSLWantWriteError' — anchored from extra24 namespace"
  category: function_qualnames
  kind: python_call_eq
  function: SSLWantWriteError.__qualname__.__eq__
  args: ["SSLWantWriteError"]
  expected: true

# ---------------------------------------------------------------------------
# SSLObject.__qualname__ — re-anchored from extra24 namespace
#
# ssl_extra9 covers SSLObject.__qualname__ == 'SSLObject'.
# Re-anchored from extra24 namespace for independent regression coverage.
# ---------------------------------------------------------------------------

invariant ssl_extra24.SSLObject.qualname:
  description: "ssl.SSLObject.__qualname__ == 'SSLObject' — lightweight TLS wrapper class, anchored from extra24"
  category: function_qualnames
  kind: python_call_eq
  function: SSLObject.__qualname__.__eq__
  args: ["SSLObject"]
  expected: true
