spec: hashlib_extra219
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "verified with Python 3.14.3."
    - "hashlib.md5().__class__.__name__ == 'HASH' — the hash object returned by md5() uses the HASH type name on CPython/OpenSSL builds."
    - "hashlib.md5().update.__class__.__name__ == 'builtin_function_or_method' — hash object methods are C builtins."
    - "hashlib.md5().digest.__class__.__name__ == 'builtin_function_or_method'."
    - "hashlib.md5().hexdigest.__class__.__name__ == 'builtin_function_or_method'."
    - "hashlib.md5().copy.__class__.__name__ == 'builtin_function_or_method'."
    - "hashlib.new.__name__ == '__hash_new' — the module attribute 'new' is bound to an internal wrapper named __hash_new."
    - "hashlib.new.__qualname__ == '__hash_new'."
    - "hashlib.file_digest.__name__ == 'file_digest'; hashlib.file_digest.__qualname__ == 'file_digest'."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac'; hashlib.pbkdf2_hmac.__qualname__ == 'pbkdf2_hmac'."
    - "'sha3_256' in hashlib.algorithms_guaranteed == True; 'blake2b' in hashlib.algorithms_guaranteed == True."
    - "'sha3_512' in hashlib.algorithms_guaranteed == True; 'shake_256' in hashlib.algorithms_guaranteed == True."
    - "hashlib.sha256().name == 'sha256'; hashlib.sha256().digest_size == 32; hashlib.sha256().block_size == 64."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Hash object method class names — md5 instance methods are C builtins
#
# hashlib.md5().update.__class__.__name__   == 'builtin_function_or_method'
# hashlib.md5().digest.__class__.__name__   == 'builtin_function_or_method'
# hashlib.md5().hexdigest.__class__.__name__ == 'builtin_function_or_method'
# hashlib.md5().copy.__class__.__name__     == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table hashlib_extra219.hash_method_class_names:
  description: "hashlib hash object method class names in hashlib219 namespace — wave 219 theme: md5 hash object methods update/digest/hexdigest/copy are all builtin_function_or_method; hash object methods are implemented in C and exposed as builtins on the HASH object; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: hashlib219

  columns: [id, function, args, expected, description]
  rows:
    - [update_class,    "hashlib.md5().update.__class__.__name__.__eq__",    ["builtin_function_or_method"],  true,  "hashlib.md5().update.__class__.__name__ == 'builtin_function_or_method' — update is a C builtin method"]
    - [digest_class,    "hashlib.md5().digest.__class__.__name__.__eq__",    ["builtin_function_or_method"],  true,  "hashlib.md5().digest.__class__.__name__ == 'builtin_function_or_method' — digest is a C builtin method"]
    - [hexdigest_class, "hashlib.md5().hexdigest.__class__.__name__.__eq__", ["builtin_function_or_method"],  true,  "hashlib.md5().hexdigest.__class__.__name__ == 'builtin_function_or_method' — hexdigest is a C builtin method"]
    - [copy_class,      "hashlib.md5().copy.__class__.__name__.__eq__",      ["builtin_function_or_method"],  true,  "hashlib.md5().copy.__class__.__name__ == 'builtin_function_or_method' — copy is a C builtin method"]

# ---------------------------------------------------------------------------
# hashlib module-level function name and qualname checks
#
# hashlib.new.__name__          == '__hash_new'
# hashlib.new.__qualname__      == '__hash_new'
# hashlib.file_digest.__name__  == 'file_digest'
# hashlib.pbkdf2_hmac.__name__  == 'pbkdf2_hmac'
# ---------------------------------------------------------------------------

table hashlib_extra219.module_function_names:
  description: "hashlib module-level function name and qualname checks in hashlib219a namespace — wave 219 theme: hashlib.new is internally named __hash_new; file_digest and pbkdf2_hmac retain their plain names; function __name__ and __qualname__ reveal the internal implementation names; verified with Python 3.14.3"
  kind: python_call_eq
  category: function_identity
  id_prefix: hashlib219a

  columns: [id, function, args, expected, description]
  rows:
    - [new_name,           "hashlib.new.__name__.__eq__",           ["__hash_new"],  true,  "hashlib.new.__name__ == '__hash_new' — the 'new' attribute is bound to the internal __hash_new wrapper"]
    - [new_qualname,       "hashlib.new.__qualname__.__eq__",       ["__hash_new"],  true,  "hashlib.new.__qualname__ == '__hash_new' — qualname also reflects the internal wrapper name"]
    - [file_digest_name,   "hashlib.file_digest.__name__.__eq__",   ["file_digest"], true,  "hashlib.file_digest.__name__ == 'file_digest' — file_digest retains its plain function name"]
    - [pbkdf2_hmac_name,   "hashlib.pbkdf2_hmac.__name__.__eq__",   ["pbkdf2_hmac"], true,  "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' — pbkdf2_hmac retains its plain function name"]

# ---------------------------------------------------------------------------
# algorithms_guaranteed — SHA3 and SHAKE membership
#
# 'sha3_256' in hashlib.algorithms_guaranteed  == True
# 'blake2b' in hashlib.algorithms_guaranteed   == True
# 'sha3_512' in hashlib.algorithms_guaranteed  == True
# 'shake_256' in hashlib.algorithms_guaranteed == True
# ---------------------------------------------------------------------------

table hashlib_extra219.algorithms_guaranteed_sha3_shake:
  description: "hashlib.algorithms_guaranteed SHA3/SHAKE/BLAKE2 membership in hashlib219b namespace — wave 219 theme: sha3_256, blake2b, sha3_512, shake_256 are all present in algorithms_guaranteed on conforming Python builds; these algorithms are mandated in FIPS 202 and RFC 7693; verified with Python 3.14.3"
  kind: python_call_eq
  category: algorithms
  id_prefix: hashlib219b

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_256_in_guaranteed,  "hashlib.algorithms_guaranteed.__contains__",  ["sha3_256"],   true,  "'sha3_256' in hashlib.algorithms_guaranteed — FIPS 202 SHA3-256 must be present"]
    - [blake2b_in_guaranteed,   "hashlib.algorithms_guaranteed.__contains__",  ["blake2b"],    true,  "'blake2b' in hashlib.algorithms_guaranteed — RFC 7693 BLAKE2b must be present"]
    - [sha3_512_in_guaranteed,  "hashlib.algorithms_guaranteed.__contains__",  ["sha3_512"],   true,  "'sha3_512' in hashlib.algorithms_guaranteed — FIPS 202 SHA3-512 must be present"]
    - [shake_256_in_guaranteed, "hashlib.algorithms_guaranteed.__contains__",  ["shake_256"],  true,  "'shake_256' in hashlib.algorithms_guaranteed — FIPS 202 SHAKE-256 must be present"]

# ---------------------------------------------------------------------------
# Hash object class name and key attribute checks
#
# hashlib.md5().__class__.__name__ == 'HASH'
# hashlib.sha256().name == 'sha256'
# hashlib.sha256().digest_size == 32
# ---------------------------------------------------------------------------

invariant hashlib_extra219.md5_hash_class_name:
  description: "hashlib.md5().__class__.__name__ == 'HASH' — the hash object returned by md5() is an instance of the HASH type on CPython/OpenSSL builds; the exact class name is 'HASH' as reported by __class__.__name__; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: "hashlib.md5().__class__.__name__.__eq__"
  args: ["HASH"]
  expected: true

invariant hashlib_extra219.sha256_name_attr:
  description: "hashlib.sha256().name == 'sha256' — the .name attribute of a SHA-256 hash object is the canonical algorithm name string 'sha256'; this is the same name accepted by hashlib.new(); verified with Python 3.14.3"
  category: attributes
  kind: python_call_eq
  function: "hashlib.sha256().name.__eq__"
  args: ["sha256"]
  expected: true

invariant hashlib_extra219.sha256_digest_size_attr:
  description: "hashlib.sha256().digest_size == 32 — SHA-256 produces 256-bit (32-byte) digests; the .digest_size attribute on the hash object reflects this; consistent with FIPS 180-4; verified with Python 3.14.3"
  category: attributes
  kind: python_call_eq
  function: "hashlib.sha256().digest_size.__eq__"
  args: [32]
  expected: true

invariant hashlib_extra219.sha256_block_size_attr:
  description: "hashlib.sha256().block_size == 64 — SHA-256 operates on 512-bit (64-byte) blocks; the .block_size attribute on the hash object reflects the internal compression block size; consistent with FIPS 180-4; verified with Python 3.14.3"
  category: attributes
  kind: python_call_eq
  function: "hashlib.sha256().block_size.__eq__"
  args: [64]
  expected: true
