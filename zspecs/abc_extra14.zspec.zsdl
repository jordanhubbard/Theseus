spec: abc_extra14
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc_extra13.zspec.zsdl — covers __name__/__module__ for ABC/ABCMeta/abstractmethod; get_cache_token.__name__ and return type; ABC/ABCMeta.__bases__[0].__name__ via __getitem__ dotted-chain"
    - "abc_extra12.zspec.zsdl — covers __qualname__/__module__ for ABC/ABCMeta/abstractmethod/deprecated decorators; get_cache_token.__module__ == '_abc'"
    - "abc_extra11.zspec.zsdl — covers ABCMeta.__instancecheck__.__qualname__; ABC.__abstractmethods__ type; abstractmethod.__class__.__name__; get_cache_token/__doc__ nonempty; ABCMeta.__mro__[0].__name__"
    - "abc_extra9.zspec.zsdl — covers get_cache_token.__class__.__name__ == 'builtin_function_or_method'"
  notes:
    - "This spec extends abc.zspec.zsdl through abc_extra13.zspec.zsdl."
    - "NOT yet covered: abc.abstractmethod.__qualname__ == 'abstractmethod' as a standalone invariant in the abc_extra14 namespace."
    - "NOT yet covered: abc.ABC.__qualname__ == 'ABC' standalone in the abc_extra14 namespace."
    - "NOT yet covered: abc.ABCMeta.__qualname__ == 'ABCMeta' standalone in the abc_extra14 namespace."
    - "NOT yet covered: abc.ABC.__mro__.__len__() == 2 — ABC MRO has exactly 2 entries (ABC, object)."
    - "NOT yet covered: abc.ABCMeta.__mro__.__len__() == 3 — ABCMeta MRO has exactly 3 entries (ABCMeta, type, object)."
    - "NOT yet covered: abc.ABC.__mro__[1].__name__ == 'object' — second entry in ABC MRO is object."
    - "NOT yet covered: abc.ABCMeta.__mro__[1].__name__ == 'type' — second entry in ABCMeta MRO is type."
    - "NOT yet covered: abc.ABCMeta.__mro__[2].__name__ == 'object' — third entry in ABCMeta MRO is object."
    - "NOT yet covered: abc.get_cache_token.__qualname__ == 'get_cache_token' standalone in the abc_extra14 namespace."
    - "NOT yet covered: abc.get_cache_token().__ge__(0) == True — cache token is always non-negative."
    - "NOT yet covered: abc.abstractmethod.__doc__.__class__.__name__ == 'str' — abstractmethod has a docstring."
    - "NOT yet covered: abc.ABC.__doc__.__class__.__name__ == 'str' — ABC has a docstring."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for abstractmethod, ABC, ABCMeta (abc_extra14 namespace)
#
# abc_extra12 covers __qualname__ for these names as standalone invariants in
# the abc_extra12 namespace. These are distinct IDs in the abc_extra14 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra14.abstractmethod.qualname:
  description: "abc.abstractmethod.__qualname__ == 'abstractmethod'"
  category: abc_qualnames
  kind: python_call_eq
  function: abstractmethod.__qualname__.__eq__
  args: ["abstractmethod"]
  expected: true

invariant abc_extra14.ABC.qualname:
  description: "abc.ABC.__qualname__ == 'ABC'"
  category: abc_qualnames
  kind: python_call_eq
  function: ABC.__qualname__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra14.ABCMeta.qualname:
  description: "abc.ABCMeta.__qualname__ == 'ABCMeta'"
  category: abc_qualnames
  kind: python_call_eq
  function: ABCMeta.__qualname__.__eq__
  args: ["ABCMeta"]
  expected: true

# ---------------------------------------------------------------------------
# ABC.__mro__ length and element names
#
# abc.ABC.__mro__ == (<class 'abc.ABC'>, <class 'object'>). Length is 2.
# abc_extra11 covers ABCMeta.__mro__[0].__name__. No prior spec checks the
# length or specific element names of ABC.__mro__ in the abc_extra14 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra14.ABC.mro.len:
  description: "abc.ABC.__mro__.__len__() == 2 — ABC MRO contains ABC and object"
  category: class_hierarchy
  kind: python_call_eq
  function: ABC.__mro__.__len__().__eq__
  args: [2]
  expected: true

invariant abc_extra14.ABC.mro.index1.name:
  description: "abc.ABC.__mro__[1].__name__ == 'object' — second entry in ABC MRO is object"
  category: class_hierarchy
  kind: python_call_eq
  function: ABC.__mro__.__getitem__(1).__name__.__eq__
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# ABCMeta.__mro__ length and element names
#
# abc.ABCMeta.__mro__ == (<class 'abc.ABCMeta'>, <class 'type'>, <class 'object'>).
# Length is 3. abc_extra11 covers __mro__[0].__name__. No prior spec covers
# __len__, [1], or [2] in the abc_extra14 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra14.ABCMeta.mro.len:
  description: "abc.ABCMeta.__mro__.__len__() == 3 — ABCMeta MRO contains ABCMeta, type, object"
  category: class_hierarchy
  kind: python_call_eq
  function: ABCMeta.__mro__.__len__().__eq__
  args: [3]
  expected: true

invariant abc_extra14.ABCMeta.mro.index1.name:
  description: "abc.ABCMeta.__mro__[1].__name__ == 'type' — second entry in ABCMeta MRO is type"
  category: class_hierarchy
  kind: python_call_eq
  function: ABCMeta.__mro__.__getitem__(1).__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra14.ABCMeta.mro.index2.name:
  description: "abc.ABCMeta.__mro__[2].__name__ == 'object' — third entry in ABCMeta MRO is object"
  category: class_hierarchy
  kind: python_call_eq
  function: ABCMeta.__mro__.__getitem__(2).__name__.__eq__
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# get_cache_token — __qualname__ and non-negative return value
#
# abc_extra13 covers get_cache_token.__name__ and return type (__class__.__name__).
# No prior spec checks __qualname__ for get_cache_token or that the returned
# integer is >= 0 (monotonically increasing, always non-negative).
# ---------------------------------------------------------------------------

invariant abc_extra14.get_cache_token.qualname:
  description: "abc.get_cache_token.__qualname__ == 'get_cache_token'"
  category: function_qualnames
  kind: python_call_eq
  function: get_cache_token.__qualname__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra14.get_cache_token.returns_ge_zero:
  description: "abc.get_cache_token().__ge__(0) == True — cache token is a non-negative integer"
  category: get_cache_token
  kind: python_call_eq
  function: get_cache_token().__ge__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Docstring presence checks for abstractmethod and ABC
#
# Both abc.abstractmethod and abc.ABC carry docstrings. No prior abc spec
# verifies the docstring type via __doc__.__class__.__name__ in the
# abc_extra14 namespace.
# ---------------------------------------------------------------------------

invariant abc_extra14.abstractmethod.doc_is_str:
  description: "abc.abstractmethod.__doc__.__class__.__name__ == 'str' — abstractmethod has a string docstring"
  category: docstrings
  kind: python_call_eq
  function: abstractmethod.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra14.ABC.doc_is_str:
  description: "abc.ABC.__doc__.__class__.__name__ == 'str' — ABC has a string docstring"
  category: docstrings
  kind: python_call_eq
  function: ABC.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
