spec: immutable
version: ">=4.0.0"
backend: node(immutable)

docs: https://immutable-js.com/

provenance:
  derived_from:
    - "Immutable.js documentation — https://immutable-js.com/"
    - "Test vectors verified with immutable via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "immutable source"
  notes:
    - "Immutable.js (Facebook) — persistent data structures. Map, List, Set, OrderedMap, Stack, Record."
    - "Install: npm install immutable"
    - "Mutating methods (.set, .delete, .push) return NEW instances; the original is unchanged. The chain primitive captures this naturally — each step gives a new value of the result of the previous."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure persistent operations; never throw on standard usage."
  stderr: "null"
  stickiness: "N/A — values are immutable."
  codes: {}

# Map — persistent map operations
table immutable.Map:
  kind: node_chain_eq
  category: Map
  entry: named
  function: Map
  id_prefix: map

  columns: [id, entry_args, chain, expected]
  rows:
    - [get_existing,
       [{a: 1, b: 2}],
       [{method: get, args: ["a"]}],
       1]

    - [get_missing,
       [{a: 1}],
       [{method: get, args: ["missing"]}],
       ~]

    - [size,
       [{a: 1, b: 2, c: 3}],
       [{get: size}],
       3]

    - [has,
       [{a: 1, b: 2}],
       [{method: has, args: ["b"]}],
       true]

    - [has_missing,
       [{a: 1}],
       [{method: has, args: ["zzz"]}],
       false]

    - [set_then_get,
       [{a: 1}],
       [{method: set, args: ["b", 2]}, {method: get, args: ["b"]}],
       2]

    - [delete_then_size,
       [{a: 1, b: 2}],
       [{method: delete, args: ["a"]}, {get: size}],
       1]

    - [merge_size,
       [{a: 1}],
       [{method: merge, args: [{b: 2, c: 3}]}, {get: size}],
       3]

# List — persistent list operations
table immutable.List:
  kind: node_chain_eq
  category: List
  entry: named
  function: List
  id_prefix: list

  columns: [id, entry_args, chain, expected]
  rows:
    - [size,
       [[1, 2, 3]],
       [{get: size}],
       3]

    - [first,
       [[1, 2, 3]],
       [{method: first, args: []}],
       1]

    - [last,
       [[1, 2, 3]],
       [{method: last, args: []}],
       3]

    - [get_index,
       [[10, 20, 30]],
       [{method: get, args: [1]}],
       20]

    - [push_then_size,
       [[1, 2]],
       [{method: push, args: [3]}, {get: size}],
       3]

    - [toJS,
       [[1, 2, 3]],
       [{method: toJS, args: []}],
       [1, 2, 3]]

# Set — persistent set operations
table immutable.Set:
  kind: node_chain_eq
  category: Set
  entry: named
  function: Set
  id_prefix: set

  columns: [id, entry_args, chain, expected]
  rows:
    - [size_dedupes,
       [[1, 2, 2, 3, 3, 3]],
       [{get: size}],
       3]

    - [has_member,
       [[1, 2, 3]],
       [{method: has, args: [2]}],
       true]

    - [has_non_member,
       [[1, 2, 3]],
       [{method: has, args: [99]}],
       false]

    - [add_then_size,
       [[1, 2]],
       [{method: add, args: [3]}, {get: size}],
       3]
