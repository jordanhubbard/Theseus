spec: jszip
version: ">=3.0.0"
backend: node(jszip)

docs: https://github.com/Stuk/jszip#readme

provenance:
  derived_from:
    - "JSZip docs — https://stuk.github.io/jszip/documentation/"
    - "Test vectors verified with jszip via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "JSZip source"
  notes:
    - "Create / read / write ZIP files in pure JS — works in Node and the browser."
    - "Install: npm install jszip"
    - "v3 CJS; require('jszip') is the JSZip class itself."
    - "Synchronous shape used here — the actual generateAsync / loadAsync I/O is async."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Constructor never throws; .file() throws on invalid path types."
  stderr: "null"
  stickiness: "N/A — each instance independent."
  codes: {}

invariant jszip.add_file_then_get_name:
  description: "After zip.file('hello.txt', 'Hello World'), zip.file('hello.txt').name is 'hello.txt'"
  category: file
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: file, args: ["hello.txt", "Hello World"]}
    - {method: file, args: ["hello.txt"]}
    - {get: name}
  expected: "hello.txt"

invariant jszip.add_file_dir_flag_false:
  description: "Plain file entry has dir === false"
  category: file
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: file, args: ["hello.txt", "Hello World"]}
    - {method: file, args: ["hello.txt"]}
    - {get: dir}
  expected: false

invariant jszip.add_file_to_subdir_creates_entry:
  description: "Adding 'dir/sub.txt' creates an entry named 'dir/sub.txt'"
  category: file
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: []
  chain:
    - {method: file, args: ["dir/sub.txt", "content"]}
    - {method: file, args: ["dir/sub.txt"]}
    - {get: name}
  expected: "dir/sub.txt"

invariant jszip.support_uint8array:
  description: "JSZip.support.uint8array is true on Node"
  category: support
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "support.uint8array"}
  expected: true

invariant jszip.support_nodebuffer:
  description: "JSZip.support.nodebuffer is true on Node"
  category: support
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "support.nodebuffer"}
  expected: true

invariant jszip.support_blob_typeof_boolean:
  description: "JSZip.support.blob is a boolean (true on Node 18+ with global Blob, false on older runtimes)"
  category: support
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "support.blob"}
    - {get: "constructor.name"}
  expected: "Boolean"

invariant jszip.version_present:
  description: "JSZip.version is '3.10.1' (current pinned major)"
  category: meta
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: version}
  expected: "3.10.1"
