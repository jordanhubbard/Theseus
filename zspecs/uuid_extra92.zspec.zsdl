spec: uuid_extra92
version: ">=3.9"
backend: python_module(uuid)
extends: uuid_extra91

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra91.zspec.zsdl — covers uuid.UUID.__init__/__str__/__repr__/__eq__/__hash__/__lt__/__int__ __qualname__.__len__() values / uuid1/uuid4 __qualname__.__len__() / qualname equality cross-checks (table + invariants)."
    - "uuid_extra90.zspec.zsdl — covers NAMESPACE_URL/OID/X500 __class__.__name__=='UUID' / NAMESPACE_* version==1 / RFC_4122/RESERVED_* __class__.__name__=='str' and __len__() / UUID.__class__.__name__=='type' (table + invariants)."
    - "uuid_extra89.zspec.zsdl — covers UUID.__hash__/__eq__/__int__/__lt__/__setattr__ __module__.__eq__('uuid') / UUID.fields.fget.__class__.__name__ and __qualname__ / getnode.__code__.co_name / uuid5.__module__ (table + invariants)."
    - "uuid_extra88.zspec.zsdl — covers UUID.__init__/__str__/__repr__ class names / UUID property hex/bytes/bytes_le/version/urn/variant fget class names and qualname equality (table + invariants)."
    - "uuid_extra87.zspec.zsdl — covers UUID.__setattr__/__delattr__ class names / UUID field property fget class names and qualnames (table + invariants)."
    - "uuid_extra86.zspec.zsdl — covers uuid.UUID.__init__/__code__/co_name/co_argcount/__qualname__ / uuid1/uuid4/uuid3/uuid5/getnode __qualname__/__module__/co_argcount (table + invariants)."
  notes:
    - "This spec extends uuid through uuid_extra91; it does NOT duplicate invariants present in those files."
    - "Wave 263 theme: uuid.UUID property fget.__code__.co_name equality for all properties / fget.__code__.co_argcount (all are 1) / fget.__code__.co_name.__len__() values."
    - "uuid.UUID.hex.fget.__code__.co_name == 'hex'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__code__.co_name == 'bytes'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.fget.__code__.co_name == 'bytes_le'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.fget.__code__.co_name == 'urn'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__code__.co_name == 'variant'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__code__.co_name == 'version'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__code__.co_name == 'fields'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__code__.co_name == 'time'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq.fget.__code__.co_name == 'clock_seq'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__code__.co_name == 'node'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All fget.__code__.co_argcount == 1 (self only). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.hex.fget.__code__.co_name.__len__() == 3 ('hex'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes.fget.__code__.co_name.__len__() == 5 ('bytes'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.bytes_le.fget.__code__.co_name.__len__() == 8 ('bytes_le'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.urn.fget.__code__.co_name.__len__() == 3 ('urn'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.variant.fget.__code__.co_name.__len__() == 7 ('variant'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.version.fget.__code__.co_name.__len__() == 7 ('version'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.fields.fget.__code__.co_name.__len__() == 6 ('fields'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.time.fget.__code__.co_name.__len__() == 4 ('time'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.clock_seq.fget.__code__.co_name.__len__() == 9 ('clock_seq'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.node.fget.__code__.co_name.__len__() == 4 ('node'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID.int is a member_descriptor (C slot), not a property — it has no .fget attribute and is excluded from this spec."
    - "Note: All UUID property fget functions take exactly 1 argument (self), as they are simple getters accessing the underlying _int slot."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__code__.co_name.__eq__('hex')
# uuid.UUID.bytes.fget.__code__.co_name.__eq__('bytes')
# uuid.UUID.bytes_le.fget.__code__.co_name.__eq__('bytes_le')
# uuid.UUID.urn.fget.__code__.co_name.__eq__('urn')
# uuid.UUID.variant.fget.__code__.co_name.__eq__('variant')
#
# Wave 263 theme: UUID property fget code.co_name equality — first five properties.
#
# For pure-Python property fget functions, the code object's co_name equals the
# function name, which equals the property name. UUID.hex.fget.__code__.co_name
# is 'hex', UUID.bytes.fget.__code__.co_name is 'bytes', etc. The co_name
# attribute of a code object gives the function's name as it appeared in the
# source. extra88 anchors fget.__class__.__name__ and __qualname__; extra86 anchors
# UUID.__init__.__code__.co_name; no prior spec anchors property fget co_name
# for hex/bytes/bytes_le/urn/variant under uuidfgetco92.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra92.uuid_property_fget_co_name_set1:
  description: "uuid.UUID.hex/fget/__code__/co_name/__eq__('hex')==True / bytes/fget/__code__/co_name/__eq__('bytes')==True / bytes_le/fget/__code__/co_name/__eq__('bytes_le')==True / urn/fget/__code__/co_name/__eq__('urn')==True / variant/fget/__code__/co_name/__eq__('variant')==True — co_name equals property name for all UUID fget functions; extra88 anchors __class__.__name__ and __qualname__; extra86 anchors UUID.__init__ co_name; first uuidfgetco92 anchor for property fget co_name equality"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidfgetco92

  columns: [id, function, args, expected, description]
  rows:
    - [hex_coname,      "UUID.hex.fget.__code__.co_name.__eq__",      ["hex"],      true, "UUID.hex.fget.__code__.co_name is 'hex'"]
    - [bytes_coname,    "UUID.bytes.fget.__code__.co_name.__eq__",    ["bytes"],    true, "UUID.bytes.fget.__code__.co_name is 'bytes'"]
    - [bytes_le_coname, "UUID.bytes_le.fget.__code__.co_name.__eq__", ["bytes_le"], true, "UUID.bytes_le.fget.__code__.co_name is 'bytes_le'"]
    - [urn_coname,      "UUID.urn.fget.__code__.co_name.__eq__",      ["urn"],      true, "UUID.urn.fget.__code__.co_name is 'urn'"]
    - [variant_coname,  "UUID.variant.fget.__code__.co_name.__eq__",  ["variant"],  true, "UUID.variant.fget.__code__.co_name is 'variant'"]

# ---------------------------------------------------------------------------
# uuid.UUID.version.fget.__code__.co_name.__eq__('version')
# uuid.UUID.fields.fget.__code__.co_name.__eq__('fields')
# uuid.UUID.time.fget.__code__.co_name.__eq__('time')
# uuid.UUID.clock_seq.fget.__code__.co_name.__eq__('clock_seq')
# uuid.UUID.node.fget.__code__.co_name.__eq__('node')
#
# Wave 263 theme: UUID property fget code.co_name equality — second five properties.
#
# Continuing the co_name equality anchors for the remaining UUID properties.
# version/fields/time/clock_seq/node are all pure-Python property fget functions
# whose code objects carry the property name as co_name. extra88 anchors version
# fget __qualname__; extra89 anchors fields fget __qualname__; the time/clock_seq/node
# properties were first covered in extra87 for __class__.__name__ and __qualname__.
# No prior spec anchors co_name for these five under uuidfgetco92.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra92.uuid_property_fget_co_name_set2:
  description: "uuid.UUID.version/fget/__code__/co_name/__eq__('version')==True / fields/fget/__code__/co_name/__eq__('fields')==True / time/fget/__code__/co_name/__eq__('time')==True / clock_seq/fget/__code__/co_name/__eq__('clock_seq')==True / node/fget/__code__/co_name/__eq__('node')==True — co_name equals property name; extra88 anchors version fget qualname; extra89 anchors fields fget qualname; extra87 anchors time/clock_seq/node fget class names; first uuidfgetco92 anchor for co_name equality for these five"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidfgetco92

  columns: [id, function, args, expected, description]
  rows:
    - [version_coname,   "UUID.version.fget.__code__.co_name.__eq__",   ["version"],   true, "UUID.version.fget.__code__.co_name is 'version'"]
    - [fields_coname,    "UUID.fields.fget.__code__.co_name.__eq__",    ["fields"],    true, "UUID.fields.fget.__code__.co_name is 'fields'"]
    - [time_coname,      "UUID.time.fget.__code__.co_name.__eq__",      ["time"],      true, "UUID.time.fget.__code__.co_name is 'time'"]
    - [clock_seq_coname, "UUID.clock_seq.fget.__code__.co_name.__eq__", ["clock_seq"], true, "UUID.clock_seq.fget.__code__.co_name is 'clock_seq'"]
    - [node_coname,      "UUID.node.fget.__code__.co_name.__eq__",      ["node"],      true, "UUID.node.fget.__code__.co_name is 'node'"]

# ---------------------------------------------------------------------------
# fget.__code__.co_argcount == 1 for all UUID properties
# and fget.__code__.co_name.__len__() values
#
# Wave 263 theme: UUID property fget co_argcount (all 1) and co_name lengths.
#
# All UUID property fget functions take exactly 1 argument (self), since they
# are simple getters. Their co_name lengths vary: 'hex'/'urn' (3), 'time'/'node'
# (4), 'bytes' (5), 'fields' (6), 'variant'/'version' (7), 'bytes_le' (8),
# 'clock_seq' (9). No prior spec anchors co_argcount or co_name.__len__() for
# UUID properties under uuidfgetco92. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra92.uuid_property_fget_co_argcount_and_name_lens:
  description: "uuid.UUID.hex/fget/__code__/co_argcount==1 / urn/co_argcount==1 / bytes/co_argcount==1 / clock_seq/co_argcount==1 / hex/fget/__code__/co_name/__len__()==3 / urn/co_name/__len__()==3 / bytes/co_name/__len__()==5 / bytes_le/co_name/__len__()==8 / clock_seq/co_name/__len__()==9 — all fget take 1 arg (self); co_name lengths vary by property name length; first uuidfgetco92 anchor for co_argcount and co_name lengths"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidfgetco92

  columns: [id, function, args, expected, description]
  rows:
    - [hex_argc,         "UUID.hex.fget.__code__.co_argcount.__eq__",      [1], true, "UUID.hex.fget takes 1 arg (self only)"]
    - [bytes_argc,       "UUID.bytes.fget.__code__.co_argcount.__eq__",    [1], true, "UUID.bytes.fget takes 1 arg (self only)"]
    - [clock_seq_argc,   "UUID.clock_seq.fget.__code__.co_argcount.__eq__", [1], true, "UUID.clock_seq.fget takes 1 arg (self only)"]
    - [hex_colen,        "UUID.hex.fget.__code__.co_name.__len__",         [], 3,  "'hex' is 3 chars"]
    - [urn_colen,        "UUID.urn.fget.__code__.co_name.__len__",         [], 3,  "'urn' is 3 chars"]
    - [bytes_colen,      "UUID.bytes.fget.__code__.co_name.__len__",       [], 5,  "'bytes' is 5 chars"]
    - [fields_colen,     "UUID.fields.fget.__code__.co_name.__len__",      [], 6,  "'fields' is 6 chars"]
    - [bytes_le_colen,   "UUID.bytes_le.fget.__code__.co_name.__len__",    [], 8,  "'bytes_le' is 8 chars"]
    - [clock_seq_colen,  "UUID.clock_seq.fget.__code__.co_name.__len__",   [], 9,  "'clock_seq' is 9 chars"]

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__code__.co_name.__eq__('hex') — standalone
#
# uuid.UUID.hex.fget.__code__.co_name is 'hex'. UUID.hex is a property that
# returns a 32-character lowercase hexadecimal string representation of the UUID
# (without hyphens). Its fget is a pure-Python function whose code object's
# co_name attribute equals the function name 'hex', which is also the property
# name. co_name is the name of the function as it appears in the source code.
# extra88 anchors hex.fget.__class__.__name__=='function' and __qualname__==
# 'UUID.hex'; no prior spec anchors hex.fget.__code__.co_name as a standalone
# under uuidfgetco92. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra92.uuid_hex_fget_co_name_hex:
  description: "uuid.UUID.hex.fget.__code__.co_name.__eq__('hex') == True — UUID.hex property returns 32-char lowercase hex string (no hyphens); fget is a pure-Python function whose code object co_name is 'hex' (the function/property name in source); extra88 anchors __class__.__name__=='function' and __qualname__=='UUID.hex'; first standalone for hex.fget.__code__.co_name under uuidfgetco92"
  category: code_attrs
  kind: python_call_eq
  function: "UUID.hex.fget.__code__.co_name.__eq__"
  args: ["hex"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.clock_seq.fget.__code__.co_name.__eq__('clock_seq') — standalone
#
# uuid.UUID.clock_seq.fget.__code__.co_name is 'clock_seq'. clock_seq is the
# clock sequence field of a version-1 UUID, used to avoid duplicates when the
# clock is set backward or the node identifier changes. Its fget function's
# code object co_name is 'clock_seq' (9 chars), the longest co_name among all
# UUID properties. extra87 anchors clock_seq.fget.__qualname__; no prior spec
# anchors clock_seq.fget.__code__.co_name as a standalone under uuidfgetco92.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra92.uuid_clock_seq_fget_co_name:
  description: "uuid.UUID.clock_seq.fget.__code__.co_name.__eq__('clock_seq') == True — clock_seq is the clock sequence field used in version-1 UUIDs to avoid collisions; its fget co_name is 'clock_seq' (9 chars), the longest co_name among all UUID properties; extra87 anchors __qualname__; first standalone for clock_seq.fget.__code__.co_name under uuidfgetco92"
  category: code_attrs
  kind: python_call_eq
  function: "UUID.clock_seq.fget.__code__.co_name.__eq__"
  args: ["clock_seq"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.hex.fget.__code__.co_argcount == 1 — standalone
#
# uuid.UUID.hex.fget.__code__.co_argcount is 1. All UUID property getter functions
# (fget) take exactly one argument — self — because they are simple read-only
# attribute accessors. The co_argcount attribute counts positional arguments
# including self (but not *args or **kwargs). For all UUID properties, this
# value is 1, reflecting the standard getter signature 'def hex(self): ...'.
# extra86 anchors UUID.__init__.__code__.co_argcount==7; no prior spec anchors
# any UUID property fget co_argcount as a standalone under uuidfgetco92.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra92.uuid_hex_fget_co_argcount_1:
  description: "uuid.UUID.hex.fget.__code__.co_argcount.__eq__(1) == True — all UUID property fget functions take exactly 1 argument (self); co_argcount counts positional args including self; standard getter signature 'def hex(self)'; extra86 anchors UUID.__init__ co_argcount==7; first standalone for UUID property fget co_argcount under uuidfgetco92"
  category: code_attrs
  kind: python_call_eq
  function: "UUID.hex.fget.__code__.co_argcount.__eq__"
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.bytes_le.fget.__code__.co_name.__len__()==8 — standalone
#
# uuid.UUID.bytes_le.fget.__code__.co_name.__len__() is 8. bytes_le returns the
# UUID as a 16-byte string in little-endian byte order (the first three fields
# are in little-endian order, as used by COM/DCOM on Windows). Its co_name is
# 'bytes_le' (8 chars): 'bytes' (5) + '_le' (3). This is the only UUID property
# name containing an underscore, making it unique in the set. extra88 anchors
# bytes_le.fget.__qualname__; no prior spec anchors bytes_le.fget.__code__.co_name
# .__len__()==8 as a standalone under uuidfgetco92.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra92.uuid_bytes_le_fget_co_name_len_8:
  description: "uuid.UUID.bytes_le.fget.__code__.co_name.__len__() == 8 — bytes_le returns UUID as 16-byte little-endian string (COM/DCOM byte order); co_name is 'bytes_le' (8 chars): 'bytes' (5) + '_le' (3); the only UUID property name with an underscore; extra88 anchors __qualname__; first standalone for bytes_le.fget.__code__.co_name.__len__() under uuidfgetco92"
  category: code_attrs
  kind: python_call_eq
  function: "UUID.bytes_le.fget.__code__.co_name.__len__"
  args: []
  expected: 8
