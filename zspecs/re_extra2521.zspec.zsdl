spec: re_extra2521
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "Wave 2521 theme: __bool__, __index__, __int__ dict-presence in re classes."
    - "Neither re.Pattern nor re.Match defines __bool__, __int__, or __index__ in its own __dict__."
    - "re.Pattern and re.Match are C-implemented types (_sre.SRE_Pattern, _sre.SRE_Match internally)."
    - "re.Pattern defines comparison operators (__eq__, __hash__, __lt__, __le__, __ne__, __gt__, __ge__) and copy support (__copy__, __deepcopy__)."
    - "re.Match defines __getitem__ (for subscript access to match groups) but no numeric protocol."
    - "re.RegexFlag is an IntFlag enum subclass; it does NOT define its own __bool__, __int__, or __index__ in re.RegexFlag.__dict__ — these are inherited from IntFlag/int."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __bool__ dict-presence — Pattern and Match define no truthiness override
# ---------------------------------------------------------------------------

table re_extra2521.bool_protocol:
  description: "__bool__ is absent from re.Pattern and re.Match __dict__s — regex objects use default object truthiness"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2521

  columns: [id, function, args, expected]
  rows:
    - ["re2521001", "re.Pattern.__dict__.__contains__", ["__bool__"], false]
    - ["re2521002", "re.Match.__dict__.__contains__",   ["__bool__"], false]

# ---------------------------------------------------------------------------
# __int__ dict-presence — Pattern and Match define no integer coercion
# ---------------------------------------------------------------------------

table re_extra2521.int_protocol:
  description: "__int__ is absent from re.Pattern and re.Match __dict__s — regex objects cannot be coerced to int"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2521

  columns: [id, function, args, expected]
  rows:
    - ["re2521003", "re.Pattern.__dict__.__contains__", ["__int__"], false]
    - ["re2521004", "re.Match.__dict__.__contains__",   ["__int__"], false]

# ---------------------------------------------------------------------------
# __index__ dict-presence — Pattern and Match define no indexing protocol
# ---------------------------------------------------------------------------

table re_extra2521.index_protocol:
  description: "__index__ is absent from re.Pattern and re.Match __dict__s — regex objects cannot be used as sequence indices"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2521

  columns: [id, function, args, expected]
  rows:
    - ["re2521005", "re.Pattern.__dict__.__contains__", ["__index__"], false]
    - ["re2521006", "re.Match.__dict__.__contains__",   ["__index__"], false]

# ---------------------------------------------------------------------------
# re.RegexFlag — also lacks __bool__, __int__, __index__ in its own __dict__
# ---------------------------------------------------------------------------

table re_extra2521.regexflag_numeric:
  description: "re.RegexFlag.__dict__ does not define __bool__, __int__, or __index__ — inherited from IntFlag/int"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2521

  columns: [id, function, args, expected]
  rows:
    - ["re2521007", "re.RegexFlag.__dict__.__contains__", ["__bool__"],  false]
    - ["re2521008", "re.RegexFlag.__dict__.__contains__", ["__int__"],   false]
    - ["re2521009", "re.RegexFlag.__dict__.__contains__", ["__index__"], false]

# ---------------------------------------------------------------------------
# Pattern comparison protocol — present in __dict__ (contrast with absent numeric protocol)
# ---------------------------------------------------------------------------

table re_extra2521.pattern_comparison_protocol:
  description: "re.Pattern defines comparison operators in its __dict__ — confirming which protocol IS present"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2521

  columns: [id, function, args, expected]
  rows:
    - ["re2521010", "re.Pattern.__dict__.__contains__", ["__eq__"],          true]
    - ["re2521011", "re.Pattern.__dict__.__contains__", ["__hash__"],        true]
    - ["re2521012", "re.Pattern.__dict__.__contains__", ["__repr__"],        true]
    - ["re2521013", "re.Pattern.__dict__.__contains__", ["__copy__"],        true]
    - ["re2521014", "re.Pattern.__dict__.__contains__", ["__deepcopy__"],    true]
    - ["re2521015", "re.Pattern.__dict__.__contains__", ["__class_getitem__"], true]

# ---------------------------------------------------------------------------
# Match subscript protocol — __getitem__ present, but no numeric protocol
# ---------------------------------------------------------------------------

table re_extra2521.match_subscript_protocol:
  description: "re.Match defines __getitem__ for group subscript access, but no numeric coercion methods"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2521

  columns: [id, function, args, expected]
  rows:
    - ["re2521016", "re.Match.__dict__.__contains__", ["__getitem__"],     true]
    - ["re2521017", "re.Match.__dict__.__contains__", ["__repr__"],        true]
    - ["re2521018", "re.Match.__dict__.__contains__", ["__copy__"],        true]
    - ["re2521019", "re.Match.__dict__.__contains__", ["__class_getitem__"], true]
    - ["re2521020", "re.Match.__dict__.__contains__", ["__deepcopy__"],    true]
