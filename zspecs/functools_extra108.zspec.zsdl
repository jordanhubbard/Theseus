spec: functools_extra108
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra107

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra107.zspec.zsdl."
    - "This spec covers: functools class __qualname__ string values and lengths for partial, partialmethod, singledispatchmethod, cached_property, lru_cache, cache, total_ordering, reduce, and cmp_to_key; wave 260."
    - "functools.partial.__qualname__ == 'partial' (len 7). Verified with Python 3.14.3."
    - "functools.partialmethod.__qualname__ == 'partialmethod' (len 13). Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__qualname__ == 'singledispatchmethod' (len 20). Verified with Python 3.14.3."
    - "functools.cached_property.__qualname__ == 'cached_property' (len 15). Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' (len 9). Verified with Python 3.14.3."
    - "functools.cache.__qualname__ == 'cache' (len 5). Verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering' (len 14). Verified with Python 3.14.3."
    - "functools.reduce.__qualname__ == 'reduce' (len 6). Verified with Python 3.14.3."
    - "functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len 10). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools class __qualname__ string lengths — C extension types
#
# Wave 260 theme: functools class __qualname__ values and lengths.
#
# functools.partial.__qualname__ == 'partial' (len 7) — C extension type
# functools.reduce.__qualname__ == 'reduce' (len 6) — C builtin function
# functools.cmp_to_key.__qualname__ == 'cmp_to_key' (len 10) — C extension type
# functools.lru_cache.__qualname__ == 'lru_cache' (len 9) — pure-Python class
# functools.cache.__qualname__ == 'cache' (len 5) — pure-Python function alias
#
# The __qualname__ of a class or function at module scope equals its simple
# definition name. C types and pure-Python classes both expose __qualname__.
# New to extra108.
# ---------------------------------------------------------------------------

table functools_extra108.qualname_lens_c_types:
  description: "functools C-type and C-builtin __qualname__ lengths: partial 7, reduce 6, cmp_to_key 10, lru_cache 9, cache 5; wave 260; new to extra108"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsqn108a

  columns: [id, function, args, expected, description]
  rows:
    - [partial_qualname_len_eq_7,
       "partial.__qualname__.__len__",
       [],
       7,
       "functools.partial.__qualname__.__len__() == 7 — functools.partial is a C extension type defined in Modules/_functoolsmodule.c; its __qualname__ is 'partial' (7 chars: p-a-r-t-i-a-l); new to extra108"]
    - [reduce_qualname_len_eq_6,
       "reduce.__qualname__.__len__",
       [],
       6,
       "functools.reduce.__qualname__.__len__() == 6 — functools.reduce is a C builtin function from Modules/_functoolsmodule.c; its __qualname__ is 'reduce' (6 chars: r-e-d-u-c-e); new to extra108"]
    - [cmp_to_key_qualname_len_eq_10,
       "cmp_to_key.__qualname__.__len__",
       [],
       10,
       "functools.cmp_to_key.__qualname__.__len__() == 10 — functools.cmp_to_key converts a comparison function to a key function for use with sorted(); it is a C extension type; its __qualname__ is 'cmp_to_key' (10 chars); new to extra108"]
    - [lru_cache_qualname_len_eq_9,
       "lru_cache.__qualname__.__len__",
       [],
       9,
       "functools.lru_cache.__qualname__.__len__() == 9 — functools.lru_cache is a pure-Python decorator class in Lib/functools.py that memoizes calls with a bounded cache; its __qualname__ is 'lru_cache' (9 chars: l-r-u-_-c-a-c-h-e); new to extra108"]
    - [cache_qualname_len_eq_5,
       "cache.__qualname__.__len__",
       [],
       5,
       "functools.cache.__qualname__.__len__() == 5 — functools.cache is the simple unbounded LRU alias (lru_cache(maxsize=None)) added in Python 3.9; its __qualname__ is 'cache' (5 chars: c-a-c-h-e); new to extra108"]

# ---------------------------------------------------------------------------
# Table 2: functools class __qualname__ string lengths — pure-Python classes
#
# Wave 260 theme: functools pure-Python class __qualname__ values and lengths.
#
# functools.partialmethod.__qualname__ == 'partialmethod' (len 13)
# functools.singledispatchmethod.__qualname__ == 'singledispatchmethod' (len 20)
# functools.cached_property.__qualname__ == 'cached_property' (len 15)
# functools.total_ordering.__qualname__ == 'total_ordering' (len 14)
#
# These are pure-Python classes defined in Lib/functools.py.
# singledispatchmethod has the longest __qualname__ of all functools classes at 20 chars.
# New to extra108.
# ---------------------------------------------------------------------------

table functools_extra108.qualname_lens_py_classes:
  description: "functools pure-Python class __qualname__ lengths: partialmethod 13, total_ordering 14, cached_property 15, singledispatchmethod 20; wave 260; new to extra108"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsqn108b

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_qualname_len_eq_13,
       "partialmethod.__qualname__.__len__",
       [],
       13,
       "functools.partialmethod.__qualname__.__len__() == 13 — functools.partialmethod is a pure-Python descriptor class in Lib/functools.py that behaves like partial for use in class bodies; its __qualname__ is 'partialmethod' (13 chars: p-a-r-t-i-a-l-m-e-t-h-o-d); new to extra108"]
    - [total_ordering_qualname_len_eq_14,
       "total_ordering.__qualname__.__len__",
       [],
       14,
       "functools.total_ordering.__qualname__.__len__() == 14 — functools.total_ordering is a class decorator in Lib/functools.py that fills in missing comparison methods given __eq__ and one of __lt__, __le__, __gt__, __ge__; its __qualname__ is 'total_ordering' (14 chars); new to extra108"]
    - [cached_property_qualname_len_eq_15,
       "cached_property.__qualname__.__len__",
       [],
       15,
       "functools.cached_property.__qualname__.__len__() == 15 — functools.cached_property is a pure-Python descriptor class added in Python 3.8 that computes a value once and stores it on the instance; its __qualname__ is 'cached_property' (15 chars: c-a-c-h-e-d-_-p-r-o-p-e-r-t-y); new to extra108"]
    - [singledispatchmethod_qualname_len_eq_20,
       "singledispatchmethod.__qualname__.__len__",
       [],
       20,
       "functools.singledispatchmethod.__qualname__.__len__() == 20 — functools.singledispatchmethod is a pure-Python class descriptor added in Python 3.8 that provides single-dispatch generic functions for methods; its __qualname__ is 'singledispatchmethod' (20 chars), the longest of all functools class qualnames; new to extra108"]

# ---------------------------------------------------------------------------
# Table 3: functools class __qualname__ string equality checks
#
# Wave 260 theme: functools class __qualname__ exact equality.
#
# functools.partial.__qualname__ == 'partial'
# functools.partialmethod.__qualname__ == 'partialmethod'
# functools.cached_property.__qualname__ == 'cached_property'
# functools.lru_cache.__qualname__ == 'lru_cache'
# functools.total_ordering.__qualname__ == 'total_ordering'
# functools.cmp_to_key.__qualname__ == 'cmp_to_key'
# functools.reduce.__qualname__ == 'reduce'
# functools.cache.__qualname__ == 'cache'
#
# Each class or function defined at functools module scope has a __qualname__
# equal to its simple name. New to extra108.
# ---------------------------------------------------------------------------

table functools_extra108.qualname_equality:
  description: "functools class __qualname__ string equality: partial, partialmethod, cached_property, lru_cache, total_ordering, cmp_to_key, reduce, cache; wave 260; new to extra108"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsqn108c

  columns: [id, function, args, expected, description]
  rows:
    - [partial_qualname_eq,
       "partial.__qualname__.__eq__",
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — partial is a C extension type with __qualname__ equal to its simple class name 'partial'; str.__eq__('partial') returns True; new to extra108"]
    - [partialmethod_qualname_eq,
       "partialmethod.__qualname__.__eq__",
       ["partialmethod"],
       true,
       "functools.partialmethod.__qualname__.__eq__('partialmethod') == True — partialmethod is a pure-Python descriptor class; its __qualname__ is 'partialmethod'; str.__eq__('partialmethod') returns True; new to extra108"]
    - [cached_property_qualname_eq,
       "cached_property.__qualname__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__.__eq__('cached_property') == True — cached_property is a pure-Python descriptor class; its __qualname__ is 'cached_property'; str.__eq__('cached_property') returns True; new to extra108"]
    - [lru_cache_qualname_eq,
       "lru_cache.__qualname__.__eq__",
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — lru_cache is a pure-Python memoizing decorator class; its __qualname__ is 'lru_cache'; str.__eq__('lru_cache') returns True; new to extra108"]
    - [total_ordering_qualname_eq,
       "total_ordering.__qualname__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — total_ordering is a class decorator that fills in missing comparison methods; its __qualname__ is 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra108"]
    - [cmp_to_key_qualname_eq,
       "cmp_to_key.__qualname__.__eq__",
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True — cmp_to_key is a C extension type that converts a comparison function to a key function; its __qualname__ is 'cmp_to_key'; str.__eq__('cmp_to_key') returns True; new to extra108"]
    - [reduce_qualname_eq,
       "reduce.__qualname__.__eq__",
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — reduce is a C builtin that applies a function cumulatively to sequence items; its __qualname__ is 'reduce'; str.__eq__('reduce') returns True; new to extra108"]
    - [singledispatchmethod_qualname_eq,
       "singledispatchmethod.__qualname__.__eq__",
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__qualname__.__eq__('singledispatchmethod') == True — singledispatchmethod is the longest-named functools class; its __qualname__ is 'singledispatchmethod'; str.__eq__('singledispatchmethod') returns True; new to extra108"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra108
# ---------------------------------------------------------------------------

invariant functools_extra108.partial_qualname_len:
  description: "len(functools.partial.__qualname__) == 7 — qualname is 'partial'; C extension type; wave 260; new to extra108"
  kind: python_call_eq
  function: partial.__qualname__.__len__
  args: []
  expected: 7

invariant functools_extra108.singledispatchmethod_qualname_len:
  description: "len(functools.singledispatchmethod.__qualname__) == 20 — longest functools class qualname; wave 260; new to extra108"
  kind: python_call_eq
  function: singledispatchmethod.__qualname__.__len__
  args: []
  expected: 20

invariant functools_extra108.cached_property_qualname:
  description: "functools.cached_property.__qualname__ == 'cached_property' — pure-Python descriptor; wave 260; new to extra108"
  kind: python_call_eq
  function: cached_property.__qualname__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra108.cache_qualname_len:
  description: "len(functools.cache.__qualname__) == 5 — qualname is 'cache'; shortest functools callable qualname; wave 260; new to extra108"
  kind: python_call_eq
  function: cache.__qualname__.__len__
  args: []
  expected: 5

invariant functools_extra108.total_ordering_qualname_len:
  description: "len(functools.total_ordering.__qualname__) == 14 — qualname is 'total_ordering'; pure-Python class decorator; wave 260; new to extra108"
  kind: python_call_eq
  function: total_ordering.__qualname__.__len__
  args: []
  expected: 14

invariant functools_extra108.cmp_to_key_qualname:
  description: "functools.cmp_to_key.__qualname__ == 'cmp_to_key' — C extension type; wave 260; new to extra108"
  kind: python_call_eq
  function: cmp_to_key.__qualname__.__eq__
  args: ["cmp_to_key"]
  expected: true
