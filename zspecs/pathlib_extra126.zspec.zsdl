spec: pathlib_extra126
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/_local.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "This spec extends pathlib_extra125.zspec.zsdl."
    - "This spec covers: pathlib.PurePath comparison operator dunder qualnames not yet covered."
    - "pathlib_extra118 covered __str__, __fspath__, __repr__, __hash__, __eq__, __lt__, __truediv__, __rtruediv__ qualnames."
    - "This spec covers: __bytes__, __le__, __gt__, __ge__ — all defined on PurePath; all type 'function'."
    - "pathlib.PurePath.__bytes__.__qualname__ == 'PurePath.__bytes__' (len 18); type 'function'."
    - "pathlib.PurePath.__le__.__qualname__ == 'PurePath.__le__' (len 15); type 'function'."
    - "pathlib.PurePath.__gt__.__qualname__ == 'PurePath.__gt__' (len 15); type 'function'."
    - "pathlib.PurePath.__ge__.__qualname__ == 'PurePath.__ge__' (len 15); type 'function'."
    - "__le__, __gt__, __ge__ all share qualname length 15 with __eq__ and __lt__ from pathlib_extra118."
    - "__bytes__ (18) is longer than __fspath__ (19)? No: __bytes__(18) < __fspath__(19); __bytes__ is second longest among these."
    - "All five comparison dunders (__eq__, __lt__, __le__, __gt__, __ge__) have qualname length 15."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath.__bytes__ qualname and type
# PurePath.__bytes__.__qualname__ == 'PurePath.__bytes__' (18 chars).
# __bytes__ implements bytes(path) conversion; defined on PurePath.
# type is 'function' (pure Python, defined in Lib/pathlib/_abc.py or _local.py).
# pathlib_extra118 covered __str__ (16), __fspath__ (19), __repr__ (17), __hash__ (17).
# __bytes__ (18) was not covered in any prior pathlib_extra spec.
# ---------------------------------------------------------------------------

table pathlib_extra126.PurePath_bytes_qualname:
  description: "pathlib.PurePath.__bytes__ qualname='PurePath.__bytes__'(18); type 'function'; __bytes__ implements bytes() conversion; 18 chars places it between __fspath__(19) and __str__(16) in length; not covered in prior specs"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibpb126a

  columns: [id, function, args, expected, description]
  rows:
    - [bytes_type,       "PurePath.__bytes__.__class__.__name__.__eq__",    ["function"],             true,  "type(pathlib.PurePath.__bytes__).__name__ == 'function' (pure Python method; defined on PurePath)"]
    - [bytes_qn_eq,      "PurePath.__bytes__.__qualname__.__eq__",          ["PurePath.__bytes__"],   true,  "pathlib.PurePath.__bytes__.__qualname__ == 'PurePath.__bytes__' (18 chars; implements bytes() on a path object)"]
    - [bytes_qn_len,     "PurePath.__bytes__.__qualname__.__len__",         [],                       18,    "pathlib.PurePath.__bytes__.__qualname__.__len__() == 18 ('PurePath.__bytes__': 'PurePath.'(9)+'__bytes__'(9)==18)"]
    - [bytes_nm_eq,      "PurePath.__bytes__.__name__.__eq__",              ["__bytes__"],            true,  "pathlib.PurePath.__bytes__.__name__ == '__bytes__' (9 chars; bare name without 'PurePath.' prefix)"]
    - [bytes_nm_len,     "PurePath.__bytes__.__name__.__len__",             [],                       9,     "pathlib.PurePath.__bytes__.__name__.__len__() == 9 ('__bytes__': '__'(2)+'bytes'(5)+'__'(2)==9)"]
    - [bytes_lt_fspath,  "PurePath.__bytes__.__qualname__.__len__.__lt__",  [19],                     true,  "len('PurePath.__bytes__') < len('PurePath.__fspath__') (18 < 19; __bytes__ is 1 char shorter than __fspath__)"]
    - [bytes_gt_str,     "PurePath.__bytes__.__qualname__.__len__.__gt__",  [16],                     true,  "len('PurePath.__bytes__') > len('PurePath.__str__') (18 > 16; __bytes__ is 2 chars longer than __str__)"]
    - [bytes_ne_str_qn,  "PurePath.__bytes__.__qualname__.__eq__",          ["PurePath.__str__"],     false, "pathlib.PurePath.__bytes__.__qualname__ != 'PurePath.__str__' (distinct qualnames; __bytes__ returns bytes, __str__ returns str)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__le__ and __gt__ qualnames and types
# Both have qualname length 15 (same as __eq__ and __lt__ from pathlib_extra118).
# __le__: 'PurePath.__le__' (15 chars); implements <= comparison.
# __gt__: 'PurePath.__gt__' (15 chars); implements > comparison.
# The five comparison dunders __eq__/__lt__/__le__/__gt__/__ge__ all have length 15.
# ---------------------------------------------------------------------------

table pathlib_extra126.PurePath_le_gt_qualnames:
  description: "pathlib.PurePath.__le__ qualname='PurePath.__le__'(15); __gt__ qualname='PurePath.__gt__'(15); both type 'function'; share length 15 with __eq__ and __lt__ from pathlib_extra118; all five comparison dunders have qualname length 15"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibcmp126b

  columns: [id, function, args, expected, description]
  rows:
    - [le_type,      "PurePath.__le__.__class__.__name__.__eq__",    ["function"],           true,  "type(pathlib.PurePath.__le__).__name__ == 'function' (pure Python method; implements <= comparison for paths)"]
    - [le_qn_eq,     "PurePath.__le__.__qualname__.__eq__",          ["PurePath.__le__"],    true,  "pathlib.PurePath.__le__.__qualname__ == 'PurePath.__le__' (15 chars; implements <= for lexicographic path comparison)"]
    - [le_qn_len,    "PurePath.__le__.__qualname__.__len__",         [],                     15,    "pathlib.PurePath.__le__.__qualname__.__len__() == 15 ('PurePath.__le__': 'PurePath.'(9)+'__le__'(6)==15)"]
    - [gt_type,      "PurePath.__gt__.__class__.__name__.__eq__",    ["function"],           true,  "type(pathlib.PurePath.__gt__).__name__ == 'function' (pure Python method; implements > comparison for paths)"]
    - [gt_qn_eq,     "PurePath.__gt__.__qualname__.__eq__",          ["PurePath.__gt__"],    true,  "pathlib.PurePath.__gt__.__qualname__ == 'PurePath.__gt__' (15 chars; implements > for lexicographic path comparison)"]
    - [gt_qn_len,    "PurePath.__gt__.__qualname__.__len__",         [],                     15,    "pathlib.PurePath.__gt__.__qualname__.__len__() == 15 ('PurePath.__gt__': 'PurePath.'(9)+'__gt__'(6)==15; same as __le__)"]
    - [le_eq_gt_len, "PurePath.__le__.__qualname__.__len__.__eq__",  [15],                   true,  "len('PurePath.__le__') == len('PurePath.__gt__') == 15 (all five comparison dunders share qualname length 15)"]
    - [le_ne_gt,     "PurePath.__le__.__qualname__.__eq__",          ["PurePath.__gt__"],    false, "pathlib.PurePath.__le__.__qualname__ != 'PurePath.__gt__' (distinct operators: __le__ is <=, __gt__ is >)"]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__ge__ qualname, type, and five-way comparison dunder summary
# __ge__: 'PurePath.__ge__' (15 chars); implements >= comparison.
# All five comparison dunders (__eq__, __lt__, __le__, __gt__, __ge__) have length 15.
# This table establishes that fact explicitly, cross-referencing pathlib_extra118.
# __bytes__ (18) is NOT a comparison dunder — it is a bytes-conversion protocol.
# Length hierarchy: __rtruediv__(21) > __truediv__(20) > __fspath__(19) > __bytes__(18) >
#   __repr__(17) == __hash__(17) > __str__(16) > __ge__(15)==__eq__(15)==__lt__(15)==__le__(15)==__gt__(15).
# ---------------------------------------------------------------------------

table pathlib_extra126.PurePath_ge_and_comparison_summary:
  description: "pathlib.PurePath.__ge__ qualname='PurePath.__ge__'(15); all five comparison dunders (__eq__/__lt__/__le__/__gt__/__ge__) share qualname length 15; __bytes__(18) is NOT a comparison dunder; length hierarchy novel summary"
  kind: python_call_eq
  category: qualnames
  id_prefix: pathlibge126c

  columns: [id, function, args, expected, description]
  rows:
    - [ge_type,      "PurePath.__ge__.__class__.__name__.__eq__",    ["function"],           true,  "type(pathlib.PurePath.__ge__).__name__ == 'function' (pure Python method; implements >= comparison for paths)"]
    - [ge_qn_eq,     "PurePath.__ge__.__qualname__.__eq__",          ["PurePath.__ge__"],    true,  "pathlib.PurePath.__ge__.__qualname__ == 'PurePath.__ge__' (15 chars; implements >= for lexicographic path comparison)"]
    - [ge_qn_len,    "PurePath.__ge__.__qualname__.__len__",         [],                     15,    "pathlib.PurePath.__ge__.__qualname__.__len__() == 15 ('PurePath.__ge__': 'PurePath.'(9)+'__ge__'(6)==15)"]
    - [ge_eq_le_len, "PurePath.__ge__.__qualname__.__len__.__eq__",  [15],                   true,  "len('PurePath.__ge__') == len('PurePath.__le__') == 15 (all five comparison dunders have identical qualname lengths)"]
    - [ge_ne_le,     "PurePath.__ge__.__qualname__.__eq__",          ["PurePath.__le__"],    false, "pathlib.PurePath.__ge__.__qualname__ != 'PurePath.__le__' (distinct operators despite equal length: __ge__ is >=, __le__ is <=)"]
    - [bytes_gt_ge,  "PurePath.__bytes__.__qualname__.__len__.__gt__", [15],                 true,  "len('PurePath.__bytes__') > len('PurePath.__ge__') (18 > 15; __bytes__ is a conversion protocol, not a comparison dunder)"]
    - [ge_lt_hash,   "PurePath.__ge__.__qualname__.__len__.__lt__",  [17],                   true,  "len('PurePath.__ge__') < len('PurePath.__hash__') (15 < 17; comparison dunders are shorter than __hash__ and __repr__)"]
    - [ge_nm_len,    "PurePath.__ge__.__name__.__len__",             [],                     6,     "pathlib.PurePath.__ge__.__name__.__len__() == 6 ('__ge__': '__'(2)+'ge'(2)+'__'(2)==6; same bare name length as __le__/__gt__/__lt__/__eq__)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra126.PurePath.bytes_qualname_eq:
  description: "pathlib.PurePath.__bytes__.__qualname__ == 'PurePath.__bytes__' (length 18; __bytes__ is a pure Python function defined on PurePath that implements the bytes() conversion protocol for path objects; 'PurePath.'(9)+'__bytes__'(9)==18; type is 'function'; __bytes__(18) falls between __fspath__(19) and __str__(16) in the qualname length ordering for PurePath protocol methods; no prior pathlib_extra spec has covered PurePath.__bytes__.__qualname__ in any form; pathlib_extra118 covered __str__(16), __fspath__(19), __repr__(17), __hash__(17), __eq__(15), __lt__(15), __truediv__(20), __rtruediv__(21) but not __bytes__, __le__, __gt__, or __ge__)"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.__bytes__.__qualname__.__eq__"
  args: ["PurePath.__bytes__"]
  expected: true

invariant pathlib_extra126.PurePath.le_qualname_eq:
  description: "pathlib.PurePath.__le__.__qualname__ == 'PurePath.__le__' (length 15; __le__ implements the <= operator for lexicographic path comparison; it is a pure Python function defined on PurePath and inherited by all concrete path classes; 'PurePath.'(9)+'__le__'(6)==15; __le__ shares its qualname length of 15 with __eq__, __lt__, __gt__, and __ge__ — all five PurePath comparison dunders have identical qualname lengths because they all use 6-char bare dunder names ('__eq__', '__lt__', '__le__', '__gt__', '__ge__') with the same 9-char 'PurePath.' prefix; no prior pathlib_extra spec has asserted PurePath.__le__.__qualname__.__eq__('PurePath.__le__'))"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.__le__.__qualname__.__eq__"
  args: ["PurePath.__le__"]
  expected: true

invariant pathlib_extra126.PurePath.gt_qualname_eq:
  description: "pathlib.PurePath.__gt__.__qualname__ == 'PurePath.__gt__' (length 15; __gt__ implements the > operator for lexicographic path comparison; it is a pure Python function defined on PurePath; 'PurePath.'(9)+'__gt__'(6)==15; __gt__ is the complement of __lt__ — on POSIX systems both are case-sensitive string comparisons of the path string; __gt__ shares qualname length 15 with __lt__, __eq__, __le__, and __ge__; no prior pathlib_extra spec has asserted PurePath.__gt__.__qualname__.__eq__('PurePath.__gt__'))"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.__gt__.__qualname__.__eq__"
  args: ["PurePath.__gt__"]
  expected: true

invariant pathlib_extra126.PurePath.ge_qualname_eq:
  description: "pathlib.PurePath.__ge__.__qualname__ == 'PurePath.__ge__' (length 15; __ge__ implements the >= operator for lexicographic path comparison; it is a pure Python function defined on PurePath; 'PurePath.'(9)+'__ge__'(6)==15; __ge__ is the complement of __le__ and is the last of the five comparison dunders all sharing qualname length 15: __eq__==__lt__==__le__==__gt__==__ge__==15; no prior pathlib_extra spec has asserted PurePath.__ge__.__qualname__.__eq__('PurePath.__ge__'))"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.__ge__.__qualname__.__eq__"
  args: ["PurePath.__ge__"]
  expected: true

invariant pathlib_extra126.PurePath.bytes_qualname_len_eq_18:
  description: "pathlib.PurePath.__bytes__.__qualname__.__len__() == 18 ('PurePath.__bytes__' has 18 characters; 'PurePath.'(9)+'__bytes__'(9)==18; the two halves of the qualname are equal in length — the 9-char 'PurePath.' prefix and the 9-char '__bytes__' bare name; no prior pathlib_extra spec has asserted this length; pathlib_extra118 established that __fspath__(19) is the longest protocol method qualname and __str__(16) is the shortest; __bytes__(18) fills the gap between them)"
  category: qualnames
  kind: python_call_eq
  function: "PurePath.__bytes__.__qualname__.__len__"
  args: []
  expected: 18
