spec: hashlib_extra158
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra157.zspec.zsdl — covers hashlib.__spec__.__class__.__name__.__eq__('ModuleSpec') / __spec__.name.__eq__('hashlib') / __all__.__class__.__name__.__eq__('tuple') / __all__.__contains__('md5'/'sha256'/'sha512') / new.__module__.__eq__('hashlib') / new.__class__.__name__.__eq__('function') (table + invariants)."
    - "hashlib_extra156.zspec.zsdl — covers hashlib.sha256/__qualname__/__eq__('openssl_sha256') / md5/__qualname__ / sha512/__qualname__ / sha256/__qualname__/__len__()==14 / blake2b/__name__/__qualname__ / sha3_256/__name__/__qualname__/__len__()==16 (table + invariants)."
    - "hashlib_extra155.zspec.zsdl — covers hashlib.sha256/__class__.__name__.__eq__('builtin_function_or_method') / sha256/__module__/__eq__('_hashlib') / sha256/__name__/__eq__('openssl_sha256') / md5/__name__ / sha1/__name__ / sha512/__name__ / pbkdf2_hmac/__module__ (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in hashlib_extra95 through hashlib_extra157."
    - "Wave 337 theme: hashlib hash constructor __doc__ and __qualname__ length checks — sha256.__doc__.__class__.__name__.__eq__('str') / md5.__doc__.__class__.__name__.__eq__('str') / sha256.__qualname__.__len__()==14 / md5.__qualname__.__len__()==11 / sha1.__qualname__.__len__()==12 / sha512.__qualname__.__len__()==14 / sha3_256.__qualname__.__len__()==16."
    - "hashlib.sha256.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__qualname__.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__qualname__.__len__() == 11. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha1.__qualname__.__len__() == 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__qualname__.__len__() == 14. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_256.__qualname__.__len__() == 16. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: hashlib.sha256.__doc__.__class__.__name__ == 'str'. The builtin_function_or_method objects from _hashlib (sha256, md5, sha1, sha512, etc.) all carry docstrings stored as plain Python str objects. Their __doc__ attribute has __class__.__name__ == 'str'. This confirms docstrings are present and are of the expected Python str type (not bytes, NoneType, or any other type)."
    - "Note: qualname length ordering for the named hash constructors: md5(11) < sha1(12) < sha256==sha512(14) < sha3_256(16). The 'openssl_' prefix (8 chars) accounts for most of the length. The algorithm suffix lengths are: 'md5'=3, 'sha1'=4, 'sha256'=6, 'sha512'=6, 'sha3_256'=8. Adding 8 gives 11, 12, 14, 14, 16 respectively. sha256 and sha512 tie at 14 chars because both algorithm names are 6 chars long."
    - "Note: hashlib.sha1.__qualname__.__len__() == 12 ('openssl_sha1' = 'openssl_'=8 + 'sha1'=4 = 12 chars). sha1 is positioned between md5 (11 chars) and sha256/sha512 (14 chars) in the qualname length ordering. SHA-1 produces a 20-byte (160-bit) digest and is considered cryptographically weak; it is still available in hashlib for legacy use."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__class__.__name__.__eq__('str')
# hashlib.md5.__doc__.__class__.__name__.__eq__('str')
# hashlib.sha256.__qualname__.__len__()==14
# hashlib.md5.__qualname__.__len__()==11
#
# Wave 337 theme: hash constructor __doc__ type and qualname lengths.
#
# sha256.__doc__.__class__.__name__ == 'str' (3 chars; docstring is a str).
# md5.__doc__.__class__.__name__ == 'str' (3 chars; docstring is a str).
# sha256.__qualname__.__len__() == 14 ('openssl_sha256' = 14 chars).
# md5.__qualname__.__len__() == 11 ('openssl_md5' = 11 chars).
# extra156 anchors sha256.__qualname__.__len__()==14 in a table; no prior hashlib spec
# anchors sha256/__doc__/__class__.__name__ or the combined doc/len table under hashdoc158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra158.hash_doc_type_and_qualname_lengths:
  description: "hashlib.sha256.__doc__.__class__.__name__.__eq__('str')==True / md5.__doc__.__class__.__name__.__eq__('str')==True / sha256.__qualname__.__len__()==14 / md5.__qualname__.__len__()==11 — sha256 and md5 docstrings are str objects (3 chars; builtin_function_or_method from _hashlib carry str docstrings); sha256 qualname is 14 chars ('openssl_sha256': 'openssl_'=8 + 'sha256'=6); md5 qualname is 11 chars ('openssl_md5': 'openssl_'=8 + 'md5'=3); first hashdoc158 anchor for sha256/md5 __doc__ class names and combined length table"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc158

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_doc_class_str,   "sha256.__doc__.__class__.__name__.__eq__", ["str"], true, "hashlib.sha256.__doc__.__class__.__name__ == 'str' (3 chars; builtin_function_or_method carries str docstring)"]
    - [md5_doc_class_str,      "md5.__doc__.__class__.__name__.__eq__",    ["str"], true, "hashlib.md5.__doc__.__class__.__name__ == 'str' (3 chars; all named hash constructors carry str docstrings)"]
    - [sha256_qualname_len_14, "sha256.__qualname__.__len__",              [],     14,   "hashlib.sha256.__qualname__.__len__() is 14 ('openssl_sha256' = 'openssl_'=8 + 'sha256'=6 = 14 chars)"]
    - [md5_qualname_len_11,    "md5.__qualname__.__len__",                 [],     11,   "hashlib.md5.__qualname__.__len__() is 11 ('openssl_md5' = 'openssl_'=8 + 'md5'=3 = 11 chars; shortest qualname)"]

# ---------------------------------------------------------------------------
# hashlib.sha1.__qualname__.__len__()==12
# hashlib.sha512.__qualname__.__len__()==14
# hashlib.sha3_256.__qualname__.__len__()==16
#
# Wave 337 theme: sha1/sha512/sha3_256 qualname lengths completing the ordering.
#
# sha1.__qualname__.__len__() == 12 ('openssl_sha1' = 8+4 = 12 chars).
# sha512.__qualname__.__len__() == 14 ('openssl_sha512' = 8+6 = 14; ties with sha256).
# sha3_256.__qualname__.__len__() == 16 ('openssl_sha3_256' = 8+8 = 16 chars; longest).
# extra156 anchors sha3_256/__qualname__/__len__()==16 in a table; no prior hashlib spec
# anchors sha1/__qualname__/__len__() as a table under hashdoc158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra158.sha1_sha512_sha3_256_qualname_lengths:
  description: "hashlib.sha1.__qualname__.__len__()==12 / sha512.__qualname__.__len__()==14 / sha3_256.__qualname__.__len__()==16 / sha256.__qualname__.__len__()==14 — sha1 is 12 chars ('openssl_sha1': 8+4); sha512 ties sha256 at 14 chars ('openssl_sha512': 8+6); sha3_256 is 16 chars ('openssl_sha3_256': 8+8; longest); full ordering: md5(11) < sha1(12) < sha256==sha512(14) < sha3_256(16); sha3_256 is 4 chars longer than sha1; first hashdoc158 anchor for sha1/sha512 qualname lengths combined with sha3_256"
  kind: python_call_eq
  category: identity
  id_prefix: hashdoc158

  columns: [id, function, args, expected, description]
  rows:
    - [sha1_qualname_len_12,    "sha1.__qualname__.__len__",    [], 12, "hashlib.sha1.__qualname__.__len__() is 12 ('openssl_sha1' = 'openssl_'=8 + 'sha1'=4 = 12 chars)"]
    - [sha512_qualname_len_14,  "sha512.__qualname__.__len__",  [], 14, "hashlib.sha512.__qualname__.__len__() is 14 ('openssl_sha512' = 'openssl_'=8 + 'sha512'=6 = 14; ties with sha256)"]
    - [sha3_256_qualname_len_16,"sha3_256.__qualname__.__len__",[], 16, "hashlib.sha3_256.__qualname__.__len__() is 16 ('openssl_sha3_256' = 'openssl_'=8 + 'sha3_256'=8 = 16; longest)"]
    - [sha256_qualname_len_14b, "sha256.__qualname__.__len__",  [], 14, "hashlib.sha256.__qualname__.__len__() is 14 ('openssl_sha256' = 8+6 = 14 chars; ties with sha512 at 14)"]

# ---------------------------------------------------------------------------
# hashlib.sha256.__doc__.__class__.__name__.__eq__('str') — standalone
#
# hashlib.sha256.__doc__.__class__.__name__ is 'str' (3 chars). The sha256 hash
# constructor is a builtin_function_or_method from the _hashlib C extension module.
# Its docstring (__doc__) is stored as a regular Python str object. The docstring
# describes the constructor's signature and behavior — it is set at the C level as a
# const char* that Python wraps as a str. __doc__.__class__.__name__ == 'str' (3 chars)
# confirms the docstring is a Python str (not None or any other type). No prior hashlib
# spec anchors sha256.__doc__.__class__.__name__ as a standalone under hashdoc158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra158.sha256_doc_class_str:
  description: "hashlib.sha256.__doc__.__class__.__name__.__eq__('str') == True — 'str' (3 chars); builtin_function_or_method carries docstring as Python str; docstring describes constructor signature; set as const char* at C level, wrapped as str by Python; __doc__ is not None, bytes, or other type; md5 also has 'str' docstring (see table); no prior hashlib spec anchors sha256.__doc__.__class__.__name__ as a standalone; first standalone under hashdoc158"
  category: identity
  kind: python_call_eq
  function: sha256.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.sha1.__qualname__.__len__()==12 — standalone
#
# hashlib.sha1.__qualname__.__len__() is 12. sha1.__qualname__ == 'openssl_sha1'
# (12 chars = 'openssl_'=8 + 'sha1'=4). sha1 occupies the second position in the
# qualname length ordering: md5(11) < sha1(12) < sha256==sha512(14) < sha3_256(16).
# SHA-1 (Secure Hash Algorithm 1) produces a 160-bit (20-byte) digest. It was
# standardized in FIPS PUB 180-1 but is now considered cryptographically weak and
# unsuitable for security-critical applications. It remains available in hashlib
# for compatibility. No prior hashlib spec anchors sha1.__qualname__.__len__() as
# a standalone under hashdoc158. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra158.sha1_qualname_len_12:
  description: "hashlib.sha1.__qualname__.__len__() == 12 — 'openssl_sha1' = 'openssl_'=8 + 'sha1'=4 = 12 chars; second in ordering: md5(11) < sha1(12) < sha256==sha512(14) < sha3_256(16); SHA-1 produces 160-bit (20-byte) digest; FIPS PUB 180-1; cryptographically weak but available for legacy use; no prior hashlib spec anchors this as a standalone; first standalone under hashdoc158"
  category: identity
  kind: python_call_eq
  function: sha1.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# hashlib.sha3_256.__qualname__.__len__()==16 — standalone
#
# hashlib.sha3_256.__qualname__.__len__() is 16. sha3_256.__qualname__ ==
# 'openssl_sha3_256' (16 chars = 'openssl_'=8 + 'sha3_256'=8). sha3_256 has the
# longest qualname among the commonly named hash constructors. The SHA-3 family
# uses the Keccak sponge construction (fundamentally different from SHA-2 which uses
# Merkle-Damgard). sha3_256 produces a 256-bit (32-byte) output — the same size as
# SHA-256 — but is algorithmically distinct. extra156 anchors sha3_256.__qualname__.__len__()
# as a table row under hashhq156; no prior hashlib spec anchors this as a standalone
# under hashdoc158. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra158.sha3_256_qualname_len_16:
  description: "hashlib.sha3_256.__qualname__.__len__() == 16 — 'openssl_sha3_256' = 'openssl_'=8 + 'sha3_256'=8 = 16 chars; longest named constructor qualname; 4 longer than sha256/sha512 (14); Keccak sponge construction (distinct from SHA-2 Merkle-Damgard); 256-bit (32-byte) output; extra156 anchors this as a table row under hashhq156; no prior hashlib spec anchors this as a standalone under hashdoc158; first standalone under hashdoc158"
  category: identity
  kind: python_call_eq
  function: sha3_256.__qualname__.__len__
  args: []
  expected: 16
