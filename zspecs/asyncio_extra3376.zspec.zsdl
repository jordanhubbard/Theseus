    - ["as3376010", operator.contains, [asyncio.LifoQueue.__dict__,        "__trunc__"], false]

# ---------------------------------------------------------------------------
# __round__ dict-presence — operator.contains(Cls.__dict__, '__round__')
#
# All 10 asyncio classes return false for __round__.
# round() delegates to __round__ (numbers.Real protocol) when defined.
# asyncio types define no numeric protocol — no real-valued magnitude is
#   associated with any asyncio concurrency primitive.
# asyncio.Event/Lock/Condition: boolean-state guards; round(event, n) is not
#   a meaningful Python expression for synchronization objects.
# asyncio.Semaphore/BoundedSemaphore: the permit counter is encapsulated and
#   not exposed through __round__ or any numeric data model method.
# asyncio.Task/Future: coroutine result handles; round(task, n) and
#   round(future, n) are not valid Python expressions.
# asyncio.Queue/PriorityQueue/LifoQueue: item stores; round(queue, n) is not
#   defined. Queue length is accessed via qsize(), not round().
# ---------------------------------------------------------------------------

