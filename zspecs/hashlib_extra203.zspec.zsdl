spec: hashlib_extra203
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "hashlib.md5, sha1, sha256, sha512, pbkdf2_hmac are C-level built-in functions: __class__.__name__ == 'builtin_function_or_method'."
    - "hashlib.blake2b and blake2s are type objects (classes): __class__.__name__ == 'type'."
    - "hashlib.new is a Python-level function: __class__.__name__ == 'function'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __class__.__name__ for hashlib constructors — builtin_function_or_method group
#
# md5, sha1, sha256, sha512, pbkdf2_hmac are all C-level built-in callables.
# ---------------------------------------------------------------------------

table hashlib_extra203.constructors_builtin:
  kind: python_call_eq
  category: types
  id_prefix: hashlibclasses203builtin

  columns: [id, function, args, expected, description]
  rows:
    - [md5_class,   md5.__class__.__name__.__eq__,       ["builtin_function_or_method"], true, "hashlib.md5.__class__.__name__ == 'builtin_function_or_method' — md5 is a C-level built-in"]
    - [sha1_class,  sha1.__class__.__name__.__eq__,      ["builtin_function_or_method"], true, "hashlib.sha1.__class__.__name__ == 'builtin_function_or_method' — sha1 is a C-level built-in"]
    - [sha256_class, sha256.__class__.__name__.__eq__,   ["builtin_function_or_method"], true, "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method' — sha256 is a C-level built-in"]
    - [sha512_class, sha512.__class__.__name__.__eq__,   ["builtin_function_or_method"], true, "hashlib.sha512.__class__.__name__ == 'builtin_function_or_method' — sha512 is a C-level built-in"]
    - [pbkdf2_class, pbkdf2_hmac.__class__.__name__.__eq__, ["builtin_function_or_method"], true, "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method' — pbkdf2_hmac is a C-level built-in"]

# ---------------------------------------------------------------------------
# __class__.__name__ for hashlib type objects — 'type' group
#
# blake2b and blake2s are exposed as type objects (classes), not built-in functions.
# ---------------------------------------------------------------------------

table hashlib_extra203.constructors_type:
  kind: python_call_eq
  category: types
  id_prefix: hashlibclasses203type

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_class, blake2b.__class__.__name__.__eq__, ["type"], true, "hashlib.blake2b.__class__.__name__ == 'type' — blake2b is a type object"]
    - [blake2s_class, blake2s.__class__.__name__.__eq__, ["type"], true, "hashlib.blake2s.__class__.__name__ == 'type' — blake2s is a type object"]

# ---------------------------------------------------------------------------
# __class__.__name__ for hashlib.new — Python function
# ---------------------------------------------------------------------------

table hashlib_extra203.new_type:
  kind: python_call_eq
  category: types
  id_prefix: hashlibclasses203new

  columns: [id, function, args, expected, description]
  rows:
    - [new_class, new.__class__.__name__.__eq__, ["function"], true, "hashlib.new.__class__.__name__ == 'function' — new is a Python-level function"]

# ---------------------------------------------------------------------------
# Standalone invariants — one per constructor (8 total)
# ---------------------------------------------------------------------------

invariant hashlib_extra203.md5.class_name:
  description: "hashlib.md5.__class__.__name__ == 'builtin_function_or_method'"
  category: types
  kind: python_call_eq
  function: md5.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra203.sha1.class_name:
  description: "hashlib.sha1.__class__.__name__ == 'builtin_function_or_method'"
  category: types
  kind: python_call_eq
  function: sha1.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra203.sha256.class_name:
  description: "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method'"
  category: types
  kind: python_call_eq
  function: sha256.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra203.sha512.class_name:
  description: "hashlib.sha512.__class__.__name__ == 'builtin_function_or_method'"
  category: types
  kind: python_call_eq
  function: sha512.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra203.blake2b.class_name:
  description: "hashlib.blake2b.__class__.__name__ == 'type' — blake2b is a type object, not a built-in function"
  category: types
  kind: python_call_eq
  function: blake2b.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant hashlib_extra203.blake2s.class_name:
  description: "hashlib.blake2s.__class__.__name__ == 'type' — blake2s is a type object, not a built-in function"
  category: types
  kind: python_call_eq
  function: blake2s.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant hashlib_extra203.pbkdf2_hmac.class_name:
  description: "hashlib.pbkdf2_hmac.__class__.__name__ == 'builtin_function_or_method'"
  category: types
  kind: python_call_eq
  function: pbkdf2_hmac.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant hashlib_extra203.new.class_name:
  description: "hashlib.new.__class__.__name__ == 'function' — new() is a Python-level function, unlike the C-level constructors"
  category: types
  kind: python_call_eq
  function: new.__class__.__name__.__eq__
  args: ["function"]
  expected: true

