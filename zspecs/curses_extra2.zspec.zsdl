spec: curses_extra2
version: ">=3.9"
backend: python_module(curses)

docs: https://docs.python.org/3/library/curses.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/curses.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/curses/__init__.py"
    - "CPython source: Modules/_cursesmodule.c"
  notes:
    - "This spec extends curses.zspec.zsdl, curses_extra.zspec.zsdl, and curses_ascii.zspec.zsdl."
    - "curses is available on POSIX systems (macOS, Linux); not available on Windows."
    - "curses.newwin.__name__ is checked here; curses.zspec covers wrapper/initscr/endwin but not newwin."
    - "COLOR_GREEN/YELLOW/BLUE/MAGENTA/CYAN/WHITE class checks are new; curses_extra covers only BLACK and RED."
    - "A_BLINK and A_DIM class checks are new; curses/curses_extra cover A_BOLD, A_UNDERLINE, A_REVERSE, A_NORMAL."
    - "All COLOR_* and A_* constants are available at import time without calling initscr()."
    - "All expected values verified by running Python 3.12 curses module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# newwin function name — not covered in curses.zspec.zsdl or curses_extra.zspec.zsdl
# ---------------------------------------------------------------------------

invariant curses_extra2.newwin.name:
  description: "curses.newwin.__name__ == 'newwin'"
  category: functions
  kind: python_call_eq
  function: newwin.__name__.__eq__
  args: ["newwin"]
  expected: true

# ---------------------------------------------------------------------------
# Color-index constants — class checks for COLOR_GREEN through COLOR_WHITE
# (curses_extra covers COLOR_BLACK and COLOR_RED; we add the remaining six)
# ---------------------------------------------------------------------------

table curses_extra2.color_constants.class_checks:
  kind: python_call_eq
  category: constants
  id_prefix: color_class

  columns: [id, function, args, expected]
  rows:
    - [COLOR_GREEN,   COLOR_GREEN.__class__.__name__.__eq__,   ["int"], true]
    - [COLOR_YELLOW,  COLOR_YELLOW.__class__.__name__.__eq__,  ["int"], true]
    - [COLOR_BLUE,    COLOR_BLUE.__class__.__name__.__eq__,    ["int"], true]
    - [COLOR_MAGENTA, COLOR_MAGENTA.__class__.__name__.__eq__, ["int"], true]
    - [COLOR_CYAN,    COLOR_CYAN.__class__.__name__.__eq__,    ["int"], true]
    - [COLOR_WHITE,   COLOR_WHITE.__class__.__name__.__eq__,   ["int"], true]

# ---------------------------------------------------------------------------
# Attribute bitmask constants — class checks for A_BLINK and A_DIM
# (curses covers A_BOLD, A_UNDERLINE, A_REVERSE; curses_extra adds A_NORMAL;
#  we add A_BLINK and A_DIM)
# ---------------------------------------------------------------------------

table curses_extra2.attr_constants.class_checks:
  kind: python_call_eq
  category: constants
  id_prefix: attr_class

  columns: [id, function, args, expected]
  rows:
    - [A_BLINK, A_BLINK.__class__.__name__.__eq__, ["int"], true]
    - [A_DIM,   A_DIM.__class__.__name__.__eq__,   ["int"], true]

# ---------------------------------------------------------------------------
# COLOR_* value checks — POSIX ncurses standard color indices
# COLOR_BLACK=0, COLOR_RED=1, COLOR_GREEN=2, COLOR_YELLOW=3,
# COLOR_BLUE=4, COLOR_MAGENTA=5, COLOR_CYAN=6, COLOR_WHITE=7
# (curses_extra covers only value checks for ERR and OK, not COLOR_*)
# ---------------------------------------------------------------------------

table curses_extra2.color_constants.values:
  kind: python_call_eq
  category: constants
  id_prefix: color_value

  columns: [id, function, args, expected]
  rows:
    - [COLOR_BLACK,   COLOR_BLACK.__eq__,   [0], true]
    - [COLOR_RED,     COLOR_RED.__eq__,     [1], true]
    - [COLOR_GREEN,   COLOR_GREEN.__eq__,   [2], true]
    - [COLOR_YELLOW,  COLOR_YELLOW.__eq__,  [3], true]
    - [COLOR_BLUE,    COLOR_BLUE.__eq__,    [4], true]
    - [COLOR_MAGENTA, COLOR_MAGENTA.__eq__, [5], true]
    - [COLOR_CYAN,    COLOR_CYAN.__eq__,    [6], true]
    - [COLOR_WHITE,   COLOR_WHITE.__eq__,   [7], true]

# ---------------------------------------------------------------------------
# newwin qualname — should match __name__ (top-level function)
# ---------------------------------------------------------------------------

invariant curses_extra2.newwin.qualname:
  description: "curses.newwin.__qualname__ == 'newwin' — top-level C builtin, qualname matches name"
  category: functions
  kind: python_call_eq
  function: newwin.__qualname__.__eq__
  args: ["newwin"]
  expected: true

# ---------------------------------------------------------------------------
# A_DIM and A_BLINK are non-negative integers (sanity bound check)
# ---------------------------------------------------------------------------

invariant curses_extra2.A_BLINK.is_non_negative:
  description: "curses.A_BLINK >= 0 — A_BLINK is a non-negative integer bitmask"
  category: constants
  kind: python_call_eq
  function: A_BLINK.__ge__
  args: [0]
  expected: true

invariant curses_extra2.A_DIM.is_non_negative:
  description: "curses.A_DIM >= 0 — A_DIM is a non-negative integer bitmask"
  category: constants
  kind: python_call_eq
  function: A_DIM.__ge__
  args: [0]
  expected: true
