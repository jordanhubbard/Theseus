spec: ab2926
version: ">=3.9"
error_model: python_exceptions
provenance:
  derived_from: [abc source, Python docs, https://docs.python.org/3/library/abc.html]
  not_derived_from: [abc_extra2911.zspec.zsdl — covers __ilshift__/__irshift__/__ipow__ dict-presence, abc_extra2896.zspec.zsdl — covers __itruediv__/__ifloordiv__/__imod__ dict-presence, abc_extra2881.zspec.zsdl — covers __iadd__/__isub__/__imul__ dict-presence, abc_extra2866.zspec.zsdl — covers __rand__/__ror__/__rxor__ dict-presence, any external dataset]
  notes: [Wave 642 theme — __iand__/__ior__/__ixor__ dict-presence checks for abc module types. In-place bitwise AND, OR, XOR operators. ABC/ABCMeta/abstractmethod/abstractclassmethod/abstractstaticmethod are abstract base class infrastructure not set or bitfield types — none define these dunders. abstractproperty excluded per campaign rules for 3.13+ removal. abstractclassmethod and abstractstaticmethod are deprecated but still present in Python 3.14.3. type(abc.abstractmethod(lambda: None)) yields function whose __dict__ also lacks these dunders. All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0 2026-04-13.]
  created_at: "2026-04-13"

table ab2926.iand:
  kind: python_call_eq
  columns: [id, function, args, expected]
  rows:
    - ["ab2926001", operator.contains, [abc.ABC.__dict__, "__iand__"], false]
    - ["ab2926002", operator.contains, [abc.ABCMeta.__dict__, "__iand__"], false]
    - ["ab2926003", operator.contains, [abc.abstractmethod.__dict__, "__iand__"], false]
    - ["ab2926004", operator.contains, [abc.abstractclassmethod.__dict__, "__iand__"], false]
    - ["ab2926005", operator.contains, [abc.abstractstaticmethod.__dict__, "__iand__"], false]
    - ["ab2926006", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__, "__iand__"], false]

