spec: socket_extra91
version: ">=3.9"
extends: socket_extra90
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra90.zspec.zsdl — covers socket.socket Python-level method __class__.__name__ identity (accept/close/makefile/__init__/sendfile/detach/dup/__enter__/__exit__/__repr__/create_connection/create_server/getfqdn all 'function') (table + invariants)."
    - "socket_extra89.zspec.zsdl — covers socket module integer constants class identity (AF_INET/AF_INET6/AF_UNSPEC AddressFamily, SOCK_DGRAM/SOCK_RAW/SOCK_SEQPACKET SocketKind, IPPROTO_TCP/IPPROTO_UDP/IPPROTO_ICMP int, SOL_SOCKET/SOL_TCP int) (table + invariants)."
    - "socket_extra88.zspec.zsdl — covers socket.socket.__dict__ negative membership / AddressFamily and SocketKind class identity (__qualname__/__module__/__mro__.__len__()==6/__name__) (table + invariants)."
    - "socket_extra86.zspec.zsdl — covers socket.socket/__module__/__qualname__/__mro__.__len__()==3/__bases__[0].__name__ / AF_INET/SOCK_STREAM class identity / AddressFamily/SocketKind __bases__[0].__name__/__qualname__ (table + invariants)."
    - "socket_extra58.zspec.zsdl — covers socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__/__cached__ class names (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra90; it does NOT duplicate invariants present in those files."
    - "Wave 256 theme: socket module string identity cross-checks + socket.socket dunder method class names + socket constant class names and values."
    - "socket.__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__package__ == '' (empty string). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__loader__.__class__.__name__ == 'SourceFileLoader'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__spec__.__class__.__name__ == 'ModuleSpec'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.__doc__.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__repr__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__enter__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__exit__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__del__.__class__.__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__getstate__.__class__.__name__ == 'function'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__reduce__.__class__.__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET.__class__.__name__ == 'AddressFamily'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_INET == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM.__class__.__name__ == 'SocketKind'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_STREAM == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.AF_UNSPEC == 0. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SOCK_DGRAM == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket_extra90 anchors __init__/__enter__/__exit__/__repr__ under socketmethcls90; this spec cross-checks them under socketmoduleid91."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.__name__.__eq__('socket')
# socket.__package__.__eq__('')
# socket.__doc__.__class__.__name__.__eq__('str') (cross-check)
# socket.__spec__.__class__.__name__.__eq__('ModuleSpec') (cross-check)
#
# Wave 256 theme: socket module string identity.
#
# socket.__name__ is 'socket' and __package__ is '' (empty string). Early socket
# extras first anchor these; this table cross-checks under socketmoduleid91.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra91.socket_module_string_identity:
  description: "socket.__name__.__eq__('socket')==True / socket.__package__.__eq__('')==True / socket.__doc__/__class__.__name__.__eq__('str')==True / socket.__spec__/__class__.__name__.__eq__('ModuleSpec')==True — socket module identity: __name__ is 'socket', __package__ is empty string, docstring is str, spec is ModuleSpec; early extras first anchor __name__/__package__; this table cross-checks under socketmoduleid91; first socketmoduleid91 anchor for socket module string identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: socketmoduleid91

  columns: [id, function, args, expected]
  rows:
    - [socket_name_eq,       __name__.__eq__,                       ["socket"],      true]
    - [socket_package_eq,    __package__.__eq__,                    [""],             true]
    - [socket_doc_class_eq,  __doc__.__class__.__name__.__eq__,     ["str"],          true]
    - [socket_spec_class_eq, __spec__.__class__.__name__.__eq__,    ["ModuleSpec"],   true]

# ---------------------------------------------------------------------------
# socket.__spec__.__class__.__name__.__eq__('ModuleSpec')
# socket.__loader__.__class__.__name__.__eq__('SourceFileLoader')
# socket.__doc__.__class__.__name__.__eq__('str') (cross-check)
# socket.__name__.__eq__('socket') (cross-check)
#
# Wave 256 theme: socket.__spec__ and __loader__ class names.
#
# socket.__spec__ is a ModuleSpec instance and socket.__loader__ is a
# SourceFileLoader (socket.py is a Python wrapper module). socket_extra58
# first anchors these; this table cross-checks under socketmoduleid91.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra91.socket_spec_loader_class_names:
  description: "socket.__spec__/__class__.__name__.__eq__('ModuleSpec')==True / socket.__loader__/__class__.__name__.__eq__('SourceFileLoader')==True / socket.__doc__/__class__.__name__.__eq__('str')==True / socket.__name__.__eq__('socket')==True — socket.py is a Python wrapper loaded by SourceFileLoader; its spec is a ModuleSpec; socket_extra58 first anchors loader/spec class names; this table cross-checks under socketmoduleid91; first socketmoduleid91 anchor for spec/loader class identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: socketmoduleid91

  columns: [id, function, args, expected]
  rows:
    - [socket_spec_modulespec,     __spec__.__class__.__name__.__eq__,    ["ModuleSpec"],       true]
    - [socket_loader_sourceloader, __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"], true]
    - [socket_doc_str_xchk,        __doc__.__class__.__name__.__eq__,     ["str"],              true]
    - [socket_name_xchk,           __name__.__eq__,                       ["socket"],           true]

# ---------------------------------------------------------------------------
# socket.socket.__init__/__class__.__name__.__eq__('function') (cross-check)
# socket.socket.__repr__/__class__.__name__.__eq__('function') (cross-check)
# socket.socket.__enter__/__class__.__name__.__eq__('function') (cross-check)
# socket.socket.__exit__/__class__.__name__.__eq__('function') (cross-check)
# socket.socket.__del__/__class__.__name__.__eq__('wrapper_descriptor')
# socket.socket.__getstate__/__class__.__name__.__eq__('function')
#
# Wave 256 theme: socket.socket dunder method class names.
#
# socket.socket.__init__, __repr__, __enter__, __exit__, and __getstate__ are
# Python-level functions (class name 'function'). __del__ is a C-level
# wrapper_descriptor. socket_extra90 anchors __init__/__enter__/__exit__/__repr__
# under socketmethcls90; this table cross-checks them and adds __del__ and
# __getstate__ under socketmoduleid91. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra91.socket_dunder_class_names:
  description: "socket.socket.__init__/__class__.__name__.__eq__('function')==True / __repr__/__class__.__name__.__eq__('function')==True / __enter__/__class__.__name__.__eq__('function')==True / __exit__/__class__.__name__.__eq__('function')==True / __del__/__class__.__name__.__eq__('wrapper_descriptor')==True / __getstate__/__class__.__name__.__eq__('function')==True — socket.socket.__init__/__repr__/__enter__/__exit__/__getstate__ are Python functions; __del__ is a C wrapper_descriptor; socket_extra90 anchors __init__/__enter__/__exit__/__repr__; this table cross-checks and adds __del__/__getstate__ under socketmoduleid91; first socketmoduleid91 anchor for socket dunder method class names"
  kind: python_call_eq
  category: module_identity
  id_prefix: socketmoduleid91

  columns: [id, function, args, expected]
  rows:
    - [socket_init_function,       socket.__init__.__class__.__name__.__eq__,      ["function"],          true]
    - [socket_repr_function,       socket.__repr__.__class__.__name__.__eq__,      ["function"],          true]
    - [socket_enter_function,      socket.__enter__.__class__.__name__.__eq__,     ["function"],          true]
    - [socket_exit_function,       socket.__exit__.__class__.__name__.__eq__,      ["function"],          true]
    - [socket_del_wrapper_desc,    socket.__del__.__class__.__name__.__eq__,       ["wrapper_descriptor"], true]
    - [socket_getstate_function,   socket.__getstate__.__class__.__name__.__eq__,  ["function"],          true]

# ---------------------------------------------------------------------------
# socket.AF_INET/__class__.__name__.__eq__('AddressFamily') (cross-check)
# socket.SOCK_STREAM/__class__.__name__.__eq__('SocketKind') (cross-check)
# socket.AF_INET.__eq__(2)
# socket.SOCK_STREAM.__eq__(1)
# socket.AF_UNSPEC.__eq__(0)
# socket.SOCK_DGRAM.__eq__(2)
#
# Wave 256 theme: socket constant class names and integer values.
#
# AF_INET is AddressFamily with value 2, SOCK_STREAM is SocketKind with value 1,
# AF_UNSPEC is AddressFamily with value 0, SOCK_DGRAM is SocketKind with value 2.
# socket_extra89 anchors class names; socket_extra86 anchors AF_INET/SOCK_STREAM
# identity; this table adds value equality under socketmoduleid91.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra91.socket_constant_values:
  description: "socket.AF_INET/__class__.__name__.__eq__('AddressFamily')==True / SOCK_STREAM/__class__.__name__.__eq__('SocketKind')==True / AF_INET.__eq__(2)==True / SOCK_STREAM.__eq__(1)==True / AF_UNSPEC.__eq__(0)==True / SOCK_DGRAM.__eq__(2)==True — AF_INET/AF_UNSPEC are AddressFamily; SOCK_STREAM/SOCK_DGRAM are SocketKind; socket_extra89 anchors class names; socket_extra86 anchors AF_INET/SOCK_STREAM identity; this table adds integer value equality; first socketmoduleid91 anchor for socket constant values"
  kind: python_call_eq
  category: module_identity
  id_prefix: socketmoduleid91

  columns: [id, function, args, expected]
  rows:
    - [af_inet_class_xchk,    AF_INET.__class__.__name__.__eq__,   ["AddressFamily"], true]
    - [sock_stream_class_xchk, SOCK_STREAM.__class__.__name__.__eq__, ["SocketKind"], true]
    - [af_inet_value_eq,      AF_INET.__eq__,                      [2],               true]
    - [sock_stream_value_eq,  SOCK_STREAM.__eq__,                  [1],               true]
    - [af_unspec_value_eq,    AF_UNSPEC.__eq__,                    [0],               true]
    - [sock_dgram_value_eq,   SOCK_DGRAM.__eq__,                   [2],               true]

# ---------------------------------------------------------------------------
# socket.__name__.__eq__('socket') — standalone
#
# socket.__name__ is 'socket'. Early socket extras first anchor this; this
# standalone re-anchors under socketmoduleid91. First standalone for
# socket.__name__ under socketmoduleid91.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra91.socket_name_eq:
  description: "socket.__name__.__eq__('socket') == True — the socket module's __name__ attribute is 'socket'; early socket extras first anchor this; this standalone re-anchors under socketmoduleid91 as a cross-check; first standalone for socket.__name__ under socketmoduleid91"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') — standalone
#
# socket.__loader__.__class__.__name__ is 'SourceFileLoader'. socket.py is a
# Python wrapper module loaded by importlib.machinery.SourceFileLoader.
# socket_extra58 first anchors this; this standalone re-anchors under
# socketmoduleid91. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra91.socket_loader_sourcefileloader:
  description: "socket.__loader__.__class__.__name__.__eq__('SourceFileLoader') == True — socket.py is a Python wrapper module loaded by importlib.machinery.SourceFileLoader; __class__.__name__ is 'SourceFileLoader'; socket_extra58 first anchors this; first standalone for socket.__loader__ class identity under socketmoduleid91"
  category: module_identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__del__.__class__.__name__.__eq__('wrapper_descriptor') — standalone
#
# socket.socket.__del__ is a C-level wrapper_descriptor (unlike __init__ and
# __repr__ which are Python-level functions). Its __class__.__name__ is
# 'wrapper_descriptor'. No prior socket spec anchors socket.__del__.__class__.__name__.__eq__
# as a standalone. First standalone for socket.socket.__del__ class identity.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra91.socket_del_wrapper_desc:
  description: "socket.socket.__del__.__class__.__name__.__eq__('wrapper_descriptor') == True — socket.socket.__del__ is a C-level wrapper_descriptor (unlike the Python-level __init__/__repr__/__enter__/__exit__ which are 'function'); its __class__.__name__ is 'wrapper_descriptor'; no prior socket spec anchors this __eq__ call; first standalone for socket.socket.__del__ class identity under socketmoduleid91"
  category: module_identity
  kind: python_call_eq
  function: socket.__del__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# socket.AF_INET.__eq__(2) — standalone
#
# socket.AF_INET has integer value 2. It is an AddressFamily IntEnum member.
# socket_extra86 and socket_extra89 anchor its class identity but not its
# integer value via __eq__. No prior socket spec anchors AF_INET.__eq__(2)
# as a standalone under socketmoduleid91. First standalone for AF_INET value.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra91.af_inet_value_eq:
  description: "socket.AF_INET.__eq__(2) == True — AF_INET is the IPv4 address family with integer value 2; it is an AddressFamily IntEnum member; socket_extra86/socket_extra89 anchor its class identity; this standalone anchors the integer value via __eq__; first standalone for AF_INET integer value under socketmoduleid91"
  category: module_identity
  kind: python_call_eq
  function: AF_INET.__eq__
  args: [2]
  expected: true

# ---------------------------------------------------------------------------
# socket.SOCK_STREAM.__eq__(1) — standalone
#
# socket.SOCK_STREAM has integer value 1. It is a SocketKind IntEnum member.
# No prior socket spec anchors SOCK_STREAM.__eq__(1) as a standalone under
# socketmoduleid91. First standalone for SOCK_STREAM value.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra91.sock_stream_value_eq:
  description: "socket.SOCK_STREAM.__eq__(1) == True — SOCK_STREAM is the TCP stream socket kind with integer value 1; it is a SocketKind IntEnum member; socket_extra86/socket_extra89 anchor its class identity; this standalone anchors the integer value via __eq__; first standalone for SOCK_STREAM integer value under socketmoduleid91"
  category: module_identity
  kind: python_call_eq
  function: SOCK_STREAM.__eq__
  args: [1]
  expected: true
