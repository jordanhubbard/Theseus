spec: py_compile_extra5
version: ">=3.9"
backend: python_module(py_compile)

docs: https://docs.python.org/3/library/py_compile.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/py_compile.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/py_compile.py"
    - "py_compile.zspec.zsdl — covers compile/__name__/__module__, PyCompileError/__name__/base/__str__.__name__, PycInvalidationMode/__name__ and TIMESTAMP/CHECKED_HASH/UNCHECKED_HASH class names and values"
    - "py_compile_extra.zspec.zsdl — covers compile/__name__/__module__, PycInvalidationMode/__name__, PyCompileError/__name__/__module__/base, enum member class names/values, value ordering"
    - "py_compile_extra2.zspec.zsdl — covers PycInvalidationMode/__module__/__bases__[0]/__name__=='int', class_names table"
    - "py_compile_extra3.zspec.zsdl — covers compile/__qualname__, PycInvalidationMode/__qualname__, PyCompileError/__qualname__ via table"
    - "py_compile_extra4.zspec.zsdl — covers compile/__class__.__name__=='function', PyCompileError/__bases__/__len__()==1, PyCompileError/__str__.__module__, PycInvalidationMode/_member_names_ len/membership, PycInvalidationMode TIMESTAMP/CHECKED_HASH/UNCHECKED_HASH .name attribute"
  notes:
    - "This spec adds invariants not covered in any prior py_compile spec."
    - "PycInvalidationMode._value2member_map_ is a dict — the enum's internal mapping from values to members; no prior spec checks this attribute."
    - "PycInvalidationMode._value2member_map_.__len__() == 3 — there are exactly 3 values (1, 2, 3) mapped."
    - "PycInvalidationMode._value2member_map_.__contains__(1) == True — value 1 (TIMESTAMP) is present in the map."
    - "PycInvalidationMode._value2member_map_.__contains__(2) == True — value 2 (CHECKED_HASH) is present."
    - "PycInvalidationMode._value2member_map_.__contains__(3) == True — value 3 (UNCHECKED_HASH) is present."
    - "PycInvalidationMode.UNCHECKED_HASH.value > 1 — UNCHECKED_HASH (3) > 1; a simple ordering check not in any prior spec."
    - "PyCompileError.__init__.__name__ == '__init__' — the constructor method name; not checked in any prior spec."
    - "compile.__doc__ is not None — the compile function has a docstring; verifiable via __doc__.__class__.__name__ == 'str'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# PycInvalidationMode._value2member_map_ — enum internal value-to-member mapping
# No prior py_compile spec checks _value2member_map_ at all.
# ---------------------------------------------------------------------------

invariant py_compile_extra5.PycInvalidationMode.value2member_is_dict:
  description: "PycInvalidationMode._value2member_map_.__class__.__name__ == 'dict'"
  category: PycInvalidationMode
  kind: python_call_eq
  function: PycInvalidationMode._value2member_map_.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant py_compile_extra5.PycInvalidationMode.value2member_len:
  description: "len(PycInvalidationMode._value2member_map_) == 3 — exactly 3 enum values"
  category: PycInvalidationMode
  kind: python_call_eq
  function: PycInvalidationMode._value2member_map_.__len__
  args: []
  expected: 3

table py_compile_extra5.PycInvalidationMode.value2member_contains:
  kind: python_call_eq
  category: PycInvalidationMode
  id_prefix: v2m

  columns: [id, function, args, expected]
  rows:
    - [timestamp,      PycInvalidationMode._value2member_map_.__contains__, [1], true]
    - [checked_hash,   PycInvalidationMode._value2member_map_.__contains__, [2], true]
    - [unchecked_hash, PycInvalidationMode._value2member_map_.__contains__, [3], true]

# ---------------------------------------------------------------------------
# PycInvalidationMode.UNCHECKED_HASH.value ordering
# py_compile_extra covers TIMESTAMP < CHECKED_HASH and CHECKED_HASH < UNCHECKED_HASH.
# This adds UNCHECKED_HASH.value > 1 — a simpler ordering fact not in any prior spec.
# ---------------------------------------------------------------------------

invariant py_compile_extra5.PycInvalidationMode.UNCHECKED_HASH_gt_one:
  description: "PycInvalidationMode.UNCHECKED_HASH.value > 1 — UNCHECKED_HASH (3) is greater than 1"
  category: PycInvalidationMode
  kind: python_call_eq
  function: PycInvalidationMode.UNCHECKED_HASH.value.__gt__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# PyCompileError.__init__.__name__ — constructor method name
# No prior py_compile spec checks PyCompileError.__init__.__name__.
# ---------------------------------------------------------------------------

invariant py_compile_extra5.PyCompileError.init_name:
  description: "py_compile.PyCompileError.__init__.__name__ == '__init__'"
  category: PyCompileError
  kind: python_call_eq
  function: PyCompileError.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

# ---------------------------------------------------------------------------
# compile.__doc__ — confirms a docstring is present
# No prior py_compile spec checks __doc__. The docstring is a str.
# ---------------------------------------------------------------------------

invariant py_compile_extra5.compile.doc_is_str:
  description: "py_compile.compile.__doc__.__class__.__name__ == 'str' — compile has a docstring"
  category: compile
  kind: python_call_eq
  function: compile.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# PyCompileError.__doc__ — confirms PyCompileError has a docstring
# No prior py_compile spec checks PyCompileError.__doc__.
# ---------------------------------------------------------------------------

invariant py_compile_extra5.PyCompileError.doc_is_str:
  description: "py_compile.PyCompileError.__doc__.__class__.__name__ == 'str' — PyCompileError has a docstring"
  category: PyCompileError
  kind: python_call_eq
  function: PyCompileError.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
