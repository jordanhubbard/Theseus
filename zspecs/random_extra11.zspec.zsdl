spec: random_extra11
version: ">=3.9"
backend: python_module(random)

docs: https://docs.python.org/3/library/random.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/random.html — Python random module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/random.py"
  notes:
    - "This spec extends random.zspec.zsdl and prior extras through random_extra10.zspec.zsdl."
    - "Prior specs cover: __name__, __module__, __qualname__ for all module-level functions and classes; BPF/VERSION/RECIP_BPF; deterministic randint/choice/randrange/uniform/getrandbits/sample vectors; shuffle/choices return types; MRO length; gauss/normalvariate value vectors; distribution function qualnames."
    - "random_extra.zspec.zsdl: Random.__module__, SystemRandom.__name__; function __name__ for randint/randrange/uniform/choice/choices/sample/shuffle/gauss/normalvariate/seed/getstate/setstate."
    - "random_extra2.zspec.zsdl: getrandbits/__name__, triangular/__name__, betavariate/__name__, expovariate/__name__."
    - "random_extra5.zspec.zsdl: expovariate/__qualname__, betavariate/__qualname__."
    - "random_extra6.zspec.zsdl: gammavariate/__qualname__, lognormvariate/__qualname__, triangular/__qualname__, vonmisesvariate/__qualname__, paretovariate/__qualname__, weibullvariate/__qualname__."
    - "No prior spec covers deterministic value vectors for triangular, expovariate, or betavariate."
    - "Random(42).triangular(0,1,0.5) == 0.5753983033817951 — seeded triangular draw."
    - "Random(0).triangular(0,1,0.5) == 0.7210930724462443 — seeded triangular draw from seed 0."
    - "Random(42).expovariate(1.0) == 1.020060287274801 — seeded exponential draw (lambda=1)."
    - "Random(0).expovariate(1.0) == 1.8606071110652234 — seeded exponential draw from seed 0."
    - "Random(42).betavariate(2,5) == 0.13961892090489622 — seeded beta draw (alpha=2, beta=5)."
    - "Random(0).betavariate(2,5) == 0.541680230537891 — seeded beta draw from seed 0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Random.triangular() — deterministic value vectors
#
# triangular(low, high, mode) returns a random float from a triangular
# distribution. prior specs verify triangular.__name__ and __qualname__ but
# no spec tests actual output with a fixed seed.
# ---------------------------------------------------------------------------

invariant random_extra11.triangular.seed42_midpoint:
  description: "Random(42).triangular(0,1,0.5) == 0.5753983033817951 — seeded triangular draw"
  category: triangular
  kind: python_call_eq
  function: Random
  args: [42]
  method: triangular
  method_args: [0, 1, 0.5]
  expected: 0.5753983033817951

invariant random_extra11.triangular.seed0_midpoint:
  description: "Random(0).triangular(0,1,0.5) == 0.7210930724462443 — seeded triangular draw from seed 0"
  category: triangular
  kind: python_call_eq
  function: Random
  args: [0]
  method: triangular
  method_args: [0, 1, 0.5]
  expected: 0.7210930724462443

# ---------------------------------------------------------------------------
# Random.expovariate() — deterministic value vectors
#
# expovariate(lambd) returns a random float from an exponential distribution
# with rate parameter lambd. No prior spec covers actual value output.
# ---------------------------------------------------------------------------

invariant random_extra11.expovariate.seed42_lambda1:
  description: "Random(42).expovariate(1.0) == 1.020060287274801 — seeded exponential draw (lambda=1)"
  category: expovariate
  kind: python_call_eq
  function: Random
  args: [42]
  method: expovariate
  method_args: [1.0]
  expected: 1.020060287274801

invariant random_extra11.expovariate.seed0_lambda1:
  description: "Random(0).expovariate(1.0) == 1.8606071110652234 — seeded exponential draw from seed 0"
  category: expovariate
  kind: python_call_eq
  function: Random
  args: [0]
  method: expovariate
  method_args: [1.0]
  expected: 1.8606071110652234

# ---------------------------------------------------------------------------
# Random.betavariate() — deterministic value vectors
#
# betavariate(alpha, beta) samples from the beta distribution. The beta
# distribution is bounded to [0, 1]. No prior spec covers value vectors.
# ---------------------------------------------------------------------------

invariant random_extra11.betavariate.seed42_alpha2_beta5:
  description: "Random(42).betavariate(2,5) == 0.13961892090489622 — seeded beta draw (alpha=2, beta=5)"
  category: betavariate
  kind: python_call_eq
  function: Random
  args: [42]
  method: betavariate
  method_args: [2, 5]
  expected: 0.13961892090489622

invariant random_extra11.betavariate.seed0_alpha2_beta5:
  description: "Random(0).betavariate(2,5) == 0.541680230537891 — seeded beta draw from seed 0"
  category: betavariate
  kind: python_call_eq
  function: Random
  args: [0]
  method: betavariate
  method_args: [2, 5]
  expected: 0.541680230537891

# ---------------------------------------------------------------------------
# Random().random() — deterministic value vectors
#
# random() returns a random float in [0.0, 1.0). Prior specs cover getrandbits
# and uniform value vectors extensively but not the base random() method itself.
# ---------------------------------------------------------------------------

invariant random_extra11.random_method.seed42:
  description: "Random(42).random() == 0.6394267984578837 — first float sample from seed 42"
  category: random_method
  kind: python_call_eq
  function: Random
  args: [42]
  method: random
  method_args: []
  expected: 0.6394267984578837

invariant random_extra11.random_method.seed0:
  description: "Random(0).random() == 0.8444218515250481 — first float sample from seed 0"
  category: random_method
  kind: python_call_eq
  function: Random
  args: [0]
  method: random
  method_args: []
  expected: 0.8444218515250481
