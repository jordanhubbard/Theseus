spec: io_extra418
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "io.IOBase methods readable, writable, seekable, readline, readlines, writelines, flush, close, __enter__, __exit__ each report __name__ matching their Python-level name"
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.IOBase method __name__ identity
# ---------------------------------------------------------------------------

table io_extra418.iobase_method_names:
  description: "io.IOBase method __name__ identity — readable, writable, seekable, readline, readlines, writelines, flush, close, __enter__, __exit__; each method's __name__ matches its Python-level name; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iobase418

  columns: [id, function, args, expected]
  rows:
    - [readable_name,   io.IOBase.readable.__name__.__eq__,   ["readable"],   true]
    - [writable_name,   io.IOBase.writable.__name__.__eq__,   ["writable"],   true]
    - [seekable_name,   io.IOBase.seekable.__name__.__eq__,   ["seekable"],   true]
    - [readline_name,   io.IOBase.readline.__name__.__eq__,   ["readline"],   true]
    - [readlines_name,  io.IOBase.readlines.__name__.__eq__,  ["readlines"],  true]
    - [writelines_name, io.IOBase.writelines.__name__.__eq__, ["writelines"], true]
    - [flush_name,      io.IOBase.flush.__name__.__eq__,      ["flush"],      true]
    - [close_name,      io.IOBase.close.__name__.__eq__,      ["close"],      true]
    - [enter_name,      "io.IOBase.__enter__.__name__.__eq__", ["__enter__"],  true]
    - [exit_name,       "io.IOBase.__exit__.__name__.__eq__",  ["__exit__"],   true]
