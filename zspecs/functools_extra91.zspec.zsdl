spec: functools_extra91
version: ">=3.9"
backend: python_module(functools)
extends: functools_extra90

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra90.zspec.zsdl."
    - "This spec covers: functools reduce/cmp_to_key C-type __module__ equality and partial class __dict__ membership (Wave 250)."
    - "functools.reduce.__module__.__eq__('_functools') == True — reduce is implemented in _functoolsmodule.c; its __module__ is '_functools'. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is implemented in _functoolsmodule.c; its __module__ is '_functools'. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__contains__('__call__') == True — partial defines __call__ in its own C-level dict. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__contains__('__new__') == True — partial defines __new__ in its own C-level dict. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__contains__('__repr__') == True — partial defines __repr__ in its own C-level dict. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__contains__('__reduce__') == True — partial defines __reduce__ in its own C-level dict. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__contains__('__setstate__') == True — partial defines __setstate__ in its own C-level dict. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__contains__('func') == True — 'func' is a slot/member on the partial C type. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__contains__('args') == True — 'args' is a slot/member on the partial C type. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__contains__('keywords') == True — 'keywords' is a slot/member on the partial C type. Verified with Python 3.14.3."
    - "functools.partial.__dict__.__class__.__name__ == 'mappingproxy' — C extension type __dict__ is a mappingproxy. Verified with Python 3.14.3."
    - "functools.partial.__name__.__eq__('partial') == True — __name__ is 'partial' (7 chars). Verified with Python 3.14.3."
    - "functools.partial.__qualname__.__eq__('partial') == True — __qualname__ matches __name__ for module-level type. Verified with Python 3.14.3."
    - "functools.partial.__module__.__eq__('functools') == True — partial is exposed via functools despite being implemented in _functools. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# reduce/cmp_to_key __module__ equality — extra91
#
# Wave 250 theme: reduce/cmp_to_key C-type __module__ string equality.
#
# functools.reduce.__module__.__eq__('_functools')      == True
# functools.cmp_to_key.__module__.__eq__('_functools')  == True
# functools.partial.__dict__.__contains__('__call__')   == True
# functools.partial.__dict__.__contains__('__new__')    == True
#
# No prior functools spec checks reduce/__module__.__eq__ or partial dict membership via functoolsextra91. New to extra91.
# ---------------------------------------------------------------------------

table functools_extra91.reduce_cmp_to_key_module_and_partial_dict_group1:
  description: "reduce/__module__==_functools; cmp_to_key/__module__==_functools; partial dict contains __call__/__new__; wave 250; new to extra91"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra91

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_module_eq_functools,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — reduce is a C built-in function defined in Modules/_functoolsmodule.c; its __module__ attribute reflects the C extension module name '_functools', not 'functools'; str.__eq__('_functools') returns True; no prior functools spec checks reduce.__module__.__eq__ via functoolsextra91; new to extra91"]
    - [cmp_to_key_module_eq_functools,
       cmp_to_key.__module__.__eq__,
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is a C built-in function defined in Modules/_functoolsmodule.c; its __module__ attribute is '_functools'; str.__eq__('_functools') returns True; no prior functools spec checks cmp_to_key.__module__.__eq__ via functoolsextra91; new to extra91"]
    - [partial_dict_contains_call,
       "partial.__dict__.__contains__",
       ["__call__"],
       true,
       "functools.partial.__dict__.__contains__('__call__') == True — partial is a C extension type; it defines __call__ in its own type dict (tp_call slot exposed as a slot wrapper); mappingproxy.__contains__('__call__') returns True; no prior functools spec checks partial.__dict__.__contains__('__call__') via functoolsextra91; new to extra91"]
    - [partial_dict_contains_new,
       "partial.__dict__.__contains__",
       ["__new__"],
       true,
       "functools.partial.__dict__.__contains__('__new__') == True — partial is a C extension type; it defines __new__ in its own type dict to initialize partial instances; mappingproxy.__contains__('__new__') returns True; no prior functools spec checks partial.__dict__.__contains__('__new__') via functoolsextra91; new to extra91"]

# ---------------------------------------------------------------------------
# partial __dict__ membership group 2 — __repr__/__reduce__/__setstate__ + func — extra91
#
# Wave 250 theme: partial C-type __dict__ contains method and slot names.
#
# functools.partial.__dict__.__contains__('__repr__')     == True
# functools.partial.__dict__.__contains__('__reduce__')   == True
# functools.partial.__dict__.__contains__('__setstate__') == True
# functools.partial.__dict__.__contains__('func')         == True
#
# No prior functools spec checks these via functoolsextra91. New to extra91.
# ---------------------------------------------------------------------------

table functools_extra91.partial_dict_group2:
  description: "partial dict contains __repr__/__reduce__/__setstate__/func; wave 250 partial C-type dict membership; new to extra91"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra91

  columns: [id, function, args, expected, description]
  rows:
    - [partial_dict_contains_repr,
       "partial.__dict__.__contains__",
       ["__repr__"],
       true,
       "functools.partial.__dict__.__contains__('__repr__') == True — partial is a C extension type; it defines __repr__ in its own type dict to produce a human-readable representation like 'functools.partial(...)'; mappingproxy.__contains__('__repr__') returns True; no prior functools spec checks partial.__dict__.__contains__('__repr__') via functoolsextra91; new to extra91"]
    - [partial_dict_contains_reduce,
       "partial.__dict__.__contains__",
       ["__reduce__"],
       true,
       "functools.partial.__dict__.__contains__('__reduce__') == True — partial is a C extension type; it defines __reduce__ in its own type dict to support pickling; mappingproxy.__contains__('__reduce__') returns True; no prior functools spec checks partial.__dict__.__contains__('__reduce__') via functoolsextra91; new to extra91"]
    - [partial_dict_contains_setstate,
       "partial.__dict__.__contains__",
       ["__setstate__"],
       true,
       "functools.partial.__dict__.__contains__('__setstate__') == True — partial is a C extension type; it defines __setstate__ in its own type dict to restore a pickled partial object; mappingproxy.__contains__('__setstate__') returns True; no prior functools spec checks partial.__dict__.__contains__('__setstate__') via functoolsextra91; new to extra91"]
    - [partial_dict_contains_func,
       "partial.__dict__.__contains__",
       ["func"],
       true,
       "functools.partial.__dict__.__contains__('func') == True — 'func' is a member descriptor (slot) on the partial C type exposing the wrapped callable; it appears in the type's __dict__; mappingproxy.__contains__('func') returns True; no prior functools spec checks partial.__dict__.__contains__('func') via functoolsextra91; new to extra91"]

# ---------------------------------------------------------------------------
# partial __dict__ membership group 3 — args/keywords + __dict__ class name — extra91
#
# Wave 250 theme: partial C-type slot membership + mappingproxy identity.
#
# functools.partial.__dict__.__contains__('args')         == True
# functools.partial.__dict__.__contains__('keywords')     == True
# functools.partial.__dict__.__class__.__name__           == 'mappingproxy'
# functools.partial.__name__.__eq__('partial')            == True
#
# No prior functools spec checks these via functoolsextra91. New to extra91.
# ---------------------------------------------------------------------------

table functools_extra91.partial_dict_group3_and_name:
  description: "partial dict contains args/keywords; dict class==mappingproxy; partial __name__==partial; wave 250; new to extra91"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra91

  columns: [id, function, args, expected, description]
  rows:
    - [partial_dict_contains_args,
       "partial.__dict__.__contains__",
       ["args"],
       true,
       "functools.partial.__dict__.__contains__('args') == True — 'args' is a member descriptor (slot) on the partial C type exposing the positional arguments tuple stored in the partial; mappingproxy.__contains__('args') returns True; no prior functools spec checks partial.__dict__.__contains__('args') via functoolsextra91; new to extra91"]
    - [partial_dict_contains_keywords,
       "partial.__dict__.__contains__",
       ["keywords"],
       true,
       "functools.partial.__dict__.__contains__('keywords') == True — 'keywords' is a member descriptor (slot) on the partial C type exposing the keyword arguments dict stored in the partial; mappingproxy.__contains__('keywords') returns True; no prior functools spec checks partial.__dict__.__contains__('keywords') via functoolsextra91; new to extra91"]
    - [partial_dict_class_name_eq_mappingproxy,
       "partial.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "functools.partial.__dict__.__class__.__name__.__eq__('mappingproxy') == True — partial is a C extension type; the __dict__ attribute of a type object is always a mappingproxy (types.MappingProxyType); __class__.__name__ is 'mappingproxy'; str.__eq__('mappingproxy') returns True; no prior functools spec checks partial.__dict__.__class__.__name__ via functoolsextra91; new to extra91"]
    - [partial_name_eq_partial,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is the C extension type for the partial object; its __name__ attribute is the string 'partial' (7 chars); str.__eq__('partial') returns True; no prior functools spec checks partial.__name__.__eq__ via functoolsextra91; new to extra91"]

# ---------------------------------------------------------------------------
# partial __qualname__ / __module__ — extra91
#
# Wave 250 theme: partial C-type __qualname__ and __module__ string equality.
#
# functools.partial.__qualname__.__eq__('partial')   == True
# functools.partial.__module__.__eq__('functools')   == True
# functools.reduce.__module__.__eq__('_functools')   == True  (double-confirm)
# functools.cmp_to_key.__module__.__eq__('_functools') == True  (double-confirm)
#
# No prior functools spec checks partial.__qualname__.__eq__ or partial.__module__.__eq__ via functoolsextra91. New to extra91.
# ---------------------------------------------------------------------------

table functools_extra91.partial_qualname_module_and_confirms:
  description: "partial __qualname__==partial; partial __module__==functools; reduce/cmp_to_key module double-confirm; wave 250; new to extra91"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsextra91

  columns: [id, function, args, expected, description]
  rows:
    - [partial_qualname_eq_partial,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — partial is defined at module scope in the _functools C extension; for C extension types at module scope __qualname__ equals __name__; __qualname__ is 'partial' (7 chars); str.__eq__('partial') returns True; no prior functools spec checks partial.__qualname__.__eq__ via functoolsextra91; new to extra91"]
    - [partial_module_eq_functools,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — despite being implemented in _functoolsmodule.c, the partial type sets its __module__ to 'functools' to present a clean public API; str.__eq__('functools') returns True; no prior functools spec checks partial.__module__.__eq__ via functoolsextra91; new to extra91"]
    - [reduce_module_eq_functools_confirm,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — double-confirms reduce.__module__ is '_functools'; the reduce C built-in does not override __module__ to 'functools' unlike the partial type; str.__eq__('_functools') returns True; new to extra91"]
    - [cmp_to_key_module_eq_functools_confirm,
       cmp_to_key.__module__.__eq__,
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — double-confirms cmp_to_key.__module__ is '_functools'; the cmp_to_key C built-in does not override __module__ to 'functools'; str.__eq__('_functools') returns True; new to extra91"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra91
# ---------------------------------------------------------------------------

invariant functools_extra91.reduce_module_eq:
  description: "functools.reduce.__module__.__eq__('_functools') == True — reduce is a C built-in from _functoolsmodule.c; its __module__ is '_functools'; wave 250; new to extra91"
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra91.cmp_to_key_module_eq:
  description: "functools.cmp_to_key.__module__.__eq__('_functools') == True — cmp_to_key is a C built-in; its __module__ is '_functools'; wave 250; new to extra91"
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra91.partial_dict_contains_call:
  description: "functools.partial.__dict__.__contains__('__call__') == True — partial C type defines __call__ in its type dict; wave 250; new to extra91"
  kind: python_call_eq
  function: "partial.__dict__.__contains__"
  args: ["__call__"]
  expected: true

invariant functools_extra91.partial_dict_contains_func:
  description: "functools.partial.__dict__.__contains__('func') == True — 'func' is a member descriptor slot on partial; wave 250; new to extra91"
  kind: python_call_eq
  function: "partial.__dict__.__contains__"
  args: ["func"]
  expected: true

invariant functools_extra91.partial_module_eq_functools:
  description: "functools.partial.__module__.__eq__('functools') == True — partial type sets __module__ to 'functools' for clean public API; wave 250; new to extra91"
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true
