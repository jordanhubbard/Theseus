spec: six_rust
version: ">=3.9"
backend: rust_module(six_rust)

docs: https://six.readthedocs.io/

provenance:
  derived_from:
    - "https://six.readthedocs.io/ — six library documentation"
  not_derived_from:
    - "six source: six.py"
  notes:
    - "Clean-room Rust reimplementation of Python six compatibility utilities, exposed via PyO3."
    - "six provides utilities for Python 2/3 compatibility."
    - "PY3 == True — running on Python 3."
    - "PY2 == False — not running on Python 2."
    - "ensure_str(s) converts bytes or str to str."
    - "ensure_str('hello') == 'hello' — str passes through."
    - "ensure_str(b'hello') == 'hello' — bytes decoded to str."
    - "ensure_binary(s) converts bytes or str to bytes."
    - "ensure_binary('hello') == b'hello' — str encoded to bytes."
    - "ensure_binary(b'hello') == b'hello' — bytes passes through."
    - "All test vectors verified against six 1.17.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# PY3 and PY2 version flags
table six_rust.version_flags:
  kind: python_call_eq
  category: constants
  id_prefix: six_flag

  columns: [id, function, args, expected]
  rows:
    - [py3, PY3.__eq__, [true],  true]
    - [py2, PY2.__eq__, [false], true]

# ensure_str — convert bytes or str to str
table six_rust.ensure_str.vectors:
  kind: python_call_eq
  category: ensure_str
  id_prefix: es
  function: ensure_str

  columns: [id, args, expected]
  rows:
    - [str_in,   ["hello"],          "hello"]
    - [bytes_in, [!b64 aGVsbG8=],   "hello"]
    - [empty_s,  [""],               ""]

# ensure_binary — convert bytes or str to bytes
table six_rust.ensure_binary.vectors:
  kind: python_call_eq
  category: ensure_binary
  id_prefix: eb
  function: ensure_binary

  columns: [id, args, expected]
  rows:
    - [str_in,   ["hello"],        !b64 aGVsbG8=]
    - [bytes_in, [!b64 aGVsbG8=], !b64 aGVsbG8=]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T22:00:50Z
  iterations: 1
  pass_count: 7
  fail_count: 0
  total_invariants: 7
  notes: Synthesis succeeded in 1 iteration(s). 7 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
