spec: io_extra1501
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "_io C extension source"
  notes:
    - "Wave 547 (_extra1501): async protocol method __dict__ presence checks for io module classes."
    - "All io classes are synchronous only. None define __await__, __aiter__, __anext__, __aenter__, or __aexit__ in their own __dict__."
    - "io.IOBase is the Python-level abstract base class; its __dict__ contains only Python-level attributes like __abstractmethods__, __doc__, and _abc_impl."
    - "io.BytesIO and io.StringIO are concrete in-memory stream classes. BytesIO.__dict__ contains __iter__, __next__, read, write, and other sync methods but no async protocol dunders."
    - "io.RawIOBase, io.BufferedIOBase, io.TextIOBase are abstract base classes for the three I/O layer types; their __dict__ entries are minimal (module, doc, abstractmethods)."
    - "The async I/O protocol (__aiter__, __anext__, __aenter__, __aexit__) is defined in asyncio stream classes, not in the synchronous io module hierarchy."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1501.iobase_async_protocol:
  description: "io.IOBase async protocol absence — __await__, __aiter__, __anext__, __aenter__, __aexit__ are all absent from io.IOBase.__dict__; io is sync-only; wave 547; new to extra1501"
  kind: python_call_eq
  category: async_protocol
  id_prefix: io1501ib
  columns: [id, function, args, expected, description]
  rows:
    - [io1501ib001,
       io.IOBase.__dict__.__contains__,
       ["__await__"],
       false,
       "io.IOBase.__dict__.__contains__('__await__') == False — io.IOBase is a synchronous I/O base class; it does not implement the awaitable protocol; __await__ is absent from io.IOBase.__dict__; verified with Python 3.12"]
    - [io1501ib002,
       io.IOBase.__dict__.__contains__,
       ["__aiter__"],
       false,
       "io.IOBase.__dict__.__contains__('__aiter__') == False — io.IOBase does not implement the async iterator protocol; __aiter__ is absent; io streams are synchronous only; verified with Python 3.12"]
    - [io1501ib003,
       io.IOBase.__dict__.__contains__,
       ["__anext__"],
       false,
       "io.IOBase.__dict__.__contains__('__anext__') == False — io.IOBase does not implement __anext__; async iteration is not part of the synchronous io module design; verified with Python 3.12"]
    - [io1501ib004,
       io.IOBase.__dict__.__contains__,
       ["__aenter__"],
       false,
       "io.IOBase.__dict__.__contains__('__aenter__') == False — io.IOBase does not implement the async context manager protocol; __aenter__ is absent; the sync context manager protocol (__enter__/__exit__) is inherited from the C-level _io._IOBase, but no async variant exists; verified with Python 3.12"]
    - [io1501ib005,
       io.IOBase.__dict__.__contains__,
       ["__aexit__"],
       false,
       "io.IOBase.__dict__.__contains__('__aexit__') == False — io.IOBase does not implement __aexit__; the async context manager protocol is entirely absent from the io module class hierarchy; verified with Python 3.12"]
    - [io1501ib006,
       io.IOBase.__dict__.__contains__,
       ["__abstractmethods__"],
       true,
       "io.IOBase.__dict__.__contains__('__abstractmethods__') == True — positive anchor: __abstractmethods__ IS defined in io.IOBase.__dict__; this is a Python-level attribute marking IOBase as an abstract class, in contrast to the async protocol dunders which are absent entirely; verified with Python 3.12"]

table io_extra1501.bytesio_stringio_async_protocol:
  description: "io.BytesIO and io.StringIO async protocol absence — neither concrete in-memory stream class defines any async protocol dunder in its __dict__; positive anchors show sync methods that ARE present; wave 547; new to extra1501"
  kind: python_call_eq
  category: async_protocol
  id_prefix: io1501bs
  columns: [id, function, args, expected, description]
  rows:
    - [io1501bs001,
       io.BytesIO.__dict__.__contains__,
       ["__await__"],
       false,
       "io.BytesIO.__dict__.__contains__('__await__') == False — io.BytesIO is an in-memory bytes stream; it is a synchronous class and does not implement the awaitable protocol; __await__ is absent from BytesIO.__dict__; verified with Python 3.12"]
    - [io1501bs002,
       io.BytesIO.__dict__.__contains__,
       ["__aiter__"],
       false,
       "io.BytesIO.__dict__.__contains__('__aiter__') == False — io.BytesIO does not implement __aiter__; async iteration over byte streams requires asyncio, not the synchronous io.BytesIO class; verified with Python 3.12"]
    - [io1501bs003,
       io.BytesIO.__dict__.__contains__,
       ["__aenter__"],
       false,
       "io.BytesIO.__dict__.__contains__('__aenter__') == False — io.BytesIO does not implement the async context manager protocol; __aenter__ is absent; 'async with io.BytesIO()' would raise AttributeError; verified with Python 3.12"]
    - [io1501bs004,
       io.BytesIO.__dict__.__contains__,
       ["__iter__"],
       true,
       "io.BytesIO.__dict__.__contains__('__iter__') == True — positive anchor: BytesIO defines the sync __iter__ in its own __dict__; BytesIO supports synchronous line-by-line iteration but not async iteration; verified with Python 3.12"]
    - [io1501bs005,
       io.BytesIO.__dict__.__contains__,
       ["read"],
       true,
       "io.BytesIO.__dict__.__contains__('read') == True — positive anchor: BytesIO defines 'read' in its own __dict__; the sync read method is present while all async protocol dunders are absent; verified with Python 3.12"]
    - [io1501bs006,
       io.StringIO.__dict__.__contains__,
       ["__await__"],
       false,
       "io.StringIO.__dict__.__contains__('__await__') == False — io.StringIO is an in-memory text stream; it is synchronous and does not implement __await__; verified with Python 3.12"]
    - [io1501bs007,
       io.StringIO.__dict__.__contains__,
       ["__aiter__"],
       false,
       "io.StringIO.__dict__.__contains__('__aiter__') == False — io.StringIO does not implement __aiter__; async text streaming requires asyncio abstractions, not io.StringIO; verified with Python 3.12"]
    - [io1501bs008,
       io.StringIO.__dict__.__contains__,
       ["__aenter__"],
       false,
       "io.StringIO.__dict__.__contains__('__aenter__') == False — io.StringIO does not implement the async context manager protocol; __aenter__ is absent from StringIO.__dict__; verified with Python 3.12"]
    - [io1501bs009,
       io.StringIO.__dict__.__contains__,
       ["read"],
       true,
       "io.StringIO.__dict__.__contains__('read') == True — positive anchor: StringIO defines 'read' in its own __dict__; the sync text-mode read method is present while all five async protocol dunders are absent; verified with Python 3.12"]

table io_extra1501.abstract_bases_async_protocol:
  description: "io.RawIOBase, io.BufferedIOBase, io.TextIOBase async protocol absence — all three abstract base classes lack all five async protocol dunders in their __dict__; wave 547; new to extra1501"
  kind: python_call_eq
  category: async_protocol
  id_prefix: io1501ab
  columns: [id, function, args, expected, description]
  rows:
    - [io1501ab001,
       io.RawIOBase.__dict__.__contains__,
       ["__await__"],
       false,
       "io.RawIOBase.__dict__.__contains__('__await__') == False — io.RawIOBase is the abstract base for raw (unbuffered) I/O; it does not implement __await__; raw I/O is synchronous by design; verified with Python 3.12"]
    - [io1501ab002,
       io.RawIOBase.__dict__.__contains__,
       ["__aiter__"],
       false,
       "io.RawIOBase.__dict__.__contains__('__aiter__') == False — io.RawIOBase does not implement __aiter__; async iteration is absent from the entire synchronous io abstract base class hierarchy; verified with Python 3.12"]
    - [io1501ab003,
       io.RawIOBase.__dict__.__contains__,
       ["__aenter__"],
       false,
       "io.RawIOBase.__dict__.__contains__('__aenter__') == False — io.RawIOBase does not implement the async context manager protocol; __aenter__ is absent; verified with Python 3.12"]
    - [io1501ab004,
       io.BufferedIOBase.__dict__.__contains__,
       ["__await__"],
       false,
       "io.BufferedIOBase.__dict__.__contains__('__await__') == False — io.BufferedIOBase is the abstract base for buffered I/O; it does not implement __await__; buffered streams in the io module are synchronous; verified with Python 3.12"]
    - [io1501ab005,
       io.BufferedIOBase.__dict__.__contains__,
       ["__aiter__"],
       false,
       "io.BufferedIOBase.__dict__.__contains__('__aiter__') == False — io.BufferedIOBase does not implement __aiter__; the async buffer protocol is defined in asyncio, not in the synchronous io.BufferedIOBase hierarchy; verified with Python 3.12"]
    - [io1501ab006,
       io.BufferedIOBase.__dict__.__contains__,
       ["__aenter__"],
       false,
       "io.BufferedIOBase.__dict__.__contains__('__aenter__') == False — io.BufferedIOBase does not implement __aenter__; verified with Python 3.12"]
    - [io1501ab007,
       io.TextIOBase.__dict__.__contains__,
       ["__await__"],
       false,
       "io.TextIOBase.__dict__.__contains__('__await__') == False — io.TextIOBase is the abstract base for text I/O; it does not implement __await__; text streams in the io module are synchronous; verified with Python 3.12"]
    - [io1501ab008,
       io.TextIOBase.__dict__.__contains__,
       ["__anext__"],
       false,
       "io.TextIOBase.__dict__.__contains__('__anext__') == False — io.TextIOBase does not implement __anext__; async text iteration is not available in the synchronous io module; verified with Python 3.12"]
    - [io1501ab009,
       io.TextIOBase.__dict__.__contains__,
       ["__aexit__"],
       false,
       "io.TextIOBase.__dict__.__contains__('__aexit__') == False — io.TextIOBase does not implement __aexit__; the async context manager protocol is absent from all three abstract io base classes (RawIOBase, BufferedIOBase, TextIOBase); none define __aenter__ or __aexit__ in their __dict__; verified with Python 3.12"]
