spec: aifc
version: ">=3.3,<3.13"
backend: python_module(aifc)

docs: https://docs.python.org/3/library/aifc.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/aifc.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "aifc source: Lib/aifc.py (PSF; source inspection permitted)"
  not_derived_from:
    - "AIFF/AIFF-C binary file format internals beyond what is publicly documented"
  notes:
    - "The aifc module was deprecated in Python 3.11 and removed in Python 3.13."
    - "This spec applies to Python >=3.3,<3.13 only."
    - "aifc.open() is the primary entry point; it returns an Aifc_read or Aifc_write object depending on the mode."
    - "aifc.Error is raised on invalid AIFF/AIFF-C data; it inherits from Exception."
    - "Aifc_read and Aifc_write are the internal implementation classes for reading and writing AIFF files."
    - "All expected values verified by inspecting aifc module on Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "aifc.Error is raised for malformed AIFF/AIFF-C data or incorrect usage of read/write objects. EOFError may also surface from underlying file reads."
  stderr: "null"
  stickiness: "N/A — module-level state is not modified by the invariants tested here."
  codes: {}

# ---------------------------------------------------------------------------
# Error class checks
# ---------------------------------------------------------------------------

invariant aifc.Error_name:
  description: "aifc.Error.__name__ == 'Error'"
  category: classes
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant aifc.Error_module:
  description: "aifc.Error.__module__ == 'aifc'"
  category: classes
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["aifc"]
  expected: true

invariant aifc.Error_base:
  description: "aifc.Error.__bases__[0].__name__ == 'Exception'"
  category: classes
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# Implementation class name checks
# ---------------------------------------------------------------------------

invariant aifc.Aifc_read_name:
  description: "aifc.Aifc_read.__name__ == 'Aifc_read'"
  category: classes
  kind: python_call_eq
  function: Aifc_read.__name__.__eq__
  args: ["Aifc_read"]
  expected: true

invariant aifc.Aifc_read_module:
  description: "aifc.Aifc_read.__module__ == 'aifc'"
  category: classes
  kind: python_call_eq
  function: Aifc_read.__module__.__eq__
  args: ["aifc"]
  expected: true

invariant aifc.Aifc_write_name:
  description: "aifc.Aifc_write.__name__ == 'Aifc_write'"
  category: classes
  kind: python_call_eq
  function: Aifc_write.__name__.__eq__
  args: ["Aifc_write"]
  expected: true

invariant aifc.Aifc_write_module:
  description: "aifc.Aifc_write.__module__ == 'aifc'"
  category: classes
  kind: python_call_eq
  function: Aifc_write.__module__.__eq__
  args: ["aifc"]
  expected: true

# ---------------------------------------------------------------------------
# open() function name check
# ---------------------------------------------------------------------------

invariant aifc.open_name:
  description: "aifc.open.__name__ == 'open'"
  category: functions
  kind: python_call_eq
  function: open.__name__.__eq__
  args: ["open"]
  expected: true

invariant aifc.open_module:
  description: "aifc.open.__module__ == 'aifc'"
  category: functions
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["aifc"]
  expected: true

# ---------------------------------------------------------------------------
# Error is a subclass of Exception (isinstance check via bases length)
# ---------------------------------------------------------------------------

invariant aifc.Error_bases_len:
  description: "len(aifc.Error.__bases__) == 1 — Error has exactly one base class"
  category: classes
  kind: python_call_eq
  function: Error.__bases__.__len__
  args: []
  expected: 1

