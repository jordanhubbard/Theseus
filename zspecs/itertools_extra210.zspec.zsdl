spec: itertools_extra210
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools.zspec.zsdl — covers class names and first-element tests for itertools types"
    - "itertools_extra209.zspec.zsdl — covers earlier __dict__ and annotation checks"
  notes:
    - "itertools.chain is a C-level type (class); it has a class dict accessible via __dict__. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__contains__('from_iterable') == True — from_iterable is a classmethod defined on chain. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__contains__('__new__') == True — chain is a C type with __new__ in its class dict. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__contains__('__doc__') == True — chain has a class-level docstring. Verified with Python 3.14.3."
    - "itertools.chain.__dict__.__len__() == 8 — class dict has exactly 8 entries: __new__, __getattribute__, __iter__, __next__, from_iterable, __class_getitem__, __doc__, __module__. Verified with Python 3.14.3."
    - "type(itertools.chain.from_iterable).__name__ == 'builtin_function_or_method' — from_iterable is a C-level classmethod descriptor exposed as a builtin_function_or_method. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.chain.__dict__ membership — entries present
#
# chain.__dict__.__contains__('from_iterable') == True
# chain.__dict__.__contains__('__new__')        == True
# chain.__dict__.__contains__('__doc__')        == True
# chain.__dict__.__contains__('__iter__')       == True
# ---------------------------------------------------------------------------

table itertools_extra210.chain_dict_present:
  description: "itertools.chain.__dict__ membership checks (present entries) in iterchain210 namespace — chain is a C-level type; its class dict is accessible via __dict__; 'from_iterable' is present (classmethod on chain); '__new__' is present (C type constructor); '__doc__' is present (class docstring); '__iter__' is present (iterator protocol __iter__); all four __contains__ calls return True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iterchain210

  columns: [id, function, args, expected, description]
  rows:
    - [chain_dict_has_from_iterable,
       "chain.__dict__.__contains__",
       ["from_iterable"],
       true,
       "itertools.chain.__dict__.__contains__('from_iterable') == True — from_iterable is a classmethod defined on chain that creates a chain object from a single iterable of iterables; __contains__('from_iterable') returns True; verified with Python 3.14.3"]
    - [chain_dict_has_new,
       "chain.__dict__.__contains__",
       ["__new__"],
       true,
       "itertools.chain.__dict__.__contains__('__new__') == True — chain is a C-level type and defines __new__ in its class dict for object creation; __contains__('__new__') returns True; verified with Python 3.14.3"]
    - [chain_dict_has_doc,
       "chain.__dict__.__contains__",
       ["__doc__"],
       true,
       "itertools.chain.__dict__.__contains__('__doc__') == True — chain has a class-level docstring stored in __doc__; __contains__('__doc__') returns True; verified with Python 3.14.3"]
    - [chain_dict_has_iter,
       "chain.__dict__.__contains__",
       ["__iter__"],
       true,
       "itertools.chain.__dict__.__contains__('__iter__') == True — chain implements the iterator protocol; __iter__ is defined in its class dict; __contains__('__iter__') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: itertools.chain.__dict__ membership — more entries and length
#
# chain.__dict__.__contains__('__next__')           == True
# chain.__dict__.__contains__('__class_getitem__')  == True
# chain.__dict__.__len__()                          == 8
# chain.__dict__.__contains__('__getattribute__')   == True
# ---------------------------------------------------------------------------

table itertools_extra210.chain_dict_more:
  description: "itertools.chain.__dict__ additional membership and length checks in iterchain210m namespace — '__next__' is present (iterator protocol __next__); '__class_getitem__' is present (supports generic alias syntax chain[int] on Python 3.9+); '__dict__.__len__() == 8' (exactly 8 entries: __new__, __getattribute__, __iter__, __next__, from_iterable, __class_getitem__, __doc__, __module__); '__getattribute__' is present; all verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iterchain210m

  columns: [id, function, args, expected, description]
  rows:
    - [chain_dict_has_next,
       "chain.__dict__.__contains__",
       ["__next__"],
       true,
       "itertools.chain.__dict__.__contains__('__next__') == True — chain implements the iterator protocol; __next__ is defined in its class dict to advance the iterator; __contains__('__next__') returns True; verified with Python 3.14.3"]
    - [chain_dict_has_class_getitem,
       "chain.__dict__.__contains__",
       ["__class_getitem__"],
       true,
       "itertools.chain.__dict__.__contains__('__class_getitem__') == True — chain supports the generic alias syntax (e.g. chain[int]) via __class_getitem__ (Python 3.9+); __contains__('__class_getitem__') returns True; verified with Python 3.14.3"]
    - [chain_dict_len_8,
       "chain.__dict__.__len__",
       [],
       8,
       "itertools.chain.__dict__.__len__() == 8 — the class dict contains exactly 8 entries: __new__, __getattribute__, __iter__, __next__, from_iterable, __class_getitem__, __doc__, __module__; __len__() returns 8; verified with Python 3.14.3"]
    - [chain_dict_has_getattribute,
       "chain.__dict__.__contains__",
       ["__getattribute__"],
       true,
       "itertools.chain.__dict__.__contains__('__getattribute__') == True — chain defines __getattribute__ in its class dict as a C-level type; __contains__('__getattribute__') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: itertools.chain.from_iterable — type identity and negative checks
#
# type(chain.from_iterable).__name__ == 'builtin_function_or_method'
# chain.__dict__.__contains__('__reduce__') == False  (not in chain's dict)
# chain.__dict__.__contains__('__init__')   == False  (chain uses __new__ only)
# chain.__dict__.__contains__('__module__') == True
# ---------------------------------------------------------------------------

table itertools_extra210.chain_from_iterable_type:
  description: "itertools.chain.from_iterable type identity and chain dict negative checks in iterchain210f namespace — chain.from_iterable.__class__.__name__ is 'builtin_function_or_method' (C-level classmethod descriptor); chain.__dict__.__contains__('__reduce__') is False (not defined on chain); chain.__dict__.__contains__('__init__') is False (chain uses __new__ for construction, not __init__); chain.__dict__.__contains__('__module__') is True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: iterchain210f

  columns: [id, function, args, expected, description]
  rows:
    - [from_iterable_class_name,
       "chain.from_iterable.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "type(itertools.chain.from_iterable).__name__ == 'builtin_function_or_method' — from_iterable is exposed as a C-level builtin_function_or_method; __class__.__name__.__eq__('builtin_function_or_method') returns True; verified with Python 3.14.3"]
    - [chain_dict_no_reduce,
       "chain.__dict__.__contains__",
       ["__reduce__"],
       false,
       "itertools.chain.__dict__.__contains__('__reduce__') == False — __reduce__ is not defined in chain's class dict; it is inherited from object; __contains__('__reduce__') returns False; negative cross-check; verified with Python 3.14.3"]
    - [chain_dict_no_init,
       "chain.__dict__.__contains__",
       ["__init__"],
       false,
       "itertools.chain.__dict__.__contains__('__init__') == False — chain uses __new__ for C-level construction and does not define __init__ in its class dict; __contains__('__init__') returns False; negative cross-check; verified with Python 3.14.3"]
    - [chain_dict_has_module,
       "chain.__dict__.__contains__",
       ["__module__"],
       true,
       "itertools.chain.__dict__.__contains__('__module__') == True — chain defines __module__ in its class dict (value is 'itertools'); __contains__('__module__') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra210
# ---------------------------------------------------------------------------

invariant itertools_extra210.chain_dict_has_from_iterable:
  description: "itertools.chain.__dict__.__contains__('from_iterable') == True — from_iterable is a classmethod on chain allowing construction from a single iterable of iterables; new to extra210; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "chain.__dict__.__contains__"
  args: ["from_iterable"]
  expected: true

invariant itertools_extra210.chain_dict_has_new:
  description: "itertools.chain.__dict__.__contains__('__new__') == True — chain is a C-level type that defines __new__ in its class dict; new to extra210; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "chain.__dict__.__contains__"
  args: ["__new__"]
  expected: true

invariant itertools_extra210.chain_dict_has_doc:
  description: "itertools.chain.__dict__.__contains__('__doc__') == True — chain has a class-level docstring in its class dict; new to extra210; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "chain.__dict__.__contains__"
  args: ["__doc__"]
  expected: true

invariant itertools_extra210.chain_dict_len_8:
  description: "itertools.chain.__dict__.__len__() == 8 — the class dict has exactly 8 entries: __new__, __getattribute__, __iter__, __next__, from_iterable, __class_getitem__, __doc__, __module__; new to extra210; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "chain.__dict__.__len__"
  args: []
  expected: 8

invariant itertools_extra210.chain_from_iterable_class_name:
  description: "type(itertools.chain.from_iterable).__name__ == 'builtin_function_or_method' — from_iterable is a C-level classmethod descriptor exposed as a builtin_function_or_method; new to extra210; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "chain.from_iterable.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra210.chain_dict_has_next:
  description: "itertools.chain.__dict__.__contains__('__next__') == True — chain implements __next__ in its class dict as part of the iterator protocol; new to extra210; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "chain.__dict__.__contains__"
  args: ["__next__"]
  expected: true

invariant itertools_extra210.chain_dict_no_init:
  description: "itertools.chain.__dict__.__contains__('__init__') == False — chain uses __new__ for construction and does not define __init__ in its class dict; new to extra210; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "chain.__dict__.__contains__"
  args: ["__init__"]
  expected: false

invariant itertools_extra210.chain_dict_has_class_getitem:
  description: "itertools.chain.__dict__.__contains__('__class_getitem__') == True — chain supports the generic alias syntax via __class_getitem__ (Python 3.9+); new to extra210; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "chain.__dict__.__contains__"
  args: ["__class_getitem__"]
  expected: true
