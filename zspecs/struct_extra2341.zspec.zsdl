spec: struct_extra2341
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/struct.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 603 (_extra2341): __slots__ content and absence checks."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "struct.Struct is a C extension type; __dict__.__contains__('__slots__') == False."
    - "C extension types expose their attributes directly in __dict__ as C-level slot descriptors, not Python __slots__."
    - "struct.Struct.__dict__ contains: __new__, __init__, format, size, pack, unpack, pack_into, unpack_from, iter_unpack."
    - "struct.error is a pure-Python exception subclass without __slots__; __dict__.__contains__('__slots__') == False."
    - "struct.error.__dict__ contains: __module__, __weakref__, __doc__."
  created_at: "2026-04-12"

table struct_extra2341.struct_no_slots:
  description: "struct.Struct is a C type — no Python __slots__ in its __dict__"
  kind: python_call_eq
  category: slots_absence
  id_prefix: st2341
  columns: [id, function, args, expected]
  rows:
    - ["st2341001", "struct.Struct.__dict__.__contains__", ["__slots__"], false]

table struct_extra2341.struct_dict_attrs:
  description: "struct.Struct C-level attributes ARE present in __dict__"
  kind: python_call_eq
  category: slots_content
  id_prefix: st2341
  columns: [id, function, args, expected]
  rows:
    - ["st2341002", "struct.Struct.__dict__.__contains__", ["__new__"], true]
    - ["st2341003", "struct.Struct.__dict__.__contains__", ["__init__"], true]
    - ["st2341004", "struct.Struct.__dict__.__contains__", ["format"], true]
    - ["st2341005", "struct.Struct.__dict__.__contains__", ["size"], true]
    - ["st2341006", "struct.Struct.__dict__.__contains__", ["pack"], true]
    - ["st2341007", "struct.Struct.__dict__.__contains__", ["unpack"], true]
    - ["st2341008", "struct.Struct.__dict__.__contains__", ["pack_into"], true]
    - ["st2341009", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st2341010", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]

table struct_extra2341.struct_error_no_slots:
  description: "struct.error is a pure-Python exception subclass without __slots__"
  kind: python_call_eq
  category: slots_absence
  id_prefix: st2341
  columns: [id, function, args, expected]
  rows:
    - ["st2341011", "struct.error.__dict__.__contains__", ["__slots__"], false]

table struct_extra2341.struct_error_dict_attrs:
  description: "struct.error.__dict__ contains expected pure-Python exception class attributes"
  kind: python_call_eq
  category: slots_content
  id_prefix: st2341
  columns: [id, function, args, expected]
  rows:
    - ["st2341012", "struct.error.__dict__.__contains__", ["__module__"], true]
    - ["st2341013", "struct.error.__dict__.__contains__", ["__weakref__"], true]

table struct_extra2341.cross_check:
  description: "Cross-check: struct types do not spuriously expose each other's attributes"
  kind: python_call_eq
  category: slots_absence
  id_prefix: st2341
  columns: [id, function, args, expected]
  rows:
    - ["st2341014", "struct.Struct.__dict__.__contains__", ["__weakref__"], false]
    - ["st2341015", "struct.Struct.__dict__.__contains__", ["__module__"], false]
    - ["st2341016", "struct.error.__dict__.__contains__", ["format"], false]
    - ["st2341017", "struct.error.__dict__.__contains__", ["size"], false]
    - ["st2341018", "struct.error.__dict__.__contains__", ["pack"], false]
    - ["st2341019", "struct.error.__dict__.__contains__", ["unpack"], false]
    - ["st2341020", "struct.Struct.__dict__.__contains__", ["nonexistent"], false]
    - ["st2341021", "struct.error.__dict__.__contains__", ["nonexistent"], false]
