spec: itertools_extra221
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools class name length and ordering contracts."
    - "itertools.chain.__name__.__len__() == 5 — 'chain' has 5 characters. Verified with Python 3.14.3."
    - "itertools.cycle.__name__.__len__() == 5 — 'cycle' has 5 characters. Verified with Python 3.14.3."
    - "itertools.repeat.__name__.__len__() == 6 — 'repeat' has 6 characters. Verified with Python 3.14.3."
    - "itertools.islice.__name__.__len__() == 6 — 'islice' has 6 characters. Verified with Python 3.14.3."
    - "itertools.groupby.__name__.__len__() == 7 — 'groupby' has 7 characters. Verified with Python 3.14.3."
    - "itertools.product.__name__.__len__() == 7 — 'product' has 7 characters. Verified with Python 3.14.3."
    - "itertools.starmap.__name__.__len__() == 7 — 'starmap' has 7 characters. Verified with Python 3.14.3."
    - "itertools.compress.__name__.__len__() == 8 — 'compress' has 8 characters. Verified with Python 3.14.3."
    - "itertools.dropwhile.__name__.__len__() == 9 — 'dropwhile' has 9 characters. Verified with Python 3.14.3."
    - "itertools.takewhile.__name__.__len__() == 9 — 'takewhile' has 9 characters. Verified with Python 3.14.3."
    - "itertools.accumulate.__name__.__len__() == 10 — 'accumulate' has 10 characters. Verified with Python 3.14.3."
    - "itertools.combinations.__name__.__len__() == 12 — 'combinations' has 12 characters. Verified with Python 3.14.3."
    - "itertools.permutations.__name__.__len__() == 12 — 'permutations' has 12 characters. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools class name lengths (5–7 characters)
#
# Verified with Python 3.14.3:
#   chain.__name__.__len__() == 5
#   cycle.__name__.__len__() == 5
#   repeat.__name__.__len__() == 6
#   islice.__name__.__len__() == 6
#   groupby.__name__.__len__() == 7
#   product.__name__.__len__() == 7
#   starmap.__name__.__len__() == 7
# ---------------------------------------------------------------------------

table itertools_extra221.name_lengths_short:
  description: "itertools class __name__ length checks for 5-7 character names; new to extra221"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra221namelen_short

  columns: [id, function, args, expected, description]
  rows:
    - [chain_name_len_eq,
       chain.__name__.__len__,
       [],
       5,
       "itertools.chain.__name__.__len__() == 5 — the itertools chain class name string is 'chain' which has 5 characters; str.__len__() returns 5; new to extra221"]
    - [cycle_name_len_eq,
       cycle.__name__.__len__,
       [],
       5,
       "itertools.cycle.__name__.__len__() == 5 — the itertools cycle class name string is 'cycle' which has 5 characters; str.__len__() returns 5; new to extra221"]
    - [repeat_name_len_eq,
       repeat.__name__.__len__,
       [],
       6,
       "itertools.repeat.__name__.__len__() == 6 — the itertools repeat class name string is 'repeat' which has 6 characters; str.__len__() returns 6; new to extra221"]
    - [islice_name_len_eq,
       islice.__name__.__len__,
       [],
       6,
       "itertools.islice.__name__.__len__() == 6 — the itertools islice class name string is 'islice' which has 6 characters; str.__len__() returns 6; new to extra221"]
    - [groupby_name_len_eq,
       groupby.__name__.__len__,
       [],
       7,
       "itertools.groupby.__name__.__len__() == 7 — the itertools groupby class name string is 'groupby' which has 7 characters; str.__len__() returns 7; new to extra221"]
    - [product_name_len_eq,
       product.__name__.__len__,
       [],
       7,
       "itertools.product.__name__.__len__() == 7 — the itertools product class name string is 'product' which has 7 characters; str.__len__() returns 7; new to extra221"]
    - [starmap_name_len_eq,
       starmap.__name__.__len__,
       [],
       7,
       "itertools.starmap.__name__.__len__() == 7 — the itertools starmap class name string is 'starmap' which has 7 characters; str.__len__() returns 7; new to extra221"]

