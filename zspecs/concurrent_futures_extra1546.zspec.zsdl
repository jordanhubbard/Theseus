spec: concurrent_futures_extra1546
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 550 (_extra1546): bitwise operator dict-presence checks for concurrent.futures classes."
    - "concurrent.futures.Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor are not bitwise types."
    - "None of these classes define __and__, __or__, __xor__, __invert__, __lshift__, __rshift__ or reflected variants in their own __dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# Future — bitwise operator dict-presence (all False)
# ---------------------------------------------------------------------------

table concurrent_futures_extra1546.future_bitwise_ops:
  description: "concurrent.futures.Future.__dict__ does not contain any bitwise operator dunder"
  kind: python_call_eq
  category: bitwise_presence
  id_prefix: cf1546fu

  columns: [id, function, args, expected]
  rows:
    - [cf1546fu001, concurrent.futures.Future.__dict__.__contains__, ["__and__"],     false]
    - [cf1546fu002, concurrent.futures.Future.__dict__.__contains__, ["__or__"],      false]
    - [cf1546fu003, concurrent.futures.Future.__dict__.__contains__, ["__xor__"],     false]
    - [cf1546fu004, concurrent.futures.Future.__dict__.__contains__, ["__invert__"],  false]
    - [cf1546fu005, concurrent.futures.Future.__dict__.__contains__, ["__lshift__"],  false]
    - [cf1546fu006, concurrent.futures.Future.__dict__.__contains__, ["__rshift__"],  false]
    - [cf1546fu007, concurrent.futures.Future.__dict__.__contains__, ["__rand__"],    false]
    - [cf1546fu008, concurrent.futures.Future.__dict__.__contains__, ["__ror__"],     false]
    - [cf1546fu009, concurrent.futures.Future.__dict__.__contains__, ["__rxor__"],    false]
    - [cf1546fu010, concurrent.futures.Future.__dict__.__contains__, ["__rlshift__"], false]
    - [cf1546fu011, concurrent.futures.Future.__dict__.__contains__, ["__rrshift__"], false]

