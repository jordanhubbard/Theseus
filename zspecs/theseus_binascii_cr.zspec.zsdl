spec: theseus_binascii_cr
version: ">=3.8"
backend: python_cleanroom(theseus_binascii_cr)
blocks: binascii

docs: https://docs.python.org/3/library/binascii.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/binascii.html"
  not_derived_from:
    - "CPython source: Modules/binascii.c"
  notes:
    - "Clean-room binascii module. Do NOT import binascii."
    - "hexlify(data): convert to hex representation."
    - "unhexlify(hexstr): decode hex representation."
    - "b2a_base64(data): encode to base64."
    - "a2b_base64(data): decode from base64."
    - "crc32(data): compute CRC-32 checksum."

error_model: python_exceptions

invariant theseus_binascii_cr.binascii2_hexlify:
  description: "hexlify(b'hello') returns b'68656c6c6f'"
  category: hexlify
  kind: python_call_eq
  function: binascii2_hexlify
  args: []
  expected: "68656c6c6f"

invariant theseus_binascii_cr.binascii2_unhexlify:
  description: "unhexlify('68656c6c6f') returns b'hello'"
  category: unhexlify
  kind: python_call_eq
  function: binascii2_unhexlify
  args: []
  expected: "hello"

invariant theseus_binascii_cr.binascii2_crc32:
  description: "crc32 returns an integer checksum"
  category: crc32
  kind: python_call_eq
  function: binascii2_crc32
  args: []
  expected: true
