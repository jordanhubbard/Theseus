spec: hashlib_extra183
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "hashlib.zspec.zsdl — core hash/hexdigest vectors."
    - "hashlib_extra.zspec.zsdl through hashlib_extra182.zspec.zsdl — prior extras."
  notes:
    - "This spec covers digest_size and block_size attributes for MD5, SHA-1, SHA-256, and SHA-512."
    - "hashlib.md5().digest_size == 16 — MD5 produces a 128-bit (16-byte) digest."
    - "hashlib.md5().block_size == 64 — MD5 uses a 512-bit (64-byte) block."
    - "hashlib.sha1().digest_size == 20 — SHA-1 produces a 160-bit (20-byte) digest."
    - "hashlib.sha1().block_size == 64 — SHA-1 uses a 512-bit (64-byte) block."
    - "hashlib.sha256().block_size == 64 — SHA-256 uses a 512-bit (64-byte) block."
    - "hashlib.sha512().digest_size == 64 — SHA-512 produces a 512-bit (64-byte) digest."
    - "hashlib.sha512().block_size == 128 — SHA-512 uses a 1024-bit (128-byte) block."
    - "hashlib.md5().name == 'md5' — the name attribute returns the algorithm name string."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: MD5 digest_size and block_size
#
# hashlib.md5().digest_size == 16  (128 bits / 8 = 16 bytes)
# hashlib.md5().block_size  == 64  (512 bits / 8 = 64 bytes)
# hashlib.md5().name        == 'md5'
#
# MD5 (Message-Digest Algorithm 5) produces a 128-bit hash. Its internal
# Merkle–Damgård compression function processes 512-bit (64-byte) blocks.
# The name attribute returns the canonical algorithm name string.
# New to extra183.
# ---------------------------------------------------------------------------

table hashlib_extra183.md5_sizes:
  description: "MD5 digest_size==16 (128-bit), block_size==64 (512-bit), name=='md5'; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibmd5183

  columns: [id, function, args, expected, description]
  rows:
    - [md5_digest_size_16,
       "md5().digest_size.__eq__",
       [16],
       true,
       "hashlib.md5().digest_size.__eq__(16) == True — MD5 produces a 128-bit digest; 128/8 = 16 bytes; digest_size is an int attribute on all hashlib hash objects; new to extra183"]
    - [md5_block_size_64,
       "md5().block_size.__eq__",
       [64],
       true,
       "hashlib.md5().block_size.__eq__(64) == True — MD5 uses a 512-bit Merkle-Damgard block; 512/8 = 64 bytes; block_size is an int attribute on all hashlib hash objects; new to extra183"]
    - [md5_name_eq,
       "md5().name.__eq__",
       ["md5"],
       true,
       "hashlib.md5().name.__eq__('md5') == True — the name attribute of a hashlib hash object returns the algorithm name string; for MD5 this is 'md5'; new to extra183"]
    - [md5_digest_size_not_20,
       "md5().digest_size.__eq__",
       [20],
       false,
       "hashlib.md5().digest_size.__eq__(20) == False — MD5 digest is 16 bytes, not 20; 20 bytes is the digest_size for SHA-1; new to extra183"]

# ---------------------------------------------------------------------------
# Table 2: SHA-1 digest_size and block_size
#
# hashlib.sha1().digest_size == 20  (160 bits / 8 = 20 bytes)
# hashlib.sha1().block_size  == 64  (512 bits / 8 = 64 bytes)
#
# SHA-1 (Secure Hash Algorithm 1) produces a 160-bit hash. Like MD5, it uses
# 512-bit (64-byte) blocks internally. Its digest_size (20) differs from MD5
# (16) even though both share the same block_size (64).
# New to extra183.
# ---------------------------------------------------------------------------

table hashlib_extra183.sha1_sizes:
  description: "SHA-1 digest_size==20 (160-bit), block_size==64 (512-bit); new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibmd5183

  columns: [id, function, args, expected, description]
  rows:
    - [sha1_digest_size_20,
       "sha1().digest_size.__eq__",
       [20],
       true,
       "hashlib.sha1().digest_size.__eq__(20) == True — SHA-1 produces a 160-bit digest; 160/8 = 20 bytes; digest_size is an int attribute on all hashlib hash objects; new to extra183"]
    - [sha1_block_size_64,
       "sha1().block_size.__eq__",
       [64],
       true,
       "hashlib.sha1().block_size.__eq__(64) == True — SHA-1 uses a 512-bit Merkle-Damgard block; 512/8 = 64 bytes; SHA-1 shares block_size with MD5 even though their digest sizes differ; new to extra183"]
    - [sha1_digest_size_not_16,
       "sha1().digest_size.__eq__",
       [16],
       false,
       "hashlib.sha1().digest_size.__eq__(16) == False — SHA-1 digest is 20 bytes, not 16; 16 bytes is the digest_size for MD5; new to extra183"]
    - [sha1_block_size_not_128,
       "sha1().block_size.__eq__",
       [128],
       false,
       "hashlib.sha1().block_size.__eq__(128) == False — SHA-1 block size is 64 bytes, not 128; 128 bytes is the block_size for SHA-512; new to extra183"]

# ---------------------------------------------------------------------------
# Table 3: SHA-256 block_size and SHA-512 digest_size and block_size
#
# hashlib.sha256().block_size == 64   (512 bits / 8 = 64 bytes)
# hashlib.sha512().digest_size == 64  (512 bits / 8 = 64 bytes)
# hashlib.sha512().block_size  == 128 (1024 bits / 8 = 128 bytes)
#
# SHA-256 and SHA-512 are SHA-2 family algorithms. SHA-256 shares its 512-bit
# (64-byte) block size with MD5 and SHA-1. SHA-512 uses a larger 1024-bit
# (128-byte) block. SHA-512's digest_size (64) coincidentally equals SHA-256's
# block_size (64) but for entirely different reasons.
# New to extra183.
# ---------------------------------------------------------------------------

table hashlib_extra183.sha256_sha512_sizes:
  description: "SHA-256 block_size==64; SHA-512 digest_size==64, block_size==128; new to extra183"
  kind: python_call_eq
  category: identity
  id_prefix: hashlibmd5183

  columns: [id, function, args, expected, description]
  rows:
    - [sha256_block_size_64,
       "sha256().block_size.__eq__",
       [64],
       true,
       "hashlib.sha256().block_size.__eq__(64) == True — SHA-256 uses a 512-bit block; 512/8 = 64 bytes; SHA-256 shares its block_size with MD5 and SHA-1 despite producing a larger 32-byte digest; new to extra183"]
    - [sha512_digest_size_64,
       "sha512().digest_size.__eq__",
       [64],
       true,
       "hashlib.sha512().digest_size.__eq__(64) == True — SHA-512 produces a 512-bit digest; 512/8 = 64 bytes; new to extra183"]
    - [sha512_block_size_128,
       "sha512().block_size.__eq__",
       [128],
       true,
       "hashlib.sha512().block_size.__eq__(128) == True — SHA-512 uses a 1024-bit block; 1024/8 = 128 bytes; this is larger than the 64-byte block used by MD5, SHA-1, and SHA-256; new to extra183"]
    - [sha512_block_size_not_64,
       "sha512().block_size.__eq__",
       [64],
       false,
       "hashlib.sha512().block_size.__eq__(64) == False — SHA-512 block size is 128 bytes, not 64; 64-byte blocks are used by MD5, SHA-1, and SHA-256; new to extra183"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra183
# ---------------------------------------------------------------------------

invariant hashlib_extra183.md5_digest_size_16:
  description: "hashlib.md5().digest_size == 16 — MD5 produces a 128-bit (16-byte) digest; new to extra183"
  category: identity
  kind: python_call_eq
  function: md5().digest_size.__eq__
  args: [16]
  expected: true

invariant hashlib_extra183.md5_block_size_64:
  description: "hashlib.md5().block_size == 64 — MD5 uses a 512-bit (64-byte) block; new to extra183"
  category: identity
  kind: python_call_eq
  function: md5().block_size.__eq__
  args: [64]
  expected: true

invariant hashlib_extra183.sha1_digest_size_20:
  description: "hashlib.sha1().digest_size == 20 — SHA-1 produces a 160-bit (20-byte) digest; new to extra183"
  category: identity
  kind: python_call_eq
  function: sha1().digest_size.__eq__
  args: [20]
  expected: true

invariant hashlib_extra183.sha1_block_size_64:
  description: "hashlib.sha1().block_size == 64 — SHA-1 uses a 512-bit (64-byte) block; new to extra183"
  category: identity
  kind: python_call_eq
  function: sha1().block_size.__eq__
  args: [64]
  expected: true

invariant hashlib_extra183.sha256_block_size_64:
  description: "hashlib.sha256().block_size == 64 — SHA-256 uses a 512-bit (64-byte) block; new to extra183"
  category: identity
  kind: python_call_eq
  function: sha256().block_size.__eq__
  args: [64]
  expected: true

invariant hashlib_extra183.sha512_digest_size_64:
  description: "hashlib.sha512().digest_size == 64 — SHA-512 produces a 512-bit (64-byte) digest; new to extra183"
  category: identity
  kind: python_call_eq
  function: sha512().digest_size.__eq__
  args: [64]
  expected: true

invariant hashlib_extra183.sha512_block_size_128:
  description: "hashlib.sha512().block_size == 128 — SHA-512 uses a 1024-bit (128-byte) block; new to extra183"
  category: identity
  kind: python_call_eq
  function: sha512().block_size.__eq__
  args: [128]
  expected: true

invariant hashlib_extra183.md5_name_eq:
  description: "hashlib.md5().name == 'md5' — the name attribute returns the algorithm name; new to extra183"
  category: identity
  kind: python_call_eq
  function: md5().name.__eq__
  args: ["md5"]
  expected: true
