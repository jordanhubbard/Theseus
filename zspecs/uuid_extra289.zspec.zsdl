spec: uuid_extra289
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.uuid4.__name__ == 'uuid4' and __module__ == 'uuid' — pure-Python function."
    - "uuid.uuid1.__name__ == 'uuid1' and __module__ == 'uuid' — pure-Python function."
    - "uuid.uuid3.__name__ == 'uuid3' and __module__ == 'uuid' — pure-Python function."
    - "uuid.uuid5.__name__ == 'uuid5' and __module__ == 'uuid' — pure-Python function."
    - "uuid.UUID.__name__ == 'UUID' and __module__ == 'uuid' — the UUID class."
    - "uuid.UUID.__bases__[0].__name__ == 'object' — UUID directly inherits from object."
    - "uuid.uuid4().__class__.__name__ == 'UUID' — uuid4() returns a UUID instance."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — predefined namespace constants are UUID instances."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — predefined namespace constant."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' — predefined namespace constant."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "uuid raises ValueError for invalid UUID strings and TypeError for wrong argument types."
  stderr: "null"
  stickiness: "N/A — uuid functions return independent UUID objects."
  codes: {}

# ---------------------------------------------------------------------------
# uuid function identity — __name__ and __module__
# ---------------------------------------------------------------------------

table uuid_extra289.function_names:
  description: "uuid module function __name__ attributes — uuid1, uuid3, uuid4, uuid5 are all pure-Python functions in the uuid module; all verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfn289

  columns: [id, function, args, expected]
  rows:
    - [uuid4_name,  uuid4.__name__.__eq__,  ["uuid4"],  true]
    - [uuid1_name,  uuid1.__name__.__eq__,  ["uuid1"],  true]
    - [uuid3_name,  uuid3.__name__.__eq__,  ["uuid3"],  true]
    - [uuid5_name,  uuid5.__name__.__eq__,  ["uuid5"],  true]

table uuid_extra289.function_modules:
  description: "uuid module function __module__ attributes — all uuid generator functions belong to the uuid module; all verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidmod289

  columns: [id, function, args, expected]
  rows:
    - [uuid4_module,  uuid4.__module__.__eq__,  ["uuid"],  true]
    - [uuid1_module,  uuid1.__module__.__eq__,  ["uuid"],  true]
    - [uuid3_module,  uuid3.__module__.__eq__,  ["uuid"],  true]
    - [uuid5_module,  uuid5.__module__.__eq__,  ["uuid"],  true]

# ---------------------------------------------------------------------------
# UUID class identity
# ---------------------------------------------------------------------------

invariant uuid_extra289.UUID.name:
  description: "uuid.UUID.__name__ == 'UUID' — the UUID class name"
  category: class_identity
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra289.UUID.module:
  description: "uuid.UUID.__module__ == 'uuid' — the UUID class belongs to the uuid module"
  category: class_identity
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra289.UUID.base_name:
  description: "uuid.UUID.__bases__[0].__name__ == 'object' — UUID directly inherits from object"
  category: class_identity
  kind: python_call_eq
  function: UUID.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# uuid4() return type
# ---------------------------------------------------------------------------

invariant uuid_extra289.uuid4.return_class:
  description: "uuid.uuid4().__class__.__name__ == 'UUID' — uuid4() returns a UUID instance"
  category: return_type
  kind: python_call_eq
  function: uuid4.__call__.__call__
  args: []
  method: __class__.__name__.__eq__
  method_args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# Predefined namespace constants — all are UUID instances
# ---------------------------------------------------------------------------

table uuid_extra289.namespace_constants_class:
  description: "uuid predefined namespace constants are UUID instances — NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID are all UUID objects; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_eq
  category: constants
  id_prefix: uuidns289

  columns: [id, function, args, expected]
  rows:
    - [ns_dns_class,  NAMESPACE_DNS.__class__.__name__.__eq__,  ["UUID"],  true]
    - [ns_url_class,  NAMESPACE_URL.__class__.__name__.__eq__,  ["UUID"],  true]
    - [ns_oid_class,  NAMESPACE_OID.__class__.__name__.__eq__,  ["UUID"],  true]
