spec: threading_extra36
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra35.zspec.zsdl."
    - "Prior specs covered: Thread.__name__/__qualname__/__len__()==6; Thread method __qualname__.__len__() for start(12)/run(10)/join(11)/is_alive(15); Event method __qualname__.__len__() for set(9)/clear(11)/wait(10)/is_set(12); Condition method __qualname__.__len__() for wait(14)/notify(16)/notify_all(20)/wait_for(18); Semaphore method __qualname__.__len__() for acquire(17)/release(17); Semaphore/__name__/__qualname__.__len__()==9; Condition/__name__/__qualname__.__len__()==9; Barrier/__name__/__qualname__.__len__()==7; Timer/__name__/__qualname__.__len__()==5; threading.local.__name__/__qualname__.__len__()==6."
    - "This spec covers: Thread.__init__.__qualname__.__len__() (15 — 'Thread.__init__'); Thread.__repr__.__qualname__.__len__() (15 — 'Thread.__repr__', same length as __init__); Thread.getName.__qualname__.__len__() (14 — 'Thread.getName'); Thread.setName.__qualname__.__len__() (14 — 'Thread.setName', same length as getName); Semaphore.__init__.__qualname__.__len__() (18 — 'Semaphore.__init__'); Semaphore.__exit__.__qualname__.__len__() (18 — 'Semaphore.__exit__', same as __init__); Condition.__init__.__qualname__.__len__() (18 — 'Condition.__init__'); Condition.__enter__.__qualname__.__len__() (19 — 'Condition.__enter__', the longest Condition method qualname)."
    - "Key findings: Thread.__init__ and Thread.__repr__ both have __qualname__ length 15 ('Thread.__init__' and 'Thread.__repr__'). Thread.getName and Thread.setName both have __qualname__ length 14. Semaphore.__init__ and Semaphore.__exit__ both have __qualname__ length 18. Condition.__init__ has __qualname__ length 18, while Condition.__enter__ is 19 chars — the class name 'Condition' (9) plus '.__enter__' (10) = 19."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Thread dunder/legacy method __qualname__.__len__() table — extra36 namespace
#
# threading.Thread.__init__.__qualname__ is 'Thread.__init__' (15 chars).
# threading.Thread.__repr__.__qualname__ is 'Thread.__repr__' (15 chars) — same
# length as __init__, because both are 'Thread.' (7) plus the 8-char dunder name.
# threading.Thread.getName.__qualname__ is 'Thread.getName' (14 chars). threading.
# Thread.setName.__qualname__ is 'Thread.setName' (14 chars) — same as getName.
# Prior specs recorded __qualname__.__len__() for Thread.start/run/join/is_alive
# but not __init__/__repr__/getName/setName. No prior threading spec records these
# four values together in the extra36 namespace.
# ---------------------------------------------------------------------------

table threading_extra36.thread_method_qualname_lengths:
  description: "threading.Thread dunder and legacy method __qualname__.__len__()"
  kind: python_call_eq
  category: string_properties
  id_prefix: threadmethqlen36

  columns: [id, function, args, expected, description]
  rows:
    - [Thread_init,
       Thread.__init__.__qualname__.__len__,
       [],
       15,
       "len(threading.Thread.__init__.__qualname__) == 15 — 'Thread.__init__' (7-char prefix + 8-char dunder)"]
    - [Thread_repr,
       Thread.__repr__.__qualname__.__len__,
       [],
       15,
       "len(threading.Thread.__repr__.__qualname__) == 15 — 'Thread.__repr__' (same length as __init__)"]
    - [Thread_getName,
       Thread.getName.__qualname__.__len__,
       [],
       14,
       "len(threading.Thread.getName.__qualname__) == 14 — 'Thread.getName' (legacy getter, 7-char prefix + 7-char method)"]
    - [Thread_setName,
       Thread.setName.__qualname__.__len__,
       [],
       14,
       "len(threading.Thread.setName.__qualname__) == 14 — 'Thread.setName' (same length as getName)"]

# ---------------------------------------------------------------------------
# Semaphore dunder method __qualname__.__len__() table — extra36 namespace
#
# threading.Semaphore.__init__.__qualname__ is 'Semaphore.__init__' (18 chars).
# threading.Semaphore.__exit__.__qualname__ is 'Semaphore.__exit__' (18 chars) —
# the same length as __init__, because 'Semaphore.' (10) plus the 8-char dunder
# gives 18 in both cases. Prior specs recorded __qualname__.__len__() for
# Semaphore.acquire (17) and Semaphore.release (17) but not for Semaphore.__init__
# or Semaphore.__exit__. No prior threading spec records these two values in the
# extra36 namespace.
# ---------------------------------------------------------------------------

table threading_extra36.semaphore_dunder_qualname_lengths:
  description: "threading.Semaphore dunder method __qualname__.__len__(): __init__(18) and __exit__(18)"
  kind: python_call_eq
  category: string_properties
  id_prefix: semdunderqlen36

  columns: [id, function, args, expected, description]
  rows:
    - [Semaphore_init,
       Semaphore.__init__.__qualname__.__len__,
       [],
       18,
       "len(threading.Semaphore.__init__.__qualname__) == 18 — 'Semaphore.__init__' (10-char prefix + 8-char dunder)"]
    - [Semaphore_exit,
       Semaphore.__exit__.__qualname__.__len__,
       [],
       18,
       "len(threading.Semaphore.__exit__.__qualname__) == 18 — 'Semaphore.__exit__' (same length as __init__)"]

# ---------------------------------------------------------------------------
# Condition dunder method __qualname__.__len__() — standalone invariants
#
# threading.Condition.__init__.__qualname__ is 'Condition.__init__' (18 chars) —
# 'Condition.' (10) plus '__init__' (8) == 18. threading.Condition.__enter__.
# __qualname__ is 'Condition.__enter__' (19 chars) — 'Condition.' (10) plus
# '__enter__' (9) == 19. __enter__ is one character longer than __init__ or __exit__
# because '__enter__' has 9 chars vs 8. This makes Condition.__enter__ the longest
# Condition method qualname recorded in the extra36 namespace. No prior threading
# spec records these two values together in the extra36 namespace.
# ---------------------------------------------------------------------------

invariant threading_extra36.Condition_init_qualname_len:
  description: "len(threading.Condition.__init__.__qualname__) == 18 — 'Condition.__init__' (10-char prefix + 8-char dunder)"
  category: string_properties
  kind: python_call_eq
  function: Condition.__init__.__qualname__.__len__
  args: []
  expected: 18

invariant threading_extra36.Condition_enter_qualname_len:
  description: "len(threading.Condition.__enter__.__qualname__) == 19 — 'Condition.__enter__' (10-char prefix + 9-char dunder; longest Condition method qualname)"
  category: string_properties
  kind: python_call_eq
  function: Condition.__enter__.__qualname__.__len__
  args: []
  expected: 19
