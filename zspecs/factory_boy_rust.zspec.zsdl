spec: factory_boy_rust
version: ">=3.9"
backend: rust_module(factory_boy_rust)

docs: https://factoryboy.readthedocs.io/en/stable/

provenance:
  derived_from:
    - "https://factoryboy.readthedocs.io/en/stable/ — factory_boy documentation"
  not_derived_from:
    - "factory_boy source: factory/__init__.py"
  notes:
    - "factory_boy provides test fixture factories for Python."
    - "import factory; factory.Factory is available."
    - "factory.Factory.__name__ == 'Factory'."
    - "factory.LazyAttribute is available."
    - "factory.__version__ is a non-empty string."
    - "Expose factory_boy_class_name() -> str: factory.Factory.__name__."
    - "Expose factory_boy_has_lazy() -> bool: hasattr(factory, 'LazyAttribute')."
    - "Expose factory_boy_version_nonempty() -> bool: len(factory.__version__) > 0."
    - "All test vectors verified against factory_boy 3.3.3."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# factory_boy_class_name — Factory class name
invariant factory_boy_rust.factory.class_name:
  description: "factory.Factory.__name__ == 'Factory'"
  category: factory
  kind: python_call_eq
  function: factory_boy_class_name
  args: []
  expected: "Factory"

# factory_boy_has_lazy — LazyAttribute present
invariant factory_boy_rust.module.has_lazy:
  description: "factory.LazyAttribute is available"
  category: module
  kind: python_call_eq
  function: factory_boy_has_lazy
  args: []
  expected: true

# factory_boy_version_nonempty — version non-empty
invariant factory_boy_rust.version.nonempty:
  description: "factory.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: factory_boy_version_nonempty
  args: []
  expected: true

