spec: itertools_extra98
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra97

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra97.zspec.zsdl."
    - "This spec covers: itertools C-type __new__.__class__.__name__ membership (all 'builtin_function_or_method'); itertools C-type __qualname__ attributes for all major iterator types (Wave 255)."
    - "itertools.chain.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.cycle.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.repeat.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.count.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.product.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.combinations.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.accumulate.__new__.__class__.__name__ == 'builtin_function_or_method'. Verified with Python 3.14.3."
    - "itertools.zip_longest.__qualname__ == 'zip_longest'. Verified with Python 3.14.3."
    - "itertools.compress.__qualname__ == 'compress'. Verified with Python 3.14.3."
    - "itertools.dropwhile.__qualname__ == 'dropwhile'. Verified with Python 3.14.3."
    - "itertools.takewhile.__qualname__ == 'takewhile'. Verified with Python 3.14.3."
    - "itertools.islice.__qualname__ == 'islice'. Verified with Python 3.14.3."
    - "itertools.starmap.__qualname__ == 'starmap'. Verified with Python 3.14.3."
    - "itertools.filterfalse.__qualname__ == 'filterfalse'. Verified with Python 3.14.3."
    - "itertools.groupby.__qualname__ == 'groupby'. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C-type __new__.__class__.__name__ (all 'builtin_function_or_method')
#
# Wave 255 theme: itertools C-type __new__ membership and __qualname__ attrs.
#
# itertools.chain.__new__.__class__.__name__ == 'builtin_function_or_method'
# itertools.cycle.__new__.__class__.__name__ == 'builtin_function_or_method'
# itertools.repeat.__new__.__class__.__name__ == 'builtin_function_or_method'
# itertools.count.__new__.__class__.__name__ == 'builtin_function_or_method'
# itertools.product.__new__.__class__.__name__ == 'builtin_function_or_method'
# itertools.combinations.__new__.__class__.__name__ == 'builtin_function_or_method'
# itertools.accumulate.__new__.__class__.__name__ == 'builtin_function_or_method'
#
# All itertools iterator types are C extension types; their __new__ method
# is a builtin_function_or_method allocated by the CPython type machinery.
# New to extra98.
# ---------------------------------------------------------------------------

table itertools_extra98.new_class_name_group:
  description: "itertools C-type __new__.__class__.__name__ == 'builtin_function_or_method' for chain/cycle/repeat/count/product/combinations/accumulate; C extension types; wave 255; new to extra98"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsnewcls98

  columns: [id, function, args, expected, description]
  rows:
    - [chain_new_class_name_eq_builtin,
       "chain.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.chain.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.chain is a C extension type implemented in Modules/itertoolsmodule.c; its __new__ slot is exposed as a builtin_function_or_method by the CPython type machinery; str.__eq__('builtin_function_or_method') returns True; new to extra98"]
    - [cycle_new_class_name_eq_builtin,
       "cycle.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.cycle.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.cycle is a C extension type; its __new__ slot is exposed as a builtin_function_or_method; str.__eq__('builtin_function_or_method') returns True; new to extra98"]
    - [repeat_new_class_name_eq_builtin,
       "repeat.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.repeat.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.repeat is a C extension type; its __new__ is a builtin_function_or_method; str.__eq__('builtin_function_or_method') returns True; new to extra98"]
    - [count_new_class_name_eq_builtin,
       "count.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.count.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.count is a C extension type; its __new__ is a builtin_function_or_method; str.__eq__('builtin_function_or_method') returns True; new to extra98"]
    - [product_new_class_name_eq_builtin,
       "product.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.product.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.product is a C extension type; its __new__ is a builtin_function_or_method; str.__eq__('builtin_function_or_method') returns True; new to extra98"]
    - [combinations_new_class_name_eq_builtin,
       "combinations.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.combinations.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.combinations is a C extension type; its __new__ is a builtin_function_or_method; str.__eq__('builtin_function_or_method') returns True; new to extra98"]
    - [accumulate_new_class_name_eq_builtin,
       "accumulate.__new__.__class__.__name__.__eq__",
       ["builtin_function_or_method"],
       true,
       "itertools.accumulate.__new__.__class__.__name__.__eq__('builtin_function_or_method') == True — itertools.accumulate is a C extension type; its __new__ is a builtin_function_or_method; str.__eq__('builtin_function_or_method') returns True; new to extra98"]

# ---------------------------------------------------------------------------
# Table 2: itertools C-type __qualname__ for filter/slice/groupby types
#
# Wave 255 theme: itertools C-type __qualname__ attributes.
#
# itertools.compress.__qualname__ == 'compress'
# itertools.dropwhile.__qualname__ == 'dropwhile'
# itertools.takewhile.__qualname__ == 'takewhile'
# itertools.islice.__qualname__ == 'islice'
# itertools.starmap.__qualname__ == 'starmap'
# itertools.filterfalse.__qualname__ == 'filterfalse'
# itertools.groupby.__qualname__ == 'groupby'
#
# All itertools C-extension types have a __qualname__ attribute equal to their
# simple class name, since they are defined at module scope in C.
# New to extra98.
# ---------------------------------------------------------------------------

table itertools_extra98.qualname_filter_slice_types:
  description: "itertools.compress/dropwhile/takewhile/islice/starmap/filterfalse/groupby __qualname__ equals their class name; C-extension types at module scope; wave 255; new to extra98"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsnewcls98

  columns: [id, function, args, expected, description]
  rows:
    - [compress_qualname_eq,
       "compress.__qualname__.__eq__",
       ["compress"],
       true,
       "itertools.compress.__qualname__.__eq__('compress') == True — itertools.compress is a C extension type defined at module scope in itertoolsmodule.c; for C types defined at module scope __qualname__ equals the simple class name; str.__eq__('compress') returns True; new to extra98"]
    - [dropwhile_qualname_eq,
       "dropwhile.__qualname__.__eq__",
       ["dropwhile"],
       true,
       "itertools.dropwhile.__qualname__.__eq__('dropwhile') == True — itertools.dropwhile is a C extension type defined at module scope; its __qualname__ equals the simple class name 'dropwhile'; str.__eq__('dropwhile') returns True; new to extra98"]
    - [takewhile_qualname_eq,
       "takewhile.__qualname__.__eq__",
       ["takewhile"],
       true,
       "itertools.takewhile.__qualname__.__eq__('takewhile') == True — itertools.takewhile is a C extension type defined at module scope; its __qualname__ equals 'takewhile'; str.__eq__('takewhile') returns True; new to extra98"]
    - [islice_qualname_eq,
       "islice.__qualname__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__qualname__.__eq__('islice') == True — itertools.islice is a C extension type; __qualname__ is the simple name 'islice' matching the type's name; str.__eq__('islice') returns True; new to extra98"]
    - [starmap_qualname_eq,
       "starmap.__qualname__.__eq__",
       ["starmap"],
       true,
       "itertools.starmap.__qualname__.__eq__('starmap') == True — itertools.starmap is a C extension type; __qualname__ equals 'starmap'; str.__eq__('starmap') returns True; new to extra98"]
    - [filterfalse_qualname_eq,
       "filterfalse.__qualname__.__eq__",
       ["filterfalse"],
       true,
       "itertools.filterfalse.__qualname__.__eq__('filterfalse') == True — itertools.filterfalse is a C extension type; __qualname__ equals 'filterfalse'; str.__eq__('filterfalse') returns True; new to extra98"]
    - [groupby_qualname_eq,
       "groupby.__qualname__.__eq__",
       ["groupby"],
       true,
       "itertools.groupby.__qualname__.__eq__('groupby') == True — itertools.groupby is a C extension type; __qualname__ equals 'groupby'; str.__eq__('groupby') returns True; new to extra98"]

# ---------------------------------------------------------------------------
# Table 3: itertools zip_longest and combo-type __qualname__
#
# Wave 255 theme: itertools zip_longest, combinations_with_replacement __qualname__.
#
# itertools.zip_longest.__qualname__ == 'zip_longest'
# itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement'
# itertools.chain.__qualname__ == 'chain'
# itertools.cycle.__qualname__ == 'cycle'
# itertools.repeat.__qualname__ == 'repeat'
#
# New to extra98.
# ---------------------------------------------------------------------------

table itertools_extra98.qualname_zip_combo_types:
  description: "itertools.zip_longest/combinations_with_replacement/chain/cycle/repeat __qualname__; C-extension types all have simple qualnames; wave 255; new to extra98"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsnewcls98

  columns: [id, function, args, expected, description]
  rows:
    - [zip_longest_qualname_eq,
       "zip_longest.__qualname__.__eq__",
       ["zip_longest"],
       true,
       "itertools.zip_longest.__qualname__.__eq__('zip_longest') == True — itertools.zip_longest is a C extension type defined at module scope in itertoolsmodule.c; its __qualname__ equals the simple class name 'zip_longest'; str.__eq__('zip_longest') returns True; new to extra98"]
    - [combinations_with_replacement_qualname_eq,
       "combinations_with_replacement.__qualname__.__eq__",
       ["combinations_with_replacement"],
       true,
       "itertools.combinations_with_replacement.__qualname__.__eq__('combinations_with_replacement') == True — itertools.combinations_with_replacement is a C extension type; __qualname__ is the full simple name 'combinations_with_replacement'; str.__eq__('combinations_with_replacement') returns True; new to extra98"]
    - [chain_qualname_eq,
       "chain.__qualname__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — itertools.chain is a C extension type; __qualname__ equals 'chain'; str.__eq__('chain') returns True; new to extra98"]
    - [cycle_qualname_eq,
       "cycle.__qualname__.__eq__",
       ["cycle"],
       true,
       "itertools.cycle.__qualname__.__eq__('cycle') == True — itertools.cycle is a C extension type; __qualname__ equals 'cycle'; str.__eq__('cycle') returns True; new to extra98"]
    - [repeat_qualname_eq,
       "repeat.__qualname__.__eq__",
       ["repeat"],
       true,
       "itertools.repeat.__qualname__.__eq__('repeat') == True — itertools.repeat is a C extension type; __qualname__ equals 'repeat'; str.__eq__('repeat') returns True; new to extra98"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra98
# ---------------------------------------------------------------------------

invariant itertools_extra98.chain_new_class_name:
  description: "itertools.chain.__new__.__class__.__name__ == 'builtin_function_or_method' — C extension type __new__ is always a C builtin; wave 255; new to extra98"
  kind: python_call_eq
  function: chain.__new__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra98.zip_longest_qualname:
  description: "itertools.zip_longest.__qualname__ == 'zip_longest' — C extension type defined at module scope has simple qualname; wave 255; new to extra98"
  kind: python_call_eq
  function: zip_longest.__qualname__.__eq__
  args: ["zip_longest"]
  expected: true

invariant itertools_extra98.filterfalse_qualname:
  description: "itertools.filterfalse.__qualname__ == 'filterfalse' — C extension type qualname equals the simple class name; wave 255; new to extra98"
  kind: python_call_eq
  function: filterfalse.__qualname__.__eq__
  args: ["filterfalse"]
  expected: true

invariant itertools_extra98.accumulate_new_class_name:
  description: "itertools.accumulate.__new__.__class__.__name__ == 'builtin_function_or_method' — accumulate is a C extension type; __new__ is a builtin; wave 255; new to extra98"
  kind: python_call_eq
  function: accumulate.__new__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant itertools_extra98.combinations_with_replacement_qualname:
  description: "itertools.combinations_with_replacement.__qualname__ == 'combinations_with_replacement' — C extension type with full descriptive name; wave 255; new to extra98"
  kind: python_call_eq
  function: combinations_with_replacement.__qualname__.__eq__
  args: ["combinations_with_replacement"]
  expected: true
