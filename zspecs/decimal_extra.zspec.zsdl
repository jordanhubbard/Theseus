spec: decimal_extra
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html
rfcs:
  - "IBM General Decimal Arithmetic Specification, Version 1.72"
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "IBM General Decimal Arithmetic Specification 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec covers decimal behaviors not in decimal.zspec.zsdl or _decimal.zspec.zsdl."
    - "Context, BasicContext, and ExtendedContext are classes; DefaultContext is an instance of Context."
    - "BasicContext and ExtendedContext are defined in the IBM General Decimal Arithmetic Specification."
    - "ROUND_HALF_UP, ROUND_HALF_DOWN, ROUND_CEILING, ROUND_FLOOR are string constants naming rounding modes."
    - "Decimal('1E+2').to_eng_string() returns engineering notation; the result is a str."
    - "Decimal('-1').is_signed() == True; Decimal('1').is_signed() == False (sign bit, not mathematical sign)."
    - "Decimal('NaN').is_nan() == True; Decimal('0').is_zero() == True; Decimal('Inf').is_infinite() == True."
    - "DefaultContext.__class__.__name__ == 'Context' confirms it is a Context instance, not a subclass."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Predicate methods — is_nan, is_infinite, is_zero, is_signed
#
# These test the special-value predicate path not covered by decimal.zspec.zsdl
# or confirm the sign-bit behavior with explicit positive/negative inputs.
# ---------------------------------------------------------------------------

invariant decimal_extra.Decimal.is_nan.true:
  description: "Decimal('NaN').is_nan() == True"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["NaN"]
  method: is_nan
  expected: true

invariant decimal_extra.Decimal.is_infinite.inf:
  description: "Decimal('Inf').is_infinite() == True"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["Inf"]
  method: is_infinite
  expected: true

invariant decimal_extra.Decimal.is_zero.zero:
  description: "Decimal('0').is_zero() == True"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["0"]
  method: is_zero
  expected: true

invariant decimal_extra.Decimal.is_signed.positive:
  description: "Decimal('1').is_signed() == False — positive numbers have sign bit 0"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["1"]
  method: is_signed
  expected: false

invariant decimal_extra.Decimal.is_signed.negative:
  description: "Decimal('-1').is_signed() == True — negative numbers have sign bit 1"
  category: predicates
  kind: python_call_eq
  function: Decimal
  args: ["-1"]
  method: is_signed
  expected: true

# ---------------------------------------------------------------------------
# to_eng_string() — returns a str in engineering notation
#
# Engineering notation restricts the exponent to multiples of 3.
# We verify the return value is a str via __class__.__name__.
# ---------------------------------------------------------------------------

invariant decimal_extra.Decimal.to_eng_string.type_is_str:
  description: "type(Decimal('1E+2').to_eng_string()).__name__ == 'str'"
  category: eng_string
  kind: python_call_eq
  function: Decimal
  args: ["1E+2"]
  method: to_eng_string
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["str"]
  expected: true

invariant decimal_extra.Decimal.to_eng_string.value:
  description: "Decimal('1E+2').to_eng_string() == '1E+2'"
  category: eng_string
  kind: python_call_eq
  function: Decimal
  args: ["1E+2"]
  method: to_eng_string
  expected: "1E+2"

# ---------------------------------------------------------------------------
# Class name checks — Context, BasicContext, ExtendedContext
#
# All three are classes defined in the decimal module; their __name__
# attributes confirm the public interface.
# ---------------------------------------------------------------------------

invariant decimal_extra.Context.class_name:
  description: "decimal.Context.__name__ == 'Context'"
  category: class_names
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra.BasicContext.class_name:
  description: "decimal.BasicContext.__name__ == 'BasicContext'"
  category: class_names
  kind: python_call_eq
  function: BasicContext.__name__.__eq__
  args: ["BasicContext"]
  expected: true

invariant decimal_extra.ExtendedContext.class_name:
  description: "decimal.ExtendedContext.__name__ == 'ExtendedContext'"
  category: class_names
  kind: python_call_eq
  function: ExtendedContext.__name__.__eq__
  args: ["ExtendedContext"]
  expected: true

# ---------------------------------------------------------------------------
# DefaultContext — is an instance of Context, not a class
#
# DefaultContext is a module-level Context instance. We confirm its runtime
# type via __class__.__name__, which must equal 'Context'.
# ---------------------------------------------------------------------------

invariant decimal_extra.DefaultContext.class_is_Context:
  description: "decimal.DefaultContext.__class__.__name__ == 'Context'"
  category: default_context
  kind: python_call_eq
  function: DefaultContext.__class__.__name__.__eq__
  args: ["Context"]
  expected: true

# ---------------------------------------------------------------------------
# Rounding mode constants — string identity
#
# The ROUND_* constants are plain strings naming the rounding mode. Each
# must equal its own name (as documented by the IBM GDA spec).
# ---------------------------------------------------------------------------

invariant decimal_extra.ROUND_HALF_UP.value:
  description: "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP'"
  category: rounding_modes
  kind: python_call_eq
  function: ROUND_HALF_UP.__eq__
  args: ["ROUND_HALF_UP"]
  expected: true

invariant decimal_extra.ROUND_HALF_DOWN.value:
  description: "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN'"
  category: rounding_modes
  kind: python_call_eq
  function: ROUND_HALF_DOWN.__eq__
  args: ["ROUND_HALF_DOWN"]
  expected: true

invariant decimal_extra.ROUND_CEILING.value:
  description: "decimal.ROUND_CEILING == 'ROUND_CEILING'"
  category: rounding_modes
  kind: python_call_eq
  function: ROUND_CEILING.__eq__
  args: ["ROUND_CEILING"]
  expected: true

invariant decimal_extra.ROUND_FLOOR.value:
  description: "decimal.ROUND_FLOOR == 'ROUND_FLOOR'"
  category: rounding_modes
  kind: python_call_eq
  function: ROUND_FLOOR.__eq__
  args: ["ROUND_FLOOR"]
  expected: true
