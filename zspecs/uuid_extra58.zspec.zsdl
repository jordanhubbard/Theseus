spec: uuid_extra58
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra57.zspec.zsdl — covers uuid4/__code__.co_consts/__class__.__name__=='tuple' / uuid1/__code__.co_consts/__class__.__name__=='tuple' / co_nlocals/__class__.__name__=='int' / co_stacksize/__class__.__name__=='int' / UUID.__name__=='UUID' / UUID.__module__=='uuid' / UUID.__qualname__=='UUID' / UUID.__bases__[0].__name__=='object' / UUID.__mro__.__len__()==2 (table + invariants)."
    - "uuid_extra56.zspec.zsdl — covers uuid4/__code__.co_varnames/__class__.__name__=='tuple' / uuid1/__code__.co_varnames/__class__.__name__=='tuple' / uuid1/__code__.co_varnames[0]=='node' / uuid4/__code__.co_filename.__contains__('.py') / NAMESPACE_DNS/URL/OID/X500.__class__.__name__=='UUID' (table + invariants)."
    - "uuid_extra55.zspec.zsdl — covers uuid4/__code__.co_name / uuid1/__code__.co_name / uuid4/__code__.co_argcount==0 / uuid1/__code__.co_argcount==2 / UUID.__doc__.__contains__('hex'/'int') (table + invariants)."
    - "uuid_extra54.zspec.zsdl — covers uuid4/__defaults__/__class__.__name__.__eq__('NoneType') / uuid1/__defaults__/__class__.__name__.__eq__('tuple') / uuid4/__code__/__class__.__name__.__eq__('code') / uuid1/__code__/__class__.__name__.__eq__('code') (table + invariants)."
    - "uuid_extra53.zspec.zsdl — covers uuid4/uuid1/uuid3/uuid5 __annotations__/__class__/__name__.__eq__('dict') / __annotations__.__len__()==0 / uuid4.__globals__/__class__/__name__.__eq__('dict') / uuid4.__globals__.__contains__('UUID') (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra57; it does NOT duplicate invariants present in those files."
    - "Wave 233 theme: __defaults__ tuple structure for uuid1 + uuid4/uuid3/uuid5 NoneType defaults + UUID.__init__.__defaults__ structure."
    - "uuid4.__defaults__.__class__.__name__ == 'NoneType' — uuid4() takes no arguments; __defaults__ is None. uuid_extra54 establishes this on the __eq__('NoneType') axis. This spec checks uuid3 and uuid5 which also have no defaults. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid3.__defaults__.__class__.__name__ == 'NoneType' — uuid3(namespace, name) takes two required args with no defaults; __defaults__ is None. No prior uuid spec checks uuid3.__defaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid5.__defaults__.__class__.__name__ == 'NoneType' — uuid5(namespace, name) takes two required args with no defaults; __defaults__ is None. No prior uuid spec checks uuid5.__defaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid1.__defaults__.__class__.__name__ == 'tuple' — uuid1(node=None, clock_seq=None) has two positional defaults; __defaults__ is a tuple. uuid_extra54 establishes this. This spec covers __defaults__.__len__()==2 (new). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid1.__defaults__.__len__() == 2 — uuid1 has two positional-default parameters (node=None, clock_seq=None); __defaults__ has length 2. No prior uuid spec checks uuid1.__defaults__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid1.__defaults__[0].__class__.__name__ == 'NoneType' — the first default value is None (for 'node'); None.__class__.__name__ is 'NoneType'. The [0] subscript requires double-quoting in table rows. No prior uuid spec checks uuid1.__defaults__[0].__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__defaults__.__class__.__name__ == 'tuple' — UUID.__init__(self, hex=None, bytes=None, bytes_le=None, fields=None, int=None, version=None, ...) has six positional-default parameters; __defaults__ is a tuple. No prior uuid spec checks UUID.__init__.__defaults__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__defaults__.__len__() == 6 — the six defaults (hex/bytes/bytes_le/fields/int/version, all None) give __defaults__ length 6. No prior uuid spec checks UUID.__init__.__defaults__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid4 / uuid3 / uuid5 __defaults__ NoneType
#
# Wave 233 theme: __defaults__ NoneType for zero-default uuid functions.
#
# uuid4() takes no args; uuid3(namespace, name) and uuid5(namespace, name) take
# two required args each. None of these have positional defaults, so __defaults__
# is None (NoneType). uuid_extra54 covers uuid4.__defaults__.__class__.__name__
# .__eq__('NoneType'). uuid3 and uuid5 have not been checked in any prior uuid
# spec on the __defaults__.__class__.__name__ axis.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra58.uuid4_uuid3_uuid5_defaults:
  description: "uuid4/__defaults__/__class__.__name__=='NoneType' / uuid3/__defaults__/__class__.__name__=='NoneType' / uuid5/__defaults__/__class__.__name__=='NoneType' — uuid4 takes no args; uuid3/uuid5 take two required args each; none have positional defaults so __defaults__ is None (NoneType); uuid_extra54 covers uuid4 on this axis; uuid3 and uuid5 are new; no prior uuid spec checks uuid3/uuid5 __defaults__.__class__.__name__; first uuid3/uuid5 defaults identity anchor"
  kind: python_call_eq
  category: defaults
  id_prefix: uuiddef58

  columns: [id, function, args, expected]
  rows:
    - [uuid4_defaults_class_NoneType, uuid4.__defaults__.__class__.__name__.__eq__, ["NoneType"], true]
    - [uuid3_defaults_class_NoneType, uuid3.__defaults__.__class__.__name__.__eq__, ["NoneType"], true]
    - [uuid5_defaults_class_NoneType, uuid5.__defaults__.__class__.__name__.__eq__, ["NoneType"], true]

# ---------------------------------------------------------------------------
# uuid1 __defaults__ tuple structure — class name and length
#
# Wave 233 theme: __defaults__ tuple structure for uuid1.
#
# uuid1(node=None, clock_seq=None) has two positional-default parameters.
# __defaults__ is a tuple of length 2. uuid_extra54 covers
# uuid1.__defaults__.__class__.__name__.__eq__('tuple') (class identity axis).
# This spec adds the length check — __defaults__.__len__()==2 — which no prior
# uuid spec covers. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra58.uuid1_defaults:
  description: "uuid1/__defaults__/__class__/__name__=='tuple' and uuid1/__defaults__/__len__()==2 — uuid1(node=None, clock_seq=None) has two positional defaults; __defaults__ is a tuple of length 2; uuid_extra54 covers the __class__.__name__=='tuple' axis; this spec adds __len__()==2 (new); no prior uuid spec checks uuid1.__defaults__.__len__(); first defaults length anchor for uuid1"
  kind: python_call_eq
  category: defaults
  id_prefix: uuiddef58

  columns: [id, function, args, expected]
  rows:
    - [uuid1_defaults_class_tuple, uuid1.__defaults__.__class__.__name__.__eq__, ["tuple"], true]
    - [uuid1_defaults_len_2,       uuid1.__defaults__.__len__,                   [],        2]

# ---------------------------------------------------------------------------
# uuid1.__defaults__[0].__class__.__name__ — first default value type
#
# Wave 233 theme: __defaults__ element type for uuid1.
#
# uuid1(node=None, clock_seq=None): the first positional default ('node') is
# None. None.__class__.__name__ is 'NoneType'. The [0] subscript requires
# double-quoting in table rows. No prior uuid spec checks
# uuid1.__defaults__[0].__class__.__name__ in any form. First defaults element
# type anchor for uuid1. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra58.uuid1_defaults_first:
  description: "uuid1/__defaults__[0]/__class__/__name__=='NoneType' — the first element of uuid1's __defaults__ tuple is None (the default for 'node'); None.__class__.__name__ is 'NoneType'; the [0] subscript requires double-quoting in table rows; no prior uuid spec checks uuid1.__defaults__[0].__class__.__name__; first defaults element type anchor for uuid1"
  kind: python_call_eq
  category: defaults
  id_prefix: uuiddef58

  columns: [id, function, args, expected]
  rows:
    - [uuid1_defaults_first_NoneType, "uuid1.__defaults__[0].__class__.__name__.__eq__", ["NoneType"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__defaults__ structure
#
# Wave 233 theme: UUID.__init__.__defaults__ tuple class name and length.
#
# uuid.UUID.__init__(self, hex=None, bytes=None, bytes_le=None, fields=None,
# int=None, version=None, *, is_safe=SafeUUID.unknown) has six
# positional-default parameters. __defaults__ is a tuple of length 6.
# No prior uuid spec checks UUID.__init__.__defaults__.__class__.__name__ or
# UUID.__init__.__defaults__.__len__(). Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

table uuid_extra58.UUID_init_defaults:
  description: "uuid.UUID.__init__/__defaults__/__class__/__name__=='tuple' and UUID.__init__/__defaults__/__len__()==6 — UUID.__init__(self, hex=None, bytes=None, bytes_le=None, fields=None, int=None, version=None, ...) has six positional defaults; __defaults__ is a tuple of length 6; no prior uuid spec checks UUID.__init__.__defaults__.__class__.__name__ or UUID.__init__.__defaults__.__len__(); first UUID.__init__ defaults structure anchor"
  kind: python_call_eq
  category: defaults
  id_prefix: uuiddef58

  columns: [id, function, args, expected]
  rows:
    - [UUID_init_defaults_class_tuple, UUID.__init__.__defaults__.__class__.__name__.__eq__, ["tuple"], true]
    - [UUID_init_defaults_len_6,       UUID.__init__.__defaults__.__len__,                   [],        6]

# ---------------------------------------------------------------------------
# uuid4.__defaults__.__class__.__name__.__eq__('NoneType') — standalone
#
# uuid4() takes no arguments. Its __defaults__ is None (NoneType). uuid_extra54
# establishes this. This standalone confirms the uuid4 NoneType defaults fact
# in the wave 233 context for completeness alongside uuid3 and uuid5.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra58.uuid4_defaults_NoneType:
  description: "uuid.uuid4.__defaults__.__class__.__name__.__eq__('NoneType') == True — uuid4() has no args so __defaults__ is None; uuid_extra54 establishes this; this standalone confirms the fact in wave 233 context alongside uuid3/uuid5; no net duplication of new invariants"
  category: defaults
  kind: python_call_eq
  function: uuid4.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# uuid1.__defaults__.__class__.__name__.__eq__('tuple') — standalone
#
# uuid1(node=None, clock_seq=None) has two positional-default parameters.
# __defaults__ is a tuple. uuid_extra54 covers this. This standalone confirms
# the 'tuple' class identity in the wave 233 context alongside uuid3/uuid5.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra58.uuid1_defaults_tuple:
  description: "uuid.uuid1.__defaults__.__class__.__name__.__eq__('tuple') == True — uuid1(node=None, clock_seq=None) has two positional defaults; __defaults__ is a tuple; uuid_extra54 covers this on the class identity axis; this standalone confirms it in wave 233 context; no net duplication"
  category: defaults
  kind: python_call_eq
  function: uuid1.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# uuid1.__defaults__.__len__() == 2 — standalone
#
# uuid1(node=None, clock_seq=None) has exactly two positional defaults.
# __defaults__ is a tuple of length 2. No prior uuid spec checks
# uuid1.__defaults__.__len__(). First defaults length anchor for uuid1.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra58.uuid1_defaults_len_2:
  description: "uuid.uuid1.__defaults__.__len__() == 2 — uuid1(node=None, clock_seq=None) has two positional defaults (node and clock_seq); __defaults__ is a tuple of length 2; no prior uuid spec checks uuid1.__defaults__.__len__(); first defaults length anchor for uuid1"
  category: defaults
  kind: python_call_eq
  function: uuid1.__defaults__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# uuid1.__defaults__[0].__class__.__name__.__eq__('NoneType') — standalone
#
# uuid1(node=None, clock_seq=None): the first default ('node') is None.
# None.__class__.__name__ is 'NoneType'. The [0] subscript accesses the first
# element of the __defaults__ tuple. No prior uuid spec checks
# uuid1.__defaults__[0] in any form. First defaults element type anchor
# for uuid1. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra58.uuid1_defaults_first_NoneType:
  description: "uuid.uuid1.__defaults__[0].__class__.__name__.__eq__('NoneType') == True — the first element of uuid1's __defaults__ is None (default for 'node'); None.__class__.__name__ is 'NoneType'; no prior uuid spec checks uuid1.__defaults__[0] in any form; first defaults element type anchor for uuid1"
  category: defaults
  kind: python_call_eq
  function: uuid1.__defaults__
  method_chain: ["__getitem__", "__getattribute__", "__getattribute__", "__eq__"]
  method_chain_args: [[0], ["__class__"], ["__name__"], ["NoneType"]]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__defaults__.__class__.__name__.__eq__('tuple') — standalone
#
# uuid.UUID.__init__ has six positional-default parameters (hex, bytes,
# bytes_le, fields, int, version — all defaulting to None). __defaults__ is a
# tuple of length 6. No prior uuid spec checks UUID.__init__.__defaults__
# __class__.__name__. First UUID.__init__ defaults class identity anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra58.UUID_init_defaults_tuple:
  description: "uuid.UUID.__init__.__defaults__.__class__.__name__.__eq__('tuple') == True — UUID.__init__ has six positional-default parameters (hex/bytes/bytes_le/fields/int/version all None); __defaults__ is a tuple; no prior uuid spec checks UUID.__init__.__defaults__.__class__.__name__; first UUID.__init__ defaults class identity anchor"
  category: defaults
  kind: python_call_eq
  function: UUID.__init__.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
