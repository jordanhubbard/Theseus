spec: polyfactory_rust
version: ">=3.9"
backend: rust_module(polyfactory_rust)

docs: https://polyfactory.litestar.dev/

provenance:
  derived_from:
    - "https://polyfactory.litestar.dev/ — polyfactory documentation"
  not_derived_from:
    - "polyfactory source: polyfactory/__init__.py"
  notes:
    - "polyfactory provides factories for Pydantic and dataclass models."
    - "from polyfactory.factories import DataclassFactory."
    - "DataclassFactory is available."
    - "DataclassFactory.__name__ == 'DataclassFactory'."
    - "polyfactory.__version__ is a non-empty string."
    - "Expose polyfactory_class_name() -> str: DataclassFactory.__name__."
    - "Expose polyfactory_has_factories() -> bool: hasattr(polyfactory, 'factories')."
    - "Expose polyfactory_version_nonempty() -> bool: len(polyfactory.__version__) > 0."
    - "All test vectors verified against polyfactory 2.21.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# polyfactory_class_name — DataclassFactory class name
invariant polyfactory_rust.factory.class_name:
  description: "DataclassFactory.__name__ == 'DataclassFactory'"
  category: factory
  kind: python_call_eq
  function: polyfactory_class_name
  args: []
  expected: "DataclassFactory"

# polyfactory_has_factories — factories module present
invariant polyfactory_rust.module.has_factories:
  description: "polyfactory.factories is available"
  category: module
  kind: python_call_eq
  function: polyfactory_has_factories
  args: []
  expected: true

# polyfactory_version_nonempty — version non-empty
invariant polyfactory_rust.version.nonempty:
  description: "polyfactory.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: polyfactory_version_nonempty
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:12:01Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
