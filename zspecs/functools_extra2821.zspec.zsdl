spec: functools_extra2821
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "any proprietary source"
  notes:
    - "Wave 635 (_extra2821): __radd__, __rsub__, and __rmul__ dict-presence checks (reflected/right-hand addition, subtraction, multiplication)."
    - "functools.partial is a C-level type — no reflected arithmetic operators defined."
    - "functools.partialmethod is a pure-Python class — no reflected arithmetic operators defined."
    - "functools.cached_property is a pure-Python descriptor class — no reflected arithmetic operators defined."
    - "functools.singledispatchmethod is a pure-Python class — no reflected arithmetic operators defined."
    - "None of the functools utility types implement numeric arithmetic protocols; __radd__, __rsub__, __rmul__ are all absent."
    - "Reflected operators (__radd__, __rsub__, __rmul__) are invoked when the left operand does not support the operation; these higher-order function wrappers have no numeric semantics."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __radd__ dict-presence (reflected addition)
#
# functools.partial, partialmethod, cached_property, singledispatchmethod
# are utility wrappers — none define __radd__ in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra2821.radd_protocol:
  description: "functools types __radd__ dict-presence checks — all False (no reflected addition protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2821
  columns: [id, function, args, expected]
  rows:
    - ["ft2821001", "functools.partial.__dict__.__contains__",              ["__radd__"], false]
    - ["ft2821002", "functools.partialmethod.__dict__.__contains__",        ["__radd__"], false]
    - ["ft2821003", "functools.cached_property.__dict__.__contains__",      ["__radd__"], false]
    - ["ft2821004", "functools.singledispatchmethod.__dict__.__contains__",  ["__radd__"], false]

# ---------------------------------------------------------------------------
# Table 2: __rsub__ dict-presence (reflected subtraction)
#
# None of the functools types define __rsub__ — these classes wrap
# callables and have no numeric subtraction semantics.
# ---------------------------------------------------------------------------

table functools_extra2821.rsub_protocol:
  description: "functools types __rsub__ dict-presence checks — all False (no reflected subtraction protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2821
  columns: [id, function, args, expected]
  rows:
    - ["ft2821005", "functools.partial.__dict__.__contains__",              ["__rsub__"], false]
    - ["ft2821006", "functools.partialmethod.__dict__.__contains__",        ["__rsub__"], false]
    - ["ft2821007", "functools.cached_property.__dict__.__contains__",      ["__rsub__"], false]
    - ["ft2821008", "functools.singledispatchmethod.__dict__.__contains__",  ["__rsub__"], false]

# ---------------------------------------------------------------------------
# Table 3: __rmul__ dict-presence (reflected multiplication)
#
# None of the functools types define __rmul__ — higher-order function
# utilities have no multiplication or sequence repetition semantics.
# ---------------------------------------------------------------------------

table functools_extra2821.rmul_protocol:
  description: "functools types __rmul__ dict-presence checks — all False (no reflected multiplication protocol)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2821
  columns: [id, function, args, expected]
  rows:
    - ["ft2821009", "functools.partial.__dict__.__contains__",              ["__rmul__"], false]
    - ["ft2821010", "functools.partialmethod.__dict__.__contains__",        ["__rmul__"], false]
    - ["ft2821011", "functools.cached_property.__dict__.__contains__",      ["__rmul__"], false]
    - ["ft2821012", "functools.singledispatchmethod.__dict__.__contains__",  ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Table 4: combined reflected arithmetic operator absence — all three ops
#
# Cross-check: each type lacks all three reflected arithmetic operators.
# Confirms that the functools API surface is strictly about higher-order
# function utilities, not numeric addition, subtraction, or multiplication.
# ---------------------------------------------------------------------------

table functools_extra2821.reflected_arith_absent:
  description: "functools types full __radd__/__rsub__/__rmul__ absence cross-check — all False"
