spec: hashlib_extra435
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib additional hash algorithm identity"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "sha3_* and shake_* algorithms are provided by the _sha3 C extension module"
    - "All classes tested here are type objects whose __module__ is '_sha3'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra435.algorithm_identity:
  description: "Identity attributes of hashlib SHA-3 and SHAKE algorithm classes"
  kind: python_call_eq
  category: identity
  id_prefix: hlex

  columns: [id, function, args, expected]
  rows:
    - [hlex001, hashlib.sha3_256.__name__.__eq__,          ["sha3_256"],  true]
    - [hlex002, hashlib.sha3_256.__module__.__eq__,        ["_sha3"],     true]
    - [hlex003, "hashlib.sha3_256.__bases__[0].__name__.__eq__", ["object"], true]
    - [hlex004, hashlib.sha3_512.__name__.__eq__,          ["sha3_512"],  true]
    - [hlex005, hashlib.sha3_512.__module__.__eq__,        ["_sha3"],     true]
    - [hlex006, "hashlib.sha3_512.__bases__[0].__name__.__eq__", ["object"], true]
    - [hlex007, hashlib.sha3_224.__name__.__eq__,          ["sha3_224"],  true]
    - [hlex008, hashlib.sha3_224.__module__.__eq__,        ["_sha3"],     true]
    - [hlex009, hashlib.sha3_384.__name__.__eq__,          ["sha3_384"],  true]
    - [hlex010, hashlib.sha3_384.__module__.__eq__,        ["_sha3"],     true]
    - [hlex011, hashlib.shake_128.__name__.__eq__,         ["shake_128"], true]
    - [hlex012, hashlib.shake_256.__name__.__eq__,         ["shake_256"], true]
