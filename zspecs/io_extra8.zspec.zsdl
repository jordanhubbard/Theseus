spec: io_extra8
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl, _io.zspec.zsdl, _io_extra.zspec.zsdl, io_extra.zspec.zsdl, io_extra2.zspec.zsdl, io_extra3.zspec.zsdl, io_extra4.zspec.zsdl, io_extra5.zspec.zsdl, io_extra6.zspec.zsdl, io_extra7.zspec.zsdl."
    - "io_extra7.zspec.zsdl covers __name__ for RawIOBase, BufferedIOBase, TextIOBase, FileIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper, and __module__ for those same classes."
    - "This spec adds __name__ and __module__ for IOBase (the root ABC), and the __bases__ inheritance chain for IOBase, RawIOBase, BufferedIOBase, TextIOBase, FileIO, BytesIO, StringIO."
    - "io.IOBase.__name__ == 'IOBase' — root abstract base class for all I/O classes."
    - "io.IOBase.__module__ == 'io' — defined in the io module."
    - "io.RawIOBase.__bases__[0].__name__ == 'IOBase' — RawIOBase inherits directly from IOBase."
    - "io.BufferedIOBase.__bases__[0].__name__ == 'IOBase' — BufferedIOBase inherits directly from IOBase."
    - "io.TextIOBase.__bases__[0].__name__ == 'IOBase' — TextIOBase inherits directly from IOBase."
    - "io.FileIO.__bases__[0].__name__ == 'RawIOBase' — FileIO inherits from RawIOBase."
    - "io.BytesIO.__bases__[0].__name__ == 'BufferedIOBase' — BytesIO inherits from BufferedIOBase."
    - "io.StringIO.__bases__[0].__name__ == 'TextIOBase' — StringIO inherits from TextIOBase."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IOBase — root ABC: __name__ and __module__
# These were not covered by io_extra7 which only covered the subclasses.
# ---------------------------------------------------------------------------

invariant io_extra8.IOBase.class_name:
  description: "io.IOBase.__name__ == 'IOBase'"
  category: class_names
  kind: python_call_eq
  function: IOBase.__name__.__eq__
  args: ["IOBase"]
  expected: true

invariant io_extra8.IOBase.module:
  description: "io.IOBase.__module__ == 'io'"
  category: module
  kind: python_call_eq
  function: IOBase.__module__.__eq__
  args: ["io"]
  expected: true

# ---------------------------------------------------------------------------
# ABC class names table — IOBase, RawIOBase, BufferedIOBase, TextIOBase
# (IOBase not in io_extra7 table; others are in io_extra7 table but we
# provide IOBase here for completeness in a focused ABC table.)
# ---------------------------------------------------------------------------

table io_extra8.abc_class_names:
  kind: python_call_eq
  category: abc_names
  id_prefix: abc_name

  columns: [id, function, args, expected]
  rows:
    - [IOBase,         IOBase.__name__.__eq__,         ["IOBase"],         true]
    - [RawIOBase,      RawIOBase.__name__.__eq__,      ["RawIOBase"],      true]
    - [BufferedIOBase, BufferedIOBase.__name__.__eq__,  ["BufferedIOBase"],  true]
    - [TextIOBase,     TextIOBase.__name__.__eq__,     ["TextIOBase"],     true]

# ---------------------------------------------------------------------------
# Inheritance hierarchy — __bases__[0].__name__ checks
#
# Verifies the direct parent class name for each ABC and concrete class.
# These vectors are new; no prior spec tests __bases__ for io classes.
# ---------------------------------------------------------------------------

invariant io_extra8.RawIOBase.base_is_IOBase:
  description: "io.RawIOBase.__bases__[0].__name__ == 'IOBase'"
  category: hierarchy
  kind: python_call_eq
  function: RawIOBase.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IOBase"

invariant io_extra8.BufferedIOBase.base_is_IOBase:
  description: "io.BufferedIOBase.__bases__[0].__name__ == 'IOBase'"
  category: hierarchy
  kind: python_call_eq
  function: BufferedIOBase.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IOBase"

invariant io_extra8.TextIOBase.base_is_IOBase:
  description: "io.TextIOBase.__bases__[0].__name__ == 'IOBase'"
  category: hierarchy
  kind: python_call_eq
  function: TextIOBase.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "IOBase"

invariant io_extra8.FileIO.base_is_RawIOBase:
  description: "io.FileIO.__bases__[0].__name__ == 'RawIOBase'"
  category: hierarchy
  kind: python_call_eq
  function: FileIO.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "RawIOBase"

invariant io_extra8.BytesIO.base_is_BufferedIOBase:
  description: "io.BytesIO.__bases__[0].__name__ == 'BufferedIOBase'"
  category: hierarchy
  kind: python_call_eq
  function: BytesIO.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BufferedIOBase"

invariant io_extra8.StringIO.base_is_TextIOBase:
  description: "io.StringIO.__bases__[0].__name__ == 'TextIOBase'"
  category: hierarchy
  kind: python_call_eq
  function: StringIO.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "TextIOBase"
