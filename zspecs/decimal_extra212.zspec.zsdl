spec: decimal_extra212
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "General Decimal Arithmetic specification — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "All rounding mode constants are plain str values: ROUND_UP='ROUND_UP', ROUND_DOWN='ROUND_DOWN', etc. Verified with Python 3.14.3."
    - "type(decimal.ROUND_UP).__name__=='str' — rounding modes are strings, not enums. Verified with Python 3.14.3."
    - "Lengths: ROUND_UP=8, ROUND_DOWN=10, ROUND_CEILING=13, ROUND_FLOOR=11, ROUND_HALF_UP=13, ROUND_HALF_DOWN=15, ROUND_HALF_EVEN=15, ROUND_05UP=10. Verified with Python 3.14.3."
    - "decimal.InvalidOperation.__bases__[0].__name__=='DecimalException'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Rounding mode string equality checks
# ---------------------------------------------------------------------------

table decimal_extra212.rounding_mode_values:
  description: "decimal rounding mode constant string equality: ROUND_UP=='ROUND_UP', ROUND_DOWN=='ROUND_DOWN', ROUND_CEILING=='ROUND_CEILING', ROUND_FLOOR=='ROUND_FLOOR', ROUND_HALF_UP=='ROUND_HALF_UP', ROUND_HALF_DOWN=='ROUND_HALF_DOWN', ROUND_HALF_EVEN=='ROUND_HALF_EVEN', ROUND_05UP=='ROUND_05UP'; all are str; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: decimalextra212a

  columns: [id, function, args, expected, description]
  rows:
    - [round_up_eq,        decimal.ROUND_UP.__eq__,        ["ROUND_UP"],        true, "decimal.ROUND_UP == 'ROUND_UP'; verified with Python 3.14.3"]
    - [round_down_eq,      decimal.ROUND_DOWN.__eq__,      ["ROUND_DOWN"],      true, "decimal.ROUND_DOWN == 'ROUND_DOWN'; verified with Python 3.14.3"]
    - [round_ceiling_eq,   decimal.ROUND_CEILING.__eq__,   ["ROUND_CEILING"],   true, "decimal.ROUND_CEILING == 'ROUND_CEILING'; verified with Python 3.14.3"]
    - [round_floor_eq,     decimal.ROUND_FLOOR.__eq__,     ["ROUND_FLOOR"],     true, "decimal.ROUND_FLOOR == 'ROUND_FLOOR'; verified with Python 3.14.3"]
    - [round_half_up_eq,   decimal.ROUND_HALF_UP.__eq__,   ["ROUND_HALF_UP"],   true, "decimal.ROUND_HALF_UP == 'ROUND_HALF_UP'; verified with Python 3.14.3"]
    - [round_half_down_eq, decimal.ROUND_HALF_DOWN.__eq__,  ["ROUND_HALF_DOWN"], true, "decimal.ROUND_HALF_DOWN == 'ROUND_HALF_DOWN'; verified with Python 3.14.3"]
    - [round_half_even_eq, decimal.ROUND_HALF_EVEN.__eq__,  ["ROUND_HALF_EVEN"], true, "decimal.ROUND_HALF_EVEN == 'ROUND_HALF_EVEN'; verified with Python 3.14.3"]
    - [round_05up_eq,      decimal.ROUND_05UP.__eq__,      ["ROUND_05UP"],      true, "decimal.ROUND_05UP == 'ROUND_05UP'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Rounding mode type checks — all are str
# ---------------------------------------------------------------------------

table decimal_extra212.rounding_mode_types:
  description: "decimal rounding mode constants are all plain str: type(ROUND_UP).__name__=='str', type(ROUND_DOWN).__name__=='str', etc.; not an enum; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: decimalextra212b

  columns: [id, function, args, expected, description]
  rows:
    - [rup_type,    decimal.ROUND_UP.__class__.__name__.__eq__,        ["str"], true, "type(decimal.ROUND_UP).__name__ == 'str'; verified with Python 3.14.3"]
    - [rdown_type,  decimal.ROUND_DOWN.__class__.__name__.__eq__,      ["str"], true, "type(decimal.ROUND_DOWN).__name__ == 'str'; verified with Python 3.14.3"]
    - [rceil_type,  decimal.ROUND_CEILING.__class__.__name__.__eq__,   ["str"], true, "type(decimal.ROUND_CEILING).__name__ == 'str'; verified with Python 3.14.3"]
    - [rfloor_type, decimal.ROUND_FLOOR.__class__.__name__.__eq__,     ["str"], true, "type(decimal.ROUND_FLOOR).__name__ == 'str'; verified with Python 3.14.3"]
    - [rhup_type,   decimal.ROUND_HALF_UP.__class__.__name__.__eq__,   ["str"], true, "type(decimal.ROUND_HALF_UP).__name__ == 'str'; verified with Python 3.14.3"]
    - [rhdown_type, decimal.ROUND_HALF_DOWN.__class__.__name__.__eq__,  ["str"], true, "type(decimal.ROUND_HALF_DOWN).__name__ == 'str'; verified with Python 3.14.3"]
    - [rheven_type, decimal.ROUND_HALF_EVEN.__class__.__name__.__eq__,  ["str"], true, "type(decimal.ROUND_HALF_EVEN).__name__ == 'str'; verified with Python 3.14.3"]
    - [r05up_type,  decimal.ROUND_05UP.__class__.__name__.__eq__,      ["str"], true, "type(decimal.ROUND_05UP).__name__ == 'str'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Rounding mode string length checks
# ---------------------------------------------------------------------------

table decimal_extra212.rounding_mode_lengths:
  description: "decimal rounding mode string lengths: ROUND_UP=8, ROUND_DOWN=10, ROUND_CEILING=13, ROUND_FLOOR=11, ROUND_HALF_UP=13, ROUND_HALF_DOWN=15, ROUND_HALF_EVEN=15, ROUND_05UP=10; verified with Python 3.14.3"
  kind: python_call_eq
  category: constants
  id_prefix: decimalextra212c

  columns: [id, function, args, expected, description]
  rows:
    - [rup_len,    decimal.ROUND_UP.__len__,        [], 8,  "len('ROUND_UP') == 8; 'ROUND_'=6+'UP'=2; verified with Python 3.14.3"]
    - [rdown_len,  decimal.ROUND_DOWN.__len__,      [], 10, "len('ROUND_DOWN') == 10; 'ROUND_'=6+'DOWN'=4; verified with Python 3.14.3"]
    - [rceil_len,  decimal.ROUND_CEILING.__len__,   [], 13, "len('ROUND_CEILING') == 13; 'ROUND_'=6+'CEILING'=7; verified with Python 3.14.3"]
    - [rfloor_len, decimal.ROUND_FLOOR.__len__,     [], 11, "len('ROUND_FLOOR') == 11; 'ROUND_'=6+'FLOOR'=5; verified with Python 3.14.3"]
    - [rhup_len,   decimal.ROUND_HALF_UP.__len__,   [], 13, "len('ROUND_HALF_UP') == 13; 'ROUND_HALF_'=11+'UP'=2; verified with Python 3.14.3"]
    - [rhdown_len, decimal.ROUND_HALF_DOWN.__len__,  [], 15, "len('ROUND_HALF_DOWN') == 15; 'ROUND_HALF_'=11+'DOWN'=4; verified with Python 3.14.3"]
    - [rheven_len, decimal.ROUND_HALF_EVEN.__len__,  [], 15, "len('ROUND_HALF_EVEN') == 15; 'ROUND_HALF_'=11+'EVEN'=4; verified with Python 3.14.3"]
    - [r05up_len,  decimal.ROUND_05UP.__len__,      [], 10, "len('ROUND_05UP') == 10; 'ROUND_'=6+'05UP'=4; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra212.round_up_eq_str:
  description: "decimal.ROUND_UP.__eq__('ROUND_UP') returns True — ROUND_UP is a plain Python str constant, not an enum value; its value is the string 'ROUND_UP'; len==8; type is str; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_UP.__eq__
  args: ["ROUND_UP"]
  expected: true

invariant decimal_extra212.round_half_even_eq_str:
  description: "decimal.ROUND_HALF_EVEN.__eq__('ROUND_HALF_EVEN') returns True — ROUND_HALF_EVEN (banker's rounding) is the default rounding mode for a new decimal Context; value is the string 'ROUND_HALF_EVEN'; len==15; type is str; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_HALF_EVEN.__eq__
  args: ["ROUND_HALF_EVEN"]
  expected: true

invariant decimal_extra212.round_half_down_len_15:
  description: "decimal.ROUND_HALF_DOWN.__len__() == 15 — 'ROUND_HALF_DOWN' has 15 characters: 'ROUND_'=6 + 'HALF_'=5 + 'DOWN'=4 = 15; same length as ROUND_HALF_EVEN (15); longest pair of equal-length rounding mode names; verified with Python 3.14.3"
  category: constants
  kind: python_call_eq
  function: decimal.ROUND_HALF_DOWN.__len__
  args: []
  expected: 15

invariant decimal_extra212.round_up_type_is_str:
  description: "decimal.ROUND_UP.__class__.__name__.__eq__('str') returns True — rounding modes are plain str constants (not enum members); this contrasts with re.IGNORECASE which is RegexFlag (an IntFlag); decimal rounding modes are just string literals; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: decimal.ROUND_UP.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# decimal.InvalidOperation exception raises
# ---------------------------------------------------------------------------

invariant decimal_extra212.invalid_operation_name:
  description: "decimal.InvalidOperation.__name__.__eq__('InvalidOperation') returns True — InvalidOperation is the exception raised when an invalid operation is performed (e.g., Decimal('nan_xyz')); __bases__[0].__name__=='DecimalException'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: decimal.InvalidOperation.__name__.__eq__
  args: ["InvalidOperation"]
  expected: true

invariant decimal_extra212.invalid_operation_base:
  description: "decimal.InvalidOperation.__bases__[0].__name__.__eq__('DecimalException') returns True — InvalidOperation inherits from DecimalException, which is the base for all decimal exceptions; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "decimal.InvalidOperation.__bases__[0].__name__.__eq__"
  args: ["DecimalException"]
  expected: true

invariant decimal_extra212.decimal_class_name:
  description: "decimal.Decimal.__name__.__eq__('Decimal') returns True — Decimal is the main class; __module__=='decimal'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: decimal.Decimal.__name__.__eq__
  args: ["Decimal"]
  expected: true
