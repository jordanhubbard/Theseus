spec: decimal_extra2671
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2656.zspec.zsdl — covers __contains__/__add__/__mul__ dict-presence"
  notes:
    - "Wave 625 (decimal_extra2671) theme: __sub__, __floordiv__, and __mod__ dict-presence checks."
    - "decimal.Decimal defines __sub__, __floordiv__, AND __mod__ in its own __dict__ — Decimal is a full arithmetic type."
    - "decimal.Decimal also defines __rfloordiv__ and __rmod__ for reflected floor-division and modulo."
    - "decimal.Context and decimal.DecimalException define none of __sub__, __floordiv__, or __mod__ in their own __dict__."
    - "decimal.Context.__sub__ is absent because Context is a configuration object, not a numeric value."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __sub__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2671.sub_in_decimal_classes:
  description: "__sub__ IS defined in decimal.Decimal __dict__ but absent from decimal.Context and decimal.DecimalException — only Decimal implements arithmetic subtraction"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2671

  columns: [id, function, args, expected]
  rows:
    - ["dc2671001", "decimal.Decimal.__dict__.__contains__",          ["__sub__"], true]
    - ["dc2671002", "decimal.Context.__dict__.__contains__",          ["__sub__"], false]
    - ["dc2671003", "decimal.DecimalException.__dict__.__contains__", ["__sub__"], false]

# ---------------------------------------------------------------------------
# __floordiv__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2671.floordiv_in_decimal_classes:
  description: "__floordiv__ IS defined in decimal.Decimal __dict__ but absent from decimal.Context and decimal.DecimalException — only Decimal implements floor-division"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2671

  columns: [id, function, args, expected]
  rows:
    - ["dc2671004", "decimal.Decimal.__dict__.__contains__",          ["__floordiv__"], true]
    - ["dc2671005", "decimal.Context.__dict__.__contains__",          ["__floordiv__"], false]
    - ["dc2671006", "decimal.DecimalException.__dict__.__contains__", ["__floordiv__"], false]

# ---------------------------------------------------------------------------
# __mod__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2671.mod_in_decimal_classes:
  description: "__mod__ IS defined in decimal.Decimal __dict__ but absent from decimal.Context and decimal.DecimalException — only Decimal implements the modulo operator"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2671

  columns: [id, function, args, expected]
  rows:
    - ["dc2671007", "decimal.Decimal.__dict__.__contains__",          ["__mod__"], true]
    - ["dc2671008", "decimal.Context.__dict__.__contains__",          ["__mod__"], false]
    - ["dc2671009", "decimal.DecimalException.__dict__.__contains__", ["__mod__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal has full arithmetic protocol including reflected operators;
# Context has configuration methods only and no arithmetic hooks
# ---------------------------------------------------------------------------

table decimal_extra2671.decimal_arithmetic_protocol_and_reflected_ops:
  description: "decimal.Decimal defines __sub__/__floordiv__/__mod__/__rfloordiv__/__rmod__/__abs__/__neg__ but NOT these in decimal.Context; Context defines prec/rounding/create_decimal but NOT arithmetic hooks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2671

  columns: [id, function, args, expected]
  rows:
    - ["dc2671010", "decimal.Decimal.__dict__.__contains__", ["__sub__"],       true]
    - ["dc2671011", "decimal.Decimal.__dict__.__contains__", ["__floordiv__"],  true]
    - ["dc2671012", "decimal.Decimal.__dict__.__contains__", ["__mod__"],       true]
    - ["dc2671013", "decimal.Decimal.__dict__.__contains__", ["__rfloordiv__"], true]
    - ["dc2671014", "decimal.Decimal.__dict__.__contains__", ["__rmod__"],      true]
    - ["dc2671015", "decimal.Decimal.__dict__.__contains__", ["__abs__"],       true]
    - ["dc2671016", "decimal.Decimal.__dict__.__contains__", ["__neg__"],       true]
    - ["dc2671017", "decimal.Context.__dict__.__contains__", ["prec"],          true]
    - ["dc2671018", "decimal.Context.__dict__.__contains__", ["rounding"],      true]
    - ["dc2671019", "decimal.Context.__dict__.__contains__", ["create_decimal"], true]
    - ["dc2671020", "decimal.Context.__dict__.__contains__", ["__sub__"],       false]
    - ["dc2671021", "decimal.Context.__dict__.__contains__", ["__floordiv__"],  false]
    - ["dc2671022", "decimal.Context.__dict__.__contains__", ["__mod__"],       false]
