spec: re_extra1636
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for ABC virtual subclassing protocol"
    - "re classes (Pattern, Match, error, RegexFlag) are not ABCs and do not define __subclasshook__."
    - "re.Pattern and re.Match are C-extension types; their metaclass is type."
    - "re.error is a plain Python exception class inheriting from Exception."
    - "In Python 3.13+, re.error was renamed to re.PatternError; re.error remains as an alias."
    - "re.error.__name__ == 'PatternError' on Python 3.13+; 'error' on Python 3.9-3.12."
    - "re.error.__bases__[0].__name__ == 'Exception' on all supported versions."
    - "re.RegexFlag is an IntFlag enum; its metaclass is EnumType (not ABCMeta)."
    - "re.RegexFlag.__bases__[0].__name__ == 'IntFlag' — IntFlag is the direct base."
    - "re.RegexFlag inherits from int transitively via IntFlag (mro[2].__name__ == 'int')."
    - "IGNORECASE == 2, MULTILINE == 8, DOTALL == 16, VERBOSE == 64, UNICODE == 32."
    - "isinstance(re.compile('abc'), re.Pattern) is True — C-level type identity check."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: re classes do not define __subclasshook__, __instancecheck__, or
# __subclasscheck__ in their own __dict__. Pattern and Match are C types;
# error is a plain Python exception; RegexFlag uses EnumType as metaclass.
# ---------------------------------------------------------------------------

table re_extra1636.no_virtual_subclassing:
  description: "re classes do not define __subclasshook__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1636

  columns: [id, function, args, expected]
  rows:
    - ["re1636001", "Pattern.__dict__.__contains__",   ["__subclasshook__"],  false]
    - ["re1636002", "Match.__dict__.__contains__",     ["__subclasshook__"],  false]
    - ["re1636003", "error.__dict__.__contains__",     ["__subclasshook__"],  false]
    - ["re1636004", "RegexFlag.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["re1636005", "Pattern.__dict__.__contains__",   ["__instancecheck__"], false]
    - ["re1636006", "Match.__dict__.__contains__",     ["__instancecheck__"], false]
    - ["re1636007", "error.__dict__.__contains__",     ["__instancecheck__"], false]
    - ["re1636008", "RegexFlag.__dict__.__contains__", ["__instancecheck__"], false]
    - ["re1636009", "Pattern.__dict__.__contains__",   ["__subclasscheck__"], false]
    - ["re1636010", "Match.__dict__.__contains__",     ["__subclasscheck__"], false]
    - ["re1636011", "error.__dict__.__contains__",     ["__subclasscheck__"], false]
    - ["re1636012", "RegexFlag.__dict__.__contains__", ["__subclasscheck__"], false]
    - ["re1636013", "Pattern.__class__.__name__.__eq__",   ["type"],          true]
    - ["re1636014", "Match.__class__.__name__.__eq__",     ["type"],          true]
    - ["re1636015", "error.__class__.__name__.__eq__",     ["type"],          true]
    - ["re1636016", "Pattern.__name__.__eq__",         ["Pattern"],           true]
    - ["re1636017", "Match.__name__.__eq__",           ["Match"],             true]
    - ["re1636018", "RegexFlag.__name__.__eq__",       ["RegexFlag"],         true]
    - ["re1636019", "error.__module__.__eq__",         ["re"],                true]
    - ["re1636020", "Pattern.__module__.__eq__",       ["re"],                true]

# ---------------------------------------------------------------------------
# Table 2: class identity confirmed via __dict__ method presence.
#
# re.Pattern defines: findall, finditer, search, match, fullmatch, split,
#   sub, subn, flags, groups, groupindex, pattern, scanner
# re.Match defines: group, groups, groupdict, start, end, span, expand,
#   pos, endpos, re, string, regs, lastindex, lastgroup
# re.error defines: __init__, __module__ (minimal exception attributes)
# re.RegexFlag defines: IGNORECASE, UNICODE, MULTILINE, DOTALL, VERBOSE,
#   ASCII, LOCALE, NOFLAG and their single-letter aliases (I, U, M, S, X, A, L)
# ---------------------------------------------------------------------------

table re_extra1636.isinstance_hierarchy:
  description: "re class method presence confirming class identity and hierarchy"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1636i

  columns: [id, function, args, expected]
  rows:
    - ["re1636i001", "Pattern.__dict__.__contains__", ["findall"],    true]
    - ["re1636i002", "Pattern.__dict__.__contains__", ["search"],     true]
    - ["re1636i003", "Pattern.__dict__.__contains__", ["match"],      true]
    - ["re1636i004", "Pattern.__dict__.__contains__", ["fullmatch"],  true]
    - ["re1636i005", "Pattern.__dict__.__contains__", ["sub"],        true]
    - ["re1636i006", "Pattern.__dict__.__contains__", ["subn"],       true]
    - ["re1636i007", "Pattern.__dict__.__contains__", ["split"],      true]
    - ["re1636i008", "Pattern.__dict__.__contains__", ["finditer"],   true]
    - ["re1636i009", "Pattern.__dict__.__contains__", ["flags"],      true]
    - ["re1636i010", "Pattern.__dict__.__contains__", ["pattern"],    true]
    - ["re1636i011", "Match.__dict__.__contains__",   ["group"],      true]
    - ["re1636i012", "Match.__dict__.__contains__",   ["groups"],     true]
    - ["re1636i013", "Match.__dict__.__contains__",   ["start"],      true]
    - ["re1636i014", "Match.__dict__.__contains__",   ["end"],        true]
    - ["re1636i015", "Match.__dict__.__contains__",   ["span"],       true]
    - ["re1636i016", "Match.__dict__.__contains__",   ["expand"],     true]
    - ["re1636i017", "Match.__dict__.__contains__",   ["groupdict"],  true]
    - ["re1636i018", "RegexFlag.__dict__.__contains__", ["IGNORECASE"], true]
    - ["re1636i019", "RegexFlag.__dict__.__contains__", ["UNICODE"],    true]
    - ["re1636i020", "RegexFlag.__dict__.__contains__", ["MULTILINE"],  true]

# ---------------------------------------------------------------------------
# Table 3: RegexFlag hierarchy — IntFlag/int chain, and re class hierarchy.
#
# re.RegexFlag.__bases__[0].__name__ == "IntFlag"
# re.RegexFlag.__mro__: RegexFlag -> IntFlag -> int -> ReprEnum -> Flag -> Enum -> object
# re.error.__bases__[0].__name__ == "Exception"
# re.Pattern.__bases__[0].__name__ == "object"
# re.Match.__bases__[0].__name__   == "object"
#
# RegexFlag flag values (all stable across Python 3.9+):
# IGNORECASE == 2, MULTILINE == 8, DOTALL == 16, VERBOSE == 64, UNICODE == 32
# ---------------------------------------------------------------------------

table re_extra1636.regexflag_hierarchy:
  description: "re class hierarchy and RegexFlag inheritance via __bases__ and __mro__ inspection"
  kind: python_call_eq
  category: issubclass
  id_prefix: re1636s

  columns: [id, function, args, method, expected]
  rows:
    - ["re1636s001", "Pattern.__bases__.__getitem__",     [0], __name__, "object"]
    - ["re1636s002", "Match.__bases__.__getitem__",       [0], __name__, "object"]
    - ["re1636s003", "error.__bases__.__getitem__",       [0], __name__, "Exception"]
    - ["re1636s004", "RegexFlag.__bases__.__getitem__",   [0], __name__, "IntFlag"]
    - ["re1636s005", "Pattern.__mro__.__getitem__",       [0], __name__, "Pattern"]
    - ["re1636s006", "Pattern.__mro__.__getitem__",       [1], __name__, "object"]
    - ["re1636s007", "Match.__mro__.__getitem__",         [0], __name__, "Match"]
    - ["re1636s008", "Match.__mro__.__getitem__",         [1], __name__, "object"]
    - ["re1636s009", "error.__mro__.__getitem__",         [1], __name__, "Exception"]
    - ["re1636s010", "error.__mro__.__getitem__",         [2], __name__, "BaseException"]
    - ["re1636s011", "RegexFlag.__mro__.__getitem__",     [0], __name__, "RegexFlag"]
    - ["re1636s012", "RegexFlag.__mro__.__getitem__",     [1], __name__, "IntFlag"]
    - ["re1636s013", "RegexFlag.__mro__.__getitem__",     [2], __name__, "int"]
    - ["re1636s014", "Pattern.__name__.__eq__",           ["Pattern"],   null, true]
    - ["re1636s015", "Match.__name__.__eq__",             ["Match"],     null, true]
    - ["re1636s016", "RegexFlag.__name__.__eq__",         ["RegexFlag"], null, true]
    - ["re1636s017", "error.__module__.__eq__",           ["re"],        null, true]
    - ["re1636s018", "Pattern.__module__.__eq__",         ["re"],        null, true]
    - ["re1636s019", "Match.__module__.__eq__",           ["re"],        null, true]
    - ["re1636s020", "RegexFlag.__module__.__eq__",       ["re"],        null, true]
    - ["re1636s021", "IGNORECASE.__eq__",                 [2],           null, true]
    - ["re1636s022", "UNICODE.__eq__",                    [32],          null, true]
    - ["re1636s023", "MULTILINE.__eq__",                  [8],           null, true]
    - ["re1636s024", "DOTALL.__eq__",                     [16],          null, true]
    - ["re1636s025", "VERBOSE.__eq__",                    [64],          null, true]
