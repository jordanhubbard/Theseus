spec: re_extra2836
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/re_extra2821.zspec.zsdl — wave 635 predecessor (covered __radd__, __rsub__, __rmul__)"
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "Wave 636 theme: __rtruediv__, __rfloordiv__, and __rmod__ dict-presence checks (reflected true division, floor division, modulo operators)."
    - "re.Pattern and re.Match are regex engine objects, not numeric types — none define reflected division or modulo operators."
    - "re.Pattern (type(re.compile(''))) does NOT define __rtruediv__, __rfloordiv__, or __rmod__ in its __dict__."
    - "re.Match (type(re.match('', ''))) does NOT define __rtruediv__, __rfloordiv__, or __rmod__ in its __dict__."
    - "Absence is uniform across both re result types."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __rtruediv__ dict-presence — absent from re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2836.rtruediv_protocol:
  description: "__rtruediv__ is absent from re.Pattern.__dict__ and re.Match.__dict__ — regex objects have no division semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2836

  columns: [id, function, args, expected]
  rows:
    - ["re2836001", "re.Pattern.__dict__.__contains__", ["__rtruediv__"], false]
    - ["re2836002", "re.Match.__dict__.__contains__",   ["__rtruediv__"], false]

# ---------------------------------------------------------------------------
# Table: __rfloordiv__ dict-presence — absent from re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2836.rfloordiv_protocol:
  description: "__rfloordiv__ is absent from re.Pattern.__dict__ and re.Match.__dict__ — regex objects have no floor division semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2836

  columns: [id, function, args, expected]
  rows:
    - ["re2836003", "re.Pattern.__dict__.__contains__", ["__rfloordiv__"], false]
    - ["re2836004", "re.Match.__dict__.__contains__",   ["__rfloordiv__"], false]

# ---------------------------------------------------------------------------
# Table: __rmod__ dict-presence — absent from re.Pattern and re.Match
# ---------------------------------------------------------------------------

table re_extra2836.rmod_protocol:
  description: "__rmod__ is absent from re.Pattern.__dict__ and re.Match.__dict__ — regex objects have no modulo semantics"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2836

  columns: [id, function, args, expected]
  rows:
    - ["re2836005", "re.Pattern.__dict__.__contains__", ["__rmod__"], false]
    - ["re2836006", "re.Match.__dict__.__contains__",   ["__rmod__"], false]

# ---------------------------------------------------------------------------
# Table: all three reflected ops — combined view for both re types
# Confirms that neither Pattern nor Match defines any reflected division/modulo protocol
# ---------------------------------------------------------------------------

table re_extra2836.reflected_ops_summary:
  description: "All three reflected division/modulo operators absent from both re.Pattern and re.Match __dict__s"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2836

  columns: [id, function, args, expected]
  rows:
    - ["re2836007", "re.Pattern.__dict__.__contains__", ["__rtruediv__"],  false]
    - ["re2836008", "re.Pattern.__dict__.__contains__", ["__rfloordiv__"], false]
    - ["re2836009", "re.Pattern.__dict__.__contains__", ["__rmod__"],      false]
    - ["re2836010", "re.Match.__dict__.__contains__",   ["__rtruediv__"],  false]
    - ["re2836011", "re.Match.__dict__.__contains__",   ["__rfloordiv__"], false]
    - ["re2836012", "re.Match.__dict__.__contains__",   ["__rmod__"],      false]
