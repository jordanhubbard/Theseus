spec: fnmatch_extra
version: ">=3.2"
backend: python_module(fnmatch)

docs: https://docs.python.org/3/library/fnmatch.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/fnmatch.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "fnmatch source: Lib/fnmatch.py (PSF; source inspection permitted)"
  not_derived_from:
    - "fnmatch source: internal implementation details"
  notes:
    - "This spec extends fnmatch.zspec.zsdl with invariants not covered there: module membership, class type checks, function kind checks, filter() on overlapping extensions, and fnmatchcase edge cases for mixed case and bracket patterns."
    - "fnmatch.fnmatch.__module__ == 'fnmatch', fnmatch.filter.__module__ == 'fnmatch', fnmatch.translate.__module__ == 'fnmatch'."
    - "fnmatch and fnmatchcase are plain Python functions (class 'function'), not builtins."
    - "filter() returns a list; translate() returns a str."
    - "fnmatch('[abc]', '[abc]') == True — a literal bracket pattern matches when the name itself contains the character."
    - "fnmatchcase is always case-sensitive; fnmatch('A.PY', '*.py') is True on case-insensitive filesystems (macOS) but the harness runs case-sensitively via fnmatchcase semantics when the platform is POSIX."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module membership checks
# ---------------------------------------------------------------------------

table fnmatch_extra.module_checks:
  kind: python_call_eq
  category: modules
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [fnmatch_module,      fnmatch.__module__.__eq__,      ["fnmatch"], true]
    - [fnmatchcase_module,  fnmatchcase.__module__.__eq__,  ["fnmatch"], true]
    - [filter_module,       filter.__module__.__eq__,       ["fnmatch"], true]
    - [translate_module,    translate.__module__.__eq__,    ["fnmatch"], true]

# ---------------------------------------------------------------------------
# Function kind checks — all four public names are plain functions
# ---------------------------------------------------------------------------

table fnmatch_extra.function_kind_checks:
  kind: python_call_eq
  category: functions
  id_prefix: fkind

  columns: [id, function, args, expected]
  rows:
    - [fnmatch_is_fn,     fnmatch.__class__.__name__.__eq__,     ["function"], true]
    - [fnmatchcase_is_fn, fnmatchcase.__class__.__name__.__eq__, ["function"], true]
    - [filter_is_fn,      filter.__class__.__name__.__eq__,      ["function"], true]
    - [translate_is_fn,   translate.__class__.__name__.__eq__,   ["function"], true]

# ---------------------------------------------------------------------------
# filter() — return type is always list
# ---------------------------------------------------------------------------

invariant fnmatch_extra.filter_returns_list:
  description: "fnmatch.filter(['a.py', 'b.txt'], '*.py').__class__.__name__ == 'list'"
  category: filter
  kind: python_call_eq
  function: filter(["a.py", "b.txt"], "*.py").__class__.__name__.__eq__
  args: ["list"]
  expected: true

# ---------------------------------------------------------------------------
# filter() — overlapping extension patterns
# ---------------------------------------------------------------------------

table fnmatch_extra.filter.overlap:
  kind: python_call_eq
  function: filter
  id_prefix: overlap
  category: filter

  columns: [id, description, args, expected]
  rows:
    - [tar_gz,    "filter selects .tar.gz from mixed list",  [["a.tar.gz", "b.zip", "c.tar.gz", "d.tar"], "*.tar.gz"],  ["a.tar.gz", "c.tar.gz"]]
    - [dotfiles,  "filter selects .* hidden files",          [[".bashrc", ".profile", "README", ".env"],  ".*"],         [".bashrc", ".profile", ".env"]]
    - [all_match, "filter with * matches everything",        [["x", "y", "z"], "*"],                                    ["x", "y", "z"]]

# ---------------------------------------------------------------------------
# translate() — return type is always str
# ---------------------------------------------------------------------------

invariant fnmatch_extra.translate_returns_str:
  description: "fnmatch.translate('*.py').__class__.__name__ == 'str'"
  category: translate
  kind: python_call_eq
  function: translate("*.py").__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# fnmatchcase — bracket pattern edge cases
# ---------------------------------------------------------------------------

table fnmatch_extra.fnmatchcase.brackets:
  kind: python_call_eq
  function: fnmatchcase
  id_prefix: bracket
  category: charclass

  columns: [id, description, args, expected]
  rows:
    - [digit_match,   "fnmatchcase('file1.txt', 'file[0-9].txt') == True",            ["file1.txt",  "file[0-9].txt"], true]
    - [digit_nomatch, "fnmatchcase('filea.txt', 'file[0-9].txt') == False",           ["filea.txt",  "file[0-9].txt"], false]
    - [negate_match,  "fnmatchcase('filex.txt', 'file[!0-9].txt') == True — negation", ["filex.txt", "file[!0-9].txt"], true]
    - [negate_no,     "fnmatchcase('file5.txt', 'file[!0-9].txt') == False — negated", ["file5.txt", "file[!0-9].txt"], false]

# ---------------------------------------------------------------------------
# fnmatch — pattern with multiple wildcards
# ---------------------------------------------------------------------------

table fnmatch_extra.fnmatch.compound:
  kind: python_call_eq
  function: fnmatch
  id_prefix: compound
  category: compound

  columns: [id, description, args, expected]
  rows:
    - [star_q_ext,    "fnmatch('test1.py', 'test?.py') == True",                  ["test1.py",  "test?.py"],    true]
    - [multi_star,    "fnmatch('a/b/c.py', '*/*.py') == False — * stops at sep?", ["a/b/c.py",  "*/*.py"],      false]
    - [hidden_py,     "fnmatch('.hidden.py', '.*.py') == True",                   [".hidden.py", ".*.py"],      true]
    - [no_dot_star,   "fnmatch('README', '[!.]*') == True — name without dot",    ["README",    "[!.]*"],       true]
