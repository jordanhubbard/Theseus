spec: inspect_extra1621
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "Python docs"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __weakref__ and weak reference protocol"
    - "inspect.BoundArguments defines __slots__ = ('arguments', '_signature', '__weakref__'); the __weakref__ slot creates a weakref_descriptor in BoundArguments.__dict__, enabling weak references to instances"
    - "inspect.Parameter defines __slots__ = ('_name', '_kind', '_default', '_annotation'); __weakref__ is NOT in its slots; Parameter instances cannot be weakly referenced"
    - "inspect.Signature defines __slots__ = ('_return_annotation', '_parameters'); __weakref__ is NOT in its slots; Signature instances cannot be weakly referenced"
    - "inspect._ParameterKind is an IntEnum subclass; it does NOT define __slots__ and therefore has no __weakref__ key in its own __dict__ (IntEnum machinery suppresses the descriptor)"
    - "A class that defines __slots__ without including '__weakref__' blocks weak reference support entirely — instances will raise TypeError when passed to weakref.ref()"
    - "weakref.ref(inspect.BoundArguments(inspect.signature(lambda: None), {})) succeeds and returns a weakref object"
    - "weakref.ref(inspect.Parameter('x', inspect.Parameter.POSITIONAL_OR_KEYWORD)) raises TypeError: cannot create weak reference to 'Parameter' object"
  created_at: "2026-04-12"
error_model: python_exceptions

table inspect_extra1621.boundsargs_has_weakref:
  description: "inspect.BoundArguments includes '__weakref__' in its __slots__; the weakref_descriptor is present in BoundArguments.__dict__, enabling instance weak referencing"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1621ba

  columns: [id, function, args, expected]
  rows:
    - ["in1621ba001", "inspect.BoundArguments.__dict__.__contains__", ["__weakref__"],   true]
    - ["in1621ba002", "inspect.BoundArguments.__dict__.__contains__", ["__slots__"],     true]
    - ["in1621ba003", "inspect.BoundArguments.__dict__.__contains__", ["arguments"],     true]
    - ["in1621ba004", "inspect.BoundArguments.__dict__.__contains__", ["_signature"],    true]
    - ["in1621ba005", "inspect.BoundArguments.__dict__.__contains__", ["__dict__"],      false]
    - ["in1621ba006", "inspect.BoundArguments.__dict__.__contains__", ["signature"],     true]
    - ["in1621ba007", "inspect.BoundArguments.__dict__.__contains__", ["args"],          true]
    - ["in1621ba008", "inspect.BoundArguments.__dict__.__contains__", ["kwargs"],        true]
    - ["in1621ba009", "inspect.BoundArguments.__dict__.__contains__", ["apply_defaults"], true]
    - ["in1621ba010", "inspect.BoundArguments.__dict__.__contains__", ["__init__"],      true]
    - ["in1621ba011", "inspect.BoundArguments.__dict__.__contains__", ["__eq__"],        true]
    - ["in1621ba012", "inspect.BoundArguments.__dict__.__contains__", ["__repr__"],      true]
    - ["in1621ba013", "inspect.BoundArguments.__dict__.__contains__", ["__hash__"],      true]
    - ["in1621ba014", "inspect.BoundArguments.__dict__.__contains__", ["__iter__"],      false]
    - ["in1621ba015", "inspect.BoundArguments.__dict__.__contains__", ["__next__"],      false]
    - ["in1621ba016", "inspect.BoundArguments.__dict__.__contains__", ["__get__"],       false]
    - ["in1621ba017", "inspect.BoundArguments.__dict__.__contains__", ["__call__"],      false]
    - ["in1621ba018", "inspect.BoundArguments.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["in1621ba019", "inspect.BoundArguments.__name__.__eq__",   ["BoundArguments"],  true]
    - ["in1621ba020", "inspect.BoundArguments.__module__.__eq__", ["inspect"],          true]
    - ["in1621ba021", "inspect.BoundArguments.__class__.__name__.__eq__", ["type"],     true]
    - ["in1621ba022", "inspect.BoundArguments.__bases__.__len__", [],                   1]
    - ["in1621ba023", "inspect.BoundArguments.__dict__.__contains__", ["__getstate__"], true]
    - ["in1621ba024", "inspect.BoundArguments.__dict__.__contains__", ["__setstate__"], true]
    - ["in1621ba025", "inspect.BoundArguments.__dict__.__contains__", ["__set__"],      false]

table inspect_extra1621.parameter_no_weakref:
  description: "inspect.Parameter and Signature define __slots__ without '__weakref__'; both classes lack a weakref_descriptor in their __dict__; instances of either class cannot be weakly referenced"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in1621pn

  columns: [id, function, args, expected]
  rows:
    - ["in1621pn001", "inspect.Parameter.__dict__.__contains__", ["__weakref__"],          false]
    - ["in1621pn002", "inspect.Parameter.__dict__.__contains__", ["__slots__"],            true]
    - ["in1621pn003", "inspect.Parameter.__dict__.__contains__", ["_name"],                true]
    - ["in1621pn004", "inspect.Parameter.__dict__.__contains__", ["_kind"],                true]
    - ["in1621pn005", "inspect.Parameter.__dict__.__contains__", ["_default"],             true]
    - ["in1621pn006", "inspect.Parameter.__dict__.__contains__", ["_annotation"],          true]
    - ["in1621pn007", "inspect.Parameter.__dict__.__contains__", ["__dict__"],             false]
    - ["in1621pn008", "inspect.Parameter.__dict__.__contains__", ["name"],                 true]
    - ["in1621pn009", "inspect.Parameter.__dict__.__contains__", ["kind"],                 true]
    - ["in1621pn010", "inspect.Parameter.__dict__.__contains__", ["default"],              true]
    - ["in1621pn011", "inspect.Parameter.__dict__.__contains__", ["annotation"],           true]
    - ["in1621pn012", "inspect.Parameter.__dict__.__contains__", ["empty"],                true]
    - ["in1621pn013", "inspect.Parameter.__dict__.__contains__", ["replace"],              true]
    - ["in1621pn014", "inspect.Parameter.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["in1621pn015", "inspect.Parameter.__name__.__eq__",   ["Parameter"],               true]
    - ["in1621pn016", "inspect.Parameter.__module__.__eq__", ["inspect"],                  true]
    - ["in1621pn017", "inspect.Signature.__dict__.__contains__", ["__weakref__"],          false]
    - ["in1621pn018", "inspect.Signature.__dict__.__contains__", ["__slots__"],            true]
    - ["in1621pn019", "inspect.Signature.__dict__.__contains__", ["_parameters"],          true]
    - ["in1621pn020", "inspect.Signature.__dict__.__contains__", ["_return_annotation"],   true]
    - ["in1621pn021", "inspect.Signature.__dict__.__contains__", ["__dict__"],             false]
    - ["in1621pn022", "inspect.Signature.__dict__.__contains__", ["parameters"],           true]
    - ["in1621pn023", "inspect.Signature.__dict__.__contains__", ["return_annotation"],    true]
    - ["in1621pn024", "inspect.Signature.__dict__.__contains__", ["bind"],                 true]
    - ["in1621pn025", "inspect.Signature.__dict__.__contains__", ["bind_partial"],         true]
    - ["in1621pn026", "inspect.Signature.__dict__.__class__.__name__.__eq__", ["mappingproxy"], true]
    - ["in1621pn027", "inspect.Signature.__name__.__eq__",   ["Signature"],               true]
    - ["in1621pn028", "inspect.Signature.__module__.__eq__", ["inspect"],                  true]
    - ["in1621pn029", "inspect._ParameterKind.__dict__.__contains__", ["__weakref__"],     false]
    - ["in1621pn030", "inspect._ParameterKind.__dict__.__contains__", ["__slots__"],       false]

table inspect_extra1621.weakref_raises:
  description: "weakref.ref() on inspect.Parameter and inspect.Signature instances raises TypeError because those classes define __slots__ without __weakref__; the error confirms they have no weak reference support"
  kind: python_call_raises
  category: dict_contains
  id_prefix: in1621wr

  columns: [id, function, args, raises]
  rows:
    - ["in1621wr001", "weakref.ref", ["inspect.Parameter('x', inspect.Parameter.POSITIONAL_OR_KEYWORD)"],                                    "TypeError"]
    - ["in1621wr002", "weakref.ref", ["inspect.Parameter('y', inspect.Parameter.KEYWORD_ONLY)"],                                             "TypeError"]
    - ["in1621wr003", "weakref.ref", ["inspect.Parameter('z', inspect.Parameter.POSITIONAL_ONLY)"],                                          "TypeError"]
    - ["in1621wr004", "weakref.ref", ["inspect.Parameter('args', inspect.Parameter.VAR_POSITIONAL)"],                                        "TypeError"]
    - ["in1621wr005", "weakref.ref", ["inspect.Parameter('kwargs', inspect.Parameter.VAR_KEYWORD)"],                                         "TypeError"]
    - ["in1621wr006", "weakref.ref", ["inspect.Signature()"],                                                                                "TypeError"]
    - ["in1621wr007", "weakref.ref", ["inspect.Signature([inspect.Parameter('x', inspect.Parameter.POSITIONAL_OR_KEYWORD)])"],                "TypeError"]
