spec: asyncio_extra901
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio primitives __module__ identity for Task, Future, Queue, Lock, Event, Semaphore, Condition"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra901.task_future_modules:
  description: "asyncio.Task and asyncio.Future __module__ identity"
  kind: python_call_eq
  category: task_future_modules
  id_prefix: as901tf
  columns: [id, function, args, expected]
  rows:
    - [as901tf001, asyncio.Task.__module__.__eq__,             ["asyncio.tasks"],   true]
    - [as901tf002, asyncio.Future.__module__.__eq__,           ["asyncio.futures"], true]
    - [as901tf003, asyncio.Task.__name__.__eq__,               ["Task"],            true]
    - [as901tf004, asyncio.Future.__name__.__eq__,             ["Future"],          true]
    - [as901tf005, asyncio.Task.__qualname__.__eq__,           ["Task"],            true]
    - [as901tf006, asyncio.Future.__qualname__.__eq__,         ["Future"],          true]

table asyncio_extra901.queue_lock_modules:
  description: "asyncio.Queue and asyncio.Lock __module__ identity"
  kind: python_call_eq
  category: queue_lock_modules
  id_prefix: as901ql
  columns: [id, function, args, expected]
  rows:
    - [as901ql001, asyncio.Queue.__module__.__eq__,            ["asyncio.queues"],  true]
    - [as901ql002, asyncio.Lock.__module__.__eq__,             ["asyncio.locks"],   true]
    - [as901ql003, asyncio.Queue.__name__.__eq__,              ["Queue"],           true]
    - [as901ql004, asyncio.Lock.__name__.__eq__,               ["Lock"],            true]
    - [as901ql005, asyncio.Queue.__qualname__.__eq__,          ["Queue"],           true]
    - [as901ql006, asyncio.Lock.__qualname__.__eq__,           ["Lock"],            true]

table asyncio_extra901.event_semaphore_condition_modules:
  description: "asyncio.Event, asyncio.Semaphore, and asyncio.Condition __module__ identity"
  kind: python_call_eq
  category: event_semaphore_condition_modules
  id_prefix: as901esc
  columns: [id, function, args, expected]
  rows:
    - [as901esc001, asyncio.Event.__module__.__eq__,           ["asyncio.locks"],   true]
    - [as901esc002, asyncio.Semaphore.__module__.__eq__,       ["asyncio.locks"],   true]
    - [as901esc003, asyncio.Condition.__module__.__eq__,       ["asyncio.locks"],   true]
    - [as901esc004, asyncio.Event.__name__.__eq__,             ["Event"],           true]
    - [as901esc005, asyncio.Semaphore.__name__.__eq__,         ["Semaphore"],       true]
    - [as901esc006, asyncio.Condition.__name__.__eq__,         ["Condition"],       true]
    - [as901esc007, asyncio.Event.__qualname__.__eq__,         ["Event"],           true]
