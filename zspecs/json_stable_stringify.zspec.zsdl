spec: json_stable_stringify
version: ">=1.0.0"
backend: node(json-stable-stringify)

docs: https://www.npmjs.com/package/json-stable-stringify

provenance:
  derived_from:
    - "json-stable-stringify README — https://www.npmjs.com/package/json-stable-stringify"
    - "Test vectors verified with json-stable-stringify via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "json-stable-stringify source"
  notes:
    - "json-stable-stringify is an npm package. Install: npm install json-stable-stringify"
    - "stringify(obj) serializes a JavaScript value with object keys sorted alphabetically."
    - "Unlike JSON.stringify, key order is deterministic — useful for hashing/signatures."
    - "Array elements are not sorted; only object keys are ordered."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns JSON string with sorted object keys."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table json_stable_stringify.stringify:
  kind: node_module_call_eq
  function: ~
  category: stringify
  id_prefix: jss

  columns: [id, args, expected]
  rows:
    - [sorted,   [{"b": 1, "a": 2}],                       '{"a":2,"b":1}']
    - [nested,   [{"z": [1, 2], "a": {"b": 1}}],            '{"a":{"b":1},"z":[1,2]}']
    - [array,    [["c", "a", "b"]],                         '["c","a","b"]']
    - [null_val, [{"a": null}],                             '{"a":null}']
    - [number,   [42],                                      '42']
