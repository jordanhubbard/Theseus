spec: multiprocessing_extra127
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/managers.py"
  notes:
    - "This spec covers: wave 255 theme — multiprocessing.managers module class identity (SyncManager, BaseManager). NEW in extra127: multiprocessing.managers.BaseManager.__name__=='BaseManager' (len=11); multiprocessing.managers.BaseManager.__module__=='multiprocessing.managers'; multiprocessing.managers.BaseManager.__mro__.__len__()==2 (MRO=[BaseManager, object]); multiprocessing.managers.BaseManager.__bases__[0].__name__=='object'; multiprocessing.managers.SyncManager.__name__=='SyncManager' (len=11); multiprocessing.managers.SyncManager.__module__=='multiprocessing.managers'; multiprocessing.managers.SyncManager.__bases__[0].__name__=='BaseManager'; multiprocessing.managers.SyncManager.__mro__.__len__()==3 (MRO=[SyncManager, BaseManager, object]); BaseManager.__class__.__name__=='type'; SyncManager.__class__.__name__=='type'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.managers.BaseManager.__mro__.__len__() == 2. BaseManager's MRO is [BaseManager, object] (depth=2) — BaseManager inherits directly from object with no intermediate base; this is the same minimal depth as asyncio.Future and concurrent.futures.Future. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.managers.SyncManager.__mro__.__len__() == 3. SyncManager's MRO is [SyncManager, BaseManager, object] (depth=3) — SyncManager adds one level over BaseManager; SyncManager provides synchronized proxies for common Python objects (list, dict, Queue, Lock, etc.). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Both BaseManager and SyncManager have __name__.__len__() == 11. 'BaseManager' and 'SyncManager' both have 11 characters ('Base'=4+'Manager'=7 and 'Sync'=4+'Manager'=7). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.managers.BaseManager class identity — extra127
#
# Wave 255 theme: multiprocessing.managers.BaseManager class identity.
#
# BaseManager.__name__              == 'BaseManager'                (len=11)
# BaseManager.__module__            == 'multiprocessing.managers'
# BaseManager.__mro__.__len__()     == 2   [BaseManager, object]
# BaseManager.__bases__[0].__name__ == 'object'
# BaseManager.__class__.__name__    == 'type'
# BaseManager.__qualname__          == 'BaseManager'               (len=11)
# ---------------------------------------------------------------------------

table multiprocessing_extra127.mp_managers_basemanager_identity:
  description: "multiprocessing.managers.BaseManager class identity checks in mpmanagers127 namespace — wave 255 theme: multiprocessing.managers.BaseManager is a pure-Python class defined in Lib/multiprocessing/managers.py; it is the base class for all manager types and provides the start() and connect() machinery for running a manager server in a separate process; BaseManager.__name__.__eq__('BaseManager')==True (len=11: 'Base'=4 + 'Manager'=7); BaseManager.__module__.__eq__('multiprocessing.managers')==True (defined in the managers submodule); BaseManager.__bases__[0].__name__.__eq__('object')==True (BaseManager inherits directly from object, making it a depth-2 MRO); BaseManager.__mro__.__len__()==2 (MRO=[BaseManager, object], minimal depth — same as asyncio.Future and concurrent.futures.Future); BaseManager.__class__.__name__.__eq__('type')==True (it is a class, metaclass is type); BaseManager.__qualname__.__eq__('BaseManager')==True (len=11, module-level class so qualname equals name); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanagers127

  columns: [id, function, args, expected, description]
  rows:
    - [bm_name,      "multiprocessing.managers.BaseManager.__name__.__eq__",              ["BaseManager"],                 true, "multiprocessing.managers.BaseManager.__name__ == 'BaseManager' (len=11); verified with Python 3.14.3"]
    - [bm_namelen,   "multiprocessing.managers.BaseManager.__name__.__len__",             [],                              11,   "multiprocessing.managers.BaseManager.__name__.__len__() == 11 ('Base'=4+'Manager'=7); verified with Python 3.14.3"]
    - [bm_module,    "multiprocessing.managers.BaseManager.__module__.__eq__",            ["multiprocessing.managers"],    true, "multiprocessing.managers.BaseManager.__module__ == 'multiprocessing.managers'; verified with Python 3.14.3"]
    - [bm_base0,     "multiprocessing.managers.BaseManager.__bases__[0].__name__.__eq__", ["object"],                      true, "multiprocessing.managers.BaseManager.__bases__[0].__name__ == 'object' — inherits directly from object; verified with Python 3.14.3"]
    - [bm_mro_len,   "multiprocessing.managers.BaseManager.__mro__.__len__",              [],                              2,    "multiprocessing.managers.BaseManager.__mro__.__len__() == 2 — MRO=[BaseManager, object]; verified with Python 3.14.3"]
    - [bm_class_nm,  "multiprocessing.managers.BaseManager.__class__.__name__.__eq__",   ["type"],                        true, "multiprocessing.managers.BaseManager.__class__.__name__ == 'type' — genuine Python class; verified with Python 3.14.3"]
    - [bm_qn_eq,     "multiprocessing.managers.BaseManager.__qualname__.__eq__",         ["BaseManager"],                 true, "multiprocessing.managers.BaseManager.__qualname__ == 'BaseManager' (len=11, module-level class); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
