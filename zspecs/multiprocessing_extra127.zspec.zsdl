# SyncManager.__module__            == 'multiprocessing.managers'
# SyncManager.__bases__[0].__name__ == 'BaseManager'
# SyncManager.__mro__.__len__()     == 3   [SyncManager, BaseManager, object]
# SyncManager.__class__.__name__    == 'type'
# SyncManager.__qualname__          == 'SyncManager'               (len=11)
# ---------------------------------------------------------------------------

table multiprocessing_extra127.mp_managers_syncmanager_identity:
  description: "multiprocessing.managers.SyncManager class identity checks in mpmanagers127 namespace — wave 255 theme: multiprocessing.managers.SyncManager is a pure-Python class defined in Lib/multiprocessing/managers.py; SyncManager extends BaseManager with pre-registered proxies for synchronized objects (list, dict, Queue, Lock, Event, Semaphore, BoundedSemaphore, Condition, Barrier, Namespace, Value, Array); SyncManager.__name__.__eq__('SyncManager')==True (len=11: 'Sync'=4 + 'Manager'=7 — same length as BaseManager.__name__.__len__()==11); SyncManager.__module__.__eq__('multiprocessing.managers')==True (same submodule as BaseManager); SyncManager.__bases__[0].__name__.__eq__('BaseManager')==True (SyncManager inherits from BaseManager, adding its synchronized proxy registrations); SyncManager.__mro__.__len__()==3 (MRO=[SyncManager, BaseManager, object], depth=3 — one deeper than BaseManager's depth-2 MRO); SyncManager.__class__.__name__.__eq__('type')==True; SyncManager.__qualname__.__eq__('SyncManager')==True (len=11, module-level class); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanagers127a

  columns: [id, function, args, expected, description]
  rows:
    - [sm_name,      "multiprocessing.managers.SyncManager.__name__.__eq__",              ["SyncManager"],                 true, "multiprocessing.managers.SyncManager.__name__ == 'SyncManager' (len=11); verified with Python 3.14.3"]
    - [sm_namelen,   "multiprocessing.managers.SyncManager.__name__.__len__",             [],                              11,   "multiprocessing.managers.SyncManager.__name__.__len__() == 11 ('Sync'=4+'Manager'=7, same len as BaseManager); verified with Python 3.14.3"]
    - [sm_module,    "multiprocessing.managers.SyncManager.__module__.__eq__",            ["multiprocessing.managers"],    true, "multiprocessing.managers.SyncManager.__module__ == 'multiprocessing.managers'; verified with Python 3.14.3"]
    - [sm_base0,     "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__", ["BaseManager"],                 true, "multiprocessing.managers.SyncManager.__bases__[0].__name__ == 'BaseManager'; verified with Python 3.14.3"]
    - [sm_mro_len,   "multiprocessing.managers.SyncManager.__mro__.__len__",              [],                              3,    "multiprocessing.managers.SyncManager.__mro__.__len__() == 3 — MRO=[SyncManager, BaseManager, object]; verified with Python 3.14.3"]
    - [sm_class_nm,  "multiprocessing.managers.SyncManager.__class__.__name__.__eq__",   ["type"],                        true, "multiprocessing.managers.SyncManager.__class__.__name__ == 'type'; verified with Python 3.14.3"]
    - [sm_qn_eq,     "multiprocessing.managers.SyncManager.__qualname__.__eq__",         ["SyncManager"],                 true, "multiprocessing.managers.SyncManager.__qualname__ == 'SyncManager' (len=11, module-level class); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# BaseManager vs SyncManager comparison — extra127
#
# Wave 255 theme: contrasting the two manager classes by MRO depth.
#
# BaseManager.__mro__.__len__() == 2  (direct object subclass)
# SyncManager.__mro__.__len__() == 3  (one deeper via BaseManager)
# ---------------------------------------------------------------------------

table multiprocessing_extra127.mp_managers_mro_comparison:
  description: "multiprocessing.managers BaseManager vs SyncManager MRO depth and name length comparison in mpmanagers127 namespace — wave 255 theme: BaseManager and SyncManager share the same module ('multiprocessing.managers') and the same name length (11 chars each: 'BaseManager' and 'SyncManager' both have 4-char prefix + 7-char 'Manager' suffix); the key structural difference is MRO depth: BaseManager.__mro__.__len__()==2 (depth=2, direct object subclass, same minimal depth as asyncio.Future and concurrent.futures.Future) while SyncManager.__mro__.__len__()==3 (depth=3, inheriting from BaseManager); both have __class__.__name__=='type' (both are genuine Python classes); BaseManager.__bases__[0].__name__=='object'; SyncManager.__bases__[0].__name__=='BaseManager'; the equal name lengths (both 11 chars) despite different class roles reflect the consistent naming pattern 'XxxxxManager'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmanagers127b

  columns: [id, function, args, expected, description]
  rows:
    - [bm_mro2,    "multiprocessing.managers.BaseManager.__mro__.__len__",    [], 2,  "BaseManager.__mro__.__len__() == 2 (depth=2, direct object subclass); verified with Python 3.14.3"]
    - [sm_mro3,    "multiprocessing.managers.SyncManager.__mro__.__len__",    [], 3,  "SyncManager.__mro__.__len__() == 3 (depth=3, one deeper via BaseManager); verified with Python 3.14.3"]
    - [bm_nm11,    "multiprocessing.managers.BaseManager.__name__.__len__",   [], 11, "BaseManager.__name__.__len__() == 11 ('Base'=4+'Manager'=7); verified with Python 3.14.3"]
    - [sm_nm11,    "multiprocessing.managers.SyncManager.__name__.__len__",   [], 11, "SyncManager.__name__.__len__() == 11 ('Sync'=4+'Manager'=7, same as BaseManager); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra127
# ---------------------------------------------------------------------------

invariant multiprocessing_extra127.BaseManager_name_eq:
  description: "multiprocessing.managers.BaseManager.__name__.__eq__('BaseManager') returns True — BaseManager.__name__ is 'BaseManager' (len=11: 'Base'=4 + 'Manager'=7); BaseManager is the abstract base class for all manager types in multiprocessing.managers; it defines the start() method to launch a manager server process, connect() for client-side connections, and the register() classmethod to register shared objects; BaseManager.__module__ is 'multiprocessing.managers'; BaseManager.__bases__[0].__name__ is 'object' (direct object subclass); BaseManager.__mro__.__len__() is 2 (minimal depth); BaseManager.__class__.__name__ is 'type'; NEW in extra127: first standalone BaseManager name invariant in mpmanagers127 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.BaseManager.__name__.__eq__"
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra127.BaseManager_mro_len_is_2:
  description: "multiprocessing.managers.BaseManager.__mro__.__len__() == 2 — BaseManager's MRO is [BaseManager, object] (length=2); this minimal depth-2 chain is shared by other direct-object-subclass classes including asyncio.TaskGroup (depth=2), asyncio.Future (depth=2), concurrent.futures.Future (depth=2), and multiprocessing.pool.Pool (depth=2); BaseManager.__module__ is 'multiprocessing.managers'; BaseManager.__bases__[0].__name__ is 'object'; the minimal MRO means BaseManager defines all its manager server logic internally without inheriting from intermediate framework classes; SyncManager adds one level (depth=3) by inheriting from BaseManager; NEW in extra127: first standalone BaseManager MRO length invariant in mpmanagers127 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.BaseManager.__mro__.__len__"
  args: []
  expected: 2

invariant multiprocessing_extra127.SyncManager_base_is_BaseManager:
  description: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__('BaseManager') returns True — SyncManager inherits from BaseManager as its single direct base class; SyncManager extends BaseManager with pre-registered proxies for synchronized Python objects including: list, dict, Queue, JoinableQueue, Event, Lock, RLock, Semaphore, BoundedSemaphore, Condition, Barrier, Namespace, Value, and Array; SyncManager.__bases__[0].__name__ is 'BaseManager'; SyncManager.__mro__.__len__() is 3 (MRO=[SyncManager, BaseManager, object]); SyncManager.__module__ is 'multiprocessing.managers'; SyncManager.__name__.__len__() is 11 (same as BaseManager.__name__.__len__()==11); NEW in extra127: first standalone SyncManager base class invariant in mpmanagers127 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.SyncManager.__bases__[0].__name__.__eq__"
  args: ["BaseManager"]
  expected: true

invariant multiprocessing_extra127.SyncManager_mro_len_is_3:
  description: "multiprocessing.managers.SyncManager.__mro__.__len__() == 3 — SyncManager's MRO is [SyncManager, BaseManager, object] (length=3); this depth-3 chain is one deeper than BaseManager's depth-2 MRO because SyncManager inherits from BaseManager; depth-3 is also the same MRO depth as concurrent.futures.ProcessPoolExecutor (MRO=[ProcessPoolExecutor, Executor, object]) and multiprocessing.Process (MRO=[Process, BaseProcess, object]); SyncManager.__module__ is 'multiprocessing.managers'; SyncManager.__bases__[0].__name__ is 'BaseManager'; SyncManager.__name__.__len__() is 11; the depth-3 chain reflects SyncManager's role as the standard concrete manager implementation built on top of the abstract BaseManager; NEW in extra127: first standalone SyncManager MRO length invariant in mpmanagers127 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.SyncManager.__mro__.__len__"
  args: []
  expected: 3

invariant multiprocessing_extra127.BaseManager_module_eq:
  description: "multiprocessing.managers.BaseManager.__module__.__eq__('multiprocessing.managers') returns True — BaseManager is defined in Lib/multiprocessing/managers.py (module='multiprocessing.managers'); both BaseManager and SyncManager share the same module 'multiprocessing.managers' since they are both defined in the same file; this module name directly corresponds to the managers.py submodule of multiprocessing; contrast with multiprocessing.pool.Pool (module='multiprocessing.pool') and multiprocessing.Process (module='multiprocessing.context') which are in different submodules; BaseManager.__class__.__name__ is 'type'; BaseManager.__name__ is 'BaseManager'; NEW in extra127: first standalone BaseManager module invariant in mpmanagers127 namespace; wave 255; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.managers.BaseManager.__module__.__eq__"
  args: ["multiprocessing.managers"]
  expected: true
