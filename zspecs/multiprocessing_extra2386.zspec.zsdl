# ---------------------------------------------------------------------------
# Table 3: cross-class consistency — str/repr type patterns in multiprocessing
#
# Both Process and Pool share the same pattern: __str__ is 'wrapper_descriptor'
# and __repr__ is 'function'. These rows verify the __eq__ relationship
# between the two classes' descriptor name strings.
# ---------------------------------------------------------------------------

table multiprocessing_extra2386.cross_class_str_repr:
  description: "Cross-class consistency: Process and Pool share the same __str__/__repr__ type pattern; new to extra2386"
  kind: python_call_eq
  category: str_repr_type
  id_prefix: mp2386

  columns: [id, function, args, expected]
  rows:
    - ["mp2386015",
       Process.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["mp2386016",
       Pool.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["mp2386017",
       Process.__repr__.__class__.__name__.__eq__,
       ["function"],
       true]
    - ["mp2386018",
