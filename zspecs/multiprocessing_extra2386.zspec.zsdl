spec: multiprocessing_extra2386
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  notes:
    - "This spec classifies __str__ and __repr__ implementation types for multiprocessing classes."
    - "multiprocessing.Process defines a custom Python __repr__; __str__ is inherited from object."
    - "Process.__str__.__class__.__name__ == 'wrapper_descriptor' — inherited slot from object."
    - "Process.__repr__.__class__.__name__ == 'function' — custom Python method defined on Process."
    - "multiprocessing.pool.Pool defines a custom Python __repr__; __str__ is inherited from object."
    - "Pool.__str__.__class__.__name__ == 'wrapper_descriptor' — inherited slot from object."
    - "Pool.__repr__.__class__.__name__ == 'function' — custom Python method defined on Pool."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Process __str__ and __repr__ implementation type
#
# Process is a pure-Python class. __str__ is inherited from object
# ('wrapper_descriptor'). __repr__ is a custom Python method ('function').
# ---------------------------------------------------------------------------

table multiprocessing_extra2386.process_str_repr:
  description: "multiprocessing.Process __str__ and __repr__ implementation type classification; new to extra2386"
  kind: python_call_eq
  category: str_repr_type
  id_prefix: mp2386

  columns: [id, function, args, expected]
  rows:
    - ["mp2386001",
       Process.__str__.__class__.__name__.__eq__,
       ["wrapper_descriptor"],
       true]
    - ["mp2386002",
       Process.__repr__.__class__.__name__.__eq__,
       ["function"],
       true]
    - ["mp2386003",
       Process.__str__.__class__.__name__.__len__,
       [],
       18]
    - ["mp2386004",
       Process.__repr__.__class__.__name__.__len__,
       [],
       8]
    - ["mp2386005",
       Process.__str__.__class__.__name__.__contains__,
       ["wrapper"],
       true]
    - ["mp2386006",
       Process.__repr__.__class__.__name__.__contains__,
       ["function"],
       true]
    - ["mp2386007",
       Process.__str__.__class__.__name__.__contains__,
       ["descriptor"],
       true]
    - ["mp2386008",
       Process.__repr__.__class__.__name__.__contains__,
       ["func"],
       true]

