spec: threading_extra210
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
    - "threading_extra.zspec.zsdl — covers class modules (BoundedSemaphore/Condition/Semaphore/Event/RLock), local name/module, current_thread class name, get_ident type, TIMEOUT_MAX float, stack_size type"
    - "threading_extra172.zspec.zsdl — covers Thread.__dict__ property descriptors (daemon/name/ident/native_id), Thread.__dict__.__len__, TIMEOUT_MAX float/gt checks"
  notes:
    - "threading.current_thread.__annotations__.__class__.__name__ == 'dict' — current_thread is a Python function; its __annotations__ is an empty dict. Verified with Python 3.14.3."
    - "threading.Thread.__init__.__annotations__.__class__.__name__ == 'dict' — Thread.__init__ is a Python method; its __annotations__ is an empty dict. Verified with Python 3.14.3."
    - "threading.Lock.__dict__.__contains__('acquire') == True — Lock defines 'acquire' in its class dict. Verified with Python 3.14.3."
    - "threading.Lock.__dict__.__contains__('release') == True — Lock defines 'release' in its class dict. Verified with Python 3.14.3."
    - "threading.Condition.__dict__.__contains__('wait') == True — Condition defines 'wait' in its class dict. Verified with Python 3.14.3."
    - "threading.Condition.__dict__.__contains__('notify') == True — Condition defines 'notify' in its class dict. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __annotations__.__class__.__name__ for current_thread and
# Thread.__init__
#
# Both are Python-level callables whose __annotations__ is an empty dict.
#
# threading.current_thread.__annotations__.__class__.__name__  == 'dict'
# threading.Thread.__init__.__annotations__.__class__.__name__ == 'dict'
# ---------------------------------------------------------------------------

table threading_extra210.annotations_class_names:
  description: "threading current_thread/Thread.__init__ __annotations__.__class__.__name__ checks in threadannotations210 namespace — current_thread is a Python function whose __annotations__ is an empty dict (class 'dict'); Thread.__init__ is a Python method whose __annotations__ is also an empty dict; both lack type annotations on their parameters; __annotations__.__class__.__name__.__eq__('dict')==True for each; negative cross-checks confirm not 'list' or 'set'; verified with Python 3.14.3"
  kind: python_call_eq
  category: annotations
  id_prefix: threadannotations210

  columns: [id, function, args, expected, description]
  rows:
    - [current_thread_ann_cls,
       current_thread.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "threading.current_thread.__annotations__.__class__.__name__ == 'dict' — current_thread is a Python-defined function; its __annotations__ is an empty dict; __class__.__name__ is 'dict'; __eq__('dict') returns True; verified with Python 3.14.3"]
    - [thread_init_ann_cls,
       Thread.__init__.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "threading.Thread.__init__.__annotations__.__class__.__name__ == 'dict' — Thread.__init__ is a Python-defined method; its __annotations__ is an empty dict; __class__.__name__ is 'dict'; __eq__('dict') returns True; verified with Python 3.14.3"]
    - [current_thread_ann_not_list,
       current_thread.__annotations__.__class__.__name__.__eq__,
       ["list"],
       false,
       "threading.current_thread.__annotations__.__class__.__name__.__eq__('list') == False — __annotations__ is a dict, not a list; __eq__('list') returns False; negative cross-check; verified with Python 3.14.3"]
    - [thread_init_ann_not_set,
       Thread.__init__.__annotations__.__class__.__name__.__eq__,
       ["set"],
       false,
       "threading.Thread.__init__.__annotations__.__class__.__name__.__eq__('set') == False — __annotations__ is a dict, not a set; __eq__('set') returns False; negative cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: threading.Lock.__dict__ membership checks
#
# Lock defines 'acquire' and 'release' in its class dict.
#
# threading.Lock.__dict__.__contains__('acquire') == True
# threading.Lock.__dict__.__contains__('release') == True
# ---------------------------------------------------------------------------

table threading_extra210.lock_dict_contains:
  description: "threading.Lock.__dict__ membership checks in threadannotations210 namespace — Lock defines 'acquire' as a method for acquiring the lock; 'release' as a method for releasing the lock; both are present in Lock.__dict__; __dict__.__contains__('acquire')==True; __dict__.__contains__('release')==True; negative: Lock.__dict__ does not contain 'wait' (that is a Condition method); negative: Lock.__dict__ does not contain 'notify' (that is also a Condition method); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: threadannotations210l

  columns: [id, function, args, expected, description]
  rows:
    - [lock_dict_has_acquire,
       "Lock.__dict__.__contains__",
       ["acquire"],
       true,
       "threading.Lock.__dict__.__contains__('acquire') == True — Lock defines 'acquire' as a method in its class dict; acquire() blocks until the lock is available and sets the locked state; __contains__('acquire') returns True; verified with Python 3.14.3"]
    - [lock_dict_has_release,
       "Lock.__dict__.__contains__",
       ["release"],
       true,
       "threading.Lock.__dict__.__contains__('release') == True — Lock defines 'release' as a method in its class dict; release() releases the lock and resets the locked state; __contains__('release') returns True; verified with Python 3.14.3"]
    - [lock_dict_no_wait,
       "Lock.__dict__.__contains__",
       ["wait"],
       false,
       "threading.Lock.__dict__.__contains__('wait') == False — 'wait' is a Condition method, not a Lock method; Lock.__dict__ does not contain 'wait'; __contains__('wait') returns False; negative cross-check; verified with Python 3.14.3"]
    - [lock_dict_no_notify,
       "Lock.__dict__.__contains__",
       ["notify"],
       false,
       "threading.Lock.__dict__.__contains__('notify') == False — 'notify' is a Condition method, not a Lock method; Lock.__dict__ does not contain 'notify'; __contains__('notify') returns False; negative cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: threading.Condition.__dict__ membership checks
#
# Condition defines 'wait' and 'notify' in its class dict.
#
# threading.Condition.__dict__.__contains__('wait')   == True
# threading.Condition.__dict__.__contains__('notify') == True
# ---------------------------------------------------------------------------

table threading_extra210.condition_dict_contains:
  description: "threading.Condition.__dict__ membership checks in threadannotations210 namespace — Condition defines 'wait' as a method that releases the lock and blocks until notified; 'notify' as a method that wakes up one thread waiting on the condition; both are present in Condition.__dict__; __dict__.__contains__('wait')==True; __dict__.__contains__('notify')==True; negative: Condition.__dict__ does not contain 'acquire' (Condition delegates to the underlying lock via __enter__/__exit__); negative: Condition.__dict__ does not contain 'nonexistent'; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: threadannotations210c

  columns: [id, function, args, expected, description]
  rows:
    - [cond_dict_has_wait,
       "Condition.__dict__.__contains__",
       ["wait"],
       true,
       "threading.Condition.__dict__.__contains__('wait') == True — Condition defines 'wait' as a method in its class dict; wait() releases the underlying lock and blocks until another thread calls notify() or notify_all(); __contains__('wait') returns True; verified with Python 3.14.3"]
    - [cond_dict_has_notify,
       "Condition.__dict__.__contains__",
       ["notify"],
       true,
       "threading.Condition.__dict__.__contains__('notify') == True — Condition defines 'notify' as a method in its class dict; notify() wakes up one thread waiting on the condition variable; __contains__('notify') returns True; verified with Python 3.14.3"]
    - [cond_dict_no_nonexistent,
       "Condition.__dict__.__contains__",
       ["nonexistent"],
       false,
       "threading.Condition.__dict__.__contains__('nonexistent') == False — 'nonexistent' is not defined on Condition; __contains__('nonexistent') returns False; negative cross-check; verified with Python 3.14.3"]
    - [cond_dict_has_notify_all,
       "Condition.__dict__.__contains__",
       ["notify_all"],
       true,
       "threading.Condition.__dict__.__contains__('notify_all') == True — Condition defines 'notify_all' as a method in its class dict; notify_all() wakes up all threads waiting on the condition variable; __contains__('notify_all') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra210
# ---------------------------------------------------------------------------

invariant threading_extra210.current_thread_annotations_class_dict:
  description: "threading.current_thread.__annotations__.__class__.__name__ == 'dict' — current_thread is a Python-defined function; its __annotations__ attribute is an empty dict; __class__.__name__ is 'dict'; new to extra210; verified with Python 3.14.3"
  category: annotations
  kind: python_call_eq
  function: current_thread.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant threading_extra210.Thread_init_annotations_class_dict:
  description: "threading.Thread.__init__.__annotations__.__class__.__name__ == 'dict' — Thread.__init__ is a Python-defined method; its __annotations__ attribute is an empty dict; __class__.__name__ is 'dict'; new to extra210; verified with Python 3.14.3"
  category: annotations
  kind: python_call_eq
  function: Thread.__init__.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant threading_extra210.Lock_dict_has_acquire:
  description: "threading.Lock.__dict__.__contains__('acquire') == True — Lock defines 'acquire' as a method in its class dict; acquire() blocks until the lock is available; __contains__('acquire') returns True; new to extra210; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Lock.__dict__.__contains__"
  args: ["acquire"]
  expected: true

invariant threading_extra210.Lock_dict_has_release:
  description: "threading.Lock.__dict__.__contains__('release') == True — Lock defines 'release' as a method in its class dict; release() releases the lock; __contains__('release') returns True; new to extra210; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Lock.__dict__.__contains__"
  args: ["release"]
  expected: true

invariant threading_extra210.Condition_dict_has_wait:
  description: "threading.Condition.__dict__.__contains__('wait') == True — Condition defines 'wait' as a method in its class dict; wait() releases the lock and blocks until notified; __contains__('wait') returns True; new to extra210; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Condition.__dict__.__contains__"
  args: ["wait"]
  expected: true

invariant threading_extra210.Condition_dict_has_notify:
  description: "threading.Condition.__dict__.__contains__('notify') == True — Condition defines 'notify' as a method in its class dict; notify() wakes up one waiting thread; __contains__('notify') returns True; new to extra210; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Condition.__dict__.__contains__"
  args: ["notify"]
  expected: true

invariant threading_extra210.Lock_dict_no_wait:
  description: "threading.Lock.__dict__.__contains__('wait') == False — 'wait' is a Condition method, not a Lock method; Lock does not define 'wait' in its class dict; __contains__('wait') returns False; negative cross-check; new to extra210; verified with Python 3.14.3"
  category: dict_membership
  kind: python_call_eq
  function: "Lock.__dict__.__contains__"
  args: ["wait"]
  expected: false

invariant threading_extra210.current_thread_ann_not_none:
  description: "threading.current_thread.__annotations__.__class__.__name__ != 'NoneType' — __annotations__ is always a dict (never None) on Python functions; __eq__('NoneType') returns False; cross-check; new to extra210; verified with Python 3.14.3"
  category: annotations
  kind: python_call_eq
  function: current_thread.__annotations__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: false
