spec: io_extra281
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "io.IOBase, io.RawIOBase, io.BufferedIOBase, and io.TextIOBase are the four ABC layers."
    - "io.IOBase.__module__ == 'io' — the public module name, not '_io'."
    - "io.RawIOBase.__bases__ == ['_RawIOBase', 'IOBase'] — dual inheritance from C and Python ABCs."
    - "io.BufferedIOBase.__bases__ == ['_BufferedIOBase', 'IOBase'] — same dual-inheritance pattern."
    - "io.TextIOBase.__bases__ == ['_TextIOBase', 'IOBase'] — same dual-inheritance pattern."
    - "io.FileIO.__module__ == '_io' — FileIO is a C-extension class from the _io accelerator."
    - "io.TextIOWrapper.__module__ == '_io' — TextIOWrapper is also from the _io C-extension."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: io ABC class __name__ and __module__ identity
# ---------------------------------------------------------------------------

table io_extra281.abc_class_identity:
  description: "io.IOBase, RawIOBase, BufferedIOBase, TextIOBase __name__ and __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: abc

  columns: [id, function, args, expected, description]
  rows:
    - [iobase_name,        IOBase.__name__.__eq__,        ["IOBase"],        true, "io.IOBase.__name__ == 'IOBase'"]
    - [iobase_module,      IOBase.__module__.__eq__,      ["io"],            true, "io.IOBase.__module__ == 'io'"]
    - [rawiobase_name,     RawIOBase.__name__.__eq__,     ["RawIOBase"],     true, "io.RawIOBase.__name__ == 'RawIOBase'"]
    - [rawiobase_module,   RawIOBase.__module__.__eq__,   ["io"],            true, "io.RawIOBase.__module__ == 'io'"]
    - [bufiobase_name,     BufferedIOBase.__name__.__eq__, ["BufferedIOBase"], true, "io.BufferedIOBase.__name__ == 'BufferedIOBase'"]
    - [bufiobase_module,   BufferedIOBase.__module__.__eq__, ["io"],          true, "io.BufferedIOBase.__module__ == 'io'"]
    - [textiobase_name,    TextIOBase.__name__.__eq__,    ["TextIOBase"],    true, "io.TextIOBase.__name__ == 'TextIOBase'"]
    - [textiobase_module,  TextIOBase.__module__.__eq__,  ["io"],            true, "io.TextIOBase.__module__ == 'io'"]

# ---------------------------------------------------------------------------
# Table: io concrete class __name__ and __module__ identity
# ---------------------------------------------------------------------------

table io_extra281.concrete_class_identity:
  description: "io.FileIO, BufferedReader, BufferedWriter, TextIOWrapper __name__ and __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: cc

  columns: [id, function, args, expected, description]
  rows:
    - [fileio_name,      FileIO.__name__.__eq__,          ["FileIO"],          true, "io.FileIO.__name__ == 'FileIO'"]
    - [fileio_module,    FileIO.__module__.__eq__,         ["_io"],             true, "io.FileIO.__module__ == '_io' — C-extension from _io accelerator"]
    - [bufread_name,     BufferedReader.__name__.__eq__,   ["BufferedReader"],  true, "io.BufferedReader.__name__ == 'BufferedReader'"]
    - [bufwrite_name,    BufferedWriter.__name__.__eq__,   ["BufferedWriter"],  true, "io.BufferedWriter.__name__ == 'BufferedWriter'"]
    - [bufrand_name,     BufferedRandom.__name__.__eq__,   ["BufferedRandom"],  true, "io.BufferedRandom.__name__ == 'BufferedRandom'"]
    - [textiowrap_name,  TextIOWrapper.__name__.__eq__,    ["TextIOWrapper"],   true, "io.TextIOWrapper.__name__ == 'TextIOWrapper'"]
    - [textiowrap_mod,   TextIOWrapper.__module__.__eq__,  ["_io"],             true, "io.TextIOWrapper.__module__ == '_io' — C-extension from _io accelerator"]

# ---------------------------------------------------------------------------
# Standalone invariants: ABC hierarchy and concrete class bases
# ---------------------------------------------------------------------------

invariant io_extra281.IOBase.base_is_object:
  description: "io.IOBase.__bases__[0].__name__ == '_IOBase' — IOBase mixes in the C-extension _IOBase"
  category: identity
  kind: python_call_eq
  function: "IOBase.__bases__[0].__name__.__eq__"
  args: ["_IOBase"]
  expected: true

invariant io_extra281.RawIOBase.base0:
  description: "io.RawIOBase.__bases__[0].__name__ == '_RawIOBase' — dual inheritance from C ABC"
  category: identity
  kind: python_call_eq
  function: "RawIOBase.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra281.RawIOBase.base1:
  description: "io.RawIOBase.__bases__[1].__name__ == 'IOBase' — second base is the Python IOBase ABC"
  category: identity
  kind: python_call_eq
  function: "RawIOBase.__bases__[1].__name__.__eq__"
  args: ["IOBase"]
  expected: true

invariant io_extra281.BufferedIOBase.base0:
  description: "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' — dual inheritance from C ABC"
  category: identity
  kind: python_call_eq
  function: "BufferedIOBase.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra281.TextIOBase.base0:
  description: "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' — dual inheritance from C ABC"
  category: identity
  kind: python_call_eq
  function: "TextIOBase.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra281.FileIO.base0:
  description: "io.FileIO.__bases__[0].__name__ == '_RawIOBase' — FileIO inherits directly from C _RawIOBase"
  category: identity
  kind: python_call_eq
  function: "FileIO.__bases__[0].__name__.__eq__"
  args: ["_RawIOBase"]
  expected: true

invariant io_extra281.DEFAULT_BUFFER_SIZE.value:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 — 128 KiB on CPython 3.14.x (NOT the often-cited 8192)"
  category: identity
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra281.DEFAULT_BUFFER_SIZE.type:
  description: "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int'"
  category: identity
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true
