spec: abc_extra141
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers: abc.ABC.__dict__ contents — __dict__.__contains__('__abstractmethods__')==True; __dict__.__contains__('__doc__')==True; __dict__.__contains__('_abc_impl')==True; __dict__.__contains__('__slots__')==True; __dict__.__class__.__name__=='mappingproxy' (len=12); len(abc.ABC.__dict__)==7. abc.ABCMeta.__dict__ contents — __dict__.__contains__('register')==True; __dict__.__contains__('__instancecheck__')==True; __dict__.__contains__('__subclasscheck__')==True; __dict__.__contains__('_dump_registry')==True; __dict__.__class__.__name__=='mappingproxy' (len=12); len(abc.ABCMeta.__dict__)==11. abc.ABC.__doc__.__len__()==78 (doc is 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n'). abc.abstractmethod.__name__=='abstractmethod' (len=14); abc.abstractmethod.__doc__.__len__()==537; abc.abstractmethod.__code__.co_argcount==1 ('funcobj'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__dict__ has 7 entries: __module__, __firstlineno__, __doc__, __slots__, __static_attributes__, __abstractmethods__, _abc_impl. abc.ABCMeta.__dict__ has 11 entries (4 more than ABC.__dict__). Both dicts are of type mappingproxy (len=12). abc.ABC.__doc__.__len__()==78 (a 2-line doc). abc.abstractmethod is a pure-Python decorator in 'abc' (len=3) with 1 parameter and doc len==537. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC.__dict__ contents — extra141
#
# abc.ABC.__dict__.__contains__('__abstractmethods__') == True
# abc.ABC.__dict__.__contains__('__doc__')             == True
# abc.ABC.__dict__.__contains__('_abc_impl')           == True
# abc.ABC.__dict__.__contains__('__slots__')           == True
# abc.ABC.__dict__.__class__.__name__                  == 'mappingproxy' (len=12)
# len(abc.ABC.__dict__)                                == 7
# ---------------------------------------------------------------------------

table abc_extra141.abc_dict_contents:
  description: "abc.ABC.__dict__ contents checks — ABC.__dict__.__contains__('__abstractmethods__')==True (present because ABCMeta installs __abstractmethods__ as a frozenset on every ABC class); ABC.__dict__.__contains__('__doc__')==True (the class docstring is stored directly in the class __dict__); ABC.__dict__.__contains__('_abc_impl')==True (the C-level _ABCData struct used by the _abc extension module for caching); ABC.__dict__.__contains__('__slots__')==True (ABC defines '__slots__ = ()' to prevent instance dict creation); ABC.__dict__.__class__.__name__.__eq__('mappingproxy')==True (len=12: the read-only view returned by type.__dict__); ABC.__dict__.__len__()==7 (the dict has 7 keys: '__module__','__firstlineno__','__doc__','__slots__','__static_attributes__','__abstractmethods__','_abc_impl'); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcdict141

  columns: [id, function, args, expected, description]
  rows:
    - [has_am,     abc.ABC.__dict__.__contains__,              ["__abstractmethods__"],  true,  "abc.ABC.__dict__.__contains__('__abstractmethods__') == True; verified with Python 3.14.3"]
    - [has_doc,    abc.ABC.__dict__.__contains__,              ["__doc__"],              true,  "abc.ABC.__dict__.__contains__('__doc__') == True; verified with Python 3.14.3"]
    - [has_abc,    abc.ABC.__dict__.__contains__,              ["_abc_impl"],            true,  "abc.ABC.__dict__.__contains__('_abc_impl') == True; verified with Python 3.14.3"]
    - [has_slots,  abc.ABC.__dict__.__contains__,              ["__slots__"],            true,  "abc.ABC.__dict__.__contains__('__slots__') == True; verified with Python 3.14.3"]
    - [proxy_name, abc.ABC.__dict__.__class__.__name__.__eq__, ["mappingproxy"],         true,  "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy' (len=12); verified with Python 3.14.3"]
    - [proxy_len,  abc.ABC.__dict__.__class__.__name__.__len__, [],                      12,    "abc.ABC.__dict__.__class__.__name__.__len__() == 12 ('mappingproxy'); verified with Python 3.14.3"]
    - [dict_len,   abc.ABC.__dict__.__len__,                   [],                       7,     "abc.ABC.__dict__.__len__() == 7 (7 keys in the ABC class dict); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__dict__ contents — extra141
#
# abc.ABCMeta.__dict__.__contains__('register')          == True
# abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True
# abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True
# abc.ABCMeta.__dict__.__contains__('_dump_registry')    == True
# abc.ABCMeta.__dict__.__len__()                         == 11
# ---------------------------------------------------------------------------

table abc_extra141.abcmeta_dict_contents:
  description: "abc.ABCMeta.__dict__ contents checks — ABCMeta.__dict__.__contains__('register')==True (the virtual subclass registration method); ABCMeta.__dict__.__contains__('__instancecheck__')==True (the isinstance() override); ABCMeta.__dict__.__contains__('__subclasscheck__')==True (the issubclass() override); ABCMeta.__dict__.__contains__('_dump_registry')==True (internal debug method that prints the ABC registry state); ABCMeta.__dict__.__len__()==11 (the dict has 11 keys: '__module__','__firstlineno__','__doc__','__new__','register','__instancecheck__','__subclasscheck__','_dump_registry','_abc_registry_clear','_abc_caches_clear','__static_attributes__'; 4 more than ABC.__dict__.__len__()==7); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetadict141

  columns: [id, function, args, expected, description]
  rows:
    - [has_reg,   abc.ABCMeta.__dict__.__contains__, ["register"],           true,  "abc.ABCMeta.__dict__.__contains__('register') == True; verified with Python 3.14.3"]
    - [has_ic,    abc.ABCMeta.__dict__.__contains__, ["__instancecheck__"],  true,  "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True; verified with Python 3.14.3"]
    - [has_sc,    abc.ABCMeta.__dict__.__contains__, ["__subclasscheck__"],  true,  "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True; verified with Python 3.14.3"]
    - [has_dr,    abc.ABCMeta.__dict__.__contains__, ["_dump_registry"],     true,  "abc.ABCMeta.__dict__.__contains__('_dump_registry') == True; verified with Python 3.14.3"]
    - [dict_len,  abc.ABCMeta.__dict__.__len__,      [],                     11,    "abc.ABCMeta.__dict__.__len__() == 11 (4 more than ABC.__dict__.__len__()==7); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC.__doc__ and abc.abstractmethod identity — extra141
#
# abc.ABC.__doc__.__len__()            == 78
# abc.abstractmethod.__name__          == 'abstractmethod' (len=14)
# abc.abstractmethod.__module__        == 'abc'            (len=3)
# abc.abstractmethod.__doc__.__len__() == 537
# abc.abstractmethod co_argcount       == 1
# abc.abstractmethod co_varnames len   == 1
# ---------------------------------------------------------------------------

table abc_extra141.abc_doc_and_abstractmethod:
  description: "abc.ABC.__doc__ and abc.abstractmethod identity, doc, and code checks — ABC.__doc__.__len__()==78 (doc is 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' — 78 chars with a newline mid-sentence and a trailing newline; a two-line doc; first seen in extra141); ABC.__name__.__eq__('ABC')==True (len=3); ABC.__module__.__eq__('abc')==True (len=3: module name equals class name in length); abstractmethod.__name__.__eq__('abstractmethod')==True (len=14: 'abstractmethod'=14); abstractmethod.__module__.__eq__('abc')==True (len=3: the pure-Python abc module); abstractmethod.__doc__.__len__()==537 (a detailed multi-paragraph doc beginning 'A decorator indicating abstract methods.' — the longest __doc__ in this spec); abstractmethod.__code__.co_argcount.__eq__(1)==True ('funcobj', the function being decorated); abstractmethod.__code__.co_varnames.__len__()==1 (only 'funcobj' — no additional locals); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcam141

  columns: [id, function, args, expected, description]
  rows:
    - [abc_doc_len,  abc.ABC.__doc__.__len__,                          [],                 78,    "abc.ABC.__doc__.__len__() == 78; verified with Python 3.14.3"]
    - [abc_name_eq,  abc.ABC.__name__.__eq__,                         ["ABC"],             true,  "abc.ABC.__name__ == 'ABC' (len=3); verified with Python 3.14.3"]
    - [abc_name_len, abc.ABC.__name__.__len__,                         [],                 3,     "abc.ABC.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [abc_mod_eq,   abc.ABC.__module__.__eq__,                       ["abc"],             true,  "abc.ABC.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [am_name_eq,   abc.abstractmethod.__name__.__eq__,              ["abstractmethod"],  true,  "abc.abstractmethod.__name__ == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [am_name_len,  abc.abstractmethod.__name__.__len__,              [],                 14,    "abc.abstractmethod.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [am_mod_eq,    abc.abstractmethod.__module__.__eq__,            ["abc"],             true,  "abc.abstractmethod.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - [am_doc_len,   abc.abstractmethod.__doc__.__len__,               [],                 537,   "abc.abstractmethod.__doc__.__len__() == 537; verified with Python 3.14.3"]
    - [am_argc,      abc.abstractmethod.__code__.co_argcount.__eq__,  [1],                 true,  "abc.abstractmethod.__code__.co_argcount == 1 ('funcobj'); verified with Python 3.14.3"]
    - [am_vlen,      abc.abstractmethod.__code__.co_varnames.__len__,  [],                 1,     "abc.abstractmethod.__code__.co_varnames.__len__() == 1 ('funcobj' only); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra141
# ---------------------------------------------------------------------------

invariant abc_extra141.abc_dict_contains_abstractmethods:
  description: "abc.ABC.__dict__.__contains__('__abstractmethods__') == True — '__abstractmethods__' is present in abc.ABC.__dict__ as a frozenset installed by ABCMeta during class creation; it tracks which methods on the class are still abstract (none for ABC itself, so it is an empty frozenset); contrast with abc.ABCMeta.__dict__ which does NOT contain '__abstractmethods__' (ABCMeta is a metaclass, not an ABC instance); abc.ABC.__dict__.__len__()==7; __dict__.__class__.__name__=='mappingproxy' (len=12); NEW in extra141: first standalone ABC.__dict__ abstractmethods containment invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__contains__
  args: ["__abstractmethods__"]
  expected: true

invariant abc_extra141.abc_dict_len_7:
  description: "abc.ABC.__dict__.__len__() == 7 — abc.ABC.__dict__ has 7 keys: '__module__', '__firstlineno__', '__doc__', '__slots__', '__static_attributes__', '__abstractmethods__', '_abc_impl'; these are the only attributes defined directly on ABC itself (not inherited from object or ABCMeta); compare abc.ABCMeta.__dict__.__len__()==11 (4 more entries); ABC.__dict__.__class__.__name__=='mappingproxy' (len=12); NEW in extra141: first standalone ABC.__dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__len__
  args: []
  expected: 7

invariant abc_extra141.abcmeta_dict_len_11:
  description: "abc.ABCMeta.__dict__.__len__() == 11 — abc.ABCMeta.__dict__ has 11 keys: '__module__','__firstlineno__','__doc__','__new__','register','__instancecheck__','__subclasscheck__','_dump_registry','_abc_registry_clear','_abc_caches_clear','__static_attributes__'; this is 4 more than abc.ABC.__dict__.__len__()==7; ABCMeta has more entries because it defines several metaclass-specific methods; ABCMeta.__dict__.__class__.__name__=='mappingproxy' (len=12); NEW in extra141: first standalone ABCMeta.__dict__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__len__
  args: []
  expected: 11

invariant abc_extra141.abc_doc_len_78:
  description: "abc.ABC.__doc__.__len__() == 78 — abc.ABC.__doc__ is 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' (78 chars: a two-line doc with an embedded newline after 'using' and a trailing newline); ABC.__name__=='ABC' (len=3); ABC.__module__=='abc' (len=3); compare abc.ABCMeta.__doc__.__len__()==576 (much longer); compare abc.abstractmethod.__doc__.__len__()==537; NEW in extra141: first standalone ABC.__doc__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__doc__.__len__
  args: []
  expected: 78

invariant abc_extra141.abcmeta_dict_contains_register:
  description: "abc.ABCMeta.__dict__.__contains__('register') == True — 'register' is present in abc.ABCMeta.__dict__ as the virtual subclass registration method; register.__qualname__=='ABCMeta.register' (len=16); register.__doc__.__len__()==99; register is a classmethod taking ('cls','subclass'); ABCMeta.__dict__.__len__()==11; NEW in extra141: first standalone ABCMeta.__dict__ register containment invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["register"]
  expected: true

invariant abc_extra141.abc_dict_proxy_class_name_mappingproxy:
  description: "abc.ABC.__dict__.__class__.__name__.__len__() == 12 — abc.ABC.__dict__.__class__.__name__ is 'mappingproxy' (12 chars: the read-only proxy type wrapping class dicts); ABC.__dict__.__class__ is <class 'mappingproxy'>; the same is true for abc.ABCMeta.__dict__.__class__.__name__ (also 'mappingproxy'); all Python class __dict__ objects are mappingproxy instances; ABC.__dict__.__len__()==7; NEW in extra141: first standalone ABC dict proxy class name length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__dict__.__class__.__name__.__len__
  args: []
  expected: 12

invariant abc_extra141.abstractmethod_doc_len_537:
  description: "abc.abstractmethod.__doc__.__len__() == 537 — abc.abstractmethod.__doc__ is a 537-char multi-paragraph doc beginning 'A decorator indicating abstract methods.' (the longest __doc__ in this spec; compare: ABCMeta=576 which is in extra140, ABC=78); abstractmethod.__name__=='abstractmethod' (len=14); abstractmethod.__module__=='abc' (len=3); co_argcount==1 ('funcobj'); co_varnames.__len__()==1 (only 'funcobj', no locals); NEW in extra141: first standalone abstractmethod doc length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__doc__.__len__
  args: []
  expected: 537

invariant abc_extra141.abcmeta_dict_contains_instancecheck:
  description: "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True — '__instancecheck__' is present in abc.ABCMeta.__dict__ as the override for isinstance() checking (it uses the ABC virtual subclass registry to return True even for classes that did not directly inherit from the ABC); ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__' (len=25); __doc__.__len__()==39; co_argcount==2 ('cls','instance'); ABCMeta.__dict__.__len__()==11; NEW in extra141: first standalone ABCMeta.__dict__ __instancecheck__ containment invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__dict__.__contains__
  args: ["__instancecheck__"]
  expected: true

