spec: uu_extra
version: ">=3.9,<3.13"
backend: python_module(uu)

docs: https://docs.python.org/3.11/library/uu.html

provenance:
  derived_from:
    - "https://docs.python.org/3.11/library/uu.html — Python uu module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uu.py"
  notes:
    - "This spec complements uu.zspec.zsdl with additional invariants."
    - "The uu module was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13."
    - "This spec targets Python 3.9 through 3.12 inclusive."
    - "encode.__name__ == 'encode' and encode.__module__ == 'uu' confirm public API identity."
    - "decode.__name__ == 'decode' confirms the decode function identity."
    - "uu.Error.__name__ == 'Error', inherits from Exception, and is defined in the uu module."
    - "uu.Error.__mro__ has length 4: Error, Exception, BaseException, object."
    - "All expected values verified by running Python 3.12 uu module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __name__ checks
# ---------------------------------------------------------------------------

invariant uu_extra.encode.name:
  description: "uu.encode.__name__ == 'encode'"
  category: function_names
  kind: python_call_eq
  function: encode.__name__.__eq__
  args: ["encode"]
  expected: true

invariant uu_extra.decode.name:
  description: "uu.decode.__name__ == 'decode'"
  category: function_names
  kind: python_call_eq
  function: decode.__name__.__eq__
  args: ["decode"]
  expected: true

# ---------------------------------------------------------------------------
# Function module affiliation
# ---------------------------------------------------------------------------

invariant uu_extra.encode.module:
  description: "uu.encode.__module__ == 'uu' — encode is defined in the uu module"
  category: module
  kind: python_call_eq
  function: encode.__module__.__eq__
  args: ["uu"]
  expected: true

invariant uu_extra.decode.module:
  description: "uu.decode.__module__ == 'uu' — decode is defined in the uu module"
  category: module
  kind: python_call_eq
  function: decode.__module__.__eq__
  args: ["uu"]
  expected: true

# ---------------------------------------------------------------------------
# Error class — name, module, and hierarchy
# ---------------------------------------------------------------------------

invariant uu_extra.Error.name:
  description: "uu.Error.__name__ == 'Error'"
  category: classnames
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant uu_extra.Error.module:
  description: "uu.Error.__module__ == 'uu' — Error is defined in the uu module"
  category: classnames
  kind: python_call_eq
  function: Error.__module__.__eq__
  args: ["uu"]
  expected: true

invariant uu_extra.Error.base_is_Exception:
  description: "uu.Error.__bases__[0].__name__ == 'Exception' — Error is a direct subclass of Exception"
  category: hierarchy
  kind: python_call_eq
  function: Error.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

invariant uu_extra.Error.mro_length:
  description: "len(uu.Error.__mro__) == 4 — mro is [Error, Exception, BaseException, object]"
  category: hierarchy
  kind: python_call_eq
  function: Error.__mro__.__len__
  args: []
  expected: 4

invariant uu_extra.Error.is_class:
  description: "uu.Error.__class__.__name__ == 'type' — uu.Error is a class object"
  category: classnames
  kind: python_call_eq
  function: Error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Callable type checks — encode and decode are plain Python functions
# ---------------------------------------------------------------------------

invariant uu_extra.encode.is_function:
  description: "uu.encode.__class__.__name__ == 'function' — encode is a plain Python function"
  category: callables
  kind: python_call_eq
  function: encode.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant uu_extra.decode.is_function:
  description: "uu.decode.__class__.__name__ == 'function' — decode is a plain Python function"
  category: callables
  kind: python_call_eq
  function: decode.__class__.__name__.__eq__
  args: ["function"]
  expected: true
