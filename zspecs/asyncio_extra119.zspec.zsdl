table asyncio_extra119.ael_exception_handler_qualname_len:
  description: "asyncio.AbstractEventLoop exception handler method __qualname__ length checks in ael119 namespace — wave 259 theme: call_soon_threadsafe, set_exception_handler, call_exception_handler, default_exception_handler qualname lengths; AbstractEventLoop.call_soon_threadsafe.__qualname__.__eq__('AbstractEventLoop.call_soon_threadsafe')==True (len=38: 'AbstractEventLoop.'=18+'call_soon_threadsafe'=20=38; call_soon_threadsafe() is thread-safe variant of call_soon; schedules callback to run in the event loop thread from another thread; uses an internal write pipe to wake the event loop); AbstractEventLoop.call_soon_threadsafe.__qualname__.__len__()==38; AbstractEventLoop.set_exception_handler.__qualname__.__eq__('AbstractEventLoop.set_exception_handler')==True (len=39: 'AbstractEventLoop.'=18+'set_exception_handler'=21=39; set_exception_handler() sets the exception handler called when an exception is raised and not caught in the event loop; tied with get_exception_handler=39); AbstractEventLoop.set_exception_handler.__qualname__.__len__()==39; AbstractEventLoop.call_exception_handler.__qualname__.__eq__('AbstractEventLoop.call_exception_handler')==True (len=40: 'AbstractEventLoop.'=18+'call_exception_handler'=22=40; call_exception_handler() calls the current exception handler; 1 more than set/get=39); AbstractEventLoop.call_exception_handler.__qualname__.__len__()==40; AbstractEventLoop.default_exception_handler.__qualname__.__eq__('AbstractEventLoop.default_exception_handler')==True (len=43: 'AbstractEventLoop.'=18+'default_exception_handler'=25=43; default_exception_handler() is the default handler that logs exceptions to stderr; longest AbstractEventLoop method qualname in spec); AbstractEventLoop.default_exception_handler.__qualname__.__len__()==43; ordering: call_soon_threadsafe=38 < set_exception_handler=39 < call_exception_handler=40 < default_exception_handler=43 (longest); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: ael119a

  columns: [id, function, args, expected, description]
  rows:
    - [cst_eq,   AbstractEventLoop.call_soon_threadsafe.__qualname__.__eq__,      ["AbstractEventLoop.call_soon_threadsafe"],      true, "AbstractEventLoop.call_soon_threadsafe.__qualname__ == 'AbstractEventLoop.call_soon_threadsafe' (len=38); verified with Python 3.14.3"]
    - [cst_len,  AbstractEventLoop.call_soon_threadsafe.__qualname__.__len__,     [],                                              38,   "AbstractEventLoop.call_soon_threadsafe.__qualname__.__len__() == 38 ('AbstractEventLoop.'=18+'call_soon_threadsafe'=20=38); verified with Python 3.14.3"]
    - [seh_eq,   AbstractEventLoop.set_exception_handler.__qualname__.__eq__,     ["AbstractEventLoop.set_exception_handler"],     true, "AbstractEventLoop.set_exception_handler.__qualname__ == 'AbstractEventLoop.set_exception_handler' (len=39); verified with Python 3.14.3"]
    - [seh_len,  AbstractEventLoop.set_exception_handler.__qualname__.__len__,    [],                                              39,   "AbstractEventLoop.set_exception_handler.__qualname__.__len__() == 39; verified with Python 3.14.3"]
    - [ceh_eq,   AbstractEventLoop.call_exception_handler.__qualname__.__eq__,    ["AbstractEventLoop.call_exception_handler"],    true, "AbstractEventLoop.call_exception_handler.__qualname__ == 'AbstractEventLoop.call_exception_handler' (len=40); verified with Python 3.14.3"]
    - [ceh_len,  AbstractEventLoop.call_exception_handler.__qualname__.__len__,   [],                                              40,   "AbstractEventLoop.call_exception_handler.__qualname__.__len__() == 40; verified with Python 3.14.3"]
    - [deh_eq,   AbstractEventLoop.default_exception_handler.__qualname__.__eq__, ["AbstractEventLoop.default_exception_handler"], true, "AbstractEventLoop.default_exception_handler.__qualname__ == 'AbstractEventLoop.default_exception_handler' (len=43, longest); verified with Python 3.14.3"]
    - [deh_len,  AbstractEventLoop.default_exception_handler.__qualname__.__len__, [],                                             43,   "AbstractEventLoop.default_exception_handler.__qualname__.__len__() == 43 (longest in spec); verified with Python 3.14.3"]

