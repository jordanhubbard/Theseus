invariant asyncio_extra119.ael_stop_qualname_eq:
  description: "asyncio.AbstractEventLoop.stop.__qualname__.__eq__('AbstractEventLoop.stop') returns True — 'AbstractEventLoop.stop' has len=22: 'AbstractEventLoop.'=18+'stop'=4=22; this is the shortest __qualname__ of any AbstractEventLoop method in this spec; AbstractEventLoop.stop() is a pure-Python function (has __code__) that schedules the event loop to stop after the current iteration; co_argcount=1 (self only; no other parameters); co_varnames=('self',) len=1 (fewest possible); AbstractEventLoop.__name__.__len__()==17 ('AbstractEventLoop'=17); AbstractEventLoop.__module__=='asyncio.events' (len=14); AbstractEventLoop.__mro__.__len__()==2 ([AbstractEventLoop, object]); 'AbstractEventLoop.' prefix len=18 is common to all method qualnames in this spec; stop is 4 chars (shortest method name in spec after the prefix); compare: close=23 (1 more than stop), call_at=25 (3 more), is_closed=call_soon=27 (5 more); first standalone AbstractEventLoop.stop qualname equality invariant in ael119 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: AbstractEventLoop.stop.__qualname__.__eq__
  args: ["AbstractEventLoop.stop"]
  expected: true

invariant asyncio_extra119.ael_run_until_complete_qualname_len_36:
  description: "asyncio.AbstractEventLoop.run_until_complete.__qualname__.__len__() == 36 — 'AbstractEventLoop.run_until_complete' = 'AbstractEventLoop.'=18+'run_until_complete'=18=36; note: prefix and method name are equal length (both 18 chars), making this a symmetric qualname; AbstractEventLoop.run_until_complete.__qualname__.__eq__('AbstractEventLoop.run_until_complete')==True; run_until_complete() wraps a coroutine in a Task if needed and runs the loop until the Task is done; compare: run_forever=29 (7 shorter: 'run_forever'=11 vs 'run_until_complete'=18, diff=7); call_soon_threadsafe=38 (2 longer: 'call_soon_threadsafe'=20 vs 'run_until_complete'=18, diff=2); run_until_complete co_varnames.__len__()==2 (('self','future'): self plus the future/coroutine argument); AbstractEventLoop.__name__.__len__()==17; AbstractEventLoop.__module__.__len__()==14; first standalone run_until_complete qualname length invariant in ael119 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: AbstractEventLoop.run_until_complete.__qualname__.__len__
  args: []
  expected: 36

invariant asyncio_extra119.ael_default_exception_handler_qualname_len_43:
  description: "asyncio.AbstractEventLoop.default_exception_handler.__qualname__.__len__() == 43 — 'AbstractEventLoop.default_exception_handler' = 'AbstractEventLoop.'=18+'default_exception_handler'=25=43; this is the longest AbstractEventLoop method qualname in this spec; 'default_exception_handler'=25 chars is the longest method-name segment; compare: call_exception_handler=40 (3 shorter: 'call_exception_handler'=22 vs 'default_exception_handler'=25, diff=3), set_exception_handler=39 (4 shorter: 'set_exception_handler'=21 vs 'default_exception_handler'=25, diff=4); AbstractEventLoop.default_exception_handler() is the built-in exception handler invoked when no custom handler is set; it logs the exception and context info to stderr using logging; AbstractEventLoop.__name__.__len__()==17; AbstractEventLoop.__module__=='asyncio.events' (len=14); first standalone default_exception_handler qualname length invariant in ael119 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: AbstractEventLoop.default_exception_handler.__qualname__.__len__
  args: []
  expected: 43

invariant asyncio_extra119.ael_run_forever_co_varnames_len_1:
  description: "asyncio.AbstractEventLoop.run_forever.__code__.co_varnames.__len__() == 1 — co_varnames==('self',): run_forever takes no arguments other than self; it is a simple abstract stub that raises NotImplementedError; co_argcount==1; co_varnames len=1 is the minimum possible for a bound method; AbstractEventLoop.run_forever.__qualname__=='AbstractEventLoop.run_forever' (len=29); compare: run_until_complete co_varnames len=2 ('self','future': 1 more), create_task co_varnames len=3 ('self','coro','kwargs': 2 more); AbstractEventLoop.run_forever.__code__.co_qualname=='AbstractEventLoop.run_forever' (co_qualname matches __qualname__ for regular methods); AbstractEventLoop.__module__=='asyncio.events'; AbstractEventLoop.__mro__.__len__()==2; first standalone AbstractEventLoop.run_forever co_varnames length invariant in ael119 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: AbstractEventLoop.run_forever.__code__.co_varnames.__len__
  args: []
  expected: 1

invariant asyncio_extra119.ael_call_soon_threadsafe_qualname_eq:
  description: "asyncio.AbstractEventLoop.call_soon_threadsafe.__qualname__.__eq__('AbstractEventLoop.call_soon_threadsafe') returns True — 'AbstractEventLoop.call_soon_threadsafe' has len=38: 'AbstractEventLoop.'=18+'call_soon_threadsafe'=20=38; call_soon_threadsafe is the thread-safe version of call_soon — it schedules callback to be called in the event loop thread from a different thread by using an internal write pipe to wake the sleeping selector; AbstractEventLoop.call_soon_threadsafe.__qualname__.__len__()==38; compare: call_soon=27 (11 shorter: 'call_soon'=9 vs 'call_soon_threadsafe'=20, diff=11 — the '_threadsafe' suffix adds 11 chars including the underscore); set_exception_handler=39 (1 more than call_soon_threadsafe=38); call_exception_handler=40 (2 more); default_exception_handler=43 (5 more); AbstractEventLoop.__name__.__len__()==17; AbstractEventLoop.__module__=='asyncio.events' (len=14); first standalone call_soon_threadsafe qualname equality invariant in ael119 namespace; wave 259; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: AbstractEventLoop.call_soon_threadsafe.__qualname__.__eq__
  args: ["AbstractEventLoop.call_soon_threadsafe"]
  expected: true

