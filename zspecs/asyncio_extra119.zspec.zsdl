table asyncio_extra119.ael_run_method_qualnames:
  description: "asyncio.AbstractEventLoop run method __qualname__ lengths and co_varnames checks in ael119 namespace — wave 259 theme: run_forever, run_until_complete, create_task qualname and code attrs; AbstractEventLoop.run_forever.__qualname__.__eq__('AbstractEventLoop.run_forever')==True (len=29: 'AbstractEventLoop.'=18+'run_forever'=11=29; run_forever() runs the event loop until stop() is called; it blocks the calling thread until the loop is stopped; tied with create_task=29); AbstractEventLoop.run_forever.__qualname__.__len__()==29; run_forever co_varnames.__len__()==1 (only 'self': run_forever takes no arguments other than self; it simply loops until stopped; co_argcount==1); AbstractEventLoop.run_until_complete.__qualname__.__eq__('AbstractEventLoop.run_until_complete')==True (len=36: 'AbstractEventLoop.'=18+'run_until_complete'=18=36; run_until_complete() runs the event loop until the Future or coroutine completes; 7 more than run_forever=29: 'run_until_complete'=18 vs 'run_forever'=11, diff=7); AbstractEventLoop.run_until_complete.__qualname__.__len__()==36; run_until_complete co_varnames.__len__()==2 (('self','future'): 1 parameter 'future' plus self; co_argcount==2); AbstractEventLoop.create_task.__qualname__.__len__()==29 (tied with run_forever=29: 'AbstractEventLoop.'=18+'create_task'=11=29); create_task co_varnames.__len__()==3 (('self','coro','kwargs'): self plus coro and kwargs; co_argcount==2); compare co_varnames lengths: run_forever=1 (fewest: self only) < run_until_complete=2 < create_task=3 (most in this table); ordering: run_forever==create_task=29 (tied) < run_until_complete=36; all are pure-Python functions in asyncio.events; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: ael119b

  columns: [id, function, args, expected, description]
  rows:
    - [rf_eq,       AbstractEventLoop.run_forever.__qualname__.__eq__,           ["AbstractEventLoop.run_forever"],        true, "AbstractEventLoop.run_forever.__qualname__ == 'AbstractEventLoop.run_forever' (len=29); verified with Python 3.14.3"]
    - [rf_len,      AbstractEventLoop.run_forever.__qualname__.__len__,          [],                                       29,   "AbstractEventLoop.run_forever.__qualname__.__len__() == 29 (tied with create_task=29); verified with Python 3.14.3"]
    - [rf_var_len,  AbstractEventLoop.run_forever.__code__.co_varnames.__len__,  [],                                       1,    "AbstractEventLoop.run_forever co_varnames.__len__() == 1 (only 'self': no params other than self); verified with Python 3.14.3"]
    - [ruc_eq,      AbstractEventLoop.run_until_complete.__qualname__.__eq__,    ["AbstractEventLoop.run_until_complete"], true, "AbstractEventLoop.run_until_complete.__qualname__ == 'AbstractEventLoop.run_until_complete' (len=36); verified with Python 3.14.3"]
    - [ruc_len,     AbstractEventLoop.run_until_complete.__qualname__.__len__,   [],                                       36,   "AbstractEventLoop.run_until_complete.__qualname__.__len__() == 36 ('AbstractEventLoop.'=18+'run_until_complete'=18=36); verified with Python 3.14.3"]
