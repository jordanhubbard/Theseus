    - [ct_len,      AbstractEventLoop.create_task.__qualname__.__len__,          [],                                       29,   "AbstractEventLoop.create_task.__qualname__.__len__() == 29 (tied with run_forever=29); verified with Python 3.14.3"]
    - [ct_var_len,  AbstractEventLoop.create_task.__code__.co_varnames.__len__,  [],                                       3,    "AbstractEventLoop.create_task co_varnames.__len__() == 3 (('self','coro','kwargs')); verified with Python 3.14.3"]

