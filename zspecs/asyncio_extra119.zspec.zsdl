spec: asyncio_extra119
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-eventloop.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-eventloop.html — Python asyncio AbstractEventLoop documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/events.py"
  notes:
    - "This spec extends asyncio_extra118.zspec.zsdl."
    - "This spec covers: wave 259 theme — asyncio.AbstractEventLoop method __qualname__ lengths and equality not previously covered. Prior specs covered: extra108 covered AbstractEventLoop.__name__, __module__, __qualname__.__len__(), __mro__.__len__(), __bases__[0].__name__; extra7 covered AbstractEventLoop.__qualname__.__eq__(). NOT previously covered as method qualname checks: AbstractEventLoop.run_forever.__qualname__ (len=29), AbstractEventLoop.run_until_complete.__qualname__ (len=36), AbstractEventLoop.stop.__qualname__ (len=22), AbstractEventLoop.close.__qualname__ (len=23), AbstractEventLoop.call_at.__qualname__ (len=25), AbstractEventLoop.is_closed.__qualname__ (len=27), AbstractEventLoop.call_soon.__qualname__ (len=27), AbstractEventLoop.call_soon_threadsafe.__qualname__ (len=38), AbstractEventLoop.set_exception_handler.__qualname__ (len=39), AbstractEventLoop.call_exception_handler.__qualname__ (len=40), AbstractEventLoop.default_exception_handler.__qualname__ (len=43). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.AbstractEventLoop method __qualname__ values all share the 'AbstractEventLoop.' prefix (len=18). Shortest method qualname: stop=22 ('AbstractEventLoop.'=18+'stop'=4=22). Longest method qualname: default_exception_handler=43 ('AbstractEventLoop.'=18+'default_exception_handler'=25=43). The prefix 'AbstractEventLoop.'=18 is the longest class prefix in any asyncio method qualname in this spec. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "AbstractEventLoop is the abstract base class for all event loop implementations in asyncio. It defines the interface that concrete implementations (such as asyncio.SelectorEventLoop on Unix) must implement. AbstractEventLoop inherits directly from object: __mro__.__len__()==2. __module__=='asyncio.events' (len=14). All methods are regular Python functions (type='function') defined in Lib/asyncio/events.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.AbstractEventLoop lifecycle method __qualname__ lengths — extra119
#
# Wave 259 theme: stop, close, call_at, is_closed, call_soon qualname lengths.
#
# AbstractEventLoop.stop.__qualname__      == 'AbstractEventLoop.stop'      (len=22, shortest)
# AbstractEventLoop.close.__qualname__     == 'AbstractEventLoop.close'     (len=23)
# AbstractEventLoop.call_at.__qualname__   == 'AbstractEventLoop.call_at'   (len=25)
# AbstractEventLoop.is_closed.__qualname__ == 'AbstractEventLoop.is_closed' (len=27, tied)
# AbstractEventLoop.call_soon.__qualname__ == 'AbstractEventLoop.call_soon' (len=27, tied)
# ---------------------------------------------------------------------------

table asyncio_extra119.ael_lifecycle_qualname_len:
  description: "asyncio.AbstractEventLoop lifecycle method __qualname__ length checks in ael119 namespace — wave 259 theme: stop, close, call_at, is_closed, call_soon qualname lengths; AbstractEventLoop.stop.__qualname__.__eq__('AbstractEventLoop.stop')==True (len=22: 'AbstractEventLoop.'=18+'stop'=4=22; stop() is the abstract method that schedules the event loop to stop after the current iteration; the loop will stop at the next convenient opportunity after stop() is called); AbstractEventLoop.stop.__qualname__.__len__()==22; AbstractEventLoop.close.__qualname__.__eq__('AbstractEventLoop.close')==True (len=23: 'AbstractEventLoop.'=18+'close'=5=23; close() releases all resources associated with the event loop and marks it as closed; cannot be called on a running loop; 1 more than stop=22); AbstractEventLoop.close.__qualname__.__len__()==23; AbstractEventLoop.call_at.__qualname__.__eq__('AbstractEventLoop.call_at')==True (len=25: 'AbstractEventLoop.'=18+'call_at'=7=25; call_at() schedules callback to be called at the absolute time 'when' in seconds; 2 more than close=23); AbstractEventLoop.call_at.__qualname__.__len__()==25; AbstractEventLoop.is_closed.__qualname__.__eq__('AbstractEventLoop.is_closed')==True (len=27: 'AbstractEventLoop.'=18+'is_closed'=9=27; is_closed() returns True if the event loop was closed; tied with call_soon=27); AbstractEventLoop.is_closed.__qualname__.__len__()==27; AbstractEventLoop.call_soon.__qualname__.__eq__('AbstractEventLoop.call_soon')==True (len=27: 'AbstractEventLoop.'=18+'call_soon'=9=27; call_soon() schedules callback to be called in the next iteration of the event loop; tied with is_closed=27); AbstractEventLoop.call_soon.__qualname__.__len__()==27; ordering: stop=22 < close=23 < call_at=25 < is_closed==call_soon==27 (tie at 27); all five are pure-Python functions with __code__ attribute; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: ael119

  columns: [id, function, args, expected, description]
  rows:
    - [stop_eq,     AbstractEventLoop.stop.__qualname__.__eq__,      ["AbstractEventLoop.stop"],      true, "AbstractEventLoop.stop.__qualname__ == 'AbstractEventLoop.stop' (len=22, shortest); verified with Python 3.14.3"]
    - [stop_len,    AbstractEventLoop.stop.__qualname__.__len__,     [],                              22,   "AbstractEventLoop.stop.__qualname__.__len__() == 22 ('AbstractEventLoop.'=18+'stop'=4=22, shortest in spec); verified with Python 3.14.3"]
    - [close_eq,    AbstractEventLoop.close.__qualname__.__eq__,     ["AbstractEventLoop.close"],     true, "AbstractEventLoop.close.__qualname__ == 'AbstractEventLoop.close' (len=23); verified with Python 3.14.3"]
    - [close_len,   AbstractEventLoop.close.__qualname__.__len__,    [],                              23,   "AbstractEventLoop.close.__qualname__.__len__() == 23 ('AbstractEventLoop.'=18+'close'=5=23); verified with Python 3.14.3"]
    - [call_at_eq,  AbstractEventLoop.call_at.__qualname__.__eq__,   ["AbstractEventLoop.call_at"],   true, "AbstractEventLoop.call_at.__qualname__ == 'AbstractEventLoop.call_at' (len=25); verified with Python 3.14.3"]
    - [call_at_len, AbstractEventLoop.call_at.__qualname__.__len__,  [],                              25,   "AbstractEventLoop.call_at.__qualname__.__len__() == 25 ('AbstractEventLoop.'=18+'call_at'=7=25); verified with Python 3.14.3"]
    - [iscls_eq,    AbstractEventLoop.is_closed.__qualname__.__eq__, ["AbstractEventLoop.is_closed"], true, "AbstractEventLoop.is_closed.__qualname__ == 'AbstractEventLoop.is_closed' (len=27, tied with call_soon); verified with Python 3.14.3"]
    - [iscls_len,   AbstractEventLoop.is_closed.__qualname__.__len__, [],                             27,   "AbstractEventLoop.is_closed.__qualname__.__len__() == 27 (tied with call_soon=27); verified with Python 3.14.3"]
    - [csoon_eq,    AbstractEventLoop.call_soon.__qualname__.__eq__, ["AbstractEventLoop.call_soon"], true, "AbstractEventLoop.call_soon.__qualname__ == 'AbstractEventLoop.call_soon' (len=27, tied with is_closed); verified with Python 3.14.3"]
    - [csoon_len,   AbstractEventLoop.call_soon.__qualname__.__len__, [],                             27,   "AbstractEventLoop.call_soon.__qualname__.__len__() == 27 (tied with is_closed=27; 'call_soon'=9=='is_closed'=9); verified with Python 3.14.3"]

