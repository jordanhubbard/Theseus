spec: statistics_extra9
version: ">=3.8"
backend: python_module(statistics)

docs: https://docs.python.org/3/library/statistics.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/statistics.html — Python statistics documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/statistics.py"
  notes:
    - "This spec extends statistics.zspec.zsdl and prior extras (statistics_extra through statistics_extra8)."
    - "statistics_extra2 covers: mean/median/stdev/variance/mode __module__."
    - "statistics_extra4 covers: fmean/geometric_mean/harmonic_mean/variance/stdev __module__ (table)."
    - "statistics_extra7 covers: pstdev/pvariance/median_low/median_high/multimode/quantiles __module__."
    - "NOT yet covered: mean/__module__ via __eq__ invariant style (extra2 used a table row)."
    - "NOT yet covered: median/__module__ via __eq__ invariant style."
    - "NOT yet covered: mode/__module__ via __eq__ invariant style."
    - "NOT yet covered: stdev/__module__ via __eq__ invariant style."
    - "NOT yet covered: variance/__module__ via __eq__ invariant style."
    - "NOT yet covered: geometric_mean/__module__ via __eq__ invariant style (extra4 used table row)."
    - "NOT yet covered: harmonic_mean/__module__ via __eq__ invariant style."
    - "NOT yet covered: median_grouped/__module__."
    - "NOT yet covered: fmean/__module__ via __eq__ invariant style."
    - "statistics.mean.__module__ == 'statistics'."
    - "statistics.median.__module__ == 'statistics'."
    - "statistics.mode.__module__ == 'statistics'."
    - "statistics.stdev.__module__ == 'statistics'."
    - "statistics.variance.__module__ == 'statistics'."
    - "statistics.pstdev.__module__ == 'statistics' — confirmed in extra7 table; here as invariant."
    - "statistics.pvariance.__module__ == 'statistics' — confirmed in extra7 table; here as invariant."
    - "statistics.geometric_mean.__module__ == 'statistics'."
    - "statistics.harmonic_mean.__module__ == 'statistics'."
    - "statistics.median_low.__module__ == 'statistics' — confirmed in extra7 table; here as invariant."
    - "statistics.median_high.__module__ == 'statistics' — confirmed in extra7 table; here as invariant."
    - "statistics.median_grouped.__module__ == 'statistics'."
    - "statistics.quantiles.__module__ == 'statistics' — confirmed in extra7 table; here as invariant."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks — invariant style (as opposed to table-row style)
#
# statistics_extra2 covered mean/median/stdev/variance/mode via a table.
# statistics_extra4 covered fmean/geometric_mean/harmonic_mean/variance/stdev
# via a table. statistics_extra7 covered pstdev/pvariance/median_low/
# median_high/multimode/quantiles via a table.
# This spec provides the same __module__ == 'statistics' checks expressed
# as individual invariants, a distinct expression axis not previously used
# for this set of functions.
# ---------------------------------------------------------------------------

invariant statistics_extra9.mean.module:
  description: "statistics.mean.__module__ == 'statistics'"
  category: function_module
  kind: python_call_eq
  function: mean.__module__.__eq__
  args: ["statistics"]
  expected: true

invariant statistics_extra9.median.module:
  description: "statistics.median.__module__ == 'statistics'"
  category: function_module
  kind: python_call_eq
  function: median.__module__.__eq__
  args: ["statistics"]
  expected: true

invariant statistics_extra9.mode.module:
  description: "statistics.mode.__module__ == 'statistics'"
  category: function_module
  kind: python_call_eq
  function: mode.__module__.__eq__
  args: ["statistics"]
  expected: true

