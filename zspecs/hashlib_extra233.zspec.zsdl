spec: hashlib_extra233
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Lib/hashlib.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "type(hashlib.sha256()).update.__name__ == 'update' — Hash object method name is 'update' (6 characters)."
    - "type(hashlib.sha256()).digest.__name__ == 'digest' — Hash object method name is 'digest' (6 characters)."
    - "type(hashlib.sha256()).hexdigest.__name__ == 'hexdigest' — Hash object method name is 'hexdigest' (9 characters)."
    - "type(hashlib.sha256()).copy.__name__ == 'copy' — Hash object method name is 'copy' (4 characters)."
    - "type(hashlib.sha256()).__name__ == 'HASH' — the CPython HASH type name is 'HASH' (4 characters)."
    - "type(hashlib.sha256()).__module__ == '_hashlib' — HASH type is from the C extension _hashlib."
    - "type(hashlib.sha256()).update.__qualname__ == 'HASH.update' — update is a method of HASH class."
    - "type(hashlib.sha256()).digest.__qualname__ == 'HASH.digest' — digest is a method of HASH class."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.Hash object method name contracts via type(sha256())
#
# type(hashlib.sha256()).update.__name__    == 'update'
# type(hashlib.sha256()).digest.__name__    == 'digest'
# type(hashlib.sha256()).hexdigest.__name__ == 'hexdigest'
# type(hashlib.sha256()).copy.__name__      == 'copy'
#
# The HASH type is the CPython C-extension implementation of hash objects.
# Method names on the type are exposed as method_descriptor objects.
# update() feeds data into the hash; digest() returns bytes; hexdigest()
# returns a hex string; copy() duplicates the current hash state.
# ---------------------------------------------------------------------------

table hashlib_extra233.hash_method_names:
  description: "type(sha256()).update.__name__=='update'; digest.__name__=='digest'; hexdigest.__name__=='hexdigest'; copy.__name__=='copy'; Hash method name contracts; new to extra233"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib233

  columns: [id, function, args, expected, description]
  rows:
    - [update_name_eq_update,
       "sha256().__class__.update.__name__.__eq__",
       ["update"],
       true,
       "type(hashlib.sha256()).update.__name__.__eq__('update') == True — update is the Hash method for feeding data; __name__ is 'update' (6 characters); feeds bytes into the running hash state; new anchor in extra233 namespace; verified Python 3.14.3"]
    - [digest_name_eq_digest,
       "sha256().__class__.digest.__name__.__eq__",
       ["digest"],
       true,
       "type(hashlib.sha256()).digest.__name__.__eq__('digest') == True — digest returns the hash value as a bytes object; __name__ is 'digest' (6 characters); same length as 'update'; new anchor in extra233 namespace; verified Python 3.14.3"]
    - [hexdigest_name_eq_hexdigest,
       "sha256().__class__.hexdigest.__name__.__eq__",
       ["hexdigest"],
       true,
       "type(hashlib.sha256()).hexdigest.__name__.__eq__('hexdigest') == True — hexdigest returns the hash value as a lowercase hex string; __name__ is 'hexdigest' (9 characters); 3 more than 'digest'; new anchor in extra233 namespace; verified Python 3.14.3"]
    - [copy_name_eq_copy,
       "sha256().__class__.copy.__name__.__eq__",
       ["copy"],
       true,
       "type(hashlib.sha256()).copy.__name__.__eq__('copy') == True — copy duplicates the current hash object state; __name__ is 'copy' (4 characters); allows branching hash computation; new anchor in extra233 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.Hash type class identity contracts
#
# type(hashlib.sha256()).__name__   == 'HASH'
# type(hashlib.sha256()).__module__ == '_hashlib'
#
# The HASH type is the underlying C-extension class. Its name is 'HASH'
# (all-caps, 4 characters). The module is '_hashlib' (the C extension).
# This is distinct from the public 'hashlib' Python module name.
# ---------------------------------------------------------------------------

table hashlib_extra233.hash_type_identity:
  description: "type(sha256()).__name__=='HASH'; type(sha256()).__module__=='_hashlib'; HASH type identity; new to extra233"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib233a

  columns: [id, function, args, expected, description]
  rows:
    - [hash_type_name_eq_HASH,
       "sha256().__class__.__name__.__eq__",
       ["HASH"],
       true,
       "type(hashlib.sha256()).__name__.__eq__('HASH') == True — the CPython HASH C-extension type is named 'HASH' (4 uppercase characters); __name__ reflects the C type registration; new anchor in extra233 namespace; verified Python 3.14.3"]
    - [hash_type_module_eq_hashlib,
       "sha256().__class__.__module__.__eq__",
       ["_hashlib"],
       true,
       "type(hashlib.sha256()).__module__.__eq__('_hashlib') == True — HASH type is implemented in the _hashlib C extension; __module__ is '_hashlib' not 'hashlib'; new anchor in extra233 namespace; verified Python 3.14.3"]
    - [hash_type_name_len_4,
       "sha256().__class__.__name__.__len__",
       [],
       4,
       "type(hashlib.sha256()).__name__.__len__() == 4 — the string 'HASH' has 4 characters; portable length anchor for HASH type name; new anchor in extra233 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# hashlib.Hash method qualname contracts
#
# type(hashlib.sha256()).update.__qualname__    == 'HASH.update'
# type(hashlib.sha256()).digest.__qualname__    == 'HASH.digest'
# type(hashlib.sha256()).hexdigest.__qualname__ == 'HASH.hexdigest'
#
# Method qualnames include the class name as a prefix 'HASH.' followed by
# the method name. This reflects the class scope for method descriptors.
# ---------------------------------------------------------------------------

table hashlib_extra233.hash_method_qualnames:
  description: "update.__qualname__=='HASH.update'; digest.__qualname__=='HASH.digest'; hexdigest.__qualname__=='HASH.hexdigest'; Hash method qualname contracts; new to extra233"
  kind: python_call_eq
  category: identity
  id_prefix: hashlib233b

  columns: [id, function, args, expected, description]
  rows:
    - [update_qualname_eq,
       "sha256().__class__.update.__qualname__.__eq__",
       ["HASH.update"],
       true,
       "type(hashlib.sha256()).update.__qualname__.__eq__('HASH.update') == True — update method qualname includes the HASH class prefix; __qualname__ is 'HASH.update' (11 characters); new anchor in extra233 namespace; verified Python 3.14.3"]
    - [digest_qualname_eq,
       "sha256().__class__.digest.__qualname__.__eq__",
       ["HASH.digest"],
       true,
       "type(hashlib.sha256()).digest.__qualname__.__eq__('HASH.digest') == True — digest method qualname is 'HASH.digest' (11 characters); same length as HASH.update; new anchor in extra233 namespace; verified Python 3.14.3"]
    - [hexdigest_qualname_eq,
       "sha256().__class__.hexdigest.__qualname__.__eq__",
       ["HASH.hexdigest"],
       true,
       "type(hashlib.sha256()).hexdigest.__qualname__.__eq__('HASH.hexdigest') == True — hexdigest method qualname is 'HASH.hexdigest' (14 characters); new anchor in extra233 namespace; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant hashlib_extra233.update_name_eq_update:
  description: "type(hashlib.sha256()).update.__name__.__eq__('update') == True — update is the primary method for feeding data into a hashlib Hash object; it accepts bytes-like objects and updates the running hash state in-place; __name__ is 'update' (6 characters); the HASH type is the CPython C-extension class (_hashlib); prior hashlib specs anchor digest vectors and algorithm attributes but extra233 is the first namespace to anchor Hash method names directly on the type; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "sha256().__class__.update.__name__.__eq__"
  args: ["update"]
  expected: true

invariant hashlib_extra233.hash_type_name_eq_HASH:
  description: "type(hashlib.sha256()).__name__.__eq__('HASH') == True — the CPython hashlib Hash objects are instances of the HASH C type defined in Modules/_hashopenssl.c; the type's __name__ is 'HASH' (4 uppercase characters); __module__ is '_hashlib'; this reflects the internal C registration; on non-CPython implementations the type name may differ; prior hashlib specs anchor algorithm names and digest_size but extra233 is the first to anchor the HASH type name itself; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "sha256().__class__.__name__.__eq__"
  args: ["HASH"]
  expected: true

invariant hashlib_extra233.hexdigest_name_len_9:
  description: "type(hashlib.sha256()).hexdigest.__name__.__len__() == 9 — hexdigest is the Hash method that returns the digest as a lowercase hex string; its __name__ is 'hexdigest' (9 characters); 3 characters longer than 'digest' (6 characters); the prefix 'hex' indicates the hexadecimal encoding; copy.__name__ is 4 characters, update and digest are both 6; extra233 is the first namespace to anchor hexdigest method name length; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "sha256().__class__.hexdigest.__name__.__len__"
  args: []
  expected: 9
