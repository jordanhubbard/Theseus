spec: ft3466
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 678 (ft3466): __iter__, __next__, __len__ dict-presence checks for functools types."
    - "All values False — functools types are callable/descriptor helpers with no iterator or sizing protocol."
    - "functools.partial and functools._lru_cache_wrapper are C-level types; functools.partialmethod and functools.cached_property are Python-level classes."
    - "type(functools.lru_cache(lambda: None)) accesses the internal _lru_cache_wrapper C type at runtime."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft3466.iter:
  description: "functools types __iter__ dict-presence checks; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ft3466
  columns: [id, function, args, expected]
  rows:
    - ["ft3466001", operator.contains, [functools.partial.__dict__,                          "__iter__"], false]
    - ["ft3466002", operator.contains, [functools.partialmethod.__dict__,                    "__iter__"], false]
    - ["ft3466003", operator.contains, [functools.cached_property.__dict__,                  "__iter__"], false]
    - ["ft3466004", operator.contains, [type(functools.lru_cache(lambda: None)).__dict__,    "__iter__"], false]

