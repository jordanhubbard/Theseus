spec: re_extra240
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra22.zspec.zsdl — covers Match.__name__ == 'Match' and Match.__module__ == 're'"
    - "re_extra9.zspec.zsdl — covers Match.__qualname__ == 'Match'"
    - "re_extra24.zspec.zsdl — covers Match.__qualname__.__len__() == 5"
  notes:
    - "This spec covers: re.Match object method identity contracts — class identity and method __name__ / __qualname__ checks."
    - "re.Match.__name__ == 'Match' — the class name is 5 characters; verified Python 3.14.3 macOS."
    - "re.Match.__module__ == 're' — Match is defined in the 're' module (not '_sre'); verified Python 3.14.3 macOS."
    - "re.Match.__bases__[0].__name__ == 'object' — Match inherits directly from object; verified Python 3.14.3 macOS."
    - "re.Match.__qualname__ == 'Match' — qualname matches __name__ for a top-level class; verified Python 3.14.3 macOS."
    - "re.Match.__class__.__name__ == 'type' — Match is a class object; verified Python 3.14.3 macOS."
    - "re.Match.group.__name__ == 'group' — length 5; verified Python 3.14.3 macOS."
    - "re.Match.group.__qualname__ == 'Match.group' — length 11; verified Python 3.14.3 macOS."
    - "re.Match.groups.__name__ == 'groups' — length 6; verified Python 3.14.3 macOS."
    - "re.Match.groups.__qualname__ == 'Match.groups' — length 12; verified Python 3.14.3 macOS."
    - "re.Match.start.__name__ == 'start' — length 5; verified Python 3.14.3 macOS."
    - "re.Match.start.__qualname__ == 'Match.start' — length 11; verified Python 3.14.3 macOS."
    - "re.Match.end.__name__ == 'end' — length 3; verified Python 3.14.3 macOS."
    - "re.Match.end.__qualname__ == 'Match.end' — length 9; verified Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match class identity contracts
# These verify the class object's identity attributes.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra240.Match.name_eq:
  description: "re.Match.__name__ == 'Match' — class name is 'Match'; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra240.Match.name_len:
  description: "len(re.Match.__name__) == 5 — 'Match' has 5 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Match.__name__.__len__
  args: []
  expected: 5

invariant re_extra240.Match.module_eq:
  description: "re.Match.__module__ == 're' — Match is defined in the 're' module; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra240.Match.module_len:
  description: "len(re.Match.__module__) == 2 — 're' has 2 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Match.__module__.__len__
  args: []
  expected: 2

invariant re_extra240.Match.qualname_eq:
  description: "re.Match.__qualname__ == 'Match' — qualname matches __name__ for a top-level class; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Match.__qualname__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra240.Match.class_is_type:
  description: "re.Match.__class__.__name__ == 'type' — Match is a class object (its metaclass is type); verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Match.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# re.Match.__bases__[0].__name__ identity contract
# Match inherits directly from object.
# Accessed via __bases__.__getitem__(0).__name__.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra240.Match.base_name:
  description: "re.Match.__bases__[0].__name__ == 'object' — Match inherits directly from object; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Match.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

invariant re_extra240.Match.base_name_len:
  description: "len(re.Match.__bases__[0].__name__) == 6 — 'object' has 6 characters; verified Python 3.14.3 macOS"
  category: class_identity
  kind: python_call_eq
  function: Match.__bases__.__getitem__
  args: [0]
  method: __name__
  method_chain: __len__
  expected: 6

# ---------------------------------------------------------------------------
# re.Match method name identity contracts
# group, groups, start, end are the primary Match methods.
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

invariant re_extra240.Match.group.name_eq:
  description: "re.Match.group.__name__ == 'group' — method name is 'group'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Match.group.__name__.__eq__
  args: ["group"]
  expected: true

invariant re_extra240.Match.group.qualname_eq:
  description: "re.Match.group.__qualname__ == 'Match.group' — qualname is 'Match.group'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Match.group.__qualname__.__eq__
  args: ["Match.group"]
  expected: true

invariant re_extra240.Match.groups.name_eq:
  description: "re.Match.groups.__name__ == 'groups' — method name is 'groups'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Match.groups.__name__.__eq__
  args: ["groups"]
  expected: true

invariant re_extra240.Match.groups.qualname_eq:
  description: "re.Match.groups.__qualname__ == 'Match.groups' — qualname is 'Match.groups'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Match.groups.__qualname__.__eq__
  args: ["Match.groups"]
  expected: true

invariant re_extra240.Match.start.name_eq:
  description: "re.Match.start.__name__ == 'start' — method name is 'start'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Match.start.__name__.__eq__
  args: ["start"]
  expected: true

invariant re_extra240.Match.end.name_eq:
  description: "re.Match.end.__name__ == 'end' — method name is 'end'; verified Python 3.14.3 macOS"
  category: method_identity
  kind: python_call_eq
  function: Match.end.__name__.__eq__
  args: ["end"]
  expected: true

# ---------------------------------------------------------------------------
# Table: re.Match method __name__ lengths — group, groups, start, end
# All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11.
# ---------------------------------------------------------------------------

table re_extra240.Match_method_name_lengths:
  description: "re.Match method __name__ lengths — group, groups, start, end; verified Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: rematch240

  columns: [id, function, args, expected]
  rows:
    - [group_name_len,  Match.group.__name__.__len__,  [], 5]
    - [groups_name_len, Match.groups.__name__.__len__, [], 6]
    - [start_name_len,  Match.start.__name__.__len__,  [], 5]
    - [end_name_len,    Match.end.__name__.__len__,    [], 3]

