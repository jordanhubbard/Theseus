  id_prefix: rematchm240

  columns: [id, function, args, expected]
  rows:
    - [group_qualname_len,  Match.group.__qualname__.__len__,  [], 11]
    - [groups_qualname_len, Match.groups.__qualname__.__len__, [], 12]
    - [start_qualname_len,  Match.start.__qualname__.__len__,  [], 11]
