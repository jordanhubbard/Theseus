spec: _weakref_extra
version: ">=3.9"
backend: python_module(_weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
  notes:
    - "This spec extends the _weakref C accelerator module."
    - "Extends weakref.zspec.zsdl, weakref_extra.zspec.zsdl, weakref_extra2.zspec.zsdl, and _weakref.zspec.zsdl."
    - "_weakref.zspec.zsdl covers: ref/__name__=='weakref', ProxyType/__name__=='weakproxy', CallableProxyType/__name__=='weakcallableproxy', ReferenceType/__name__=='weakref', getweakrefcount/__name__, getweakrefs/__name__, getweakrefcount([]) returns 0, getweakrefs([]) returns empty list, ref/__module__=='_weakref', ProxyType/__module__=='_weakref'."
    - "This spec adds: proxy/__name__, proxy/__module__, getweakrefcount/__module__, getweakrefs/__module__, ReferenceType is_type, CallableProxyType/__module__, ReferenceType/__module__, ref is_type, ProxyType is_type."
    - "_weakref.ref.__name__ == 'weakref' — the C type's tp_name is 'weakref'."
    - "_weakref.proxy.__name__ == 'weakproxy' — proxy() is a C builtin that returns a non-callable proxy; the function itself is named 'proxy'."
    - "_weakref.ReferenceType is the same object as _weakref.ref — an alias; __name__ is 'weakref'."
    - "_weakref.ProxyType.__name__ == 'weakproxy' — non-callable proxy C type."
    - "_weakref.CallableProxyType.__name__ == 'weakcallableproxy' — callable proxy C type."
    - "_weakref.getweakrefcount and _weakref.getweakrefs are C builtin functions from the _weakref extension."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# C type name checks
# ---------------------------------------------------------------------------

invariant _weakref_extra.ref.name:
  description: "_weakref.ref.__name__ == 'weakref' — the C type tp_name"
  category: type_names
  kind: python_call_eq
  function: ref.__name__.__eq__
  args: ["weakref"]
  expected: true

invariant _weakref_extra.ref.is_type:
  description: "_weakref.ref.__class__.__name__ == 'type' — ref is a class object"
  category: type_names
  kind: python_call_eq
  function: ref.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant _weakref_extra.ProxyType.name:
  description: "_weakref.ProxyType.__name__ == 'weakproxy'"
  category: type_names
  kind: python_call_eq
  function: ProxyType.__name__.__eq__
  args: ["weakproxy"]
  expected: true

invariant _weakref_extra.ProxyType.is_type:
  description: "_weakref.ProxyType.__class__.__name__ == 'type' — ProxyType is a class object"
  category: type_names
  kind: python_call_eq
  function: ProxyType.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant _weakref_extra.CallableProxyType.name:
  description: "_weakref.CallableProxyType.__name__ == 'weakcallableproxy'"
  category: type_names
  kind: python_call_eq
  function: CallableProxyType.__name__.__eq__
  args: ["weakcallableproxy"]
  expected: true

invariant _weakref_extra.CallableProxyType.is_type:
  description: "_weakref.CallableProxyType.__class__.__name__ == 'type' — CallableProxyType is a class object"
  category: type_names
  kind: python_call_eq
  function: CallableProxyType.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant _weakref_extra.ReferenceType.name:
  description: "_weakref.ReferenceType.__name__ == 'weakref' — ReferenceType is an alias for ref"
  category: type_names
  kind: python_call_eq
  function: ReferenceType.__name__.__eq__
  args: ["weakref"]
  expected: true

invariant _weakref_extra.ReferenceType.is_type:
  description: "_weakref.ReferenceType.__class__.__name__ == 'type' — ReferenceType is a class object"
  category: type_names
  kind: python_call_eq
  function: ReferenceType.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant _weakref_extra.getweakrefcount.name:
  description: "_weakref.getweakrefcount.__name__ == 'getweakrefcount'"
  category: function_names
  kind: python_call_eq
  function: getweakrefcount.__name__.__eq__
  args: ["getweakrefcount"]
  expected: true

invariant _weakref_extra.getweakrefs.name:
  description: "_weakref.getweakrefs.__name__ == 'getweakrefs'"
  category: function_names
  kind: python_call_eq
  function: getweakrefs.__name__.__eq__
  args: ["getweakrefs"]
  expected: true

invariant _weakref_extra.proxy.name:
  description: "_weakref.proxy.__name__ == 'proxy' — the C builtin function name"
  category: function_names
  kind: python_call_eq
  function: proxy.__name__.__eq__
  args: ["proxy"]
  expected: true

# ---------------------------------------------------------------------------
# Module checks — all types and functions live in _weakref
# ---------------------------------------------------------------------------

invariant _weakref_extra.ref.module:
  description: "_weakref.ref.__module__ == '_weakref'"
  category: modules
  kind: python_call_eq
  function: ref.__module__.__eq__
  args: ["_weakref"]
  expected: true

invariant _weakref_extra.CallableProxyType.module:
  description: "_weakref.CallableProxyType.__module__ == '_weakref'"
  category: modules
  kind: python_call_eq
  function: CallableProxyType.__module__.__eq__
  args: ["_weakref"]
  expected: true

invariant _weakref_extra.ReferenceType.module:
  description: "_weakref.ReferenceType.__module__ == '_weakref'"
  category: modules
  kind: python_call_eq
  function: ReferenceType.__module__.__eq__
  args: ["_weakref"]
  expected: true
