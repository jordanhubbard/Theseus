spec: functools_extra287
version: ">=3.2"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools._lru_cache_wrapper is a C-level type: __class__.__name__ == 'type', __module__ == 'functools', __name__ == '_lru_cache_wrapper'."
    - "_lru_cache_wrapper.__doc__ is not None — the C type ships with a detailed docstring."
    - "functools.partial is a C-level type: __class__.__name__ == 'type', __module__ == 'functools', __name__ == 'partial'."
    - "functools.partial.__doc__ is not None — partial ships with a docstring."
    - "functools.reduce is a C builtin function: __class__.__name__ == 'builtin_function_or_method', __module__ == '_functools'."
    - "functools.reduce.__doc__ is not None — reduce ships with a docstring."
    - "functools.cmp_to_key is a C builtin function: __class__.__name__ == 'builtin_function_or_method', __module__ == '_functools'."
    - "functools.cmp_to_key.__doc__ is not None — cmp_to_key ships with a docstring."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools._lru_cache_wrapper and functools.partial — C builtin docstrings
#
# _lru_cache_wrapper is a C-level type: __class__.__name__ == 'type'.
# partial is a C-level type: __class__.__name__ == 'type'.
# Both ship with non-None docstrings accessible at __doc__.
# ---------------------------------------------------------------------------

table functools_extra287.c_type_docstrings:
  description: "functools._lru_cache_wrapper and partial — C-level types with non-None docstrings; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex287cd

  columns: [id, function, args, expected, description]
  rows:
    - [cd_lru_doc,    _lru_cache_wrapper.__doc__.__eq__,           [null],              false, "functools._lru_cache_wrapper.__doc__ is not None — C type ships with a docstring; verified with Python 3.14.3"]
    - [cd_lru_cls,    _lru_cache_wrapper.__class__.__name__.__eq__, ["type"],            true,  "functools._lru_cache_wrapper.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [cd_lru_mod,    _lru_cache_wrapper.__module__.__eq__,         ["functools"],       true,  "functools._lru_cache_wrapper.__module__ == 'functools'; verified with Python 3.14.3"]
    - [cd_lru_name,   _lru_cache_wrapper.__name__.__eq__,           ["_lru_cache_wrapper"], true, "functools._lru_cache_wrapper.__name__ == '_lru_cache_wrapper'; verified with Python 3.14.3"]
    - [cd_par_doc,    partial.__doc__.__eq__,                       [null],              false, "functools.partial.__doc__ is not None — C type ships with a docstring; verified with Python 3.14.3"]
    - [cd_par_cls,    partial.__class__.__name__.__eq__,            ["type"],            true,  "functools.partial.__class__.__name__ == 'type' (C-level type); verified with Python 3.14.3"]
    - [cd_par_mod,    partial.__module__.__eq__,                    ["functools"],       true,  "functools.partial.__module__ == 'functools'; verified with Python 3.14.3"]
    - [cd_par_name,   partial.__name__.__eq__,                      ["partial"],         true,  "functools.partial.__name__ == 'partial'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools.reduce and functools.cmp_to_key — C builtin function docstrings
#
# reduce is a C builtin: __class__.__name__ == 'builtin_function_or_method', __module__ == '_functools'.
# cmp_to_key is a C builtin: __class__.__name__ == 'builtin_function_or_method', __module__ == '_functools'.
# Both ship with non-None docstrings.
# ---------------------------------------------------------------------------

table functools_extra287.c_builtin_docstrings:
  description: "functools.reduce and cmp_to_key — C builtin functions with non-None docstrings; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex287cb

  columns: [id, function, args, expected, description]
  rows:
    - [cb_red_doc,    reduce.__doc__.__eq__,                       [null],                       false, "functools.reduce.__doc__ is not None — C builtin ships with a docstring; verified with Python 3.14.3"]
    - [cb_red_cls,    reduce.__class__.__name__.__eq__,            ["builtin_function_or_method"], true, "functools.reduce.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]
    - [cb_red_mod,    reduce.__module__.__eq__,                    ["_functools"],                true, "functools.reduce.__module__ == '_functools' (implemented in C extension); verified with Python 3.14.3"]
    - [cb_red_name,   reduce.__name__.__eq__,                      ["reduce"],                   true, "functools.reduce.__name__ == 'reduce'; verified with Python 3.14.3"]
    - [cb_cmp_doc,    cmp_to_key.__doc__.__eq__,                   [null],                       false, "functools.cmp_to_key.__doc__ is not None — C builtin ships with a docstring; verified with Python 3.14.3"]
    - [cb_cmp_cls,    cmp_to_key.__class__.__name__.__eq__,        ["builtin_function_or_method"], true, "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]
    - [cb_cmp_mod,    cmp_to_key.__module__.__eq__,                ["_functools"],                true, "functools.cmp_to_key.__module__ == '_functools' (implemented in C extension); verified with Python 3.14.3"]
    - [cb_cmp_name,   cmp_to_key.__name__.__eq__,                  ["cmp_to_key"],               true, "functools.cmp_to_key.__name__ == 'cmp_to_key'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra287
# ---------------------------------------------------------------------------

invariant functools_extra287.lru_cache_wrapper_has_docstring:
  description: "functools._lru_cache_wrapper.__doc__.__eq__(None) == False — the C type ships with a non-None docstring"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.__doc__.__eq__
  args: [null]
  expected: false

invariant functools_extra287.lru_cache_wrapper_is_type:
  description: "functools._lru_cache_wrapper.__class__.__name__ == 'type' — _lru_cache_wrapper is a C-level type object"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra287.lru_cache_wrapper_module_is_functools:
  description: "functools._lru_cache_wrapper.__module__ == 'functools' — _lru_cache_wrapper is registered in the functools module"
  category: identity
  kind: python_call_eq
  function: _lru_cache_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra287.partial_has_docstring:
  description: "functools.partial.__doc__.__eq__(None) == False — partial ships with a non-None docstring"
  category: identity
  kind: python_call_eq
  function: partial.__doc__.__eq__
  args: [null]
  expected: false

invariant functools_extra287.partial_is_type:
  description: "functools.partial.__class__.__name__ == 'type' — partial is a C-level type, not a function"
  category: identity
  kind: python_call_eq
  function: partial.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra287.reduce_has_docstring:
  description: "functools.reduce.__doc__.__eq__(None) == False — reduce ships with a non-None docstring"
  category: identity
  kind: python_call_eq
  function: reduce.__doc__.__eq__
  args: [null]
  expected: false

invariant functools_extra287.reduce_is_builtin:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin function"
  category: identity
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra287.reduce_module_is_c_functools:
  description: "functools.reduce.__module__ == '_functools' — reduce is implemented in the _functools C extension"
  category: identity
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra287.cmp_to_key_has_docstring:
  description: "functools.cmp_to_key.__doc__.__eq__(None) == False — cmp_to_key ships with a non-None docstring"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__doc__.__eq__
  args: [null]
  expected: false

invariant functools_extra287.cmp_to_key_is_builtin:
  description: "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C builtin function"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra287.cmp_to_key_module_is_c_functools:
  description: "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is implemented in the _functools C extension"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true
