spec: struct_extra102
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra101.zspec.zsdl — covers struct.error class identity (__name__/__module__/__bases__[0].__name__/__mro__.__len__()==4/__class__.__name__=='type') / Struct class attribute equality / Struct method types (wrapper_descriptor/method_descriptor) and instance size (table + invariants)."
    - "struct_extra100.zspec.zsdl — covers Struct instance method qualname lengths / module-level function qualname lengths / Struct class-level method_descriptor type names (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers module-level function __doc__ lengths / Struct.size/__format__ __doc__ equality and lengths / struct module __doc__ length (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / descriptor qualname/name lengths and __objclass__.__name__ / Struct.__doc__ length (table + invariants)."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6 (table + invariants)."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() and error.__name__/__len__() (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__() (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / error __bases__/__module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra101; it does NOT duplicate invariants present in those files."
    - "Wave 268 theme: struct.calcsize for various format strings using network byte order prefix '!' for standard (platform-independent) sizes."
    - "struct.calcsize('!B') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!H') == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!I') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!Q') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!b') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!h') == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!i') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!q') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!f') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!d') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!BH') == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!IQ') == 12. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!4s') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('c') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('x') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!HH') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('!II') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: The '!' prefix selects network byte order (big-endian) with standard sizes (same as '>'). Standard sizes: B/b=1, H/h=2, I/i=4, Q/q=8, f=4, d=8. No alignment padding is added in standard mode."
    - "Note: 'c' (char) and 'x' (pad byte) always have size 1 regardless of byte order prefix. '4s' (4-char string) has size 4 regardless of byte order."
    - "Note: No prior struct spec anchors struct.calcsize return values as a grouped table under structcalc102."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize('!B')==1 / struct.calcsize('!H')==2
# struct.calcsize('!I')==4 / struct.calcsize('!Q')==8
# struct.calcsize('!b')==1
#
# Wave 268 theme: struct.calcsize for unsigned integer format codes with '!'.
#
# The '!' prefix (network byte order) selects standard sizes: B (unsigned
# char) = 1 byte, H (unsigned short) = 2 bytes, I (unsigned int) = 4 bytes,
# Q (unsigned long long) = 8 bytes. The corresponding signed codes b, h, i, q
# have the same standard sizes. calcsize returns the number of bytes required
# to represent the given format string. No prior struct spec anchors
# struct.calcsize return values as a grouped table under structcalc102.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra102.calcsize_unsigned_network_order:
  description: "calcsize('!B')==1 / calcsize('!H')==2 / calcsize('!I')==4 / calcsize('!Q')==8 / calcsize('!b')==1 — '!' prefix gives network byte order (big-endian) with standard sizes; unsigned B/H/I/Q are 1/2/4/8 bytes; signed b is also 1 byte; no alignment padding in '!' mode; no prior struct spec anchors calcsize values; first structcalc102 anchor"
  kind: python_call_eq
  category: calcsize
  id_prefix: structcalc102

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_net_B,  "calcsize", ["!B"],  1, "calcsize('!B')==1 — unsigned char B is 1 byte in standard/network mode"]
    - [calcsize_net_H,  "calcsize", ["!H"],  2, "calcsize('!H')==2 — unsigned short H is 2 bytes in standard/network mode"]
    - [calcsize_net_I,  "calcsize", ["!I"],  4, "calcsize('!I')==4 — unsigned int I is 4 bytes in standard/network mode"]
    - [calcsize_net_Q,  "calcsize", ["!Q"],  8, "calcsize('!Q')==8 — unsigned long long Q is 8 bytes in standard/network mode"]
    - [calcsize_net_b,  "calcsize", ["!b"],  1, "calcsize('!b')==1 — signed char b is 1 byte in standard/network mode (same size as unsigned B)"]

# ---------------------------------------------------------------------------
# struct.calcsize('!h')==2 / struct.calcsize('!i')==4
# struct.calcsize('!q')==8 / struct.calcsize('!f')==4
# struct.calcsize('!d')==8
#
# Wave 268 theme: struct.calcsize for signed integer and float codes with '!'.
#
# Signed codes h, i, q have the same standard sizes as their unsigned
# counterparts H, I, Q: 2, 4, 8 bytes. IEEE 754 floats: f (single) = 4 bytes,
# d (double) = 8 bytes. These sizes are guaranteed regardless of platform
# when using '!' or other standard byte order prefixes ('>','<','=').
# No prior struct spec anchors these calcsize values under structcalc102.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra102.calcsize_signed_and_float_network_order:
  description: "calcsize('!h')==2 / calcsize('!i')==4 / calcsize('!q')==8 / calcsize('!f')==4 / calcsize('!d')==8 — signed h/i/q have same standard sizes as H/I/Q (2/4/8 bytes); f=4 (IEEE 754 single) and d=8 (IEEE 754 double); sizes guaranteed regardless of platform in standard mode ('!'/'>''/'<'/'='); no prior struct spec anchors these calcsize values; first structcalc102 anchor for signed and float sizes"
  kind: python_call_eq
  category: calcsize
  id_prefix: structcalc102

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_net_h,  "calcsize", ["!h"],  2, "calcsize('!h')==2 — signed short h is 2 bytes in standard mode (same as unsigned H)"]
    - [calcsize_net_i,  "calcsize", ["!i"],  4, "calcsize('!i')==4 — signed int i is 4 bytes in standard mode (same as unsigned I)"]
    - [calcsize_net_q,  "calcsize", ["!q"],  8, "calcsize('!q')==8 — signed long long q is 8 bytes in standard mode (same as unsigned Q)"]
    - [calcsize_net_f,  "calcsize", ["!f"],  4, "calcsize('!f')==4 — IEEE 754 single-precision float f is 4 bytes in standard mode"]
    - [calcsize_net_d,  "calcsize", ["!d"],  8, "calcsize('!d')==8 — IEEE 754 double-precision float d is 8 bytes in standard mode"]

# ---------------------------------------------------------------------------
# struct.calcsize('!BH')==3 / struct.calcsize('!IQ')==12
# struct.calcsize('!4s')==4 / struct.calcsize('c')==1
# struct.calcsize('x')==1
#
# Wave 268 theme: struct.calcsize for composite formats and special codes.
#
# Composite format '!BH' packs B(1)+H(2)=3 bytes with no padding in standard
# mode. '!IQ' packs I(4)+Q(8)=12 bytes. '!4s' is a 4-char bytes string =
# 4 bytes. 'c' (char) is always 1 byte; 'x' (pad byte) is always 1 byte.
# The '!' prefix removes alignment padding that the native '@'/'=' mode
# might add. No prior struct spec anchors composite calcsize values under
# structcalc102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra102.calcsize_composite_and_special:
  description: "calcsize('!BH')==3 / calcsize('!IQ')==12 / calcsize('!4s')==4 / calcsize('c')==1 / calcsize('x')==1 — composite BH=B(1)+H(2)=3 (no padding in '!' mode); IQ=I(4)+Q(8)=12; 4s=4-char bytes string=4; c (char) and x (pad byte) are always 1 regardless of prefix; '!' removes alignment padding vs native mode; no prior struct spec anchors composite calcsize; first structcalc102 anchor"
  kind: python_call_eq
  category: calcsize
  id_prefix: structcalc102

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_net_BH,  "calcsize", ["!BH"],  3,  "calcsize('!BH')==3 — B(1)+H(2)=3 bytes; no alignment padding in '!' standard mode"]
    - [calcsize_net_IQ,  "calcsize", ["!IQ"],  12, "calcsize('!IQ')==12 — I(4)+Q(8)=12 bytes; no alignment padding in '!' standard mode"]
    - [calcsize_net_4s,  "calcsize", ["!4s"],  4,  "calcsize('!4s')==4 — 4-char bytes string is 4 bytes (count prefix applies to 's' format)"]
    - [calcsize_c,       "calcsize", ["c"],    1,  "calcsize('c')==1 — char c is always 1 byte regardless of byte order prefix"]
    - [calcsize_x,       "calcsize", ["x"],    1,  "calcsize('x')==1 — pad byte x is always 1 byte regardless of byte order prefix"]

# ---------------------------------------------------------------------------
# struct.calcsize('!Q')==8 — standalone
#
# struct.calcsize('!Q') is 8. The 'Q' format code represents an unsigned
# long long in struct packing. In standard mode ('!' = network byte order),
# 'Q' is guaranteed to be exactly 8 bytes (64-bit unsigned integer), regardless
# of the platform's native unsigned long long size. This is the largest
# standard scalar size in struct format strings. No prior struct spec anchors
# struct.calcsize('!Q') as a standalone under structcalc102.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra102.calcsize_net_Q_eq_8:
  description: "struct.calcsize('!Q') == 8 — 'Q' is unsigned long long; standard mode '!' guarantees 8 bytes (64-bit) regardless of platform; largest standard scalar size in struct format strings; no prior struct spec anchors calcsize('!Q') as standalone; first standalone under structcalc102"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!Q"]
  expected: 8

# ---------------------------------------------------------------------------
# struct.calcsize('!I')==4 — standalone
#
# struct.calcsize('!I') is 4. The 'I' format code represents an unsigned int
# in struct packing. In standard mode ('!'), 'I' is guaranteed to be exactly
# 4 bytes (32-bit unsigned integer). This is one of the most commonly used
# struct format codes — it matches the size of a C uint32_t or network
# protocol 4-byte unsigned fields. struct_extra101 anchors Struct('I').size==4
# (via Struct instance attribute); no prior struct spec anchors calcsize('!I')
# as a standalone function call under structcalc102.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra102.calcsize_net_I_eq_4:
  description: "struct.calcsize('!I') == 4 — 'I' is unsigned int; standard mode '!' guarantees 4 bytes (32-bit); most common network protocol size for length fields and IP addresses; extra101 anchors Struct('I').size==4 via Struct instance; first standalone for calcsize('!I') function call under structcalc102"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!I"]
  expected: 4

# ---------------------------------------------------------------------------
# struct.calcsize('!d')==8 — standalone
#
# struct.calcsize('!d') is 8. The 'd' format code represents a double-
# precision IEEE 754 floating-point number. In standard mode ('!'), 'd' is
# guaranteed to be exactly 8 bytes (64-bit double). This matches the C
# double size on all platforms that support IEEE 754. The 'd' format allows
# packing 64-bit floats into binary protocols that require cross-platform
# compatibility. No prior struct spec anchors calcsize('!d') as a standalone
# under structcalc102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra102.calcsize_net_d_eq_8:
  description: "struct.calcsize('!d') == 8 — 'd' is IEEE 754 double; standard mode '!' guarantees 8 bytes (64-bit float); matches C double on all IEEE 754 platforms; used for cross-platform 64-bit float binary protocols; no prior struct spec anchors calcsize('!d') as standalone; first standalone under structcalc102"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!d"]
  expected: 8

# ---------------------------------------------------------------------------
# struct.calcsize('!BH')==3 — standalone
#
# struct.calcsize('!BH') is 3. In standard/network byte order mode ('!'),
# composite formats have no alignment padding. B (1 byte) + H (2 bytes) = 3
# bytes total. In native mode ('@'), B+H might be 4 bytes due to alignment
# (H would be padded to align to a 2-byte boundary after B, giving 1+1+2=4).
# The '!' prefix removes this padding, giving the exact sum of component sizes.
# No prior struct spec anchors calcsize('!BH') as a standalone under
# structcalc102. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra102.calcsize_net_BH_eq_3:
  description: "struct.calcsize('!BH') == 3 — B(1)+H(2)=3 bytes; '!' removes alignment padding that native '@' mode might add (B+padding+H=4 in native); standard mode always gives exact sum of component sizes; demonstrates padding elimination; no prior struct spec anchors calcsize('!BH') as standalone; first standalone under structcalc102"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["!BH"]
  expected: 3

# ---------------------------------------------------------------------------
# struct.calcsize('x')==1 — standalone
#
# struct.calcsize('x') is 1. The 'x' format code is a pad byte — it
# contributes one byte to the packed data but is not stored or loaded when
# packing or unpacking. It is used to insert padding bytes for alignment
# in protocol messages. The pad byte 'x' always occupies exactly 1 byte
# regardless of any byte order prefix. No prior struct spec anchors
# calcsize('x') as a standalone under structcalc102.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra102.calcsize_x_eq_1:
  description: "struct.calcsize('x') == 1 — 'x' is a pad byte; contributes 1 byte to packed data but is not stored/loaded during pack/unpack; used for alignment in protocol messages; always 1 byte regardless of byte order prefix; no prior struct spec anchors calcsize('x') as standalone; first standalone under structcalc102"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["x"]
  expected: 1
