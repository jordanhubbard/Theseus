spec: asyncio_extra1006
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio Task and Future documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks asyncio.Task and asyncio.Future method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table asyncio_extra1006.task_method_qualnames:
  description: "asyncio.Task method __qualname__ identity"
  kind: python_call_eq
  category: task_qualnames
  id_prefix: as1006tq
  columns: [id, function, args, expected]
  rows:
    - [as1006tq001, asyncio.Task.cancel.__qualname__.__eq__,            ["Task.cancel"],            true]
    - [as1006tq002, asyncio.Task.cancelled.__qualname__.__eq__,         ["Task.cancelled"],         true]
    - [as1006tq003, asyncio.Task.done.__qualname__.__eq__,              ["Task.done"],              true]
    - [as1006tq004, asyncio.Task.result.__qualname__.__eq__,            ["Task.result"],            true]
    - [as1006tq005, asyncio.Task.exception.__qualname__.__eq__,         ["Task.exception"],         true]
    - [as1006tq006, asyncio.Task.add_done_callback.__qualname__.__eq__, ["Task.add_done_callback"], true]

table asyncio_extra1006.future_method_qualnames:
  description: "asyncio.Future method __qualname__ identity"
  kind: python_call_eq
  category: future_qualnames
  id_prefix: as1006fq
  columns: [id, function, args, expected]
  rows:
    - [as1006fq001, asyncio.Future.cancel.__qualname__.__eq__,    ["Future.cancel"],    true]
    - [as1006fq002, asyncio.Future.cancelled.__qualname__.__eq__, ["Future.cancelled"], true]
    - [as1006fq003, asyncio.Future.done.__qualname__.__eq__,      ["Future.done"],      true]
    - [as1006fq004, asyncio.Future.result.__qualname__.__eq__,    ["Future.result"],    true]

table asyncio_extra1006.task_module_identity:
  description: "asyncio.Task and asyncio.Future module and class identity"
  kind: python_call_eq
  category: module_identity
  id_prefix: as1006mi
  columns: [id, function, args, expected]
  rows:
    - [as1006mi001, asyncio.Task.__module__.__eq__,            ["asyncio.tasks"],   true]
    - [as1006mi002, asyncio.Future.__module__.__eq__,          ["asyncio.futures"], true]
    - [as1006mi003, asyncio.Task.__name__.__eq__,              ["Task"],            true]
    - [as1006mi004, asyncio.Future.__name__.__eq__,            ["Future"],          true]
    - [as1006mi005, asyncio.Task.__qualname__.__eq__,          ["Task"],            true]
    - [as1006mi006, asyncio.Future.__qualname__.__eq__,        ["Future"],          true]
