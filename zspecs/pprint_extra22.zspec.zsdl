spec: pprint_extra22
version: ">=3.9"
backend: python_module(pprint)

docs: https://docs.python.org/3/library/pprint.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pprint.html — Python pprint module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pprint.py"
  notes:
    - "This spec extends pprint_extra21.zspec.zsdl."
    - "Prior specs covered: pprint.__name__/__package__; module-level function __name__/__module__; PrettyPrinter __name__/__module__/__qualname__/__bases__; __qualname__ checks; __all__ type/length; PrettyPrinter method qualnames; __module__.__len__() for module-level functions; __name__.__len__() for all 6 module-level functions and PrettyPrinter (extra21); PrettyPrinter.__init__/__qualname__.__len__() (extra21); PrettyPrinter method name/qualname lens table (extra21)."
    - "This spec covers: pprint.__all__.__len__() (7 exports); PrettyPrinter.__mro__.__len__() (MRO depth); PrettyPrinter.__reduce__.__qualname__.__len__(); module-level function __qualname__.__len__() table; pprint.__all__ element name lengths table."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "pprint.__all__.__len__() == 7. Verified."
    - "pprint.PrettyPrinter.__mro__.__len__() == 2 (PrettyPrinter, object). Verified."
    - "pprint.PrettyPrinter.__reduce__.__qualname__ == 'object.__reduce__'; len == 17. Verified."
    - "pprint.pformat.__qualname__.__len__() == 7. Verified."
    - "pprint.isreadable.__qualname__.__len__() == 10. Verified."
    - "pprint.isrecursive.__qualname__.__len__() == 11. Verified."
    - "pprint.saferepr.__qualname__.__len__() == 8. Verified."
    - "pprint.pp.__qualname__.__len__() == 2. Verified."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pprint.__all__.__len__() — 7 public names exported
#
# pprint.__all__ == ['pprint', 'pformat', 'isreadable', 'isrecursive',
# 'saferepr', 'PrettyPrinter', 'pp'] — exactly 7 entries. pprint_extra21
# verified that __all__ exists but did not check __all__.__len__() as a
# standalone invariant. This invariant fills that gap in extra22.
# ---------------------------------------------------------------------------

invariant pprint_extra22.all.len:
  description: "pprint.__all__.__len__() == 7 — seven public names: pprint, pformat, isreadable, isrecursive, saferepr, PrettyPrinter, pp"
  category: module_all
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# pprint.PrettyPrinter.__mro__.__len__() — MRO depth 2 (PrettyPrinter, object)
#
# PrettyPrinter has no explicit base class beyond object. MRO is
# [PrettyPrinter, object], length 2. No prior pprint spec checks
# __mro__.__len__() for PrettyPrinter as a standalone invariant.
# ---------------------------------------------------------------------------

invariant pprint_extra22.PrettyPrinter.mro_len:
  description: "pprint.PrettyPrinter.__mro__.__len__() == 2 — MRO: [PrettyPrinter, object]"
  category: class_mro
  kind: python_call_eq
  function: PrettyPrinter.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# pprint.PrettyPrinter.__reduce__.__qualname__.__len__() — length of 'object.__reduce__' (17)
#
# PrettyPrinter does not define its own __reduce__; it inherits from object.
# Therefore PrettyPrinter.__reduce__.__qualname__ == 'object.__reduce__',
# which is 17 characters. No prior pprint spec checks this attribute chain.
# ---------------------------------------------------------------------------

invariant pprint_extra22.PrettyPrinter.reduce_qualname_len:
  description: "pprint.PrettyPrinter.__reduce__.__qualname__.__len__() == 17 — len('object.__reduce__') == 17; inherited from object"
  category: function_qualname
  kind: python_call_eq
  function: PrettyPrinter.__reduce__.__qualname__.__len__
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# pprint.PrettyPrinter.__bases__[0].__name__.__len__() — length of 'object' (6)
#
# PrettyPrinter.__bases__[0] is object; __name__ == 'object', len == 6.
# pprint_extra21 confirms that __bases__[0].__name__ == 'object' as an
# equality; this invariant adds the length check in extra22.
# ---------------------------------------------------------------------------

invariant pprint_extra22.PrettyPrinter.bases_name_len:
  description: "pprint.PrettyPrinter.__bases__[0].__name__.__len__() == 6 — len('object') == 6"
  category: class_mro
  kind: python_call_eq
  function: "PrettyPrinter.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Table: module-level function __qualname__.__len__() — extra22 namespace
#
# All six module-level pprint functions are top-level definitions in
# Lib/pprint.py; their __qualname__ equals their __name__. Therefore
# __qualname__.__len__() == __name__.__len__() for each. pprint_extra21
# verified __name__.__len__() for all 6; this table confirms the
# qualname==name invariant by measuring qualname lengths directly in extra22.
# id_prefix pp22ql is novel.
# ---------------------------------------------------------------------------

table pprint_extra22.module_level_qualname_lens:
  description: "pprint module-level function __qualname__.__len__() — equals __name__.__len__() for all (top-level definitions)"
  kind: python_call_eq
  category: function_qualname
  id_prefix: pp22ql

  columns: [id, function, args, expected]
  rows:
    - [pprint_func_ql,  pprint.__qualname__.__len__,      [], 6]
    - [pformat_ql,      pformat.__qualname__.__len__,      [], 7]
    - [isreadable_ql,   isreadable.__qualname__.__len__,   [], 10]
    - [isrecursive_ql,  isrecursive.__qualname__.__len__,  [], 11]
    - [saferepr_ql,     saferepr.__qualname__.__len__,      [], 8]
    - [pp_ql,           pp.__qualname__.__len__,            [], 2]

# ---------------------------------------------------------------------------
# Table: pprint.__all__ element name lengths
#
# Each element of pprint.__all__ is a string with a measurable length.
# The lengths are: 'pprint'(6), 'pformat'(7), 'isreadable'(10),
# 'isrecursive'(11), 'saferepr'(8), 'PrettyPrinter'(13), 'pp'(2). This table
# indexes the __all__ list directly and checks each element's length. The
# angle is novel to extra22 — prior specs checked __all__ as a container
# but not individual element string lengths. id_prefix pp22al is novel.
# ---------------------------------------------------------------------------

table pprint_extra22.all_element_lens:
  description: "Length of each name string in pprint.__all__ — pprint=6, pformat=7, isreadable=10, isrecursive=11, saferepr=8, PrettyPrinter=13, pp=2"
  kind: python_call_eq
  category: module_all
  id_prefix: pp22al

  columns: [id, function, method, method_args, expected]
  rows:
    - [all0_len, "__all__[0]", __len__, [], 6]
    - [all1_len, "__all__[1]", __len__, [], 7]
    - [all2_len, "__all__[2]", __len__, [], 10]
    - [all3_len, "__all__[3]", __len__, [], 11]
    - [all4_len, "__all__[4]", __len__, [], 8]
    - [all5_len, "__all__[5]", __len__, [], 13]
    - [all6_len, "__all__[6]", __len__, [], 2]
