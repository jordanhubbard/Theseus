spec: io_extra144
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/fileio.c"
  notes:
    - "This spec covers: io.open identity (__qualname__, __name__, __module__, __class__.__name__), io.open_code identity (__qualname__, __name__, __module__, __class__.__name__), and io.DEFAULT_BUFFER_SIZE identity (__class__.__name__, __class__.__module__, value, bit_length)."
    - "io.open is a C builtin: type(io.open).__name__ == 'builtin_function_or_method'. io.open is _io.open is True — io re-exports the C function from _io."
    - "io.open.__qualname__ == 'open' (length 4) — no class prefix because open is a top-level function, not a method."
    - "io.open.__module__ == '_io' (length 3) — open is defined in the C extension _io, not the Python io wrapper."
    - "io.open_code.__qualname__ == 'open_code' (length 9) — open_code is the audited variant, also defined at top level in _io."
    - "io.open_code.__module__ == '_io' (length 3) — also defined in the C extension _io."
    - "io.DEFAULT_BUFFER_SIZE == 131072 — 2^17 bytes (128 KiB), the default size for buffered I/O."
    - "io.DEFAULT_BUFFER_SIZE.bit_length() == 18 — 131072 in binary has 18 bits (1 followed by 17 zeros)."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__name__ == 'int' — the constant is a plain Python int."
    - "io.DEFAULT_BUFFER_SIZE.__class__.__module__ == 'builtins' — int is a built-in type."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.open builtin function identity
# io.open is a C builtin re-exported from _io.
# __qualname__ == 'open' (4), __name__ == 'open' (4), __module__ == '_io' (3).
# __class__.__name__ == 'builtin_function_or_method' (not 'function').
# ---------------------------------------------------------------------------

table io_extra144.open_identity:
  description: "io.open builtin function identity: __qualname__='open' (4), __name__='open' (4), __module__='_io' (3), __class__.__name__='builtin_function_or_method'"
  kind: python_call_eq
  category: builtin_identity
  id_prefix: ioopen144

  columns: [id, function, args, expected]
  rows:
    - [open_qn_eq,      open.__qualname__.__eq__,              ["open"],                        true]
    - [open_qn_len,     open.__qualname__.__len__,             [],                              4]
    - [open_name_eq,    open.__name__.__eq__,                  ["open"],                        true]
    - [open_name_len,   open.__name__.__len__,                 [],                              4]
    - [open_mod_eq,     open.__module__.__eq__,                ["_io"],                         true]
    - [open_mod_not_io, open.__module__.__eq__,                ["io"],                          false]
    - [open_mod_len,    open.__module__.__len__,               [],                              3]
    - [open_cls_eq,     open.__class__.__name__.__eq__,        ["builtin_function_or_method"],  true]
    - [open_cls_not_fn, open.__class__.__name__.__eq__,        ["function"],                    false]

# ---------------------------------------------------------------------------
# io.open_code builtin function identity
# io.open_code is the audit-hook variant of open, also in _io.
# __qualname__ == 'open_code' (9), __name__ == 'open_code' (9), __module__ == '_io' (3).
# __class__.__name__ == 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

table io_extra144.open_code_identity:
  description: "io.open_code builtin function identity: __qualname__='open_code' (9), __name__='open_code' (9), __module__='_io' (3), __class__.__name__='builtin_function_or_method'"
  kind: python_call_eq
  category: builtin_identity
  id_prefix: ioopen144

  columns: [id, function, args, expected]
  rows:
    - [oc_qn_eq,      open_code.__qualname__.__eq__,       ["open_code"],                   true]
    - [oc_qn_len,     open_code.__qualname__.__len__,      [],                              9]
    - [oc_name_eq,    open_code.__name__.__eq__,           ["open_code"],                   true]
    - [oc_name_len,   open_code.__name__.__len__,          [],                              9]
    - [oc_mod_eq,     open_code.__module__.__eq__,         ["_io"],                         true]
    - [oc_mod_len,    open_code.__module__.__len__,        [],                              3]
    - [oc_cls_eq,     open_code.__class__.__name__.__eq__, ["builtin_function_or_method"],  true]

# ---------------------------------------------------------------------------
# io.DEFAULT_BUFFER_SIZE identity
# DEFAULT_BUFFER_SIZE == 131072 == 2^17 bytes (128 KiB).
# __class__.__name__ == 'int', __class__.__module__ == 'builtins'.
# bit_length() == 18 (131072 in binary is 100000000000000000, 18 bits).
# ---------------------------------------------------------------------------

table io_extra144.default_buffer_size_identity:
  description: "io.DEFAULT_BUFFER_SIZE identity: value=131072 (2^17, 128 KiB), __class__.__name__='int', __class__.__module__='builtins', bit_length()==18"
  kind: python_call_eq
  category: constant_identity
  id_prefix: iodbs144

  columns: [id, function, args, expected]
  rows:
    - [dbs_value_eq,     DEFAULT_BUFFER_SIZE.__eq__,                 [131072],    true]
    - [dbs_value_not,    DEFAULT_BUFFER_SIZE.__eq__,                 [8192],      false]
    - [dbs_cls_eq,       DEFAULT_BUFFER_SIZE.__class__.__name__.__eq__, ["int"],  true]
    - [dbs_mod_eq,       DEFAULT_BUFFER_SIZE.__class__.__module__.__eq__, ["builtins"], true]
    - [dbs_bits_eq,      DEFAULT_BUFFER_SIZE.bit_length,             [],          18]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra144.open.qualname_is_open:
  description: "io.open.__qualname__ == 'open' (length 4; open is a top-level C builtin in _io with no class prefix in its qualname)"
  category: builtin_identity
  kind: python_call_eq
  function: open.__qualname__.__eq__
  args: ["open"]
  expected: true

invariant io_extra144.open.module_is_underscored_io:
  description: "io.open.__module__ == '_io' (length 3; io.open is the C builtin from the _io extension, re-exported by the Python io wrapper; __module__ reflects its origin)"
  category: builtin_identity
  kind: python_call_eq
  function: open.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra144.open.class_is_builtin:
  description: "io.open.__class__.__name__ == 'builtin_function_or_method' (io.open is implemented in C, not a Python def; its type name distinguishes it from Python functions)"
  category: builtin_identity
  kind: python_call_eq
  function: open.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant io_extra144.open_code.qualname_is_open_code:
  description: "io.open_code.__qualname__ == 'open_code' (length 9; open_code is the auditing variant of open, also a top-level C builtin in _io with no class prefix)"
  category: builtin_identity
  kind: python_call_eq
  function: open_code.__qualname__.__eq__
  args: ["open_code"]
  expected: true

invariant io_extra144.DEFAULT_BUFFER_SIZE.value_131072:
  description: "io.DEFAULT_BUFFER_SIZE == 131072 (2^17 bytes = 128 KiB; this is the default size for BufferedReader/BufferedWriter internal buffers)"
  category: constant_identity
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.__eq__
  args: [131072]
  expected: true

invariant io_extra144.DEFAULT_BUFFER_SIZE.bit_length_18:
  description: "io.DEFAULT_BUFFER_SIZE.bit_length() == 18 (131072 in binary is 100000000000000000, requiring 18 bits; equivalently 131072 == 2^17 so bit_length == 17+1 == 18)"
  category: constant_identity
  kind: python_call_eq
  function: DEFAULT_BUFFER_SIZE.bit_length
  args: []
  expected: 18

