  id_prefix: uu1951

  columns: [id, function, args, expected]
  rows:
    - ["uu1951009", "uuid.UUID.__dict__.__contains__",     ["__anext__"], false]
    - ["uu1951010", "uuid.SafeUUID.__dict__.__contains__", ["__anext__"], false]

table uuid_extra1951.uuid_full_sweep:
  description: "uuid.UUID __dict__ sweep for all five iteration dunder methods"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1951

  columns: [id, function, args, expected]
  rows:
    - ["uu1951011", "uuid.UUID.__dict__.__contains__", ["__contains__"], false]
    - ["uu1951012", "uuid.UUID.__dict__.__contains__", ["__iter__"],     false]
    - ["uu1951013", "uuid.UUID.__dict__.__contains__", ["__next__"],     false]
    - ["uu1951014", "uuid.UUID.__dict__.__contains__", ["__aiter__"],    false]
    - ["uu1951015", "uuid.UUID.__dict__.__contains__", ["__anext__"],    false]

table uuid_extra1951.safeuuid_full_sweep:
  description: "uuid.SafeUUID __dict__ sweep for all five iteration dunder methods — IntEnum metaclass provides __contains__, not SafeUUID itself"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1951

  columns: [id, function, args, expected]
  rows:
    - ["uu1951016", "uuid.SafeUUID.__dict__.__contains__", ["__contains__"], false]
    - ["uu1951017", "uuid.SafeUUID.__dict__.__contains__", ["__iter__"],     false]
    - ["uu1951018", "uuid.SafeUUID.__dict__.__contains__", ["__next__"],     false]
    - ["uu1951019", "uuid.SafeUUID.__dict__.__contains__", ["__aiter__"],    false]
    - ["uu1951020", "uuid.SafeUUID.__dict__.__contains__", ["__anext__"],    false]

table uuid_extra1951.class_names:
  description: "uuid type __class__.__name__ identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: uu1951

  columns: [id, function, args, expected]
  rows:
    - ["uu1951021", "uuid.UUID.__class__.__name__.__eq__",     ["type"],    true]
    - ["uu1951022", "uuid.SafeUUID.__class__.__name__.__eq__", ["EnumType"], true]

table uuid_extra1951.module_level_attrs:
  description: "uuid module-level dunder iteration presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1951

  columns: [id, function, args, expected]
  rows:
    - ["uu1951023", "uuid.__dict__.__contains__", ["__contains__"], false]
    - ["uu1951024", "uuid.__dict__.__contains__", ["__iter__"],     false]
    - ["uu1951025", "uuid.__dict__.__contains__", ["__next__"],     false]
    - ["uu1951026", "uuid.__dict__.__contains__", ["__aiter__"],    false]
    - ["uu1951027", "uuid.__dict__.__contains__", ["__anext__"],    false]

table uuid_extra1951.uuid_metaclass:
  description: "uuid.UUID metaclass is type; SafeUUID metaclass (EnumType) provides __contains__ but not SafeUUID itself"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1951

  columns: [id, function, args, expected]
  rows:
    - ["uu1951028", "uuid.UUID.__class__.__dict__.__contains__",     ["__contains__"], false]
    - ["uu1951029", "uuid.SafeUUID.__class__.__dict__.__contains__", ["__contains__"], true]
    - ["uu1951030", "uuid.UUID.__class__.__dict__.__contains__",     ["__iter__"],     false]
    - ["uu1951031", "uuid.SafeUUID.__class__.__dict__.__contains__", ["__iter__"],     true]
    - ["uu1951032", "uuid.UUID.__class__.__dict__.__contains__",     ["__aiter__"],    false]
    - ["uu1951033", "uuid.SafeUUID.__class__.__dict__.__contains__", ["__aiter__"],    false]
