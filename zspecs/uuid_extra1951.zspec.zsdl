spec: uuid_extra1951
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/uuid.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 577 (_extra1951): __contains__, __iter__, __next__, __aiter__, __anext__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "uuid.UUID does not define __contains__, __iter__, __next__, __aiter__, or __anext__ in its own __dict__."
    - "uuid.UUID objects are not iterable — UUID.__dict__ contains no __iter__ entry."
    - "uuid.SafeUUID is an IntEnum subclass; __contains__ is defined by the EnumMeta metaclass, not in SafeUUID.__dict__ itself."
    - "uuid.SafeUUID.__dict__ does not contain __iter__, __next__, __aiter__, or __anext__."
    - "No uuid class defines any async iteration method."
  created_at: "2026-04-12"
error_model: python_exceptions

table uuid_extra1951.contains_protocol:
  description: "uuid types __contains__ dict-presence — none define __contains__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1951

  columns: [id, function, args, expected]
  rows:
    - ["uu1951001", "uuid.UUID.__dict__.__contains__",     ["__contains__"], false]
    - ["uu1951002", "uuid.SafeUUID.__dict__.__contains__", ["__contains__"], false]

table uuid_extra1951.iter_protocol:
  description: "uuid types __iter__ dict-presence — uuid.UUID is not iterable; no class defines __iter__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: uu1951

  columns: [id, function, args, expected]
  rows:
    - ["uu1951003", "uuid.UUID.__dict__.__contains__",     ["__iter__"], false]
    - ["uu1951004", "uuid.SafeUUID.__dict__.__contains__", ["__iter__"], false]

table uuid_extra1951.next_protocol:
