  rows:
    - ["uu1951007", "uuid.UUID.__dict__.__contains__",     ["__aiter__"], false]
    - ["uu1951008", "uuid.SafeUUID.__dict__.__contains__", ["__aiter__"], false]

table uuid_extra1951.anext_protocol:
  description: "uuid types __anext__ dict-presence — no async iteration support in any uuid class"
  kind: python_call_eq
