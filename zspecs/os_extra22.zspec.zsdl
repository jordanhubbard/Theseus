spec: os_extra22
version: ">=3.9"
backend: python_module(os)

docs: https://docs.python.org/3/library/os.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/os.html — Python os module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/posixmodule.c"
    - "CPython source: Lib/os.py"
    - "os_extra21.zspec.zsdl — covers getenv/putenv name/module; environ class name; curdir/pardir/sep class names and values; altsep/devnull/extsep class names"
    - "os_extra19.zspec.zsdl — covers curdir/pardir/extsep __class__.__name__ == 'str' in table"
    - "os_extra17.zspec.zsdl — covers curdir/pardir/sep/extsep/devnull exact values"
  notes:
    - "This spec extends os.zspec.zsdl and prior extras through os_extra21.zspec.zsdl."
    - "os.getcwd().__class__.__name__ == 'str' — getcwd returns a str path."
    - "os.getpid().__class__.__name__ == 'int' — getpid returns an integer process ID."
    - "os.getuid().__class__.__name__ == 'int' — getuid returns an integer user ID (POSIX only)."
    - "os.getgid().__class__.__name__ == 'int' — getgid returns an integer group ID (POSIX only)."
    - "os.cpu_count().__class__.__name__ == 'int' — cpu_count returns an int on macOS/Linux when CPUs are detectable."
    - "os.urandom(8).__class__.__name__ == 'bytes' — urandom returns a bytes object."
    - "os.urandom(8).__len__() == 8 — urandom returns exactly the requested number of bytes."
    - "os.linesep.__class__.__name__ == 'str' — linesep is always a str."
    - "os.pathsep.__class__.__name__ == 'str' — pathsep is always a str."
    - "os.name.__class__.__name__ == 'str' — name is always a str ('posix', 'nt', etc.)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# os.getcwd() — return type is str
#
# No prior os spec checks getcwd().__class__.__name__ == 'str'.
# getcwd() returns the current working directory as a string path.
# ---------------------------------------------------------------------------

invariant os_extra22.getcwd.class_name:
  description: "os.getcwd().__class__.__name__ == 'str' — getcwd returns a str"
  category: function_return_types
  kind: python_call_eq
  function: getcwd
  args: []
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# os.getpid() — return type is int
#
# No prior os spec checks getpid().__class__.__name__ == 'int'.
# getpid() returns the current process ID as an integer.
# ---------------------------------------------------------------------------

invariant os_extra22.getpid.class_name:
  description: "os.getpid().__class__.__name__ == 'int' — getpid returns an int"
  category: function_return_types
  kind: python_call_eq
  function: getpid
  args: []
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# os.getuid() — return type is int (POSIX)
#
# No prior os spec checks getuid().__class__.__name__ == 'int'.
# getuid() returns the current process's real user ID as an integer.
# ---------------------------------------------------------------------------

invariant os_extra22.getuid.class_name:
  description: "os.getuid().__class__.__name__ == 'int' — getuid returns an int (POSIX)"
  category: function_return_types
  kind: python_call_eq
  function: getuid
  args: []
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# os.getgid() — return type is int (POSIX)
#
# No prior os spec checks getgid().__class__.__name__ == 'int'.
# getgid() returns the current process's real group ID as an integer.
# ---------------------------------------------------------------------------

invariant os_extra22.getgid.class_name:
  description: "os.getgid().__class__.__name__ == 'int' — getgid returns an int (POSIX)"
  category: function_return_types
  kind: python_call_eq
  function: getgid
  args: []
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# os.cpu_count() — return type is int
#
# No prior os spec checks cpu_count().__class__.__name__ == 'int'.
# On macOS and Linux, cpu_count() returns an integer when detectable.
# ---------------------------------------------------------------------------

invariant os_extra22.cpu_count.class_name:
  description: "os.cpu_count().__class__.__name__ == 'int' — cpu_count returns an int"
  category: function_return_types
  kind: python_call_eq
  function: cpu_count
  args: []
  method: __class__.__name__.__eq__
  method_args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# os.urandom(8) — return type is bytes and length is 8
#
# No prior os spec checks urandom return type or length.
# os.urandom(n) returns n cryptographically random bytes.
# ---------------------------------------------------------------------------

invariant os_extra22.urandom.class_name:
  description: "os.urandom(8).__class__.__name__ == 'bytes' — urandom returns bytes"
  category: function_return_types
  kind: python_call_eq
  function: urandom
  args: [8]
  method: __class__.__name__.__eq__
  method_args: ["bytes"]
  expected: true

invariant os_extra22.urandom.length:
  description: "os.urandom(8).__len__() == 8 — urandom returns exactly the requested number of bytes"
  category: function_return_types
  kind: python_call_eq
  function: urandom
  args: [8]
  method: __len__
  method_args: []
  expected: 8

# ---------------------------------------------------------------------------
# os.linesep, os.pathsep, os.name — __class__.__name__ == 'str'
#
# No prior os spec checks linesep, pathsep, or name class names.
# os_extra17 covers exact values of some constants; os_extra19 covers
# curdir/pardir/extsep. This spec adds linesep, pathsep, and name.
# ---------------------------------------------------------------------------

invariant os_extra22.linesep.class_name:
  description: "os.linesep.__class__.__name__ == 'str' — linesep is always a str"
  category: constant_types
  kind: python_call_eq
  function: linesep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_extra22.pathsep.class_name:
  description: "os.pathsep.__class__.__name__ == 'str' — pathsep is always a str"
  category: constant_types
  kind: python_call_eq
  function: pathsep.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant os_extra22.name.class_name:
  description: "os.name.__class__.__name__ == 'str' — os.name is always a str"
  category: constant_types
  kind: python_call_eq
  function: name.__class__.__name__.__eq__
  args: ["str"]
  expected: true
