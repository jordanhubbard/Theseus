spec: asyncio_extra6
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and Coroutines"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/runners.py"
    - "CPython source: Lib/asyncio/timeouts.py"
  notes:
    - "Extends asyncio.zspec.zsdl, asyncio_events.zspec.zsdl, asyncio_extra.zspec.zsdl, asyncio_extra2.zspec.zsdl, asyncio_extra3.zspec.zsdl, asyncio_extra4.zspec.zsdl, asyncio_extra5.zspec.zsdl."
    - "asyncio_extra3.zspec.zsdl covers __qualname__ for Task/Future/Queue/Lock/Event/Semaphore/Condition; gather/sleep/create_task __qualname__; PriorityQueue/LifoQueue __qualname__; Barrier/TaskGroup/Runner __name__+__module__ (Python 3.11+)."
    - "asyncio_extra5.zspec.zsdl covers __name__ for Queue/PriorityQueue/LifoQueue/QueueEmpty/QueueFull/Lock/Event/Condition/Semaphore/BoundedSemaphore; iscoroutine/iscoroutinefunction/isfuture __name__; Semaphore/Lock/Queue __module__."
    - "This spec adds: __qualname__ for Barrier/TaskGroup/Runner/timeout (Python 3.11+); __qualname__ for BoundedSemaphore/Condition; __qualname__ for to_thread/wait_for/wait/shield/run; __qualname__ for QueueEmpty/QueueFull exception classes."
    - "asyncio.Barrier.__qualname__ == 'Barrier' — Python 3.11+ synchronization barrier."
    - "asyncio.TaskGroup.__qualname__ == 'TaskGroup' — Python 3.11+ structured concurrency context manager."
    - "asyncio.Runner.__qualname__ == 'Runner' — Python 3.11+ event loop manager."
    - "asyncio.timeout.__qualname__ == 'timeout' — Python 3.11+ context manager class in asyncio.timeouts."
    - "asyncio.BoundedSemaphore.__qualname__ == 'BoundedSemaphore' — top-level class, qualname equals name."
    - "asyncio.Condition.__qualname__ == 'Condition' — not checked for __qualname__ in prior specs."
    - "asyncio.to_thread.__qualname__ == 'to_thread' — Python 3.9+ coroutine function."
    - "asyncio.wait_for.__qualname__ == 'wait_for' — top-level coroutine function."
    - "asyncio.wait.__qualname__ == 'wait' — top-level coroutine function."
    - "asyncio.shield.__qualname__ == 'shield' — top-level coroutine function."
    - "asyncio.run.__qualname__ == 'run' — top-level function in asyncio.runners."
    - "asyncio.QueueEmpty.__qualname__ == 'QueueEmpty' — exception class for asyncio queues."
    - "asyncio.QueueFull.__qualname__ == 'QueueFull' — exception class for asyncio queues."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for Python 3.11+ asyncio additions
#
# asyncio_extra3 checked __name__+__module__ for Barrier/TaskGroup/Runner.
# This spec adds __qualname__ for those same classes (independent vectors).
# asyncio.timeout is a context manager class added in Python 3.11.
# ---------------------------------------------------------------------------

invariant asyncio_extra6.Barrier.qualname:
  description: "asyncio.Barrier.__qualname__ == 'Barrier' (Python 3.11+)"
  category: qualnames_311
  kind: python_call_eq
  function: Barrier.__qualname__.__eq__
  args: ["Barrier"]
  expected: true
  version: ">=3.11"

invariant asyncio_extra6.TaskGroup.qualname:
  description: "asyncio.TaskGroup.__qualname__ == 'TaskGroup' (Python 3.11+)"
  category: qualnames_311
  kind: python_call_eq
  function: TaskGroup.__qualname__.__eq__
  args: ["TaskGroup"]
  expected: true
  version: ">=3.11"

invariant asyncio_extra6.Runner.qualname:
  description: "asyncio.Runner.__qualname__ == 'Runner' (Python 3.11+)"
  category: qualnames_311
  kind: python_call_eq
  function: Runner.__qualname__.__eq__
  args: ["Runner"]
  expected: true
  version: ">=3.11"

invariant asyncio_extra6.timeout.qualname:
  description: "asyncio.timeout.__qualname__ == 'timeout' — context manager class (Python 3.11+)"
  category: qualnames_311
  kind: python_call_eq
  function: timeout.__qualname__.__eq__
  args: ["timeout"]
  expected: true
  version: ">=3.11"

# ---------------------------------------------------------------------------
# __qualname__ for BoundedSemaphore and Condition
#
# asyncio_extra5 covered these via __name__ in a table; this spec adds
# __qualname__ checks as independent new vectors.
# ---------------------------------------------------------------------------

invariant asyncio_extra6.BoundedSemaphore.qualname:
  description: "asyncio.BoundedSemaphore.__qualname__ == 'BoundedSemaphore'"
  category: qualnames
  kind: python_call_eq
  function: BoundedSemaphore.__qualname__.__eq__
  args: ["BoundedSemaphore"]
  expected: true

invariant asyncio_extra6.Condition.qualname:
  description: "asyncio.Condition.__qualname__ == 'Condition'"
  category: qualnames
  kind: python_call_eq
  function: Condition.__qualname__.__eq__
  args: ["Condition"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for exception classes
#
# QueueEmpty and QueueFull are exception classes in asyncio.queues. Their
# __qualname__ equals their __name__ (top-level class definitions).
# asyncio_extra5 covered their __name__; this adds __qualname__ vectors.
# ---------------------------------------------------------------------------

invariant asyncio_extra6.QueueEmpty.qualname:
  description: "asyncio.QueueEmpty.__qualname__ == 'QueueEmpty'"
  category: exception_qualnames
  kind: python_call_eq
  function: QueueEmpty.__qualname__.__eq__
  args: ["QueueEmpty"]
  expected: true

invariant asyncio_extra6.QueueFull.qualname:
  description: "asyncio.QueueFull.__qualname__ == 'QueueFull'"
  category: exception_qualnames
  kind: python_call_eq
  function: QueueFull.__qualname__.__eq__
  args: ["QueueFull"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for top-level asyncio coroutine functions
#
# asyncio_extra3 covered gather/sleep/create_task __qualname__.
# This spec adds to_thread (Python 3.9+), wait_for, wait, shield, and run
# as independent __qualname__ vectors not yet present in any prior spec.
# ---------------------------------------------------------------------------

invariant asyncio_extra6.to_thread.qualname:
  description: "asyncio.to_thread.__qualname__ == 'to_thread' (Python 3.9+)"
  category: function_qualnames
  kind: python_call_eq
  function: to_thread.__qualname__.__eq__
  args: ["to_thread"]
  expected: true

invariant asyncio_extra6.wait_for.qualname:
  description: "asyncio.wait_for.__qualname__ == 'wait_for'"
  category: function_qualnames
  kind: python_call_eq
  function: wait_for.__qualname__.__eq__
  args: ["wait_for"]
  expected: true

invariant asyncio_extra6.wait.qualname:
  description: "asyncio.wait.__qualname__ == 'wait'"
  category: function_qualnames
  kind: python_call_eq
  function: wait.__qualname__.__eq__
  args: ["wait"]
  expected: true

invariant asyncio_extra6.shield.qualname:
  description: "asyncio.shield.__qualname__ == 'shield'"
  category: function_qualnames
  kind: python_call_eq
  function: shield.__qualname__.__eq__
  args: ["shield"]
  expected: true

invariant asyncio_extra6.run.qualname:
  description: "asyncio.run.__qualname__ == 'run'"
  category: function_qualnames
  kind: python_call_eq
  function: run.__qualname__.__eq__
  args: ["run"]
  expected: true
