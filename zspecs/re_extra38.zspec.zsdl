spec: re_extra38
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra37.zspec.zsdl — covers Pattern/Match member_descriptor attribute __qualname__.__len__() for pattern/flags/groups/groupindex and string/re/pos/endpos/lastindex/lastgroup."
    - "re_extra36.zspec.zsdl — covers Match.expand/groupdict __qualname__.__len__(); RegexFlag member .name.__len__() for IGNORECASE/MULTILINE/DOTALL/VERBOSE/ASCII/UNICODE/NOFLAG."
    - "re_extra34.zspec.zsdl — covers module-level function __qualname__.__len__() for compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge."
    - "re_extra33.zspec.zsdl — covers re.__all__.__len__()==31; IGNORECASE.__class__.__name__.__len__()==9; int flag values for IGNORECASE(2)/MULTILINE(8)/DOTALL(16)."
    - "re_extra17.zspec.zsdl — covers escape for star/brackets; split with escaped dot and digit-runs; findall three words; match named group by string key ('year')."
    - "re_extra11.zspec.zsdl — covers sub count=1; split maxsplit=2; match.string/pos/endpos; search.lastindex None."
  notes:
    - "This spec extends re_extra37.zspec.zsdl."
    - "Prior specs collectively covered: all Pattern/Match/__name__/__module__/__qualname__ and their lengths; all public function __name__/__module__/__qualname__/__qualname__.__len__(); error/__name__/__module__/__qualname__/__bases__; RegexFlag attributes; IGNORECASE/MULTILINE/DOTALL/VERBOSE values (as RegexFlag .value, not as compiled pattern .flags integer); Pattern/Match method __qualname__.__len__() for all main methods; module-level function __qualname__.__len__(); Match.expand/groupdict __qualname__.__len__(); RegexFlag member .name lengths; Pattern/Match descriptor __qualname__.__len__(); re_extra17 named group access .group('year') for a single named group."
    - "This spec covers: re.compile(r'test', IGNORECASE).flags==34 (NOVEL — IGNORECASE(2)+UNICODE(32)=34; prior specs check .flags class name and IGNORECASE.value separately but NOT the combined integer flags on a compiled pattern); re.compile(r'^t', MULTILINE).flags==40 (NOVEL — MULTILINE(8)+UNICODE(32)=40); re.compile(r'.+', DOTALL).flags==48 (NOVEL — DOTALL(16)+UNICODE(32)=48); re.split(r'(\\s+)', 'a b  c') == ['a',' ','b','  ','c'] (NOVEL — prior specs split without capturing group; a capturing group in the delimiter causes the delimiters to be included in the result list); re.findall(r'(\\d+)-(\\w+)', 'a1-foo b22-bar') returns list of tuples (NOVEL — prior findall tests return flat lists; two capture groups yields tuples); re.search(r'(?P<year>\\d{4})-(?P<month>\\d{2})', '2024-03').lastgroup == 'month' (NOVEL — re_extra17 checks .group('year') for a single named group but NOT lastgroup on a multi-named-group pattern); re.escape('a.b*c') == 'a\\.b\\*c' (NOVEL — re_extra10 escapes 'a.b', re_extra17 escapes 'a*b'; no prior spec escapes a string with both dot and star metacharacters)."
    - "re.compile(r'test', re.IGNORECASE).flags == 34 — IGNORECASE=2 combined with UNICODE=32 (always set by default on Python 3). No prior re spec checks the integer value of .flags on a pattern compiled with an explicit flag. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.compile(r'^t', re.MULTILINE).flags == 40 — MULTILINE=8 + UNICODE=32 = 40. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.compile(r'.+', re.DOTALL).flags == 48 — DOTALL=16 + UNICODE=32 = 48. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.split(r'(\\s+)', 'a b  c') == ['a', ' ', 'b', '  ', 'c'] — when the delimiter pattern contains a capturing group, the captured text is included in the result list. len==5. No prior re spec uses split with a capturing group delimiter. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.findall(r'(\\d+)-(\\w+)', 'a1-foo b22-bar') == [('1','foo'),('22','bar')] — two capture groups cause findall to return a list of tuples instead of a flat list of strings. No prior re spec tests findall with two capture groups. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.search(r'(?P<year>\\d{4})-(?P<month>\\d{2})', '2024-03').lastgroup == 'month' — lastgroup is the name of the last matched named group, not 'year'. re_extra17 covers .group('year') but NOT lastgroup on a multi-named-group pattern. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "re.escape('a.b*c') == 'a\\.b\\*c' — escapes both dot and star in the same string (len 7). re_extra10 covers escape('a.b'), re_extra17 covers escape('a*b'); no prior spec uses a string with both metacharacters together. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Compiled pattern .flags integer values with explicit flags
#
# re_extra33 checks int(IGNORECASE)==2, int(MULTILINE)==8, int(DOTALL)==16
# as standalone flag values. No prior re spec checks the .flags attribute
# on a compiled Pattern object when an explicit flag is passed. On Python 3
# the UNICODE flag (32) is always enabled by default, so a pattern compiled
# with IGNORECASE has .flags == 2 + 32 == 34.
#
#   compile(r'test', IGNORECASE).flags == 34   (IGNORECASE=2 + UNICODE=32)
#   compile(r'^t',  MULTILINE ).flags == 40   (MULTILINE=8  + UNICODE=32)
#   compile(r'.+',  DOTALL    ).flags == 48   (DOTALL=16    + UNICODE=32)
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra38.compiled_pattern_flags_values:
  description: "re.compile(pattern, flag).flags integer: IGNORECASE(34)/MULTILINE(40)/DOTALL(48) — UNICODE(32) is always added; novel; no prior re spec checks .flags on a compiled pattern"
  kind: python_call_eq
  category: pattern_flags
  id_prefix: cpfv38

  columns: [id, function, args, expected]
  rows:
    - [ignorecase_flags, "compile.__call__(r'test', IGNORECASE).flags.__eq__", [34], true]
    - [multiline_flags,  "compile.__call__(r'^t', MULTILINE).flags.__eq__",   [40], true]
    - [dotall_flags,     "compile.__call__(r'.+', DOTALL).flags.__eq__",      [48], true]

# ---------------------------------------------------------------------------
# re.split with a capturing-group delimiter
#
# When the delimiter pattern contains a capturing group, re.split() includes
# the captured delimiter text in the result list. This is different from
# split without a capturing group, which discards the delimiter.
#
# re_extra.split.whitespace_runs covers split(r'\s+', 'a b  c') == ['a','b','c']
# (3 items, delimiter discarded). This spec covers split(r'(\s+)', 'a b  c')
# == ['a', ' ', 'b', '  ', 'c'] (5 items, delimiters captured and retained).
# No prior re spec uses a capturing group in the split delimiter. Novel.
# ---------------------------------------------------------------------------

invariant re_extra38.split_capturing_group_result:
  description: "re.split(r'(\\s+)', 'a b  c') == ['a', ' ', 'b', '  ', 'c'] — capturing group in delimiter includes delimiters in result; len==5; novel (prior specs split without capturing group)"
  category: split
  kind: python_call_eq
  function: "split.__call__(r'(\\s+)', 'a b  c').__eq__"
  args: [["a", " ", "b", "  ", "c"]]
  expected: true

invariant re_extra38.split_capturing_group_len:
  description: "len(re.split(r'(\\s+)', 'a b  c')) == 5 — five items because capturing group retains the two whitespace separators in the result; novel"
  category: split
  kind: python_call_eq
  function: "split.__call__(r'(\\s+)', 'a b  c').__len__"
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# re.findall with two capture groups returns list of tuples
#
# When the pattern has two or more capture groups, re.findall() returns a
# list of tuples rather than a list of strings. No prior re spec tests
# findall with two capture groups. The pattern r'(\d+)-(\w+)' finds
# digit-dash-word pairs; applied to 'a1-foo b22-bar' it yields two tuples.
#
#   findall(r'(\d+)-(\w+)', 'a1-foo b22-bar') == [('1','foo'), ('22','bar')]
#   len == 2
#   result[0] == ('1', 'foo')
#
# All novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra38.findall_two_groups_result:
  description: "re.findall(r'(\\d+)-(\\w+)', 'a1-foo b22-bar') == [('1','foo'),('22','bar')] — two capture groups return list of tuples; novel; prior findall tests use zero or one group"
  category: findall
  kind: python_call_eq
  function: "findall.__call__(r'(\\d+)-(\\w+)', 'a1-foo b22-bar').__eq__"
  args: [["1", "foo"], ["22", "bar"]]
  expected: true

invariant re_extra38.findall_two_groups_len:
  description: "len(re.findall(r'(\\d+)-(\\w+)', 'a1-foo b22-bar')) == 2 — two matches found; novel"
  category: findall
  kind: python_call_eq
  function: "findall.__call__(r'(\\d+)-(\\w+)', 'a1-foo b22-bar').__len__"
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# re.search lastgroup with multiple named groups
#
# re_extra17 covers .group('year') for a pattern with a single named group,
# but no prior re spec checks .lastgroup when there are multiple named groups.
# .lastgroup is the name of the last matched capturing group. For a pattern
# with two named groups (?P<year>...) and (?P<month>...) applied to '2024-03',
# both groups match and lastgroup is 'month' (the last one).
#
#   search(r'(?P<year>\d{4})-(?P<month>\d{2})', '2024-03').lastgroup == 'month'
#
# Novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra38.search_lastgroup_named:
  description: "re.search(r'(?P<year>\\d{4})-(?P<month>\\d{2})', '2024-03').lastgroup == 'month' — lastgroup is name of last matched group; novel; re_extra17 covers .group('year') for single named group but not lastgroup"
  category: match_attributes
  kind: python_call_eq
  function: "search.__call__(r'(?P<year>\\d{4})-(?P<month>\\d{2})', '2024-03').lastgroup.__eq__"
  args: ["month"]
  expected: true

# ---------------------------------------------------------------------------
# re.escape with mixed dot-and-star metacharacters
#
# re_extra10 covers escape('a.b') == 'a\\.b' (escaping only a dot).
# re_extra17 covers escape('a*b') == 'a\\*b' (escaping only a star).
# No prior re spec escapes a string that contains both . and * metacharacters.
#
#   escape('a.b*c') == 'a\\.b\\*c'   (7 chars after escaping)
#
# Both the dot and the star each add one backslash, so the 5-char input
# 'a.b*c' becomes a 7-char escaped string. Novel.
# Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant re_extra38.escape_dot_and_star:
  description: "re.escape('a.b*c') == 'a\\.b\\*c' — escapes both dot and star in one call; 5-char input becomes 7-char output; novel; prior specs escape only dot (extra10) or only star (extra17) but not both"
  category: escape
  kind: python_call_eq
  function: "escape.__call__('a.b*c').__eq__"
  args: ["a\\.b\\*c"]
  expected: true

invariant re_extra38.escape_dot_and_star_len:
  description: "len(re.escape('a.b*c')) == 7 — each of the two metacharacters gains a backslash; novel"
  category: escape
  kind: python_call_eq
  function: "escape.__call__('a.b*c').__len__"
  args: []
  expected: 7
