spec: natural_compare_lite
version: ">=1.4.0"
backend: node(natural-compare-lite)

docs: https://www.npmjs.com/package/natural-compare-lite

provenance:
  derived_from:
    - "natural-compare-lite README — https://www.npmjs.com/package/natural-compare-lite"
    - "Test vectors verified with natural-compare-lite via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "natural-compare-lite source"
  notes:
    - "natural-compare-lite is an npm package. Install: npm install natural-compare-lite"
    - "Compares two strings using natural sort order (numbers sorted numerically)."
    - "Returns negative if a < b, positive if a > b, 0 if equal."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number (comparator-style)."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table natural_compare_lite.compare:
  kind: node_module_call_eq
  function: ~
  category: strings
  id_prefix: natcmp

  columns: [id, args, expected]
  rows:
    - [a_before_b, ["a1", "a2"],  -1]
    - [num_order,  ["a10", "a9"], 1]
    - [alpha_asc,  ["a", "b"],   -1]
    - [alpha_desc, ["b", "a"],    1]
    - [equal,      ["a", "a"],    0]
