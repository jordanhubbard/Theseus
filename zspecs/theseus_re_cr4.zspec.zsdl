spec: theseus_re_cr4
version: ">=3.9"
backend: python_cleanroom(theseus_re_cr4)
blocks: re

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html"
  notes:
    - "Clean-room extended regex utilities. Do NOT import re."
    - "sub(pattern, repl, string): replace matches; repl can be a string or callable."
    - "finditer(pattern, string): iterate over match objects for non-overlapping matches."
    - "search(pattern, string): scan for first match, return match object or None."
    - "re4_sub_fn(): sub(r'\\d+', lambda m: str(int(m.group())*2), 'a1b2') == 'a2b4'."
    - "re4_finditer_groups(): list(finditer(r'(\\w+)', 'hello world'))[0].group(1) == 'hello'."
    - "re4_named_group(): search(r'(?P<name>\\w+)', 'hello').group('name') == 'hello'."
    - "Zero-arg invariant signatures — def re4_sub_fn(): return hardcoded_result"
    - "sub with callable: call repl(match) for each match, use return value as replacement."
    - "finditer: return iterator of match objects; each has group(n) and group(name) methods."
    - "Named groups: (?P<name>...) captures match accessible by .group('name')."
    - "Export: match, search, findall, finditer, sub, subn, split, compile, fullmatch, escape."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_re_cr4.sub_fn:
  description: "sub with callable doubles each digit: 'a1b2' -> 'a2b4'"
  category: sub
  kind: python_call_eq
  function: re4_sub_fn
  args: []
  expected: "a2b4"

invariant theseus_re_cr4.finditer_groups:
  description: "finditer groups: first match group(1) == 'hello'"
  category: finditer
  kind: python_call_eq
  function: re4_finditer_groups
  args: []
  expected: "hello"

invariant theseus_re_cr4.named_group:
  description: "search with named group: .group('name') == 'hello'"
  category: named_group
  kind: python_call_eq
  function: re4_named_group
  args: []
  expected: "hello"
