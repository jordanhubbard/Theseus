spec: inspect_extra283
version: ">=3.3"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.isbuiltin, inspect.isfunction, inspect.isroutine predicates, inspect.ismethod docstring, and inspect.getfile raising TypeError for built-in types."
    - "inspect.isbuiltin(len) == True — len is a C built-in function. Verified with Python 3.14.3."
    - "inspect.isfunction(len) == False — len is a builtin, not a Python function. Verified with Python 3.14.3."
    - "inspect.isroutine(len) == True — isroutine returns True for builtins and functions alike. Verified with Python 3.14.3."
    - "inspect.ismethod.__doc__ is not None — ismethod ships with the docstring 'Return true if the object is an instance method.'. Verified with Python 3.14.3."
    - "inspect.getfile(list) raises TypeError — list is a built-in C type; its source file cannot be determined. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__class__.__name__ == 'function' — isbuiltin is a pure-Python function in inspect.py. Verified with Python 3.14.3."
    - "inspect.isbuiltin.__module__ == 'inspect' — isbuiltin is defined in the inspect module. Verified with Python 3.14.3."
    - "Passing built-in objects (len, list) as args uses the quoted bracket form '[len]' / '[list]' per harness convention (values containing '[' must be double-quoted). Verified with Python 3.14.3."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect predicate identity — isbuiltin, isfunction, ismethod, isroutine
#
# All four are pure-Python functions: __class__.__name__ == 'function'.
# All four are defined in inspect: __module__ == 'inspect'.
# ---------------------------------------------------------------------------

table inspect_extra283.predicate_identity:
  description: "inspect.isbuiltin, isfunction, ismethod, isroutine: all are pure-Python functions in the inspect module; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex283pi

  columns: [id, function, args, expected, description]
  rows:
    - [pi_isb_cls,   isbuiltin.__class__.__name__.__eq__,  ["function"], true, "inspect.isbuiltin.__class__.__name__ == 'function' — pure-Python function; verified with Python 3.14.3"]
    - [pi_isb_mod,   isbuiltin.__module__.__eq__,           ["inspect"],  true, "inspect.isbuiltin.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [pi_isf_cls,   isfunction.__class__.__name__.__eq__,  ["function"], true, "inspect.isfunction.__class__.__name__ == 'function' — pure-Python function; verified with Python 3.14.3"]
    - [pi_isf_mod,   isfunction.__module__.__eq__,          ["inspect"],  true, "inspect.isfunction.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [pi_ism_cls,   ismethod.__class__.__name__.__eq__,    ["function"], true, "inspect.ismethod.__class__.__name__ == 'function' — pure-Python function; verified with Python 3.14.3"]
    - [pi_ism_mod,   ismethod.__module__.__eq__,            ["inspect"],  true, "inspect.ismethod.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [pi_ism_doc,   ismethod.__doc__.__eq__,               [null],       false, "inspect.ismethod.__doc__ is not None — ships with docstring 'Return true if the object is an instance method.'; verified with Python 3.14.3"]
    - [pi_isr_cls,   isroutine.__class__.__name__.__eq__,   ["function"], true, "inspect.isroutine.__class__.__name__ == 'function' — pure-Python function; verified with Python 3.14.3"]
    - [pi_isr_mod,   isroutine.__module__.__eq__,           ["inspect"],  true, "inspect.isroutine.__module__ == 'inspect'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: inspect predicate behaviors on len (a C builtin)
#
# isbuiltin(len) == True  — len is a C builtin
# isfunction(len) == False — len is not a Python function
# isroutine(len) == True  — len is callable (any kind)
#
# len is passed using the '[len]' quoted-bracket form per harness convention.
# ---------------------------------------------------------------------------

table inspect_extra283.predicate_behaviors:
  description: "inspect.isbuiltin, isfunction, isroutine predicate behaviors on len (a C builtin); verified with Python 3.14.3"
  kind: python_call_eq
  category: predicates
  id_prefix: inex283pb

  columns: [id, function, args, expected, description]
  rows:
    - [pb_isb_len,   isbuiltin,   "[len]",  true,  "inspect.isbuiltin(len) == True — len is a C built-in function; verified with Python 3.14.3"]
    - [pb_isf_len,   isfunction,  "[len]",  false, "inspect.isfunction(len) == False — len is a builtin, not a Python function; verified with Python 3.14.3"]
    - [pb_isr_len,   isroutine,   "[len]",  true,  "inspect.isroutine(len) == True — isroutine is True for any callable including builtins; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra283
# ---------------------------------------------------------------------------

invariant inspect_extra283.isbuiltin_len_is_true:
  description: "inspect.isbuiltin(len) == True — len is a C built-in function; new to extra283"
  category: predicates
  kind: python_call_eq
  function: isbuiltin
  args: "[len]"
  expected: true

invariant inspect_extra283.isfunction_len_is_false:
  description: "inspect.isfunction(len) == False — len is a built-in, not a Python-defined function; new to extra283"
  category: predicates
  kind: python_call_eq
  function: isfunction
  args: "[len]"
  expected: false

invariant inspect_extra283.isroutine_len_is_true:
  description: "inspect.isroutine(len) == True — isroutine returns True for both builtins and Python functions; new to extra283"
  category: predicates
  kind: python_call_eq
  function: isroutine
  args: "[len]"
  expected: true

invariant inspect_extra283.isbuiltin_is_function:
  description: "inspect.isbuiltin.__class__.__name__ == 'function' — isbuiltin is a pure-Python function in inspect.py; new to extra283"
  category: identity
  kind: python_call_eq
  function: isbuiltin.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra283.isbuiltin_module_is_inspect:
  description: "inspect.isbuiltin.__module__ == 'inspect' — isbuiltin is defined in the inspect module; new to extra283"
  category: identity
  kind: python_call_eq
  function: isbuiltin.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra283.ismethod_doc_is_not_none:
  description: "inspect.ismethod.__doc__.__eq__(None) == False — ismethod ships with a non-None docstring; new to extra283"
  category: identity
  kind: python_call_eq
  function: ismethod.__doc__.__eq__
  args: [null]
  expected: false

invariant inspect_extra283.ismethod_module_is_inspect:
  description: "inspect.ismethod.__module__ == 'inspect' — ismethod is defined in the inspect module; new to extra283"
  category: identity
  kind: python_call_eq
  function: ismethod.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra283.getfile_list_raises_typeerror:
  description: "inspect.getfile(list) raises TypeError — list is a built-in C type and has no accessible source file; new to extra283"
  category: errors
  kind: python_call_raises
  function: getfile
  args: "[list]"
  raises: TypeError
