spec: concurrent_futures_extra1831
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "concurrent.futures stdlib documentation"
    - "CPython source: Lib/concurrent/futures/future.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  not_derived_from:
    - "asyncio integration layer"
  notes:
    - "concurrent.futures.Future is NOT awaitable; use asyncio.wrap_future for that"
    - "None of the cf classes are descriptors (no __get__/__set__)"
    - "Executors define __enter__/__exit__ for context manager protocol but not __call__"
  created_at: "2026-04-12"

table concurrent_futures_extra1831.descriptor_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["cf1831-dp-001", "concurrent.futures.Future.__dict__.__contains__", ["__get__"], false]
