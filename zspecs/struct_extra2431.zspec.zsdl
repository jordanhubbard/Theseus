spec: struct_extra2431
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "struct_extra.zspec.zsdl — covers Struct format/size attrs, calcsize, pack_into, unpack_from, iter_unpack, struct.error"
  notes:
    - "Theme: __aiter__ and __anext__ async iteration protocol dict-presence for struct.Struct."
    - "struct.Struct is a compiled C-extension class; it is not an iterator of any kind."
    - "Struct does not define __iter__, __next__, __aiter__, or __anext__ in its class __dict__."
    - "Struct defines pack, unpack, pack_into, unpack_from, and iter_unpack as sync methods."
    - "iter_unpack returns a synchronous struct_unpack_iterator object, not an async iterator."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ===
# Table 1: __aiter__ and __anext__ absent from struct.Struct __dict__
# ===

table struct_extra2431.aiter_in_dict_Struct:
  description: "__aiter__ and __anext__ dict-presence for struct.Struct — not an async iterable"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2431

  columns: [id, function, args, expected]
  rows:
    - ["st2431001", "struct.Struct.__dict__.__contains__", ["__aiter__"], false]
    - ["st2431002", "struct.Struct.__dict__.__contains__", ["__anext__"], false]

# ===
# Table 2: Sync iteration protocol also absent from struct.Struct __dict__
# ===

table struct_extra2431.sync_iter_also_absent:
  description: "struct.Struct also does not define __iter__ or __next__ — it is not a sync iterator either"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2431

  columns: [id, function, args, expected]
  rows:
    - ["st2431003", "struct.Struct.__dict__.__contains__", ["__iter__"],  false]
    - ["st2431004", "struct.Struct.__dict__.__contains__", ["__next__"],  false]
    - ["st2431005", "struct.Struct.__dict__.__contains__", ["__aiter__"], false]
    - ["st2431006", "struct.Struct.__dict__.__contains__", ["__anext__"], false]

# ===
# Table 3: Contrast — sync pack/unpack methods present in struct.Struct __dict__
# ===

table struct_extra2431.sync_methods_present:
  description: "struct.Struct defines sync pack/unpack methods but NOT async protocol methods"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2431

  columns: [id, function, args, expected]
  rows:
    - ["st2431007", "struct.Struct.__dict__.__contains__", ["pack"],        true]
    - ["st2431008", "struct.Struct.__dict__.__contains__", ["unpack"],      true]
    - ["st2431009", "struct.Struct.__dict__.__contains__", ["pack_into"],   true]
    - ["st2431010", "struct.Struct.__dict__.__contains__", ["unpack_from"], true]
    - ["st2431011", "struct.Struct.__dict__.__contains__", ["iter_unpack"], true]
    - ["st2431012", "struct.Struct.__dict__.__contains__", ["__aiter__"],   false]
    - ["st2431013", "struct.Struct.__dict__.__contains__", ["__anext__"],   false]
    - ["st2431014", "struct.Struct.__dict__.__contains__", ["__iter__"],    false]
    - ["st2431015", "struct.Struct.__dict__.__contains__", ["__next__"],    false]
