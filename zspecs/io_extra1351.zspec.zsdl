spec: io_extra1351
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO, UnsupportedOperation, BufferedReader, BufferedWriter documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks at the class __dict__ level."
    - "All io abstract base classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase) are implemented as C extension types; none define __slots__ in their own __dict__."
    - "All io concrete classes (BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, BufferedRandom) are C extension types; none define __slots__ in their own __dict__."
    - "io.UnsupportedOperation is a pure-Python exception class (subclass of OSError and io.IOError); it defines __weakref__ in its own __dict__ (True) but not __slots__ or __dict__."
    - "All C-level io classes have no __weakref__ entry in their own __dict__ because weak-reference support is handled at the C extension type level, not in a Python-level __dict__ descriptor."
    - "None of the io C extension types expose __dict__ in their class __dict__ because instances of these types do not have a Python-level instance __dict__."
    - "io.IOBase.__dict__.__contains__('__slots__') is False; io.BytesIO.__dict__.__contains__('__slots__') is False — C types do not use Python __slots__."
    - "io.UnsupportedOperation.__dict__.__contains__('__weakref__') is True — it is a regular Python class at the top of its own inheritance chain (not a subclass of another Python class that already added __weakref__)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table io_extra1351.IOBase_RawIOBase_slots_weakref_dict:
  description: "io.IOBase and io.RawIOBase __slots__, __weakref__, and __dict__ membership in class __dict__: both are C extension types; neither defines __slots__, __weakref__, or __dict__ in their own class __dict__; verified with Python 3.12"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: io1351ir
  columns: [id, function, args, expected]
  rows:
    - [io1351ir001, io.IOBase.__dict__.__contains__,    ["__slots__"],   false]
    - [io1351ir002, io.IOBase.__dict__.__contains__,    ["__weakref__"], false]
    - [io1351ir003, io.IOBase.__dict__.__contains__,    ["__dict__"],    false]
    - [io1351ir004, io.RawIOBase.__dict__.__contains__, ["__slots__"],   false]
    - [io1351ir005, io.RawIOBase.__dict__.__contains__, ["__weakref__"], false]
    - [io1351ir006, io.RawIOBase.__dict__.__contains__, ["__dict__"],    false]

