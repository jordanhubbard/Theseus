table io_extra1351.UnsupportedOperation_BufferedReader_slots_weakref_dict:
  description: "io.UnsupportedOperation and io.BufferedReader __slots__, __weakref__, and __dict__ checks: UnsupportedOperation is a Python exception class that defines __weakref__ (True); BufferedReader is a C extension type with no __slots__, __weakref__, or __dict__ in its class __dict__; verified with Python 3.12"
  kind: python_call_eq
  category: slots_weakref_dict_checks
  id_prefix: io1351ub
