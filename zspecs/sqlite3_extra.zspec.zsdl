spec: sqlite3_extra
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "https://www.sqlite.org/lang.html — SQLite Language Reference"
    - "Test vectors verified by running Python 3.12 sqlite3 module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_sqlite/"
    - "SQLite source: sqlite3.c"
  notes:
    - "This spec extends sqlite3.zspec.zsdl and sqlite3_cli.zspec.zsdl with class/constant identity invariants."
    - "sqlite3.zspec.zsdl covers: complete_statement(), roundtrip SQL tests, error on non-string input."
    - "sqlite3_cli.zspec.zsdl covers: CLI version/help/sql/typeof/string/math/builtins/error behaviors."
    - "sqlite3.Connection is the class returned by sqlite3.connect()."
    - "sqlite3.Cursor is the class returned by Connection.cursor()."
    - "sqlite3.Row is a row factory that supports column access by name."
    - "sqlite3.Error is the base exception for all sqlite3 exceptions."
    - "sqlite3.DatabaseError is a subclass of sqlite3.Error."
    - "sqlite3.OperationalError is a subclass of sqlite3.DatabaseError."
    - "sqlite3.IntegrityError is a subclass of sqlite3.DatabaseError."
    - "sqlite3.ProgrammingError is a subclass of sqlite3.DatabaseError."
    - "sqlite3.DataError is a subclass of sqlite3.DatabaseError."
    - "sqlite3.sqlite_version is a str giving the SQLite library version (e.g. '3.39.5')."
    - "sqlite3.version is a str giving the pysqlite version (e.g. '2.6.0')."
    - "sqlite3.threadsafety is an int in {0, 1, 2, 3} per DB-API 2.0 spec."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Connection class identity
# ---------------------------------------------------------------------------

invariant sqlite3_extra.Connection.class_name:
  description: "sqlite3.Connection.__name__ == 'Connection'"
  category: class_names
  kind: python_call_eq
  function: Connection.__name__.__eq__
  args: ["Connection"]
  expected: true

invariant sqlite3_extra.Connection.module_name:
  description: "sqlite3.Connection.__module__ == 'sqlite3'"
  category: class_names
  kind: python_call_eq
  function: Connection.__module__.__eq__
  args: ["sqlite3"]
  expected: true

# ---------------------------------------------------------------------------
# Cursor class identity
# ---------------------------------------------------------------------------

invariant sqlite3_extra.Cursor.class_name:
  description: "sqlite3.Cursor.__name__ == 'Cursor'"
  category: class_names
  kind: python_call_eq
  function: Cursor.__name__.__eq__
  args: ["Cursor"]
  expected: true

# ---------------------------------------------------------------------------
# Row class identity
# ---------------------------------------------------------------------------

invariant sqlite3_extra.Row.class_name:
  description: "sqlite3.Row.__name__ == 'Row'"
  category: class_names
  kind: python_call_eq
  function: Row.__name__.__eq__
  args: ["Row"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class names
# ---------------------------------------------------------------------------

invariant sqlite3_extra.Error.class_name:
  description: "sqlite3.Error.__name__ == 'Error'"
  category: class_names
  kind: python_call_eq
  function: Error.__name__.__eq__
  args: ["Error"]
  expected: true

invariant sqlite3_extra.DatabaseError.class_name:
  description: "sqlite3.DatabaseError.__name__ == 'DatabaseError'"
  category: class_names
  kind: python_call_eq
  function: DatabaseError.__name__.__eq__
  args: ["DatabaseError"]
  expected: true

invariant sqlite3_extra.OperationalError.class_name:
  description: "sqlite3.OperationalError.__name__ == 'OperationalError'"
  category: class_names
  kind: python_call_eq
  function: OperationalError.__name__.__eq__
  args: ["OperationalError"]
  expected: true

invariant sqlite3_extra.IntegrityError.class_name:
  description: "sqlite3.IntegrityError.__name__ == 'IntegrityError'"
  category: class_names
  kind: python_call_eq
  function: IntegrityError.__name__.__eq__
  args: ["IntegrityError"]
  expected: true

invariant sqlite3_extra.ProgrammingError.class_name:
  description: "sqlite3.ProgrammingError.__name__ == 'ProgrammingError'"
  category: class_names
  kind: python_call_eq
  function: ProgrammingError.__name__.__eq__
  args: ["ProgrammingError"]
  expected: true

invariant sqlite3_extra.DataError.class_name:
  description: "sqlite3.DataError.__name__ == 'DataError'"
  category: class_names
  kind: python_call_eq
  function: DataError.__name__.__eq__
  args: ["DataError"]
  expected: true

# ---------------------------------------------------------------------------
# Exception class hierarchy
# ---------------------------------------------------------------------------

invariant sqlite3_extra.DatabaseError.base_is_Error:
  description: "sqlite3.DatabaseError.__bases__[0].__name__ == 'Error'"
  category: class_hierarchy
  kind: python_call_eq
  function: DatabaseError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

invariant sqlite3_extra.OperationalError.base_is_DatabaseError:
  description: "sqlite3.OperationalError.__bases__[0].__name__ == 'DatabaseError'"
  category: class_hierarchy
  kind: python_call_eq
  function: OperationalError.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "DatabaseError"

# ---------------------------------------------------------------------------
# Module-level constants — type checks
# ---------------------------------------------------------------------------

invariant sqlite3_extra.sqlite_version.class_is_str:
  description: "sqlite3.sqlite_version.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: sqlite_version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sqlite3_extra.version.class_is_str:
  description: "sqlite3.version.__class__.__name__ == 'str'"
  category: constants
  kind: python_call_eq
  function: version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant sqlite3_extra.threadsafety.class_is_int:
  description: "sqlite3.threadsafety.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: threadsafety.__class__.__name__.__eq__
  args: ["int"]
  expected: true
