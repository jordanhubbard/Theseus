# ---------------------------------------------------------------------------

table multiprocessing_extra70.ProcessError_hierarchy:
  description: "multiprocessing ProcessError __name__/__module__/__bases__ checks in mpann70 namespace — wave 238 theme: ProcessError exception base class identity; ProcessError.__name__=='ProcessError'; ProcessError.__module__=='multiprocessing.context'; ProcessError.__bases__[0].__name__=='Exception' (ProcessError is the root multiprocessing exception inheriting from Exception); NEW in extra70: first module and bases checks for ProcessError in the mpann70 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpann70a

  columns: [id, function, args, expected, description]
  rows:
    - [procerr_name,   ProcessError.__name__.__eq__,   ["ProcessError"],          true, "ProcessError.__name__ == 'ProcessError' — multiprocessing.ProcessError is the root multiprocessing exception class; its __name__ is 'ProcessError'; NEW in extra70: first __name__.__eq__ check for ProcessError in the mpann70 namespace; verified with Python 3.14.3"]
    - [procerr_module, ProcessError.__module__.__eq__, ["multiprocessing.context"], true, "ProcessError.__module__ == 'multiprocessing.context' — ProcessError is defined in multiprocessing/context.py; its __module__ is 'multiprocessing.context'; NEW in extra70: first __module__.__eq__ check for ProcessError in the mpann70 namespace; verified with Python 3.14.3"]
    - [procerr_bases0, "ProcessError.__bases__[0].__name__.__eq__", ["Exception"], true, "ProcessError.__bases__[0].__name__ == 'Exception' — multiprocessing.ProcessError inherits directly from Exception; __bases__[0].__name__ is 'Exception'; NEW in extra70: first __bases__[0].__name__.__eq__ check for ProcessError in the mpann70 namespace; verified with Python 3.14.3"]

