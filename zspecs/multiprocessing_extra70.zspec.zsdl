    - [tmoerr_name,   TimeoutError.__name__.__eq__,   ["TimeoutError"],           true, "TimeoutError.__name__ == 'TimeoutError' — multiprocessing.TimeoutError is a distinct class from the built-in TimeoutError; its __name__ is 'TimeoutError'; NEW in extra70: first __name__.__eq__ check for multiprocessing.TimeoutError in the mpann70 namespace; verified with Python 3.14.3"]
    - [tmoerr_module, TimeoutError.__module__.__eq__, ["multiprocessing.context"], true, "TimeoutError.__module__ == 'multiprocessing.context' — multiprocessing.TimeoutError is defined in multiprocessing/context.py; its __module__ is 'multiprocessing.context'; NEW in extra70: first __module__.__eq__ check for multiprocessing.TimeoutError in the mpann70 namespace; verified with Python 3.14.3"]
    - [tmoerr_bases0, "TimeoutError.__bases__[0].__name__.__eq__", ["ProcessError"], true, "TimeoutError.__bases__[0].__name__ == 'ProcessError' — multiprocessing.TimeoutError inherits from ProcessError; __bases__[0].__name__ is 'ProcessError'; NEW in extra70: first __bases__[0].__name__.__eq__ check for multiprocessing.TimeoutError in the mpann70 namespace; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Queue and Pipe factory class checks — extra70
#
# Wave 238 theme: Queue and Pipe are context-bound methods (factories).
#
# Queue.__class__.__name__ == 'method'
# Pipe.__class__.__name__ == 'method'
# ---------------------------------------------------------------------------

table multiprocessing_extra70.Queue_Pipe_factory:
  description: "multiprocessing Queue and Pipe __class__.__name__ checks in mpann70 namespace — wave 238 theme: Queue and Pipe are context-bound methods (factories); Queue.__class__.__name__=='method' (multiprocessing.Queue is a context-bound method returning a multiprocessing.queues.Queue instance); Pipe.__class__.__name__=='method' (multiprocessing.Pipe is a context-bound method); NEW in extra70: first __class__.__name__ checks for Queue and Pipe in the mpann70 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpann70c

  columns: [id, function, args, expected, description]
  rows:
    - [queue_class_name, Queue.__class__.__name__.__eq__, ["method"], true, "Queue.__class__.__name__ == 'method' — multiprocessing.Queue is a context-bound method (factory function) that returns a multiprocessing.queues.Queue instance; its __class__.__name__ is 'method'; NEW in extra70: first __class__.__name__.__eq__('method') check for Queue in the mpann70 namespace; verified with Python 3.14.3"]
    - [pipe_class_name,  Pipe.__class__.__name__.__eq__,  ["method"], true, "Pipe.__class__.__name__ == 'method' — multiprocessing.Pipe is a context-bound method (factory function); its __class__.__name__ is 'method'; NEW in extra70: first __class__.__name__.__eq__('method') check for Pipe in the mpann70 namespace; verified with Python 3.14.3"]

