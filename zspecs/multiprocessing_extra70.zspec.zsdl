spec: multiprocessing_extra70
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#exceptions — Python multiprocessing Exceptions documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "This spec extends multiprocessing_extra69.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__/__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/active_children/current_process __qualname__, Pool/Queue __doc__.__class__.__name__=='str', exception __module__ and __len__() tables, context-bound class __qualname__.__len__() tables, Process/Pool method tables, __mro__.__len__() tables, __all__ metadata, class __dict__ tables, class __class__ identity, mp.__all__ membership and length, __loader__/__spec__/__file__/__cached__ class names, __spec__ attributes, code object attribute chains, exception hierarchy, Pool/Process __init__ code object attributes, Process/Pool MRO entry names."
    - "This spec covers (mpann70 namespace): wave 238 theme — multiprocessing exception hierarchy + Queue/Pipe identity. NEW in extra70: AuthenticationError.__name__=='AuthenticationError'; AuthenticationError.__module__=='multiprocessing.context'; AuthenticationError.__bases__[0].__name__=='ProcessError' (AuthenticationError inherits from ProcessError, not Exception directly); ProcessError.__name__=='ProcessError'; ProcessError.__module__=='multiprocessing.context'; ProcessError.__bases__[0].__name__=='Exception'; TimeoutError.__name__=='TimeoutError'; TimeoutError.__module__=='multiprocessing.context'; TimeoutError.__bases__[0].__name__=='ProcessError'; Queue.__class__.__name__=='method' (multiprocessing.Queue is a context-bound method/factory, not a class directly); Pipe.__class__.__name__=='method' (multiprocessing.Pipe is a context-bound method/factory)."
    - "multiprocessing.AuthenticationError.__name__ == 'AuthenticationError'. AuthenticationError is defined in multiprocessing/context.py; its __name__ is 'AuthenticationError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__module__ == 'multiprocessing.context'. AuthenticationError is defined in multiprocessing/context.py; its __module__ is 'multiprocessing.context'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.AuthenticationError.__bases__[0].__name__ == 'ProcessError'. AuthenticationError inherits from ProcessError (not Exception directly); __bases__[0].__name__ is 'ProcessError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__name__ == 'ProcessError'. ProcessError is the root multiprocessing exception; its __name__ is 'ProcessError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.ProcessError.__bases__[0].__name__ == 'Exception'. ProcessError inherits directly from Exception; __bases__[0].__name__ is 'Exception'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__name__ == 'TimeoutError'. The multiprocessing.TimeoutError is a different class from the built-in TimeoutError; it inherits from ProcessError; __name__ is 'TimeoutError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.TimeoutError.__bases__[0].__name__ == 'ProcessError'. multiprocessing.TimeoutError inherits from ProcessError; __bases__[0].__name__ is 'ProcessError'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Queue.__class__.__name__ == 'method'. multiprocessing.Queue is a context-bound method (factory function) returning a multiprocessing.queues.Queue instance; its __class__.__name__ is 'method'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Pipe.__class__.__name__ == 'method'. multiprocessing.Pipe is a context-bound method (factory function); its __class__.__name__ is 'method'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing AuthenticationError identity checks — extra70
#
# Wave 238 theme: multiprocessing exception hierarchy.
#
# AuthenticationError.__name__ == 'AuthenticationError'
# AuthenticationError.__module__ == 'multiprocessing.context'
# AuthenticationError.__bases__[0].__name__ == 'ProcessError'
# ---------------------------------------------------------------------------

table multiprocessing_extra70.AuthenticationError_identity:
  description: "multiprocessing AuthenticationError __name__/__module__/__bases__ checks in mpann70 namespace — wave 238 theme: multiprocessing exception hierarchy; AuthenticationError.__name__=='AuthenticationError'; AuthenticationError.__module__=='multiprocessing.context'; AuthenticationError.__bases__[0].__name__=='ProcessError' (AuthenticationError inherits from ProcessError, not Exception directly); NEW in extra70: first module and bases checks for AuthenticationError in the mpann70 namespace; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpann70

  columns: [id, function, args, expected, description]
  rows:
    - [autherr_name,     AuthenticationError.__name__.__eq__,     ["AuthenticationError"],    true, "AuthenticationError.__name__ == 'AuthenticationError' — multiprocessing.AuthenticationError is defined in multiprocessing/context.py; its __name__ is 'AuthenticationError'; NEW in extra70: first __name__.__eq__ check for AuthenticationError in the mpann70 namespace; verified with Python 3.14.3"]
    - [autherr_module,   AuthenticationError.__module__.__eq__,   ["multiprocessing.context"], true, "AuthenticationError.__module__ == 'multiprocessing.context' — AuthenticationError is defined in multiprocessing/context.py; its __module__ is 'multiprocessing.context'; NEW in extra70: first __module__.__eq__ check for AuthenticationError in the mpann70 namespace; verified with Python 3.14.3"]
    - [autherr_bases0,   "AuthenticationError.__bases__[0].__name__.__eq__", ["ProcessError"], true, "AuthenticationError.__bases__[0].__name__ == 'ProcessError' — multiprocessing.AuthenticationError inherits from ProcessError; __bases__[0].__name__ is 'ProcessError'; NEW in extra70: first __bases__[0].__name__.__eq__ check for AuthenticationError in the mpann70 namespace; verified with Python 3.14.3"]

