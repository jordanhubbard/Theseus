invariant multiprocessing_extra70.AuthenticationError_module:
  description: "multiprocessing.AuthenticationError.__module__.__eq__('multiprocessing.context') returns True — AuthenticationError is defined in multiprocessing/context.py; its __module__ is 'multiprocessing.context'; NEW in extra70: first standalone __module__ invariant for AuthenticationError in the mpann70 namespace; wave 238 first module identity invariant for AuthenticationError; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: AuthenticationError.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra70.AuthenticationError_bases0_ProcessError:
  description: "multiprocessing.AuthenticationError.__bases__[0].__name__.__eq__('ProcessError') returns True — AuthenticationError inherits from ProcessError; __bases__[0].__name__ is 'ProcessError'; NEW in extra70: first standalone __bases__[0].__name__ invariant for AuthenticationError in the mpann70 namespace; wave 238 first exception hierarchy invariant for AuthenticationError; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "AuthenticationError.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
  expected: true

invariant multiprocessing_extra70.ProcessError_bases0_Exception:
  description: "multiprocessing.ProcessError.__bases__[0].__name__.__eq__('Exception') returns True — ProcessError inherits directly from Exception; __bases__[0].__name__ is 'Exception'; NEW in extra70: first standalone __bases__[0].__name__ invariant for ProcessError in the mpann70 namespace; wave 238 first exception hierarchy invariant for ProcessError; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "ProcessError.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

invariant multiprocessing_extra70.TimeoutError_bases0_ProcessError:
  description: "multiprocessing.TimeoutError.__bases__[0].__name__.__eq__('ProcessError') returns True — multiprocessing.TimeoutError inherits from ProcessError; __bases__[0].__name__ is 'ProcessError'; NEW in extra70: first standalone __bases__[0].__name__ invariant for multiprocessing.TimeoutError in the mpann70 namespace; wave 238 first exception hierarchy invariant for multiprocessing.TimeoutError; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "TimeoutError.__bases__[0].__name__.__eq__"
  args: ["ProcessError"]
