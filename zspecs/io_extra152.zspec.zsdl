spec: io_extra152
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.BufferedReader and io.BufferedWriter method __qualname__ values and lengths, class identity (both have __module__=='_io', MRO length 4), and io.BytesIO and io.StringIO method __qualname__ values."
    - "io.BufferedReader method qualnames use the public class name 'BufferedReader' (not a private prefix), unlike io.IOBase which uses '_IOBase'. This reflects that BufferedReader is a concrete class, not an ABC."
    - "io.BufferedReader.read.__qualname__ == 'BufferedReader.read' (len=19); peek=19, read1=20, close=20, readline=23, readinto=23, readinto1=24."
    - "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write' (len=20); flush=20, seek=19, tell=19, close=20."
    - "io.BufferedReader.__module__ == '_io' (the C extension); __bases__[0].__name__ == '_BufferedIOBase'; MRO length == 4: [BufferedReader, _BufferedIOBase, _IOBase, object]."
    - "io.BytesIO method qualnames: read=12, seek=12, tell=12, write=13, close=13, getvalue=16, getbuffer=17."
    - "io.StringIO method qualnames: read=13, seek=13, write=14, getvalue=17, readline=17."
    - "io.BytesIO.__init__.__qualname__ == 'BytesIO.__init__' (len=16); io.StringIO.__init__.__qualname__ == 'StringIO.__init__' (len=17)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedReader method __qualname__ values and lengths
# All follow 'BufferedReader.<method>' pattern (public class name, not private prefix).
# read=19, peek=19, seek=19, tell=19; read1=20, close=20; readline=23, readinto=23; readinto1=24.
# ---------------------------------------------------------------------------

table io_extra152.BufferedReader_method_qualnames:
  description: "io.BufferedReader method __qualname__ values: read/peek=19, read1/close=20, readline/readinto=23, readinto1=24; all use public class name 'BufferedReader'"
  kind: python_call_eq
  category: qualname
  id_prefix: iobufr152

  columns: [id, function, args, expected, description]
  rows:
    - [br_read_qeq,       BufferedReader.read.__qualname__.__eq__,       ["BufferedReader.read"],       true, "io.BufferedReader.read.__qualname__ == 'BufferedReader.read' (len=19; reads up to size bytes from the underlying raw stream)"]
    - [br_read_qlen,      BufferedReader.read.__qualname__.__len__,      [],                            19,   "io.BufferedReader.read.__qualname__.__len__() == 19 ('BufferedReader.read' has 19 characters)"]
    - [br_peek_qeq,       BufferedReader.peek.__qualname__.__eq__,       ["BufferedReader.peek"],       true, "io.BufferedReader.peek.__qualname__ == 'BufferedReader.peek' (len=19; returns buffered bytes without advancing the position; tied with read)"]
    - [br_peek_qlen,      BufferedReader.peek.__qualname__.__len__,      [],                            19,   "io.BufferedReader.peek.__qualname__.__len__() == 19 (tied with read and seek and tell)"]
    - [br_read1_qeq,      BufferedReader.read1.__qualname__.__eq__,      ["BufferedReader.read1"],      true, "io.BufferedReader.read1.__qualname__ == 'BufferedReader.read1' (len=20; read up to size bytes with at most one raw read call)"]
    - [br_read1_qlen,     BufferedReader.read1.__qualname__.__len__,     [],                            20,   "io.BufferedReader.read1.__qualname__.__len__() == 20 ('BufferedReader.read1' has 20 characters; tied with close)"]
    - [br_readline_qeq,   BufferedReader.readline.__qualname__.__eq__,   ["BufferedReader.readline"],   true, "io.BufferedReader.readline.__qualname__ == 'BufferedReader.readline' (len=23; reads a single line from the buffered stream)"]
    - [br_readline_qlen,  BufferedReader.readline.__qualname__.__len__,  [],                            23,   "io.BufferedReader.readline.__qualname__.__len__() == 23 ('BufferedReader.readline' has 23 characters; tied with readinto)"]
    - [br_readinto_qeq,   BufferedReader.readinto.__qualname__.__eq__,   ["BufferedReader.readinto"],   true, "io.BufferedReader.readinto.__qualname__ == 'BufferedReader.readinto' (len=23; reads into a pre-allocated buffer object; tied with readline)"]
    - [br_readinto1_qeq,  BufferedReader.readinto1.__qualname__.__eq__,  ["BufferedReader.readinto1"],  true, "io.BufferedReader.readinto1.__qualname__ == 'BufferedReader.readinto1' (len=24; reads with at most one raw read call; longest BufferedReader method qualname)"]
    - [br_readinto1_qlen, BufferedReader.readinto1.__qualname__.__len__, [],                            24,   "io.BufferedReader.readinto1.__qualname__.__len__() == 24 ('BufferedReader.readinto1' has 24 characters; longest BufferedReader method qualname)"]

# ---------------------------------------------------------------------------
# io.BufferedWriter method __qualname__ values and lengths
# All follow 'BufferedWriter.<method>' pattern.
# seek=19, tell=19; write=20, flush=20, close=20.
# ---------------------------------------------------------------------------

table io_extra152.BufferedWriter_method_qualnames:
  description: "io.BufferedWriter method __qualname__ values: seek/tell=19, write/flush/close=20; all use public class name 'BufferedWriter'"
  kind: python_call_eq
  category: qualname
  id_prefix: iobufr152

  columns: [id, function, args, expected, description]
  rows:
    - [bw_write_qeq,   BufferedWriter.write.__qualname__.__eq__,  ["BufferedWriter.write"],  true, "io.BufferedWriter.write.__qualname__ == 'BufferedWriter.write' (len=20; writes the given bytes-like object to the buffer)"]
    - [bw_write_qlen,  BufferedWriter.write.__qualname__.__len__, [],                         20,   "io.BufferedWriter.write.__qualname__.__len__() == 20 ('BufferedWriter.write' has 20 characters; tied with flush and close)"]
    - [bw_flush_qeq,   BufferedWriter.flush.__qualname__.__eq__,  ["BufferedWriter.flush"],  true, "io.BufferedWriter.flush.__qualname__ == 'BufferedWriter.flush' (len=20; forces bytes held in the buffer into the raw stream)"]
    - [bw_flush_qlen,  BufferedWriter.flush.__qualname__.__len__, [],                         20,   "io.BufferedWriter.flush.__qualname__.__len__() == 20 (tied with write and close at 20)"]
    - [bw_seek_qeq,    BufferedWriter.seek.__qualname__.__eq__,   ["BufferedWriter.seek"],   true, "io.BufferedWriter.seek.__qualname__ == 'BufferedWriter.seek' (len=19; changes the stream position; shorter than write because 'seek' is 4 chars vs 'write' 5 chars)"]
    - [bw_seek_qlen,   BufferedWriter.seek.__qualname__.__len__,  [],                         19,   "io.BufferedWriter.seek.__qualname__.__len__() == 19 ('BufferedWriter.seek' has 19 characters; tied with tell)"]
    - [bw_tell_qeq,    BufferedWriter.tell.__qualname__.__eq__,   ["BufferedWriter.tell"],   true, "io.BufferedWriter.tell.__qualname__ == 'BufferedWriter.tell' (len=19; returns current stream position; tied with seek)"]
    - [bw_close_qeq,   BufferedWriter.close.__qualname__.__eq__,  ["BufferedWriter.close"],  true, "io.BufferedWriter.close.__qualname__ == 'BufferedWriter.close' (len=20; flushes the write buffer then closes the raw stream)"]

# ---------------------------------------------------------------------------
# io.BytesIO and io.StringIO method __qualname__ values and lengths
# BytesIO: read/seek/tell=12, write/close=13, getvalue=16, getbuffer=17.
# StringIO: read/seek=13, write=14, getvalue/readline=17.
# BytesIO.__init__: 'BytesIO.__init__' (len=16).
# StringIO.__init__: 'StringIO.__init__' (len=17).
# ---------------------------------------------------------------------------

table io_extra152.BytesIO_StringIO_qualnames:
  description: "io.BytesIO method qualnames: read/seek/tell=12, write/close=13, getvalue=16, getbuffer=17; io.StringIO: read/seek=13, write=14, getvalue/readline=17"
  kind: python_call_eq
  category: qualname
  id_prefix: iobufr152

  columns: [id, function, args, expected, description]
  rows:
    - [bio_init_qeq,      BytesIO.__init__.__qualname__.__eq__,     ["BytesIO.__init__"],  true, "io.BytesIO.__init__.__qualname__ == 'BytesIO.__init__' (len=16; BytesIO defines its own __init__)"]
    - [bio_init_qlen,     BytesIO.__init__.__qualname__.__len__,    [],                    16,   "io.BytesIO.__init__.__qualname__.__len__() == 16 ('BytesIO.__init__' has 16 characters)"]
    - [bio_read_qeq,      BytesIO.read.__qualname__.__eq__,         ["BytesIO.read"],      true, "io.BytesIO.read.__qualname__ == 'BytesIO.read' (len=12; reads and returns up to size bytes)"]
    - [bio_read_qlen,     BytesIO.read.__qualname__.__len__,        [],                    12,   "io.BytesIO.read.__qualname__.__len__() == 12 (tied with seek and tell)"]
    - [bio_getvalue_qeq,  BytesIO.getvalue.__qualname__.__eq__,     ["BytesIO.getvalue"],  true, "io.BytesIO.getvalue.__qualname__ == 'BytesIO.getvalue' (len=16; returns the entire buffer contents)"]
    - [bio_getvalue_qlen, BytesIO.getvalue.__qualname__.__len__,    [],                    16,   "io.BytesIO.getvalue.__qualname__.__len__() == 16 ('BytesIO.getvalue' has 16 characters)"]
    - [bio_getbuf_qeq,    BytesIO.getbuffer.__qualname__.__eq__,    ["BytesIO.getbuffer"], true, "io.BytesIO.getbuffer.__qualname__ == 'BytesIO.getbuffer' (len=17; returns a readable/writable view of the buffer without copying)"]
    - [bio_getbuf_qlen,   BytesIO.getbuffer.__qualname__.__len__,   [],                    17,   "io.BytesIO.getbuffer.__qualname__.__len__() == 17 ('BytesIO.getbuffer' has 17 characters; the longest BytesIO method qualname)"]
    - [sio_init_qeq,      StringIO.__init__.__qualname__.__eq__,    ["StringIO.__init__"], true, "io.StringIO.__init__.__qualname__ == 'StringIO.__init__' (len=17; StringIO defines its own __init__)"]
    - [sio_init_qlen,     StringIO.__init__.__qualname__.__len__,   [],                    17,   "io.StringIO.__init__.__qualname__.__len__() == 17 ('StringIO.__init__' has 17 characters; 1 longer than BytesIO.__init__ because 'String' is 6 chars vs 'Bytes' is 5)"]
    - [sio_getvalue_qeq,  StringIO.getvalue.__qualname__.__eq__,    ["StringIO.getvalue"], true, "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue' (len=17; returns the entire string buffer contents; tied with __init__)"]
    - [sio_readline_qeq,  StringIO.readline.__qualname__.__eq__,    ["StringIO.readline"], true, "io.StringIO.readline.__qualname__ == 'StringIO.readline' (len=17; tied with getvalue; reads one line from the string buffer)"]

# ---------------------------------------------------------------------------
# io.BufferedReader and io.BufferedWriter class identity
# Both have __module__ == '_io', __bases__[0].__name__ == '_BufferedIOBase', MRO length == 4.
# BufferedReader.__doc__ len == 68; BufferedWriter.__doc__ len == 196.
# ---------------------------------------------------------------------------

table io_extra152.BufferedReader_BufferedWriter_class_identity:
  description: "io.BufferedReader and io.BufferedWriter class identity: both __module__='_io', __bases__[0]='_BufferedIOBase', MRO length=4; BufferedReader.__doc__ len=68, BufferedWriter.__doc__ len=196"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobufr152

  columns: [id, function, args, expected, description]
  rows:
    - [br_name_eq,     BufferedReader.__name__.__eq__,                     ["BufferedReader"], true, "io.BufferedReader.__name__ == 'BufferedReader'"]
    - [br_name_len,    BufferedReader.__name__.__len__,                    [],                 14,   "io.BufferedReader.__name__.__len__() == 14 ('BufferedReader' has 14 characters)"]
    - [br_module_eq,   BufferedReader.__module__.__eq__,                   ["_io"],            true, "io.BufferedReader.__module__ == '_io' (implemented in the C extension _io, like most concrete io classes)"]
    - [br_mro_len,     "BufferedReader.__mro__.__len__",                   [],                 4,    "io.BufferedReader.__mro__.__len__() == 4 (MRO: [BufferedReader, _BufferedIOBase, _IOBase, object])"]
    - [br_base0_eq,    "BufferedReader.__bases__[0].__name__.__eq__",      ["_BufferedIOBase"],true, "io.BufferedReader.__bases__[0].__name__ == '_BufferedIOBase' (the private C-extension base; note the leading underscore)"]
    - [br_doc_len,     BufferedReader.__doc__.__len__,                     [],                 68,   "io.BufferedReader.__doc__.__len__() == 68 (68 characters; a brief class docstring describing the readable buffered IO)"]
    - [bw_name_eq,     BufferedWriter.__name__.__eq__,                     ["BufferedWriter"], true, "io.BufferedWriter.__name__ == 'BufferedWriter'"]
    - [bw_module_eq,   BufferedWriter.__module__.__eq__,                   ["_io"],            true, "io.BufferedWriter.__module__ == '_io' (also implemented in the C extension _io)"]
    - [bw_mro_len,     "BufferedWriter.__mro__.__len__",                   [],                 4,    "io.BufferedWriter.__mro__.__len__() == 4 (same 4-entry MRO structure as BufferedReader: [BufferedWriter, _BufferedIOBase, _IOBase, object])"]
    - [bw_base0_eq,    "BufferedWriter.__bases__[0].__name__.__eq__",      ["_BufferedIOBase"],true, "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' (same direct base as BufferedReader)"]
    - [bw_doc_len,     BufferedWriter.__doc__.__len__,                     [],                 196,  "io.BufferedWriter.__doc__.__len__() == 196 (196 characters; notably longer than BufferedReader (68), describing the writeable sequential raw IO buffer and the constructor_size parameter)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra152.BufferedReader.read_qualname_uses_public_name:
  description: "io.BufferedReader.read.__qualname__ == 'BufferedReader.read' (len=19) — unlike io.IOBase methods whose qualnames use the private C-extension prefix '_IOBase', concrete io classes like BufferedReader use their public class name in __qualname__. This reveals that BufferedReader is a distinct C extension type, not just an alias for a private type."
  category: qualname
  kind: python_call_eq
  function: BufferedReader.read.__qualname__.__eq__
  args: ["BufferedReader.read"]
  expected: true

invariant io_extra152.BufferedReader.readinto1_qualname_len_24:
  description: "io.BufferedReader.readinto1.__qualname__.__len__() == 24 ('BufferedReader.readinto1' has 24 characters; the longest BufferedReader method qualname; 'BufferedReader.' prefix (15) + 'readinto1' (9) = 24)"
  category: qualname
  kind: python_call_eq
  function: BufferedReader.readinto1.__qualname__.__len__
  args: []
  expected: 24

invariant io_extra152.BufferedWriter.flush_qualname_eq:
  description: "io.BufferedWriter.flush.__qualname__ == 'BufferedWriter.flush' (len=20) — BufferedWriter.flush forces any data remaining in the write buffer into the underlying raw stream; its qualname uses the public class name, unlike io.IOBase.flush.__qualname__ == '_IOBase.flush' (len=13) from io_extra150"
  category: qualname
  kind: python_call_eq
  function: BufferedWriter.flush.__qualname__.__eq__
  args: ["BufferedWriter.flush"]
  expected: true

invariant io_extra152.BufferedReader.mro_len_4:
  description: "io.BufferedReader.__mro__.__len__() == 4 (MRO is [BufferedReader, _BufferedIOBase, _IOBase, object]; the concrete buffered reader sits above the private ABC chain; this 4-entry MRO is the same depth as BytesIO and StringIO)"
  category: class_identity
  kind: python_call_eq
  function: "BufferedReader.__mro__.__len__"
  args: []
  expected: 4

invariant io_extra152.BytesIO.init_qualname_len_16:
  description: "io.BytesIO.__init__.__qualname__.__len__() == 16 ('BytesIO.__init__' has 16 characters; BytesIO defines its own __init__ that takes an optional initial bytes value; this contrasts with io.BufferedReader which does not have __init__ in the same sense)"
  category: qualname
  kind: python_call_eq
  function: BytesIO.__init__.__qualname__.__len__
  args: []
  expected: 16

invariant io_extra152.StringIO.init_qualname_len_17:
  description: "io.StringIO.__init__.__qualname__.__len__() == 17 ('StringIO.__init__' has 17 characters; 1 longer than BytesIO.__init__ (16) because 'String' is 6 characters while 'Bytes' is 5; StringIO's __init__ accepts optional initial value and newline parameters)"
  category: qualname
  kind: python_call_eq
  function: StringIO.__init__.__qualname__.__len__
  args: []
  expected: 17

invariant io_extra152.BytesIO.getbuffer_qualname_len_17:
  description: "io.BytesIO.getbuffer.__qualname__.__len__() == 17 ('BytesIO.getbuffer' has 17 characters; the longest BytesIO method qualname; getbuffer returns a readable/writable memoryview of the buffer contents without copying the data)"
  category: qualname
  kind: python_call_eq
  function: BytesIO.getbuffer.__qualname__.__len__
  args: []
  expected: 17

invariant io_extra152.BufferedReader.module_eq__io:
  description: "io.BufferedReader.__module__ == '_io' — the concrete io classes (BufferedReader, BufferedWriter, BytesIO, StringIO, FileIO) are all implemented in the C extension module _io, not in Lib/io.py; the public 'io' package re-exports them; this is consistent with io.open.__module__ == '_io' (io_extra151)"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__module__.__eq__
  args: ["_io"]
  expected: true

