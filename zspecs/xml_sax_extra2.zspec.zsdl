spec: xml_sax_extra2
version: ">=3.0"
backend: python_module(xml.sax.handler)

docs: https://docs.python.org/3/library/xml.sax.handler.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xml.sax.handler.html — Python xml.sax.handler documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xml/sax/handler.py"
  notes:
    - "This spec targets the xml.sax.handler submodule (backend: python_module(xml.sax.handler))."
    - "xml_sax.zspec.zsdl and xml_sax_extra.zspec.zsdl use backend python_module(xml.sax) and cover the parent xml.sax namespace."
    - "xml.sax.handler exposes ContentHandler, ErrorHandler, DTDHandler, EntityResolver, and LexicalHandler classes."
    - "xml.sax.handler also defines SAX2 feature URI constants (feature_namespaces, feature_validation, etc.) and property URI constants."
    - "xml.sax.handler.version == '2.0beta' — the SAX2 specification version string."
    - "xml.sax.handler.all_features is a list of 6 feature URI strings."
    - "xml.sax.handler.all_properties is a list of 6 property URI strings."
    - "All handler classes have __module__ == 'xml.sax.handler'."
    - "LexicalHandler is defined in xml.sax.handler but not re-exported to xml.sax directly."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Handler class __name__ checks (from xml.sax.handler submodule)
# ---------------------------------------------------------------------------

table xml_sax_extra2.handler_class_names:
  kind: python_call_eq
  category: classes
  id_prefix: hcname

  columns: [id, function, args, expected]
  rows:
    - [ContentHandler,  ContentHandler.__name__.__eq__,  ["ContentHandler"],  true]
    - [ErrorHandler,    ErrorHandler.__name__.__eq__,    ["ErrorHandler"],    true]
    - [DTDHandler,      DTDHandler.__name__.__eq__,      ["DTDHandler"],      true]
    - [EntityResolver,  EntityResolver.__name__.__eq__,  ["EntityResolver"],  true]
    - [LexicalHandler,  LexicalHandler.__name__.__eq__,  ["LexicalHandler"],  true]

# ---------------------------------------------------------------------------
# Handler class __module__ checks
# ---------------------------------------------------------------------------

table xml_sax_extra2.handler_class_modules:
  kind: python_call_eq
  category: classes
  id_prefix: hcmod

  columns: [id, function, args, expected]
  rows:
    - [ContentHandler,  ContentHandler.__module__.__eq__,  ["xml.sax.handler"], true]
    - [ErrorHandler,    ErrorHandler.__module__.__eq__,    ["xml.sax.handler"], true]
    - [DTDHandler,      DTDHandler.__module__.__eq__,      ["xml.sax.handler"], true]
    - [EntityResolver,  EntityResolver.__module__.__eq__,  ["xml.sax.handler"], true]
    - [LexicalHandler,  LexicalHandler.__module__.__eq__,  ["xml.sax.handler"], true]

# ---------------------------------------------------------------------------
# Handler class __qualname__ checks
# ---------------------------------------------------------------------------

table xml_sax_extra2.handler_class_qualnames:
  kind: python_call_eq
  category: classes
  id_prefix: hcqname

  columns: [id, function, args, expected]
  rows:
    - [ContentHandler,  ContentHandler.__qualname__.__eq__,  ["ContentHandler"],  true]
    - [ErrorHandler,    ErrorHandler.__qualname__.__eq__,    ["ErrorHandler"],    true]
    - [DTDHandler,      DTDHandler.__qualname__.__eq__,      ["DTDHandler"],      true]
    - [EntityResolver,  EntityResolver.__qualname__.__eq__,  ["EntityResolver"],  true]
    - [LexicalHandler,  LexicalHandler.__qualname__.__eq__,  ["LexicalHandler"],  true]

# ---------------------------------------------------------------------------
# SAX feature URI string constants
# ---------------------------------------------------------------------------

table xml_sax_extra2.feature_constants:
  kind: python_call_eq
  category: constants
  id_prefix: feat

  columns: [id, function, args, expected]
  rows:
    - [namespaces,         feature_namespaces.__eq__,         ["http://xml.org/sax/features/namespaces"],          true]
    - [namespace_prefixes, feature_namespace_prefixes.__eq__,  ["http://xml.org/sax/features/namespace-prefixes"],  true]
    - [string_interning,   feature_string_interning.__eq__,    ["http://xml.org/sax/features/string-interning"],    true]
    - [validation,         feature_validation.__eq__,          ["http://xml.org/sax/features/validation"],          true]
    - [ext_ges,            feature_external_ges.__eq__,        ["http://xml.org/sax/features/external-general-entities"], true]
    - [ext_pes,            feature_external_pes.__eq__,        ["http://xml.org/sax/features/external-parameter-entities"], true]

# ---------------------------------------------------------------------------
# SAX property URI string constants
# ---------------------------------------------------------------------------

table xml_sax_extra2.property_constants:
  kind: python_call_eq
  category: constants
  id_prefix: prop

  columns: [id, function, args, expected]
  rows:
    - [lexical_handler,  property_lexical_handler.__eq__,  ["http://xml.org/sax/properties/lexical-handler"],   true]
    - [dom_node,         property_dom_node.__eq__,          ["http://xml.org/sax/properties/dom-node"],          true]
    - [encoding,         property_encoding.__eq__,          ["http://www.python.org/sax/properties/encoding"],   true]

# ---------------------------------------------------------------------------
# version and list-length invariants
# ---------------------------------------------------------------------------

invariant xml_sax_extra2.version:
  description: "xml.sax.handler.version == '2.0beta'"
  category: constants
  kind: python_call_eq
  function: version.__eq__
  args: ["2.0beta"]
  expected: true

invariant xml_sax_extra2.all_features_length:
  description: "len(xml.sax.handler.all_features) == 6"
  category: constants
  kind: python_call_eq
  function: all_features.__len__
  args: []
  expected: 6

invariant xml_sax_extra2.all_properties_length:
  description: "len(xml.sax.handler.all_properties) == 6"
  category: constants
  kind: python_call_eq
  function: all_properties.__len__
  args: []
  expected: 6
