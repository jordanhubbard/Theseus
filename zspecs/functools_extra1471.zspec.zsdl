spec: functools_extra1471
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "Wave 545 theme: __len__ and __getitem__ method presence and type checks for functools classes."
    - "functools.partial: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "functools.cached_property: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "functools.singledispatchmethod: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "functools.partialmethod: no __len__, no __getitem__, no __setitem__, no __delitem__ in __dict__. Verified with Python 3.12."
    - "All functools classes in this wave are callable wrappers, descriptors, or dispatch helpers — none implement the sequence or mapping protocols."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial — __len__ and __getitem__ absence checks
#
# Wave 545 theme: functools.partial — partial application of a callable.
#
# functools.partial.__dict__.__contains__("__len__") == False
# functools.partial.__dict__.__contains__("__getitem__") == False
# functools.partial.__dict__.__contains__("__setitem__") == False
# functools.partial.__dict__.__contains__("__delitem__") == False
# functools.partial.__dict__.__contains__("__iter__") == False
#
# partial wraps another callable with preset positional and keyword arguments.
# It does not implement the sequence or mapping protocol. New to extra1471.
# ---------------------------------------------------------------------------

table functools_extra1471.partial_len_getitem_absence:
  description: "functools.partial has no __len__, __getitem__, __setitem__, __delitem__, __iter__ in __dict__; wave 545; new to extra1471"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1471pa

  columns: [id, function, args, expected, description]
  rows:
    - [fu1471pa001,
       "partial.__dict__.__contains__",
       ["__len__"],
       false,
       "functools.partial.__dict__.__contains__('__len__') == False — partial is a callable wrapper that does not implement the sequence protocol; __len__ is not defined in partial.__dict__; verified with Python 3.12; new to extra1471"]
    - [fu1471pa002,
       "partial.__dict__.__contains__",
       ["__getitem__"],
       false,
       "functools.partial.__dict__.__contains__('__getitem__') == False — partial does not support index access; __getitem__ is not defined in partial.__dict__; verified with Python 3.12; new to extra1471"]
    - [fu1471pa003,
       "partial.__dict__.__contains__",
       ["__setitem__"],
       false,
       "functools.partial.__dict__.__contains__('__setitem__') == False — partial does not support item assignment; __setitem__ is not defined in partial.__dict__; verified with Python 3.12; new to extra1471"]
    - [fu1471pa004,
       "partial.__dict__.__contains__",
       ["__delitem__"],
       false,
       "functools.partial.__dict__.__contains__('__delitem__') == False — partial does not support item deletion; __delitem__ is not defined in partial.__dict__; verified with Python 3.12; new to extra1471"]
    - [fu1471pa005,
       "partial.__dict__.__contains__",
       ["__iter__"],
       false,
       "functools.partial.__dict__.__contains__('__iter__') == False — partial is not iterable; __iter__ is not defined in partial.__dict__; verified with Python 3.12; new to extra1471"]
    - [fu1471pa006,
       "partial.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a class object; its metaclass is the built-in type; str.__eq__('type') returns True; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 2: functools.cached_property — __len__ and __getitem__ absence checks
#
# Wave 545 theme: functools.cached_property — descriptor that caches method results.
#
# functools.cached_property.__dict__.__contains__("__len__") == False
# functools.cached_property.__dict__.__contains__("__getitem__") == False
# functools.cached_property.__dict__.__contains__("__setitem__") == False
# functools.cached_property.__dict__.__contains__("__delitem__") == False
#
# cached_property is a data descriptor whose instances cache computed values
# in the instance __dict__. It has __get__ and __set_name__ but no sequence
# or mapping protocol methods. New to extra1471.
# ---------------------------------------------------------------------------

table functools_extra1471.cached_property_len_getitem_absence:
  description: "functools.cached_property has no __len__, __getitem__, __setitem__, __delitem__ in __dict__; wave 545; new to extra1471"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1471cp

  columns: [id, function, args, expected, description]
  rows:
    - [fu1471cp001,
       "cached_property.__dict__.__contains__",
       ["__len__"],
       false,
       "functools.cached_property.__dict__.__contains__('__len__') == False — cached_property is a descriptor class; it does not implement the sequence protocol; __len__ is not defined in cached_property.__dict__; verified with Python 3.12; new to extra1471"]
    - [fu1471cp002,
       "cached_property.__dict__.__contains__",
       ["__getitem__"],
       false,
       "functools.cached_property.__dict__.__contains__('__getitem__') == False — cached_property does not support index access; __getitem__ is not defined in its __dict__; verified with Python 3.12; new to extra1471"]
    - [fu1471cp003,
       "cached_property.__dict__.__contains__",
       ["__setitem__"],
       false,
       "functools.cached_property.__dict__.__contains__('__setitem__') == False — cached_property does not support item assignment; __setitem__ is not in its __dict__; verified with Python 3.12; new to extra1471"]
    - [fu1471cp004,
       "cached_property.__dict__.__contains__",
       ["__delitem__"],
       false,
       "functools.cached_property.__dict__.__contains__('__delitem__') == False — cached_property does not support item deletion; __delitem__ is not in its __dict__; verified with Python 3.12; new to extra1471"]
    - [fu1471cp005,
       "cached_property.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.cached_property.__dict__.__contains__('__get__') == True — cached_property IS a descriptor and does define __get__ in its __dict__; str.__contains__ returns True; verified with Python 3.12; new to extra1471"]
    - [fu1471cp006,
       "cached_property.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a class object; its metaclass is the built-in type; str.__eq__('type') returns True; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 3: functools.singledispatchmethod — __len__ and __getitem__ absence
#
# Wave 545 theme: functools.singledispatchmethod — decorator for single-dispatch
# generic methods; dispatches based on the type of the first non-self argument.
#
# functools.singledispatchmethod.__dict__.__contains__("__len__") == False
# functools.singledispatchmethod.__dict__.__contains__("__getitem__") == False
# functools.singledispatchmethod.__dict__.__contains__("__setitem__") == False
# functools.singledispatchmethod.__dict__.__contains__("__delitem__") == False
#
# singledispatchmethod is a descriptor; it has __get__ and __init__ but no
# sequence or mapping protocol methods. New to extra1471.
# ---------------------------------------------------------------------------

table functools_extra1471.singledispatchmethod_len_getitem_absence:
  description: "functools.singledispatchmethod has no __len__, __getitem__, __setitem__, __delitem__ in __dict__; wave 545; new to extra1471"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1471sd

  columns: [id, function, args, expected, description]
  rows:
    - [fu1471sd001,
       "singledispatchmethod.__dict__.__contains__",
       ["__len__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__len__') == False — singledispatchmethod is a dispatch decorator; it does not implement the sequence protocol; __len__ is not in its __dict__; verified with Python 3.12; new to extra1471"]
    - [fu1471sd002,
       "singledispatchmethod.__dict__.__contains__",
       ["__getitem__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__getitem__') == False — singledispatchmethod does not support index access; __getitem__ is not in its __dict__; verified with Python 3.12; new to extra1471"]
    - [fu1471sd003,
       "singledispatchmethod.__dict__.__contains__",
       ["__setitem__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__setitem__') == False — singledispatchmethod does not support item assignment; __setitem__ is not in its __dict__; verified with Python 3.12; new to extra1471"]
    - [fu1471sd004,
       "singledispatchmethod.__dict__.__contains__",
       ["__delitem__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__delitem__') == False — singledispatchmethod does not support item deletion; __delitem__ is not in its __dict__; verified with Python 3.12; new to extra1471"]
    - [fu1471sd005,
       "singledispatchmethod.__dict__.__contains__",
       ["__get__"],
       true,
       "functools.singledispatchmethod.__dict__.__contains__('__get__') == True — singledispatchmethod IS a descriptor and defines __get__ in its __dict__; str.__contains__ returns True; verified with Python 3.12; new to extra1471"]
    - [fu1471sd006,
       "singledispatchmethod.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.singledispatchmethod.__class__.__name__.__eq__('type') == True — singledispatchmethod is a class object; its metaclass is the built-in type; str.__eq__('type') returns True; new to extra1471"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1471
# ---------------------------------------------------------------------------

invariant functools_extra1471.partial_no_len:
  description: "functools.partial.__dict__ does not contain '__len__' — partial is a callable wrapper, not a sequence; wave 545; new to extra1471"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant functools_extra1471.partial_no_getitem:
  description: "functools.partial.__dict__ does not contain '__getitem__' — partial does not support index access; wave 545; new to extra1471"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__getitem__"]
  expected: false

invariant functools_extra1471.cached_property_no_len:
  description: "functools.cached_property.__dict__ does not contain '__len__' — cached_property is a descriptor, not a sequence; wave 545; new to extra1471"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant functools_extra1471.cached_property_no_getitem:
  description: "functools.cached_property.__dict__ does not contain '__getitem__' — cached_property does not support index access; wave 545; new to extra1471"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__getitem__"]
  expected: false

invariant functools_extra1471.singledispatchmethod_no_len:
  description: "functools.singledispatchmethod.__dict__ does not contain '__len__' — singledispatchmethod is a dispatch decorator, not a sequence; wave 545; new to extra1471"
  kind: python_call_eq
  function: singledispatchmethod.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant functools_extra1471.singledispatchmethod_no_getitem:
  description: "functools.singledispatchmethod.__dict__ does not contain '__getitem__' — singledispatchmethod does not support index access; wave 545; new to extra1471"
  kind: python_call_eq
  function: singledispatchmethod.__dict__.__contains__
  args: ["__getitem__"]
  expected: false
