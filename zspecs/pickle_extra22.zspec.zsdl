spec: pickle_extra22
version: ">=3.9"
backend: python_module(pickle)

docs: https://docs.python.org/3/library/pickle.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pickle.html — Python pickle module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pickle.py"
    - "CPython source: Modules/_pickle.c"
  notes:
    - "This spec extends pickle.zspec.zsdl through pickle_extra21.zspec.zsdl."
    - "Prior specs covered: Pickler/Unpickler __name__/__module__/__qualname__/__bases__[0].__name__, PickleError/PicklingError/UnpicklingError __name__/__module__/__bases__, pickle.dumps/loads/dump/load __name__/__module__/__qualname__, Pickler/Unpickler __init__.__name__, DEFAULT_PROTOCOL/HIGHEST_PROTOCOL type and class."
    - "This spec covers: __len__() of __module__ strings for Pickler, Unpickler, PickleError, PicklingError, UnpicklingError, dumps, loads; __len__() of __name__ strings for Pickler, Unpickler, PickleError, PicklingError, UnpicklingError."
    - "No prior pickle spec checks pickle.Pickler.__module__.__len__()."
    - "No prior pickle spec checks pickle.Unpickler.__module__.__len__()."
    - "No prior pickle spec checks pickle.PickleError.__module__.__len__()."
    - "No prior pickle spec checks pickle.PicklingError.__module__.__len__()."
    - "No prior pickle spec checks pickle.UnpicklingError.__module__.__len__()."
    - "No prior pickle spec checks pickle.Pickler.__name__.__len__()."
    - "No prior pickle spec checks pickle.Unpickler.__name__.__len__()."
    - "No prior pickle spec checks pickle.PickleError.__name__.__len__()."
    - "No prior pickle spec checks pickle.PicklingError.__name__.__len__()."
    - "No prior pickle spec checks pickle.UnpicklingError.__name__.__len__()."
    - "No prior pickle spec checks pickle.dumps.__module__.__len__()."
    - "No prior pickle spec checks pickle.loads.__module__.__len__()."
    - "pickle.Pickler.__module__ == '_pickle' — len 7 (C extension module)."
    - "pickle.Unpickler.__module__ == '_pickle' — len 7 (C extension module)."
    - "pickle.PickleError.__module__ == '_pickle' — len 7 (C extension module)."
    - "pickle.PicklingError.__module__ == '_pickle' — len 7 (C extension module)."
    - "pickle.UnpicklingError.__module__ == '_pickle' — len 7 (C extension module)."
    - "pickle.Pickler.__name__ == 'Pickler' — len 7."
    - "pickle.Unpickler.__name__ == 'Unpickler' — len 9."
    - "pickle.PickleError.__name__ == 'PickleError' — len 11."
    - "pickle.PicklingError.__name__ == 'PicklingError' — len 13."
    - "pickle.UnpicklingError.__name__ == 'UnpicklingError' — len 15."
    - "pickle.dumps.__module__ == '_pickle' — len 7 (implemented in C extension)."
    - "pickle.loads.__module__ == '_pickle' — len 7 (implemented in C extension)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for Pickler, Unpickler, PickleError, PicklingError,
# UnpicklingError
#
# All five classes are defined in the C extension module '_pickle'; their
# __module__ string is '_pickle' which has length 7.  No prior pickle spec
# checks the length of any class's __module__ string.
# ---------------------------------------------------------------------------

invariant pickle_extra22.Pickler.module.len:
  description: "pickle.Pickler.__module__.__len__() == 7 — '_pickle' has 7 characters"
  category: string_lengths
  kind: python_call_eq
  function: Pickler.__module__.__len__
  args: []
  expected: 7

invariant pickle_extra22.Unpickler.module.len:
  description: "pickle.Unpickler.__module__.__len__() == 7 — '_pickle' has 7 characters"
  category: string_lengths
  kind: python_call_eq
  function: Unpickler.__module__.__len__
  args: []
  expected: 7

invariant pickle_extra22.PickleError.module.len:
  description: "pickle.PickleError.__module__.__len__() == 7 — '_pickle' has 7 characters"
  category: string_lengths
  kind: python_call_eq
  function: PickleError.__module__.__len__
  args: []
  expected: 7

invariant pickle_extra22.PicklingError.module.len:
  description: "pickle.PicklingError.__module__.__len__() == 7 — '_pickle' has 7 characters"
  category: string_lengths
  kind: python_call_eq
  function: PicklingError.__module__.__len__
  args: []
  expected: 7

invariant pickle_extra22.UnpicklingError.module.len:
  description: "pickle.UnpicklingError.__module__.__len__() == 7 — '_pickle' has 7 characters"
  category: string_lengths
  kind: python_call_eq
  function: UnpicklingError.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# __name__.__len__() for Pickler, Unpickler, PickleError, PicklingError,
# UnpicklingError
#
# The five class names have differing lengths: 'Pickler' (7), 'Unpickler' (9),
# 'PickleError' (11), 'PicklingError' (13), 'UnpicklingError' (15).  No prior
# pickle spec checks the length of any class's __name__ string.
# ---------------------------------------------------------------------------

invariant pickle_extra22.Pickler.name.len:
  description: "pickle.Pickler.__name__.__len__() == 7 — 'Pickler' has 7 characters"
  category: string_lengths
  kind: python_call_eq
  function: Pickler.__name__.__len__
  args: []
  expected: 7

invariant pickle_extra22.Unpickler.name.len:
  description: "pickle.Unpickler.__name__.__len__() == 9 — 'Unpickler' has 9 characters"
  category: string_lengths
  kind: python_call_eq
  function: Unpickler.__name__.__len__
  args: []
  expected: 9

invariant pickle_extra22.PickleError.name.len:
  description: "pickle.PickleError.__name__.__len__() == 11 — 'PickleError' has 11 characters"
  category: string_lengths
  kind: python_call_eq
  function: PickleError.__name__.__len__
  args: []
  expected: 11

invariant pickle_extra22.PicklingError.name.len:
  description: "pickle.PicklingError.__name__.__len__() == 13 — 'PicklingError' has 13 characters"
  category: string_lengths
  kind: python_call_eq
  function: PicklingError.__name__.__len__
  args: []
  expected: 13

invariant pickle_extra22.UnpicklingError.name.len:
  description: "pickle.UnpicklingError.__name__.__len__() == 15 — 'UnpicklingError' has 15 characters"
  category: string_lengths
  kind: python_call_eq
  function: UnpicklingError.__name__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# __module__.__len__() for dumps and loads
#
# pickle.dumps and pickle.loads are C extension functions implemented in
# '_pickle'; their __module__ is '_pickle' (len 7).  No prior pickle spec
# checks the length of any function's __module__ string.
# ---------------------------------------------------------------------------

invariant pickle_extra22.dumps.module.len:
  description: "pickle.dumps.__module__.__len__() == 7 — '_pickle' has 7 characters"
  category: string_lengths
  kind: python_call_eq
  function: dumps.__module__.__len__
  args: []
  expected: 7

invariant pickle_extra22.loads.module.len:
  description: "pickle.loads.__module__.__len__() == 7 — '_pickle' has 7 characters"
  category: string_lengths
  kind: python_call_eq
  function: loads.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Consolidated table — all twelve new invariants
#
# All twelve are first covered in this spec (pickle_extra22).
# ---------------------------------------------------------------------------

table pickle_extra22.module_and_name_lengths:
  description: "pickle class and function __module__/__name__ string lengths via __len__()"
  kind: python_call_eq
  category: string_lengths
  id_prefix: pfa22

  columns: [id, function, args, expected]
  rows:
    - [Pickler_module_len,         Pickler.__module__.__len__,         [],  7]
    - [Unpickler_module_len,       Unpickler.__module__.__len__,       [],  7]
    - [PickleError_module_len,     PickleError.__module__.__len__,     [],  7]
    - [PicklingError_module_len,   PicklingError.__module__.__len__,   [],  7]
    - [UnpicklingError_module_len, UnpicklingError.__module__.__len__, [],  7]
    - [Pickler_name_len,           Pickler.__name__.__len__,           [],  7]
    - [Unpickler_name_len,         Unpickler.__name__.__len__,         [],  9]
    - [PickleError_name_len,       PickleError.__name__.__len__,       [], 11]
    - [PicklingError_name_len,     PicklingError.__name__.__len__,     [], 13]
    - [UnpicklingError_name_len,   UnpicklingError.__name__.__len__,   [], 15]
    - [dumps_module_len,           dumps.__module__.__len__,           [],  7]
    - [loads_module_len,           loads.__module__.__len__,           [],  7]
