spec: io_extra91
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra90."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__ membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO lengths; BufferedReader/BufferedWriter/TextIOWrapper __dict__.__class__.__name__ and key method membership; BytesIO/StringIO/FileIO __dict__.__class__.__name__ and membership; UnsupportedOperation identity, bases, MRO; DEFAULT_BUFFER_SIZE and SEEK_* constants class and value; BufferedRandom/__name__/__module__/bases/MRO; BufferedRWPair identity and hierarchy; IncrementalNewlineDecoder identity; TextIOWrapper/__name__/__module__/bases/MRO; StringIO/__name__/__module__/bases/MRO; FileIO/__name__/__module__/bases/MRO; BytesIO/__name__/__module__/bases/MRO; RawIOBase/BufferedIOBase/TextIOBase/IOBase class identity and hierarchy; io.open/__class__/__module__/__qualname__; io.open_code identity; io.DEFAULT_BUFFER_SIZE value; io.UnsupportedOperation hierarchy; BufferedReader/BufferedWriter/BufferedRandom __name__/__module__/bases/MRO/qualname; IOBase.__dict__.__contains__ for read/readline/readlines/writelines/close/flush/__enter__/__exit__/__iter__ (all False); IOBase/RawIOBase/BufferedIOBase/TextIOBase __dict__.__class__.__name__; IOBase/__qualname__; RawIOBase/__qualname__; IOBase/__name__; IOBase/__module__; TextIOWrapper.__dict__.__contains__ for read/readline/write/flush/close/name/encoding (True) and mode (False); TextIOWrapper/__dict__.__class__.__name__; TextIOWrapper/__name__/__qualname__; StringIO/BytesIO/FileIO __dict__.__class__.__name__."
    - "This spec covers: io.FileIO.__dict__.__contains__ for 'read', 'readall', 'readinto', 'write', 'seek', 'tell', 'close' (all True — FileIO implements these); io.FileIO.__dict__.__contains__ for 'name' (False — name is NOT in FileIO.__dict__), 'mode' (True), 'closefd' (True); io.FileIO.__dict__.__class__.__name__ == 'mappingproxy'; io.FileIO.__qualname__ == 'FileIO'; io.FileIO.__name__ == 'FileIO'; io.BytesIO.__dict__.__contains__('read') == True; io.BytesIO.__dict__.__contains__('write') == True."
    - "io.FileIO.__dict__.__contains__('read') == True — FileIO defines read at C level, appears in its __dict__."
    - "io.FileIO.__dict__.__contains__('readall') == True — FileIO defines readall."
    - "io.FileIO.__dict__.__contains__('readinto') == True — FileIO defines readinto."
    - "io.FileIO.__dict__.__contains__('write') == True — FileIO defines write."
    - "io.FileIO.__dict__.__contains__('seek') == True — FileIO defines seek."
    - "io.FileIO.__dict__.__contains__('tell') == True — FileIO defines tell."
    - "io.FileIO.__dict__.__contains__('close') == True — FileIO defines close."
    - "io.FileIO.__dict__.__contains__('name') == False — 'name' is NOT in FileIO.__dict__ (verified on Python 3.14.3; it is not a property on FileIO itself)."
    - "io.FileIO.__dict__.__contains__('mode') == True — 'mode' is a property in FileIO.__dict__."
    - "io.FileIO.__dict__.__contains__('closefd') == True — 'closefd' is a property in FileIO.__dict__."
    - "io.FileIO.__dict__.__class__.__name__ == 'mappingproxy' — as expected for any type's __dict__."
    - "io.FileIO.__qualname__ == 'FileIO' — top-level class, qualname equals name."
    - "io.FileIO.__name__ == 'FileIO' — the C type name."
    - "io.BytesIO.__dict__.__contains__('read') == True — BytesIO defines read."
    - "io.BytesIO.__dict__.__contains__('write') == True — BytesIO defines write."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.FileIO.__dict__.__contains__ for core read methods
# 'read', 'readall', 'readinto' are all defined on FileIO at the C level.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra91.FileIO_dict_read_methods:
  description: "io.FileIO.__dict__.__contains__ for 'read', 'readall', 'readinto' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioextra91

  columns: [id, function, args, expected]
  rows:
    - [fio_read,    FileIO.__dict__.__contains__, ["read"],    true]
    - [fio_readall, FileIO.__dict__.__contains__, ["readall"], true]
    - [fio_readinto, FileIO.__dict__.__contains__, ["readinto"], true]

# ---------------------------------------------------------------------------
# io.FileIO.__dict__.__contains__ for write/seek/tell/close
# All defined on FileIO at the C level.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra91.FileIO_dict_write_seek_tell:
  description: "io.FileIO.__dict__.__contains__ for 'write', 'seek', 'tell', 'close' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioextra91

  columns: [id, function, args, expected]
  rows:
    - [fio_write, FileIO.__dict__.__contains__, ["write"], true]
    - [fio_seek,  FileIO.__dict__.__contains__, ["seek"],  true]
    - [fio_tell,  FileIO.__dict__.__contains__, ["tell"],  true]
    - [fio_close, FileIO.__dict__.__contains__, ["close"], true]

# ---------------------------------------------------------------------------
# io.FileIO.__dict__.__contains__ for properties: name, mode, closefd
# 'name' is False (not in FileIO.__dict__); 'mode' and 'closefd' are True.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra91.FileIO_dict_properties:
  description: "io.FileIO.__dict__.__contains__ for 'name' (False), 'mode' (True), 'closefd' (True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: ioextra91

  columns: [id, function, args, expected]
  rows:
    - [fio_name,    FileIO.__dict__.__contains__, ["name"],    false]
    - [fio_mode,    FileIO.__dict__.__contains__, ["mode"],    true]
    - [fio_closefd, FileIO.__dict__.__contains__, ["closefd"], true]

# ---------------------------------------------------------------------------
# io.FileIO identity: __dict__.__class__.__name__, __qualname__, __name__
# Also: io.BytesIO.__dict__.__contains__ for 'read' and 'write'.
# Not covered in any prior io spec at this specific table.
# ---------------------------------------------------------------------------

table io_extra91.FileIO_identity_and_BytesIO_dict:
  description: "io.FileIO __dict__.__class__.__name__, __qualname__, __name__; io.BytesIO dict read/write"
  kind: python_call_eq
  category: class_identity
  id_prefix: ioextra91

  columns: [id, function, args, expected]
  rows:
    - [fio_dict_cls,  FileIO.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [fio_qualname,  FileIO.__qualname__.__eq__,                ["FileIO"],       true]
    - [fio_name,      FileIO.__name__.__eq__,                    ["FileIO"],       true]
    - [bio_dict_read, BytesIO.__dict__.__contains__,             ["read"],         true]
    - [bio_dict_write, BytesIO.__dict__.__contains__,            ["write"],        true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra91.FileIO_dict.contains_read:
  description: "io.FileIO.__dict__.__contains__('read') == True (FileIO defines read at C level)"
  category: dict_membership
  kind: python_call_eq
  function: FileIO.__dict__.__contains__
  args: ["read"]
  expected: true

invariant io_extra91.FileIO_dict.contains_write:
  description: "io.FileIO.__dict__.__contains__('write') == True (FileIO defines write at C level)"
  category: dict_membership
  kind: python_call_eq
  function: FileIO.__dict__.__contains__
  args: ["write"]
  expected: true

invariant io_extra91.FileIO_dict.name_absent:
  description: "io.FileIO.__dict__.__contains__('name') == False ('name' is not in FileIO.__dict__ on Python 3.14.3)"
  category: dict_membership
  kind: python_call_eq
  function: FileIO.__dict__.__contains__
  args: ["name"]
  expected: false

invariant io_extra91.FileIO.qualname:
  description: "io.FileIO.__qualname__ == 'FileIO' (top-level class; qualname equals name)"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__qualname__.__eq__
  args: ["FileIO"]
  expected: true

invariant io_extra91.FileIO_dict.dict_class_name:
  description: "io.FileIO.__dict__.__class__.__name__ == 'mappingproxy' (as expected for any type's __dict__)"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
