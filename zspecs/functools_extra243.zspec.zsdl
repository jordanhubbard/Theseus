spec: functools_extra243
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools.lru_cache function identity contracts."
    - "functools.lru_cache.__name__ == 'lru_cache' (len=9) — the decorator function name. Verified with Python 3.14.3."
    - "functools.lru_cache.__module__ == 'functools' (len=9) — lru_cache is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.lru_cache.__qualname__ == 'lru_cache' (len=9) — top-level function with unqualified qualname. Verified with Python 3.14.3."
    - "functools.lru_cache.__class__.__name__ == 'function' — lru_cache is a Python function. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__contains__('cache') == True — docstring mentions cache. Verified with Python 3.14.3."
    - "functools.lru_cache.__doc__.__contains__('maxsize') == True — docstring mentions maxsize. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.lru_cache function identity contracts
#
# functools.lru_cache.__name__ == 'lru_cache' (len=9)
# functools.lru_cache.__module__ == 'functools' (len=9)
# functools.lru_cache.__qualname__ == 'lru_cache' (len=9)
# functools.lru_cache.__class__.__name__ == 'function'
# functools.lru_cache.__name__.__len__() == 9
#
# lru_cache is a Python function (decorator) in Lib/functools.py. New to extra243.
# ---------------------------------------------------------------------------

table functools_extra243.lrucache_identity:
  description: "functools.lru_cache decorator function identity: name, module, qualname, class; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: lrucache243

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_name_eq,
       lru_cache.__name__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__name__.__eq__('lru_cache') == True — lru_cache is a Python decorator function in Lib/functools.py; __name__ is 'lru_cache' (len=9); new to extra243"]
    - [lru_cache_name_len_9,
       lru_cache.__name__.__len__,
       [],
       9,
       "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has exactly 9 characters; str.__len__() returns 9; new to extra243"]
    - [lru_cache_module_eq,
       lru_cache.__module__.__eq__,
       ["functools"],
       true,
       "functools.lru_cache.__module__.__eq__('functools') == True — lru_cache is defined in Lib/functools.py; __module__ is 'functools' (len=9); new to extra243"]
    - [lru_cache_qualname_eq,
       lru_cache.__qualname__.__eq__,
       ["lru_cache"],
       true,
       "functools.lru_cache.__qualname__.__eq__('lru_cache') == True — lru_cache is a top-level function with unqualified qualname 'lru_cache'; new to extra243"]
    - [lru_cache_class_is_function,
       lru_cache.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.lru_cache.__class__.__name__.__eq__('function') == True — lru_cache is a Python function; its __class__ is the built-in function type; new to extra243"]

# ---------------------------------------------------------------------------
# Table 2: functools.lru_cache doc checks
#
# functools.lru_cache.__doc__.__contains__('cache') == True
# functools.lru_cache.__doc__.__contains__('maxsize') == True
# functools.lru_cache.__doc__.__contains__('decorator') == True
# functools.lru_cache.__doc__.__contains__('typed') == True
# functools.lru_cache.__doc__.__class__.__name__ == 'str'
#
# lru_cache docstring describes cache, maxsize, typed. New to extra243.
# ---------------------------------------------------------------------------

table functools_extra243.lrucache243a_doc_checks:
  description: "functools.lru_cache doc contains 'cache', 'maxsize', 'decorator', 'typed'; doc class is str; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: lrucache243a

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_doc_contains_cache,
       lru_cache.__doc__.__contains__,
       ["cache"],
       true,
       "functools.lru_cache.__doc__.__contains__('cache') == True — docstring describes the LRU cache mechanism; str.__contains__('cache') returns True; new to extra243"]
    - [lru_cache_doc_contains_maxsize,
       lru_cache.__doc__.__contains__,
       ["maxsize"],
       true,
       "functools.lru_cache.__doc__.__contains__('maxsize') == True — docstring describes the maxsize parameter controlling cache size; str.__contains__('maxsize') returns True; new to extra243"]
    - [lru_cache_doc_contains_decorator,
       lru_cache.__doc__.__contains__,
       ["decorator"],
       true,
       "functools.lru_cache.__doc__.__contains__('decorator') == True — docstring describes lru_cache as a cache decorator; str.__contains__('decorator') returns True; new to extra243"]
    - [lru_cache_doc_contains_typed,
       lru_cache.__doc__.__contains__,
       ["typed"],
       true,
       "functools.lru_cache.__doc__.__contains__('typed') == True — docstring describes the typed parameter for type-sensitive caching; str.__contains__('typed') returns True; new to extra243"]
    - [lru_cache_doc_class_is_str,
       lru_cache.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.lru_cache.__doc__.__class__.__name__.__eq__('str') == True — the lru_cache docstring is a plain Python str object; new to extra243"]

# ---------------------------------------------------------------------------
# Table 3: functools.lru_cache module and qualname length contracts
#
# functools.lru_cache.__module__.__len__() == 9
# functools.lru_cache.__qualname__.__len__() == 9
# functools.lru_cache.__name__.__contains__('lru') == True
# functools.lru_cache.__name__.__contains__('cache') == True
# functools.lru_cache.__module__.__contains__('functools') == True
#
# Length and substring contracts for lru_cache. New to extra243.
# ---------------------------------------------------------------------------

table functools_extra243.lrucache243_lengths:
  description: "functools.lru_cache name/module/qualname length and substring contracts; new to extra243"
  kind: python_call_eq
  category: identity
  id_prefix: lrucache243len

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_module_len_9,
       lru_cache.__module__.__len__,
       [],
       9,
       "functools.lru_cache.__module__.__len__() == 9 — 'functools' has exactly 9 characters (f-u-n-c-t-o-o-l-s); str.__len__() returns 9; new to extra243"]
    - [lru_cache_qualname_len_9,
       lru_cache.__qualname__.__len__,
       [],
       9,
       "functools.lru_cache.__qualname__.__len__() == 9 — 'lru_cache' qualname has exactly 9 characters; str.__len__() returns 9; new to extra243"]
    - [lru_cache_name_contains_lru,
       lru_cache.__name__.__contains__,
       ["lru"],
       true,
       "functools.lru_cache.__name__.__contains__('lru') == True — name starts with 'lru'; str.__contains__('lru') returns True; new to extra243"]
    - [lru_cache_name_contains_cache,
       lru_cache.__name__.__contains__,
       ["cache"],
       true,
       "functools.lru_cache.__name__.__contains__('cache') == True — name ends with 'cache'; str.__contains__('cache') returns True; new to extra243"]
    - [lru_cache_module_contains_functools,
       lru_cache.__module__.__contains__,
       ["functools"],
       true,
       "functools.lru_cache.__module__.__contains__('functools') == True — __module__ contains 'functools'; str.__contains__('functools') returns True; new to extra243"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra243
# ---------------------------------------------------------------------------

invariant functools_extra243.lru_cache_name_eq:
  description: "functools.lru_cache.__name__ == 'lru_cache' (len=9); new to extra243"
  kind: python_call_eq
  function: lru_cache.__name__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra243.lru_cache_name_len_9:
  description: "functools.lru_cache.__name__.__len__() == 9 — 'lru_cache' has 9 characters; new to extra243"
  kind: python_call_eq
  function: lru_cache.__name__.__len__
  args: []
  expected: 9

invariant functools_extra243.lru_cache_module_eq:
  description: "functools.lru_cache.__module__ == 'functools'; new to extra243"
  kind: python_call_eq
  function: lru_cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra243.lru_cache_module_len_9:
  description: "functools.lru_cache.__module__.__len__() == 9 — 'functools' has 9 characters; new to extra243"
  kind: python_call_eq
  function: lru_cache.__module__.__len__
  args: []
  expected: 9

invariant functools_extra243.lru_cache_qualname_eq:
  description: "functools.lru_cache.__qualname__ == 'lru_cache'; new to extra243"
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra243.lru_cache_qualname_len_9:
  description: "functools.lru_cache.__qualname__.__len__() == 9 — 'lru_cache' has 9 characters; new to extra243"
  kind: python_call_eq
  function: lru_cache.__qualname__.__len__
  args: []
  expected: 9

invariant functools_extra243.lru_cache_class_is_function:
  description: "functools.lru_cache.__class__.__name__ == 'function'; new to extra243"
  kind: python_call_eq
  function: lru_cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra243.lru_cache_doc_contains_cache:
  description: "functools.lru_cache.__doc__.__contains__('cache') == True; new to extra243"
  kind: python_call_eq
  function: lru_cache.__doc__.__contains__
  args: ["cache"]
  expected: true

invariant functools_extra243.lru_cache_doc_contains_maxsize:
  description: "functools.lru_cache.__doc__.__contains__('maxsize') == True; new to extra243"
  kind: python_call_eq
  function: lru_cache.__doc__.__contains__
  args: ["maxsize"]
  expected: true

invariant functools_extra243.lru_cache_doc_class_is_str:
  description: "functools.lru_cache.__doc__.__class__.__name__ == 'str' — docstring is a plain str; new to extra243"
  kind: python_call_eq
  function: lru_cache.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
