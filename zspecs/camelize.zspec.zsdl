spec: camelize
version: ">=1.0.1"
backend: node(camelize)

docs: https://www.npmjs.com/package/camelize

provenance:
  derived_from:
    - "camelize README — https://www.npmjs.com/package/camelize"
    - "Test vectors verified with camelize via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "camelize source"
  notes:
    - "camelize is an npm package. Install: npm install camelize"
    - "Recursively converts object keys and strings to camelCase."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string or object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table camelize.camelize:
  kind: node_module_call_eq
  function: ~
  category: string
  id_prefix: camelize

  columns: [id, args, expected]
  rows:
    - [hyphen,    ["hello-world"],    "helloWorld"]
    - [snake,     ["foo_bar_baz"],    "fooBarBaz"]
    - [no_change, ["fooBar"],         "fooBar"]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T06:07:59Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
