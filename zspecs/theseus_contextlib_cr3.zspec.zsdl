spec: theseus_contextlib_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_contextlib_cr3)
blocks: contextlib

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html"
  notes:
    - "Clean-room extended contextlib. Do NOT import contextlib."
    - "ExitStack: context manager that holds a stack of other context managers."
    - "AbstractContextManager: ABC for context managers (has __enter__/__exit__)."
    - "nullcontext(enter_result=None): context manager that does nothing."
    - "contextlib3_exitstack(): ExitStack() can enter/exit a simple context manager."
    - "contextlib3_nullcontext(): with nullcontext(42) as val: val == 42."
    - "contextlib3_suppress(): with suppress(ValueError): raise ValueError; no error raised."
    - "suppress(*exceptions): context manager that swallows specified exceptions."
    - "ExitStack: maintains a list of cleanup callbacks; __exit__ calls them in LIFO order."
    - "nullcontext: __enter__ returns enter_result; __exit__ does nothing."
    - "suppress: catches specified exceptions in __exit__, returns True."
    - "Export: ExitStack, nullcontext, suppress, AbstractContextManager."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_contextlib_cr3.exitstack:
  description: "ExitStack enters and exits a context manager correctly"
  category: exitstack
  kind: python_call_eq
  function: contextlib3_exitstack
  args: []
  expected: true

invariant theseus_contextlib_cr3.nullcontext:
  description: "nullcontext(42) yields 42 as context value"
  category: nullcontext
  kind: python_call_eq
  function: contextlib3_nullcontext
  args: []
  expected: 42

invariant theseus_contextlib_cr3.suppress:
  description: "suppress(ValueError) swallows ValueError without propagating"
  category: suppress
  kind: python_call_eq
  function: contextlib3_suppress
  args: []
  expected: true
