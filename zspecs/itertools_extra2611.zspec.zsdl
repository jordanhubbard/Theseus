spec: itertools_extra2611
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 621 (_extra2611): __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks for itertools types."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
    - "__init_subclass__ is a classmethod defined on object; no itertools type defines it in its own __dict__ — all False."
    - "__subclasshook__ is an ABCMeta hook; no itertools type is an ABC, so none define it — all False."
    - "__class_getitem__: itertools.chain defines it (True for generic alias support); all other itertools iterator types return False."
    - "The 17 itertools types tested: chain, count, repeat, cycle, islice, compress, dropwhile, takewhile, starmap, groupby, filterfalse, accumulate, zip_longest, pairwise, product, permutations, combinations."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __init_subclass__ dict-presence for itertools iterator types
#
# All itertools types are implemented in C (Modules/itertoolsmodule.c) and
# none override __init_subclass__. The hook is present only via MRO
# inheritance from object's C-level classmethod, not in any type's own dict.
# ---------------------------------------------------------------------------

table itertools_extra2611.init_subclass_absent:
  description: "itertools iterator types do not define __init_subclass__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2611

  columns: [id, function, args, expected]
  rows:
    - ["it2611001", "itertools.chain.__dict__.__contains__",         ["__init_subclass__"], false]
    - ["it2611002", "itertools.count.__dict__.__contains__",         ["__init_subclass__"], false]
    - ["it2611003", "itertools.repeat.__dict__.__contains__",        ["__init_subclass__"], false]
    - ["it2611004", "itertools.cycle.__dict__.__contains__",         ["__init_subclass__"], false]
    - ["it2611005", "itertools.islice.__dict__.__contains__",        ["__init_subclass__"], false]
    - ["it2611006", "itertools.compress.__dict__.__contains__",      ["__init_subclass__"], false]
    - ["it2611007", "itertools.dropwhile.__dict__.__contains__",     ["__init_subclass__"], false]
    - ["it2611008", "itertools.takewhile.__dict__.__contains__",     ["__init_subclass__"], false]
    - ["it2611009", "itertools.starmap.__dict__.__contains__",       ["__init_subclass__"], false]
    - ["it2611010", "itertools.groupby.__dict__.__contains__",       ["__init_subclass__"], false]
    - ["it2611011", "itertools.filterfalse.__dict__.__contains__",   ["__init_subclass__"], false]
    - ["it2611012", "itertools.accumulate.__dict__.__contains__",    ["__init_subclass__"], false]
    - ["it2611013", "itertools.zip_longest.__dict__.__contains__",   ["__init_subclass__"], false]
    - ["it2611014", "itertools.pairwise.__dict__.__contains__",      ["__init_subclass__"], false]
    - ["it2611015", "itertools.product.__dict__.__contains__",       ["__init_subclass__"], false]
    - ["it2611016", "itertools.permutations.__dict__.__contains__",  ["__init_subclass__"], false]
    - ["it2611017", "itertools.combinations.__dict__.__contains__",  ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Table 2: __subclasshook__ dict-presence for itertools iterator types
#
# None of the itertools types are abstract base classes. __subclasshook__ is
# meaningful only for classes using ABCMeta, so all itertools types return
# False for this dict-presence check.
# ---------------------------------------------------------------------------

table itertools_extra2611.subclasshook_absent:
  description: "itertools types do not define __subclasshook__ in their own __dict__ — none are ABCs"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2611

  columns: [id, function, args, expected]
  rows:
    - ["it2611018", "itertools.chain.__dict__.__contains__",         ["__subclasshook__"], false]
    - ["it2611019", "itertools.count.__dict__.__contains__",         ["__subclasshook__"], false]
    - ["it2611020", "itertools.repeat.__dict__.__contains__",        ["__subclasshook__"], false]
    - ["it2611021", "itertools.cycle.__dict__.__contains__",         ["__subclasshook__"], false]
    - ["it2611022", "itertools.islice.__dict__.__contains__",        ["__subclasshook__"], false]
    - ["it2611023", "itertools.compress.__dict__.__contains__",      ["__subclasshook__"], false]
    - ["it2611024", "itertools.dropwhile.__dict__.__contains__",     ["__subclasshook__"], false]
    - ["it2611025", "itertools.takewhile.__dict__.__contains__",     ["__subclasshook__"], false]
    - ["it2611026", "itertools.starmap.__dict__.__contains__",       ["__subclasshook__"], false]
    - ["it2611027", "itertools.groupby.__dict__.__contains__",       ["__subclasshook__"], false]
    - ["it2611028", "itertools.filterfalse.__dict__.__contains__",   ["__subclasshook__"], false]
    - ["it2611029", "itertools.accumulate.__dict__.__contains__",    ["__subclasshook__"], false]
    - ["it2611030", "itertools.zip_longest.__dict__.__contains__",   ["__subclasshook__"], false]
    - ["it2611031", "itertools.pairwise.__dict__.__contains__",      ["__subclasshook__"], false]
    - ["it2611032", "itertools.product.__dict__.__contains__",       ["__subclasshook__"], false]
    - ["it2611033", "itertools.permutations.__dict__.__contains__",  ["__subclasshook__"], false]
    - ["it2611034", "itertools.combinations.__dict__.__contains__",  ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# Table 3: __class_getitem__ dict-presence for itertools iterator types
#
# itertools.chain defines __class_getitem__, enabling chain[int] generic alias
# syntax (PEP 585). All other itertools types do NOT define it — they are
# C-implemented types that predate or opted out of generic alias support.
# ---------------------------------------------------------------------------

table itertools_extra2611.class_getitem_checks:
  description: "itertools __class_getitem__ dict-presence — chain True, all others False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2611

  columns: [id, function, args, expected]
  rows:
    - ["it2611035", "itertools.chain.__dict__.__contains__",         ["__class_getitem__"], true]
    - ["it2611036", "itertools.count.__dict__.__contains__",         ["__class_getitem__"], false]
    - ["it2611037", "itertools.repeat.__dict__.__contains__",        ["__class_getitem__"], false]
    - ["it2611038", "itertools.cycle.__dict__.__contains__",         ["__class_getitem__"], false]
    - ["it2611039", "itertools.islice.__dict__.__contains__",        ["__class_getitem__"], false]
    - ["it2611040", "itertools.compress.__dict__.__contains__",      ["__class_getitem__"], false]
    - ["it2611041", "itertools.dropwhile.__dict__.__contains__",     ["__class_getitem__"], false]
    - ["it2611042", "itertools.takewhile.__dict__.__contains__",     ["__class_getitem__"], false]
    - ["it2611043", "itertools.starmap.__dict__.__contains__",       ["__class_getitem__"], false]
    - ["it2611044", "itertools.groupby.__dict__.__contains__",       ["__class_getitem__"], false]
    - ["it2611045", "itertools.filterfalse.__dict__.__contains__",   ["__class_getitem__"], false]
    - ["it2611046", "itertools.accumulate.__dict__.__contains__",    ["__class_getitem__"], false]
    - ["it2611047", "itertools.zip_longest.__dict__.__contains__",   ["__class_getitem__"], false]
    - ["it2611048", "itertools.pairwise.__dict__.__contains__",      ["__class_getitem__"], false]
    - ["it2611049", "itertools.product.__dict__.__contains__",       ["__class_getitem__"], false]
    - ["it2611050", "itertools.permutations.__dict__.__contains__",  ["__class_getitem__"], false]
    - ["it2611051", "itertools.combinations.__dict__.__contains__",  ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Table 4: Inherited hook accessibility via __qualname__
#
# Although __init_subclass__ is absent from each type's own __dict__, it is
# still accessible via normal attribute lookup (inherited through the MRO).
# For C-implemented types, the bound classmethod's __qualname__ reflects
# the name of the type it is bound to, not 'object'. A representative
# subset of itertools types is checked here.
# ---------------------------------------------------------------------------

table itertools_extra2611.object_inherited_hooks:
  description: "itertools types inherit __init_subclass__ via MRO — qualname reflects per-class binding"
  kind: python_call_eq
  category: qualname_eq
  id_prefix: it2611

  columns: [id, function, args, expected]
  rows:
    - ["it2611052", "itertools.chain.__init_subclass__.__qualname__.__eq__",        ["chain.__init_subclass__"],        true]
    - ["it2611053", "itertools.count.__init_subclass__.__qualname__.__eq__",        ["count.__init_subclass__"],        true]
    - ["it2611054", "itertools.repeat.__init_subclass__.__qualname__.__eq__",       ["repeat.__init_subclass__"],       true]
    - ["it2611055", "itertools.cycle.__init_subclass__.__qualname__.__eq__",        ["cycle.__init_subclass__"],        true]
    - ["it2611056", "itertools.islice.__init_subclass__.__qualname__.__eq__",       ["islice.__init_subclass__"],       true]
    - ["it2611057", "itertools.compress.__init_subclass__.__qualname__.__eq__",     ["compress.__init_subclass__"],     true]
    - ["it2611058", "itertools.dropwhile.__init_subclass__.__qualname__.__eq__",    ["dropwhile.__init_subclass__"],    true]
    - ["it2611059", "itertools.takewhile.__init_subclass__.__qualname__.__eq__",    ["takewhile.__init_subclass__"],    true]
    - ["it2611060", "itertools.product.__init_subclass__.__qualname__.__eq__",      ["product.__init_subclass__"],      true]
    - ["it2611061", "itertools.permutations.__init_subclass__.__qualname__.__eq__", ["permutations.__init_subclass__"], true]
    - ["it2611062", "itertools.combinations.__init_subclass__.__qualname__.__eq__", ["combinations.__init_subclass__"], true]
