spec: hashlib_extra2641
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 623: checks hashlib HASH (accessed via hashlib.new('sha256').__class__), blake2b, blake2s __dict__ for __copy__, __deepcopy__, __sizeof__ presence. All three classes return False for all three dunders — none defines __copy__, __deepcopy__, or __sizeof__ in its own __dict__."]
  created_at: "2026-04-13"
error_model: python_exceptions

table hashlib_extra2641.HASH_dict_presence:
  description: "hashlib HASH class (hashlib.new('sha256').__class__) __dict__ does not contain __copy__, __deepcopy__, or __sizeof__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2641hd
  columns: [id, function, args, expected]
  rows:
    - ["hl2641hd001", hashlib.new("sha256").__class__.__dict__.__contains__, ["__copy__"],     false]
    - ["hl2641hd002", hashlib.new("sha256").__class__.__dict__.__contains__, ["__deepcopy__"], false]
    - ["hl2641hd003", hashlib.new("sha256").__class__.__dict__.__contains__, ["__sizeof__"],   false]

table hashlib_extra2641.blake2b_dict_presence:
  description: "hashlib.blake2b __dict__ does not contain __copy__, __deepcopy__, or __sizeof__"
  kind: python_call_eq
