  id_prefix: hl2641b2s
  columns: [id, function, args, expected]
  rows:
    - ["hl2641b2s001", hashlib.blake2s.__dict__.__contains__, ["__copy__"],     false]
    - ["hl2641b2s002", hashlib.blake2s.__dict__.__contains__, ["__deepcopy__"], false]
    - ["hl2641b2s003", hashlib.blake2s.__dict__.__contains__, ["__sizeof__"],   false]

table hashlib_extra2641.hash_types_cross:
  description: "Cross-checks: HASH class, blake2b, blake2s __dict__ do not contain __copy__, __deepcopy__, __sizeof__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: hl2641cx
  columns: [id, function, args, expected]
  rows:
    - ["hl2641cx001", hashlib.new("sha256").__class__.__dict__.__contains__, ["__copy__"],     false]
    - ["hl2641cx002", hashlib.blake2b.__dict__.__contains__,                 ["__deepcopy__"], false]
    - ["hl2641cx003", hashlib.blake2s.__dict__.__contains__,                 ["__sizeof__"],   false]
    - ["hl2641cx004", hashlib.new("sha256").__class__.__dict__.__contains__, ["__sizeof__"],   false]
    - ["hl2641cx005", hashlib.blake2b.__dict__.__contains__,                 ["__sizeof__"],   false]
    - ["hl2641cx006", hashlib.blake2s.__dict__.__contains__,                 ["__copy__"],     false]
