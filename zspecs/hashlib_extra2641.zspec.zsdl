  id_prefix: hl2641b2b
  columns: [id, function, args, expected]
  rows:
    - ["hl2641b2b001", hashlib.blake2b.__dict__.__contains__, ["__copy__"],     false]
    - ["hl2641b2b002", hashlib.blake2b.__dict__.__contains__, ["__deepcopy__"], false]
    - ["hl2641b2b003", hashlib.blake2b.__dict__.__contains__, ["__sizeof__"],   false]

