spec: certifi_rust
version: ">=3.9"
backend: rust_module(certifi_rust)

docs: https://certifiio.readthedocs.io/

provenance:
  derived_from:
    - "https://certifiio.readthedocs.io/ — certifi"
  notes:
    - "certifi provides Mozilla's CA Bundle."
    - "certifi.where() returns path to CA bundle."
    - "os.path.exists(certifi.where()) is True."
    - "certifi.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant certifi_rust.where_nonempty:
  description: "certifi.where() returns non-empty string"
  category: where
  kind: python_call_eq
  function: certifi_where_nonempty
  args: []
  expected: true

invariant certifi_rust.where_file_exists:
  description: "os.path.exists(certifi.where()) is True"
  category: where
  kind: python_call_eq
  function: certifi_where_file_exists
  args: []
  expected: true

invariant certifi_rust.version_nonempty:
  description: "certifi.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: certifi_version_nonempty
  args: []
  expected: true

