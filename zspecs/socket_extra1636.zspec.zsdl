spec: socket_extra1636
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "behavioral invariants for ABC virtual subclassing protocol"
    - "socket.socket is a Python class defined in Lib/socket.py; it is not an ABC and does not define __subclasshook__ or __instancecheck__ in its own __dict__."
    - "socket.error is an alias for OSError (Python 3.3+); socket.timeout is an alias for TimeoutError (Python 3.3+)."
    - "socket.herror and socket.gaierror are concrete subclasses of OSError (which socket.error aliases)."
    - "issubclass(socket.herror, socket.error) is True because socket.error IS OSError and herror inherits from OSError."
    - "issubclass(socket.timeout, socket.error) is True because TimeoutError inherits from OSError."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; they define __subclasshook__ via the EnumType metaclass, not in their own __dict__."
    - "isinstance(socket.AF_INET, socket.AddressFamily) is True — AF_INET is an AddressFamily member."
    - "isinstance(socket.SOCK_STREAM, socket.SocketKind) is True — SOCK_STREAM is a SocketKind member."
    - "issubclass(socket.AddressFamily, int) is True — IntEnum inherits from int."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: socket.socket does not define ABC virtual-subclassing hooks
#
# socket.socket is a plain Python class; it is not an ABC and does not define
# __subclasshook__, __instancecheck__, or __subclasscheck__ in its __dict__.
# The exception classes (error, herror, gaierror, timeout) similarly lack
# these hooks in their own __dict__ — they inherit exception machinery from
# BaseException/OSError, not ABC machinery.
# ---------------------------------------------------------------------------

table socket_extra1636.socket_no_virtual_subclassing:
  description: "socket.socket and exception classes do not define ABC virtual-subclassing hooks in their __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk1636

  columns: [id, function, args, expected]
  rows:
    - ["sk1636001", "socket.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["sk1636002", "socket.__dict__.__contains__", ["__instancecheck__"], false]
    - ["sk1636003", "socket.__dict__.__contains__", ["__subclasscheck__"], false]
    - ["sk1636004", "herror.__dict__.__contains__", ["__subclasshook__"],  false]
    - ["sk1636005", "herror.__dict__.__contains__", ["__instancecheck__"], false]
    - ["sk1636006", "herror.__dict__.__contains__", ["__subclasscheck__"], false]
    - ["sk1636007", "gaierror.__dict__.__contains__",["__subclasshook__"], false]
    - ["sk1636008", "gaierror.__dict__.__contains__",["__instancecheck__"],false]
    - ["sk1636009", "gaierror.__dict__.__contains__",["__subclasscheck__"],false]
    - ["sk1636010", "socket.__dict__.__contains__", ["fileno"],            true]
    - ["sk1636011", "socket.__dict__.__contains__", ["bind"],              true]
    - ["sk1636012", "socket.__dict__.__contains__", ["connect"],           true]
    - ["sk1636013", "socket.__dict__.__contains__", ["close"],             true]
    - ["sk1636014", "socket.__dict__.__contains__", ["send"],              true]
    - ["sk1636015", "socket.__dict__.__contains__", ["recv"],              true]
    - ["sk1636016", "socket.__name__.__eq__",        ["socket"],           true]
    - ["sk1636017", "socket.__module__.__eq__",      ["socket"],           true]
    - ["sk1636018", "herror.__name__.__eq__",         ["herror"],          true]
    - ["sk1636019", "gaierror.__name__.__eq__",       ["gaierror"],        true]
    - ["sk1636020", "socket.__bases__.__getitem__",   [0],                 "object"]

# ---------------------------------------------------------------------------
# Table 2: socket exception hierarchy
#
# socket.error is OSError (Python 3.3+ alias); socket.timeout is TimeoutError.
# herror and gaierror are OSError subclasses. TimeoutError inherits from
# OSError, so socket.timeout is also a subclass of socket.error.
# ---------------------------------------------------------------------------

table socket_extra1636.socket_exception_hierarchy:
  description: "socket exception hierarchy: error aliases OSError; timeout aliases TimeoutError; herror/gaierror are OSError subclasses"
  kind: python_call_eq
  category: exception_hierarchy
  id_prefix: sk1636

  columns: [id, function, args, expected]
  rows:
    - ["sk1636021", "error.__name__.__eq__",          ["OSError"],         true]
    - ["sk1636022", "timeout.__name__.__eq__",        ["TimeoutError"],    true]
    - ["sk1636023", "herror.__bases__.__getitem__",   [0],                 "OSError"]
    - ["sk1636024", "gaierror.__bases__.__getitem__", [0],                 "OSError"]
    - ["sk1636025", "timeout.__bases__.__getitem__",  [0],                 "OSError"]
    - ["sk1636026", "herror.__mro__.__len__",         [],                  5]
    - ["sk1636027", "gaierror.__mro__.__len__",       [],                  5]
    - ["sk1636028", "herror.__mro__.__getitem__",     [0],                 "herror"]
    - ["sk1636029", "herror.__mro__.__getitem__",     [1],                 "OSError"]
    - ["sk1636030", "herror.__mro__.__getitem__",     [2],                 "Exception"]
    - ["sk1636031", "gaierror.__mro__.__getitem__",   [0],                 "gaierror"]
    - ["sk1636032", "gaierror.__mro__.__getitem__",   [1],                 "OSError"]
    - ["sk1636033", "timeout.__mro__.__getitem__",    [0],                 "TimeoutError"]
    - ["sk1636034", "timeout.__mro__.__getitem__",    [1],                 "OSError"]
    - ["sk1636035", "timeout.__mro__.__getitem__",    [2],                 "Exception"]
    - ["sk1636036", "error.__dict__.__contains__",    ["__subclasshook__"],  false]
    - ["sk1636037", "error.__dict__.__contains__",    ["__instancecheck__"], false]
    - ["sk1636038", "herror.__dict__.__contains__",   ["__subclasshook__"],  false]
    - ["sk1636039", "timeout.__dict__.__contains__",  ["__subclasshook__"],  false]
    - ["sk1636040", "timeout.__dict__.__contains__",  ["__instancecheck__"], false]

# ---------------------------------------------------------------------------
# Table 3: socket.AddressFamily and socket.SocketKind IntEnum isinstance checks
#
# AddressFamily and SocketKind are IntEnum subclasses. Enum members are
# instances of their enum class. Both enum classes are subclasses of int
# (via IntEnum). The enum hook __subclasshook__ lives on the EnumType
# metaclass, not in AddressFamily.__dict__ or SocketKind.__dict__.
# ---------------------------------------------------------------------------

table socket_extra1636.socket_enum_isinstance:
  description: "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; members are proper instances"
  kind: python_call_eq
  category: enum_isinstance
  id_prefix: sk1636

  columns: [id, function, args, expected]
  rows:
    - ["sk1636041", "AddressFamily.__name__.__eq__",              ["AddressFamily"],  true]
    - ["sk1636042", "SocketKind.__name__.__eq__",                 ["SocketKind"],     true]
    - ["sk1636043", "AddressFamily.__bases__.__getitem__",        [0],                "IntEnum"]
    - ["sk1636044", "SocketKind.__bases__.__getitem__",           [0],                "IntEnum"]
    - ["sk1636045", "AF_INET.__class__.__name__.__eq__",          ["AddressFamily"],  true]
    - ["sk1636046", "AF_INET6.__class__.__name__.__eq__",         ["AddressFamily"],  true]
    - ["sk1636047", "SOCK_STREAM.__class__.__name__.__eq__",      ["SocketKind"],     true]
    - ["sk1636048", "SOCK_DGRAM.__class__.__name__.__eq__",       ["SocketKind"],     true]
    - ["sk1636049", "AddressFamily.__dict__.__contains__",        ["__subclasshook__"],  false]
    - ["sk1636050", "AddressFamily.__dict__.__contains__",        ["__instancecheck__"], false]
    - ["sk1636051", "AddressFamily.__dict__.__contains__",        ["__subclasscheck__"], false]
    - ["sk1636052", "SocketKind.__dict__.__contains__",           ["__subclasshook__"],  false]
    - ["sk1636053", "SocketKind.__dict__.__contains__",           ["__instancecheck__"], false]
    - ["sk1636054", "SocketKind.__dict__.__contains__",           ["__subclasscheck__"], false]
    - ["sk1636055", "AddressFamily.__dict__.__contains__",        ["AF_INET"],        true]
    - ["sk1636056", "AddressFamily.__dict__.__contains__",        ["AF_INET6"],       true]
    - ["sk1636057", "SocketKind.__dict__.__contains__",           ["SOCK_STREAM"],    true]
    - ["sk1636058", "SocketKind.__dict__.__contains__",           ["SOCK_DGRAM"],     true]
    - ["sk1636059", "AF_INET.__eq__",                             [2],               true]
    - ["sk1636060", "SOCK_STREAM.__eq__",                         [1],               true]
