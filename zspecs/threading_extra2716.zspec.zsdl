spec: threading_extra2716
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/threading.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 628 theme: __neg__, __pos__, and __abs__ dict-presence checks (unary minus, unary plus, absolute value)."
    - "threading.Thread is a runnable object; it does not define unary arithmetic protocols."
    - "threading.Lock (accessed as threading.Lock, actual type is _thread.lock) is a synchronization primitive; it defines acquire/release but not __neg__, __pos__, or __abs__."
    - "threading.Event, threading.Condition, threading.Semaphore, threading.BoundedSemaphore are synchronization primitives; none define __neg__, __pos__, or __abs__."
    - "threading.Timer is a Thread subclass for deferred execution; it defines none of these unary arithmetic protocols."
    - "threading.Barrier is a synchronization barrier; it does not define __neg__, __pos__, or __abs__."
    - "threading.local is a thread-local storage object; it does not define unary arithmetic protocols."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __neg__ dict-presence — absent from all threading synchronization types
# ---------------------------------------------------------------------------

table threading_extra2716.neg_protocol:
  description: "__neg__ is absent from all threading type __dict__s — synchronization primitives do not implement unary minus"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th2716

  columns: [id, function, args, expected]
  rows:
    - ["th2716001", "threading.Thread.__dict__.__contains__",           ["__neg__"], false]
    - ["th2716002", "threading.Lock.__dict__.__contains__",             ["__neg__"], false]
    - ["th2716003", "threading.Event.__dict__.__contains__",            ["__neg__"], false]
    - ["th2716004", "threading.Condition.__dict__.__contains__",        ["__neg__"], false]
    - ["th2716005", "threading.Semaphore.__dict__.__contains__",        ["__neg__"], false]
    - ["th2716006", "threading.BoundedSemaphore.__dict__.__contains__", ["__neg__"], false]
    - ["th2716007", "threading.Timer.__dict__.__contains__",            ["__neg__"], false]
    - ["th2716008", "threading.Barrier.__dict__.__contains__",          ["__neg__"], false]
    - ["th2716009", "threading.local.__dict__.__contains__",            ["__neg__"], false]

