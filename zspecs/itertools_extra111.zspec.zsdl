    - "itertools.cycle.__repr__.__qualname__ == 'object.__repr__'. Verified with Python 3.14.3."
    - "type(itertools.repeat.__repr__).__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.repeat.__repr__.__qualname__ == 'repeat.__repr__'. Verified with Python 3.14.3."
    - "type(itertools.chain.__repr__).__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.chain.__repr__.__qualname__ == 'object.__repr__'. Verified with Python 3.14.3."
    - "type(itertools.compress.__repr__).__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.compress.__repr__.__qualname__ == 'object.__repr__'. Verified with Python 3.14.3."
    - "type(itertools.count.__iter__).__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.count.__iter__.__qualname__ == 'count.__iter__'. Verified with Python 3.14.3."
    - "type(itertools.cycle.__iter__).__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.cycle.__iter__.__qualname__ == 'cycle.__iter__'. Verified with Python 3.14.3."
    - "type(itertools.repeat.__iter__).__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.repeat.__iter__.__qualname__ == 'repeat.__iter__'. Verified with Python 3.14.3."
    - "type(itertools.chain.__iter__).__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "itertools.chain.__iter__.__qualname__ == 'chain.__iter__'. Verified with Python 3.14.3."
    - "type(itertools.count.__next__).__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "type(itertools.cycle.__next__).__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "type(itertools.repeat.__next__).__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "type(itertools.chain.__next__).__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
