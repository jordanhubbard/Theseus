  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C-extension type __repr__ qualnames
#
# Wave 263 theme: itertools C-extension types vary in whether they implement
# their own tp_repr slot. itertools.count and itertools.repeat define custom
# tp_repr slots and so their __repr__ qualname is type-specific ('count.__repr__'
# and 'repeat.__repr__'). The remaining types (cycle, chain, compress, islice,
# starmap, product, permutations, combinations) do NOT define tp_repr and
# inherit __repr__ from object, giving qualname 'object.__repr__'. All are
# 'wrapper_descriptor' type.
#
# itertools.count.__repr__.__qualname__ == 'count.__repr__'
# itertools.cycle.__repr__.__qualname__ == 'object.__repr__'
# itertools.repeat.__repr__.__qualname__ == 'repeat.__repr__'
# itertools.chain.__repr__.__qualname__ == 'object.__repr__'
# itertools.compress.__repr__.__qualname__ == 'object.__repr__'
#
# New to extra111.
# ---------------------------------------------------------------------------

table itertools_extra111.repr_qualnames:
  description: "itertools __repr__ qualnames: count/repeat have own 'count.__repr__'/'repeat.__repr__'; cycle/chain/compress inherit 'object.__repr__'; all wrapper_descriptor; wave 263; new to extra111"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsrqn111

  columns: [id, function, args, expected, description]
  rows:
    - [count_repr_qualname_own,
       "count.__repr__.__qualname__.__eq__",
       ["count.__repr__"],
       true,
       "itertools.count.__repr__.__qualname__.__eq__('count.__repr__') == True — itertools.count defines its own tp_repr slot in Modules/itertoolsmodule.c to produce a human-readable representation like 'count(10)' or 'count(10, 2)'; because it has a custom slot, the wrapper_descriptor's __qualname__ is 'count.__repr__' (type-specific); str.__eq__('count.__repr__') returns True; new to extra111"]
    - [repeat_repr_qualname_own,
       "repeat.__repr__.__qualname__.__eq__",
       ["repeat.__repr__"],
       true,
       "itertools.repeat.__repr__.__qualname__.__eq__('repeat.__repr__') == True — itertools.repeat defines its own tp_repr slot to produce representations like 'repeat(42)' or 'repeat(42, 3)'; because it has a custom slot, the wrapper_descriptor's __qualname__ is 'repeat.__repr__' (type-specific); str.__eq__('repeat.__repr__') returns True; new to extra111"]
    - [cycle_repr_qualname_inherited,
       "cycle.__repr__.__qualname__.__eq__",
       ["object.__repr__"],
       true,
       "itertools.cycle.__repr__.__qualname__.__eq__('object.__repr__') == True — itertools.cycle does NOT define its own tp_repr slot; it inherits object.__repr__; the wrapper_descriptor's __qualname__ is 'object.__repr__' indicating it belongs to the base object class; str.__eq__('object.__repr__') returns True; new to extra111"]
    - [chain_repr_qualname_inherited,
       "chain.__repr__.__qualname__.__eq__",
       ["object.__repr__"],
       true,
       "itertools.chain.__repr__.__qualname__.__eq__('object.__repr__') == True — itertools.chain does NOT define its own tp_repr; it inherits object.__repr__; the wrapper_descriptor's __qualname__ is 'object.__repr__'; str.__eq__('object.__repr__') returns True; new to extra111"]
    - [compress_repr_qualname_inherited,
       "compress.__repr__.__qualname__.__eq__",
       ["object.__repr__"],
       true,
       "itertools.compress.__repr__.__qualname__.__eq__('object.__repr__') == True — itertools.compress does NOT define its own tp_repr; it inherits object.__repr__; the wrapper_descriptor's __qualname__ is 'object.__repr__'; str.__eq__('object.__repr__') returns True; new to extra111"]
    - [count_repr_type_wrapper,
       "count.__repr__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.count.__repr__.__class__.__name__.__eq__('wrapper_descriptor') == True — even though count defines its own tp_repr, the class-level access of __repr__ is still a 'wrapper_descriptor' (the C slot wrapper descriptor exposed on the type object); str.__eq__('wrapper_descriptor') returns True; new to extra111"]
    - [repeat_repr_type_wrapper,
       "repeat.__repr__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.repeat.__repr__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.repeat's custom tp_repr is also exposed as a 'wrapper_descriptor' on the class; all special method C slots are accessed as wrapper_descriptors; str.__eq__('wrapper_descriptor') returns True; new to extra111"]

# ---------------------------------------------------------------------------
# Table 2: itertools C-extension type __iter__ qualnames
#
# Wave 263 theme: all itertools iterator types define their own tp_iter slot.
# Unlike __repr__ where some types inherit from object, every itertools C type
# defines tp_iter to return self (iterators are their own iterables). Therefore
# the __iter__ wrapper_descriptor on each type has a type-specific qualname:
# 'count.__iter__', 'cycle.__iter__', 'repeat.__iter__', 'chain.__iter__'.
# This demonstrates that tp_iter is always customized for itertools types.
#
# itertools.count.__iter__.__qualname__ == 'count.__iter__'
# itertools.cycle.__iter__.__qualname__ == 'cycle.__iter__'
# itertools.repeat.__iter__.__qualname__ == 'repeat.__iter__'
# itertools.chain.__iter__.__qualname__ == 'chain.__iter__'
#
# New to extra111.
# ---------------------------------------------------------------------------

table itertools_extra111.iter_qualnames:
  description: "itertools __iter__ qualnames are all type-specific: count/cycle/repeat/chain all define own tp_iter; qualnames 'count.__iter__'/'cycle.__iter__'/'repeat.__iter__'/'chain.__iter__'; wave 263; new to extra111"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsiqn111

  columns: [id, function, args, expected, description]
  rows:
    - [count_iter_qualname,
       "count.__iter__.__qualname__.__eq__",
       ["count.__iter__"],
       true,
       "itertools.count.__iter__.__qualname__.__eq__('count.__iter__') == True — itertools.count defines its own tp_iter slot (returning self, since it is its own iterator); the wrapper_descriptor's __qualname__ is 'count.__iter__' (type-specific, not inherited from object); str.__eq__('count.__iter__') returns True; new to extra111"]
    - [cycle_iter_qualname,
       "cycle.__iter__.__qualname__.__eq__",
       ["cycle.__iter__"],
       true,
       "itertools.cycle.__iter__.__qualname__.__eq__('cycle.__iter__') == True — itertools.cycle defines its own tp_iter slot; the wrapper_descriptor's __qualname__ is 'cycle.__iter__'; unlike __repr__ which cycle inherits from object, cycle does define its own __iter__; str.__eq__('cycle.__iter__') returns True; new to extra111"]
    - [repeat_iter_qualname,
       "repeat.__iter__.__qualname__.__eq__",
       ["repeat.__iter__"],
       true,
       "itertools.repeat.__iter__.__qualname__.__eq__('repeat.__iter__') == True — itertools.repeat defines its own tp_iter slot; its wrapper_descriptor __qualname__ is 'repeat.__iter__'; str.__eq__('repeat.__iter__') returns True; new to extra111"]
    - [chain_iter_qualname,
       "chain.__iter__.__qualname__.__eq__",
       ["chain.__iter__"],
       true,
       "itertools.chain.__iter__.__qualname__.__eq__('chain.__iter__') == True — itertools.chain defines its own tp_iter slot; the wrapper_descriptor's __qualname__ is 'chain.__iter__'; unlike chain.__repr__ which inherits 'object.__repr__', chain.__iter__ is type-specific; str.__eq__('chain.__iter__') returns True; new to extra111"]
    - [count_iter_type_wrapper,
       "count.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.count.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.count's tp_iter slot is exposed as a 'wrapper_descriptor' on the class; all C-level iterator protocol slots are accessed as wrapper_descriptors from the class; str.__eq__('wrapper_descriptor') returns True; new to extra111"]
    - [chain_iter_type_wrapper,
       "chain.__iter__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.chain.__iter__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.chain's tp_iter slot is exposed as a 'wrapper_descriptor'; even though chain's __repr__ is inherited from object, its __iter__ has its own slot; str.__eq__('wrapper_descriptor') returns True; new to extra111"]

# ---------------------------------------------------------------------------
# Table 3: itertools C-extension type __next__ method types
#
# Wave 263 theme: all itertools iterator types define their own tp_iternext
# slot, exposed as __next__. Like __iter__, __next__ is always type-specific
# for itertools types. The class-level __next__ is a 'wrapper_descriptor'.
# This table verifies the type for count, cycle, repeat, and chain, and
# contrasts with __repr__ (which only count and repeat have as type-specific).
#
# type(itertools.count.__next__).__name__ == 'wrapper_descriptor'
# type(itertools.cycle.__next__).__name__ == 'wrapper_descriptor'
# type(itertools.repeat.__next__).__name__ == 'wrapper_descriptor'
# type(itertools.chain.__next__).__name__ == 'wrapper_descriptor'
#
# New to extra111.
# ---------------------------------------------------------------------------

table itertools_extra111.next_types:
  description: "itertools __next__ types: count/cycle/repeat/chain all have 'wrapper_descriptor' for __next__; all itertools types define their own tp_iternext slot; wave 263; new to extra111"
  kind: python_call_eq
  category: type_identity
  id_prefix: itertoolsnt111

  columns: [id, function, args, expected, description]
  rows:
    - [count_next_type_wrapper,
       "count.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.count.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.count defines its own tp_iternext slot; it is exposed as a 'wrapper_descriptor' on the class; count.__next__ advances the counter and returns the next value; str.__eq__('wrapper_descriptor') returns True; new to extra111"]
    - [cycle_next_type_wrapper,
       "cycle.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.cycle.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.cycle defines its own tp_iternext slot; cycle.__next__ cycles through the saved sequence; exposed as 'wrapper_descriptor' on the class; str.__eq__('wrapper_descriptor') returns True; new to extra111"]
    - [repeat_next_type_wrapper,
       "repeat.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.repeat.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.repeat defines its own tp_iternext slot; repeat.__next__ returns the repeated object (with optional count decrement); exposed as 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra111"]
    - [chain_next_type_wrapper,
       "chain.__next__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "itertools.chain.__next__.__class__.__name__.__eq__('wrapper_descriptor') == True — itertools.chain defines its own tp_iternext slot; chain.__next__ advances through the chained iterators in sequence; exposed as 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra111"]
    - [count_repr_vs_iter_contrast,
       "count.__repr__.__qualname__.__eq__",
       ["count.__repr__"],
       true,
       "itertools.count.__repr__.__qualname__.__eq__('count.__repr__') == True — contrast: count defines both its own tp_repr ('count.__repr__') and its own tp_iter ('count.__iter__') and tp_iternext; while cycle only defines tp_iter and tp_iternext (inheriting tp_repr from object); str.__eq__('count.__repr__') returns True; new to extra111"]
    - [cycle_repr_vs_iter_contrast,
       "cycle.__repr__.__qualname__.__eq__",
       ["object.__repr__"],
       true,
       "itertools.cycle.__repr__.__qualname__.__eq__('object.__repr__') == True — contrast: cycle does NOT define tp_repr (inherits 'object.__repr__') but DOES define tp_iter ('cycle.__iter__') and tp_iternext; this shows that __iter__/__next__ are universal for itertools types while __repr__ is selective; str.__eq__('object.__repr__') returns True; new to extra111"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra111
# ---------------------------------------------------------------------------

invariant itertools_extra111.count_repr_qualname:
  description: "itertools.count.__repr__.__qualname__ == 'count.__repr__' — count defines own tp_repr (unlike most itertools types); wave 263; new to extra111"
  kind: python_call_eq
  function: count.__repr__.__qualname__.__eq__
  args: ["count.__repr__"]
  expected: true

invariant itertools_extra111.cycle_repr_qualname_inherited:
  description: "itertools.cycle.__repr__.__qualname__ == 'object.__repr__' — cycle inherits tp_repr from object; wave 263; new to extra111"
  kind: python_call_eq
  function: cycle.__repr__.__qualname__.__eq__
  args: ["object.__repr__"]
  expected: true

invariant itertools_extra111.count_iter_qualname:
  description: "itertools.count.__iter__.__qualname__ == 'count.__iter__' — all itertools types define own tp_iter; count-specific; wave 263; new to extra111"
  kind: python_call_eq
  function: count.__iter__.__qualname__.__eq__
  args: ["count.__iter__"]
  expected: true

invariant itertools_extra111.chain_iter_qualname:
  description: "itertools.chain.__iter__.__qualname__ == 'chain.__iter__' — chain defines own tp_iter despite inheriting tp_repr from object; wave 263; new to extra111"
  kind: python_call_eq
  function: chain.__iter__.__qualname__.__eq__
  args: ["chain.__iter__"]
  expected: true

invariant itertools_extra111.repeat_next_type:
  description: "type(itertools.repeat.__next__).__name__ == 'wrapper_descriptor' — all itertools types define tp_iternext; repeat's __next__ is a wrapper_descriptor; wave 263; new to extra111"
  kind: python_call_eq
  function: repeat.__next__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
