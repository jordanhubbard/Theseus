spec: array_extra23
version: ">=3.9"
backend: python_module(array)

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html — Python array module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/arraymodule.c"
    - "array.zspec.zsdl — baseline typecode, itemsize, and instance vectors."
    - "array_extra.zspec.zsdl through array_extra22.zspec.zsdl — prior extras."
  notes:
    - "This spec extends array.zspec.zsdl through array_extra22.zspec.zsdl."
    - "array_extra21 covers __qualname__ for: append/extend/pop/insert/remove/reverse/tolist/tobytes/frombytes."
    - "array_extra22 covers __qualname__ for: buffer_info/byteswap/index."
    - "No prior array spec checks __qualname__ for: count/fromlist/fromfile/tofile/__len__/__iter__."
    - "array.array.copy does not exist in Python 3.12 — verified absent."
    - "array.array.fromstring does not exist in Python 3.12 — removed in Python 3.9."
    - "This spec adds NEW axes:"
    - "  (1) array.array.count.__qualname__ == 'array.count'."
    - "  (2) array.array.fromlist.__qualname__ == 'array.fromlist'."
    - "  (3) array.array.fromfile.__qualname__ == 'array.fromfile'."
    - "  (4) array.array.tofile.__qualname__ == 'array.tofile'."
    - "  (5) array.array.__len__.__qualname__ == 'array.__len__'."
    - "  (6) array.array.__iter__.__qualname__ == 'array.__iter__'."
    - "array.array.count.__qualname__ == 'array.count' — Verified Python 3.12 macOS."
    - "array.array.fromlist.__qualname__ == 'array.fromlist' — Verified."
    - "array.array.fromfile.__qualname__ == 'array.fromfile' — Verified."
    - "array.array.tofile.__qualname__ == 'array.tofile' — Verified."
    - "array.array.__len__.__qualname__ == 'array.__len__' — Verified."
    - "array.array.__iter__.__qualname__ == 'array.__iter__' — Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# array.array method __qualname__ — remaining methods not covered in prior specs
#
# Coverage summary of prior specs:
#   array_extra21: append, extend, pop, insert, remove, reverse, tolist,
#                  tobytes, frombytes
#   array_extra22: buffer_info, byteswap, index
#
# Remaining: count, fromlist, fromfile, tofile, __len__, __iter__.
# array.array.copy and array.array.fromstring do not exist in Python 3.12.
# Under python_module(array), 'array.count.__qualname__.__eq__' resolves as
# array_module.array.count.__qualname__.__eq__.
# ---------------------------------------------------------------------------

table array_extra23.method_qualnames:
  description: "array.array method __qualname__ values for count/fromlist/fromfile/tofile/__len__/__iter__"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aqn23

  columns: [id, function, args, expected]
  rows:
    - [count,    "array.count.__qualname__.__eq__",    ["array.count"],    true]
    - [fromlist, "array.fromlist.__qualname__.__eq__", ["array.fromlist"], true]
    - [fromfile, "array.fromfile.__qualname__.__eq__", ["array.fromfile"], true]
    - [tofile,   "array.tofile.__qualname__.__eq__",   ["array.tofile"],   true]
    - [dunder_len,  "array.__len__.__qualname__.__eq__",  ["array.__len__"],  true]
    - [dunder_iter, "array.__iter__.__qualname__.__eq__", ["array.__iter__"], true]
