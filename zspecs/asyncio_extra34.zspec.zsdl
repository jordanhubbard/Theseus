spec: asyncio_extra34
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/taskgroups.py"
    - "CPython source: Modules/_asynciomodule.c"
  notes:
    - "This spec extends asyncio_extra33.zspec.zsdl."
    - "Prior specs covered: asyncio.__name__/__package__, Queue/Lock/Event/Semaphore/BoundedSemaphore/Condition/__name__, PriorityQueue/LifoQueue/__name__, QueueEmpty/QueueFull/__name__, Task/Future/__name__, CancelledError/TimeoutError/InvalidStateError/__name__, gather/sleep/wait/__name__, Queue/__bases__[0]/__module__, class __module__/__len__() tables, class __qualname__.__len__() tables, Condition/BoundedSemaphore/TaskGroup __module__.__len__(), Task/Future __module__.__len__() (C extension), Queue/Lock method __qualname__.__len__(), InvalidStateError/TimeoutError/CancelledError __bases__[0].__name__ and __mro__.__len__(), asyncio.__all__.__len__() == 95, class __dict__.__class__.__name__.__len__() tables, Event/Semaphore/Condition method __qualname__.__len__(), create_task/run_coroutine_threadsafe __qualname__.__len__(), Queue.__mro__.__len__() == 3, BoundedSemaphore.__mro__.__len__() == 5, Queue method __qualname__.__len__() tables, wait_for/shield/sleep module/name lengths, timeout class identity, TaskGroup class identity, Task/Future MRO depths and base name lengths."
    - "This spec covers: Queue.__bases__[0].__name__.__len__()==15 ('_LoopBoundMixin'); PriorityQueue.__mro__.__len__()==4, PriorityQueue.__bases__[0].__name__.__len__()==5 ('Queue'); LifoQueue.__mro__.__len__()==4, LifoQueue.__bases__[0].__name__.__len__()==5 ('Queue'); Lock.__mro__.__len__()==4, Lock.__bases__[0].__name__.__len__()==20 ('_ContextManagerMixin'); Event.__mro__.__len__()==3, Event.__bases__[0].__name__.__len__()==15 ('_LoopBoundMixin'); Semaphore.__mro__.__len__()==4, Semaphore.__bases__[0].__name__.__len__()==20 ('_ContextManagerMixin'); BoundedSemaphore.__bases__[0].__name__.__len__()==9 ('Semaphore'); Condition.__mro__.__len__()==4, Condition.__bases__[0].__name__.__len__()==20 ('_ContextManagerMixin'); TaskGroup.__bases__[0].__name__.__len__()==6 ('object')."
    - "asyncio.Queue.__bases__[0].__name__ == '_LoopBoundMixin' (15 chars) — Queue inherits from this internal mixin, not directly from object."
    - "asyncio.PriorityQueue and asyncio.LifoQueue both have MRO depth 4 — they subclass Queue which subclasses _LoopBoundMixin which subclasses object."
    - "asyncio.Lock, asyncio.Semaphore, and asyncio.Condition all inherit from '_ContextManagerMixin' (20 chars) as their direct base, giving MRO depth 4."
    - "asyncio.Event.__bases__[0].__name__ == '_LoopBoundMixin' (15 chars) — Event shares the same base mixin as Queue."
    - "asyncio.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' (9 chars) — BoundedSemaphore subclasses Semaphore, giving MRO depth 5."
    - "asyncio.TaskGroup.__bases__[0].__name__ == 'object' (6 chars) — TaskGroup is a direct subclass of object with MRO depth 2."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Queue base class name length — extra34 namespace
#
# asyncio.Queue does not directly subclass object. Its immediate base is
# _LoopBoundMixin, an internal mixin:
#   Queue.__bases__[0].__name__ == '_LoopBoundMixin' (15 chars)
#   Queue.__bases__[0].__name__.__len__() == 15
# This contrasts with multiprocessing.queues.Queue which directly subclasses
# object (6 chars). No prior asyncio spec has measured this __len__() as a
# standalone invariant (only the name itself was noted in extra33 notes).
# ---------------------------------------------------------------------------

invariant asyncio_extra34.Queue_base_name_len:
  description: "asyncio.Queue.__bases__[0].__name__.__len__() == 15 — '_LoopBoundMixin' has 15 characters, Queue does not directly subclass object"
  category: class_hierarchy
  kind: python_call_eq
  function: "Queue.__bases__[0].__name__.__len__"
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# asyncio PriorityQueue and LifoQueue MRO depths — extra34 namespace
#
# PriorityQueue and LifoQueue are subclasses of Queue. Their MRO chains:
#   PriorityQueue.__mro__ == (PriorityQueue, Queue, _LoopBoundMixin, object) — depth 4
#   LifoQueue.__mro__     == (LifoQueue, Queue, _LoopBoundMixin, object)     — depth 4
# Both have the same MRO depth (4) and the same direct base (Queue, 5 chars).
# Prior specs confirmed Queue.__mro__.__len__() == 3 but did not measure
# PriorityQueue or LifoQueue MRO depths in table rows.
# ---------------------------------------------------------------------------

table asyncio_extra34.queue_subclass_mro_depths:
  description: "asyncio PriorityQueue and LifoQueue __mro__.__len__() in extra34 namespace — both depth 4"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: qsubmrolen34

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [PriorityQueue, PriorityQueue.__mro__, [], !ascii "", __len__, [], "PriorityQueue MRO depth == 4 — (PriorityQueue, Queue, _LoopBoundMixin, object)"]
    - [LifoQueue,     LifoQueue.__mro__,     [], !ascii "", __len__, [], "LifoQueue MRO depth == 4 — (LifoQueue, Queue, _LoopBoundMixin, object)"]

table asyncio_extra34.queue_subclass_base_name_lengths:
  description: "asyncio PriorityQueue and LifoQueue __bases__[0].__name__.__len__() in extra34 namespace — both 5 ('Queue')"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: qsubbaselen34

  columns: [id, function, args, expected]
  rows:
    - [PriorityQueue, "PriorityQueue.__bases__[0].__name__.__len__", [], 5]
    - [LifoQueue,     "LifoQueue.__bases__[0].__name__.__len__",     [], 5]

# ---------------------------------------------------------------------------
# asyncio Lock, Semaphore, and Condition MRO depths — extra34 namespace
#
# Lock, Semaphore, and Condition all inherit from _ContextManagerMixin (20 chars)
# as their immediate base. Their MRO chains have depth 4:
#   Lock.__mro__      == (Lock, _ContextManagerMixin, _LoopBoundMixin, object)
#   Semaphore.__mro__ == (Semaphore, _ContextManagerMixin, _LoopBoundMixin, object)
#   Condition.__mro__ == (Condition, _ContextManagerMixin, _LoopBoundMixin, object)
# The base class name '_ContextManagerMixin' is 20 characters long.
# No prior asyncio spec measured Lock or Condition MRO depth (BoundedSemaphore
# MRO depth 5 was covered in prior specs; Semaphore was not explicitly tabled).
# ---------------------------------------------------------------------------

table asyncio_extra34.lock_semaphore_condition_mro_depths:
  description: "asyncio Lock, Semaphore, and Condition __mro__.__len__() in extra34 namespace — all depth 4"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: lscmrolen34

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [Lock,      Lock.__mro__,      [], !ascii "", __len__, [], "Lock MRO depth == 4 — (Lock, _ContextManagerMixin, _LoopBoundMixin, object)"]
    - [Semaphore, Semaphore.__mro__, [], !ascii "", __len__, [], "Semaphore MRO depth == 4 — (Semaphore, _ContextManagerMixin, _LoopBoundMixin, object)"]
    - [Condition, Condition.__mro__, [], !ascii "", __len__, [], "Condition MRO depth == 4 — (Condition, _ContextManagerMixin, _LoopBoundMixin, object)"]

table asyncio_extra34.lock_semaphore_condition_base_name_lengths:
  description: "asyncio Lock, Semaphore, and Condition __bases__[0].__name__.__len__() in extra34 namespace — all 20 ('_ContextManagerMixin')"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: lscbaselen34

  columns: [id, function, args, expected]
  rows:
    - [Lock,      "Lock.__bases__[0].__name__.__len__",      [], 20]
    - [Semaphore, "Semaphore.__bases__[0].__name__.__len__", [], 20]
    - [Condition, "Condition.__bases__[0].__name__.__len__", [], 20]

# ---------------------------------------------------------------------------
# asyncio.Event MRO depth and base class — extra34 namespace
#
# asyncio.Event inherits from _LoopBoundMixin (not _ContextManagerMixin):
#   Event.__mro__.__len__() == 3 — (Event, _LoopBoundMixin, object)
#   Event.__bases__[0].__name__ == '_LoopBoundMixin' (15 chars)
# This is shallower than Lock/Semaphore/Condition (depth 4) because Event
# does not need the context manager protocol. Event shares its base mixin
# with Queue (also _LoopBoundMixin, also depth 3 from Event's perspective).
# No prior spec measured Event.__mro__.__len__() in an explicit table.
# ---------------------------------------------------------------------------

invariant asyncio_extra34.Event_mro_len:
  description: "asyncio.Event.__mro__.__len__() == 3 — (Event, _LoopBoundMixin, object) — shallower than Lock/Semaphore/Condition"
  category: class_hierarchy
  kind: python_call_eq
  function: Event.__mro__.__len__
  args: []
  expected: 3

invariant asyncio_extra34.Event_base_name_len:
  description: "asyncio.Event.__bases__[0].__name__.__len__() == 15 — '_LoopBoundMixin' (15 chars), same base mixin as Queue"
  category: class_hierarchy
  kind: python_call_eq
  function: "Event.__bases__[0].__name__.__len__"
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# asyncio.BoundedSemaphore base class name length — extra34 namespace
#
# BoundedSemaphore subclasses Semaphore (not _ContextManagerMixin directly):
#   BoundedSemaphore.__bases__[0].__name__ == 'Semaphore' (9 chars)
#   BoundedSemaphore.__mro__.__len__() == 5 — already covered in prior specs
# The base name length (9) distinguishes it from Lock/Semaphore/Condition
# whose bases are '_ContextManagerMixin' (20 chars).
# ---------------------------------------------------------------------------

invariant asyncio_extra34.BoundedSemaphore_base_name_len:
  description: "asyncio.BoundedSemaphore.__bases__[0].__name__.__len__() == 9 — base is 'Semaphore' (9 chars), not _ContextManagerMixin"
  category: class_hierarchy
  kind: python_call_eq
  function: "BoundedSemaphore.__bases__[0].__name__.__len__"
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# asyncio.TaskGroup base class name length — extra34 namespace
#
# TaskGroup is a direct subclass of object:
#   TaskGroup.__bases__[0].__name__ == 'object' (6 chars)
#   TaskGroup.__mro__.__len__() == 2 — already covered in extra33
# The base name length (6) confirms the flat hierarchy for structured
# concurrency context manager (no mixin intermediate classes).
# ---------------------------------------------------------------------------

invariant asyncio_extra34.TaskGroup_base_name_len:
  description: "asyncio.TaskGroup.__bases__[0].__name__.__len__() == 6 — 'object' (6 chars), TaskGroup has flat single-level inheritance"
  category: class_hierarchy
  kind: python_call_eq
  function: "TaskGroup.__bases__[0].__name__.__len__"
  args: []
  expected: 6
