  id_prefix: as2401

  columns: [id, function, args, expected]
  rows:
    - ["as2401021", Queue.__hash__.__class__.__name__.__eq__,           ["wrapper_descriptor"], true]
    - ["as2401022", Queue.__eq__.__class__.__name__.__eq__,             ["wrapper_descriptor"], true]
    - ["as2401023", Queue.__dict__.__contains__,                        ["__hash__"], false]
    - ["as2401024", Queue.__dict__.__contains__,                        ["__eq__"], false]
    - ["as2401025", Semaphore.__hash__.__class__.__name__.__eq__,       ["wrapper_descriptor"], true]
    - ["as2401026", Semaphore.__eq__.__class__.__name__.__eq__,         ["wrapper_descriptor"], true]
    - ["as2401027", Condition.__hash__.__class__.__name__.__eq__,       ["wrapper_descriptor"], true]
