spec: asyncio_extra2401
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_asynciomodule.c"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/queues.py"
  notes:
    - "Theme: __hash__ and __eq__ implementation type classification via .__hash__.__class__.__name__ and .__eq__.__class__.__name__."
    - "All asyncio classes tested here inherit __hash__ and __eq__ from object (none set __hash__ = None)."
    - "asyncio.Task is a C-accelerated type; __hash__ and __eq__ are 'wrapper_descriptor' (inherited slot wrappers from object)."
    - "asyncio.Future is also C-accelerated; __hash__ and __eq__ are 'wrapper_descriptor'."
    - "asyncio.Event, Lock, Queue, Semaphore, Condition, BoundedSemaphore are pure-Python classes that do not define __hash__ or __eq__; all inherit 'wrapper_descriptor' from object."
    - "None of these classes set __hash__ = None, so __hash__.__class__.__name__ is never 'NoneType' for any of them."
    - "Task.__dict__, Future.__dict__, Event.__dict__, Lock.__dict__, Queue.__dict__, Semaphore.__dict__ do not contain '__hash__' or '__eq__'."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: asyncio.Task __hash__ and __eq__ implementation type
#
# Task is a C-accelerated coroutine wrapper type. __hash__ and __eq__ are
# both 'wrapper_descriptor', inherited from object via the C slot mechanism.
# Task does not override either method, so its __dict__ contains neither.
# ---------------------------------------------------------------------------

table asyncio_extra2401.task_hash_eq:
  description: "asyncio.Task __hash__ and __eq__ implementation type classification"
  kind: python_call_eq
  category: hash_eq_type
  id_prefix: as2401

  columns: [id, function, args, expected]
  rows:
    - ["as2401001", Task.__hash__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - ["as2401002", Task.__eq__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - ["as2401003", Task.__hash__.__class__.__name__.__len__, [], 18]
    - ["as2401004", Task.__eq__.__class__.__name__.__len__,   [], 18]
    - ["as2401005", Task.__dict__.__contains__,               ["__hash__"], false]
    - ["as2401006", Task.__dict__.__contains__,               ["__eq__"], false]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Future __hash__ and __eq__ implementation type
#
# Future is also C-accelerated. __hash__ and __eq__ are 'wrapper_descriptor',
# inherited from object. Future.__dict__ contains neither '__hash__' nor '__eq__'.
# ---------------------------------------------------------------------------

table asyncio_extra2401.future_hash_eq:
  description: "asyncio.Future __hash__ and __eq__ implementation type classification"
  kind: python_call_eq
  category: hash_eq_type
  id_prefix: as2401

  columns: [id, function, args, expected]
  rows:
    - ["as2401007", Future.__hash__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - ["as2401008", Future.__eq__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - ["as2401009", Future.__hash__.__class__.__name__.__len__, [], 18]
    - ["as2401010", Future.__eq__.__class__.__name__.__len__,   [], 18]
    - ["as2401011", Future.__dict__.__contains__,               ["__hash__"], false]
    - ["as2401012", Future.__dict__.__contains__,               ["__eq__"], false]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Event and asyncio.Lock __hash__ and __eq__ types
#
# Both are pure-Python classes. Neither defines __hash__ or __eq__, so both
# inherit 'wrapper_descriptor' slot wrappers from object. Their __dict__ maps
# contain neither '__hash__' nor '__eq__'.
# ---------------------------------------------------------------------------

table asyncio_extra2401.event_lock_hash_eq:
  description: "asyncio.Event and asyncio.Lock __hash__ and __eq__ implementation type classification"
  kind: python_call_eq
  category: hash_eq_type
  id_prefix: as2401

  columns: [id, function, args, expected]
  rows:
    - ["as2401013", Event.__hash__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]
    - ["as2401014", Event.__eq__.__class__.__name__.__eq__,   ["wrapper_descriptor"], true]
    - ["as2401015", Event.__dict__.__contains__,              ["__hash__"], false]
    - ["as2401016", Event.__dict__.__contains__,              ["__eq__"], false]
    - ["as2401017", Lock.__hash__.__class__.__name__.__eq__,  ["wrapper_descriptor"], true]
    - ["as2401018", Lock.__eq__.__class__.__name__.__eq__,    ["wrapper_descriptor"], true]
    - ["as2401019", Lock.__dict__.__contains__,               ["__hash__"], false]
    - ["as2401020", Lock.__dict__.__contains__,               ["__eq__"], false]

# ---------------------------------------------------------------------------
# Table 4: asyncio.Queue, asyncio.Semaphore, asyncio.Condition,
#          asyncio.BoundedSemaphore __hash__ and __eq__ types
#
# All four are pure-Python classes that do not define __hash__ or __eq__.
# All inherit 'wrapper_descriptor' from object. None sets __hash__ = None,
# so __hash__.__class__.__name__ is never 'NoneType'.
# ---------------------------------------------------------------------------

table asyncio_extra2401.queue_semaphore_condition_hash_eq:
  description: "asyncio.Queue, Semaphore, Condition, BoundedSemaphore __hash__ and __eq__ type classification"
  kind: python_call_eq
