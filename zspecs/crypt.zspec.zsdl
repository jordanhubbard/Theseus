spec: crypt
version: ">=3.3,<3.13"
backend: python_module(crypt)

docs: https://docs.python.org/3/library/crypt.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/crypt.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
    - "crypt source: Lib/crypt.py (PSF; source inspection permitted)"
  not_derived_from:
    - "crypt internal OS-level crypt(3) libc implementation details"
  notes:
    - "Deprecated since Python 3.11; removed in Python 3.13."
    - "The crypt module provides an interface to the Unix crypt(3) password hashing function."
    - "crypt.crypt(word, salt) returns the hashed password as a string."
    - "crypt.mksalt([method]) generates a random salt string for the given method."
    - "crypt.methods is a list of available hashing methods on the current platform."
    - "METHOD_SHA512, METHOD_SHA256, METHOD_MD5, METHOD_CRYPT are _Method namedtuple instances."
    - "All expected values verified by running Python 3.12 crypt module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "crypt.crypt() raises OSError if the underlying crypt(3) call fails. mksalt() raises ValueError for an unknown method."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# Function name checks
# ---------------------------------------------------------------------------

invariant crypt.crypt_func_name:
  description: "crypt.crypt.__name__ == 'crypt'"
  category: functions
  kind: python_call_eq
  function: crypt.__name__.__eq__
  args: ["crypt"]
  expected: true

invariant crypt.crypt_func_module:
  description: "crypt.crypt.__module__ == 'crypt'"
  category: functions
  kind: python_call_eq
  function: crypt.__module__.__eq__
  args: ["crypt"]
  expected: true

invariant crypt.mksalt_name:
  description: "crypt.mksalt.__name__ == 'mksalt'"
  category: functions
  kind: python_call_eq
  function: mksalt.__name__.__eq__
  args: ["mksalt"]
  expected: true

invariant crypt.mksalt_module:
  description: "crypt.mksalt.__module__ == 'crypt'"
  category: functions
  kind: python_call_eq
  function: mksalt.__module__.__eq__
  args: ["crypt"]
  expected: true

# ---------------------------------------------------------------------------
# methods list checks
# ---------------------------------------------------------------------------

invariant crypt.methods_is_list:
  description: "crypt.methods.__class__.__name__ == 'list'"
  category: methods_list
  kind: python_call_eq
  function: methods.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant crypt.methods_nonempty:
  description: "len(crypt.methods) > 0 — at least one hashing method is available"
  category: methods_list
  kind: python_call_eq
  function: methods.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# METHOD_CRYPT namedtuple checks (present on all POSIX platforms)
# ---------------------------------------------------------------------------

invariant crypt.METHOD_CRYPT_class_name:
  description: "crypt.METHOD_CRYPT.__class__.__name__ == '_Method'"
  category: method_constants
  kind: python_call_eq
  function: METHOD_CRYPT.__class__.__name__.__eq__
  args: ["_Method"]
  expected: true

invariant crypt.METHOD_CRYPT_name_attr:
  description: "crypt.METHOD_CRYPT.name == 'crypt' — the METHOD_CRYPT namedtuple's name field"
  category: method_constants
  kind: python_call_eq
  function: METHOD_CRYPT.name.__eq__
  args: ["crypt"]
  expected: true

# ---------------------------------------------------------------------------
# mksalt return type checks
# ---------------------------------------------------------------------------

invariant crypt.mksalt_returns_str:
  description: "mksalt(METHOD_CRYPT).__class__.__name__ == 'str'"
  category: mksalt
  kind: python_call_eq
  function: mksalt
  args: [METHOD_CRYPT]
  method: __class__.__name__.__eq__
  method_args: ["str"]
  expected: true

invariant crypt.mksalt_nonempty:
  description: "mksalt(METHOD_CRYPT).__len__() > 0 — salt string is non-empty"
  category: mksalt
  kind: python_call_eq
  function: mksalt
  args: [METHOD_CRYPT]
  method: __len__
  method_args: []
  expected: 2
