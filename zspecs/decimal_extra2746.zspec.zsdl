spec: decimal_extra2746
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2731.zspec.zsdl — covers __trunc__/__floor__/__ceil__ dict-presence"
    - "decimal_extra2716.zspec.zsdl — covers __neg__/__pos__/__abs__ dict-presence"
  notes:
    - "Wave 630 (decimal_extra2746) theme: __round__, __divmod__, and __pow__ dict-presence checks."
    - "decimal.Decimal DOES define __round__, __divmod__, and __pow__ in its own __dict__ — Decimal implements the full numeric tower including rounding, quotient-remainder, and exponentiation protocols."
    - "decimal.Context and decimal.DecimalException do NOT define __round__, __divmod__, or __pow__ in their own __dict__."
    - "__round__ (built-in round()) on Decimal rounds to a given number of decimal places using the active context."
    - "__divmod__ (divmod()) on Decimal returns (quotient, remainder) with full decimal precision."
    - "__pow__ (** operator) on Decimal supports decimal exponentiation including fractional and negative exponents."
    - "decimal.Context provides context-level control for arithmetic but does not itself support these numeric protocols."
    - "decimal.DecimalException is an exception base class with no numeric operator semantics."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __round__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2746.round_presence_in_decimal_classes:
  description: "__round__ is present in decimal.Decimal __dict__ (full numeric tower) but absent from decimal.Context and decimal.DecimalException"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2746

  columns: [id, function, args, expected]
  rows:
    - ["dc2746001", "decimal.Decimal.__dict__.__contains__",          ["__round__"], true]
    - ["dc2746002", "decimal.Context.__dict__.__contains__",          ["__round__"], false]
    - ["dc2746003", "decimal.DecimalException.__dict__.__contains__", ["__round__"], false]

