  rows:
    - ["dc2746004", "decimal.Decimal.__dict__.__contains__",          ["__divmod__"], true]
    - ["dc2746005", "decimal.Context.__dict__.__contains__",          ["__divmod__"], false]
    - ["dc2746006", "decimal.DecimalException.__dict__.__contains__", ["__divmod__"], false]

