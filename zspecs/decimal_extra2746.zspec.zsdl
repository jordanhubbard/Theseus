# ---------------------------------------------------------------------------

table decimal_extra2746.pow_presence_in_decimal_classes:
  description: "__pow__ is present in decimal.Decimal __dict__ (full numeric tower) but absent from decimal.Context and decimal.DecimalException"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2746

  columns: [id, function, args, expected]
  rows:
    - ["dc2746007", "decimal.Decimal.__dict__.__contains__",          ["__pow__"], true]
    - ["dc2746008", "decimal.Context.__dict__.__contains__",          ["__pow__"], false]
    - ["dc2746009", "decimal.DecimalException.__dict__.__contains__", ["__pow__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal has full arithmetic dunders including round/divmod/pow protocols
# Contrasts Decimal's arithmetic hooks with the absent __round__/__divmod__/__pow__ on Context and DecimalException
# ---------------------------------------------------------------------------

table decimal_extra2746.decimal_has_full_arithmetic_numeric_protocol:
  description: "decimal.Decimal defines __add__/__sub__/__mul__ and also __round__/__divmod__/__pow__; decimal.Context and decimal.DecimalException define none of __round__/__divmod__/__pow__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2746

  columns: [id, function, args, expected]
  rows:
    - ["dc2746010", "decimal.Decimal.__dict__.__contains__", ["__add__"],    true]
    - ["dc2746011", "decimal.Decimal.__dict__.__contains__", ["__sub__"],    true]
    - ["dc2746012", "decimal.Decimal.__dict__.__contains__", ["__mul__"],    true]
    - ["dc2746013", "decimal.Decimal.__dict__.__contains__", ["__round__"],  true]
    - ["dc2746014", "decimal.Decimal.__dict__.__contains__", ["__divmod__"], true]
    - ["dc2746015", "decimal.Decimal.__dict__.__contains__", ["__pow__"],    true]
    - ["dc2746016", "decimal.Context.__dict__.__contains__", ["__round__"],  false]
    - ["dc2746017", "decimal.Context.__dict__.__contains__", ["__divmod__"], false]
    - ["dc2746018", "decimal.Context.__dict__.__contains__", ["__pow__"],    false]
    - ["dc2746019", "decimal.DecimalException.__dict__.__contains__", ["__round__"],  false]
    - ["dc2746020", "decimal.DecimalException.__dict__.__contains__", ["__divmod__"], false]
    - ["dc2746021", "decimal.DecimalException.__dict__.__contains__", ["__pow__"],    false]
