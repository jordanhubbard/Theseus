spec: itertools_extra246
version: ">=3.12"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools.batched and itertools.cycle class identity."
    - "itertools.batched was added in Python 3.12 (PEP 618 follow-up). Verified with Python 3.14.3."
    - "itertools.batched.__name__ == 'batched' (len=7). Verified with Python 3.14.3."
    - "itertools.batched.__module__ == 'itertools' (len=9). Verified with Python 3.14.3."
    - "itertools.batched.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "itertools.batched.__qualname__ == 'batched'. Verified with Python 3.14.3."
    - "itertools.cycle.__name__ == 'cycle' (len=5). Verified with Python 3.14.3."
    - "itertools.cycle.__module__ == 'itertools' (len=9). Verified with Python 3.14.3."
    - "itertools.cycle.__bases__[0].__name__ == 'object'. Verified with Python 3.14.3."
    - "itertools.cycle.__qualname__ == 'cycle'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.batched class identity contracts
#
# itertools.batched.__name__ == 'batched' (len=7)
# itertools.batched.__module__ == 'itertools' (len=9)
# itertools.batched.__bases__[0].__name__ == 'object'
# itertools.batched.__qualname__ == 'batched'
# itertools.batched.__name__.__len__() == 7
#
# batched is a C-level iterator class added in Python 3.12. New to extra246.
# ---------------------------------------------------------------------------

table itertools_extra246.batched246_identity:
  description: "itertools.batched class identity: name, module, bases, qualname; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: batched246

  columns: [id, function, args, expected, description]
  rows:
    - [batched_name_eq,
       batched.__name__.__eq__,
       ["batched"],
       true,
       "itertools.batched.__name__.__eq__('batched') == True — batched is a C-level iterator class added in Python 3.12; __name__ is 'batched' (len=7); new to extra246"]
    - [batched_name_len_7,
       batched.__name__.__len__,
       [],
       7,
       "itertools.batched.__name__.__len__() == 7 — 'batched' has exactly 7 characters; str.__len__() returns 7; new to extra246"]
    - [batched_module_itertools,
       batched.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.batched.__module__.__eq__('itertools') == True — batched is defined in the itertools C extension; __module__ is 'itertools' (len=9); new to extra246"]
    - [batched_module_len_9,
       batched.__module__.__len__,
       [],
       9,
       "itertools.batched.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra246"]
    - [batched_bases0_object,
       "batched.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.batched.__bases__[0].__name__.__eq__('object') == True — batched directly inherits from object; __bases__[0].__name__ is 'object'; new to extra246"]

# ---------------------------------------------------------------------------
# Table 2: itertools.batched extra class checks
#
# itertools.batched.__qualname__ == 'batched'
# itertools.batched.__class__.__name__ == 'type'
# itertools.batched.__bases__[0].__module__ == 'builtins'
# itertools.batched.__name__.__contains__('batch') == True
# itertools.batched.__module__.__contains__('iter') == True
#
# New to extra246.
# ---------------------------------------------------------------------------

table itertools_extra246.batched246_extra:
  description: "itertools.batched extra class checks: qualname, class type, name/module content; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: batched246b

  columns: [id, function, args, expected, description]
  rows:
    - [batched_qualname_eq,
       batched.__qualname__.__eq__,
       ["batched"],
       true,
       "itertools.batched.__qualname__.__eq__('batched') == True — __qualname__ equals __name__ for a top-level class; 'batched'; new to extra246"]
    - [batched_class_is_type,
       batched.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.batched.__class__.__name__.__eq__('type') == True — batched is a class so __class__ is 'type'; new to extra246"]
    - [batched_bases0_module_builtins,
       "batched.__bases__[0].__module__.__eq__",
       ["builtins"],
       true,
       "itertools.batched.__bases__[0].__module__.__eq__('builtins') == True — object is defined in builtins; __bases__[0].__module__ is 'builtins'; new to extra246"]
    - [batched_name_contains_batch,
       batched.__name__.__contains__,
       ["batch"],
       true,
       "itertools.batched.__name__.__contains__('batch') == True — 'batched' contains 'batch'; new to extra246"]
    - [batched_module_contains_iter,
       batched.__module__.__contains__,
       ["iter"],
       true,
       "itertools.batched.__module__.__contains__('iter') == True — 'itertools' contains 'iter'; new to extra246"]

# ---------------------------------------------------------------------------
# Table 3: itertools.cycle class identity contracts
#
# itertools.cycle.__name__ == 'cycle' (len=5)
# itertools.cycle.__module__ == 'itertools' (len=9)
# itertools.cycle.__bases__[0].__name__ == 'object'
# itertools.cycle.__qualname__ == 'cycle'
# itertools.cycle.__name__.__len__() == 5
#
# cycle is a C-level iterator class. New to extra246.
# ---------------------------------------------------------------------------

table itertools_extra246.cycle246_identity:
  description: "itertools.cycle class identity: name, module, bases, qualname; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: cycle246

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_name_eq,
       cycle.__name__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__name__.__eq__('cycle') == True — cycle is a C-level iterator class in the itertools module; __name__ is 'cycle' (len=5); new to extra246"]
    - [cycle_name_len_5,
       cycle.__name__.__len__,
       [],
       5,
       "itertools.cycle.__name__.__len__() == 5 — 'cycle' has exactly 5 characters; str.__len__() returns 5; new to extra246"]
    - [cycle_module_itertools,
       cycle.__module__.__eq__,
       ["itertools"],
       true,
       "itertools.cycle.__module__.__eq__('itertools') == True — cycle is defined in the itertools C extension; __module__ is 'itertools' (len=9); new to extra246"]
    - [cycle_module_len_9,
       cycle.__module__.__len__,
       [],
       9,
       "itertools.cycle.__module__.__len__() == 9 — 'itertools' has exactly 9 characters; str.__len__() returns 9; new to extra246"]
    - [cycle_bases0_object,
       "cycle.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.cycle.__bases__[0].__name__.__eq__('object') == True — cycle directly inherits from object; __bases__[0].__name__ is 'object'; new to extra246"]

# ---------------------------------------------------------------------------
# Table 4: itertools.cycle extra class checks
#
# itertools.cycle.__qualname__ == 'cycle'
# itertools.cycle.__class__.__name__ == 'type'
# itertools.cycle.__bases__[0].__module__ == 'builtins'
# itertools.cycle.__name__.__contains__('cycle') == True
# itertools.cycle.__module__.__contains__('iter') == True
#
# New to extra246.
# ---------------------------------------------------------------------------

table itertools_extra246.cycle246_extra:
  description: "itertools.cycle extra class checks: qualname, class type, name/module content; new to extra246"
  kind: python_call_eq
  category: identity
  id_prefix: cycle246b

  columns: [id, function, args, expected, description]
  rows:
    - [cycle_qualname_eq,
       cycle.__qualname__.__eq__,
       ["cycle"],
       true,
       "itertools.cycle.__qualname__.__eq__('cycle') == True — __qualname__ equals __name__ for a top-level class; 'cycle'; new to extra246"]
    - [cycle_class_is_type,
       cycle.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.cycle.__class__.__name__.__eq__('type') == True — cycle is a class so __class__ is 'type'; new to extra246"]
    - [cycle_bases0_module_builtins,
       "cycle.__bases__[0].__module__.__eq__",
       ["builtins"],
       true,
       "itertools.cycle.__bases__[0].__module__.__eq__('builtins') == True — object is defined in builtins; __bases__[0].__module__ is 'builtins'; new to extra246"]
    - [cycle_name_contains_cycle,
       cycle.__name__.__contains__,
       ["cycle"],
       true,
       "itertools.cycle.__name__.__contains__('cycle') == True — 'cycle' contains 'cycle'; new to extra246"]
    - [cycle_module_contains_iter,
       cycle.__module__.__contains__,
       ["iter"],
       true,
       "itertools.cycle.__module__.__contains__('iter') == True — 'itertools' contains 'iter'; new to extra246"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra246
# ---------------------------------------------------------------------------

invariant itertools_extra246.batched_name_eq:
  description: "itertools.batched.__name__ == 'batched' (len=7); new to extra246"
  kind: python_call_eq
  function: batched.__name__.__eq__
  args: ["batched"]
  expected: true

invariant itertools_extra246.batched_module_itertools:
  description: "itertools.batched.__module__ == 'itertools' — C extension class; new to extra246"
  kind: python_call_eq
  function: batched.__module__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra246.batched_bases0_object:
  description: "itertools.batched.__bases__[0].__name__ == 'object'; new to extra246"
  kind: python_call_eq
  function: "batched.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant itertools_extra246.batched_name_len_7:
  description: "itertools.batched.__name__.__len__() == 7; new to extra246"
  kind: python_call_eq
  function: batched.__name__.__len__
  args: []
  expected: 7

invariant itertools_extra246.cycle_name_eq:
  description: "itertools.cycle.__name__ == 'cycle' (len=5); new to extra246"
