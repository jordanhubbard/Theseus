spec: functools_extra631
version: ">=3.9"
backend: python_module(functools)
docs: "Deeper identity checks for functools.reduce, cmp_to_key, partial, WRAPPER_ASSIGNMENTS, and WRAPPER_UPDATES."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __qualname__, __doc__, __class__.__name__ identity for reduce, cmp_to_key, partial, and wrapper constants"
  created_at: "2026-04-12T00:00:00Z"

table functools_extra631.reduce_identity:
  description: "Identity checks for functools.reduce"
  kind: python_call_eq
  category: functools_reduce
  id_prefix: ft631ro
  columns: [id, function, args, expected]
  rows:
    - [ft631ro001, functools.reduce.__qualname__.__eq__, ["reduce"], true]
    - [ft631ro002, functools.reduce.__doc__.__class__.__name__.__eq__, ["str"], true]

table functools_extra631.cmp_to_key_identity:
  description: "Identity checks for functools.cmp_to_key"
  kind: python_call_eq
  category: functools_cmp_to_key
  id_prefix: ft631cm
  columns: [id, function, args, expected]
  rows:
    - [ft631cm001, functools.cmp_to_key.__qualname__.__eq__, ["cmp_to_key"], true]
    - [ft631cm002, functools.cmp_to_key.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [ft631cm003, functools.cmp_to_key.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

table functools_extra631.wrapper_constants_identity:
  description: "Identity checks for WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES length method qualname"
  kind: python_call_eq
  category: functools_wrapper_constants
  id_prefix: ft631wc
  columns: [id, function, args, expected]
  rows:
    - [ft631wc001, functools.WRAPPER_ASSIGNMENTS.__len__.__qualname__.__eq__, ["tuple.__len__"], true]
    - [ft631wc002, functools.WRAPPER_UPDATES.__len__.__qualname__.__eq__, ["tuple.__len__"], true]

table functools_extra631.partial_identity:
  description: "Identity checks for functools.partial special methods"
  kind: python_call_eq
  category: functools_partial
  id_prefix: ft631pa
  columns: [id, function, args, expected]
  rows:
    - [ft631pa001, functools.partial.__init__.__qualname__.__eq__, ["partial.__init__"], true]
    - [ft631pa002, functools.partial.__new__.__qualname__.__eq__, ["partial.__new__"], true]
    - [ft631pa003, functools.partial.__repr__.__qualname__.__eq__, ["partial.__repr__"], true]
    - [ft631pa004, functools.partial.__call__.__qualname__.__eq__, ["partial.__call__"], true]
    - [ft631pa005, functools.partial.__reduce__.__qualname__.__eq__, ["partial.__reduce__"], true]
