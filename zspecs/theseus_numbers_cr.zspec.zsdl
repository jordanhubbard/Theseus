spec: theseus_numbers_cr
version: ">=3.9"
backend: python_cleanroom(theseus_numbers_cr)
blocks: numbers

docs: https://docs.python.org/3/library/numbers.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/numbers.html"
  notes:
    - "Clean-room numeric tower ABCs. Do NOT import numbers."
    - "Number: abstract base for all numbers."
    - "Complex: abstract base for complex numbers (has real, imag)."
    - "Real: abstract base for real numbers."
    - "Integral: abstract base for integers."
    - "numbers_int_is_integral(): isinstance(42, Integral) == True."
    - "numbers_float_is_real(): isinstance(3.14, Real) == True."
    - "numbers_int_is_complex(): isinstance(1, Complex) == True."
    - "Export: Number, Complex, Real, Rational, Integral ABCs."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_numbers_cr.int_is_integral:
  description: "isinstance(42, Integral) == True"
  category: hierarchy
  kind: python_call_eq
  function: numbers_int_is_integral
  args: []
  expected: true

invariant theseus_numbers_cr.float_is_real:
  description: "isinstance(3.14, Real) == True"
  category: hierarchy
  kind: python_call_eq
  function: numbers_float_is_real
  args: []
  expected: true

invariant theseus_numbers_cr.int_is_complex:
  description: "isinstance(1, Complex) == True"
  category: hierarchy
  kind: python_call_eq
  function: numbers_int_is_complex
  args: []
  expected: true
