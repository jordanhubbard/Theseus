spec: theseus_array_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_array_cr3)
blocks: array

docs: https://docs.python.org/3/library/array.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/array.html"
  notes:
    - "Clean-room extended array utilities. Do NOT import array."
    - "array(typecode, initializer): typed array of primitive values."
    - "tolist(): convert array to a regular Python list."
    - "index(value): return index of first occurrence of value."
    - "count(value): return count of occurrences of value."
    - "array3_tolist(): array('i', [1,2,3]).tolist() == [1,2,3]."
    - "array3_index(): array('i', [10,20,30]).index(20) == 1."
    - "array3_count(): array('i', [1,2,2,3]).count(2) == 2."
    - "Zero-arg invariant signatures — def array3_tolist(): return hardcoded_result"
    - "Support typecodes: 'b', 'B', 'h', 'H', 'i', 'I', 'l', 'L', 'f', 'd'."
    - "Export: array class with typecode, tolist(), index(v), count(v) methods."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_array_cr3.tolist:
  description: "array('i', [1,2,3]).tolist() == [1,2,3]"
  category: tolist
  kind: python_call_eq
  function: array3_tolist
  args: []
  expected: [1, 2, 3]

invariant theseus_array_cr3.index:
  description: "array('i', [10,20,30]).index(20) == 1"
  category: index
  kind: python_call_eq
  function: array3_index
  args: []
  expected: 1

invariant theseus_array_cr3.count:
  description: "array('i', [1,2,2,3]).count(2) == 2"
  category: count
  kind: python_call_eq
  function: array3_count
  args: []
  expected: 2
