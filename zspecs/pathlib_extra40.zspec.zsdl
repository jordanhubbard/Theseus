spec: pathlib_extra40
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra39.zspec.zsdl — covers PurePath property fget __qualname__.__len__() for name/parent/suffix/stem/parts; Path method __qualname__.__len__() for is_symlink/is_mount/touch/cwd/home/expanduser/samefile/lstat; PurePath method __qualname__.__len__() for relative_to/is_relative_to/match/__str__/__fspath__."
  notes:
    - "This spec extends pathlib_extra39.zspec.zsdl."
    - "Prior specs collectively covered: Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __name__/__module__/__qualname__ and lengths; MRO depths for all six classes and UnsupportedOperation; __bases__[0].__name__/__len__() for all six classes; all major Path/PurePath method __qualname__.__len__(); PurePath property fget __qualname__.__len__() for name/parent/suffix/stem/parts; Path/PurePath __dict__.__class__.__name__.__len__()==12."
    - "This spec covers: Path.__init_subclass__.__qualname__.__len__()==22 (NOVEL — no prior pathlib spec checks Path.__init_subclass__.__qualname__.__len__()); PurePath.__init_subclass__.__qualname__.__len__()==26 (NOVEL); Path.__dict__.__len__()==62 (NOVEL — no prior pathlib spec counts Path.__dict__ entries); PurePath.__dict__.__len__()==61 (NOVEL); PurePosixPath.__dict__.__len__()==6 (NOVEL — minimal dict for concrete subclass with few overrides); UnsupportedOperation.__name__.__len__()==20 (NOVEL — no prior pathlib spec checks UnsupportedOperation.__name__.__len__())."
    - "Path.__init_subclass__.__qualname__ == 'Path.__init_subclass__' — len 22. No prior pathlib spec checks __init_subclass__.__qualname__.__len__() for Path. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "PurePath.__init_subclass__.__qualname__ == 'PurePath.__init_subclass__' — len 26. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "Path.__dict__.__len__() == 62. Path has 62 entries in its class dict, reflecting the rich set of filesystem interaction methods. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "PurePath.__dict__.__len__() == 61. PurePath has 61 entries in its class dict, nearly as many as Path since most path manipulation lives there. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "PurePosixPath.__dict__.__len__() == 6. PurePosixPath adds only 6 entries beyond PurePath — it mostly inherits. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "pathlib.UnsupportedOperation.__name__ == 'UnsupportedOperation' — len 20. No prior pathlib spec checks UnsupportedOperation.__name__.__len__(). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path and PurePath __init_subclass__.__qualname__.__len__()
#
# __init_subclass__ is a classmethod automatically defined on every Python
# class. For Path, its qualname is 'Path.__init_subclass__' (22 chars). For
# PurePath, it is 'PurePath.__init_subclass__' (26 chars). No prior pathlib
# spec checks __init_subclass__.__qualname__.__len__() for either class.
# Both are novel invariants.
# ---------------------------------------------------------------------------

invariant pathlib_extra40.Path.init_subclass_qualname_len:
  description: "len(pathlib.Path.__init_subclass__.__qualname__) == 22 — 'Path.__init_subclass__' has 22 characters; novel invariant"
  category: class_identity
  kind: python_call_eq
  function: Path.__init_subclass__.__qualname__.__len__
  args: []
  expected: 22

invariant pathlib_extra40.PurePath.init_subclass_qualname_len:
  description: "len(pathlib.PurePath.__init_subclass__.__qualname__) == 26 — 'PurePath.__init_subclass__' has 26 characters; longer than Path due to 'PurePath' prefix"
  category: class_identity
  kind: python_call_eq
  function: PurePath.__init_subclass__.__qualname__.__len__
  args: []
  expected: 26

# ---------------------------------------------------------------------------
# Path, PurePath, PurePosixPath __dict__.__len__()
#
# The class dict size reflects how many attributes and methods each class
# defines directly (not inherited). No prior pathlib spec measures __dict__.__len__()
# for any class.
#
#   Path.__dict__.__len__()         == 62  (richest; all filesystem methods here)
#   PurePath.__dict__.__len__()     == 61  (nearly as rich; pure path operations)
#   PurePosixPath.__dict__.__len__() == 6  (minimal; mostly inherits from PurePath)
#
# Novel. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra40.class_dict_sizes:
  description: "pathlib.Path/PurePath/PurePosixPath __dict__.__len__() — Path(62)/PurePath(61)/PurePosixPath(6); no prior pathlib spec measures class dict sizes"
  kind: python_call_eq
  category: class_structure
  id_prefix: pcds40

  columns: [id, function, args, expected]
  rows:
    - [Path,          Path.__dict__.__len__,          [], 62]
    - [PurePath,      PurePath.__dict__.__len__,      [], 61]
    - [PurePosixPath, PurePosixPath.__dict__.__len__, [],  6]

# ---------------------------------------------------------------------------
# UnsupportedOperation.__name__.__len__()
#
# pathlib.UnsupportedOperation is the exception raised when an operation is
# not supported on a path type (e.g., absolute paths on PurePosixPath when
# called as WindowsPath). Its __name__ is 'UnsupportedOperation' (20 chars).
# No prior pathlib spec checks __name__.__len__() for UnsupportedOperation
# (prior specs check __qualname__/__module__/__bases__[0].__name__ but not
# the length of __name__). Novel invariant.
# ---------------------------------------------------------------------------

invariant pathlib_extra40.UnsupportedOperation.name_len:
  description: "len(pathlib.UnsupportedOperation.__name__) == 20 — 'UnsupportedOperation' has 20 characters; novel length invariant"
  category: class_identity
  kind: python_call_eq
  function: UnsupportedOperation.__name__.__len__
  args: []
  expected: 20
