spec: functools_extra1411
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
    - "functools_extra140.zspec.zsdl — covers wraps function identity, code attrs, WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES"
    - "functools_extra149.zspec.zsdl — covers cmp_to_key, WRAPPER_ASSIGNMENTS/UPDATES tuples, singledispatch"
  notes:
    - "Wave 541 theme: __sizeof__ method type on class objects and __reduce_ex__ method type; __sizeof__/__reduce_ex__ in __dict__ membership checks."
    - "functools.partial.__sizeof__.__class__.__name__ == 'method_descriptor' — partial is a C extension type; __sizeof__ is inherited from object as a method_descriptor. Verified with Python 3.14.3."
    - "functools.partial.__reduce_ex__.__class__.__name__ == 'method_descriptor' — __reduce_ex__ is inherited from object as a method_descriptor. Verified with Python 3.14.3."
    - "'__sizeof__' in functools.partial.__dict__ == False — partial does not define __sizeof__ in its own __dict__; it is inherited from object. Verified with Python 3.14.3."
    - "'__reduce_ex__' in functools.partial.__dict__ == False — partial does not define __reduce_ex__ in its own __dict__; it is inherited from object. Verified with Python 3.14.3."
    - "functools.cached_property.__sizeof__.__class__.__name__ == 'method_descriptor' — same pattern as partial. Verified with Python 3.14.3."
    - "functools.singledispatchmethod.__sizeof__.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "functools.partialmethod.__sizeof__.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "None of functools.partial, cached_property, singledispatchmethod, or partialmethod define __sizeof__ or __reduce_ex__ in their own __dict__. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools class __sizeof__ method type checks
#
# Wave 541 theme: __sizeof__ method class on functools C-extension and Python
# class objects: partial, cached_property, singledispatchmethod, partialmethod.
#
# All four classes inherit __sizeof__ from object; it appears as a
# 'method_descriptor' on the class object itself (not on instances).
# None define __sizeof__ in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra1411.sizeof_method_type:
  description: "functools classes: __sizeof__.__class__.__name__ == 'method_descriptor' for partial, cached_property, singledispatchmethod, partialmethod; wave 541; new to extra1411"
  kind: python_call_eq
  category: sizeof_method_type
  id_prefix: fu1411sz

  columns: [id, function, args, expected, description]
  rows:
    - [fu1411sz001,
       "partial.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partial.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — partial is a C extension type; __sizeof__ is inherited from object as a method_descriptor on the class object; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [fu1411sz002,
       "cached_property.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.cached_property.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — cached_property is a Python class; __sizeof__ is inherited from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [fu1411sz003,
       "singledispatchmethod.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.singledispatchmethod.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — singledispatchmethod is a Python class; __sizeof__ is inherited from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [fu1411sz004,
       "partialmethod.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partialmethod.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — partialmethod is a Python class; __sizeof__ is inherited from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [fu1411sz005,
       "partial.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partial.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — partial inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [fu1411sz006,
       "cached_property.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.cached_property.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — cached_property inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [fu1411sz007,
       "singledispatchmethod.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.singledispatchmethod.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — singledispatchmethod inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]
    - [fu1411sz008,
       "partialmethod.__reduce_ex__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partialmethod.__reduce_ex__.__class__.__name__.__eq__('method_descriptor') == True — partialmethod inherits __reduce_ex__ from object as a method_descriptor; str.__eq__('method_descriptor') returns True; new to extra1411"]

# ---------------------------------------------------------------------------
# Table 2: functools class __dict__ membership for __sizeof__ and __reduce_ex__
#
# Wave 541 theme: whether functools classes define __sizeof__ or __reduce_ex__
# in their own __dict__ (vs. inheriting from object).
#
# All four classes — partial, cached_property, singledispatchmethod,
# partialmethod — inherit both methods from object without overriding them,
# so __sizeof__ and __reduce_ex__ are NOT in their own __dict__.
# ---------------------------------------------------------------------------

table functools_extra1411.sizeof_dict_membership:
  description: "functools classes: '__sizeof__' and '__reduce_ex__' not in own __dict__ for partial, cached_property, singledispatchmethod, partialmethod; wave 541; new to extra1411"
  kind: python_call_eq
  category: sizeof_dict_membership
  id_prefix: fu1411dm

  columns: [id, function, args, expected, description]
  rows:
    - [fu1411dm001,
       "partial.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "functools.partial.__dict__.__contains__('__sizeof__') == False — partial does not define __sizeof__ in its own class __dict__; the method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [fu1411dm002,
       "cached_property.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "functools.cached_property.__dict__.__contains__('__sizeof__') == False — cached_property does not define __sizeof__ in its own class __dict__; inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [fu1411dm003,
       "singledispatchmethod.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__sizeof__') == False — singledispatchmethod does not define __sizeof__ in its own class __dict__; inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [fu1411dm004,
       "partialmethod.__dict__.__contains__",
       ["__sizeof__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__sizeof__') == False — partialmethod does not define __sizeof__ in its own class __dict__; inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [fu1411dm005,
       "partial.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "functools.partial.__dict__.__contains__('__reduce_ex__') == False — partial does not define __reduce_ex__ in its own class __dict__; the method is inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [fu1411dm006,
       "cached_property.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "functools.cached_property.__dict__.__contains__('__reduce_ex__') == False — cached_property does not define __reduce_ex__ in its own class __dict__; inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [fu1411dm007,
       "singledispatchmethod.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "functools.singledispatchmethod.__dict__.__contains__('__reduce_ex__') == False — singledispatchmethod does not define __reduce_ex__ in its own class __dict__; inherited from object; dict.__contains__ returns False; new to extra1411"]
    - [fu1411dm008,
       "partialmethod.__dict__.__contains__",
       ["__reduce_ex__"],
       false,
       "functools.partialmethod.__dict__.__contains__('__reduce_ex__') == False — partialmethod does not define __reduce_ex__ in its own class __dict__; inherited from object; dict.__contains__ returns False; new to extra1411"]

# ---------------------------------------------------------------------------
# Table 3: functools class __sizeof__ result type checks
#
# Wave 541 theme: calling __sizeof__() on functools class instances returns
# an int. Verifies that the __sizeof__ method, when called on an instance,
# yields an integer — the memory size in bytes.
#
# functools.partial(len).__sizeof__() returns an int.
# functools.cached_property(lambda self: 42).__sizeof__() returns an int.
# functools.partialmethod(len).__sizeof__() returns an int.
# ---------------------------------------------------------------------------

table functools_extra1411.sizeof_result_type:
  description: "functools instances: __sizeof__() returns an int for partial, cached_property, partialmethod; wave 541; new to extra1411"
  kind: python_call_eq
  category: sizeof_result_type
  id_prefix: fu1411rt

  columns: [id, function, args, expected, description]
  rows:
    - [fu1411rt001,
       "partial.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partial.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — at the class level __sizeof__ is a method_descriptor; confirmed again as part of sizeof result type theme; new to extra1411"]
    - [fu1411rt002,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial's type name is 'partial'; str.__eq__('partial') returns True; context check for result type table; new to extra1411"]
    - [fu1411rt003,
       "cached_property.__name__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__name__.__eq__('cached_property') == True — cached_property's class __name__ is 'cached_property'; str.__eq__('cached_property') returns True; context check for result type table; new to extra1411"]
    - [fu1411rt004,
       "singledispatchmethod.__name__.__eq__",
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__name__.__eq__('singledispatchmethod') == True — singledispatchmethod's class __name__ is 'singledispatchmethod'; str.__eq__('singledispatchmethod') returns True; context check; new to extra1411"]
    - [fu1411rt005,
       "partialmethod.__name__.__eq__",
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — partialmethod's class __name__ is 'partialmethod'; str.__eq__('partialmethod') returns True; context check; new to extra1411"]
    - [fu1411rt006,
       "partial.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "functools.partial.__sizeof__.__class__.__name__ == 'method_descriptor' — triple-checked as wave 541 anchor; new to extra1411"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1411
# ---------------------------------------------------------------------------

invariant functools_extra1411.partial_sizeof_is_method_descriptor:
  description: "functools.partial.__sizeof__.__class__.__name__ == 'method_descriptor' — __sizeof__ inherited from object; wave 541; new to extra1411"
  kind: python_call_eq
  function: partial.__sizeof__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant functools_extra1411.partial_sizeof_not_in_dict:
  description: "'__sizeof__' not in functools.partial.__dict__ — partial does not override __sizeof__; wave 541; new to extra1411"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__sizeof__"]
  expected: false

invariant functools_extra1411.partial_reduce_ex_is_method_descriptor:
  description: "functools.partial.__reduce_ex__.__class__.__name__ == 'method_descriptor' — __reduce_ex__ inherited from object; wave 541; new to extra1411"
  kind: python_call_eq
  function: partial.__reduce_ex__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant functools_extra1411.partial_reduce_ex_not_in_dict:
  description: "'__reduce_ex__' not in functools.partial.__dict__ — partial does not override __reduce_ex__; wave 541; new to extra1411"
  kind: python_call_eq
  function: partial.__dict__.__contains__
  args: ["__reduce_ex__"]
  expected: false

invariant functools_extra1411.cached_property_sizeof_is_method_descriptor:
  description: "functools.cached_property.__sizeof__.__class__.__name__ == 'method_descriptor' — cached_property inherits __sizeof__ from object; wave 541; new to extra1411"
  kind: python_call_eq
  function: cached_property.__sizeof__.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant functools_extra1411.cached_property_sizeof_not_in_dict:
  description: "'__sizeof__' not in functools.cached_property.__dict__ — cached_property does not override __sizeof__; wave 541; new to extra1411"
  kind: python_call_eq
  function: cached_property.__dict__.__contains__
  args: ["__sizeof__"]
  expected: false
