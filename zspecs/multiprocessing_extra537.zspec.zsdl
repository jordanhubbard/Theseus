spec: multiprocessing_extra537
version: ">=3.9"
backend: python_module(multiprocessing.synchronize)
docs: "multiprocessing.synchronize module class identity checks"
provenance:
  derived_from:
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"
error_model: strict

table multiprocessing_extra537.class_names:
  description: "multiprocessing.synchronize class __name__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: mpname
  columns: [id, function, args, expected]
  rows:
    - [mpname001, multiprocessing.synchronize.Semaphore.__name__.__eq__, ["Semaphore"], true]
    - [mpname002, multiprocessing.synchronize.BoundedSemaphore.__name__.__eq__, ["BoundedSemaphore"], true]
    - [mpname003, multiprocessing.synchronize.Lock.__name__.__eq__, ["Lock"], true]
    - [mpname004, multiprocessing.synchronize.RLock.__name__.__eq__, ["RLock"], true]
    - [mpname005, multiprocessing.synchronize.Event.__name__.__eq__, ["Event"], true]
    - [mpname006, multiprocessing.synchronize.Condition.__name__.__eq__, ["Condition"], true]
    - [mpname007, multiprocessing.synchronize.Barrier.__name__.__eq__, ["Barrier"], true]

table multiprocessing_extra537.class_modules:
  description: "multiprocessing.synchronize class __module__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: mpmod
  columns: [id, function, args, expected]
  rows:
    - [mpmod001, multiprocessing.synchronize.Semaphore.__module__.__eq__, ["multiprocessing.synchronize"], true]
    - [mpmod002, multiprocessing.synchronize.Lock.__module__.__eq__, ["multiprocessing.synchronize"], true]

invariant multiprocessing_extra537.semaphore_base_name:
  description: "Semaphore first base class is named SemLock"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__"
  args: ["SemLock"]
  expected: true
