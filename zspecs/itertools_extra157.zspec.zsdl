spec: itertools_extra157
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.product.__doc__.__len__() 681; itertools.combinations_with_replacement.__doc__.__len__() 234; itertools.combinations.__doc__.__len__() 134; itertools.permutations.__doc__.__len__() 140; itertools.chain.__doc__.__len__() 190; ordering comparisons: product doc > combinations doc, combinations_with_replacement doc > combinations doc, chain doc > permutations doc (Wave 286)."
    - "itertools.product.__doc__.__len__() == 681 — the product type docstring is 681 characters; it describes the Cartesian product of input iterables. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__doc__.__len__() == 234 — the combinations_with_replacement type docstring is 234 characters. Verified with Python 3.14.3."
    - "itertools.combinations.__doc__.__len__() == 134 — the combinations type docstring is 134 characters. Verified with Python 3.14.3."
    - "itertools.permutations.__doc__.__len__() == 140 — the permutations type docstring is 140 characters. Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__len__() == 190 — the chain type docstring is 190 characters. Verified with Python 3.14.3."
    - "itertools.product.__doc__.__len__() > itertools.combinations.__doc__.__len__() == True — product (681) has a longer docstring than combinations (134). Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__doc__.__len__() > itertools.combinations.__doc__.__len__() == True — combinations_with_replacement (234) > combinations (134). Verified with Python 3.14.3."
    - "itertools.chain.__doc__.__len__() > itertools.permutations.__doc__.__len__() == True — chain (190) > permutations (140). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools product and combinations_with_replacement doc lengths
#
# Wave 286 theme: itertools combinatoric iterator type docstring lengths.
#
# itertools.product.__doc__.__len__() == 681
# itertools.combinations_with_replacement.__doc__.__len__() == 234
# itertools.combinations.__doc__.__len__() == 134
# itertools.permutations.__doc__.__len__() == 140
#
# All four combinatoric iterator types are C extension types defined in
# itertoolsmodule.c. product has the longest docstring (681) as it describes
# the Cartesian product behavior and repeating. combinations_with_replacement
# (234) has a longer docstring than plain combinations (134). permutations (140)
# is slightly longer than combinations. New to extra157.
# ---------------------------------------------------------------------------

table itertools_extra157.combinatoric_doc_lengths:
  description: "itertools combinatoric doc lengths: product 681, combinations_with_replacement 234, combinations 134, permutations 140; wave 286; new to extra157"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscdl157

  columns: [id, function, args, expected, description]
  rows:
    - [product_doc_len_eq_681,
       "product.__doc__.__len__",
       [],
       681,
       "itertools.product.__doc__.__len__() == 681 — the product C extension type docstring is 681 characters; it describes the Cartesian product of input iterables, equivalent to nested for-loops, with optional repeat argument; str.__len__() returns 681; new to extra157"]
    - [combinations_with_replacement_doc_len_eq_234,
       "combinations_with_replacement.__doc__.__len__",
       [],
       234,
       "itertools.combinations_with_replacement.__doc__.__len__() == 234 — the combinations_with_replacement C extension type docstring is 234 characters; it describes returning combinations allowing individual elements to be repeated more than once; str.__len__() returns 234; new to extra157"]
    - [combinations_doc_len_eq_134,
       "combinations.__doc__.__len__",
       [],
       134,
       "itertools.combinations.__doc__.__len__() == 134 — the combinations C extension type docstring is 134 characters; it describes returning r-length tuples of elements from the input iterable without replacement; str.__len__() returns 134; new to extra157"]
    - [permutations_doc_len_eq_140,
       "permutations.__doc__.__len__",
       [],
       140,
       "itertools.permutations.__doc__.__len__() == 140 — the permutations C extension type docstring is 140 characters; it describes returning successive r-length permutations of elements from the iterable; str.__len__() returns 140; new to extra157"]

# ---------------------------------------------------------------------------
# Table 2: itertools chain doc length and ordering comparisons
#
# Wave 286 theme: itertools chain docstring length and doc length ordering
# comparisons between combinatoric types.
#
# itertools.chain.__doc__.__len__() == 190
# itertools.product.__doc__.__len__() > itertools.combinations.__doc__.__len__()
# itertools.combinations_with_replacement.__doc__.__len__() > itertools.combinations.__doc__.__len__()
# itertools.chain.__doc__.__len__() > itertools.permutations.__doc__.__len__()
#
# chain is a core itertools type that chains multiple iterables end-to-end.
# Its docstring length (190) sits between permutations (140) and
# combinations_with_replacement (234). The ordering comparisons validate
# relative lengths of the combinatoric type docstrings. New to extra157.
# ---------------------------------------------------------------------------

table itertools_extra157.chain_doc_len_and_ordering:
  description: "itertools.chain doc len 190; product doc > combinations doc; combinations_with_replacement doc > combinations doc; chain doc > permutations doc; wave 286; new to extra157"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscdlo157

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_len_eq_190,
       "chain.__doc__.__len__",
       [],
       190,
       "itertools.chain.__doc__.__len__() == 190 — the chain C extension type docstring is 190 characters; it describes chaining multiple iterables end-to-end into a single iterator; str.__len__() returns 190; new to extra157"]
    - [product_doc_gt_combinations_doc,
       "product.__doc__.__len__().__gt__",
       [134],
       true,
       "itertools.product.__doc__.__len__() > itertools.combinations.__doc__.__len__() == True — product docstring (681) is longer than combinations docstring (134); int.__gt__(134) called on 681 returns True; product describes Cartesian products with more detail; new to extra157"]
    - [combinations_with_replacement_doc_gt_combinations_doc,
       "combinations_with_replacement.__doc__.__len__().__gt__",
       [134],
       true,
       "itertools.combinations_with_replacement.__doc__.__len__() > itertools.combinations.__doc__.__len__() == True — combinations_with_replacement (234) > combinations (134); combinations_with_replacement has a longer docstring than plain combinations; int.__gt__(134) called on 234 returns True; new to extra157"]
    - [chain_doc_gt_permutations_doc,
       "chain.__doc__.__len__().__gt__",
       [140],
       true,
       "itertools.chain.__doc__.__len__() > itertools.permutations.__doc__.__len__() == True — chain docstring (190) is longer than permutations docstring (140); int.__gt__(140) called on 190 returns True; new to extra157"]

