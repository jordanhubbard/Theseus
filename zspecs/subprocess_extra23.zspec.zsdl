spec: subprocess_extra23
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
    - "subprocess_extra.zspec.zsdl — covers PIPE/STDOUT/DEVNULL __class__.__name__ == 'int' (eq form); NOT __class__.__name__.__len__()."
    - "subprocess_extra15.zspec.zsdl — covers __qualname__.__len__() for CompletedProcess/CalledProcessError/TimeoutExpired/run/call/check_output; NOT check_call.__qualname__.__len__()."
    - "subprocess_extra22.zspec.zsdl — covers Popen method __qualname__.__len__() and __name__.__len__() for __init__/communicate/wait/poll/kill/terminate; NOT module-level class __dict__.__class__.__name__.__len__()."
  notes:
    - "This spec extends subprocess_extra22.zspec.zsdl."
    - "No prior spec covers: subprocess.__all__.__len__() == 14 — the module exports 14 public names."
    - "No prior spec covers: subprocess.__all__.__class__.__name__.__len__() == 4 — __all__ is a list (len('list')==4)."
    - "No prior spec covers: Popen.__dict__.__class__.__name__.__len__() == 12 — __dict__ is a mappingproxy."
    - "No prior spec covers: CompletedProcess.__dict__.__class__.__name__.__len__() == 12 — same mappingproxy pattern."
    - "No prior spec covers: CalledProcessError.__dict__.__class__.__name__.__len__() == 12 — same mappingproxy pattern."
    - "No prior spec covers: TimeoutExpired.__dict__.__class__.__name__.__len__() == 12 — same mappingproxy pattern."
    - "No prior spec covers: CalledProcessError.__bases__[0].__name__.__len__() == 15 — 'SubprocessError' has 15 characters. NOTE: the task description suggested 14 but actual value is 15."
    - "No prior spec covers: TimeoutExpired.__bases__[0].__name__.__len__() == 15 — 'SubprocessError' has 15 characters. Same correction as above."
    - "No prior spec covers: SubprocessError.__bases__[0].__name__.__len__() == 9 — 'Exception' has 9 characters."
    - "No prior spec covers: PIPE.__class__.__name__.__len__() == 3 — PIPE is an int; 'int' has 3 characters."
    - "No prior spec covers: STDOUT.__class__.__name__.__len__() == 3 — same int pattern."
    - "No prior spec covers: DEVNULL.__class__.__name__.__len__() == 3 — same int pattern."
    - "No prior spec covers: check_call.__qualname__.__len__() == 10 — subprocess_extra15 covers run/call/check_output but not check_call qualname length."
    - "Verified: subprocess.__all__.__len__() == 14."
    - "Verified: subprocess.__all__.__class__.__name__ == 'list'; len == 4."
    - "Verified: Popen/CompletedProcess/CalledProcessError/TimeoutExpired __dict__.__class__.__name__ == 'mappingproxy'; len == 12."
    - "Verified: CalledProcessError.__bases__[0].__name__ == 'SubprocessError'; len == 15 (NOT 14 as the task description suggested)."
    - "Verified: TimeoutExpired.__bases__[0].__name__ == 'SubprocessError'; len == 15."
    - "Verified: SubprocessError.__bases__[0].__name__ == 'Exception'; len == 9."
    - "Verified: PIPE/STDOUT/DEVNULL.__class__.__name__ == 'int'; len == 3."
    - "Verified: check_call.__qualname__ == 'check_call'; len == 10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# subprocess.__all__ length and class name
#
# No prior subprocess spec checks __all__.__len__() or __all__.__class__.__name__.__len__().
# subprocess.__all__ has 14 entries. __class__.__name__ == 'list' (len 4).
# ---------------------------------------------------------------------------

invariant subprocess_extra23.all.len:
  description: "subprocess.__all__.__len__() == 14 — the module exports 14 public names"
  category: module_attrs
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 14

invariant subprocess_extra23.all.class_name_len:
  description: "subprocess.__all__.__class__.__name__.__len__() == 4 — __all__ is a list; 'list' has 4 characters"
  category: module_attrs
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# __dict__.__class__.__name__.__len__() for key subprocess classes
#
# All Python classes store their namespace in a mappingproxy object.
# len('mappingproxy') == 12. No prior subprocess spec checks this on any class.
# ---------------------------------------------------------------------------

table subprocess_extra23.dict_class_name_len:
  description: "Popen/CompletedProcess/CalledProcessError/TimeoutExpired __dict__.__class__.__name__.__len__() == 12"
  kind: python_call_eq
  category: class_attrs
  id_prefix: dcnlen23

  columns: [id, function, args, expected]
  rows:
    - [Popen,               Popen.__dict__.__class__.__name__.__len__,               [], 12]
    - [CompletedProcess,    CompletedProcess.__dict__.__class__.__name__.__len__,    [], 12]
    - [CalledProcessError,  CalledProcessError.__dict__.__class__.__name__.__len__,  [], 12]
    - [TimeoutExpired,      TimeoutExpired.__dict__.__class__.__name__.__len__,      [], 12]

# ---------------------------------------------------------------------------
# Exception base class name lengths
#
# No prior subprocess spec checks __bases__[0].__name__.__len__() for any class.
# CalledProcessError.__bases__[0].__name__ == 'SubprocessError' (len 15).
# TimeoutExpired.__bases__[0].__name__ == 'SubprocessError' (len 15).
# SubprocessError.__bases__[0].__name__ == 'Exception' (len 9).
# NOTE: The task description suggested len 14 for SubprocessError, but the
# actual length is 15: len('SubprocessError') == 15. Verified with Python.
# Function paths contain '[' and MUST be quoted.
# ---------------------------------------------------------------------------

invariant subprocess_extra23.CalledProcessError.base_name_len:
  description: "subprocess.CalledProcessError.__bases__[0].__name__.__len__() == 15 — 'SubprocessError' has 15 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "CalledProcessError.__bases__[0].__name__.__len__"
  args: []
  expected: 15

invariant subprocess_extra23.TimeoutExpired.base_name_len:
  description: "subprocess.TimeoutExpired.__bases__[0].__name__.__len__() == 15 — 'SubprocessError' has 15 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "TimeoutExpired.__bases__[0].__name__.__len__"
  args: []
  expected: 15

invariant subprocess_extra23.SubprocessError.base_name_len:
  description: "subprocess.SubprocessError.__bases__[0].__name__.__len__() == 9 — 'Exception' has 9 characters"
  category: class_hierarchy
  kind: python_call_eq
  function: "SubprocessError.__bases__[0].__name__.__len__"
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# PIPE/STDOUT/DEVNULL __class__.__name__.__len__() == 3
#
# subprocess_extra.zspec.zsdl covers PIPE/STDOUT/DEVNULL __class__.__name__ == 'int'
# via __eq__ (boolean form). No prior spec checks __class__.__name__.__len__().
# len('int') == 3. This is the length-axis complement to the equality checks.
# ---------------------------------------------------------------------------

table subprocess_extra23.sentinel_class_name_len:
  description: "PIPE/STDOUT/DEVNULL __class__.__name__.__len__() == 3 — all are int; 'int' has 3 characters"
  kind: python_call_eq
  category: constants
  id_prefix: scnlen23

  columns: [id, function, args, expected]
  rows:
    - [PIPE,    PIPE.__class__.__name__.__len__,    [], 3]
    - [STDOUT,  STDOUT.__class__.__name__.__len__,  [], 3]
    - [DEVNULL, DEVNULL.__class__.__name__.__len__, [], 3]

# ---------------------------------------------------------------------------
# check_call.__qualname__.__len__() == 10
#
# subprocess_extra15 covers run/call/check_output qualname lengths (3, 4, 12).
# No prior subprocess spec covers check_call.__qualname__.__len__().
# check_call.__qualname__ == 'check_call' (len 10).
# ---------------------------------------------------------------------------

invariant subprocess_extra23.check_call.qualname_len:
  description: "subprocess.check_call.__qualname__.__len__() == 10 — 'check_call' has 10 characters"
  category: function_attrs
  kind: python_call_eq
  function: check_call.__qualname__.__len__
  args: []
  expected: 10
