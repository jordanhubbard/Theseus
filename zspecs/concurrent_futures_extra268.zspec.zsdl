spec: concurrent_futures_extra268
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "concurrent.futures.__spec__.name == 'concurrent.futures' and __spec__.parent == 'concurrent.futures'."
    - "concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec' (importlib.machinery.ModuleSpec)."
    - "concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader'."
    - "concurrent.__spec__.name == 'concurrent' and __spec__.parent == 'concurrent'."
    - "concurrent.__loader__.__class__.__name__ == 'SourceFileLoader'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures module __spec__ and __package__ identity — table
#
# Module-level attributes: __name__, __package__, __spec__.name, loader class.
# ---------------------------------------------------------------------------

table concurrent_futures_extra268.cf_module_identity:
  description: "concurrent.futures module __name__, __package__, and __spec__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: cfmod

  columns: [id, function, args, expected, description]
  rows:
    - [cf_name,       __name__.__eq__,                       ["concurrent.futures"],   true, "concurrent.futures.__name__ == 'concurrent.futures'"]
    - [cf_package,    __package__.__eq__,                    ["concurrent.futures"],   true, "concurrent.futures.__package__ == 'concurrent.futures'"]
    - [cf_spec_name,  __spec__.name.__eq__,                  ["concurrent.futures"],   true, "concurrent.futures.__spec__.name == 'concurrent.futures'"]
    - [cf_spec_cls,   __spec__.__class__.__name__.__eq__,    ["ModuleSpec"],           true, "concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec'"]
    - [cf_loader_cls, __loader__.__class__.__name__.__eq__,  ["SourceFileLoader"],     true, "concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader'"]

# ---------------------------------------------------------------------------
# concurrent package identity — table
#
# Parent package attributes: __name__, __package__, __spec__.name, loader class.
# ---------------------------------------------------------------------------

table concurrent_futures_extra268.concurrent_pkg_identity:
  description: "concurrent package __name__, __package__, and __spec__ identity"
  kind: python_call_eq
  category: identity
  id_prefix: cpkg

  columns: [id, function, args, expected, description]
  rows:
    - [c_name,        concurrent.__name__.__eq__,                      ["concurrent"],  true, "concurrent.__name__ == 'concurrent'"]
    - [c_package,     concurrent.__package__.__eq__,                   ["concurrent"],  true, "concurrent.__package__ == 'concurrent'"]
    - [c_spec_name,   concurrent.__spec__.name.__eq__,                 ["concurrent"],  true, "concurrent.__spec__.name == 'concurrent'"]
    - [c_loader_cls,  concurrent.__loader__.__class__.__name__.__eq__, ["SourceFileLoader"], true, "concurrent.__loader__.__class__.__name__ == 'SourceFileLoader'"]
    - [c_spec_cls,    concurrent.__spec__.__class__.__name__.__eq__,   ["ModuleSpec"],  true, "concurrent.__spec__.__class__.__name__ == 'ModuleSpec'"]

# ---------------------------------------------------------------------------
# concurrent.futures.__spec__.parent — standalone invariant
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra268.cf_spec_parent:
  description: "concurrent.futures.__spec__.parent == 'concurrent.futures'"
  category: identity
  kind: python_call_eq
  function: __spec__.parent.__eq__
  args: ["concurrent.futures"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent.__spec__.parent — standalone invariant
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra268.concurrent_spec_parent:
  description: "concurrent.__spec__.parent == 'concurrent'"
  category: identity
  kind: python_call_eq
  function: concurrent.__spec__.parent.__eq__
  args: ["concurrent"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent package __spec__.__class__ is ModuleSpec — standalone invariant
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra268.concurrent_spec_qualname:
  description: "concurrent.__spec__.__class__.__qualname__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: concurrent.__spec__.__class__.__qualname__.__eq__
  args: ["ModuleSpec"]
  expected: true
