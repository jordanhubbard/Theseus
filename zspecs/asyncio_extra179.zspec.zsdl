# asyncio.StreamReader.__module__ == 'asyncio.streams'
# asyncio.StreamReader.__mro__.__len__() == 2  (StreamReader > object)
#
# StreamReader is defined in asyncio.streams and inherits directly from object.
# New to extra179.
# ---------------------------------------------------------------------------

table asyncio_extra179.streamreader_identity:
  description: "asyncio.StreamReader.__name__ 'StreamReader' len 12; __module__ 'asyncio.streams'; __mro__.__len__()==2; new to extra179"
  kind: python_call_eq
  category: identity
  id_prefix: asynciostreams179

  columns: [id, function, args, expected, description]
  rows:
    - [sr_name_eq,
       StreamReader.__name__.__eq__,
       ["StreamReader"],
       true,
       "asyncio.StreamReader.__name__.__eq__('StreamReader') == True — asyncio.StreamReader is the read side of an async stream connection; its __name__ is 'StreamReader' (12 chars: S-t-r-e-a-m-R-e-a-d-e-r); str.__eq__('StreamReader') returns True; new to extra179"]
    - [sr_name_len_12,
       StreamReader.__name__.__len__,
