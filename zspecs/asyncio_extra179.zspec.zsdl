       12,
       "asyncio.StreamReader.__name__.__len__() == 12 — 'StreamReader' has 12 characters: S-t-r-e-a-m-R-e-a-d-e-r; same length as 'StreamWriter'=12 and 'start_server'=12; str.__len__() returns 12; new to extra179"]
    - [sr_module_eq,
       StreamReader.__module__.__eq__,
       ["asyncio.streams"],
       true,
       "asyncio.StreamReader.__module__.__eq__('asyncio.streams') == True — StreamReader is defined in the asyncio.streams submodule, not in asyncio.__init__; its __module__ is 'asyncio.streams'; str.__eq__('asyncio.streams') returns True; new to extra179"]
    - [sr_mro_len_2,
       StreamReader.__mro__.__len__,
       [],
       2,
       "asyncio.StreamReader.__mro__.__len__() == 2 — MRO is [StreamReader, object]; StreamReader is a direct subclass of object with no intermediate base classes; __mro__.__len__() returns 2; new to extra179"]
    - [sr_module_len,
       StreamReader.__module__.__len__,
       [],
       15,
       "asyncio.StreamReader.__module__.__len__() == 15 — 'asyncio.streams' has 15 characters: asyncio=7 + '.'=1 + streams=7 = 15; str.__len__() returns 15; new to extra179"]

