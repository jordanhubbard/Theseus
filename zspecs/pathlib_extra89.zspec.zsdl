spec: pathlib_extra89
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec extends all prior pathlib specs through pathlib_extra88."
    - "Prior specs covered: PurePath/Path class identity; Path method __name__/__qualname__; Path MRO; Path.__code__ attributes for many methods; PurePath/__dict__ membership; Path/__dict__ membership; Path properties as descriptors; Path method co_name and co_argcount for open/read_text/write_text/iterdir/mkdir/rmdir/stat/lstat/exists/unlink/rename/resolve/absolute/expanduser; PurePath/__name__/__module__/__bases__/__mro__; PosixPath identity; Path.__init__/__new__ co_name and co_argcount; Path.is_dir/is_file/is_symlink/is_mount/is_absolute/is_relative_to/exists/samefile __code__ attributes."
    - "This spec covers: pathlib.Path.__dict__.__contains__ for 'read_text', 'write_text', 'read_bytes', 'write_bytes' (all True); pathlib.Path.__dict__.__contains__ for 'mkdir', 'iterdir', 'glob', 'exists' (all True); pathlib.Path.__dict__.__contains__ for 'is_dir' and 'stat' (True); pathlib.Path.__dict__.__class__.__name__; pathlib.Path.__qualname__; pathlib.Path.__name__; pathlib.Path.__module__; pathlib.Path.__qualname__.__len__(); pathlib.Path.__name__.__len__(); pathlib.Path.__module__.__len__()."
    - "pathlib.Path.__dict__.__contains__('read_text') == True — 'read_text' is defined directly on Path."
    - "pathlib.Path.__dict__.__contains__('write_text') == True — 'write_text' is defined directly on Path."
    - "pathlib.Path.__dict__.__contains__('read_bytes') == True — 'read_bytes' is defined directly on Path."
    - "pathlib.Path.__dict__.__contains__('write_bytes') == True — 'write_bytes' is defined directly on Path."
    - "pathlib.Path.__dict__.__contains__('mkdir') == True — 'mkdir' is defined directly on Path."
    - "pathlib.Path.__dict__.__contains__('iterdir') == True — 'iterdir' is defined directly on Path."
    - "pathlib.Path.__dict__.__contains__('glob') == True — 'glob' is defined directly on Path."
    - "pathlib.Path.__dict__.__contains__('exists') == True — 'exists' is defined directly on Path."
    - "pathlib.Path.__dict__.__contains__('is_dir') == True — 'is_dir' is defined directly on Path."
    - "pathlib.Path.__dict__.__contains__('stat') == True — 'stat' is defined directly on Path."
    - "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy' — as expected for any type's __dict__."
    - "pathlib.Path.__qualname__ == 'Path' — length 4."
    - "pathlib.Path.__name__ == 'Path' — length 4."
    - "pathlib.Path.__module__ == 'pathlib' — length 7."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ membership for read/write methods
# 'read_text', 'write_text', 'read_bytes', 'write_bytes' are all defined directly on Path.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra89.Path_dict_rw_methods:
  description: "pathlib.Path.__dict__.__contains__ for 'read_text', 'write_text', 'read_bytes', 'write_bytes' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibextra89

  columns: [id, function, args, expected]
  rows:
    - [dict_read_text,   Path.__dict__.__contains__, ["read_text"],   true]
    - [dict_write_text,  Path.__dict__.__contains__, ["write_text"],  true]
    - [dict_read_bytes,  Path.__dict__.__contains__, ["read_bytes"],  true]
    - [dict_write_bytes, Path.__dict__.__contains__, ["write_bytes"], true]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ membership for traversal/query methods
# 'mkdir', 'iterdir', 'glob', 'exists' are all defined directly on Path.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra89.Path_dict_traversal_methods:
  description: "pathlib.Path.__dict__.__contains__ for 'mkdir', 'iterdir', 'glob', 'exists' (all True)"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibextra89

  columns: [id, function, args, expected]
  rows:
    - [dict_mkdir,   Path.__dict__.__contains__, ["mkdir"],   true]
    - [dict_iterdir, Path.__dict__.__contains__, ["iterdir"], true]
    - [dict_glob,    Path.__dict__.__contains__, ["glob"],    true]
    - [dict_exists,  Path.__dict__.__contains__, ["exists"],  true]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ membership for is_dir/stat, plus __dict__ class name
# 'is_dir' and 'stat' are defined directly on Path.
# __dict__.__class__.__name__ == 'mappingproxy'.
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra89.Path_dict_isdir_stat_and_class:
  description: "pathlib.Path.__dict__.__contains__ for 'is_dir' and 'stat'; __dict__.__class__.__name__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: pathlibextra89

  columns: [id, function, args, expected]
  rows:
    - [dict_is_dir,    Path.__dict__.__contains__,            ["is_dir"],       true]
    - [dict_stat,      Path.__dict__.__contains__,            ["stat"],         true]
    - [dict_cls_name,  Path.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [path_qualname,  Path.__qualname__.__eq__,              ["Path"],         true]

# ---------------------------------------------------------------------------
# pathlib.Path class identity: __qualname__, __name__, __module__ and their lengths
# Path.__qualname__ == Path.__name__ == 'Path' (len 4); __module__ == 'pathlib' (len 7).
# Not covered in any prior pathlib spec at this specific table.
# ---------------------------------------------------------------------------

table pathlib_extra89.Path_identity:
  description: "pathlib.Path.__qualname__, __name__, __module__ values and lengths"
  kind: python_call_eq
  category: class_identity
  id_prefix: pathlibextra89

  columns: [id, function, args, expected]
  rows:
    - [path_name,       Path.__name__.__eq__,        ["Path"],    true]
    - [path_module,     Path.__module__.__eq__,       ["pathlib"], true]
    - [path_qn_len,     Path.__qualname__.__len__,   [],          4]
    - [path_module_len, Path.__module__.__len__,     [],          7]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra89.Path_dict.contains_read_text:
  description: "pathlib.Path.__dict__.__contains__('read_text') == True"
  category: dict_membership
  kind: python_call_eq
  function: Path.__dict__.__contains__
  args: ["read_text"]
  expected: true

invariant pathlib_extra89.Path_dict.contains_mkdir:
  description: "pathlib.Path.__dict__.__contains__('mkdir') == True"
  category: dict_membership
  kind: python_call_eq
  function: Path.__dict__.__contains__
  args: ["mkdir"]
  expected: true

invariant pathlib_extra89.Path_dict.class_name:
  description: "pathlib.Path.__dict__.__class__.__name__ == 'mappingproxy'"
  category: dict_membership
  kind: python_call_eq
  function: Path.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant pathlib_extra89.Path.qualname:
  description: "pathlib.Path.__qualname__ == 'Path' (length 4)"
  category: class_identity
  kind: python_call_eq
  function: Path.__qualname__.__eq__
  args: ["Path"]
  expected: true

invariant pathlib_extra89.Path.module:
  description: "pathlib.Path.__module__ == 'pathlib' (length 7)"
  category: class_identity
  kind: python_call_eq
  function: Path.__module__.__eq__
  args: ["pathlib"]
  expected: true
