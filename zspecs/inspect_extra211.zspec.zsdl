spec: inspect_extra211
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
    - "inspect_extra.zspec.zsdl — covers ismethod/isgenerator/iscoroutine/getsourcefile __name__/__module__, isclass(int/str), isbuiltin(len), isfunction(len), Parameter/__name__, Signature/__name__"
    - "inspect_signature.zspec.zsdl — covers BoundArguments/__name__/__module__, Signature/__module__, Parameter/__module__, Parameter kind names, Parameter.empty, Signature.empty, signature(len) behavior"
  notes:
    - "inspect.BoundArguments.__dict__.__contains__('args') == True — BoundArguments defines 'args' as a property in its class dict; it returns the positional arguments as a tuple. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__dict__.__contains__('kwargs') == True — BoundArguments defines 'kwargs' as a property in its class dict; it returns the keyword arguments as a dict. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__dict__.__contains__('apply_defaults') == True — BoundArguments defines 'apply_defaults' as a method in its class dict. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__dict__.__contains__('__slots__') == True — BoundArguments uses __slots__ for memory efficiency. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__dict__.__contains__('signature') == True — BoundArguments stores a 'signature' attribute in its class dict (a property referencing the associated Signature). Verified with Python 3.14.3."
    - "inspect.BoundArguments.__dict__.__len__() == 18 — the class dict has exactly 18 entries. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — FullArgSpec is a namedtuple; its first (and only) base class is tuple. The function field 'FullArgSpec.__bases__[0].__name__.__eq__' contains '[' and MUST be double-quoted. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.BoundArguments.__dict__ membership — args, kwargs, apply_defaults
#
# BoundArguments.__dict__.__contains__('args')           == True
# BoundArguments.__dict__.__contains__('kwargs')         == True
# BoundArguments.__dict__.__contains__('apply_defaults') == True
# BoundArguments.__dict__.__contains__('__slots__')      == True
# ---------------------------------------------------------------------------

table inspect_extra211.bound_arguments_dict_primary:
  description: "inspect.BoundArguments.__dict__ membership checks for primary public attributes in inspectparams211ba namespace — 'args' is a property returning positional arguments as a tuple; 'kwargs' is a property returning keyword arguments as a dict; 'apply_defaults' is a method that applies parameter defaults; '__slots__' is present for memory efficiency; all four __contains__ checks return True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: inspectparams211ba

  columns: [id, function, args, expected, description]
  rows:
    - [bound_arguments_has_args,
       "BoundArguments.__dict__.__contains__",
       ["args"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('args') == True — 'args' is defined as a property in BoundArguments.__dict__; it provides access to the positional arguments bound to the function's positional parameters; __contains__('args') returns True; verified with Python 3.14.3"]
    - [bound_arguments_has_kwargs,
       "BoundArguments.__dict__.__contains__",
       ["kwargs"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('kwargs') == True — 'kwargs' is defined as a property in BoundArguments.__dict__; it provides access to keyword arguments bound to the function's keyword parameters; __contains__('kwargs') returns True; verified with Python 3.14.3"]
    - [bound_arguments_has_apply_defaults,
       "BoundArguments.__dict__.__contains__",
       ["apply_defaults"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('apply_defaults') == True — 'apply_defaults' is a method defined in BoundArguments.__dict__; it sets default values for missing parameters; __contains__('apply_defaults') returns True; verified with Python 3.14.3"]
    - [bound_arguments_has_slots,
       "BoundArguments.__dict__.__contains__",
       ["__slots__"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('__slots__') == True — BoundArguments uses __slots__ to reduce memory overhead; __slots__ is present in the class dict; __contains__('__slots__') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 2: inspect.BoundArguments.__dict__ — signature, repr, and len
#
# BoundArguments.__dict__.__contains__('signature') == True
# BoundArguments.__dict__.__contains__('__repr__')  == True
# BoundArguments.__dict__.__len__()                 == 18
# BoundArguments.__dict__.__contains__('arguments') == True
# ---------------------------------------------------------------------------

table inspect_extra211.bound_arguments_dict_secondary:
  description: "inspect.BoundArguments.__dict__ secondary checks in inspectparams211bs namespace — 'signature' is a property in the class dict referencing the associated Signature; '__repr__' is defined for debugging output; the dict length is exactly 18; 'arguments' is also in the dict (the OrderedDict of bound arguments); all four checks verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: inspectparams211bs

  columns: [id, function, args, expected, description]
  rows:
    - [bound_arguments_has_signature,
       "BoundArguments.__dict__.__contains__",
       ["signature"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('signature') == True — 'signature' is a property in BoundArguments.__dict__ referencing the associated Signature object; __contains__('signature') returns True; verified with Python 3.14.3"]
    - [bound_arguments_has_repr,
       "BoundArguments.__dict__.__contains__",
       ["__repr__"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('__repr__') == True — BoundArguments defines __repr__ in its class dict for a useful debugging representation; __contains__('__repr__') returns True; verified with Python 3.14.3"]
    - [bound_arguments_dict_len,
       "BoundArguments.__dict__.__len__",
       [],
       18,
       "inspect.BoundArguments.__dict__.__len__() == 18 — the BoundArguments class dict has exactly 18 entries; __len__() returns 18; verified with Python 3.14.3"]
    - [bound_arguments_has_arguments,
       "BoundArguments.__dict__.__contains__",
       ["arguments"],
       true,
       "inspect.BoundArguments.__dict__.__contains__('arguments') == True — 'arguments' is an attribute in BoundArguments.__dict__; it holds the ordered dict mapping parameter names to bound values; __contains__('arguments') returns True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: inspect.FullArgSpec — namedtuple base and fields membership
#
# FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True   [bracket → double-quote]
# FullArgSpec._fields.__contains__('args')          == True
# FullArgSpec._fields.__contains__('varargs')       == True
# FullArgSpec._fields.__len__()                     == 7
# ---------------------------------------------------------------------------

table inspect_extra211.fullargspec_namedtuple:
  description: "inspect.FullArgSpec namedtuple checks in inspectparams211fs namespace — FullArgSpec is a namedtuple; its base class is tuple; _fields contains 'args' and 'varargs'; _fields has exactly 7 entries (args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults, annotations); the function field for FullArgSpec.__bases__[0].__name__.__eq__ contains '[' and is double-quoted; verified with Python 3.14.3"
  kind: python_call_eq
  category: fullargspec
  id_prefix: inspectparams211fs

  columns: [id, function, args, expected, description]
  rows:
    - [fullargspec_base_is_tuple,
       "FullArgSpec.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — FullArgSpec is a namedtuple; its only base class is tuple; __bases__[0].__name__ is 'tuple'; __eq__('tuple') returns True; function field contains '[' and is double-quoted; verified with Python 3.14.3"]
    - [fullargspec_fields_has_args,
       FullArgSpec._fields.__contains__,
       ["args"],
       true,
       "inspect.FullArgSpec._fields.__contains__('args') == True — FullArgSpec._fields is ('args', 'varargs', 'varkw', 'defaults', 'kwonlyargs', 'kwonlydefaults', 'annotations'); 'args' is the first field; __contains__('args') returns True; verified with Python 3.14.3"]
    - [fullargspec_fields_has_varargs,
       FullArgSpec._fields.__contains__,
       ["varargs"],
       true,
       "inspect.FullArgSpec._fields.__contains__('varargs') == True — 'varargs' is the second field in FullArgSpec._fields; it captures *args parameters; __contains__('varargs') returns True; verified with Python 3.14.3"]
    - [fullargspec_fields_len,
       FullArgSpec._fields.__len__,
       [],
       7,
       "inspect.FullArgSpec._fields.__len__() == 7 — FullArgSpec has exactly 7 fields: args, varargs, varkw, defaults, kwonlyargs, kwonlydefaults, annotations; __len__() returns 7; verified with Python 3.14.3"]

