spec: inspect_extra51
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra50.zspec.zsdl."
    - "Prior specs covered: CO_* constant integer values (extra50); Parameter kind integer values (extra50); ismodule/isclass/isfunction/ismethod/isbuiltin/isroutine/__class__.__name__ (extra47/extra48); getmembers/getfile/getsource/getmodule/signature/stack/currentframe __qualname__.__len__() (various); Parameter.empty/__class__.__name__.__len__()==4 (extra34); Parameter.empty/__class__.__name__=='type' and Signature.empty/__class__.__name__=='type' (extra27); Parameter.empty/__name__.__len__()==6 (extra38); inspect.__all__.__len__()==107 (noted in prior specs)."
    - "This spec covers: inspect.getmembers.__doc__.__class__.__name__.__eq__('str')==true; inspect.getfile.__doc__.__class__.__name__.__eq__('str')==true; inspect.getsource.__doc__.__class__.__name__.__eq__('str')==true; inspect.getmodule.__doc__.__class__.__name__.__eq__('str')==true; inspect.signature.__doc__.__class__.__name__.__eq__('str')==true; inspect.stack.__doc__.__class__.__name__.__eq__('str')==true; inspect.__doc__.__class__.__name__.__eq__('str')==true; inspect.__doc__.__class__.__qualname__.__eq__('str')==true."
    - "Key findings: inspect is a pure-Python module in Lib/inspect.py. All its public functions carry a Python string object as their __doc__ (the docstring literal from the function body). Therefore for any inspect function F: F.__doc__.__class__.__name__ == 'str' (3 chars) and F.__doc__.__class__.__qualname__ == 'str'. The inspect module itself has a module-level docstring, also a Python str. The str built-in type has __name__ == __qualname__ == 'str' and __module__ == 'builtins'. This pattern holds uniformly for pure-Python functions (unlike C-extension functions where the docstring comes from PyMethodDef.ml_doc — but even there the result is a str). All eight invariants are new to extra51. No prior inspect spec records __doc__.__class__.__name__.__eq__ or __doc__.__class__.__qualname__.__eq__ for any inspect function."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect function __doc__.__class__.__name__ == 'str' — extra51 namespace
#
# inspect is a pure-Python module in Lib/inspect.py. Every public inspect
# function that has a docstring stores it as a Python str object literal in
# the function's code object co_consts. Therefore for any such function F:
#   F.__doc__.__class__.__name__ == 'str' (3 chars).
# Six functions are chosen to represent the major categories of inspect's API:
#   getmembers  — member enumeration
#   getfile     — source file discovery
#   getsource   — source retrieval
#   getmodule   — module discovery
#   signature   — introspection entry point
#   stack       — call stack introspection
# No prior inspect spec records __doc__.__class__.__name__.__eq__ for any
# inspect function. All six are new to extra51.
# ---------------------------------------------------------------------------

table inspect_extra51.function_doc_class_names:
  description: "inspect function __doc__.__class__.__name__ == 'str' — all inspect public functions are pure-Python and store docstrings as Python str literals; the str type has __name__ == 'str' (3 chars); holds for member enumeration, source retrieval, module discovery, signature, and stack functions"
  kind: python_call_eq
  category: identity
  id_prefix: inspecdoc51

  columns: [id, function, args, expected, description]
  rows:
    - [getmembers_doc_class_name,
       getmembers.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.getmembers.__doc__.__class__.__name__ == 'str' — pure-Python function in Lib/inspect.py; returns all attributes of an object as a sorted list of (name, value) pairs; docstring is a Python string literal stored in the function's co_consts; __doc__.__class__.__name__ == 'str' (3 chars); new to extra51"]
    - [getfile_doc_class_name,
       getfile.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.getfile.__doc__.__class__.__name__ == 'str' — pure-Python function in Lib/inspect.py; returns the file path of the Python source file in which an object was defined; raises OSError for built-in objects; docstring is a Python string literal; __doc__.__class__.__name__ == 'str' (3 chars); new to extra51"]
    - [getsource_doc_class_name,
       getsource.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.getsource.__doc__.__class__.__name__ == 'str' — pure-Python function in Lib/inspect.py; returns the text of the source code for an object (module, class, method, function, traceback, frame, or code object); raises OSError if source cannot be retrieved; docstring is a Python string literal; __doc__.__class__.__name__ == 'str' (3 chars); new to extra51"]
    - [getmodule_doc_class_name,
       getmodule.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.getmodule.__doc__.__class__.__name__ == 'str' — pure-Python function in Lib/inspect.py; tries to guess which module an object was defined in by examining __module__ attributes and sys.modules; docstring is a Python string literal in co_consts; __doc__.__class__.__name__ == 'str' (3 chars); new to extra51"]
    - [signature_doc_class_name,
       signature.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.signature.__doc__.__class__.__name__ == 'str' — pure-Python function in Lib/inspect.py; the primary entry point for getting a Signature object describing a callable's parameters; returns an inspect.Signature instance; docstring is a Python string literal; __doc__.__class__.__name__ == 'str' (3 chars); new to extra51"]
    - [stack_doc_class_name,
       stack.__doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.stack.__doc__.__class__.__name__ == 'str' — pure-Python function in Lib/inspect.py; returns the call stack as a list of FrameInfo named tuples for the caller's frame and each enclosing frame; accepts optional context argument for number of lines of context; docstring is a Python string literal; __doc__.__class__.__name__ == 'str' (3 chars); new to extra51"]

# ---------------------------------------------------------------------------
# inspect module __doc__.__class__.__name__ and __qualname__ — extra51 namespace
#
# The inspect module has a module-level docstring describing its purpose.
# This docstring is a Python str object. The str built-in type has
# __name__ == __qualname__ == 'str' (3 chars) and __module__ == 'builtins'.
# No prior inspect spec records inspect.__doc__.__class__.__name__.__eq__ or
# inspect.__doc__.__class__.__qualname__.__eq__. Both are new to extra51.
# ---------------------------------------------------------------------------

table inspect_extra51.module_doc_class_name_qualname:
  description: "inspect.__doc__.__class__.__name__ == 'str' and __class__.__qualname__ == 'str' — the inspect module docstring is a Python str object; the str built-in type has __name__ == __qualname__ == 'str' (3 chars); new to extra51"
  kind: python_call_eq
  category: identity
  id_prefix: inspecdoc51

  columns: [id, function, args, expected, description]
  rows:
    - [module_doc_class_name,
       __doc__.__class__.__name__.__eq__,
       ["str"],
       true,
       "inspect.__doc__.__class__.__name__ == 'str' — the inspect module has a module-level docstring beginning 'Get useful information from live Python objects'; this docstring is a Python str object stored as the module's __doc__ attribute; __doc__.__class__.__name__ == 'str' (3 chars); consistent with all pure-Python standard library modules; new to extra51"]
    - [module_doc_class_qualname,
       __doc__.__class__.__qualname__.__eq__,
       ["str"],
       true,
       "inspect.__doc__.__class__.__qualname__ == 'str' — the module docstring is a str object; the str built-in type is a top-level type with __qualname__ == __name__ == 'str' (3 chars); no dotted prefix because str is not a nested class; consistent with functools (extra55 wraps/__doc__.__class__.__qualname__) and itertools (extra50 accumulate/__doc__.__class__.__qualname__); new to extra51"]
