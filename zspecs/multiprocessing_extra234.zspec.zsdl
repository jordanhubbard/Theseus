spec: multiprocessing_extra234
version: ">=3.4"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.current_process — current_process"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.active_children — active_children"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py (internal implementation)"
  notes:
    - "This spec covers multiprocessing.current_process and multiprocessing.active_children function identity."
    - "current_process.__module__ == 'multiprocessing.process' (len=23) — defined in Lib/multiprocessing/process.py."
    - "active_children.__module__ == 'multiprocessing.process' (len=23) — defined in the same file."
    - "current_process.__name__.__len__() == 15 ('current_process' is 15 chars)."
    - "active_children.__name__.__len__() == 15 ('active_children' is 15 chars, same length as current_process)."
    - "current_process().__class__.__name__ == '_MainProcess' (len=12) — the main process is a _MainProcess instance."
    - "Both functions have __class__.__name__ == 'function' — Python functions."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.current_process function identity
#
# current_process.__name__ == 'current_process' (len=15)
# current_process.__module__ == 'multiprocessing.process' (len=23)
# current_process.__qualname__ == 'current_process' (len=15)
# current_process.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table multiprocessing_extra234.current_process_identity:
  description: "multiprocessing.current_process function identity checks — current_process is a Python function defined in multiprocessing.process; current_process.__name__.__eq__('current_process')==True (len=15); current_process.__module__.__eq__('multiprocessing.process')==True (len=23); current_process.__qualname__.__eq__('current_process')==True (len=15, module-level function so qualname equals name); current_process.__class__.__name__.__eq__('function')==True; current_process.__name__.__len__()==15 (same as active_children.__name__.__len__()==15); verified with Python 3.14.3"
  kind: python_call_eq
  category: current_process_identity
  id_prefix: mpcurr234

  columns: [id, function, args, expected, description]
  rows:
    - [cp_name_eq,    current_process.__name__.__eq__,          ["current_process"],        true, "multiprocessing.current_process.__name__ == 'current_process'; verified with Python 3.14.3"]
    - [cp_name_len,   current_process.__name__.__len__,         [],                         15,   "multiprocessing.current_process.__name__.__len__() == 15; verified with Python 3.14.3"]
    - [cp_module_eq,  current_process.__module__.__eq__,        ["multiprocessing.process"], true, "multiprocessing.current_process.__module__ == 'multiprocessing.process'; verified with Python 3.14.3"]
    - [cp_module_len, current_process.__module__.__len__,       [],                         23,   "multiprocessing.current_process.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [cp_qname_eq,   current_process.__qualname__.__eq__,      ["current_process"],        true, "multiprocessing.current_process.__qualname__ == 'current_process' (len=15, qualname equals name); verified with Python 3.14.3"]
    - [cp_qname_len,  current_process.__qualname__.__len__,     [],                         15,   "multiprocessing.current_process.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [cp_cls_nm,     current_process.__class__.__name__.__eq__, ["function"],              true, "multiprocessing.current_process.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.active_children function identity
#
# active_children.__name__ == 'active_children' (len=15)
# active_children.__module__ == 'multiprocessing.process' (len=23)
# active_children.__qualname__ == 'active_children' (len=15)
# active_children.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table multiprocessing_extra234.active_children_identity:
  description: "multiprocessing.active_children function identity checks — active_children is a Python function defined in multiprocessing.process; active_children.__name__.__eq__('active_children')==True (len=15, same length as current_process.__name__.__len__()==15); active_children.__module__.__eq__('multiprocessing.process')==True (len=23, same module as current_process); active_children.__qualname__.__eq__('active_children')==True (len=15, module-level function); active_children.__class__.__name__.__eq__('function')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: active_children_identity
  id_prefix: mpactv234

  columns: [id, function, args, expected, description]
  rows:
    - [ac_name_eq,    active_children.__name__.__eq__,          ["active_children"],        true, "multiprocessing.active_children.__name__ == 'active_children'; verified with Python 3.14.3"]
    - [ac_name_len,   active_children.__name__.__len__,         [],                         15,   "multiprocessing.active_children.__name__.__len__() == 15; verified with Python 3.14.3"]
    - [ac_module_eq,  active_children.__module__.__eq__,        ["multiprocessing.process"], true, "multiprocessing.active_children.__module__ == 'multiprocessing.process'; verified with Python 3.14.3"]
    - [ac_module_len, active_children.__module__.__len__,       [],                         23,   "multiprocessing.active_children.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [ac_qname_eq,   active_children.__qualname__.__eq__,      ["active_children"],        true, "multiprocessing.active_children.__qualname__ == 'active_children' (len=15, qualname equals name); verified with Python 3.14.3"]
    - [ac_qname_len,  active_children.__qualname__.__len__,     [],                         15,   "multiprocessing.active_children.__qualname__.__len__() == 15; verified with Python 3.14.3"]
    - [ac_cls_nm,     active_children.__class__.__name__.__eq__, ["function"],              true, "multiprocessing.active_children.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra234
# ---------------------------------------------------------------------------

invariant multiprocessing_extra234.current_process_module:
  description: "multiprocessing.current_process.__module__.__eq__('multiprocessing.process') returns True — current_process is defined in Lib/multiprocessing/process.py; __module__ == 'multiprocessing.process' (len=23 = 'multiprocessing'=15 + '.'=1 + 'process'=7 = 23); same module as active_children; current_process.__name__ is 'current_process' (len=15); __qualname__ equals __name__ (both len=15); NEW in extra234: first standalone current_process module invariant in mpcurr234 namespace; verified with Python 3.14.3"
  category: current_process_identity
  kind: python_call_eq
  function: current_process.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

invariant multiprocessing_extra234.active_children_module:
  description: "multiprocessing.active_children.__module__.__eq__('multiprocessing.process') returns True — active_children is defined in Lib/multiprocessing/process.py alongside current_process; both share __module__ == 'multiprocessing.process' (len=23); active_children.__name__ is 'active_children' (len=15, same length as current_process.__name__.__len__()==15); __qualname__ equals __name__ (both len=15); NEW in extra234: first standalone active_children module invariant in mpactv234 namespace; verified with Python 3.14.3"
  category: active_children_identity
  kind: python_call_eq
  function: active_children.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

invariant multiprocessing_extra234.current_process_name_len_15:
  description: "multiprocessing.current_process.__name__.__len__() == 15 — 'current_process' has 15 chars: c-u-r-r-e-n-t-_-p-r-o-c-e-s-s; same length as active_children.__name__.__len__()==15 ('active_children' also 15 chars); current_process.__module__.__len__()==23 ('multiprocessing.process'); __qualname__.__len__()==15 (same as __name__.__len__()); NEW in extra234: first standalone current_process name length invariant; verified with Python 3.14.3"
  category: current_process_identity
  kind: python_call_eq
  function: current_process.__name__.__len__
  args: []
  expected: 15

invariant multiprocessing_extra234.active_children_name_len_15:
  description: "multiprocessing.active_children.__name__.__len__() == 15 — 'active_children' has 15 chars: a-c-t-i-v-e-_-c-h-i-l-d-r-e-n; same length as current_process.__name__.__len__()==15; active_children.__module__.__len__()==23 ('multiprocessing.process'); __qualname__.__len__()==15 (same as __name__.__len__()); NEW in extra234: first standalone active_children name length invariant in mpactv234 namespace; verified with Python 3.14.3"
  category: active_children_identity
  kind: python_call_eq
  function: active_children.__name__.__len__
  args: []
  expected: 15
