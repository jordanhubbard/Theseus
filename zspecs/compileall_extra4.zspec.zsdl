spec: compileall_extra4
version: ">=3.9"
backend: python_module(compileall)

docs: https://docs.python.org/3/library/compileall.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/compileall.html — Python compileall module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/compileall.py"
  notes:
    - "This spec extends compileall.zspec.zsdl, compileall_extra.zspec.zsdl, compileall_extra2.zspec.zsdl, and compileall_extra3.zspec.zsdl."
    - "compileall (base) covers: __name__, __module__, type (function), docstring, and __qualname__ for compile_file and compile_dir."
    - "compileall_extra covers: __name__ and __module__ for compile_file, compile_dir, compile_path."
    - "compileall_extra2 covers: __name__, __module__, __qualname__, type, and docstring for all three functions."
    - "compileall_extra3 covers: __name__, __module__, and __qualname__ for all three functions (as separate invariants and table)."
    - "This spec adds: __code__.__class__.__name__ == 'code' for each function (not in any prior spec, confirms they are pure-Python functions with a code object rather than C builtins), and __code__.co_name cross-checks (not in any prior spec)."
    - "compile_file.__code__.__class__.__name__ == 'code' — compile_file is implemented in Python (Lib/compileall.py), so it has a code object."
    - "compile_dir.__code__.__class__.__name__ == 'code' — same rationale for compile_dir."
    - "compile_path.__code__.__class__.__name__ == 'code' — same rationale for compile_path."
    - "compile_file.__code__.co_name == 'compile_file' — the code object's function name matches the function name."
    - "compile_dir.__code__.co_name == 'compile_dir' — same for compile_dir."
    - "compile_path.__code__.co_name == 'compile_path' — same for compile_path."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __code__.__class__.__name__ — confirms all three are pure-Python functions
# compileall_extra2 and compileall (base) use __class__.__name__.__eq__('function')
# to verify the function type. This adds a complementary check on the code object itself.
# ---------------------------------------------------------------------------

table compileall_extra4.code_object_types:
  kind: python_call_eq
  category: code_objects
  id_prefix: code_type

  columns: [id, function, args, expected]
  rows:
    - [compile_file, compile_file.__code__.__class__.__name__.__eq__, ["code"], true]
    - [compile_dir,  compile_dir.__code__.__class__.__name__.__eq__,  ["code"], true]
    - [compile_path, compile_path.__code__.__class__.__name__.__eq__, ["code"], true]

# ---------------------------------------------------------------------------
# __code__.co_name — the code object's recorded function name
# This verifies the bytecode-level function name matches the Python-level name.
# Not covered in any prior compileall spec.
# ---------------------------------------------------------------------------

table compileall_extra4.code_object_names:
  kind: python_call_eq
  category: code_objects
  id_prefix: co_name

  columns: [id, function, args, expected]
  rows:
    - [compile_file, compile_file.__code__.co_name.__eq__, ["compile_file"], true]
    - [compile_dir,  compile_dir.__code__.co_name.__eq__,  ["compile_dir"],  true]
    - [compile_path, compile_path.__code__.co_name.__eq__, ["compile_path"], true]
