    - [future_adc_co_name,     Future.add_done_callback.__code__.co_name.__eq__,     ["add_done_callback"], true, "Future.add_done_callback.__code__.co_name == 'add_done_callback' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [future_adc_co_argcount, Future.add_done_callback.__code__.co_argcount.__eq__,  [2],                   true, "Future.add_done_callback.__code__.co_argcount == 2 — add_done_callback takes self and fn as positional parameters; verified with Python 3.14.3"]

