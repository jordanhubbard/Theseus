spec: concurrent_futures_extra75
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
  notes:
    - "This spec extends concurrent_futures_extra74.zspec.zsdl."
    - "This spec covers: wave 244 theme — concurrent.futures Future method code attributes + as_completed co_varnames length. NEW in extra75: Future.__init__.__code__.co_name=='__init__'; Future.__init__.__code__.co_varnames.__class__.__name__=='tuple'; Future.done.__code__.co_name=='done'; Future.done.__code__.co_argcount==1; Future.exception.__code__.co_name=='exception'; Future.exception.__code__.co_argcount==2 (self + timeout); Future.add_done_callback.__code__.co_name=='add_done_callback'; Future.add_done_callback.__code__.co_argcount==2 (self + fn); as_completed.__code__.co_varnames.__len__()==9. NOTE: ThreadPoolExecutor does NOT override map — it inherits map from Executor; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__init__.__code__.co_name == '__init__'. Future is a Python class in concurrent/futures/_base.py; its __init__ is a Python method with a code object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'. co_varnames is always a tuple in CPython code objects. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.done.__code__.co_name == 'done'. Future.done is a Python method in concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.done.__code__.co_argcount == 1. done takes only self as positional parameter. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.exception.__code__.co_name == 'exception'. Future.exception is a Python method in concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.exception.__code__.co_argcount == 2. exception takes self and timeout as positional parameters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.add_done_callback.__code__.co_name == 'add_done_callback'. Future.add_done_callback is a Python method in concurrent/futures/_base.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.Future.add_done_callback.__code__.co_argcount == 2. add_done_callback takes self and fn as positional parameters. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "concurrent.futures.as_completed.__code__.co_varnames.__len__() == 9. as_completed is a generator function with 9 local variables in its code object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures Future.__init__ and done code attributes — extra75
#
# Wave 244 theme: Future method code attributes.
#
# Future.__init__.__code__.co_name == '__init__'
# Future.__init__.__code__.co_varnames.__class__.__name__ == 'tuple'
# Future.done.__code__.co_name == 'done'
# Future.done.__code__.co_argcount == 1
# ---------------------------------------------------------------------------

table concurrent_futures_extra75.Future_init_and_done_code_attrs:
  description: "concurrent.futures Future.__init__ and done code attribute checks in cfmore75 namespace — wave 244 theme: Future method code attributes; Future.__init__.__code__.co_name=='__init__' (code object co_name matches method name); Future.__init__.__code__.co_varnames.__class__.__name__=='tuple' (co_varnames is always a tuple in CPython); Future.done.__code__.co_name=='done'; Future.done.__code__.co_argcount==1 (only self); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfmore75

  columns: [id, function, args, expected, description]
  rows:
    - [future_init_co_name,     Future.__init__.__code__.co_name.__eq__,                    ["__init__"], true, "Future.__init__.__code__.co_name == '__init__' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [future_init_varnames_cls, Future.__init__.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"],    true, "Future.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple in CPython; verified with Python 3.14.3"]
    - [future_done_co_name,     Future.done.__code__.co_name.__eq__,                        ["done"],     true, "Future.done.__code__.co_name == 'done' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [future_done_co_argcount, Future.done.__code__.co_argcount.__eq__,                    [1],          true, "Future.done.__code__.co_argcount == 1 — done takes only self as positional parameter; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
