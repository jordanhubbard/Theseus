  description: "concurrent.futures Future.exception code attribute checks in cfmore75 namespace — wave 244 theme: Future.exception code attributes; Future.exception.__code__.co_name=='exception'; Future.exception.__code__.co_argcount==2 (self + timeout); verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfmore75a

  columns: [id, function, args, expected, description]
  rows:
    - [future_exc_co_name,     Future.exception.__code__.co_name.__eq__,     ["exception"], true, "Future.exception.__code__.co_name == 'exception' — code object co_name matches the method name; verified with Python 3.14.3"]
    - [future_exc_co_argcount, Future.exception.__code__.co_argcount.__eq__,  [2],           true, "Future.exception.__code__.co_argcount == 2 — exception takes self and timeout as positional parameters; verified with Python 3.14.3"]

