table concurrent_futures_extra75.as_completed_varnames_len_and_cross_check:
  description: "concurrent.futures as_completed co_varnames length and Future code attribute cross-check in cfmore75 namespace — wave 244 theme: as_completed co_varnames length + Future method cross-checks; as_completed.__code__.co_varnames.__len__()==9 (generator function with 9 local vars); Future.done.__code__.co_name=='done'; Future.exception.__code__.co_name=='exception'; Future.add_done_callback.__code__.co_name=='add_done_callback'; verified with Python 3.14.3"
  kind: python_call_eq
  category: code
  id_prefix: cfmore75c

  columns: [id, function, args, expected, description]
  rows:
    - [as_completed_varnames_len, as_completed.__code__.co_varnames.__len__, [],    9,    "as_completed.__code__.co_varnames.__len__() == 9 — as_completed is a generator function with 9 local variables; verified with Python 3.14.3"]
    - [future_done_name_cross,    Future.done.__code__.co_name.__eq__,       ["done"],      true, "Future.done.__code__.co_name == 'done' — cross-check; verified with Python 3.14.3"]
    - [future_exc_name_cross,     Future.exception.__code__.co_name.__eq__,  ["exception"], true, "Future.exception.__code__.co_name == 'exception' — cross-check; verified with Python 3.14.3"]
    - [future_adc_name_cross,     Future.add_done_callback.__code__.co_name.__eq__, ["add_done_callback"], true, "Future.add_done_callback.__code__.co_name == 'add_done_callback' — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra75
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra75.Future_init_co_name:
  description: "concurrent.futures.Future.__init__.__code__.co_name.__eq__('__init__') returns True — Future is a Python class in concurrent/futures/_base.py; its __init__ is a Python method with a code object; NEW in extra75: first standalone co_name invariant for Future.__init__ in cfmore75 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Future.__init__.__code__.co_name.__eq__
  args: ["__init__"]
  expected: true

invariant concurrent_futures_extra75.Future_init_varnames_class_name:
  description: "concurrent.futures.Future.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — co_varnames is always a tuple in CPython code objects; NEW in extra75: first standalone co_varnames.__class__.__name__ invariant for Future.__init__ in cfmore75 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Future.__init__.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant concurrent_futures_extra75.Future_done_co_argcount:
  description: "concurrent.futures.Future.done.__code__.co_argcount.__eq__(1) returns True — done takes only self as a positional parameter; NEW in extra75: first standalone co_argcount invariant for Future.done in cfmore75 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Future.done.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant concurrent_futures_extra75.Future_exception_co_argcount:
  description: "concurrent.futures.Future.exception.__code__.co_argcount.__eq__(2) returns True — exception takes self and timeout as positional parameters; NEW in extra75: first standalone co_argcount invariant for Future.exception in cfmore75 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: Future.exception.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant concurrent_futures_extra75.as_completed_varnames_len:
  description: "concurrent.futures.as_completed.__code__.co_varnames.__len__() == 9 — as_completed is a Python generator function with 9 local variables in its code object; NEW in extra75: first standalone co_varnames.__len__ invariant for as_completed in cfmore75 namespace; wave 244; verified with Python 3.14.3"
  category: code
  kind: python_call_eq
  function: as_completed.__code__.co_varnames.__len__
  args: []
  expected: 9
