spec: theseus_difflib_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_difflib_cr2)
blocks: difflib

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html"
    - "https://en.wikipedia.org/wiki/Longest_common_subsequence"
  notes:
    - "Clean-room extended difflib utilities. Do NOT import difflib."
    - "SequenceMatcher(isjunk, a, b): compare two sequences; ratio() in [0, 1]."
    - "get_close_matches(word, possibilities, n=3, cutoff=0.6): return close matches."
    - "ndiff(a, b): delta lines with '+ ', '- ', '? ' prefixes."
    - "difflib2_ratio(): SequenceMatcher(None, 'abcde', 'abcde').ratio() == 1.0."
    - "difflib2_close_matches(): get_close_matches('appel', ['apple', 'mango'])[0] == 'apple'."
    - "difflib2_ndiff(): some line from ndiff(['a\\n'], ['b\\n']) starts with '?' — returns True."
    - "Zero-arg invariant signatures — def difflib2_ratio(): return hardcoded_result"
    - "Export: SequenceMatcher(isjunk, a, b), get_close_matches(word, possibilities), ndiff(a, b)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_difflib_cr2.ratio:
  description: "SequenceMatcher(None, 'abcde', 'abcde').ratio() == 1.0"
  category: ratio
  kind: python_call_eq
  function: difflib2_ratio
  args: []
  expected: 1.0

invariant theseus_difflib_cr2.close_matches:
  description: "get_close_matches('appel', ['apple', 'mango'])[0] == 'apple'"
  category: close_matches
  kind: python_call_eq
  function: difflib2_close_matches
  args: []
  expected: "apple"

invariant theseus_difflib_cr2.ndiff:
  description: "ndiff output contains lines starting with '?'"
  category: ndiff
  kind: python_call_eq
  function: difflib2_ndiff
  args: []
  expected: true
