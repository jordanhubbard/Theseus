spec: lodash_defaultto
version: ">=4.0.0"
backend: node(lodash.defaultto)

docs: https://lodash.com/docs/#defaultTo

provenance:
  derived_from:
    - "lodash.defaultto README — https://www.npmjs.com/package/lodash.defaultto"
    - "Test vectors verified with lodash.defaultto@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.defaultto exports the _.defaultTo function directly as module.exports."
    - "defaultTo(value, defaultValue) returns value if not null/undefined/NaN, otherwise defaultValue."
    - "JSON cannot represent NaN so only null is tested here."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns value or defaultValue."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_defaultto.defaultto:
  kind: node_module_call_eq
  function: ~
  category: defaultto
  id_prefix: ldto

  columns: [id, args, expected]
  rows:
    - [has_value,  [1, 10],     1]
    - [null_v,     [null, 10],  10]
    - [zero,       [0, 10],     0]
    - [string,     ["", 10],    ""]

