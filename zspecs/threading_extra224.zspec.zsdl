spec: threading_extra224
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading Thread, Semaphore, and Event method co_argcount contracts."
    - "threading.Thread.start.__code__.co_argcount == 1 (self only). Verified with Python 3.14.3."
    - "threading.Thread.join.__code__.co_argcount == 2 (self, timeout). Verified with Python 3.14.3."
    - "threading.Thread.run.__code__.co_argcount == 1 (self only). Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__code__.co_argcount == 1 (self only). Verified with Python 3.14.3."
    - "threading.Thread.start.__code__.co_argcount.__class__.__name__ == 'int'. Verified with Python 3.14.3."
    - "threading.Semaphore.acquire.__code__.co_argcount == 3 (self, blocking, timeout). Verified with Python 3.14.3."
    - "threading.Semaphore.release.__code__.co_argcount == 2 (self, n). Verified with Python 3.14.3."
    - "threading.Event.set.__code__.co_argcount == 1 (self only). Verified with Python 3.14.3."
    - "threading.Event.clear.__code__.co_argcount == 1 (self only). Verified with Python 3.14.3."
    - "threading.Event.wait.__code__.co_argcount == 2 (self, timeout). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread method co_argcount checks
#
# Verified with Python 3.14.3:
#   threading.Thread.start.__code__.co_argcount == 1  (self)
#   threading.Thread.join.__code__.co_argcount  == 2  (self, timeout)
#   threading.Thread.run.__code__.co_argcount   == 1  (self)
#   threading.Thread.is_alive.__code__.co_argcount == 1  (self)
# ---------------------------------------------------------------------------

table threading_extra224.thread_method_co_argcount:
  description: "threading.Thread method __code__.co_argcount checks; new to extra224"
  kind: python_call_eq
  category: code_inspection
  id_prefix: threadingextra224threadcoa

  columns: [id, function, args, expected, description]
  rows:
    - [thread_start_co_argcount_eq,
       "Thread.start.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Thread.start.__code__.co_argcount.__eq__(1) == True — Thread.start(self) takes only self; co_argcount is 1; int.__eq__(1) returns True; new to extra224"]
    - [thread_join_co_argcount_eq,
       "Thread.join.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Thread.join.__code__.co_argcount.__eq__(2) == True — Thread.join(self, timeout=None) takes self and timeout; co_argcount is 2; int.__eq__(2) returns True; new to extra224"]
    - [thread_run_co_argcount_eq,
       "Thread.run.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Thread.run.__code__.co_argcount.__eq__(1) == True — Thread.run(self) takes only self; co_argcount is 1; int.__eq__(1) returns True; new to extra224"]
    - [thread_is_alive_co_argcount_eq,
       "Thread.is_alive.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Thread.is_alive.__code__.co_argcount.__eq__(1) == True — Thread.is_alive(self) takes only self; co_argcount is 1; int.__eq__(1) returns True; new to extra224"]

# ---------------------------------------------------------------------------
# Table 2: threading.Semaphore and Event method co_argcount checks
#
# Verified with Python 3.14.3:
#   threading.Semaphore.acquire.__code__.co_argcount == 3  (self, blocking, timeout)
#   threading.Semaphore.release.__code__.co_argcount == 2  (self, n)
#   threading.Event.set.__code__.co_argcount   == 1  (self)
#   threading.Event.clear.__code__.co_argcount == 1  (self)
#   threading.Event.wait.__code__.co_argcount  == 2  (self, timeout)
# ---------------------------------------------------------------------------

table threading_extra224.semaphore_event_co_argcount:
  description: "threading.Semaphore and Event method __code__.co_argcount checks; new to extra224"
  kind: python_call_eq
  category: code_inspection
  id_prefix: threadingextra224semevtcoa

  columns: [id, function, args, expected, description]
  rows:
    - [semaphore_acquire_co_argcount_eq,
       "Semaphore.acquire.__code__.co_argcount.__eq__",
       [3],
       true,
       "threading.Semaphore.acquire.__code__.co_argcount.__eq__(3) == True — Semaphore.acquire(self, blocking=True, timeout=None) takes self, blocking, and timeout; co_argcount is 3; int.__eq__(3) returns True; new to extra224"]
    - [semaphore_release_co_argcount_eq,
       "Semaphore.release.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Semaphore.release.__code__.co_argcount.__eq__(2) == True — Semaphore.release(self, n=1) takes self and n; co_argcount is 2; int.__eq__(2) returns True; new to extra224"]
    - [event_set_co_argcount_eq,
       "Event.set.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Event.set.__code__.co_argcount.__eq__(1) == True — Event.set(self) takes only self; co_argcount is 1; int.__eq__(1) returns True; new to extra224"]
    - [event_clear_co_argcount_eq,
       "Event.clear.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading.Event.clear.__code__.co_argcount.__eq__(1) == True — Event.clear(self) takes only self; co_argcount is 1; int.__eq__(1) returns True; new to extra224"]
    - [event_wait_co_argcount_eq,
       "Event.wait.__code__.co_argcount.__eq__",
       [2],
       true,
       "threading.Event.wait.__code__.co_argcount.__eq__(2) == True — Event.wait(self, timeout=None) takes self and timeout; co_argcount is 2; int.__eq__(2) returns True; new to extra224"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra224
# ---------------------------------------------------------------------------

invariant threading_extra224.Thread_start_co_argcount:
  description: "threading.Thread.start.__code__.co_argcount == 1 — start takes only self; new to extra224"
  kind: python_call_eq
  function: Thread.start.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant threading_extra224.Thread_join_co_argcount:
  description: "threading.Thread.join.__code__.co_argcount == 2 — join takes self and timeout; new to extra224"
  kind: python_call_eq
  function: Thread.join.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant threading_extra224.Thread_run_co_argcount:
  description: "threading.Thread.run.__code__.co_argcount == 1 — run takes only self; new to extra224"
  kind: python_call_eq
  function: Thread.run.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant threading_extra224.Thread_is_alive_co_argcount:
  description: "threading.Thread.is_alive.__code__.co_argcount == 1 — is_alive takes only self; new to extra224"
  kind: python_call_eq
  function: Thread.is_alive.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant threading_extra224.Thread_start_co_argcount_class_name:
  description: "threading.Thread.start.__code__.co_argcount.__class__.__name__.__eq__('int') == True — co_argcount is an int; new to extra224"
  kind: python_call_eq
  function: Thread.start.__code__.co_argcount.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant threading_extra224.Semaphore_acquire_co_argcount:
  description: "threading.Semaphore.acquire.__code__.co_argcount == 3 — acquire takes self, blocking, timeout; new to extra224"
  kind: python_call_eq
  function: Semaphore.acquire.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant threading_extra224.Semaphore_release_co_argcount:
  description: "threading.Semaphore.release.__code__.co_argcount == 2 — release takes self and n; new to extra224"
  kind: python_call_eq
  function: Semaphore.release.__code__.co_argcount.__eq__
  args: [2]
  expected: true

invariant threading_extra224.Event_set_co_argcount:
  description: "threading.Event.set.__code__.co_argcount == 1 — set takes only self; new to extra224"
  kind: python_call_eq
  function: Event.set.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant threading_extra224.Event_clear_co_argcount:
  description: "threading.Event.clear.__code__.co_argcount == 1 — clear takes only self; new to extra224"
  kind: python_call_eq
  function: Event.clear.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant threading_extra224.Event_wait_co_argcount:
  description: "threading.Event.wait.__code__.co_argcount == 2 — wait takes self and timeout; new to extra224"
  kind: python_call_eq
  function: Event.wait.__code__.co_argcount.__eq__
  args: [2]
  expected: true
