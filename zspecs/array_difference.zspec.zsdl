spec: array_difference
version: ">=0.0.2"
backend: node(array-difference)

docs: https://www.npmjs.com/package/array-difference

provenance:
  derived_from:
    - "array-difference README — https://www.npmjs.com/package/array-difference"
    - "Test vectors verified with array-difference via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "array-difference source"
  notes:
    - "array-difference is an npm package. Install: npm install array-difference"
    - "Returns elements present in the first array but not in the second."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table array_difference.diff:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: adiff

  columns: [id, args, expected]
  rows:
    - [numbers,  [[1, 2, 3, 4], [2, 4]],      [1, 3]]
    - [strings,  [["a", "b", "c"], ["b"]],    ["a", "c"]]
