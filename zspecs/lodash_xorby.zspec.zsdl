spec: lodash_xorby
version: ">=4.0.0"
backend: node(lodash.xorby)

docs: https://lodash.com/docs/#xorBy

provenance:
  derived_from:
    - "lodash.xorby README — https://www.npmjs.com/package/lodash.xorby"
    - "Test vectors verified with lodash.xorby@4.7.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.xorby exports the _.xorBy function directly as module.exports."
    - "xorBy(array, values, iteratee) computes symmetric difference using iteratee."
    - "String iteratee plucks property for comparison."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of elements in exactly one of the arrays."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_xorby.xorby:
  kind: node_module_call_eq
  function: ~
  category: xorby
  id_prefix: lxby

  columns: [id, args, expected]
  rows:
    - [by_x,  [[{"x": 1}, {"x": 2}], [{"x": 2}, {"x": 3}], "x"],
       [{"x": 1}, {"x": 3}]]
