spec: io_extra1111
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module abstract base class and concrete class __init__ qualname/module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks io abstract base class (IOBase/RawIOBase/BufferedIOBase/TextIOBase) __name__/__module__/__qualname__, concrete class __init__ __qualname__ (BufferedReader/BufferedWriter/FileIO/BytesIO/StringIO/TextIOWrapper), and io module-level identity (__name__, __spec__.name); none of these were covered in _extra1081 or _extra1096"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1111.abstract_base_class_identity:
  description: "io abstract base class IOBase, RawIOBase, BufferedIOBase, TextIOBase __name__, __module__, __qualname__ checks"
  kind: python_call_eq
  category: abstract_base_class_identity
  id_prefix: io1111ab
  columns: [id, function, args, expected]
  rows:
    - [io1111ab001, io.IOBase.__name__.__eq__,          ["IOBase"],       true]
    - [io1111ab002, io.IOBase.__module__.__eq__,         ["io"],           true]
    - [io1111ab003, io.IOBase.__qualname__.__eq__,       ["IOBase"],       true]
    - [io1111ab004, io.RawIOBase.__name__.__eq__,        ["RawIOBase"],    true]
    - [io1111ab005, io.RawIOBase.__module__.__eq__,      ["io"],           true]
    - [io1111ab006, io.RawIOBase.__qualname__.__eq__,    ["RawIOBase"],    true]
    - [io1111ab007, io.BufferedIOBase.__name__.__eq__,   ["BufferedIOBase"], true]
    - [io1111ab008, io.BufferedIOBase.__module__.__eq__,  ["io"],          true]
    - [io1111ab009, io.BufferedIOBase.__qualname__.__eq__, ["BufferedIOBase"], true]
    - [io1111ab010, io.TextIOBase.__name__.__eq__,       ["TextIOBase"],   true]
    - [io1111ab011, io.TextIOBase.__module__.__eq__,     ["io"],           true]
    - [io1111ab012, io.TextIOBase.__qualname__.__eq__,   ["TextIOBase"],   true]

table io_extra1111.concrete_class_init_qualnames:
  description: "io concrete class __init__ method __qualname__ checks for BufferedReader, BufferedWriter, FileIO, BytesIO, StringIO, TextIOWrapper"
  kind: python_call_eq
  category: concrete_class_init_qualnames
  id_prefix: io1111ci
  columns: [id, function, args, expected]
  rows:
    - [io1111ci001, io.BufferedReader.__init__.__qualname__.__eq__,  ["BufferedReader.__init__"],  true]
    - [io1111ci002, io.BufferedWriter.__init__.__qualname__.__eq__,  ["BufferedWriter.__init__"],  true]
    - [io1111ci003, io.FileIO.__init__.__qualname__.__eq__,          ["FileIO.__init__"],          true]
    - [io1111ci004, io.BytesIO.__init__.__qualname__.__eq__,         ["BytesIO.__init__"],         true]
    - [io1111ci005, io.StringIO.__init__.__qualname__.__eq__,        ["StringIO.__init__"],        true]
    - [io1111ci006, io.TextIOWrapper.__init__.__qualname__.__eq__,   ["TextIOWrapper.__init__"],   true]
    - [io1111ci007, io.BufferedReader.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"],  true]
    - [io1111ci008, io.BytesIO.__init__.__class__.__name__.__eq__,        ["wrapper_descriptor"],  true]
    - [io1111ci009, io.StringIO.__init__.__class__.__name__.__eq__,       ["wrapper_descriptor"],  true]

table io_extra1111.module_and_concrete_class_module:
  description: "io module __name__ and __spec__.name identity, and concrete class __module__ checks"
  kind: python_call_eq
  category: module_and_concrete_class_module
  id_prefix: io1111mm
  columns: [id, function, args, expected]
  rows:
    - [io1111mm001, io.__name__.__eq__,                   ["io"],    true]
    - [io1111mm002, io.__spec__.name.__eq__,              ["io"],    true]
    - [io1111mm003, io.TextIOWrapper.__name__.__eq__,     ["TextIOWrapper"], true]
    - [io1111mm004, io.TextIOWrapper.__qualname__.__eq__, ["TextIOWrapper"], true]
    - [io1111mm005, io.FileIO.__name__.__eq__,            ["FileIO"],        true]
    - [io1111mm006, io.FileIO.__qualname__.__eq__,        ["FileIO"],        true]
    - [io1111mm007, io.BytesIO.__name__.__eq__,           ["BytesIO"],       true]
    - [io1111mm008, io.StringIO.__name__.__eq__,          ["StringIO"],      true]
    - [io1111mm009, io.IOBase.__module__.__eq__,          ["_io"],           false]
