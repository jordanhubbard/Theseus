spec: decimal_extra281
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Rounding modes and Context class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py, Modules/_decimal/_decimal.c"
  notes:
    - "decimal rounding mode constants are plain string objects (not enum members)"
    - "decimal.ROUND_UP is the string 'ROUND_UP', etc."
    - "decimal.Context.__module__ is 'decimal'"
    - "DefaultContext, BasicContext, ExtendedContext are pre-built Context instances"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table decimal_extra281.rounding_modes:
  description: "Rounding mode string constant values"
  kind: python_call_eq
  category: identity
  id_prefix: dec281r

  columns: [id, function, args, expected, description]
  rows:
    - [dec281r001, decimal.ROUND_UP.__eq__, ["ROUND_UP"], true, "ROUND_UP string value"]
    - [dec281r002, decimal.ROUND_DOWN.__eq__, ["ROUND_DOWN"], true, "ROUND_DOWN string value"]
    - [dec281r003, decimal.ROUND_CEILING.__eq__, ["ROUND_CEILING"], true, "ROUND_CEILING string value"]
    - [dec281r004, decimal.ROUND_FLOOR.__eq__, ["ROUND_FLOOR"], true, "ROUND_FLOOR string value"]
    - [dec281r005, decimal.ROUND_HALF_UP.__eq__, ["ROUND_HALF_UP"], true, "ROUND_HALF_UP string value"]
    - [dec281r006, decimal.ROUND_HALF_DOWN.__eq__, ["ROUND_HALF_DOWN"], true, "ROUND_HALF_DOWN string value"]
    - [dec281r007, decimal.ROUND_HALF_EVEN.__eq__, ["ROUND_HALF_EVEN"], true, "ROUND_HALF_EVEN string value"]
    - [dec281r008, decimal.ROUND_05UP.__eq__, ["ROUND_05UP"], true, "ROUND_05UP string value"]

table decimal_extra281.context_instances:
  description: "DefaultContext, BasicContext, ExtendedContext are Context instances"
  kind: python_call_eq
  category: identity
  id_prefix: dec281i

  columns: [id, function, args, expected, description]
  rows:
    - [dec281i001, decimal.DefaultContext.__class__.__name__.__eq__, ["Context"], true, "DefaultContext is a Context"]
    - [dec281i002, decimal.BasicContext.__class__.__name__.__eq__, ["Context"], true, "BasicContext is a Context"]
    - [dec281i003, decimal.ExtendedContext.__class__.__name__.__eq__, ["Context"], true, "ExtendedContext is a Context"]

invariant decimal_extra281.context_name:
  description: "decimal.Context.__name__ is 'Context'"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra281.context_module:
  description: "decimal.Context.__module__ is 'decimal'"
  category: identity
  kind: python_call_eq
  function: decimal.Context.__module__.__eq__
  args: ["decimal"]
  expected: true

invariant decimal_extra281.context_base:
  description: "decimal.Context.__bases__[0].__name__ is 'object'"
  category: identity
  kind: python_call_eq
  function: "decimal.Context.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
