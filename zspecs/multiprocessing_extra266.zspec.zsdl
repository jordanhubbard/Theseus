spec: multiprocessing_extra266
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/connection.py"
  notes:
    - "This spec covers: multiprocessing.connection module class and function identity. NEW in extra266: multiprocessing.connection.Client.__module__=='multiprocessing.connection' (Client is a function, not a class); multiprocessing.connection.Client.__qualname__=='Client'; multiprocessing.connection.Listener.__module__=='multiprocessing.connection'; multiprocessing.connection.Listener.__mro__.__len__()==2; multiprocessing.connection.Listener.__bases__[0].__name__=='object'; multiprocessing.connection.wait.__module__=='multiprocessing.connection'; multiprocessing.connection.wait.__qualname__=='wait'; multiprocessing.connection.Connection.__module__=='multiprocessing.connection'; multiprocessing.connection.Connection.__mro__.__len__()==3 ([Connection, _ConnectionBase, object]); multiprocessing.connection.Connection.__bases__[0].__name__=='_ConnectionBase'; multiprocessing.connection.deliver_challenge.__module__=='multiprocessing.connection'; multiprocessing.connection.answer_challenge.__module__=='multiprocessing.connection'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.connection.Client is a function, not a class. Client.__class__.__name__ == 'function'; Client is a factory function that returns a Connection object, similar to socket.create_connection(). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "multiprocessing.connection.Connection.__mro__ == [Connection, _ConnectionBase, object] (len=3). Connection inherits from _ConnectionBase which provides the core send/recv logic; _ConnectionBase.__module__ is 'multiprocessing.connection'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.connection Client, Listener, and wait identity — extra266
#
# multiprocessing.connection.Client.__module__    == 'multiprocessing.connection'
# multiprocessing.connection.Client.__qualname__  == 'Client'    (function, not class)
# multiprocessing.connection.Listener.__module__  == 'multiprocessing.connection'
# multiprocessing.connection.Listener.__mro__.__len__() == 2
# multiprocessing.connection.wait.__module__      == 'multiprocessing.connection'
# multiprocessing.connection.wait.__qualname__    == 'wait'
# ---------------------------------------------------------------------------

table multiprocessing_extra266.mp_connection_client_listener_wait:
  description: "multiprocessing.connection Client, Listener, and wait identity checks in mpconnident266 namespace — multiprocessing.connection.Client is a factory function (not a class) that creates a Connection to a Listener; Client.__class__.__name__.__eq__('function')==True; Client.__module__.__eq__('multiprocessing.connection')==True; Client.__qualname__.__eq__('Client')==True (module-level function, qualname equals name); multiprocessing.connection.Listener is a class that binds to an address and accepts connections; Listener.__module__.__eq__('multiprocessing.connection')==True; Listener.__mro__.__len__()==2 ([Listener, object]); Listener.__bases__[0].__name__.__eq__('object')==True (direct subclass of object); Listener.__qualname__.__eq__('Listener')==True; multiprocessing.connection.wait is a function for waiting on multiple connection objects; wait.__module__.__eq__('multiprocessing.connection')==True; wait.__qualname__.__eq__('wait')==True; wait.__class__.__name__.__eq__('function')==True; all three are defined in Lib/multiprocessing/connection.py; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpconnident266

  columns: [id, function, args, expected, description]
  rows:
    - [client_cls,     multiprocessing.connection.Client.__class__.__name__.__eq__,   ["function"],                    true, "multiprocessing.connection.Client.__class__.__name__ == 'function' (Client is a function, not a class); verified with Python 3.14.3"]
    - [client_mod_eq,  multiprocessing.connection.Client.__module__.__eq__,           ["multiprocessing.connection"],  true, "multiprocessing.connection.Client.__module__ == 'multiprocessing.connection'; verified with Python 3.14.3"]
    - [client_qn_eq,   multiprocessing.connection.Client.__qualname__.__eq__,         ["Client"],                      true, "multiprocessing.connection.Client.__qualname__ == 'Client' (module-level function); verified with Python 3.14.3"]
    - [listener_mod,   multiprocessing.connection.Listener.__module__.__eq__,         ["multiprocessing.connection"],  true, "multiprocessing.connection.Listener.__module__ == 'multiprocessing.connection'; verified with Python 3.14.3"]
    - [listener_mro,   multiprocessing.connection.Listener.__mro__.__len__,           [],                              2,    "multiprocessing.connection.Listener.__mro__.__len__() == 2 — [Listener, object]; verified with Python 3.14.3"]
    - [listener_base0, "multiprocessing.connection.Listener.__bases__[0].__name__.__eq__", ["object"],                 true, "multiprocessing.connection.Listener.__bases__[0].__name__ == 'object' — direct subclass; verified with Python 3.14.3"]
    - [listener_qn,    multiprocessing.connection.Listener.__qualname__.__eq__,       ["Listener"],                    true, "multiprocessing.connection.Listener.__qualname__ == 'Listener' (module-level class); verified with Python 3.14.3"]
    - [wait_mod_eq,    multiprocessing.connection.wait.__module__.__eq__,             ["multiprocessing.connection"],  true, "multiprocessing.connection.wait.__module__ == 'multiprocessing.connection'; verified with Python 3.14.3"]
    - [wait_qn_eq,     multiprocessing.connection.wait.__qualname__.__eq__,           ["wait"],                        true, "multiprocessing.connection.wait.__qualname__ == 'wait'; verified with Python 3.14.3"]
    - [wait_cls,       multiprocessing.connection.wait.__class__.__name__.__eq__,     ["function"],                    true, "multiprocessing.connection.wait.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.connection Connection and helpers — extra266
#
# multiprocessing.connection.Connection.__module__             == 'multiprocessing.connection'
# multiprocessing.connection.Connection.__mro__.__len__()      == 3
# multiprocessing.connection.Connection.__bases__[0].__name__  == '_ConnectionBase'
# multiprocessing.connection.deliver_challenge.__module__      == 'multiprocessing.connection'
# multiprocessing.connection.answer_challenge.__module__       == 'multiprocessing.connection'
# multiprocessing.connection.deliver_challenge.__qualname__    == 'deliver_challenge'
# ---------------------------------------------------------------------------

table multiprocessing_extra266.mp_connection_connection_helpers:
  description: "multiprocessing.connection Connection class and helper function identity checks in mpconnident266 namespace — multiprocessing.connection.Connection is a class that wraps a socket or pipe handle; Connection.__module__.__eq__('multiprocessing.connection')==True; Connection.__mro__.__len__()==3 ([Connection, _ConnectionBase, object]); Connection.__bases__[0].__name__.__eq__('_ConnectionBase')==True (Connection inherits from internal _ConnectionBase which provides send/recv/poll logic); Connection.__qualname__.__eq__('Connection')==True; deliver_challenge and answer_challenge are functions implementing HMAC-based authentication; deliver_challenge.__module__.__eq__('multiprocessing.connection')==True; deliver_challenge.__qualname__.__eq__('deliver_challenge')==True; deliver_challenge.__class__.__name__.__eq__('function')==True; answer_challenge.__module__.__eq__('multiprocessing.connection')==True; answer_challenge.__qualname__.__eq__('answer_challenge')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpconnident266a

  columns: [id, function, args, expected, description]
  rows:
    - [conn_mod_eq,    multiprocessing.connection.Connection.__module__.__eq__,            ["multiprocessing.connection"],  true, "multiprocessing.connection.Connection.__module__ == 'multiprocessing.connection'; verified with Python 3.14.3"]
    - [conn_mro_len,   multiprocessing.connection.Connection.__mro__.__len__,              [],                              3,    "multiprocessing.connection.Connection.__mro__.__len__() == 3 — [Connection, _ConnectionBase, object]; verified with Python 3.14.3"]
    - [conn_base0_eq,  "multiprocessing.connection.Connection.__bases__[0].__name__.__eq__", ["_ConnectionBase"],           true, "multiprocessing.connection.Connection.__bases__[0].__name__ == '_ConnectionBase'; verified with Python 3.14.3"]
    - [conn_qn_eq,     multiprocessing.connection.Connection.__qualname__.__eq__,          ["Connection"],                  true, "multiprocessing.connection.Connection.__qualname__ == 'Connection'; verified with Python 3.14.3"]
    - [deliv_mod_eq,   multiprocessing.connection.deliver_challenge.__module__.__eq__,     ["multiprocessing.connection"],  true, "multiprocessing.connection.deliver_challenge.__module__ == 'multiprocessing.connection'; verified with Python 3.14.3"]
    - [deliv_qn_eq,    multiprocessing.connection.deliver_challenge.__qualname__.__eq__,   ["deliver_challenge"],           true, "multiprocessing.connection.deliver_challenge.__qualname__ == 'deliver_challenge'; verified with Python 3.14.3"]
    - [deliv_cls_eq,   multiprocessing.connection.deliver_challenge.__class__.__name__.__eq__, ["function"],                true, "multiprocessing.connection.deliver_challenge.__class__.__name__ == 'function'; verified with Python 3.14.3"]
    - [answ_mod_eq,    multiprocessing.connection.answer_challenge.__module__.__eq__,      ["multiprocessing.connection"],  true, "multiprocessing.connection.answer_challenge.__module__ == 'multiprocessing.connection'; verified with Python 3.14.3"]
    - [answ_qn_eq,     multiprocessing.connection.answer_challenge.__qualname__.__eq__,    ["answer_challenge"],            true, "multiprocessing.connection.answer_challenge.__qualname__ == 'answer_challenge'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra266
# ---------------------------------------------------------------------------

invariant multiprocessing_extra266.Client_is_function_not_class:
  description: "multiprocessing.connection.Client.__class__.__name__.__eq__('function') returns True — multiprocessing.connection.Client is a factory function (not a class); it creates and returns a Connection object connected to a Listener; this contrasts with multiprocessing.connection.Listener which IS a class (Listener.__class__.__name__ is 'type'); Client's signature is Client(address, family=None, authkey=None); Client.__module__ is 'multiprocessing.connection'; Client.__qualname__ is 'Client' (module-level function, qualname equals __name__); Client.__name__ is 'Client'; the function-not-class distinction is significant: you cannot subclass Client, and type(Client) is 'function' not 'type'; NEW in extra266: first standalone Client is-function invariant in mpconnident266 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.connection.Client.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant multiprocessing_extra266.Connection_mro_len_is_3:
  description: "multiprocessing.connection.Connection.__mro__.__len__() == 3 — Connection's MRO is [Connection, _ConnectionBase, object] (length=3); Connection inherits from _ConnectionBase which provides the core send/recv/poll implementation; _ConnectionBase.__module__ is 'multiprocessing.connection'; _ConnectionBase.__mro__.__len__() is 2 ([_ConnectionBase, object]); the 3-element MRO parallels asyncio.Task (Task→Future→object) and asyncio.Protocol (Protocol→BaseProtocol→object); Connection.__module__ is 'multiprocessing.connection'; Connection.__bases__[0].__name__ is '_ConnectionBase' (underscore-prefixed internal class); NEW in extra266: first standalone Connection MRO length invariant in mpconnident266 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.connection.Connection.__mro__.__len__
  args: []
  expected: 3

invariant multiprocessing_extra266.Connection_base_is_ConnectionBase:
  description: "multiprocessing.connection.Connection.__bases__[0].__name__.__eq__('_ConnectionBase') returns True — Connection inherits from _ConnectionBase as its sole direct base; _ConnectionBase is an underscore-prefixed internal class in Lib/multiprocessing/connection.py; it provides the core IPC primitives: send, recv, send_bytes, recv_bytes, poll, fileno, close; Connection overrides or extends these methods as needed; the leading underscore in '_ConnectionBase' signals it is a private implementation detail not intended for direct use; Connection.__mro__.__len__() is 3 ([Connection, _ConnectionBase, object]); NEW in extra266: first standalone Connection base class invariant in mpconnident266 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.connection.Connection.__bases__[0].__name__.__eq__"
  args: ["_ConnectionBase"]
  expected: true

invariant multiprocessing_extra266.Listener_mro_len_is_2:
  description: "multiprocessing.connection.Listener.__mro__.__len__() == 2 — Listener's MRO is [Listener, object] (length=2); Listener is a stand-alone class with no intermediate base; it directly subclasses object; compare with Connection which has MRO length 3 ([Connection, _ConnectionBase, object]) because Connection has an intermediate _ConnectionBase base; Listener.__module__ is 'multiprocessing.connection'; Listener.__bases__[0].__name__ is 'object'; Listener binds to an address and accepts connections from Client(); Listener exposes accept(), close(), address, and last_accepted attributes; NEW in extra266: first standalone Listener MRO length invariant in mpconnident266 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.connection.Listener.__mro__.__len__
  args: []
  expected: 2

invariant multiprocessing_extra266.deliver_challenge_module_is_connection:
  description: "multiprocessing.connection.deliver_challenge.__module__.__eq__('multiprocessing.connection') returns True — deliver_challenge is a pure-Python function defined in Lib/multiprocessing/connection.py that implements the server side of HMAC-based connection authentication; it sends a random challenge and verifies the client's HMAC-signed response; its counterpart answer_challenge (client side) also has __module__ 'multiprocessing.connection'; deliver_challenge.__qualname__ is 'deliver_challenge' (module-level function, qualname equals __name__); deliver_challenge.__class__.__name__ is 'function'; authentication is triggered when Listener or Client are called with an authkey argument; NEW in extra266: first standalone deliver_challenge module invariant in mpconnident266 namespace; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.connection.deliver_challenge.__module__.__eq__
  args: ["multiprocessing.connection"]
  expected: true
