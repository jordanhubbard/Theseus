spec: bandit_rust
version: ">=3.9"
backend: rust_module(bandit_rust)

docs: https://bandit.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://bandit.readthedocs.io/en/latest/ — Bandit documentation"
  not_derived_from:
    - "bandit source: bandit/__init__.py"
  notes:
    - "Bandit is a tool for finding security issues in Python code."
    - "bandit.__version__ is a non-empty string."
    - "bandit.core.manager.BanditManager is available."
    - "bandit.core is available."
    - "Expose bandit_version_nonempty() -> bool: len(bandit.__version__) > 0."
    - "Expose bandit_has_core() -> bool: hasattr(bandit, 'core')."
    - "All test vectors verified against bandit 1.9.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# bandit_version_nonempty — version non-empty
invariant bandit_rust.version.nonempty:
  description: "bandit.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: bandit_version_nonempty
  args: []
  expected: true

# bandit_has_core — core module present
invariant bandit_rust.module.has_core:
  description: "bandit.core is available"
  category: module
  kind: python_call_eq
  function: bandit_has_core
  args: []
  expected: true

