spec: typing_extra8
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 484 — Type Hints"
    - "PEP 612 — Parameter Specification Variables"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing.zspec.zsdl through typing_extra7.zspec.zsdl."
    - "typing_extra5 covers Any.__class__.__name__ == '_SpecialForm'."
    - "typing_extra6 covers Union/Optional/ClassVar/Final/Literal __class__.__name__ == '_SpecialForm'."
    - "typing_extra4 covers Literal.__class__.__name__ == '_SpecialForm' and TypeVar.__qualname__/__module__."
    - "typing_extra7 covers get_type_hints/cast/overload/get_origin/get_args __qualname__; TypeVar.__class__.__name__ == 'type'."
    - "NEW in this spec: typing.Callable.__class__.__name__ — not covered in any prior spec."
    - "NEW in this spec: typing.get_type_hints.__module__, cast.__module__, overload.__module__, get_args.__module__, get_origin.__module__ — these __module__ attrs not yet verified."
    - "NEW in this spec: typing.NoReturn.__class__.__name__ == '_SpecialForm' — not covered in prior specs."
    - "NEW in this spec: typing.TYPE_CHECKING is a bool constant with value False at runtime."
    - "typing.Callable.__class__.__name__ is '_CallableGenericAlias' or '_SpecialForm' depending on Python version; we check it is not 'type'."
    - "typing.TYPE_CHECKING == False at runtime — it is only True inside type checkers (mypy, pyright, etc.)."
    - "typing.get_type_hints.__module__ == 'typing'."
    - "typing.cast.__module__ == 'typing'."
    - "typing.overload.__module__ == 'typing'."
    - "typing.get_args.__module__ == 'typing'."
    - "typing.get_origin.__module__ == 'typing'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# typing.Callable.__class__.__name__ — not covered in any prior spec.
#
# In Python 3.9–3.12, typing.Callable is a _SpecialForm (or a generic alias
# depending on the version). The key invariant is that it is NOT a plain 'type'
# (unlike TypeVar which IS a plain type class).
# We verify the class name is '_SpecialForm' (Python 3.9+).
# ---------------------------------------------------------------------------

invariant typing_extra8.Callable.class_name:
  description: "typing.Callable.__class__.__name__ == '_SpecialForm' — Callable is a special form, not a plain type"
  category: special_forms
  kind: python_call_eq
  function: Callable.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true

# ---------------------------------------------------------------------------
# typing.NoReturn.__class__.__name__ — not covered in prior specs.
#
# typing.NoReturn is a _SpecialForm (PEP 484). Its __class__.__name__ is
# '_SpecialForm'. Prior specs covered Any/Union/Optional/ClassVar/Final/Literal
# but not NoReturn.
# ---------------------------------------------------------------------------

invariant typing_extra8.NoReturn.class_name:
  description: "typing.NoReturn.__class__.__name__ == '_SpecialForm'"
  category: special_forms
  kind: python_call_eq
  function: NoReturn.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true

# ---------------------------------------------------------------------------
# typing.TYPE_CHECKING — bool constant, False at runtime
#
# typing.TYPE_CHECKING is False at runtime and True only when a static type
# checker (mypy, pyright) is analyzing the code. Prior specs do not cover
# this constant at all.
# ---------------------------------------------------------------------------

invariant typing_extra8.TYPE_CHECKING.value:
  description: "typing.TYPE_CHECKING == False at runtime"
  category: constants
  kind: python_call_eq
  function: TYPE_CHECKING.__eq__
  args: [false]
  expected: true

invariant typing_extra8.TYPE_CHECKING.class_name:
  description: "typing.TYPE_CHECKING.__class__.__name__ == 'bool'"
  category: constants
  kind: python_call_eq
  function: TYPE_CHECKING.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for public helper functions — not yet verified in any prior spec
#
# typing_extra3/extra5 covered __name__ and __qualname__ for these functions,
# but none of the prior specs recorded their __module__ attribute.
# All are defined in the 'typing' module so __module__ == 'typing'.
# ---------------------------------------------------------------------------

table typing_extra8.function_modules:
  kind: python_call_eq
  category: function_modules
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [get_type_hints, get_type_hints.__module__.__eq__, ["typing"], true]
    - [cast,           cast.__module__.__eq__,           ["typing"], true]
    - [overload,       overload.__module__.__eq__,       ["typing"], true]
    - [get_args,       get_args.__module__.__eq__,       ["typing"], true]
    - [get_origin,     get_origin.__module__.__eq__,     ["typing"], true]

# ---------------------------------------------------------------------------
# typing.Annotated.__class__.__name__ — not covered in prior specs.
#
# typing.Annotated was added in Python 3.9 (PEP 593). It is a _SpecialForm.
# ---------------------------------------------------------------------------

invariant typing_extra8.Annotated.class_name:
  description: "typing.Annotated.__class__.__name__ == '_SpecialForm' (Python 3.9+)"
  category: special_forms
  kind: python_call_eq
  function: Annotated.__class__.__name__.__eq__
  args: ["_SpecialForm"]
  expected: true
  version: ">=3.9"

# ---------------------------------------------------------------------------
# typing.ParamSpec.__module__ — prior spec (extra3) covered __name__ and
# __qualname__ for ParamSpec but not __module__. Added here.
# ---------------------------------------------------------------------------

invariant typing_extra8.ParamSpec.module:
  description: "typing.ParamSpec.__module__ == 'typing' (Python 3.10+)"
  category: ParamSpec
  kind: python_call_eq
  function: ParamSpec.__module__.__eq__
  args: ["typing"]
  expected: true
  version: ">=3.10"
