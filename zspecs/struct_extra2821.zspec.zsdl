spec: struct_extra2821
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, and __ipow__ absence for Struct, struct.error."
    - "struct_extra2791.zspec.zsdl — covers __iand__, __ior__, and __ixor__ absence for Struct, struct.error."
    - "struct_extra2776.zspec.zsdl — covers __isub__, __imul__, and __itruediv__ absence for Struct, struct.error."
    - "decimal_extra204.zspec.zsdl — covers decimal.Decimal __dict__ membership for arithmetic dunders; same dict-presence pattern."
  notes:
    - "struct.Struct.__dict__.__contains__('__radd__') == False — struct.Struct is a binary format descriptor; it does not define the reflected addition operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__rsub__') == False — struct.Struct does not define the reflected subtraction operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.Struct.__dict__.__contains__('__rmul__') == False — struct.Struct does not define the reflected multiplication operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__radd__') == False — struct.error is an Exception subclass; exception types never define reflected arithmetic operators in their own __dict__; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__rsub__') == False — struct.error does not define the reflected subtraction operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "struct.error.__dict__.__contains__('__rmul__') == False — struct.error does not define the reflected multiplication operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct.__dict__ — __radd__, __rsub__, __rmul__ absence
# struct.Struct is the compiled format object returned by struct.Struct(fmt).
# It exposes pack/unpack/pack_into/unpack_from/iter_unpack methods and the
# size/format attributes. Reflected arithmetic operators (__radd__, __rsub__,
# __rmul__) are invoked when the left operand does not support the operation;
# a binary format descriptor is not a numeric operand, so none are defined.
# ---------------------------------------------------------------------------

table struct_extra2821.struct_dict_radd_rsub_rmul:
  description: "struct.Struct.__dict__ does not contain __radd__, __rsub__, or __rmul__ — Struct is a binary format descriptor, not a numeric operand; reflected arithmetic operators are absent; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2821

  columns: [id, function, args, expected]
  rows:
    - ["st2821-struct-radd", struct.Struct.__dict__.__contains__, ["__radd__"], false]
    - ["st2821-struct-rsub", struct.Struct.__dict__.__contains__, ["__rsub__"], false]
    - ["st2821-struct-rmul", struct.Struct.__dict__.__contains__, ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Table 2: struct.error.__dict__ — __radd__, __rsub__, __rmul__ absence
# struct.error is a subclass of Exception raised on pack/unpack failures.
# Exception types never define reflected arithmetic operators in their own
# __dict__; arithmetic on exceptions is undefined.
# ---------------------------------------------------------------------------

table struct_extra2821.error_dict_radd_rsub_rmul:
  description: "struct.error.__dict__ does not contain __radd__, __rsub__, or __rmul__ — struct.error is an Exception subclass; exception types define no reflected arithmetic operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2821

  columns: [id, function, args, expected]
  rows:
    - ["st2821-error-radd", struct.error.__dict__.__contains__, ["__radd__"], false]
    - ["st2821-error-rsub", struct.error.__dict__.__contains__, ["__rsub__"], false]
    - ["st2821-error-rmul", struct.error.__dict__.__contains__, ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Table 3: struct.Struct.__dict__ — per-dunder detail with descriptions
# ---------------------------------------------------------------------------

table struct_extra2821.struct_dict_detail:
  description: "struct.Struct.__dict__ reflected arithmetic operator absence detail — __radd__, __rsub__, and __rmul__ are not defined because Struct is a packing/unpacking tool, not a bitwise or arithmetic operand; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2821

  columns: [id, function, args, expected, description]
  rows:
    - ["st2821-d-radd", struct.Struct.__dict__.__contains__, ["__radd__"], false, "struct.Struct does not support reflected + — binary format descriptors have no addition semantics"]
    - ["st2821-d-rsub", struct.Struct.__dict__.__contains__, ["__rsub__"], false, "struct.Struct does not support reflected - — right-hand subtraction has no defined meaning for a format descriptor"]
    - ["st2821-d-rmul", struct.Struct.__dict__.__contains__, ["__rmul__"], false, "struct.Struct does not support reflected * — right-hand multiplication is undefined for a binary format descriptor"]

# ---------------------------------------------------------------------------
# Table 4: cross-type summary — Struct and error both lack all three dunders
# ---------------------------------------------------------------------------

table struct_extra2821.all_types_all_dunders_absent:
  description: "struct.Struct and struct.error both lack __radd__, __rsub__, and __rmul__ in __dict__ — neither struct type defines reflected addition, subtraction, or multiplication operators; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  kind: python_call_eq
  category: dict_membership
  id_prefix: st2821

  columns: [id, function, args, expected]
  rows:
    - ["st2821-x-struct-radd", struct.Struct.__dict__.__contains__, ["__radd__"], false]
    - ["st2821-x-struct-rsub", struct.Struct.__dict__.__contains__, ["__rsub__"], false]
    - ["st2821-x-struct-rmul", struct.Struct.__dict__.__contains__, ["__rmul__"], false]
    - ["st2821-x-error-radd",  struct.error.__dict__.__contains__,  ["__radd__"], false]
    - ["st2821-x-error-rsub",  struct.error.__dict__.__contains__,  ["__rsub__"], false]
    - ["st2821-x-error-rmul",  struct.error.__dict__.__contains__,  ["__rmul__"], false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant struct_extra2821.struct_no_radd:
  description: "struct.Struct.__dict__.__contains__('__radd__') == False — struct.Struct does not define the reflected addition operator; it is a binary packing/unpacking tool with no arithmetic semantics; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__radd__"]
  expected: false

invariant struct_extra2821.struct_no_rsub:
  description: "struct.Struct.__dict__.__contains__('__rsub__') == False — struct.Struct does not define the reflected subtraction operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__rsub__"]
  expected: false

invariant struct_extra2821.struct_no_rmul:
  description: "struct.Struct.__dict__.__contains__('__rmul__') == False — struct.Struct does not define the reflected multiplication operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.Struct.__dict__.__contains__
  args: ["__rmul__"]
  expected: false

invariant struct_extra2821.error_no_radd:
  description: "struct.error.__dict__.__contains__('__radd__') == False — struct.error (Exception subclass) does not define the reflected addition operator; exception types carry no arithmetic semantics; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__radd__"]
  expected: false

invariant struct_extra2821.error_no_rsub:
  description: "struct.error.__dict__.__contains__('__rsub__') == False — struct.error does not define the reflected subtraction operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
  args: ["__rsub__"]
  expected: false

invariant struct_extra2821.error_no_rmul:
  description: "struct.error.__dict__.__contains__('__rmul__') == False — struct.error does not define the reflected multiplication operator; confirmed Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-13"
  category: dict_membership
  kind: python_call_eq
  function: struct.error.__dict__.__contains__
