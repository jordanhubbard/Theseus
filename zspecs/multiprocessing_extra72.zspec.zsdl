spec: multiprocessing_extra72
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec extends multiprocessing_extra71.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__/__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/active_children/current_process __qualname__, Pool/Queue __doc__.__class__.__name__=='str', exception __module__ and __len__() tables, context-bound class __qualname__.__len__() tables, Process/Pool method tables, __mro__.__len__() tables, __all__ metadata, class __dict__ tables, class __class__ identity, mp.__all__ membership and length, __loader__/__spec__/__file__/__cached__ class names, __spec__ attributes, code object attribute chains, exception hierarchy, Pool/Process __init__ code object attributes, Process/Pool MRO entry names, exception __name__/__module__, Queue/Pipe __class__.__name__=='method', Process.start/run/join code objects, Lock/Semaphore/Value __class__.__name__=='method'."
    - "This spec covers (mpmore72 namespace): wave 240 theme — multiprocessing Process.__dict__ content + spawn/fork context. NEW in extra72: Process.__dict__.__class__.__name__=='mappingproxy'; Process.__dict__.__contains__('__module__')==True; Process.__dict__.__contains__('__doc__')==True; Process.__dict__.__contains__('_start_method')==True; Process.__dict__.__contains__('_Popen')==True; Process.__dict__.__contains__('_after_fork')==True; Process.__mro__.__len__()==3 (Process, BaseProcess, object); Process.__bases__[0].__name__=='BaseProcess'; multiprocessing.current_process.__class__.__name__=='function'; multiprocessing.active_children.__class__.__name__=='function'."
    - "multiprocessing.Process.__dict__.__class__.__name__ == 'mappingproxy'. The __dict__ of any Python class is a read-only mappingproxy; Process.__dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__contains__('__module__') == True. Process defines __module__ directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__contains__('__doc__') == True. Process defines __doc__ in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__contains__('_start_method') == True. Process (the context-specific subclass) stores _start_method in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__contains__('_Popen') == True. Process stores _Popen (the context-specific Popen class) in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__dict__.__contains__('_after_fork') == True. Process stores the _after_fork method override in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__mro__.__len__() == 3. MRO is (Process, BaseProcess, object) — 3 entries. The context-specific Process class subclasses BaseProcess directly. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess'. The context-specific Process directly subclasses BaseProcess. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.current_process.__class__.__name__ == 'function'. multiprocessing.current_process is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "multiprocessing.active_children.__class__.__name__ == 'function'. multiprocessing.active_children is a plain Python function; __class__.__name__ is 'function'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing Process.__dict__ class name and module/doc content — extra72
#
# Wave 240 theme: Process.__dict__ content + spawn/fork context.
#
# Process.__dict__.__class__.__name__ == 'mappingproxy'
# Process.__dict__.__contains__('__module__') == True
# Process.__dict__.__contains__('__doc__') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra72.Process_dict_class_and_content:
  description: "multiprocessing Process.__dict__ class name and __contains__ checks in mpmore72 namespace — wave 240 theme: Process.__dict__ content; Process.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is read-only mappingproxy); Process.__dict__.__contains__('__module__')==True; Process.__dict__.__contains__('__doc__')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: mpmore72

  columns: [id, function, args, expected, description]
  rows:
    - [process_dict_class_name, Process.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "Process.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [process_dict_has_module, Process.__dict__.__contains__,              ["__module__"],   true, "Process.__dict__.__contains__('__module__') == True — context-specific Process defines __module__ directly; verified with Python 3.14.3"]
    - [process_dict_has_doc,    Process.__dict__.__contains__,              ["__doc__"],      true, "Process.__dict__.__contains__('__doc__') == True — context-specific Process defines __doc__ directly; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process.__dict__ spawn/fork context attrs — extra72
#
# Process.__dict__.__contains__('_start_method') == True
# Process.__dict__.__contains__('_Popen') == True
# Process.__dict__.__contains__('_after_fork') == True
# ---------------------------------------------------------------------------

table multiprocessing_extra72.Process_dict_context_attrs:
  description: "multiprocessing Process.__dict__ context-specific attribute checks in mpmore72 namespace — wave 240 theme: spawn/fork context; Process.__dict__.__contains__('_start_method')==True (context start method stored in __dict__); Process.__dict__.__contains__('_Popen')==True (context-specific Popen class); Process.__dict__.__contains__('_after_fork')==True (context-specific _after_fork override); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: mpmore72a

  columns: [id, function, args, expected, description]
  rows:
    - [process_dict_has_start_method, Process.__dict__.__contains__, ["_start_method"], true, "Process.__dict__.__contains__('_start_method') == True — context-specific start method stored in __dict__; verified with Python 3.14.3"]
    - [process_dict_has_popen,        Process.__dict__.__contains__, ["_Popen"],         true, "Process.__dict__.__contains__('_Popen') == True — context-specific Popen class stored in __dict__; verified with Python 3.14.3"]
    - [process_dict_has_after_fork,   Process.__dict__.__contains__, ["_after_fork"],    true, "Process.__dict__.__contains__('_after_fork') == True — context-specific _after_fork override in __dict__; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing Process MRO and bases checks — extra72
#
# Process.__mro__.__len__() == 3
# Process.__bases__[0].__name__ == 'BaseProcess'
# ---------------------------------------------------------------------------

table multiprocessing_extra72.Process_mro_and_bases:
  description: "multiprocessing Process MRO length and base class checks in mpmore72 namespace — wave 240 theme: Process identity; Process.__mro__.__len__()==3 (Process, BaseProcess, object); Process.__bases__[0].__name__=='BaseProcess' (context-specific Process directly subclasses BaseProcess); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmore72b

  columns: [id, function, args, expected, description]
  rows:
    - [process_mro_len,      Process.__mro__.__len__,                [], 3,              "Process.__mro__.__len__() == 3 — MRO: (Process, BaseProcess, object); verified with Python 3.14.3"]
    - [process_base_name,    "Process.__bases__[0].__name__.__eq__", ["BaseProcess"], true, "Process.__bases__[0].__name__ == 'BaseProcess' — context-specific Process directly subclasses BaseProcess; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing module-level function class names — extra72
#
# multiprocessing.current_process.__class__.__name__ == 'function'
# multiprocessing.active_children.__class__.__name__ == 'function'
# ---------------------------------------------------------------------------

table multiprocessing_extra72.module_function_class_names:
  description: "multiprocessing module-level function __class__.__name__ checks in mpmore72 namespace — wave 240 theme: module-level function identity; current_process.__class__.__name__=='function' (plain Python function); active_children.__class__.__name__=='function' (plain Python function); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmore72c

  columns: [id, function, args, expected, description]
  rows:
    - [current_process_class_name, current_process.__class__.__name__.__eq__, ["function"], true, "multiprocessing.current_process.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]
    - [active_children_class_name, active_children.__class__.__name__.__eq__, ["function"], true, "multiprocessing.active_children.__class__.__name__ == 'function' — plain Python function; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra72
# ---------------------------------------------------------------------------

invariant multiprocessing_extra72.Process_dict_class_name:
  description: "multiprocessing.Process.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — class __dict__ objects are always mappingproxy in CPython; NEW in extra72: first standalone __class__.__name__ invariant for Process.__dict__ in mpmore72 namespace; wave 240; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: Process.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant multiprocessing_extra72.Process_dict_has_start_method:
  description: "multiprocessing.Process.__dict__.__contains__('_start_method') returns True — context-specific Process stores _start_method in its own __dict__; NEW in extra72: first standalone __contains__('_start_method') invariant for Process in mpmore72 namespace; wave 240; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: Process.__dict__.__contains__
  args: ["_start_method"]
  expected: true

invariant multiprocessing_extra72.Process_mro_len:
  description: "multiprocessing.Process.__mro__.__len__() == 3 — MRO is (Process, BaseProcess, object); context-specific Process directly subclasses BaseProcess; NEW in extra72: first standalone __mro__.__len__ invariant for Process in mpmore72 namespace; wave 240; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: Process.__mro__.__len__
  args: []
  expected: 3

invariant multiprocessing_extra72.current_process_class_name:
  description: "multiprocessing.current_process.__class__.__name__.__eq__('function') returns True — multiprocessing.current_process is a plain Python function; __class__.__name__ is 'function'; NEW in extra72: first standalone __class__.__name__ invariant for current_process in mpmore72 namespace; wave 240; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: current_process.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant multiprocessing_extra72.active_children_class_name:
  description: "multiprocessing.active_children.__class__.__name__.__eq__('function') returns True — multiprocessing.active_children is a plain Python function; __class__.__name__ is 'function'; NEW in extra72: first standalone __class__.__name__ invariant for active_children in mpmore72 namespace; wave 240; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: active_children.__class__.__name__.__eq__
  args: ["function"]
  expected: true
