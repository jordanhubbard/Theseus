spec: concurrent_futures_extra163
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
  notes:
    - "This spec covers: concurrent.futures.Future class name, module, and base class identity; concurrent.futures.Executor class name, module, and base class identity. Both Future and Executor are defined in Lib/concurrent/futures/_base.py — their __module__ is 'concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24; '_base'=5 has a leading underscore indicating a private implementation module). Both inherit from object directly: Future.__bases__[0].__name__=='object' and Executor.__bases__[0].__name__=='object'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Future.__name__=='Future' (len=6: 'F'+'u'+'t'+'u'+'r'+'e'=6); concurrent.futures.Future.__module__=='concurrent.futures._base' (len=24); concurrent.futures.Future.__bases__[0].__name__=='object' (Future inherits from object directly; no intermediate base class); compare: asyncio.Future.__module__=='_asyncio' (len=8) vs concurrent.futures.Future.__module__=='concurrent.futures._base' (len=24) — cf Future module is 16 chars longer because cf.Future is pure Python while asyncio.Future is C-accelerated; both classes are named 'Future' (len=6) despite being completely different implementations. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.Executor.__name__=='Executor' (len=8: 'E'+'x'+'e'+'c'+'u'+'t'+'o'+'r'=8); concurrent.futures.Executor.__module__=='concurrent.futures._base' (len=24; same module as Future — both defined in _base.py); concurrent.futures.Executor.__bases__[0].__name__=='object' (Executor inherits from object directly; Executor is an abstract class defining the submit(), map(), and shutdown() interface); compare: ThreadPoolExecutor.__name__.__len__()==18 (from extra161) vs Executor.__name__.__len__()==8; Executor(8) is 10 chars shorter than ThreadPoolExecutor(18) because 'Thread'=6+'Pool'=4=10 is the additional prefix; ProcessPoolExecutor.__name__.__len__()==19 (from extra162) vs Executor(8); Executor module len(24)==TPE module len... wait: TPE module='concurrent.futures.thread'(len=25); Executor module='concurrent.futures._base'(len=24); '_base'=5 < 'thread'=6 by 1 so Executor module(24) < TPE module(25) by 1. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future class identity — extra163
#
# concurrent.futures.Future.__name__.__eq__('Future')                    == True
# concurrent.futures.Future.__name__.__len__()                           == 6
# concurrent.futures.Future.__module__.__eq__('concurrent.futures._base') == True
# concurrent.futures.Future.__module__.__len__()                         == 24
# ---------------------------------------------------------------------------

table concurrent_futures_extra163.cf_future_identity:
  description: "concurrent.futures.Future class name and module identity checks in cffutid163 namespace — concurrent.futures.Future.__name__.__eq__('Future')==True (concurrent.futures.Future is the thread-safe future class for concurrent.futures; Future.__name__=='Future' (len=6: 'F'+'u'+'t'+'u'+'r'+'e'=6); concurrent.futures.Future represents the result of an asynchronous computation submitted to an Executor; it is thread-safe — result() and exception() block the calling thread until the future is done; cancel() can cancel a pending future before it starts executing); concurrent.futures.Future.__name__.__len__()==6 ('Future'=6; same class name length as concurrent.futures.Executor.__name__.__len__()... no: 'Executor'=8; Future(6) < Executor(8) in name length); concurrent.futures.Future.__module__.__eq__('concurrent.futures._base')==True (Future is defined in Lib/concurrent/futures/_base.py; __module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24; '_base'=5 has a leading underscore indicating a private implementation module)); concurrent.futures.Future.__module__.__len__()==24 (compare: ThreadPoolExecutor module len=25 ('concurrent.futures.thread'=25); Executor module len(24) < TPE module len(25) by 1 because '_base'=5 < 'thread'=6); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutid163

  columns: [id, function, args, expected, description]
  rows:
    - [cf_fut_name_eq,  concurrent.futures.Future.__name__.__eq__,    ["Future"],                     true,  "cf.Future.__name__ == 'Future' (len=6: 'Future'=6; thread-safe future class); verified with Python 3.14.3"]
    - [cf_fut_name_len, concurrent.futures.Future.__name__.__len__,   [],                             6,     "cf.Future.__name__.__len__() == 6 ('Future'=6; shorter than Executor=8 by 2); verified with Python 3.14.3"]
    - [cf_fut_mod_eq,   concurrent.futures.Future.__module__.__eq__,  ["concurrent.futures._base"],  true,  "cf.Future.__module__ == 'concurrent.futures._base' (len=24; '_base' private impl module); verified with Python 3.14.3"]
    - [cf_fut_mod_len,  concurrent.futures.Future.__module__.__len__, [],                             24,    "cf.Future.__module__.__len__() == 24 ('concurrent.futures._base'=24; 1 shorter than TPE module=25); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Future base class — extra163
#
# concurrent.futures.Future.__bases__[0].__name__.__eq__('object') == True
# concurrent.futures.Future.__bases__[0].__name__.__len__()        == 6
# ---------------------------------------------------------------------------

table concurrent_futures_extra163.cf_future_base_class:
  description: "concurrent.futures.Future base class checks in cffutbase163 namespace — concurrent.futures.Future.__bases__[0].__name__.__eq__('object')==True (Future inherits from object directly; Future.__bases__ == (<class 'object'>,); Future.__bases__[0].__name__=='object' (len=6: 'o'+'b'+'j'+'e'+'c'+'t'=6); concurrent.futures.Future does not inherit from any intermediate class — it is a standalone thread-safe future implementation with no base class except object; compare: asyncio.Task.__bases__[0].__name__=='Future' (asyncio.Task inherits from asyncio.Future, not object; established in extra166) while cf.Future.__bases__[0].__name__=='object' (cf.Future IS the base); concurrent.futures.Future.__bases__[0].__name__.__len__()==6 ('object'=6: same length as 'Future'=6 — the base class name 'object' has the same length as the derived class name 'Future'; both are 6-char names); concurrent.futures.Executor.__bases__[0].__name__=='object' too (Executor also inherits from object directly; both Future and Executor are top-level concrete/abstract classes rooted at object); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cffutbase163

  columns: [id, function, args, expected, description]
  rows:
    - [cf_fut_base_name_eq,  "concurrent.futures.Future.__bases__[0].__name__.__eq__",  ["object"],  true,  "cf.Future.__bases__[0].__name__ == 'object' (Future inherits directly from object); verified with Python 3.14.3"]
    - [cf_fut_base_name_len, "concurrent.futures.Future.__bases__[0].__name__.__len__", [],          6,     "cf.Future.__bases__[0].__name__.__len__() == 6 ('object'=6; same length as 'Future'=6); verified with Python 3.14.3"]
    - [cf_fut_name_eq2,      concurrent.futures.Future.__name__.__eq__,                 ["Future"],  true,  "cf.Future.__name__ == 'Future' (cross-check; len=6); verified with Python 3.14.3"]
    - [cf_fut_mod_len2,      concurrent.futures.Future.__module__.__len__,               [],          24,    "cf.Future.__module__.__len__() == 24 (cross-check; 'concurrent.futures._base'=24); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Executor class identity — extra163
#
# concurrent.futures.Executor.__name__.__eq__('Executor')                    == True
# concurrent.futures.Executor.__name__.__len__()                             == 8
# concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base')  == True
# concurrent.futures.Executor.__module__.__len__()                           == 24
# ---------------------------------------------------------------------------

table concurrent_futures_extra163.cf_executor_identity:
  description: "concurrent.futures.Executor class name and module identity checks in cfexecid163 namespace — concurrent.futures.Executor.__name__.__eq__('Executor')==True (Executor.__name__=='Executor' (len=8: 'E'+'x'+'e'+'c'+'u'+'t'+'o'+'r'=8); concurrent.futures.Executor is the abstract base class defining the interface for all executor implementations; Executor.submit() raises NotImplementedError — concrete subclasses (ThreadPoolExecutor, ProcessPoolExecutor) must implement it; Executor.map() and Executor.shutdown() have default implementations inherited by both TPE and PPE); concurrent.futures.Executor.__name__.__len__()==8 ('Executor'=8; Executor(8) > Future(6) by 2 chars; 'Executor'=8: 'Execut'=6+'or'=2=8); concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base')==True (same module as Future: Lib/concurrent/futures/_base.py defines both Future and Executor; __module__=='concurrent.futures._base' (len=24)); concurrent.futures.Executor.__module__.__len__()==24 (same length as Future.__module__.__len__()==24 — both are in the same module); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexecid163

  columns: [id, function, args, expected, description]
  rows:
    - [exec_name_eq,  concurrent.futures.Executor.__name__.__eq__,    ["Executor"],                   true,  "cf.Executor.__name__ == 'Executor' (len=8: 'Executor'=8; abstract base class for executors); verified with Python 3.14.3"]
    - [exec_name_len, concurrent.futures.Executor.__name__.__len__,   [],                             8,     "cf.Executor.__name__.__len__() == 8 ('Executor'=8; 2 longer than Future=6); verified with Python 3.14.3"]
    - [exec_mod_eq,   concurrent.futures.Executor.__module__.__eq__,  ["concurrent.futures._base"],  true,  "cf.Executor.__module__ == 'concurrent.futures._base' (len=24; same module as Future); verified with Python 3.14.3"]
    - [exec_mod_len,  concurrent.futures.Executor.__module__.__len__, [],                             24,    "cf.Executor.__module__.__len__() == 24 ('concurrent.futures._base'=24; same as Future module len=24); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.Executor base class and cross-comparison — extra163
#
# concurrent.futures.Executor.__bases__[0].__name__.__eq__('object') == True
# concurrent.futures.Executor.__name__.__len__()                     == 8
# concurrent.futures.Future.__name__.__len__()                       == 6
# ---------------------------------------------------------------------------

table concurrent_futures_extra163.cf_executor_base_and_comparison:
  description: "concurrent.futures.Executor base class and name length comparison in cfexecbase163 namespace — concurrent.futures.Executor.__bases__[0].__name__.__eq__('object')==True (Executor inherits from object directly; Executor.__bases__ == (<class 'object'>,); Executor.__bases__[0].__name__=='object' (len=6); like concurrent.futures.Future, Executor has no intermediate base — it is an abstract class rooted directly at object; Executor.__bases__[0].__name__.__len__()==6 ('object'=6; same as Future.__bases__[0].__name__.__len__()==6 — both base classes are object with the same 6-char name)); concurrent.futures.Executor.__name__.__len__()==8 ('Executor'=8; 2 longer than concurrent.futures.Future.__name__.__len__()==6); concurrent.futures.Future.__name__.__len__()==6 (cross-check; Future(6) < Executor(8) by 2); KEY LENGTH ORDERING in this spec: Future(6) < Executor(8) in class name length; Future module len == Executor module len == 24 (both in concurrent.futures._base); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfexecbase163

  columns: [id, function, args, expected, description]
  rows:
    - [exec_base_name_eq,  "concurrent.futures.Executor.__bases__[0].__name__.__eq__",  ["object"],  true,  "cf.Executor.__bases__[0].__name__ == 'object' (Executor inherits from object directly); verified with Python 3.14.3"]
    - [exec_base_name_len, "concurrent.futures.Executor.__bases__[0].__name__.__len__", [],          6,     "cf.Executor.__bases__[0].__name__.__len__() == 6 ('object'=6; same as Future base=6); verified with Python 3.14.3"]
    - [exec_name_len2,     concurrent.futures.Executor.__name__.__len__,                [],          8,     "cf.Executor.__name__.__len__() == 8 (cross-check; 'Executor'=8 > Future=6 by 2); verified with Python 3.14.3"]
    - [cf_fut_name_len2,   concurrent.futures.Future.__name__.__len__,                  [],          6,     "cf.Future.__name__.__len__() == 6 (cross-check; 'Future'=6 < Executor=8 by 2); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra163
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra163.cf_Future_name_eq:
  description: "concurrent.futures.Future.__name__.__eq__('Future') returns True — concurrent.futures.Future is the thread-safe future class for the concurrent.futures framework; Future.__name__=='Future' (len=6: 'F'+'u'+'t'+'u'+'r'+'e'=6); concurrent.futures.Future is distinct from asyncio.Future despite sharing the same class name: cf.Future is thread-safe and uses threading.Condition for synchronization; asyncio.Future is coroutine-safe and designed for the asyncio event loop; cf.Future.__module__=='concurrent.futures._base' (len=24) while asyncio.Future.__module__=='_asyncio' (len=8) — the module name length difference (24 vs 8) reflects that cf.Future is pure Python while asyncio.Future is C-accelerated; cf.Future.__bases__[0].__name__=='object' (Future inherits directly from object, not from any abstract executor); Future and Executor are both defined in concurrent/futures/_base.py, sharing the same 24-char module path; NEW in extra163: first standalone cf.Future.__name__ identity invariant in cffutid163 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__name__.__eq__
  args: ["Future"]
  expected: true

invariant concurrent_futures_extra163.cf_Future_module_eq:
  description: "concurrent.futures.Future.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures.Future.__module__=='concurrent.futures._base' (len=24: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'_base'=5=24); the '_base' submodule name has a leading underscore indicating it is a private implementation module not intended for direct import; Lib/concurrent/futures/_base.py defines: Future, Executor, CancelledError, TimeoutError, BrokenExecutor, InvalidStateError, _base FUTURES states (PENDING, RUNNING, CANCELLED, etc.); module len(24): 'concurrent'=10 is the longest component; compare: ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25; 'thread'=6 vs '_base'=5; thread submodule is 1 longer); ProcessPoolExecutor.__module__=='concurrent.futures.process' (len=26; 'process'=7 vs '_base'=5; process submodule is 2 longer); _base(24) < thread(25) < process(26) in module path length ordering; NEW in extra163: first standalone cf.Future.__module__ identity invariant in cffutid163 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Future.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra163.cf_Future_base_is_object:
  description: "concurrent.futures.Future.__bases__[0].__name__.__eq__('object') returns True — concurrent.futures.Future.__bases__[0] is object; Future.__bases__[0].__name__=='object' (len=6: 'o'+'b'+'j'+'e'+'c'+'t'=6); concurrent.futures.Future inherits directly from object with no intermediate abstract base class; this design makes Future a standalone concrete class that does not depend on any ABC hierarchy; compare: asyncio.Task.__bases__[0].__name__=='Future' (asyncio.Task inherits from asyncio.Future — established in extra166) vs concurrent.futures.Future.__bases__[0].__name__=='object' (cf.Future itself is a base with no parent beyond object); concurrent.futures.Executor.__bases__[0].__name__=='object' too (Executor also inherits from object directly — both top-level cf classes root at object); 'object'.__len__()==6 == 'Future'.__len__()==6 — base class name and class name share the same 6-char length; NEW in extra163: first standalone cf.Future.__bases__[0].__name__ invariant in cffutbase163 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Future.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant concurrent_futures_extra163.cf_Executor_name_eq:
  description: "concurrent.futures.Executor.__name__.__eq__('Executor') returns True — concurrent.futures.Executor is the abstract base class for all concurrent.futures executor implementations; Executor.__name__=='Executor' (len=8: 'E'+'x'+'e'+'c'+'u'+'t'+'o'+'r'=8); Executor defines the interface: submit(fn, *args, **kwargs) returns a Future, map(fn, *iterables) applies fn to iterables via submit(), shutdown(wait=True) cleans up resources; Executor.submit() raises NotImplementedError forcing subclasses to implement it; ThreadPoolExecutor and ProcessPoolExecutor are the two concrete subclasses provided in the stdlib; Executor.__module__=='concurrent.futures._base' (len=24; same module as Future); Executor.__bases__[0].__name__=='object'; compare: Executor.__name__.__len__()==8 > Future.__name__.__len__()==6 by 2 chars; ThreadPoolExecutor.__name__.__len__()==18 (from extra161) > Executor.__name__.__len__()==8 by 10 chars — the 'ThreadPool' prefix (10 chars) accounts for the entire difference; NEW in extra163: first standalone Executor.__name__ identity invariant in cfexecid163 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.__name__.__eq__
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra163.cf_Executor_module_eq:
  description: "concurrent.futures.Executor.__module__.__eq__('concurrent.futures._base') returns True — concurrent.futures.Executor.__module__=='concurrent.futures._base' (len=24: same module as concurrent.futures.Future; both Executor and Future are defined in Lib/concurrent/futures/_base.py); the co-location of Future and Executor in _base.py reflects their tight coupling: Executor.submit() must return a Future, Executor.map() calls submit() and collects Futures; the _base module serves as the foundation for the entire concurrent.futures framework; Executor module len(24) == Future module len(24) — both share the same module; compare with the concrete executor subclass modules: thread(25) and process(26) are in longer-named submodules; the _base module name ('_base'=5) is shorter than 'thread'=6 and 'process'=7, giving the _base module path (24) the shortest length among the cf submodule paths; NEW in extra163: first standalone Executor.__module__ identity invariant in cfexecid163 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.Executor.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra163.cf_Executor_base_is_object:
  description: "concurrent.futures.Executor.__bases__[0].__name__.__eq__('object') returns True — concurrent.futures.Executor.__bases__[0] is object; Executor.__bases__[0].__name__=='object' (len=6); Executor inherits directly from object; as an abstract class, Executor relies on its own submit() raising NotImplementedError to enforce the abstract interface rather than using abc.ABCMeta and @abstractmethod; this is a design choice: Executor is abstract by convention (submit raises NotImplementedError) rather than by ABC enforcement; Executor.__bases__[0].__name__=='object' and concurrent.futures.Future.__bases__[0].__name__=='object' — both top-level classes in _base.py inherit from object directly; compare: abc.ABC.__bases__[0].__name__=='object' (also object; established via abc prior specs) — the pattern of direct object inheritance is common for framework base classes; NEW in extra163: first standalone Executor.__bases__[0].__name__ invariant in cfexecbase163 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.Executor.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true
