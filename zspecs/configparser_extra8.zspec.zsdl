spec: configparser_extra8
version: ">=3.9"
backend: python_module(configparser)

docs: https://docs.python.org/3/library/configparser.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/configparser.html — Python configparser documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/configparser.py"
  notes:
    - "This spec extends configparser.zspec.zsdl and configparser_extra through configparser_extra7."
    - "configparser_extra covers: ConfigParser/__name__/__module__, RawConfigParser/__name__, Error/__name__, NoSectionError/__name__, and their bases."
    - "configparser_extra2 covers: __module__ table for major classes/exceptions, ConfigParser method names (read, read_string, get, set, add_section, has_section, sections, options, items, write, remove_section, remove_option), Error/__bases__[0].__name__=='Exception', ConfigParser/__class__.__name__=='type', RawConfigParser/__class__.__name__=='type'."
    - "configparser_extra3 covers: __name__ tables, DEFAULTSECT value, MAX_INTERPOLATION_DEPTH value."
    - "configparser_extra4 covers: __qualname__ table for ConfigParser, RawConfigParser, all exceptions."
    - "configparser_extra5 covers: configparser.__name__=='configparser', ConfigParser.__bases__[0].__name__=='RawConfigParser', RawConfigParser.__module__."
    - "configparser_extra6 covers: Interpolation/__bases__[0].__name__, BasicInterpolation/__bases__[0].__name__, ExtendedInterpolation/__bases__[0].__name__, MAX_INTERPOLATION_DEPTH/__class__.__name__=='int'."
    - "configparser_extra7 covers: interpolation sub-exception __bases__[0].__name__ table, DuplicateOptionError/__bases__[0], ParsingError/__bases__[0], DEFAULTSECT/__class__.__name__=='str', MAX_INTERPOLATION_DEPTH ordering invariants."
    - "This spec adds: __bases__.__len__() == 1 for ConfigParser, RawConfigParser, Error, NoSectionError (single-base inheritance); ConfigParser method names not in extra2 (read_dict, has_option, getint, getfloat, getboolean); NoSectionError.__class__.__name__=='type'."
    - "configparser.ConfigParser.__bases__.__len__() == 1 — ConfigParser has exactly one direct base (RawConfigParser)."
    - "configparser.RawConfigParser.__bases__.__len__() == 1 — RawConfigParser has exactly one direct base (MutableMapping mixin chain; Python's configparser defines it with one explicit base)."
    - "configparser.Error.__bases__.__len__() == 1 — Error inherits only from Exception."
    - "configparser.NoSectionError.__bases__.__len__() == 1 — NoSectionError inherits only from Error."
    - "configparser.ConfigParser.read_dict.__name__ == 'read_dict' — extra2 covers read/read_string/get/set/add_section/has_section/sections/options/items/write/remove_section/remove_option but NOT read_dict."
    - "configparser.ConfigParser.has_option.__name__ == 'has_option' — not in any prior method name coverage."
    - "configparser.ConfigParser.getint.__name__ == 'getint' — not in any prior spec."
    - "configparser.ConfigParser.getfloat.__name__ == 'getfloat' — not in any prior spec."
    - "configparser.ConfigParser.getboolean.__name__ == 'getboolean' — not in any prior spec."
    - "configparser.NoSectionError.__class__.__name__ == 'type' — NoSectionError is a class object; extra2 covers ConfigParser/RawConfigParser but not exception classes."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__.__len__() == 1 for ConfigParser, RawConfigParser, Error, NoSectionError.
# Prior specs verify __bases__[0].__name__ for these classes but no spec
# checks the length of the __bases__ tuple (single-inheritance confirmation).
# ---------------------------------------------------------------------------

table configparser_extra8.bases_len:
  kind: python_call_eq
  category: hierarchy
  id_prefix: baselen8

  columns: [id, function, args, expected]
  rows:
    - [ConfigParser,    ConfigParser.__bases__.__len__,    [], 1]
    - [RawConfigParser, RawConfigParser.__bases__.__len__, [], 1]
    - [Error,           Error.__bases__.__len__,           [], 1]
    - [NoSectionError,  NoSectionError.__bases__.__len__,  [], 1]

# ---------------------------------------------------------------------------
# ConfigParser method names not covered in configparser_extra2.
# extra2 covers: read, read_string, get, set, add_section, has_section,
#   sections, options, items, write, remove_section, remove_option.
# This table adds: read_dict, has_option, getint, getfloat, getboolean.
# ---------------------------------------------------------------------------

table configparser_extra8.ConfigParser.additional_method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: mname8

  columns: [id, function, args, expected]
  rows:
    - [read_dict,   ConfigParser.read_dict.__name__.__eq__,   ["read_dict"],   true]
    - [has_option,  ConfigParser.has_option.__name__.__eq__,  ["has_option"],  true]
    - [getint,      ConfigParser.getint.__name__.__eq__,      ["getint"],      true]
    - [getfloat,    ConfigParser.getfloat.__name__.__eq__,    ["getfloat"],    true]
    - [getboolean,  ConfigParser.getboolean.__name__.__eq__,  ["getboolean"],  true]

# ---------------------------------------------------------------------------
# Exception class metaclass check.
# configparser_extra2 verifies ConfigParser.__class__.__name__=='type' and
# RawConfigParser.__class__.__name__=='type', but not any exception class.
# NoSectionError is a class object; its metaclass is 'type'.
# ---------------------------------------------------------------------------

invariant configparser_extra8.NoSectionError.is_type:
  description: "configparser.NoSectionError.__class__.__name__ == 'type' — NoSectionError is a class object"
  category: class_metadata
  kind: python_call_eq
  function: NoSectionError.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant configparser_extra8.Error.is_type:
  description: "configparser.Error.__class__.__name__ == 'type' — Error is a class object"
  category: class_metadata
  kind: python_call_eq
  function: Error.__class__.__name__.__eq__
  args: ["type"]
  expected: true
