spec: io_extra2491
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "Theme: __setitem__, __delitem__, and __missing__ dict-presence — checking whether io classes define mutable item access and missing-key protocol in their class __dict__."
    - "io stream classes are pure I/O objects and define no mutable item access in their own __dict__."
    - "io.BytesIO.__dict__ does NOT contain '__setitem__' (False) — BytesIO is a stream, not a mutable mapping."
    - "io.BytesIO.__dict__ does NOT contain '__delitem__' (False) — BytesIO does not support item deletion."
    - "io.BytesIO.__dict__ does NOT contain '__missing__' (False) — BytesIO has no missing-key protocol."
    - "io.StringIO.__dict__ does NOT contain '__setitem__', '__delitem__', or '__missing__' (all False)."
    - "io.FileIO.__dict__ does NOT contain '__setitem__', '__delitem__', or '__missing__' (all False)."
    - "io.BufferedWriter.__dict__ does NOT contain '__setitem__', '__delitem__', or '__missing__' (all False)."
    - "io.TextIOWrapper.__dict__ does NOT contain '__setitem__', '__delitem__', or '__missing__' (all False)."
    - "Accessing '__setitem__' via io.BytesIO.__dict__.__getitem__ raises KeyError — the key is absent from the mappingproxy."
    - "io.BytesIO.__dict__ DOES contain 'read', 'write', 'seek', 'tell', 'getvalue', 'getbuffer', 'readline', 'truncate' (all True) — stream interface is present."
    - "io.StringIO.__dict__ DOES contain 'read', 'write', 'seek', 'tell', 'getvalue', 'readline' (all True) — text-stream interface is present."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO.__dict__ — mutable item access protocol absence
# BytesIO is a byte-stream, not a mutable mapping.
# __setitem__, __delitem__, and __missing__ are absent from its class __dict__.
# ---------------------------------------------------------------------------

table io_extra2491.BytesIO_mutable_item_absence:
  description: "io.BytesIO.__dict__ does not contain __setitem__, __delitem__, or __missing__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: io2491

  columns: [id, function, args, expected]
  rows:
    - ["io2491001", io.BytesIO.__dict__.__contains__, ["__setitem__"], false]
    - ["io2491002", io.BytesIO.__dict__.__contains__, ["__delitem__"], false]
    - ["io2491003", io.BytesIO.__dict__.__contains__, ["__missing__"], false]

# ---------------------------------------------------------------------------
# io.BytesIO.__dict__ — stream methods that ARE present
# Confirms the stream API is defined directly on BytesIO, providing contrast
# with the absent mutable-mapping protocol entries above.
# ---------------------------------------------------------------------------

table io_extra2491.BytesIO_stream_method_presence:
  description: "io.BytesIO.__dict__ contains its stream methods: read, write, seek, tell, getvalue, getbuffer, readline, truncate"
  kind: python_call_eq
  category: dict_membership
  id_prefix: io2491

  columns: [id, function, args, expected]
  rows:
    - ["io2491004", io.BytesIO.__dict__.__contains__, ["read"],      true]
    - ["io2491005", io.BytesIO.__dict__.__contains__, ["write"],     true]
    - ["io2491006", io.BytesIO.__dict__.__contains__, ["seek"],      true]
    - ["io2491007", io.BytesIO.__dict__.__contains__, ["tell"],      true]
    - ["io2491008", io.BytesIO.__dict__.__contains__, ["getvalue"],  true]
    - ["io2491009", io.BytesIO.__dict__.__contains__, ["getbuffer"], true]
    - ["io2491010", io.BytesIO.__dict__.__contains__, ["readline"],  true]
    - ["io2491011", io.BytesIO.__dict__.__contains__, ["truncate"],  true]

# ---------------------------------------------------------------------------
# io.BytesIO.__dict__.__getitem__ — KeyError for mutable-item protocol keys
# Accessing an absent key via __getitem__ raises KeyError, consistent with
# mappingproxy semantics. Confirms the protocol keys are genuinely absent.
# ---------------------------------------------------------------------------

table io_extra2491.BytesIO_dict_getitem_raises:
  description: "io.BytesIO.__dict__.__getitem__ raises KeyError for __setitem__, __delitem__, __missing__"
  kind: python_call_raises
  category: dict_membership
  id_prefix: io2491

  columns: [id, function, args, expected]
  rows:
    - ["io2491012", io.BytesIO.__dict__.__getitem__, ["__setitem__"], KeyError]
    - ["io2491013", io.BytesIO.__dict__.__getitem__, ["__delitem__"], KeyError]
    - ["io2491014", io.BytesIO.__dict__.__getitem__, ["__missing__"], KeyError]

# ---------------------------------------------------------------------------
# io.StringIO.__dict__ — mutable item access protocol absence
# StringIO is a text-stream, not a mutable mapping.
# __setitem__, __delitem__, and __missing__ are absent from its class __dict__.
# ---------------------------------------------------------------------------

table io_extra2491.StringIO_mutable_item_absence:
  description: "io.StringIO.__dict__ does not contain __setitem__, __delitem__, or __missing__"
