  rows:
    - ["io2491015", io.StringIO.__dict__.__contains__, ["__setitem__"], false]
    - ["io2491016", io.StringIO.__dict__.__contains__, ["__delitem__"], false]
    - ["io2491017", io.StringIO.__dict__.__contains__, ["__missing__"], false]
    - ["io2491018", io.StringIO.__dict__.__contains__, ["read"],        true]
    - ["io2491019", io.StringIO.__dict__.__contains__, ["write"],       true]
