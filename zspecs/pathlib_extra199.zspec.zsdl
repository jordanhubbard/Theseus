spec: pathlib_extra199
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
  notes:
    - "This spec extends pathlib_extra198.zspec.zsdl."
    - "This spec covers pathlib.Path class-level constants and attributes: Path.__name__ len, PurePath.__name__ len, PosixPath.__name__, PosixPath.__module__, PosixPath.__bases__[0].__name__, WindowsPath.__name__, WindowsPath.__module__, WindowsPath.__bases__[0].__name__."
    - "pathlib.Path.__name__ == 'Path' (len=4); confirmed Python 3.14.3 macOS."
    - "pathlib.PurePath.__name__ == 'PurePath' (len=8); confirmed Python 3.14.3 macOS."
    - "pathlib.PosixPath.__name__ == 'PosixPath' (len=9); confirmed Python 3.14.3 macOS."
    - "pathlib.PosixPath.__module__ == 'pathlib' (len=7); PosixPath is implemented in the pure-Python pathlib module; confirmed Python 3.14.3 macOS."
    - "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath inherits directly from Path; confirmed Python 3.14.3 macOS."
    - "pathlib.WindowsPath.__name__ == 'WindowsPath' (len=11); confirmed Python 3.14.3 macOS."
    - "pathlib.WindowsPath.__module__ == 'pathlib' (len=7); same module as PosixPath; confirmed Python 3.14.3 macOS."
    - "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — WindowsPath also inherits directly from Path, symmetrically with PosixPath; confirmed Python 3.14.3 macOS."
    - "Name length ordering: Path(4) < PurePath(8) < PosixPath(9) < WindowsPath(11); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: pathlib class __name__ equality and lengths
# Path(4), PurePath(8), PosixPath(9), WindowsPath(11)
# ---------------------------------------------------------------------------

table pathlib_extra199.class_names:
  description: "pathlib class __name__ values and lengths: Path='Path'(4), PurePath='PurePath'(8), PosixPath='PosixPath'(9), WindowsPath='WindowsPath'(11)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibposix199

  columns: [id, function, args, expected, description]
  rows:
    - [path_name_len,        pathlib.Path.__name__.__len__,        [], 4, "pathlib.Path.__name__.__len__() == 4 — P(1)a(2)t(3)h(4); shortest class name in spec; confirmed Python 3.14.3 macOS"]
    - [purepath_name_len,    pathlib.PurePath.__name__.__len__,    [], 8, "pathlib.PurePath.__name__.__len__() == 8 — P(1)u(2)r(3)e(4)P(5)a(6)t(7)h(8); confirmed Python 3.14.3 macOS"]
    - [posixpath_name_eq,    pathlib.PosixPath.__name__.__eq__,    ["PosixPath"],   true, "pathlib.PosixPath.__name__ == 'PosixPath' (len=9); confirmed Python 3.14.3 macOS"]
    - [windowspath_name_eq,  pathlib.WindowsPath.__name__.__eq__,  ["WindowsPath"], true, "pathlib.WindowsPath.__name__ == 'WindowsPath' (len=11); confirmed Python 3.14.3 macOS"]
    - [posixpath_name_len,   pathlib.PosixPath.__name__.__len__,   [], 9,  "pathlib.PosixPath.__name__.__len__() == 9 — P(1)o(2)s(3)i(4)x(5)P(6)a(7)t(8)h(9); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: pathlib.PosixPath and pathlib.WindowsPath module equality
# both report __module__ == 'pathlib' (len=7)
# ---------------------------------------------------------------------------

table pathlib_extra199.subclass_modules:
  description: "pathlib.PosixPath and pathlib.WindowsPath __module__ values: both == 'pathlib' (len=7)"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibposix199

  columns: [id, function, args, expected, description]
  rows:
    - [posixpath_module_eq,   pathlib.PosixPath.__module__.__eq__,   ["pathlib"], true, "pathlib.PosixPath.__module__ == 'pathlib' (len=7); pure-Python module; confirmed Python 3.14.3 macOS"]
    - [windowspath_module_eq, pathlib.WindowsPath.__module__.__eq__, ["pathlib"], true, "pathlib.WindowsPath.__module__ == 'pathlib' (len=7, same as PosixPath); confirmed Python 3.14.3 macOS"]
    - [posixpath_module_len,  pathlib.PosixPath.__module__.__len__,  [], 7, "pathlib.PosixPath.__module__.__len__() == 7 — p(1)a(2)t(3)h(4)l(5)i(6)b(7); confirmed Python 3.14.3 macOS"]
    - [windowspath_module_len, pathlib.WindowsPath.__module__.__len__, [], 7, "pathlib.WindowsPath.__module__.__len__() == 7 — same length as PosixPath.__module__; confirmed Python 3.14.3 macOS"]
    - [windowspath_name_len,  pathlib.WindowsPath.__name__.__len__,  [], 11, "pathlib.WindowsPath.__name__.__len__() == 11 — W(1)i(2)n(3)d(4)o(5)w(6)s(7)P(8)a(9)t(10)h(11); longest class name in spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: pathlib.PosixPath and pathlib.WindowsPath base class identity
# both inherit from Path as __bases__[0]
# ---------------------------------------------------------------------------

table pathlib_extra199.subclass_bases:
  description: "pathlib.PosixPath and pathlib.WindowsPath base class identity: both __bases__[0].__name__ == 'Path'"
  kind: python_call_eq
  category: identity
  id_prefix: pathlibposix199

  columns: [id, function, args, expected, description]
  rows:
    - [posixpath_base_eq,   "pathlib.PosixPath.__bases__[0].__name__.__eq__",   ["Path"], true, "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath inherits directly from Path; confirmed Python 3.14.3 macOS"]
    - [windowspath_base_eq, "pathlib.WindowsPath.__bases__[0].__name__.__eq__", ["Path"], true, "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — WindowsPath also inherits directly from Path, symmetrically with PosixPath; confirmed Python 3.14.3 macOS"]
    - [posixpath_base_len,  "pathlib.PosixPath.__bases__[0].__name__.__len__",  [], 4, "pathlib.PosixPath.__bases__[0].__name__.__len__() == 4 — base class name 'Path' has 4 characters; same as pathlib.Path.__name__.__len__(); confirmed Python 3.14.3 macOS"]
    - [windowspath_base_len, "pathlib.WindowsPath.__bases__[0].__name__.__len__", [], 4, "pathlib.WindowsPath.__bases__[0].__name__.__len__() == 4 — same base 'Path'=4 as PosixPath; confirmed Python 3.14.3 macOS"]
    - [purepath_name_eq,    pathlib.PurePath.__name__.__eq__,  ["PurePath"], true, "pathlib.PurePath.__name__ == 'PurePath' (len=8); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant pathlib_extra199.path_name_len:
  description: "pathlib.Path.__name__.__len__() == 4 — 'Path' has 4 characters: P(1)a(2)t(3)h(4); Path is the concrete cross-platform path class and has the shortest name among the pathlib hierarchy classes examined in this spec; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.Path.__name__.__len__
  args: []
  expected: 4

invariant pathlib_extra199.purepath_name_len:
  description: "pathlib.PurePath.__name__.__len__() == 8 — 'PurePath' has 8 characters: P(1)u(2)r(3)e(4)P(5)a(6)t(7)h(8); PurePath is the abstract base that provides path manipulation methods without file system access; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PurePath.__name__.__len__
  args: []
  expected: 8

invariant pathlib_extra199.posixpath_name_eq:
  description: "pathlib.PosixPath.__name__ == 'PosixPath' — class name string length 9 ('PosixPath'); PosixPath is the POSIX-specific concrete path class usable on Unix/macOS; its __name__ is the plain class name; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PosixPath.__name__.__eq__
  args: ["PosixPath"]
  expected: true

invariant pathlib_extra199.posixpath_module_eq:
  description: "pathlib.PosixPath.__module__ == 'pathlib' — PosixPath is defined in the pure-Python pathlib module (len=7); unlike io classes that live in the _io C extension, pathlib classes all report __module__=='pathlib'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.PosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra199.posixpath_base_eq:
  description: "pathlib.PosixPath.__bases__[0].__name__ == 'Path' — PosixPath inherits directly from Path (len=4); Path is the concrete cross-platform class and PosixPath specialises it for POSIX systems; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "pathlib.PosixPath.__bases__[0].__name__.__eq__"
  args: ["Path"]
  expected: true

invariant pathlib_extra199.windowspath_name_eq:
  description: "pathlib.WindowsPath.__name__ == 'WindowsPath' — class name string length 11 ('WindowsPath'); WindowsPath is the Windows-specific concrete path class; it has the longest name among the pathlib hierarchy classes examined in this spec; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.WindowsPath.__name__.__eq__
  args: ["WindowsPath"]
  expected: true

invariant pathlib_extra199.windowspath_module_eq:
  description: "pathlib.WindowsPath.__module__ == 'pathlib' — WindowsPath is also defined in the pure-Python pathlib module (len=7); the module is the same as PosixPath.__module__; both concrete path classes live in the same module; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: pathlib.WindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra199.windowspath_base_eq:
  description: "pathlib.WindowsPath.__bases__[0].__name__ == 'Path' — WindowsPath inherits directly from Path (len=4), symmetrically with PosixPath; both PosixPath and WindowsPath are concrete specialisations of Path for their respective platforms; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "pathlib.WindowsPath.__bases__[0].__name__.__eq__"
  args: ["Path"]
  expected: true

