spec: to_number
version: ">=1.0.2"
backend: node(to-number)

docs: https://www.npmjs.com/package/to-number

provenance:
  derived_from:
    - "to-number README — https://www.npmjs.com/package/to-number"
    - "Test vectors verified with to-number via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "to-number source"
  notes:
    - "to-number is an npm package. Install: npm install to-number"
    - "Converts a value to a number. Returns NaN for non-numeric strings and booleans."
    - "Only numeric-returning cases are included; NaN is not JSON-serializable."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table to_number.convert:
  kind: node_module_call_eq
  function: ~
  category: numbers
  id_prefix: tonum

  columns: [id, args, expected]
  rows:
    - [already_num,  [42],     42]
    - [int_string,   ["42"],   42]
    - [float_string, ["3.14"], 3.14]
