spec: threading_extra219
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading.Condition and threading.Event method name checks (wave 384)."
    - "Condition.wait.__name__ == 'wait'; __qualname__ == 'Condition.wait'. Verified with Python 3.14.3."
    - "Condition.notify.__name__ == 'notify'; __qualname__ == 'Condition.notify'. Verified with Python 3.14.3."
    - "Condition.wait_for.__name__ == 'wait_for'; __qualname__ == 'Condition.wait_for'. Verified with Python 3.14.3."
    - "Event.set.__name__ == 'set'; __qualname__ == 'Event.set'. Verified with Python 3.14.3."
    - "Event.wait.__name__ == 'wait'; __qualname__ == 'Event.wait'. Verified with Python 3.14.3."
    - "Event.clear.__name__ == 'clear'; Event.is_set.__name__ == 'is_set'. Verified with Python 3.14.3."
    - "Condition.acquire and Condition.release are bound to the underlying lock (builtin_function_or_method on an instance); class-level wait/notify/wait_for/notify_all are Python functions. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Condition class method __name__ checks
#
# Condition.wait, notify, wait_for, and notify_all are pure-Python methods
# defined in Lib/threading.py. Their __name__ equals the unqualified method
# name, and __qualname__ includes the class name prefix.
#
# Verified with Python 3.14.3:
#   Condition.wait.__name__ == 'wait'
#   Condition.notify.__name__ == 'notify'
#   Condition.wait_for.__name__ == 'wait_for'
#   Condition.notify_all.__name__ == 'notify_all'
# ---------------------------------------------------------------------------

table threading_extra219.condition_method_names:
  description: "threading.Condition class method __name__ checks; wave 384; new to extra219"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra219condnames

  columns: [id, function, args, expected, description]
  rows:
    - [condition_wait_name_eq,
       Condition.wait.__name__.__eq__,
       ["wait"],
       true,
       "threading.Condition.wait.__name__.__eq__('wait') == True — Condition.wait is a pure-Python method in Lib/threading.py; its __name__ is 'wait'; str.__eq__('wait') returns True; new to extra219"]
    - [condition_notify_name_eq,
       Condition.notify.__name__.__eq__,
       ["notify"],
       true,
       "threading.Condition.notify.__name__.__eq__('notify') == True — Condition.notify wakes up one or more threads waiting on the condition; its __name__ is 'notify'; str.__eq__('notify') returns True; new to extra219"]
    - [condition_wait_for_name_eq,
       Condition.wait_for.__name__.__eq__,
       ["wait_for"],
       true,
       "threading.Condition.wait_for.__name__.__eq__('wait_for') == True — Condition.wait_for waits until a predicate returns true; its __name__ is 'wait_for'; str.__eq__('wait_for') returns True; new to extra219"]
    - [condition_notify_all_name_eq,
       Condition.notify_all.__name__.__eq__,
       ["notify_all"],
       true,
       "threading.Condition.notify_all.__name__.__eq__('notify_all') == True — Condition.notify_all wakes all threads waiting on the condition; its __name__ is 'notify_all'; str.__eq__('notify_all') returns True; new to extra219"]

# ---------------------------------------------------------------------------
# Table 2: threading.Condition class method __qualname__ checks
#
# The __qualname__ of a method defined inside a class body includes the class
# name as a prefix in the form 'ClassName.method_name'.
#
# Verified with Python 3.14.3:
#   Condition.wait.__qualname__ == 'Condition.wait'
#   Condition.notify.__qualname__ == 'Condition.notify'
#   Condition.wait_for.__qualname__ == 'Condition.wait_for'
# ---------------------------------------------------------------------------

table threading_extra219.condition_method_qualnames:
  description: "threading.Condition class method __qualname__ checks; wave 384; new to extra219"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra219condqualnames

  columns: [id, function, args, expected, description]
  rows:
    - [condition_wait_qualname_eq,
       Condition.wait.__qualname__.__eq__,
       ["Condition.wait"],
       true,
       "threading.Condition.wait.__qualname__.__eq__('Condition.wait') == True — __qualname__ for a class method includes the class name; 'Condition.wait' identifies the method's defining scope; str.__eq__('Condition.wait') returns True; new to extra219"]
    - [condition_notify_qualname_eq,
       Condition.notify.__qualname__.__eq__,
       ["Condition.notify"],
       true,
       "threading.Condition.notify.__qualname__.__eq__('Condition.notify') == True — __qualname__ includes the class name prefix; str.__eq__('Condition.notify') returns True; new to extra219"]
    - [condition_wait_for_qualname_eq,
       Condition.wait_for.__qualname__.__eq__,
       ["Condition.wait_for"],
       true,
       "threading.Condition.wait_for.__qualname__.__eq__('Condition.wait_for') == True — __qualname__ includes the class name prefix for the wait_for method; str.__eq__('Condition.wait_for') returns True; new to extra219"]

# ---------------------------------------------------------------------------
# Table 3: threading.Event class method __name__ checks
#
# Event.set, wait, clear, and is_set are pure-Python methods defined in
# Lib/threading.py. Their __name__ equals the unqualified method name.
#
# Verified with Python 3.14.3:
#   Event.set.__name__ == 'set'
#   Event.wait.__name__ == 'wait'
#   Event.clear.__name__ == 'clear'
#   Event.is_set.__name__ == 'is_set'
# ---------------------------------------------------------------------------

table threading_extra219.event_method_names:
  description: "threading.Event class method __name__ checks; wave 384; new to extra219"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra219eventnames

  columns: [id, function, args, expected, description]
  rows:
    - [event_set_name_eq,
       Event.set.__name__.__eq__,
       ["set"],
       true,
       "threading.Event.set.__name__.__eq__('set') == True — Event.set sets the internal flag, waking threads waiting in wait(); its __name__ is 'set'; str.__eq__('set') returns True; new to extra219"]
    - [event_wait_name_eq,
       Event.wait.__name__.__eq__,
       ["wait"],
       true,
       "threading.Event.wait.__name__.__eq__('wait') == True — Event.wait blocks until the internal flag is set; its __name__ is 'wait'; str.__eq__('wait') returns True; new to extra219"]
    - [event_clear_name_eq,
       Event.clear.__name__.__eq__,
       ["clear"],
       true,
       "threading.Event.clear.__name__.__eq__('clear') == True — Event.clear resets the internal flag to False; its __name__ is 'clear'; str.__eq__('clear') returns True; new to extra219"]
    - [event_is_set_name_eq,
       Event.is_set.__name__.__eq__,
       ["is_set"],
       true,
       "threading.Event.is_set.__name__.__eq__('is_set') == True — Event.is_set returns True if the internal flag is set; its __name__ is 'is_set'; str.__eq__('is_set') returns True; new to extra219"]

# ---------------------------------------------------------------------------
# Table 4: threading.Event class method __qualname__ checks
#
# The __qualname__ of each Event method includes the class name prefix.
#
# Verified with Python 3.14.3:
#   Event.set.__qualname__ == 'Event.set'
#   Event.wait.__qualname__ == 'Event.wait'
# ---------------------------------------------------------------------------

table threading_extra219.event_method_qualnames:
  description: "threading.Event class method __qualname__ checks; wave 384; new to extra219"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra219eventqualnames

  columns: [id, function, args, expected, description]
  rows:
    - [event_set_qualname_eq,
       Event.set.__qualname__.__eq__,
       ["Event.set"],
       true,
       "threading.Event.set.__qualname__.__eq__('Event.set') == True — __qualname__ of Event.set includes the class name; 'Event.set' identifies the defining class scope; str.__eq__('Event.set') returns True; new to extra219"]
    - [event_wait_qualname_eq,
       Event.wait.__qualname__.__eq__,
       ["Event.wait"],
       true,
       "threading.Event.wait.__qualname__.__eq__('Event.wait') == True — __qualname__ of Event.wait is 'Event.wait'; str.__eq__('Event.wait') returns True; new to extra219"]

# ---------------------------------------------------------------------------
# Table 5: threading.Condition and Event method __name__ length checks
#
# The lengths of method names are stable string invariants.
#
# Verified with Python 3.14.3:
#   len('wait') == 4
#   len('notify') == 6
#   len('wait_for') == 8
#   len('notify_all') == 10
#   len('is_set') == 6
#   len('clear') == 5
# ---------------------------------------------------------------------------

table threading_extra219.method_name_lengths:
  description: "threading.Condition and Event method __name__ length checks; wave 384; new to extra219"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra219namelens

  columns: [id, function, args, expected, description]
  rows:
    - [condition_wait_name_len_4,
       Condition.wait.__name__.__len__,
       [],
       4,
       "threading.Condition.wait.__name__.__len__() == 4 — 'wait' has 4 characters; str.__len__() returns 4; new to extra219"]
    - [condition_notify_name_len_6,
       Condition.notify.__name__.__len__,
       [],
       6,
       "threading.Condition.notify.__name__.__len__() == 6 — 'notify' has 6 characters; str.__len__() returns 6; new to extra219"]
    - [condition_wait_for_name_len_8,
       Condition.wait_for.__name__.__len__,
       [],
       8,
       "threading.Condition.wait_for.__name__.__len__() == 8 — 'wait_for' has 8 characters; str.__len__() returns 8; new to extra219"]
    - [condition_notify_all_name_len_10,
       Condition.notify_all.__name__.__len__,
       [],
       10,
       "threading.Condition.notify_all.__name__.__len__() == 10 — 'notify_all' has 10 characters; str.__len__() returns 10; new to extra219"]
    - [event_is_set_name_len_6,
       Event.is_set.__name__.__len__,
       [],
       6,
       "threading.Event.is_set.__name__.__len__() == 6 — 'is_set' has 6 characters matching 'notify'; str.__len__() returns 6; new to extra219"]
    - [event_clear_name_len_5,
       Event.clear.__name__.__len__,
       [],
       5,
       "threading.Event.clear.__name__.__len__() == 5 — 'clear' has 5 characters; str.__len__() returns 5; new to extra219"]
    - [event_set_name_len_3,
       Event.set.__name__.__len__,
       [],
       3,
       "threading.Event.set.__name__.__len__() == 3 — 'set' has 3 characters; str.__len__() returns 3; new to extra219"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra219
# ---------------------------------------------------------------------------

invariant threading_extra219.condition_wait_name:
  description: "threading.Condition.wait.__name__.__eq__('wait') == True; wave 384; new to extra219"
  kind: python_call_eq
  function: Condition.wait.__name__.__eq__
  args: ["wait"]
  expected: true

