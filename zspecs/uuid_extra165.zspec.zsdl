    - [uuid_init_argc_7_b,   "UUID.__init__.__code__.co_argcount",   [], 7, "uuid.UUID.__init__.__code__.co_argcount is 7 (confirmed; largest value in spec; 7 > 4 > 3 > 2; complete ordering: mro(2)<str(3)<name(4)==mod(4)<argc(7))"]

# ---------------------------------------------------------------------------
# uuid.UUID.__name__.__eq__('UUID') — standalone
#
# uuid.UUID.__name__ is 'UUID' (4 chars, all uppercase). The class is named UUID,
# not Uuid. 'UUID'(4 chars) == uuid.UUID.__module__.__len__()==4 — both are 4 chars.
# Novel anchor under uuidclass165. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra165.UUID_name_eq:
  description: "uuid.UUID.__name__.__eq__('UUID') == True — 'UUID' (4 chars, all uppercase; uuid.UUID is the class for creating and working with 128-bit universally unique identifiers per RFC 4122/9562; the class name 'UUID' is 4 uppercase letters; 'UUID'(4) == 'uuid'.__len__(4) — class name length equals module name length; 'UUID' contrasts with 'uuid' (module name, lowercase): the class uses uppercase while the module uses lowercase; novel anchor: no prior uuid spec anchors UUID.__name__.__eq__('UUID') under uuidclass165; first uuidclass165 standalone for UUID.__name__.__eq__('UUID')"
  category: identity
  kind: python_call_eq
  function: UUID.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__module__.__eq__('uuid') — standalone
#
# uuid.UUID.__module__ is 'uuid' (4 chars, all lowercase). UUID is defined in
# Lib/uuid.py. 'uuid'(4) == 'UUID'(4) in length — same count, different case.
# Novel anchor under uuidclass165. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra165.UUID_module_eq:
  description: "uuid.UUID.__module__.__eq__('uuid') == True — 'uuid' (4 chars, all lowercase; uuid.UUID is defined in the uuid module (Lib/uuid.py); UUID.__module__=='uuid' confirms the class belongs to the uuid module namespace; 'uuid'(4 lowercase) vs 'UUID'(4 uppercase) — same 4-char length, different case (module lowercase, class uppercase); UUID.__module__.__len__()==4==UUID.__name__.__len__()==4: a coincidental equal-length pairing between module and class names; novel anchor: no prior uuid spec anchors UUID.__module__.__eq__('uuid') under uuidclass165; first uuidclass165 standalone for UUID.__module__.__eq__('uuid')"
  category: identity
  kind: python_call_eq
  function: UUID.__module__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_argcount == 7 — standalone
#
# uuid.UUID.__init__.__code__.co_argcount is 7. UUID.__init__ accepts 7 positional
# parameters: self, hex, bytes, bytes_le, fields, int, version. This large argcount
# reflects UUID's flexible multi-representation constructor.
# Novel anchor under uuidclass165. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra165.UUID_init_argcount_7:
  description: "uuid.UUID.__init__.__code__.co_argcount == 7 — uuid.UUID.__init__ has 7 positional parameters tracked by co_argcount: (1) self, (2) hex — a 32-char hex string optionally hyphenated, (3) bytes — 16 big-endian bytes, (4) bytes_le — 16 little-endian bytes, (5) fields — a 6-tuple of (time_low, time_mid, time_hi_version, clock_seq_hi_variant, clock_seq_low, node), (6) int — a 128-bit integer, (7) version — version number 1/3/4/5; UUID's constructor accepts exactly one of hex/bytes/bytes_le/fields/int as input; co_argcount==7 > UUID.__mro__.__len__()==2 by 5: far more parameters than MRO classes; co_argcount==7 > UUID.__name__.__len__()==4 by 3: the parameter count exceeds the class name length; novel anchor: no prior uuid spec anchors UUID.__init__.__code__.co_argcount under uuidclass165; first uuidclass165 standalone for UUID.__init__.__code__.co_argcount==7"
  category: identity
  kind: python_call_eq
  function: UUID.__init__.__code__.co_argcount
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_DNS.__class__.__name__ is 'UUID' (4 chars). NAMESPACE_DNS is the
# predefined UUID namespace for DNS-based name UUIDs. It is a UUID instance.
# uuid_extra161 anchors this; confirmed here under uuidclass165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra165.NAMESPACE_DNS_class_name:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID') == True — 'UUID' (4 chars; uuid.NAMESPACE_DNS is the pre-defined namespace UUID for DNS names: UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8'); it is an instance of the UUID class itself; NAMESPACE_DNS is used as the namespace argument to uuid3() and uuid5() when generating UUIDs from DNS hostnames (e.g. uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org')); NAMESPACE_DNS.__class__.__name__=='UUID'(4) == UUID.__name__(4) — the instance class name equals the class __name__; uuid_extra161 anchors NAMESPACE_DNS.__class__.__name__=='UUID'; this spec confirms under uuidclass165 as a fresh anchor; first uuidclass165 standalone for NAMESPACE_DNS.__class__.__name__.__eq__('UUID')"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID') — standalone
#
# uuid.NAMESPACE_URL.__class__.__name__ is 'UUID' (4 chars). NAMESPACE_URL is the
# predefined namespace UUID for URL-based name UUIDs. Also a UUID instance.
# uuid_extra161 anchors this; confirmed here under uuidclass165.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra165.NAMESPACE_URL_class_name:
  description: "uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID') == True — 'UUID' (4 chars; uuid.NAMESPACE_URL is the predefined namespace UUID for URL names: UUID('6ba7b811-9dad-11d1-80b4-00c04fd430c8'); it differs from NAMESPACE_DNS by only the last hex digit of the time_low field (810 vs 811); NAMESPACE_URL is also used as namespace argument to uuid3()/uuid5() when generating UUIDs from URLs; NAMESPACE_URL.__class__.__name__=='UUID'(4)==NAMESPACE_DNS.__class__.__name__(4) — both namespaces are UUID instances with the same 4-char class name; uuid_extra161 anchors NAMESPACE_URL.__class__.__name__=='UUID'; this spec confirms under uuidclass165 as a fresh anchor; first uuidclass165 standalone for NAMESPACE_URL.__class__.__name__.__eq__('UUID')"
  category: identity
  kind: python_call_eq
  function: NAMESPACE_URL.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

