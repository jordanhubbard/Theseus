spec: uuid_extra165
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra164.zspec.zsdl — covers uuid.UUID.__mro__.__len__()==2 / uuid.SafeUUID.__mro__.__len__()==3 / uuid1/uuid3/uuid4/uuid5 __qualname__ attributes / uuid4.__class__.__name__=='function' (table + invariants)."
    - "uuid_extra163.zspec.zsdl — covers uuid.__name__/__package__/__spec__/__doc__ module-level identity and UUID.__dict__ v1 timestamp fields (table + invariants)."
    - "uuid_extra162.zspec.zsdl — covers uuid.UUID.__dict__.__contains__ for __init__/__new__/__repr__ and UUID.__dict__.__len__()==37 (table + invariants)."
    - "uuid_extra161.zspec.zsdl — covers uuid.NAMESPACE_DNS/__NAMESPACE_URL class names / UUID.__dict__.__contains__ for __int__/__hash__/__eq__/__str__ (table + invariants)."
    - "uuid_extra158.zspec.zsdl — covers uuid.uuid1/__uuid3/__uuid4/__uuid5 .__name__/__module__/__class__.__name__ (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__=='uuid' and uuid.__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in uuid_extra86 through uuid_extra164."
    - "Wave 354 theme: uuid.UUID class identity — uuid.UUID.__name__=='UUID' (len=4); uuid.UUID.__module__=='uuid' (len=4); uuid.UUID.__mro__.__len__()==2; uuid.UUID.__init__.__code__.co_argcount==7; uuid.NAMESPACE_DNS.__class__.__name__=='UUID'; uuid.NAMESPACE_URL.__class__.__name__=='UUID'; uuid.RFC_4122.__class__.__name__=='str'. uuid_extra164 anchors UUID.__mro__.__len__()==2; uuid_extra161 anchors NAMESPACE_DNS/URL class names; this spec anchors UUID.__name__/__module__ lengths and UUID.__init__.__code__.co_argcount and RFC_4122.__class__.__name__ as primary novel content."
    - "uuid.UUID.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'UUID'=4 chars, all uppercase."
    - "uuid.UUID.__name__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0. 'uuid'=4 chars, all lowercase."
    - "uuid.UUID.__module__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__mro__.__len__() == 2. Verified Python 3.14.3 macOS/Darwin 25.4.0. MRO: (uuid.UUID, object) — 2 classes. uuid_extra164 anchors this."
    - "uuid.UUID.__init__.__code__.co_argcount == 7. Verified Python 3.14.3 macOS/Darwin 25.4.0. UUID.__init__ takes: self, hex, bytes, bytes_le, fields, int, version (7 positional parameters)."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0. NAMESPACE_DNS is a UUID instance (a predefined namespace UUID for DNS names). uuid_extra161 anchors this."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'. Verified Python 3.14.3 macOS/Darwin 25.4.0. NAMESPACE_URL is also a UUID instance. uuid_extra161 anchors this."
    - "uuid.RFC_4122.__class__.__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0. uuid.RFC_4122 is the string 'specified in RFC 4122' — a plain str constant describing the UUID variant, NOT an integer."
    - "Note: uuid.UUID.__name__ == 'UUID' and uuid.UUID.__module__ == 'uuid'. Both are 4-char strings ('UUID' uppercase, 'uuid' lowercase). This is a rare coincidence where a class's __name__ length equals its module's __name__ length. 'UUID'(4) == 'uuid'(4) in length though they differ in case."
    - "Note: uuid.UUID.__init__.__code__.co_argcount == 7. UUID.__init__ accepts: self, hex (hex string), bytes (big-endian bytes), bytes_le (little-endian bytes), fields (6-tuple), int (128-bit integer), and version (variant 1/3/4/5). Including self, that's 7 total parameters tracked by co_argcount. This large argcount reflects UUID's flexible construction interface."
    - "Note: uuid.RFC_4122 is a str, not an int. The RFC_4122 constant is the string 'specified in RFC 4122' — it is the textual description of the UUID variant as stored in uuid.UUID.variant. It is NOT a numeric variant code. This is a common misconception."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__name__.__eq__('UUID')
# uuid.UUID.__module__.__eq__('uuid')
# uuid.UUID.__name__.__len__() == 4
# uuid.UUID.__module__.__len__() == 4
#
# Wave 354 theme: UUID class __name__ and __module__ — both 4-char strings.
#
# UUID.__name__ is 'UUID' (4 chars, all uppercase).
# UUID.__module__ is 'uuid' (4 chars, all lowercase).
# Both are 4-char strings — same length, different case.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra165.UUID_name_and_module:
  description: "uuid.UUID.__name__.__eq__('UUID')==True / uuid.UUID.__module__.__eq__('uuid')==True / uuid.UUID.__name__.__len__()==4 / uuid.UUID.__module__.__len__()==4 — UUID.__name__ is 'UUID' (4 chars, all uppercase; UUID.__name__ is the class's own simple name; 'UUID'=4 chars; novel anchor: no prior uuid spec anchors UUID.__name__ via __eq__ call under uuidclass165; first anchor for 'UUID' string equality as primary content); UUID.__module__ is 'uuid' (4 chars, all lowercase; UUID.__module__ is 'uuid' — the module where uuid.UUID is defined (Lib/uuid.py); 'uuid'(4 chars) == UUID.__name__.__len__(4) — a coincidence where class name length equals module name length; novel anchor under uuidclass165); UUID.__name__.__len__() is 4 ('UUID' = 4 chars; __len__() confirms the 4-char class name; 'UUID'(4 uppercase) vs 'uuid'(4 lowercase) — same length, different case; novel __len__ anchor); UUID.__module__.__len__() is 4 ('uuid' = 4 chars; __module__.__len__()==__name__.__len__()==4 — class name and module name have the same 4-char length; this 4-way equality (name=4, module=4, name-len=4, module-len=4) is novel anchor content; first uuidclass165 anchor for UUID name and module)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidclass165

  columns: [id, function, args, expected, description]
  rows:
    - [uuid_name_uuid,    "UUID.__name__.__eq__",    ["UUID"], true, "uuid.UUID.__name__ == 'UUID' (4 chars, uppercase; simple class name; novel anchor via __eq__ call)"]
    - [uuid_mod_uuid,     "UUID.__module__.__eq__",  ["uuid"], true, "uuid.UUID.__module__ == 'uuid' (4 chars, lowercase; defined in Lib/uuid.py; novel anchor)"]
    - [uuid_name_len_4,   "UUID.__name__.__len__",   [],       4,    "uuid.UUID.__name__.__len__() is 4 ('UUID'=4; uppercase; 'UUID'(4)=='uuid'(4) in length; novel __len__ anchor)"]
    - [uuid_mod_len_4,    "UUID.__module__.__len__", [],       4,    "uuid.UUID.__module__.__len__() is 4 ('uuid'=4; lowercase; __name__.__len__()==__module__.__len__()==4; novel anchor)"]

