# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra165.namespace_dns_url_and_rfc4122_class:
  description: "uuid.NAMESPACE_DNS.__class__.__name__.__eq__('UUID')==True / uuid.NAMESPACE_URL.__class__.__name__.__eq__('UUID')==True / uuid.RFC_4122.__class__.__name__.__eq__('str')==True — NAMESPACE_DNS.__class__.__name__ is 'UUID' (4 chars; uuid.NAMESPACE_DNS is a predefined UUID namespace for generating version-3 and version-5 UUIDs from DNS names; its value is UUID('6ba7b810-9dad-11d1-80b4-00c04fd430c8'); NAMESPACE_DNS is an instance of the UUID class itself; uuid_extra161 anchors NAMESPACE_DNS.__class__.__name__=='UUID'; confirmed here under uuidclass165 in combination with RFC_4122); NAMESPACE_URL.__class__.__name__ is 'UUID' (4 chars; uuid.NAMESPACE_URL is the predefined namespace UUID for URL-based name UUIDs; its value is UUID('6ba7b811-9dad-11d1-80b4-00c04fd430c8'); NAMESPACE_URL is also a UUID instance; uuid_extra161 anchors NAMESPACE_URL.__class__.__name__=='UUID'; confirmed here); RFC_4122.__class__.__name__ is 'str' (3 chars; uuid.RFC_4122 is the string constant 'specified in RFC 4122' — the textual description of the UUID variant stored in uuid.UUID.variant; RFC_4122 is NOT an integer variant code but a plain Python str; 'str'(3) < 'UUID'(4) by 1: the RFC_4122 class name is 1 char shorter than the NAMESPACE class name; novel anchor: no prior uuid spec anchors RFC_4122.__class__.__name__ under uuidclass165; first uuidclass165 anchor combining NAMESPACE_DNS/URL and RFC_4122 class names)"
  kind: python_call_eq
  category: identity
  id_prefix: uuidclass165

  columns: [id, function, args, expected, description]
  rows:
    - [ns_dns_cls_uuid,   "NAMESPACE_DNS.__class__.__name__.__eq__", ["UUID"], true, "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' (4 chars; predefined DNS namespace; UUID instance; uuid_extra161 anchors; confirmed here)"]
    - [ns_url_cls_uuid,   "NAMESPACE_URL.__class__.__name__.__eq__", ["UUID"], true, "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' (4 chars; predefined URL namespace; UUID instance; uuid_extra161 anchors; confirmed here)"]
