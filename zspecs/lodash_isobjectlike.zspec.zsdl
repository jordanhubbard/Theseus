spec: lodash_isobjectlike
version: ">=4.0.0"
backend: node(lodash.isobjectlike)

docs: https://lodash.com/docs/#isObjectLike

provenance:
  derived_from:
    - "lodash.isobjectlike README — https://www.npmjs.com/package/lodash.isobjectlike"
    - "Test vectors verified with lodash.isobjectlike@4.0.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.isobjectlike exports the _.isObjectLike function directly as module.exports."
    - "isObjectLike returns true if the value is object-like (not null and typeof is object)."
    - "Arrays, plain objects, and typed arrays are object-like. Null is not."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_isobjectlike.isobjectlike:
  kind: node_module_call_eq
  function: ~
  category: isobjectlike
  id_prefix: liol

  columns: [id, args, expected]
  rows:
    - [plain_obj,  [{"a": 1}],    true]
    - [array,      [[1, 2, 3]],   true]
    - [null_v,     [null],        false]
    - [number,     [42],          false]
    - [string,     ["abc"],       false]

