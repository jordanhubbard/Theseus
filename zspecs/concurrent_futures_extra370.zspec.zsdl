spec: concurrent_futures_extra370
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "BrokenExecutor lives in module concurrent.futures._base and derives from RuntimeError"
    - "Executor lives in module concurrent.futures._base"
    - "Executor.submit.__name__ is 'submit'; __module__ is concurrent.futures._base"
    - "ThreadPoolExecutor lives in concurrent.futures.thread and derives from Executor"
    - "ProcessPoolExecutor lives in concurrent.futures.process and derives from Executor"
    - "BrokenThreadPool and BrokenProcessPool are NOT present in this Python version"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra370.executor_names:
  description: "Verify __name__ attribute of concurrent.futures executor classes"
  kind: python_call_eq
  category: identity
  id_prefix: cf370n

  columns: [id, function, args, expected]
  rows:
    - [cf370n001, concurrent.futures.BrokenExecutor.__name__.__eq__, ["BrokenExecutor"], true]
    - [cf370n002, concurrent.futures.Executor.__name__.__eq__, ["Executor"], true]
    - [cf370n003, concurrent.futures.ThreadPoolExecutor.__name__.__eq__, ["ThreadPoolExecutor"], true]
    - [cf370n004, concurrent.futures.ProcessPoolExecutor.__name__.__eq__, ["ProcessPoolExecutor"], true]

table concurrent_futures_extra370.executor_modules:
  description: "Verify __module__ attribute of concurrent.futures executor classes"
  kind: python_call_eq
  category: identity
  id_prefix: cf370m

  columns: [id, function, args, expected]
  rows:
    - [cf370m001, concurrent.futures.BrokenExecutor.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf370m002, concurrent.futures.Executor.__module__.__eq__, ["concurrent.futures._base"], true]
    - [cf370m003, concurrent.futures.ThreadPoolExecutor.__module__.__eq__, ["concurrent.futures.thread"], true]
    - [cf370m004, concurrent.futures.ProcessPoolExecutor.__module__.__eq__, ["concurrent.futures.process"], true]

table concurrent_futures_extra370.executor_bases:
  description: "Verify __bases__[0].__name__ (immediate base class name) of concurrent.futures executor classes"
  kind: python_call_eq
  category: identity
  id_prefix: cf370b

  columns: [id, function, args, expected]
  rows:
    - [cf370b001, concurrent.futures.BrokenExecutor.__bases__[0].__name__.__eq__, ["RuntimeError"], true]
    - ["cf370b002", "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"], true]
    - ["cf370b003", "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__", ["Executor"], true]

table concurrent_futures_extra370.submit_identity:
  description: "Verify __name__ and __module__ of concurrent.futures.Executor.submit"
  kind: python_call_eq
  category: identity
  id_prefix: cf370s

  columns: [id, function, args, expected]
  rows:
    - [cf370s001, concurrent.futures.Executor.submit.__name__.__eq__, ["submit"], true]
    - [cf370s002, concurrent.futures.Executor.submit.__module__.__eq__, ["concurrent.futures._base"], true]
