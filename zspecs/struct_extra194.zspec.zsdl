spec: struct_extra194
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.__name__ == 'struct' (len=6) — the module's own __name__ attribute."
    - "struct.Struct.__name__ == 'Struct' (len=6) — the Struct class name; same length as module name."
    - "struct.error.__name__ == 'error' (len=5) — the struct exception class name."
    - "struct.pack.__name__ == 'pack' (len=4) — the pack function name; shortest name covered here."
    - "struct.unpack.__name__ == 'unpack' (len=6) — the unpack function name; same length as module name."
    - "struct.calcsize.__name__ == 'calcsize' (len=8) — the calcsize function name."
    - "struct.pack_into.__name__ == 'pack_into' (len=9) — the pack_into function name."
    - "struct.iter_unpack.__name__ == 'iter_unpack' (len=11) — the iter_unpack function name; longest covered here."
    - "Name length ordering: pack(4) < error(5) < struct/Struct/unpack(6) < calcsize(8) < pack_into(9) < iter_unpack(11)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct module and class name lengths — group A
# struct.__name__, struct.Struct.__name__, struct.error.__name__
# ---------------------------------------------------------------------------

table structnamelens194.module_and_class_names_a:
  kind: python_call_eq
  category: name_lengths
  id_prefix: structnamelens194

  columns: [id, function, args, expected, description]
  rows:
    - [module_name_len,  __name__.__len__,        [], 6, "struct.__name__.__len__() == 6 ('struct' has 6 characters)"]
    - [Struct_name_len,  Struct.__name__.__len__,  [], 6, "struct.Struct.__name__.__len__() == 6 ('Struct' has 6 characters, same length as module name)"]
    - [error_name_len,   error.__name__.__len__,   [], 5, "struct.error.__name__.__len__() == 5 ('error' has 5 characters)"]

# ---------------------------------------------------------------------------
# struct pack/unpack function name lengths — group B
# struct.pack.__name__, struct.unpack.__name__, struct.calcsize.__name__
# ---------------------------------------------------------------------------

table structnamelens194.pack_unpack_names_b:
  kind: python_call_eq
  category: name_lengths
  id_prefix: structnamelens194

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_len,      pack.__name__.__len__,      [], 4, "struct.pack.__name__.__len__() == 4 ('pack' has 4 characters; shortest name covered in this spec)"]
    - [unpack_name_len,    unpack.__name__.__len__,    [], 6, "struct.unpack.__name__.__len__() == 6 ('unpack' has 6 characters, same length as module name)"]
    - [calcsize_name_len,  calcsize.__name__.__len__,  [], 8, "struct.calcsize.__name__.__len__() == 8 ('calcsize' has 8 characters)"]

# ---------------------------------------------------------------------------
# struct pack_into/iter_unpack function name lengths — group C
# struct.pack_into.__name__, struct.iter_unpack.__name__
# ---------------------------------------------------------------------------

table structnamelens194.pack_into_iter_names_c:
  kind: python_call_eq
  category: name_lengths
  id_prefix: structnamelens194

  columns: [id, function, args, expected, description]
  rows:
    - [pack_into_name_len,    pack_into.__name__.__len__,    [], 9,  "struct.pack_into.__name__.__len__() == 9 ('pack_into' has 9 characters)"]
    - [iter_unpack_name_len,  iter_unpack.__name__.__len__,  [], 11, "struct.iter_unpack.__name__.__len__() == 11 ('iter_unpack' has 11 characters; longest name covered in this spec)"]
    - [module_name_eq,        __name__.__eq__,               ["struct"], true, "struct.__name__ == 'struct' (the module's canonical name)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant structnamelens194.struct_module_name_len:
  description: "struct.__name__.__len__() == 6 — 'struct' has exactly 6 characters"
  category: name_lengths
  kind: python_call_eq
  function: __name__.__len__
  args: []
  expected: 6

invariant structnamelens194.Struct_class_name_len:
  description: "struct.Struct.__name__.__len__() == 6 — 'Struct' has 6 characters, same length as the module name 'struct'"
  category: name_lengths
  kind: python_call_eq
  function: Struct.__name__.__len__
  args: []
  expected: 6

invariant structnamelens194.error_name_len:
  description: "struct.error.__name__.__len__() == 5 — 'error' has 5 characters; the struct exception class"
  category: name_lengths
  kind: python_call_eq
  function: error.__name__.__len__
  args: []
  expected: 5

invariant structnamelens194.pack_name_len:
  description: "struct.pack.__name__.__len__() == 4 — 'pack' has 4 characters; shortest name covered in this spec"
  category: name_lengths
  kind: python_call_eq
  function: pack.__name__.__len__
  args: []
  expected: 4

invariant structnamelens194.unpack_name_len:
  description: "struct.unpack.__name__.__len__() == 6 — 'unpack' has 6 characters, same length as module name and Struct class name"
  category: name_lengths
  kind: python_call_eq
  function: unpack.__name__.__len__
  args: []
  expected: 6

invariant structnamelens194.calcsize_name_len:
  description: "struct.calcsize.__name__.__len__() == 8 — 'calcsize' has 8 characters"
  category: name_lengths
  kind: python_call_eq
  function: calcsize.__name__.__len__
  args: []
  expected: 8

invariant structnamelens194.pack_into_name_len:
  description: "struct.pack_into.__name__.__len__() == 9 — 'pack_into' has 9 characters"
  category: name_lengths
  kind: python_call_eq
  function: pack_into.__name__.__len__
  args: []
  expected: 9

invariant structnamelens194.iter_unpack_name_len:
  description: "struct.iter_unpack.__name__.__len__() == 11 — 'iter_unpack' has 11 characters; longest name covered in this spec"
  category: name_lengths
  kind: python_call_eq
  function: iter_unpack.__name__.__len__
  args: []
  expected: 11
