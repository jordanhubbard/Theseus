spec: hashlib_extra503
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib sha3 family and utility functions"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers sha3 family, shake variants, blake2 family, new, and pbkdf2_hmac __qualname__ identity"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra503.qualname_checks:
  description: "hashlib sha3 family and utility function __qualname__ identity checks"
  kind: python_call_eq
  category: identity
  id_prefix: HE503

  columns: [id, function, args, expected]
  rows:
    - [id001, hashlib.sha3_256.__qualname__.__eq__, ["sha3_256"], true]
    - [id002, hashlib.sha3_512.__qualname__.__eq__, ["sha3_512"], true]
    - [id003, hashlib.sha3_224.__qualname__.__eq__, ["sha3_224"], true]
    - [id004, hashlib.sha3_384.__qualname__.__eq__, ["sha3_384"], true]
    - [id005, hashlib.shake_128.__qualname__.__eq__, ["shake_128"], true]
    - [id006, hashlib.shake_256.__qualname__.__eq__, ["shake_256"], true]
    - [id007, hashlib.blake2b.__qualname__.__eq__, ["blake2b"], true]
    - [id008, hashlib.blake2s.__qualname__.__eq__, ["blake2s"], true]
    - [id009, hashlib.new.__qualname__.__eq__, ["new"], true]
    - [id010, hashlib.pbkdf2_hmac.__qualname__.__eq__, ["pbkdf2_hmac"], true]
