  id_prefix: hl2731

  columns: [id, function, args, expected]
  rows:
    - ["hl2731004", "type(hashlib.new('sha256')).__dict__.__contains__", ["__floor__"], false]
    - ["hl2731005", "hashlib.blake2b.__dict__.__contains__",             ["__floor__"], false]
    - ["hl2731006", "hashlib.blake2s.__dict__.__contains__",             ["__floor__"], false]

# ---------------------------------------------------------------------------
# __ceil__ dict-presence — absent from all hashlib classes
# ---------------------------------------------------------------------------

table hashlib_extra2731.ceil_protocol:
  description: "__ceil__ is absent from all hashlib class __dict__s — none implement ceiling rounding"
  kind: python_call_eq
