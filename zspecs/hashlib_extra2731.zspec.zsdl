spec: hashlib_extra2731
version: ">=3.9"
backend: python_module(hashlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/hashlib.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 629 theme: __trunc__, __floor__, and __ceil__ dict-presence checks (numeric rounding protocol)."
    - "hashlib.HASH (the internal _hashlib.HASH type) is a hash object; it does not implement numeric rounding protocols."
    - "hashlib.blake2b is a hash constructor class; it similarly defines none of __trunc__, __floor__, or __ceil__."
    - "hashlib.blake2s is a hash constructor class; it similarly defines none of __trunc__, __floor__, or __ceil__."
    - "None of the hashlib public classes define __trunc__, __floor__, or __ceil__ in their own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __trunc__ dict-presence — absent from all hashlib classes
# ---------------------------------------------------------------------------

table hashlib_extra2731.trunc_protocol:
  description: "__trunc__ is absent from all hashlib class __dict__s — none implement numeric truncation"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2731

  columns: [id, function, args, expected]
  rows:
    - ["hl2731001", "type(hashlib.new('sha256')).__dict__.__contains__", ["__trunc__"], false]
    - ["hl2731002", "hashlib.blake2b.__dict__.__contains__",             ["__trunc__"], false]
    - ["hl2731003", "hashlib.blake2s.__dict__.__contains__",             ["__trunc__"], false]

# ---------------------------------------------------------------------------
