  columns: [id, function, args, expected]
  rows:
    - ["hl2731007", "type(hashlib.new('sha256')).__dict__.__contains__", ["__ceil__"], false]
    - ["hl2731008", "hashlib.blake2b.__dict__.__contains__",             ["__ceil__"], false]
    - ["hl2731009", "hashlib.blake2s.__dict__.__contains__",             ["__ceil__"], false]

# ---------------------------------------------------------------------------
# Combined view — blake2b and blake2s vs. all three rounding protocols
# ---------------------------------------------------------------------------

table hashlib_extra2731.blake_rounding_combined:
  description: "hashlib.blake2b and hashlib.blake2s define none of __trunc__, __floor__, __ceil__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl2731

  columns: [id, function, args, expected]
  rows:
    - ["hl2731010", "hashlib.blake2b.__dict__.__contains__", ["__trunc__"], false]
    - ["hl2731011", "hashlib.blake2b.__dict__.__contains__", ["__floor__"], false]
    - ["hl2731012", "hashlib.blake2b.__dict__.__contains__", ["__ceil__"],  false]
    - ["hl2731013", "hashlib.blake2s.__dict__.__contains__", ["__trunc__"], false]
    - ["hl2731014", "hashlib.blake2s.__dict__.__contains__", ["__floor__"], false]
    - ["hl2731015", "hashlib.blake2s.__dict__.__contains__", ["__ceil__"],  false]
