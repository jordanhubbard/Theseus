spec: uuid_extra200
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 9562 — Universally Unique IDentifiers (UUID)"

provenance:
  derived_from:
    - "Python uuid documentation — https://docs.python.org/3/library/uuid.html"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "This spec extends uuid.zspec.zsdl and uuid_extra.zspec.zsdl; it does NOT duplicate invariants already present there."
    - "uuid_extra.zspec.zsdl covers: UUID.__name__, UUID.__module__, uuid1/3/4/5 __name__ attrs, uuid4 return type and version, NAMESPACE_* class names, UUID.int and UUID.hex class names."
    - "uuid.UUID.__dict__ contains property descriptors for all UUID attributes: urn, fields, time_low, time_mid, time_hi_version, clock_seq, bytes, hex, version, variant, int, node."
    - "NAMESPACE_DNS, NAMESPACE_URL are both instances of uuid.UUID; their __class__.__name__ == 'UUID'."
    - "UUID.__dict__ membership is tested here via __contains__ to verify the class exposes expected property descriptors."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__dict__ membership — core property descriptors
# These are properties defined on the UUID class itself (not instance attributes).
# ---------------------------------------------------------------------------

table uuidannotations200.UUID_dict.core_props:
  description: "uuid.UUID.__dict__ contains core property descriptors for UUID attributes"
  kind: python_call_eq
  category: class_metadata
  id_prefix: uuidannotations200_dict_core

  columns: [id, function, args, expected, description]
  rows:
    - [urn,      "UUID.__dict__.__contains__", ["urn"],      true, "UUID.__dict__ contains 'urn' property descriptor"]
    - [fields,   "UUID.__dict__.__contains__", ["fields"],   true, "UUID.__dict__ contains 'fields' property descriptor"]
    - [time_low, "UUID.__dict__.__contains__", ["time_low"], true, "UUID.__dict__ contains 'time_low' property descriptor"]
    - [time_mid, "UUID.__dict__.__contains__", ["time_mid"], true, "UUID.__dict__ contains 'time_mid' property descriptor"]

# ---------------------------------------------------------------------------
# UUID.__dict__ membership — additional property descriptors
# ---------------------------------------------------------------------------

table uuidannotations200.UUID_dict.extra_props:
  description: "uuid.UUID.__dict__ contains additional property descriptors"
  kind: python_call_eq
  category: class_metadata
  id_prefix: uuidannotations200_dict_extra

  columns: [id, function, args, expected, description]
  rows:
    - [time_hi_version, "UUID.__dict__.__contains__", ["time_hi_version"], true, "UUID.__dict__ contains 'time_hi_version' property descriptor"]
    - [clock_seq,       "UUID.__dict__.__contains__", ["clock_seq"],       true, "UUID.__dict__ contains 'clock_seq' property descriptor"]
    - [version,         "UUID.__dict__.__contains__", ["version"],         true, "UUID.__dict__ contains 'version' property descriptor"]
    - [node,            "UUID.__dict__.__contains__", ["node"],            true, "UUID.__dict__ contains 'node' property descriptor"]

# ---------------------------------------------------------------------------
# NAMESPACE_* constants — class name checks
# NAMESPACE_DNS and NAMESPACE_URL are pre-defined UUID constants.
# These are distinct from uuid_extra.zspec.zsdl which checks all four NAMESPACE_* constants
# via a table; here we test standalone invariants for DNS and URL specifically.
# ---------------------------------------------------------------------------

table uuidannotations200.namespace_constants.class_names:
  description: "NAMESPACE_DNS and NAMESPACE_URL are UUID instances; their __class__.__name__ == 'UUID'"
  kind: python_call_eq
  category: namespace_constants
  id_prefix: uuidannotations200_ns

  columns: [id, function, args, expected, description]
  rows:
    - [dns_class,  NAMESPACE_DNS.__class__.__name__.__eq__,  ["UUID"], true, "NAMESPACE_DNS.__class__.__name__ == 'UUID'"]
    - [url_class,  NAMESPACE_URL.__class__.__name__.__eq__,  ["UUID"], true, "NAMESPACE_URL.__class__.__name__ == 'UUID'"]
    - [oid_class,  NAMESPACE_OID.__class__.__name__.__eq__,  ["UUID"], true, "NAMESPACE_OID.__class__.__name__ == 'UUID'"]
    - [x500_class, NAMESPACE_X500.__class__.__name__.__eq__, ["UUID"], true, "NAMESPACE_X500.__class__.__name__ == 'UUID'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuidannotations200.UUID_dict.contains_urn:
