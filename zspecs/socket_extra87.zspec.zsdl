spec: socket_extra87
version: ">=3.9"
extends: socket_extra86
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra86.zspec.zsdl — covers socket.socket/__module__/__qualname__/__mro__.__len__()==3/__bases__[0].__name__/__eq__ / AF_INET/SOCK_STREAM/__class__/__name__/__qualname__/__eq__ / AddressFamily/SocketKind/__bases__[0].__name__/__eq__/__qualname__/__eq__ / socket.error/__name__/__eq__/'OSError' / socket.timeout/__name__/__eq__/'TimeoutError' / socket.socket/__dict__/__class__.__name__=='mappingproxy' (table + invariants)."
    - "socket_extra85.zspec.zsdl — covers socket.socket.__dict__.__contains__ for accept/close/__init__/makefile/detach/dup/sendfile/__enter__/__exit__/__repr__/family/type/get_inheritable/set_inheritable (table + invariants)."
    - "socket_extra84.zspec.zsdl — covers INADDR_ANY/INADDR_BROADCAST/INADDR_LOOPBACK/INADDR_NONE class and value identity / SHUT_RD/SHUT_WR/SHUT_RDWR / SOL_TCP (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra86; it does NOT duplicate invariants present in those files."
    - "Wave 253 theme: socket module-level function __qualname__ string equality and socket.socket class __name__/__module__/__qualname__ identity."
    - "socket.socket.__name__.__eq__('socket') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__qualname__.__eq__('socket') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__.__eq__('socket') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__qualname__.__eq__('create_connection') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_server.__qualname__.__eq__('create_server') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__qualname__.__eq__('getfqdn') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getaddrinfo.__qualname__.__eq__('getaddrinfo') == True — getaddrinfo is a Python wrapper function in socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__qualname__.__eq__('gethostname') == True — gethostname is a builtin_function_or_method from _socket. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__qualname__.__eq__('gethostbyname') == True — gethostbyname is a builtin_function_or_method from _socket. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.setdefaulttimeout.__qualname__.__eq__('setdefaulttimeout') == True — setdefaulttimeout is a builtin_function_or_method from _socket. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('__init__') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('accept') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__dict__.__contains__('close') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket/__name__/__eq__('socket')
# socket.socket/__module__/__eq__('socket')
# socket.socket/__qualname__/__eq__('socket')
# socket.socket/__mro__/__len__() == 3
#
# Wave 253 theme: socket.socket class name/module/qualname identity.
#
# socket_extra86 anchors __module__/__qualname__/__mro__.__len__() and
# __bases__[0].__name__ already. This table cross-anchors __name__/__eq__
# and re-anchors __module__/__qualname__/__mro__.__len__ under the new
# id_prefix socketnamemod87.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra87.socket_class_name_module:
  description: "socket.socket/__name__/__eq__('socket')==True / socket.socket/__module__/__eq__('socket')==True / socket.socket/__qualname__/__eq__('socket')==True / socket.socket/__mro__/__len__()==3 — socket.socket is the Python-level wrapper class in socket.py; __name__, __module__, and __qualname__ are all 'socket'; MRO has 3 entries [socket.socket, _socket.socket, object]; socket_extra86 anchors __module__/__qualname__/__mro__.__len__; this table anchors __name__/__eq__ and cross-anchors the others under socketnamemod87; first __name__.__eq__ anchor for socket.socket class under socketnamemod87"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketnamemod87

  columns: [id, function, args, expected]
  rows:
    - [socket_cls_name_eq,     socket.__name__.__eq__,     ["socket"], true]
    - [socket_cls_module_eq,   socket.__module__.__eq__,   ["socket"], true]
    - [socket_cls_qualname_eq, socket.__qualname__.__eq__,  ["socket"], true]
    - [socket_cls_mro_len_3,   socket.__mro__.__len__,      [],         3]

# ---------------------------------------------------------------------------
# socket.create_connection/__qualname__/__eq__('create_connection')
# socket.create_server/__qualname__/__eq__('create_server')
# socket.getfqdn/__qualname__/__eq__('getfqdn')
# socket.getaddrinfo/__qualname__/__eq__('getaddrinfo')
#
# Wave 253 theme: Python-level socket module function __qualname__ string equality.
#
# create_connection, create_server, getfqdn, and getaddrinfo are all Python
# functions defined in socket.py with simple unqualified __qualname__ strings.
# No prior socket spec checks __qualname__.__eq__ for these four functions.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra87.socket_python_func_qualnames:
  description: "socket.create_connection/__qualname__/__eq__('create_connection')==True / socket.create_server/__qualname__/__eq__('create_server')==True / socket.getfqdn/__qualname__/__eq__('getfqdn')==True / socket.getaddrinfo/__qualname__/__eq__('getaddrinfo')==True — create_connection/create_server/getfqdn/getaddrinfo are Python functions in socket.py with simple unqualified __qualname__ strings; no prior socket spec checks __qualname__.__eq__ for these; first __qualname__.__eq__ anchor for socket.create_connection/create_server/getfqdn/getaddrinfo"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketnamemod87

  columns: [id, function, args, expected]
  rows:
    - [create_connection_qualname_eq, create_connection.__qualname__.__eq__, ["create_connection"], true]
    - [create_server_qualname_eq,     create_server.__qualname__.__eq__,     ["create_server"],     true]
    - [getfqdn_qualname_eq,           getfqdn.__qualname__.__eq__,           ["getfqdn"],           true]
    - [getaddrinfo_qualname_eq,       getaddrinfo.__qualname__.__eq__,       ["getaddrinfo"],       true]

# ---------------------------------------------------------------------------
# socket.gethostname/__qualname__/__eq__('gethostname')
# socket.gethostbyname/__qualname__/__eq__('gethostbyname')
# socket.setdefaulttimeout/__qualname__/__eq__('setdefaulttimeout')
# socket.socket/__name__/__eq__('socket') (cross-check)
#
# Wave 253 theme: builtin socket function __qualname__ string equality.
#
# gethostname, gethostbyname, and setdefaulttimeout are builtin_function_or_method
# objects from _socket. They still carry a __qualname__ attribute equal to
# their bare name. socket.__name__ cross-checks the class identity table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra87.socket_builtin_func_qualnames:
  description: "socket.gethostname/__qualname__/__eq__('gethostname')==True / socket.gethostbyname/__qualname__/__eq__('gethostbyname')==True / socket.setdefaulttimeout/__qualname__/__eq__('setdefaulttimeout')==True / socket.socket/__name__/__eq__('socket')==True — gethostname/gethostbyname/setdefaulttimeout are builtin_function_or_method objects from _socket; they carry a __qualname__ equal to their name; socket.__name__ cross-checks class identity; no prior socket spec checks __qualname__.__eq__ for these builtins; first __qualname__.__eq__ anchor for socket.gethostname/gethostbyname/setdefaulttimeout"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketnamemod87

  columns: [id, function, args, expected]
  rows:
    - [gethostname_qualname_eq,      gethostname.__qualname__.__eq__,      ["gethostname"],      true]
    - [gethostbyname_qualname_eq,    gethostbyname.__qualname__.__eq__,    ["gethostbyname"],    true]
    - [setdefaulttimeout_qualname_eq, setdefaulttimeout.__qualname__.__eq__, ["setdefaulttimeout"], true]
    - [socket_cls_name_eq2,          socket.__name__.__eq__,               ["socket"],           true]

# ---------------------------------------------------------------------------
# socket.socket/__dict__/__contains__('__init__') == True
# socket.socket/__dict__/__contains__('accept') == True
# socket.socket/__dict__/__contains__('close') == True
# socket.socket/__dict__/__contains__('dup') == True
#
# Wave 253 theme: socket.socket __dict__ membership cross-check.
#
# socket_extra85 anchors __dict__.__contains__ for __init__/accept/close/dup.
# This table cross-anchors them under socketnamemod87.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra87.socket_dict_membership:
  description: "socket.socket/__dict__/__contains__('__init__')==True / socket.socket/__dict__/__contains__('accept')==True / socket.socket/__dict__/__contains__('close')==True / socket.socket/__dict__/__contains__('dup')==True — __init__/accept/close/dup are Python methods defined in socket.py and present in socket.socket.__dict__; socket_extra85 anchors these; this table cross-anchors them under socketnamemod87 alongside the function qualname tables; first socketnamemod87 anchor for socket.socket dict membership"
  kind: python_call_eq
  category: class_attrs
  id_prefix: socketnamemod87

  columns: [id, function, args, expected]
  rows:
    - [socket_dict_has_init,   "socket.__dict__.__contains__", ["__init__"], true]
    - [socket_dict_has_accept, "socket.__dict__.__contains__", ["accept"],   true]
    - [socket_dict_has_close,  "socket.__dict__.__contains__", ["close"],    true]
    - [socket_dict_has_dup,    "socket.__dict__.__contains__", ["dup"],      true]

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket') — standalone
#
# socket.socket.__name__ is 'socket'. socket_extra86 anchors __qualname__.__eq__
# and __module__.__eq__ for the socket class but not __name__.__eq__.
# No prior socket spec checks socket.socket.__name__.__eq__ as a call.
# First __name__.__eq__ standalone for socket.socket class.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra87.socket_cls_name_eq:
  description: "socket.socket.__name__.__eq__('socket') == True — socket.socket is the Python-level wrapper class in socket.py; its __name__ is 'socket' (same as the module name and __qualname__); socket_extra86 anchors __qualname__.__eq__ and __module__.__eq__; this standalone anchors __name__.__eq__; first __name__.__eq__ standalone for socket.socket class"
  category: class_attrs
  kind: python_call_eq
  function: socket.__name__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_connection.__qualname__.__eq__('create_connection') — standalone
#
# socket.create_connection.__qualname__ is 'create_connection'. No prior socket
# spec checks create_connection.__qualname__.__eq__ as a call.
# First __qualname__.__eq__ standalone for socket.create_connection.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra87.create_connection_qualname_eq:
  description: "socket.create_connection.__qualname__.__eq__('create_connection') == True — socket.create_connection is a Python function in socket.py that creates a TCP connection; its __qualname__ is the bare name 'create_connection'; no prior socket spec checks create_connection.__qualname__.__eq__; first __qualname__.__eq__ standalone for socket.create_connection"
  category: class_attrs
  kind: python_call_eq
  function: create_connection.__qualname__.__eq__
  args: ["create_connection"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostname.__qualname__.__eq__('gethostname') — standalone
#
# socket.gethostname.__qualname__ is 'gethostname'. gethostname is a
# builtin_function_or_method from _socket that still carries a __qualname__.
# No prior socket spec checks gethostname.__qualname__.__eq__ as a call.
# First __qualname__.__eq__ standalone for socket.gethostname.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra87.gethostname_qualname_eq:
  description: "socket.gethostname.__qualname__.__eq__('gethostname') == True — socket.gethostname is a builtin_function_or_method from _socket; despite being a C-level function it carries a __qualname__ attribute equal to its bare name 'gethostname'; no prior socket spec checks gethostname.__qualname__.__eq__; first __qualname__.__eq__ standalone for socket.gethostname"
  category: class_attrs
  kind: python_call_eq
  function: gethostname.__qualname__.__eq__
  args: ["gethostname"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getfqdn.__qualname__.__eq__('getfqdn') — standalone
#
# socket.getfqdn.__qualname__ is 'getfqdn'. getfqdn is a Python function in
# socket.py. No prior socket spec checks getfqdn.__qualname__.__eq__ as a call.
# First __qualname__.__eq__ standalone for socket.getfqdn.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra87.getfqdn_qualname_eq:
  description: "socket.getfqdn.__qualname__.__eq__('getfqdn') == True — socket.getfqdn is a Python function in socket.py that returns the fully qualified domain name; its __qualname__ is the bare name 'getfqdn'; no prior socket spec checks getfqdn.__qualname__.__eq__; first __qualname__.__eq__ standalone for socket.getfqdn"
  category: class_attrs
  kind: python_call_eq
  function: getfqdn.__qualname__.__eq__
  args: ["getfqdn"]
  expected: true

# ---------------------------------------------------------------------------
# socket.setdefaulttimeout.__qualname__.__eq__('setdefaulttimeout') — standalone
#
# socket.setdefaulttimeout.__qualname__ is 'setdefaulttimeout'. setdefaulttimeout
# is a builtin_function_or_method from _socket. No prior socket spec checks
# setdefaulttimeout.__qualname__.__eq__ as a call.
# First __qualname__.__eq__ standalone for socket.setdefaulttimeout.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra87.setdefaulttimeout_qualname_eq:
  description: "socket.setdefaulttimeout.__qualname__.__eq__('setdefaulttimeout') == True — socket.setdefaulttimeout is a builtin_function_or_method from _socket that sets the global default timeout; its __qualname__ is the bare name 'setdefaulttimeout'; no prior socket spec checks setdefaulttimeout.__qualname__.__eq__; first __qualname__.__eq__ standalone for socket.setdefaulttimeout"
  category: class_attrs
  kind: python_call_eq
  function: setdefaulttimeout.__qualname__.__eq__
  args: ["setdefaulttimeout"]
  expected: true
