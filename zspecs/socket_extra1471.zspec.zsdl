spec: socket_extra1471
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra1456.zspec.zsdl — covers __contains__ and __iter__ for socket.socket and exceptions"
    - "_socket_extra.zspec.zsdl — covers _socket C extension type and method presence checks"
    - "_socket.zspec.zsdl — covers low-level _socket constants and type names"
  notes:
    - "Wave 545 theme: __len__ and __getitem__ method presence and type checks."
    - "socket.socket is the high-level Python socket class; it wraps _socket.socket (C-level)."
    - "socket.error is an alias for OSError; socket.timeout is a subclass of socket.error (TimeoutError)."
    - "socket.herror and socket.gaierror are also socket.error subclasses for host/address errors."
    - "socket.socket.__dict__ does not contain '__len__' or '__getitem__' — sockets are not sequences."
    - "socket.error.__dict__ does not contain '__len__' or '__getitem__' — OSError is not a sequence."
    - "socket.timeout.__dict__ does not contain '__len__' or '__getitem__' — timeout is not a sequence."
    - "socket.herror.__dict__ does not contain '__len__' or '__getitem__' — herror is not a sequence."
    - "socket.gaierror.__dict__ does not contain '__len__' or '__getitem__' — gaierror is not a sequence."
    - "list.__len__.__class__.__name__ == 'wrapper_descriptor' — reference descriptor type for sized sequences."
    - "list.__getitem__.__class__.__name__ == 'method_descriptor' — reference descriptor type for indexed access."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket — __len__ and __getitem__ absence checks
#
# socket.socket is a bidirectional communication endpoint. It provides methods
# like send(), recv(), connect(), bind(), accept() — but it is not a sequence
# or mapping. Neither __len__ nor __getitem__ is defined in socket.socket.__dict__
# or anywhere in its MRO (socket.socket > _socket.socket > object).
# ---------------------------------------------------------------------------

table socket_extra1471.socket_len_getitem:
  description: "socket.socket has no __len__ or __getitem__ — socket.socket is a communication endpoint, not a sequence; neither method in socket.__dict__; wave 545 __len__/__getitem__ absence theme; sk1471lg anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk1471lg

  columns: [id, function, args, expected, description]
  rows:
    - [sk1471lg001, "socket.socket.__dict__.__contains__", ["__len__"],     false, "socket.socket.__dict__ does not contain '__len__' — socket is not a sized sequence"]
    - [sk1471lg002, "socket.socket.__dict__.__contains__", ["__getitem__"], false, "socket.socket.__dict__ does not contain '__getitem__' — socket does not support subscript indexing"]
    - [sk1471lg003, "socket.socket.__dict__.__contains__", ["close"],       true,  "socket.socket.__dict__ contains 'close' — confirms __dict__ lookup works correctly on socket.socket"]
    - [sk1471lg004, "socket.socket.__dict__.__contains__", ["accept"],      true,  "socket.socket.__dict__ contains 'accept' — confirms __dict__ lookup works correctly on socket.socket"]
    - [sk1471lg005, "socket.socket.__dict__.__contains__", ["makefile"],    true,  "socket.socket.__dict__ contains 'makefile' — confirms __dict__ lookup works correctly on socket.socket"]
    - [sk1471lg006, "socket.socket.__dict__.__contains__", ["__repr__"],    true,  "socket.socket.__dict__ contains '__repr__' — confirms __dict__ lookup works correctly on socket.socket"]

# ---------------------------------------------------------------------------
# socket exception types — __len__ and __getitem__ absence checks
#
# socket.error (OSError alias), socket.timeout (TimeoutError subclass),
# socket.herror, and socket.gaierror are all exception classes. As OSError
# subclasses they have no sequence protocol. Neither __len__ nor __getitem__
# appears anywhere in their MRO chains.
# ---------------------------------------------------------------------------

table socket_extra1471.error_timeout_len_getitem:
  description: "socket.error and socket.timeout have no __len__ or __getitem__ — both are OSError subclasses, not sequences; neither method in their __dict__; wave 545 theme; sk1471et anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk1471et

  columns: [id, function, args, expected, description]
  rows:
    - [sk1471et001, "socket.error.__dict__.__contains__",    ["__len__"],     false, "socket.error.__dict__ does not contain '__len__' — socket.error (OSError) is not a sized sequence"]
    - [sk1471et002, "socket.error.__dict__.__contains__",    ["__getitem__"], false, "socket.error.__dict__ does not contain '__getitem__' — socket.error does not support subscript access"]
    - [sk1471et003, "socket.timeout.__dict__.__contains__",  ["__len__"],     false, "socket.timeout.__dict__ does not contain '__len__' — socket.timeout is not a sized sequence"]
    - [sk1471et004, "socket.timeout.__dict__.__contains__",  ["__getitem__"], false, "socket.timeout.__dict__ does not contain '__getitem__' — socket.timeout does not support subscript access"]
    - [sk1471et005, "socket.herror.__dict__.__contains__",   ["__len__"],     false, "socket.herror.__dict__ does not contain '__len__' — socket.herror is not a sized sequence"]
    - [sk1471et006, "socket.gaierror.__dict__.__contains__", ["__len__"],     false, "socket.gaierror.__dict__ does not contain '__len__' — socket.gaierror is not a sized sequence"]

# ---------------------------------------------------------------------------
# socket.socket vs list symmetry — socket lacks sequence protocol that list has
#
# list defines __len__ (wrapper_descriptor) and __getitem__ (method_descriptor).
# socket.socket has neither. This table anchors the contrast and also verifies
# the socket class identity as a non-sequence communication primitive.
# ---------------------------------------------------------------------------

table socket_extra1471.socket_vs_list_protocol:
  description: "socket.socket lacks __len__/__getitem__ that list provides — list.__len__ is 'wrapper_descriptor', list.__getitem__ is 'method_descriptor'; socket has neither; contrast confirms socket is not a sequence; wave 545 sk1471vs anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sk1471vs

  columns: [id, function, args, expected, description]
  rows:
    - [sk1471vs001, "socket.socket.__dict__.__contains__",       ["__len__"],            false, "socket.socket.__dict__ does not contain '__len__' — contrast with list which defines __len__"]
    - [sk1471vs002, "socket.socket.__dict__.__contains__",       ["__getitem__"],        false, "socket.socket.__dict__ does not contain '__getitem__' — contrast with list which defines __getitem__"]
    - [sk1471vs003, "list.__len__.__class__.__name__.__eq__",    ["wrapper_descriptor"], true,  "list.__len__.__class__.__name__ == 'wrapper_descriptor' — reference value that socket does NOT have"]
    - [sk1471vs004, "list.__getitem__.__class__.__name__.__eq__", ["method_descriptor"], true,  "list.__getitem__.__class__.__name__ == 'method_descriptor' — reference value that socket does NOT have"]
    - [sk1471vs005, "socket.socket.__name__.__eq__",             ["socket"],             true,  "socket.socket.__name__ == 'socket' — confirms the class is named socket"]
    - [sk1471vs006, "socket.socket.__module__.__eq__",           ["socket"],             true,  "socket.socket.__module__ == 'socket' — confirms socket.socket is defined in the socket module"]
