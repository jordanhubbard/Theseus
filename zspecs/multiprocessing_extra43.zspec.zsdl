spec: multiprocessing_extra43
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#multiprocessing.context.BaseContext — BaseContext documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/exceptions.py"
  notes:
    - "This spec extends multiprocessing_extra42.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() tables, Process method __qualname__.__len__() tables, Pool method tables, Process/Pool __mro__.__len__() tables, __all__ metadata, class __dict__ tables, DefaultContext method qualname lengths, BaseProcess metadata, function __name__.__len__() tables, pool result class tables, Process/__name__=='Process' (extra37), Process/__module__=='multiprocessing.context' (extra37), Queue/__name__=='Queue' (extra37), Pipe/__name__=='Pipe' (extra37), Process method qualname lens for start/join/run (extra37), Process.__bases__[0].__name__=='BaseProcess'/__mro__.__len__()==3/Manager.__name__=='Manager' (extra38), function __name__/__module__ string equality for cpu_count/current_process/active_children (extra38), AuthenticationError/__name__/__module__/__bases__[0].__name__, ProcessError/__name__/__bases__[0].__name__, BufferTooShort/__name__, TimeoutError/__name__/__bases__[0].__name__, all four exception __module__ string equality (extra39), ProcessError/__mro__.__len__()==4, exception subclass MRO depths (5), Process/__qualname__=='Process', Process/__qualname__.__len__()==7, context.BaseContext/__name__=='BaseContext', get_start_method/__name__=='get_start_method' (extra40), Queue/__qualname__=='BaseContext.Queue', Pipe/__qualname__=='BaseContext.Pipe', cpu_count/__qualname__=='BaseContext.cpu_count', current_process/__qualname__=='current_process', active_children/__qualname__=='active_children', get_start_method/__qualname__=='DefaultContext.get_start_method', set_start_method/__name__=='set_start_method' (extra41), Process/__qualname__.__len__()==7, ProcessError/__qualname__=='ProcessError', ProcessError/__qualname__.__len__()==12, AuthenticationError/__qualname__=='AuthenticationError', AuthenticationError/__qualname__.__len__()==19, TimeoutError/__qualname__=='TimeoutError', BufferTooShort/__qualname__=='BufferTooShort', BufferTooShort/__qualname__.__len__()==14 (extra42)."
    - "This spec covers: context.BaseContext/__qualname__=='BaseContext'; context.BaseContext/__qualname__.__len__()==11; context.BaseContext/__module__=='multiprocessing.context'; context.BaseContext/__module__.__len__()==23; context.BaseContext/__mro__.__len__()==2; context.SpawnContext/__name__=='SpawnContext'; context.SpawnContext/__qualname__.__len__()==12; context.ForkContext/__name__=='ForkContext'; context.ForkContext/__qualname__.__len__()==11; context.ForkServerContext/__name__=='ForkServerContext'; context.ForkServerContext/__qualname__.__len__()==17; context.DefaultContext/__name__=='DefaultContext'; all four context subclasses share __module__=='multiprocessing.context'; SpawnContext/ForkContext/ForkServerContext/DefaultContext each have __mro__.__len__()==3."
    - "multiprocessing.context.BaseContext.__qualname__ == 'BaseContext'. BaseContext is defined as a top-level class in multiprocessing.context; __qualname__ equals __name__ for top-level classes. len('BaseContext') == 11. Verified with Python 3.14.3."
    - "multiprocessing.context.BaseContext.__module__ == 'multiprocessing.context'. BaseContext.__module__ == 'multiprocessing.context'; len('multiprocessing.context') == 23. Verified with Python 3.14.3."
    - "multiprocessing.context.BaseContext.__mro__.__len__() == 2. BaseContext.__mro__ == (BaseContext, object); it has no intermediate base classes. Verified with Python 3.14.3."
    - "multiprocessing.context.SpawnContext.__name__ == 'SpawnContext'. SpawnContext is a top-level class in multiprocessing.context that subclasses BaseContext. Accessible as multiprocessing.context.SpawnContext. len('SpawnContext') == 12. Verified with Python 3.14.3."
    - "multiprocessing.context.ForkContext.__name__ == 'ForkContext'. ForkContext is a top-level class in multiprocessing.context that subclasses BaseContext. len('ForkContext') == 11. Verified with Python 3.14.3."
    - "multiprocessing.context.ForkServerContext.__name__ == 'ForkServerContext'. ForkServerContext is the longest-named context subclass. len('ForkServerContext') == 17. Verified with Python 3.14.3."
    - "multiprocessing.context.DefaultContext.__name__ == 'DefaultContext'. DefaultContext subclasses BaseContext; it is the context used when no specific start method is specified. len('DefaultContext') == 14. Verified with Python 3.14.3."
    - "All four context subclasses (SpawnContext, ForkContext, ForkServerContext, DefaultContext) share __module__ == 'multiprocessing.context' (23 chars) and __mro__.__len__() == 3 (subclass -> BaseContext -> object). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.context.BaseContext identity — extra43 namespace
#
# BaseContext is the abstract base for all multiprocessing context objects.
# It provides the start-method-agnostic API (Process, Queue, Pipe, etc.).
# Accessed as multiprocessing.context.BaseContext (not directly from the
# multiprocessing namespace).
#   BaseContext.__qualname__ == 'BaseContext'    (11 chars)
#   BaseContext.__module__   == 'multiprocessing.context'  (23 chars)
#   BaseContext.__mro__.__len__() == 2  (BaseContext -> object)
# Prior spec extra40 captured BaseContext.__name__=='BaseContext'; extra43
# extends to __qualname__, __module__, and MRO depth.
# ---------------------------------------------------------------------------

table multiprocessing_extra43.BaseContext_identity:
  description: "multiprocessing.context.BaseContext __qualname__/__module__ string equality and MRO depth in extra43 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: mpbasectxid43

  columns: [id, function, args, expected, description]
  rows:
    - [qualname_eq,  "context.BaseContext.__qualname__.__eq__",  ["BaseContext"],             true, "BaseContext.__qualname__ == 'BaseContext' — top-level class; qualname equals name (11 chars)"]
    - [qualname_len, "context.BaseContext.__qualname__.__len__", [],                          11,   "BaseContext.__qualname__.__len__() == 11 — 'BaseContext' has 11 characters"]
    - [module_eq,    "context.BaseContext.__module__.__eq__",    ["multiprocessing.context"], true, "BaseContext.__module__ == 'multiprocessing.context' — defined in the context sub-module"]
    - [module_len,   "context.BaseContext.__module__.__len__",   [],                          23,   "BaseContext.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters"]
    - [mro_len,      "context.BaseContext.__mro__.__len__",      [],                           2,   "BaseContext.__mro__.__len__() == 2 — BaseContext -> object; no intermediate base classes"]

# ---------------------------------------------------------------------------
# multiprocessing.context subclass names — extra43 namespace
#
# Four concrete context subclasses inherit from BaseContext:
#   SpawnContext.__name__      == 'SpawnContext'       (12 chars)
#   ForkContext.__name__       == 'ForkContext'        (11 chars)
#   ForkServerContext.__name__ == 'ForkServerContext'  (17 chars)
#   DefaultContext.__name__    == 'DefaultContext'     (14 chars)
# All are accessible via multiprocessing.context and share the same
# __module__ == 'multiprocessing.context' (23 chars).
# ForkContext name length (11) matches BaseContext name length.
# ---------------------------------------------------------------------------

table multiprocessing_extra43.context_subclass_names:
  description: "multiprocessing.context subclass __name__ string equality in extra43 namespace — SpawnContext, ForkContext, ForkServerContext, DefaultContext"
  kind: python_call_eq
  category: class_names
  id_prefix: mpctxsubname43

  columns: [id, function, args, expected, description]
  rows:
    - [SpawnContext,       "context.SpawnContext.__name__.__eq__",       ["SpawnContext"],       true, "SpawnContext.__name__ == 'SpawnContext' — spawn-based context; 12 chars"]
    - [ForkContext,        "context.ForkContext.__name__.__eq__",        ["ForkContext"],        true, "ForkContext.__name__ == 'ForkContext' — fork-based context; 11 chars (same as BaseContext)"]
    - [ForkServerContext,  "context.ForkServerContext.__name__.__eq__",  ["ForkServerContext"],  true, "ForkServerContext.__name__ == 'ForkServerContext' — forkserver-based context; 17 chars"]
    - [DefaultContext,     "context.DefaultContext.__name__.__eq__",     ["DefaultContext"],     true, "DefaultContext.__name__ == 'DefaultContext' — default start-method context; 14 chars"]

# ---------------------------------------------------------------------------
# multiprocessing.context subclass __qualname__ lengths — extra43 namespace
#
#   SpawnContext.__qualname__.__len__()      == 12  ('SpawnContext')
#   ForkContext.__qualname__.__len__()       == 11  ('ForkContext')
#   ForkServerContext.__qualname__.__len__() == 17  ('ForkServerContext')
#   DefaultContext.__qualname__.__len__()    == 14  ('DefaultContext')
# All are top-level classes; __qualname__ equals __name__.
# ForkServerContext is the longest; ForkContext is the shortest (same as BaseContext at 11).
# ---------------------------------------------------------------------------

table multiprocessing_extra43.context_subclass_qualname_lengths:
  description: "multiprocessing.context subclass __qualname__.__len__() in extra43 namespace — SpawnContext, ForkContext, ForkServerContext, DefaultContext"
  kind: python_call_eq
  category: class_names
  id_prefix: mpctxsubqnlen43

  columns: [id, function, args, expected, description]
  rows:
    - [SpawnContext,      "context.SpawnContext.__qualname__.__len__",      [], 12, "SpawnContext.__qualname__.__len__() == 12 — 'SpawnContext' has 12 characters"]
    - [ForkContext,       "context.ForkContext.__qualname__.__len__",       [], 11, "ForkContext.__qualname__.__len__() == 11 — 'ForkContext' has 11 characters; same length as BaseContext"]
    - [ForkServerContext, "context.ForkServerContext.__qualname__.__len__", [], 17, "ForkServerContext.__qualname__.__len__() == 17 — 'ForkServerContext' has 17 characters; longest context class name"]
    - [DefaultContext,    "context.DefaultContext.__qualname__.__len__",    [], 14, "DefaultContext.__qualname__.__len__() == 14 — 'DefaultContext' has 14 characters"]

# ---------------------------------------------------------------------------
# multiprocessing.context subclass MRO depths — extra43 namespace
#
# All four subclasses share the same MRO pattern: (Subclass, BaseContext, object)
#   SpawnContext.__mro__.__len__()      == 3
#   ForkContext.__mro__.__len__()       == 3
#   ForkServerContext.__mro__.__len__() == 3
#   DefaultContext.__mro__.__len__()    == 3
# This contrasts with BaseContext.__mro__.__len__() == 2.
# ---------------------------------------------------------------------------

table multiprocessing_extra43.context_subclass_mro_depths:
  description: "multiprocessing.context subclass __mro__.__len__() in extra43 namespace — SpawnContext, ForkContext, ForkServerContext, DefaultContext"
  kind: python_call_eq
  category: class_names
  id_prefix: mpctxsubmrodepth43

  columns: [id, function, args, expected, description]
  rows:
    - [SpawnContext,      "context.SpawnContext.__mro__.__len__",      [], 3, "SpawnContext.__mro__.__len__() == 3 — SpawnContext -> BaseContext -> object"]
    - [ForkContext,       "context.ForkContext.__mro__.__len__",       [], 3, "ForkContext.__mro__.__len__() == 3 — ForkContext -> BaseContext -> object"]
    - [ForkServerContext, "context.ForkServerContext.__mro__.__len__", [], 3, "ForkServerContext.__mro__.__len__() == 3 — ForkServerContext -> BaseContext -> object"]
    - [DefaultContext,    "context.DefaultContext.__mro__.__len__",    [], 3, "DefaultContext.__mro__.__len__() == 3 — DefaultContext -> BaseContext -> object"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra43
# ---------------------------------------------------------------------------

invariant multiprocessing_extra43.BaseContext_qualname_eq:
  description: "multiprocessing.context.BaseContext.__qualname__ == 'BaseContext' — top-level class; qualname equals name (11 chars)"
  category: class_names
  kind: python_call_eq
  function: "context.BaseContext.__qualname__.__eq__"
  args: ["BaseContext"]
  expected: true

invariant multiprocessing_extra43.BaseContext_qualname_len:
  description: "multiprocessing.context.BaseContext.__qualname__.__len__() == 11 — 'BaseContext' has 11 characters"
  category: class_names
  kind: python_call_eq
  function: "context.BaseContext.__qualname__.__len__"
  args: []
  expected: 11

invariant multiprocessing_extra43.BaseContext_module_eq:
  description: "multiprocessing.context.BaseContext.__module__ == 'multiprocessing.context' — defined in the context sub-module"
  category: module_identity
  kind: python_call_eq
  function: "context.BaseContext.__module__.__eq__"
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra43.BaseContext_module_len:
  description: "multiprocessing.context.BaseContext.__module__.__len__() == 23 — 'multiprocessing.context' has 23 characters"
  category: module_identity
  kind: python_call_eq
  function: "context.BaseContext.__module__.__len__"
  args: []
  expected: 23

invariant multiprocessing_extra43.BaseContext_mro_len:
  description: "multiprocessing.context.BaseContext.__mro__.__len__() == 2 — BaseContext -> object; no intermediate base classes"
  category: class_names
  kind: python_call_eq
  function: "context.BaseContext.__mro__.__len__"
  args: []
  expected: 2

invariant multiprocessing_extra43.SpawnContext_qualname_len:
  description: "multiprocessing.context.SpawnContext.__qualname__.__len__() == 12 — 'SpawnContext' has 12 characters"
  category: class_names
  kind: python_call_eq
  function: "context.SpawnContext.__qualname__.__len__"
  args: []
  expected: 12

invariant multiprocessing_extra43.ForkContext_qualname_len:
  description: "multiprocessing.context.ForkContext.__qualname__.__len__() == 11 — 'ForkContext' has 11 characters; same as BaseContext"
  category: class_names
  kind: python_call_eq
  function: "context.ForkContext.__qualname__.__len__"
  args: []
  expected: 11

invariant multiprocessing_extra43.ForkServerContext_qualname_len:
  description: "multiprocessing.context.ForkServerContext.__qualname__.__len__() == 17 — 'ForkServerContext' has 17 characters; longest context class name"
  category: class_names
  kind: python_call_eq
  function: "context.ForkServerContext.__qualname__.__len__"
  args: []
  expected: 17

invariant multiprocessing_extra43.DefaultContext_name_eq:
  description: "multiprocessing.context.DefaultContext.__name__ == 'DefaultContext' — default start-method context class; 14 chars"
  category: class_names
  kind: python_call_eq
  function: "context.DefaultContext.__name__.__eq__"
  args: ["DefaultContext"]
  expected: true
