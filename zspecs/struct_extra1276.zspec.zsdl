spec: struct_extra1276
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 532 (_extra1276): class attribute TYPE checks. struct.Struct.__subclasses__() returns a list; struct.Struct.__mro__ and struct.Struct.__bases__ are tuples. Same pattern applied to struct.error (an Exception subclass)."
    - "struct.Struct.__mro__ == (Struct, object). struct.Struct.__bases__ == (object,). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__ == (error, Exception, BaseException, object). struct.error.__bases__ == (Exception,). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1276.struct_class_type_checks:
  description: "struct.Struct __subclasses__() is a list; __mro__ and __bases__ are tuples — direct class attribute type checks"
  kind: python_call_eq
  category: class_type_checks
  id_prefix: st1276sc
  columns: [id, function, args, expected]
  rows:
    - [st1276sc001, struct.Struct.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [st1276sc002, struct.Struct.__subclasses__().__class__.__name__.__eq__, ["tuple"], false]
    - [st1276sc003, struct.Struct.__mro__.__class__.__name__.__eq__,         ["tuple"], true]
    - [st1276sc004, struct.Struct.__mro__.__class__.__name__.__eq__,         ["list"],  false]
    - [st1276sc005, struct.Struct.__bases__.__class__.__name__.__eq__,       ["tuple"], true]
    - [st1276sc006, struct.Struct.__bases__.__class__.__name__.__eq__,       ["list"],  false]
    - [st1276sc007, struct.Struct.__mro__.__class__.__bases__.__class__.__name__.__eq__,   ["tuple"], true]
    - [st1276sc008, struct.Struct.__bases__.__class__.__mro__.__class__.__name__.__eq__,   ["tuple"], true]
    - [st1276sc009, struct.Struct.__subclasses__().__class__.__mro__.__class__.__name__.__eq__, ["tuple"], true]
    - [st1276sc010, struct.Struct.__mro__.__class__.__name__.__eq__,         ["set"],   false]
    - [st1276sc011, struct.Struct.__bases__.__class__.__name__.__eq__,       ["set"],   false]
    - [st1276sc012, struct.Struct.__subclasses__().__class__.__name__.__eq__, ["set"],   false]

table struct_extra1276.error_class_type_checks:
  description: "struct.error __subclasses__() is a list; __mro__ and __bases__ are tuples — struct.error is an Exception subclass"
  kind: python_call_eq
  category: class_type_checks
  id_prefix: st1276ec
  columns: [id, function, args, expected]
  rows:
    - [st1276ec001, struct.error.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [st1276ec002, struct.error.__subclasses__().__class__.__name__.__eq__, ["tuple"], false]
    - [st1276ec003, struct.error.__mro__.__class__.__name__.__eq__,         ["tuple"], true]
    - [st1276ec004, struct.error.__mro__.__class__.__name__.__eq__,         ["list"],  false]
    - [st1276ec005, struct.error.__bases__.__class__.__name__.__eq__,       ["tuple"], true]
    - [st1276ec006, struct.error.__bases__.__class__.__name__.__eq__,       ["list"],  false]
    - [st1276ec007, struct.error.__mro__.__class__.__bases__.__class__.__name__.__eq__,   ["tuple"], true]
    - [st1276ec008, struct.error.__bases__.__class__.__mro__.__class__.__name__.__eq__,   ["tuple"], true]
    - [st1276ec009, struct.error.__subclasses__().__class__.__mro__.__class__.__name__.__eq__, ["tuple"], true]
    - [st1276ec010, struct.error.__mro__.__class__.__name__.__eq__,         ["set"],   false]
    - [st1276ec011, struct.error.__bases__.__class__.__name__.__eq__,       ["set"],   false]
    - [st1276ec012, struct.error.__subclasses__().__class__.__name__.__eq__, ["set"],   false]

table struct_extra1276.class_neg_checks:
  description: "struct.Struct and struct.error class attribute types are not dict, frozenset, or str — negative identity checks"
  kind: python_call_eq
  category: class_neg_checks
  id_prefix: st1276ng
  columns: [id, function, args, expected]
  rows:
    - [st1276ng001, struct.Struct.__subclasses__().__class__.__name__.__eq__, ["dict"],      false]
    - [st1276ng002, struct.Struct.__subclasses__().__class__.__name__.__eq__, ["frozenset"], false]
    - [st1276ng003, struct.Struct.__mro__.__class__.__name__.__eq__,          ["dict"],      false]
    - [st1276ng004, struct.Struct.__mro__.__class__.__name__.__eq__,          ["frozenset"], false]
    - [st1276ng005, struct.Struct.__bases__.__class__.__name__.__eq__,        ["dict"],      false]
    - [st1276ng006, struct.Struct.__bases__.__class__.__name__.__eq__,        ["frozenset"], false]
    - [st1276ng007, struct.error.__subclasses__().__class__.__name__.__eq__,  ["dict"],      false]
    - [st1276ng008, struct.error.__subclasses__().__class__.__name__.__eq__,  ["frozenset"], false]
    - [st1276ng009, struct.error.__mro__.__class__.__name__.__eq__,           ["dict"],      false]
    - [st1276ng010, struct.error.__bases__.__class__.__name__.__eq__,         ["dict"],      false]
    - [st1276ng011, struct.Struct.__mro__.__class__.__bases__.__class__.__name__.__eq__,  ["list"], false]
    - [st1276ng012, struct.error.__bases__.__class__.__mro__.__class__.__name__.__eq__,   ["list"], false]
