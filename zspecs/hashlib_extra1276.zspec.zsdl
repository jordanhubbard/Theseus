spec: hashlib_extra1276
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra1261.zspec.zsdl — covers hashlib.__all__.__contains__ membership checks and __all__ class identity (tuple)."
    - "hashlib_extra1246.zspec.zsdl — covers hashlib module and function __doc__ class name checks (str vs NoneType)."
    - "hashlib_extra99.zspec.zsdl — covers md5/sha1/sha256/sha512 constructor __class__.__name__ / algorithms_guaranteed length."
  notes:
    - "Wave 532 (_extra1276): class attribute TYPE checks. hashlib exposes no user-subclassable classes directly, so this spec focuses on algorithms_guaranteed (a set) and algorithms_available (a set), checking __class__.__subclasses__, __class__.__mro__, and __class__.__bases__ type names. Also verifies set membership for key algorithm names."
    - "hashlib.algorithms_guaranteed.__class__.__name__ == 'set'. hashlib.algorithms_available.__class__.__name__ == 'set'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.algorithms_guaranteed.__class__.__subclasses__() returns a list. __class__.__mro__ and __class__.__bases__ are tuples. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1276.algorithms_class_type_checks:
  description: "algorithms_guaranteed and algorithms_available are sets; __class__.__subclasses__() is list, __class__.__mro__ and __class__.__bases__ are tuples"
  kind: python_call_eq
  category: class_type_checks
  id_prefix: hl1276ac
  columns: [id, function, args, expected]
  rows:
    - [hl1276ac001, hashlib.algorithms_guaranteed.__class__.__name__.__eq__,                       ["set"],   true]
    - [hl1276ac002, hashlib.algorithms_guaranteed.__class__.__name__.__eq__,                       ["list"],  false]
    - [hl1276ac003, hashlib.algorithms_guaranteed.__class__.__subclasses__().__class__.__name__.__eq__, ["list"],  true]
    - [hl1276ac004, hashlib.algorithms_guaranteed.__class__.__subclasses__().__class__.__name__.__eq__, ["tuple"], false]
    - [hl1276ac005, hashlib.algorithms_guaranteed.__class__.__mro__.__class__.__name__.__eq__,     ["tuple"], true]
    - [hl1276ac006, hashlib.algorithms_guaranteed.__class__.__mro__.__class__.__name__.__eq__,     ["list"],  false]
    - [hl1276ac007, hashlib.algorithms_guaranteed.__class__.__bases__.__class__.__name__.__eq__,   ["tuple"], true]
    - [hl1276ac008, hashlib.algorithms_guaranteed.__class__.__bases__.__class__.__name__.__eq__,   ["list"],  false]
    - [hl1276ac009, hashlib.algorithms_available.__class__.__name__.__eq__,                        ["set"],   true]
    - [hl1276ac010, hashlib.algorithms_available.__class__.__mro__.__class__.__name__.__eq__,      ["tuple"], true]
    - [hl1276ac011, hashlib.algorithms_available.__class__.__bases__.__class__.__name__.__eq__,    ["tuple"], true]
    - [hl1276ac012, hashlib.algorithms_available.__class__.__subclasses__().__class__.__name__.__eq__, ["list"], true]

table hashlib_extra1276.algorithms_guaranteed_membership:
  description: "algorithms_guaranteed contains key algorithm names (true) and lacks absent names (false)"
  kind: python_call_eq
  category: membership_checks
  id_prefix: hl1276gm
  columns: [id, function, args, expected]
  rows:
    - [hl1276gm001, hashlib.algorithms_guaranteed.__contains__, ["sha256"],    true]
    - [hl1276gm002, hashlib.algorithms_guaranteed.__contains__, ["sha512"],    true]
    - [hl1276gm003, hashlib.algorithms_guaranteed.__contains__, ["md5"],       true]
    - [hl1276gm004, hashlib.algorithms_guaranteed.__contains__, ["sha1"],      true]
    - [hl1276gm005, hashlib.algorithms_guaranteed.__contains__, ["sha3_256"],  true]
    - [hl1276gm006, hashlib.algorithms_guaranteed.__contains__, ["sha224"],    true]
    - [hl1276gm007, hashlib.algorithms_guaranteed.__contains__, ["sha384"],    true]
    - [hl1276gm008, hashlib.algorithms_guaranteed.__contains__, ["blake2b"],   true]
    - [hl1276gm009, hashlib.algorithms_guaranteed.__contains__, ["md4"],       false]
    - [hl1276gm010, hashlib.algorithms_guaranteed.__contains__, ["sha999"],    false]
    - [hl1276gm011, hashlib.algorithms_guaranteed.__contains__, ["ripemd160"], false]
    - [hl1276gm012, hashlib.algorithms_guaranteed.__contains__, ["whirlpool"], false]

table hashlib_extra1276.set_class_identity_neg:
  description: "algorithms_guaranteed and algorithms_available class name is not list, tuple, frozenset, or dict"
  kind: python_call_eq
  category: class_identity_neg
  id_prefix: hl1276sn
  columns: [id, function, args, expected]
  rows:
    - [hl1276sn001, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["frozenset"], false]
    - [hl1276sn002, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["dict"],      false]
    - [hl1276sn003, hashlib.algorithms_guaranteed.__class__.__name__.__eq__, ["tuple"],     false]
    - [hl1276sn004, hashlib.algorithms_available.__class__.__name__.__eq__,  ["frozenset"], false]
    - [hl1276sn005, hashlib.algorithms_available.__class__.__name__.__eq__,  ["dict"],      false]
    - [hl1276sn006, hashlib.algorithms_available.__class__.__name__.__eq__,  ["list"],      false]
    - [hl1276sn007, hashlib.algorithms_guaranteed.__class__.__mro__.__class__.__name__.__eq__,   ["list"],  false]
    - [hl1276sn008, hashlib.algorithms_guaranteed.__class__.__bases__.__class__.__name__.__eq__,  ["list"],  false]
    - [hl1276sn009, hashlib.algorithms_available.__class__.__mro__.__class__.__name__.__eq__,    ["list"],  false]
    - [hl1276sn010, hashlib.algorithms_available.__class__.__bases__.__class__.__name__.__eq__,   ["list"],  false]
    - [hl1276sn011, hashlib.algorithms_guaranteed.__class__.__subclasses__().__class__.__name__.__eq__, ["set"],   false]
    - [hl1276sn012, hashlib.algorithms_available.__class__.__subclasses__().__class__.__name__.__eq__, ["tuple"], false]
