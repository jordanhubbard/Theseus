spec: functools_extra2311
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 601 (_extra2311): __abstractmethods__ content and absence checks."
    - "functools.partial: C extension type — __abstractmethods__ absent from __dict__ and raises AttributeError on direct access."
    - "functools.partialmethod: Python class — same absence pattern."
    - "functools.cached_property: Python descriptor class — same absence pattern."
    - "functools._lru_cache_wrapper: C extension wrapper type — same absence pattern."
    - "functools.singledispatchmethod: Python descriptor class — same absence pattern."
    - "None of the functools utility classes are abstract; none register __abstractmethods__ in their class dict."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __abstractmethods__ absence from __dict__ — all functools classes
#
# Checks that "__abstractmethods__" is NOT a key in each class's __dict__.
# Non-abstract classes never set this attribute on the class itself.
# All expected False.
# ---------------------------------------------------------------------------

table functools_extra2311.abstract_absence:
  description: "functools classes have no __abstractmethods__ in class dict — all False — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2311

  columns: [id, function, args, expected]
  rows:
    - ["ft2311001", "functools.partial.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ft2311002", "functools.partialmethod.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ft2311003", "functools.cached_property.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ft2311004", "functools._lru_cache_wrapper.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ft2311005", "functools.singledispatchmethod.__dict__.__contains__", ["__abstractmethods__"], false]

# ---------------------------------------------------------------------------
# Table 2: __abstractmethods__ direct attribute access raises AttributeError
#
# Since __abstractmethods__ is absent from each class's __dict__ and no base
# class in the MRO provides it, accessing cls.__abstractmethods__ raises
# AttributeError for all five functools utility classes.
# ---------------------------------------------------------------------------

table functools_extra2311.abstract_attr_error:
  description: "functools classes raise AttributeError on __abstractmethods__ access — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: ft2311

  columns: [id, function, args, expected]
  rows:
    - ["ft2311006", "functools.partial.__abstractmethods__.__len__", [], "AttributeError"]
    - ["ft2311007", "functools.partialmethod.__abstractmethods__.__len__", [], "AttributeError"]
    - ["ft2311008", "functools.cached_property.__abstractmethods__.__len__", [], "AttributeError"]
    - ["ft2311009", "functools._lru_cache_wrapper.__abstractmethods__.__len__", [], "AttributeError"]
    - ["ft2311010", "functools.singledispatchmethod.__abstractmethods__.__len__", [], "AttributeError"]

# ---------------------------------------------------------------------------
# Table 3: __abstractmethods__.__contains__ raises AttributeError
#
# Chained access to __abstractmethods__.__contains__ also raises AttributeError
# because the intermediate __abstractmethods__ attribute does not exist.
# ---------------------------------------------------------------------------

table functools_extra2311.abstract_contains_error:
  description: "functools __abstractmethods__.__contains__ raises AttributeError — wave 601 _extra2311"
  kind: python_call_raises
  category: attribute_access
  id_prefix: ft2311

  columns: [id, function, args, expected]
  rows:
    - ["ft2311011", "functools.partial.__abstractmethods__.__contains__", ["run"], "AttributeError"]
    - ["ft2311012", "functools.partialmethod.__abstractmethods__.__contains__", ["run"], "AttributeError"]
    - ["ft2311013", "functools.cached_property.__abstractmethods__.__contains__", ["run"], "AttributeError"]
    - ["ft2311014", "functools._lru_cache_wrapper.__abstractmethods__.__contains__", ["run"], "AttributeError"]
    - ["ft2311015", "functools.singledispatchmethod.__abstractmethods__.__contains__", ["run"], "AttributeError"]

# ---------------------------------------------------------------------------
# Table 4: cross-check — other protocol dunders also absent from __dict__
#
# Confirms that __isabstractmethod__ (descriptor protocol, not the class-level
# frozenset) is only present on functools.partialmethod and singledispatchmethod
# (which are descriptors that propagate abstractness). The class-level
# __abstractmethods__ frozenset is still absent from all class dicts.
# Also re-verifies partial and cached_property for completeness.
# ---------------------------------------------------------------------------

table functools_extra2311.partial_abstract:
  description: "functools.partial __abstractmethods__ dict-presence — False — wave 601 _extra2311"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2311

  columns: [id, function, args, expected]
  rows:
    - ["ft2311016", "functools.partial.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ft2311017", "functools.partialmethod.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ft2311018", "functools.cached_property.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ft2311019", "functools._lru_cache_wrapper.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["ft2311020", "functools.singledispatchmethod.__dict__.__contains__", ["__abstractmethods__"], false]
