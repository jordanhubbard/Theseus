# concurrent.futures.ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process') == True
# concurrent.futures.ProcessPoolExecutor.__module__.__len__()                   == 26
# ---------------------------------------------------------------------------

table concurrent_futures_extra164.cf_ppe_identity:
  description: "concurrent.futures.ProcessPoolExecutor class name and module identity checks in cfppeid164 namespace — concurrent.futures.ProcessPoolExecutor.__name__.__eq__('ProcessPoolExecutor')==True (ProcessPoolExecutor.__name__=='ProcessPoolExecutor' (len=19: 'Process'=7+'Pool'=4+'Executor'=8=19); ProcessPoolExecutor manages a pool of worker processes; work items are pickled and sent to worker processes via a multiprocessing queue; ProcessPoolExecutor is suited for CPU-bound tasks that benefit from true parallelism — unlike threads, processes are not limited by the GIL); concurrent.futures.ProcessPoolExecutor.__name__.__len__()==19 ('ProcessPoolExecutor'=19: 1 longer than ThreadPoolExecutor=18 because 'Process'=7 > 'Thread'=6 by 1; 'PoolExecutor'=12 is shared: 'Pool'=4+'Executor'=8=12); concurrent.futures.ProcessPoolExecutor.__module__.__eq__('concurrent.futures.process')==True (__module__=='concurrent.futures.process' (len=26: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'process'=7=26; 1 longer than thread module=25 because 'process'=7 > 'thread'=6)); concurrent.futures.ProcessPoolExecutor.__module__.__len__()==26; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfppeid164

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_name_eq,  concurrent.futures.ProcessPoolExecutor.__name__.__eq__,    ["ProcessPoolExecutor"],            true,  "PPE.__name__ == 'ProcessPoolExecutor' (len=19: 'Process'=7+'Pool'=4+'Executor'=8=19); verified with Python 3.14.3"]
    - [ppe_name_len, concurrent.futures.ProcessPoolExecutor.__name__.__len__,   [],                                 19,    "PPE.__name__.__len__() == 19 ('ProcessPoolExecutor'=19; 1 longer than TPE=18); verified with Python 3.14.3"]
    - [ppe_mod_eq,   concurrent.futures.ProcessPoolExecutor.__module__.__eq__,  ["concurrent.futures.process"],     true,  "PPE.__module__ == 'concurrent.futures.process' (len=26; 1 longer than thread=25); verified with Python 3.14.3"]
    - [ppe_mod_len,  concurrent.futures.ProcessPoolExecutor.__module__.__len__, [],                                 26,    "PPE.__module__.__len__() == 26 ('concurrent.futures.process'=26; 'process'=7 > 'thread'=6 by 1); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor base class and TPE/PPE cross-comparison — extra164
#
# PPE.__bases__[0].__name__.__eq__('Executor') == True
# PPE.__name__.__len__() == 19  vs  TPE.__name__.__len__() == 18
# PPE.__module__.__len__() == 26  vs  TPE.__module__.__len__() == 25
# ---------------------------------------------------------------------------

table concurrent_futures_extra164.cf_ppe_base_and_tpe_comparison:
  description: "ProcessPoolExecutor base class and TPE vs PPE cross-comparison in cfppebase164 namespace — concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (PPE.__bases__[0].__name__=='Executor' (len=8); PPE inherits from Executor directly — same base class as TPE; both ThreadPoolExecutor and ProcessPoolExecutor share the same single base class Executor, reflecting a uniform interface: submit() returns a Future, map() applies a function to an iterable, shutdown() cleans up); PPE.__bases__[0].__name__.__len__()==8 ('Executor'=8; same as TPE.__bases__[0].__name__.__len__()==8); concurrent.futures.ProcessPoolExecutor.__name__.__len__()==19 vs concurrent.futures.ThreadPoolExecutor.__name__.__len__()==18 (PPE name is 1 longer than TPE name); concurrent.futures.ProcessPoolExecutor.__module__.__len__()==26 vs concurrent.futures.ThreadPoolExecutor.__module__.__len__()==25 (PPE module path is 1 longer than TPE module path — the same 1-char difference in 'process'=7 vs 'thread'=6 appears consistently in both class name and module path); KEY PATTERN: PPE is exactly 1 char longer than TPE in BOTH class name and module path; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cfppebase164

  columns: [id, function, args, expected, description]
  rows:
    - [ppe_base_name_eq,  "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__",  ["Executor"],  true,  "PPE.__bases__[0].__name__ == 'Executor' (same base as TPE; both inherit Executor); verified with Python 3.14.3"]
    - [ppe_base_name_len, "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__len__", [],            8,     "PPE.__bases__[0].__name__.__len__() == 8 ('Executor'=8; same as TPE base len=8); verified with Python 3.14.3"]
    - [ppe_name_len2,     concurrent.futures.ProcessPoolExecutor.__name__.__len__,                [],            19,    "PPE.__name__.__len__() == 19 (cross-check; 1 longer than TPE=18); verified with Python 3.14.3"]
    - [tpe_name_len2,     concurrent.futures.ThreadPoolExecutor.__name__.__len__,                 [],            18,    "TPE.__name__.__len__() == 18 (cross-check; 1 shorter than PPE=19); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra164
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra164.cf_TPE_name_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__name__.__eq__('ThreadPoolExecutor') returns True — concurrent.futures.ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18: 'Thread'=6+'Pool'=4+'Executor'=8=18); ThreadPoolExecutor manages a pool of reusable worker threads for I/O-bound or cooperative tasks; it avoids process-creation overhead by reusing threads; the pool size is bounded by max_workers (defaults to min(32, os.cpu_count() + 4) in Python 3.8+); TPE.submit(fn, *args) returns a Future immediately; the Future is resolved when fn completes in a worker thread; ThreadPoolExecutor is the most common concurrent.futures executor for network I/O, file I/O, and other blocking calls; compare: ProcessPoolExecutor.__name__=='ProcessPoolExecutor' (len=19; 1 longer than TPE=18); Executor.__name__=='Executor' (len=8; 10 shorter than TPE=18 — the 'ThreadPool' prefix is 10 chars); NEW in extra164: first standalone TPE.__name__ identity invariant in cftpeid164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__name__.__eq__
  args: ["ThreadPoolExecutor"]
  expected: true

invariant concurrent_futures_extra164.cf_TPE_module_eq:
  description: "concurrent.futures.ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread') returns True — concurrent.futures.ThreadPoolExecutor.__module__=='concurrent.futures.thread' (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25); TPE is defined in Lib/concurrent/futures/thread.py; the submodule name 'thread'=6 matches the first component of the class name prefix 'Thread'=6 (case-insensitively); compare: concurrent.futures._base module (len=24: '_base'=5 vs 'thread'=6; '_base' is 1 char shorter — _base has a leading underscore making it private); concurrent.futures.process module (len=26: 'process'=7 vs 'thread'=6; process module is 1 longer); the three cf submodule path lengths: _base(24) < thread(25) < process(26); TPE module len(25) is in the middle; NEW in extra164: first standalone TPE.__module__ identity invariant in cftpeid164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__module__.__eq__
  args: ["concurrent.futures.thread"]
  expected: true

invariant concurrent_futures_extra164.cf_TPE_base_is_Executor:
  description: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor') returns True — ThreadPoolExecutor.__bases__[0] is concurrent.futures.Executor; TPE.__bases__[0].__name__=='Executor' (len=8); ThreadPoolExecutor inherits from Executor and implements submit(fn, *args, **kwargs) by dispatching fn to a worker thread via the internal work queue; Executor.submit() raises NotImplementedError forcing TPE to provide a concrete implementation; Executor.map() and Executor.shutdown() are inherited without override (TPE does NOT override map() — established in extra162 where TPE.__dict__.__contains__('map')==False); TPE.__bases__[0].__name__=='Executor' == PPE.__bases__[0].__name__=='Executor' — both concrete executor classes share the same base; the 'Executor'=8 suffix in 'ThreadPoolExecutor'=18 visually signals the inheritance relationship: the class name embeds the parent class name; NEW in extra164: first standalone TPE.__bases__[0].__name__ invariant in cftpebase164 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

invariant concurrent_futures_extra164.cf_PPE_name_eq:
  description: "concurrent.futures.ProcessPoolExecutor.__name__.__eq__('ProcessPoolExecutor') returns True — concurrent.futures.ProcessPoolExecutor.__name__=='ProcessPoolExecutor' (len=19: 'Process'=7+'Pool'=4+'Executor'=8=19); ProcessPoolExecutor is the concurrent.futures executor for CPU-bound parallel computation; it bypasses the Python GIL by running work in separate processes; work items (fn, args) are pickled and sent to worker processes via multiprocessing queues; PPE is best suited for CPU-intensive pure-Python computations where thread-based parallelism is limited by the GIL; ProcessPoolExecutor.__name__.__len__()==19 > ThreadPoolExecutor.__name__.__len__()==18 by exactly 1 char because 'Process'=7 > 'Thread'=6 by 1; the 'PoolExecutor'=12 suffix ('Pool'=4+'Executor'=8=12) is shared between both executors; NEW in extra164: first standalone PPE.__name__ identity invariant in cfppeid164 namespace (cross-spec: extra162 covered PPE.__name__ in cfppedli162; here covered in cfppeid164 with base class context); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: concurrent.futures.ProcessPoolExecutor.__name__.__eq__
  args: ["ProcessPoolExecutor"]
  expected: true

invariant concurrent_futures_extra164.cf_PPE_base_is_Executor:
  description: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__('Executor') returns True — ProcessPoolExecutor.__bases__[0] is concurrent.futures.Executor; PPE.__bases__[0].__name__=='Executor' (len=8); ProcessPoolExecutor inherits from Executor and implements submit(fn, *args, **kwargs) with a process-pool-based dispatch using multiprocessing queues and process management; PPE also overrides map() to support the chunksize argument (established in extra162 where PPE.__dict__.__contains__('map')==True); the shared base class Executor guarantees that TPE and PPE present the same interface: submit(), map(), and shutdown() — callers can treat both executor types identically through the Executor interface; PPE.__bases__[0].__name__=='Executor' == TPE.__bases__[0].__name__=='Executor' — both concrete executor types share the same single base class; NEW in extra164: first standalone PPE.__bases__[0].__name__ invariant in cfppebase164 namespace with TPE comparison context; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "concurrent.futures.ProcessPoolExecutor.__bases__[0].__name__.__eq__"
  args: ["Executor"]
  expected: true

