spec: concurrent_futures_extra164
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
  notes:
    - "This spec covers: concurrent.futures.ThreadPoolExecutor class name, module, and base class identity; concurrent.futures.ProcessPoolExecutor class name, module, and base class identity. Both executors inherit from concurrent.futures.Executor: TPE.__bases__[0].__name__=='Executor' and PPE.__bases__[0].__name__=='Executor'. TPE.__module__=='concurrent.futures.thread' (len=25); PPE.__module__=='concurrent.futures.process' (len=26). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18: 'Thread'=6+'Pool'=4+'Executor'=8=18); __module__=='concurrent.futures.thread' (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25); __bases__[0].__name__=='Executor' (len=8: TPE inherits from Executor; the 'Executor'=8 suffix appears in both ThreadPoolExecutor and ProcessPoolExecutor names; established in extra161 for name/module identity; established in extra162 for __dict__ membership; established in extra163 for Executor base class identity). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "concurrent.futures.ProcessPoolExecutor.__name__=='ProcessPoolExecutor' (len=19: 'Process'=7+'Pool'=4+'Executor'=8=19; 1 longer than ThreadPoolExecutor=18 because 'Process'=7 > 'Thread'=6 by 1); __module__=='concurrent.futures.process' (len=26: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'process'=7=26; 1 longer than thread module=25); __bases__[0].__name__=='Executor' (len=8: PPE also inherits from Executor; both TPE and PPE share the same base class). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor class identity — extra164
#
# concurrent.futures.ThreadPoolExecutor.__name__.__eq__('ThreadPoolExecutor') == True
# concurrent.futures.ThreadPoolExecutor.__name__.__len__()                    == 18
# concurrent.futures.ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread') == True
# concurrent.futures.ThreadPoolExecutor.__module__.__len__()                  == 25
# ---------------------------------------------------------------------------

table concurrent_futures_extra164.cf_tpe_identity:
  description: "concurrent.futures.ThreadPoolExecutor class name and module identity checks in cftpeid164 namespace — concurrent.futures.ThreadPoolExecutor.__name__.__eq__('ThreadPoolExecutor')==True (ThreadPoolExecutor.__name__=='ThreadPoolExecutor' (len=18: 'Thread'=6+'Pool'=4+'Executor'=8=18); ThreadPoolExecutor manages a pool of worker threads; submit(fn, *args, **kwargs) runs fn in a thread and returns a Future; thread creation is bounded by max_workers; threads are reused across calls; worker threads are daemon threads by default when initializer is not set); concurrent.futures.ThreadPoolExecutor.__name__.__len__()==18 ('ThreadPoolExecutor'=18: the 'Executor'=8 suffix is shared with ProcessPoolExecutor; 'Thread'=6+'Pool'=4=10 is the distinctive prefix); concurrent.futures.ThreadPoolExecutor.__module__.__eq__('concurrent.futures.thread')==True (__module__=='concurrent.futures.thread' (len=25: 'concurrent'=10+'.'=1+'futures'=7+'.'=1+'thread'=6=25; 'thread'=6 matches 'Thread'=6 in class name — the submodule name equals the first component of the class name prefix)); concurrent.futures.ThreadPoolExecutor.__module__.__len__()==25 ('concurrent.futures.thread'=25; compare: Executor module 'concurrent.futures._base'=24 is 1 shorter — '_base'=5 < 'thread'=6); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpeid164

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_name_eq,  concurrent.futures.ThreadPoolExecutor.__name__.__eq__,    ["ThreadPoolExecutor"],           true,  "TPE.__name__ == 'ThreadPoolExecutor' (len=18: 'Thread'=6+'Pool'=4+'Executor'=8=18); verified with Python 3.14.3"]
    - [tpe_name_len, concurrent.futures.ThreadPoolExecutor.__name__.__len__,   [],                               18,    "TPE.__name__.__len__() == 18 ('ThreadPoolExecutor'=18; 1 shorter than ProcessPoolExecutor=19); verified with Python 3.14.3"]
    - [tpe_mod_eq,   concurrent.futures.ThreadPoolExecutor.__module__.__eq__,  ["concurrent.futures.thread"],    true,  "TPE.__module__ == 'concurrent.futures.thread' (len=25; 'thread'=6 submodule); verified with Python 3.14.3"]
    - [tpe_mod_len,  concurrent.futures.ThreadPoolExecutor.__module__.__len__, [],                               25,    "TPE.__module__.__len__() == 25 ('concurrent.futures.thread'=25; 1 longer than _base=24); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor base class — extra164
#
# concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor') == True
# concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__len__()          == 8
# ---------------------------------------------------------------------------

table concurrent_futures_extra164.cf_tpe_base_class:
  description: "concurrent.futures.ThreadPoolExecutor base class checks in cftpebase164 namespace — concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__('Executor')==True (ThreadPoolExecutor.__bases__ == (<class 'concurrent.futures._base.Executor'>,); __bases__[0].__name__=='Executor' (len=8: 'E'+'x'+'e'+'c'+'u'+'t'+'o'+'r'=8); ThreadPoolExecutor inherits from Executor (the abstract base class established in extra163) and implements submit() with a thread-pool-based dispatch mechanism; TPE does NOT override map() — it inherits Executor.map() directly (established in extra162 table cf_ppe_vs_tpe_map_contrast)); concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__len__()==8 ('Executor'=8; the base class name 'Executor'=8 is also the suffix of 'ThreadPoolExecutor'=18: 18-8=10 is the 'ThreadPool' prefix length; 'Thread'=6+'Pool'=4=10); tpe_name_len cross-check: TPE.__name__.__len__()==18 (confirmed in table above; 18 > Executor base name len=8 by 10 — the 'ThreadPool' prefix is 10 chars); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: cftpebase164

  columns: [id, function, args, expected, description]
  rows:
    - [tpe_base_name_eq,  "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__eq__",  ["Executor"],  true,  "TPE.__bases__[0].__name__ == 'Executor' (inherits from Executor abstract base class); verified with Python 3.14.3"]
    - [tpe_base_name_len, "concurrent.futures.ThreadPoolExecutor.__bases__[0].__name__.__len__", [],            8,     "TPE.__bases__[0].__name__.__len__() == 8 ('Executor'=8; suffix of ThreadPoolExecutor=18; 18-8=10='ThreadPool'); verified with Python 3.14.3"]
    - [tpe_name_len2,     concurrent.futures.ThreadPoolExecutor.__name__.__len__,                [],            18,    "TPE.__name__.__len__() == 18 (cross-check; 'ThreadPoolExecutor'=18); verified with Python 3.14.3"]
    - [tpe_mod_len2,      concurrent.futures.ThreadPoolExecutor.__module__.__len__,               [],            25,    "TPE.__module__.__len__() == 25 (cross-check; 'concurrent.futures.thread'=25); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor class identity — extra164
#
# concurrent.futures.ProcessPoolExecutor.__name__.__eq__('ProcessPoolExecutor') == True
