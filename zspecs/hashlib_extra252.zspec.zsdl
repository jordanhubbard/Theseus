spec: hashlib_extra252
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra.zspec.zsdl — covers blake2b default/custom digest_size / sha3_224/sha3_384 attrs / algorithms_guaranteed (table + invariants)."
    - "hashlib_extra251.zspec.zsdl — covers algorithms_guaranteed.__contains__ for md5/sha1/sha256/sha3_256/blake2b / algorithms_guaranteed type identity / len==14 (table + invariants)."
  notes:
    - "Wave 295 theme: hashlib SHAKE algorithms and BLAKE2 digest_size behavior / SHA-3 digest_size table."
    - "hashlib.sha3_256(b'').digest_size == 32. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_512(b'').digest_size == 64. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_224(b'').digest_size == 28. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha3_384(b'').digest_size == 48. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b(b'').digest_size == 64 (default). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s(b'').digest_size == 32 (default). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_128(b'').digest(16).__len__() == 16 (variable-length output). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.shake_256(b'').digest(32).__len__() == 32 (variable-length output). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__name__ == 'blake2b'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2b.__module__ == '_blake2'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__name__ == 'blake2s'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.blake2s.__module__ == '_blake2'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: On macOS, hashlib.sha3_256 is a builtin_function_or_method with __name__=='openssl_sha3_256' (OpenSSL-backed). The digest_size is read from the instance returned by calling the constructor with b''. SHA-3 uses a Keccak sponge construction with fixed output sizes: sha3_224=28, sha3_256=32, sha3_384=48, sha3_512=64 bytes."
    - "Note: SHAKE (SHA-3 XOF) algorithms produce variable-length output. Unlike sha3_256/sha3_512 which have a fixed digest_size attribute, SHAKE digests require a length argument to .digest(n). shake_128 provides 128-bit security; shake_256 provides 256-bit security — regardless of the output length requested."
    - "Note: blake2b and blake2s are defined in the _blake2 C extension (Modules/_blake2/). Their default digest sizes are blake2b=64 bytes (512-bit) and blake2s=32 bytes (256-bit). Custom digest sizes can be specified via the digest_size keyword argument."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SHA-3 digest_size values for all four SHA-3 variants
#
# Wave 295 theme: SHA-3 family (sha3_224/sha3_256/sha3_384/sha3_512) digest_size.
#
# The SHA-3 family uses a Keccak sponge construction with four standard output
# sizes: 224, 256, 384, and 512 bits (28, 32, 48, and 64 bytes). On macOS the
# constructors are OpenSSL-backed builtin_function_or_method objects. The
# digest_size is a property of the instance, not the constructor. hashlib_extra
# anchors sha3_224/sha3_384 attrs; no prior spec anchors all four SHA-3
# digest_size values together as a grouped table under hashlibshake295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra252.sha3_digest_sizes:
  description: "sha3_224(b'').digest_size.__eq__(28)==True / sha3_256(b'').digest_size.__eq__(32)==True / sha3_384(b'').digest_size.__eq__(48)==True / sha3_512(b'').digest_size.__eq__(64)==True — SHA-3 family has four fixed output sizes (28/32/48/64 bytes); Keccak sponge construction; on macOS constructors are openssl_sha3_* builtins; hashlib_extra anchors sha3_224/sha3_384 attrs; first hashlibshake295 anchor for all four SHA-3 digest_size values together"
  kind: python_call_eq
  category: digest_size
  id_prefix: hashlibshake295

  columns: [id, function, args, expected, description]
  rows:
    - [sha3_224_dsize,  "sha3_224(b'').digest_size.__eq__",  [28], true, "sha3_224 digest_size is 28 bytes (224 bits; smallest SHA-3 standard size)"]
    - [sha3_256_dsize,  "sha3_256(b'').digest_size.__eq__",  [32], true, "sha3_256 digest_size is 32 bytes (256 bits; most widely used SHA-3 variant)"]
    - [sha3_384_dsize,  "sha3_384(b'').digest_size.__eq__",  [48], true, "sha3_384 digest_size is 48 bytes (384 bits; SHA-3 intermediate output size)"]
    - [sha3_512_dsize,  "sha3_512(b'').digest_size.__eq__",  [64], true, "sha3_512 digest_size is 64 bytes (512 bits; largest SHA-3 standard size)"]

# ---------------------------------------------------------------------------
# BLAKE2 default digest_size values: blake2b and blake2s
#
# Wave 295 theme: BLAKE2 default digest_size for blake2b (64) and blake2s (32).
#
# BLAKE2 is a cryptographic hash function faster than MD5/SHA-1/SHA-2/SHA-3
# on 64-bit platforms. blake2b is optimized for 64-bit systems (max 64-byte
# output); blake2s is optimized for 8-to-32-bit systems (max 32-byte output).
# When called with no digest_size keyword, both use their maximum output size.
# blake2b and blake2s have __module__=='_blake2' (the C extension). hashlib_extra
# anchors blake2b digest_size in a table; no prior spec anchors blake2b and
# blake2s digest_size together with __name__ in a grouped table under hashlibshake295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra252.blake2_identity_and_digest_size:
  description: "blake2b.__name__.__eq__('blake2b')==True / blake2b.__module__.__eq__('_blake2')==True / blake2b(b'').digest_size.__eq__(64)==True / blake2s.__name__.__eq__('blake2s')==True / blake2s.__module__.__eq__('_blake2')==True / blake2s(b'').digest_size.__eq__(32)==True — BLAKE2 is faster than SHA-2/SHA-3 on 64-bit; blake2b max=64 bytes / blake2s max=32 bytes; both from _blake2 C extension; hashlib_extra anchors blake2b digest_size; first hashlibshake295 anchor for blake2 __name__/__module__ identity + digest_size"
  kind: python_call_eq
  category: blake2_identity
  id_prefix: hashlibshake295

  columns: [id, function, args, expected, description]
  rows:
    - [blake2b_name_eq,    "blake2b.__name__.__eq__",          ["blake2b"],  true, "blake2b.__name__ is 'blake2b' (C type name in _blake2 extension)"]
    - [blake2b_module_eq,  "blake2b.__module__.__eq__",        ["_blake2"],  true, "blake2b.__module__ is '_blake2' (C extension module, not 'hashlib')"]
    - [blake2b_dsize_eq,   "blake2b(b'').digest_size.__eq__",  [64],         true, "blake2b default digest_size is 64 bytes (512-bit; optimized for 64-bit platforms)"]
    - [blake2s_name_eq,    "blake2s.__name__.__eq__",          ["blake2s"],  true, "blake2s.__name__ is 'blake2s' (C type name in _blake2 extension)"]
    - [blake2s_module_eq,  "blake2s.__module__.__eq__",        ["_blake2"],  true, "blake2s.__module__ is '_blake2' (same C extension as blake2b)"]
    - [blake2s_dsize_eq,   "blake2s(b'').digest_size.__eq__",  [32],         true, "blake2s default digest_size is 32 bytes (256-bit; optimized for 32-bit platforms)"]

# ---------------------------------------------------------------------------
# SHAKE variable-length output: shake_128.digest(16) and shake_256.digest(32)
#
# Wave 295 theme: SHAKE (Extendable Output Function) variable-length digest.
#
# SHAKE-128 and SHAKE-256 are SHA-3 XOF (Extendable Output Function) variants
# that produce variable-length output. Unlike fixed-output SHA-3 variants, SHAKE
# algorithms require a length argument to .digest(n). The length of the returned
# bytes object equals the argument passed to .digest(). shake_128 provides
# 128-bit security regardless of output length; shake_256 provides 256-bit
# security. No prior spec anchors shake_128.digest(16).__len__() and
# shake_256.digest(32).__len__() as standalone invariants under hashlibshake295.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra252.shake_128_digest_16_len:
  description: "hashlib.shake_128(b'').digest(16).__len__() == 16 — SHAKE-128 is an XOF (extendable output function); .digest(n) returns exactly n bytes; provides 128-bit security regardless of output length; hashlib.shake_128.__name__=='openssl_shake_128' on macOS (OpenSSL-backed); no prior spec anchors shake_128 digest length as standalone; first standalone under hashlibshake295"
  category: shake_output
  kind: python_call_eq
  function: "shake_128(b'').digest(16).__len__"
  args: []
  expected: 16

invariant hashlib_extra252.shake_256_digest_32_len:
  description: "hashlib.shake_256(b'').digest(32).__len__() == 32 — SHAKE-256 is an XOF (extendable output function); .digest(n) returns exactly n bytes; provides 256-bit security regardless of output length; hashlib.shake_256.__name__=='openssl_shake_256' on macOS (OpenSSL-backed); no prior spec anchors shake_256 digest length as standalone; first standalone under hashlibshake295"
  category: shake_output
  kind: python_call_eq
  function: "shake_256(b'').digest(32).__len__"
  args: []
  expected: 32

invariant hashlib_extra252.blake2b_default_digest_size:
  description: "hashlib.blake2b(b'').digest_size.__eq__(64) == True — blake2b default digest_size is 64 bytes (512 bits); this is the maximum output size for blake2b; can be reduced via digest_size= keyword argument (min 1, max 64); designed for 64-bit platforms; hashlib_extra anchors blake2b digest_size in a table; no prior spec anchors blake2b default digest_size as standalone; first standalone under hashlibshake295"
  category: digest_size
  kind: python_call_eq
  function: "blake2b(b'').digest_size.__eq__"
  args: [64]
  expected: true
