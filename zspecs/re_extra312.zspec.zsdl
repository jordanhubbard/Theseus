spec: re_extra312
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.sub(r'\\d+', 'N', 'abc123def456') == 'abcNdefN' — replaces all digit runs."
    - "re.sub(r'\\d+', 'N', 'abc123def456', count=1) == 'abcNdef456' — count=1 stops after first replacement."
    - "re.split(r'\\s+', 'hello world foo') == ['hello', 'world', 'foo'] — three elements."
    - "re.findall(r'\\d+', 'abc123def456') == ['123', '456'] — two digit runs found."
    - "re.findall(r'[a-z]+', 'abc123def456') == ['abc', 'def'] — two lowercase runs found."
    - "re.search(r'\\d+', 'abc123def').group() == '123' — returns the first match."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.sub — full replacement and count-limited replacement
# ---------------------------------------------------------------------------

invariant re_extra312.sub.all_digits:
  description: "re.sub(r'\\d+', 'N', 'abc123def456') == 'abcNdefN' — replaces all digit runs with 'N'; verified with Python 3.14.3"
  category: substitution
  kind: python_call_eq
  function: sub
  args: ["\\d+", "N", "abc123def456"]
  expected: "abcNdefN"

invariant re_extra312.sub.count_1:
  description: "re.sub(r'\\d+', 'N', 'abc123def456', count=1) == 'abcNdef456' — count=1 limits to first replacement; verified with Python 3.14.3"
  category: substitution
  kind: python_call_eq
  function: sub
  args: ["\\d+", "N", "abc123def456", 1]
  expected: "abcNdef456"

# ---------------------------------------------------------------------------
# re.split — whitespace splitting
# ---------------------------------------------------------------------------

invariant re_extra312.split.whitespace:
  description: "re.split(r'\\s+', 'hello world foo') == ['hello', 'world', 'foo']; verified with Python 3.14.3"
  category: split
  kind: python_call_eq
  function: split
  args: ["\\s+", "hello world foo"]
  expected: ["hello", "world", "foo"]

invariant re_extra312.split.whitespace.len:
  description: "re.split(r'\\s+', 'hello world foo').__len__() == 3; verified with Python 3.14.3"
  category: split
  kind: python_call_eq
  function: "split('\\s+', 'hello world foo').__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# re.findall — digit and lowercase runs
# ---------------------------------------------------------------------------

invariant re_extra312.findall.digits:
  description: "re.findall(r'\\d+', 'abc123def456') == ['123', '456']; verified with Python 3.14.3"
  category: findall
  kind: python_call_eq
  function: findall
  args: ["\\d+", "abc123def456"]
  expected: ["123", "456"]

invariant re_extra312.findall.digits.len:
  description: "re.findall(r'\\d+', 'abc123def456').__len__() == 2; two digit runs found; verified with Python 3.14.3"
  category: findall
  kind: python_call_eq
  function: "findall('\\d+', 'abc123def456').__len__"
  args: []
  expected: 2

invariant re_extra312.findall.lowercase.len:
  description: "re.findall(r'[a-z]+', 'abc123def456').__len__() == 2; two lowercase letter runs found; verified with Python 3.14.3"
  category: findall
  kind: python_call_eq
  function: "findall('[a-z]+', 'abc123def456').__len__"
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# re.search — first match group
# ---------------------------------------------------------------------------

invariant re_extra312.search.group:
  description: "re.search(r'\\d+', 'abc123def').group() == '123' — first digit run found; verified with Python 3.14.3"
  category: search
  kind: python_call_eq
  function: "search('\\d+', 'abc123def').group"
  args: []
  expected: "123"
