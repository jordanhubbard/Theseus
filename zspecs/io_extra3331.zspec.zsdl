spec: io3331
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 669 (io3331): __iand__, __ior__, __ixor__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "Theme: __iand__, __ior__, __ixor__ dict-presence (in-place &=, |=, ^=)."
    - "No io class defines __iand__ in its own __dict__: stream I/O classes are sequential I/O abstractions, not numeric or bitwise types, and do not implement in-place bitwise AND."
    - "No io class defines __ior__ in its own __dict__: stream I/O classes do not implement in-place bitwise OR; bitwise operators have no meaning for I/O streams."
    - "No io class defines __ixor__ in its own __dict__: stream I/O classes do not implement in-place bitwise XOR; augmented bitwise assignment operators are not part of the I/O stream protocol."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with waves 666/667/668 pattern: all in-place arithmetic/bitwise operators absent from io class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iand__ dict-presence — operator.contains(Cls.__dict__, '__iand__')
#
# No io class defines __iand__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not numeric types,
# and do not implement the in-place bitwise AND operator (&=).
# ---------------------------------------------------------------------------

table io3331.iand:
  description: "io types __iand__ dict-presence checks; wave 669"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: io3331

  columns: [id, function, args, expected]
  rows:
    - ["io3331001", operator.contains, [io.RawIOBase.__dict__,       "__iand__"], false]
    - ["io3331002", operator.contains, [io.BufferedIOBase.__dict__,  "__iand__"], false]
