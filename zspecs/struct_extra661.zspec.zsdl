spec: struct_extra661
backend: python_module(struct)
description: "struct.Struct additional property descriptor qualnames, method names, and class identity"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct.Struct class attributes and methods"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers Struct property qualnames, method __name__ values, __repr__ qualname, and error class identity"]
  created_at: "2026-04-12T00:00:00Z"

table struct_extra661.struct_property_qualnames:
  description: "Qualified names of Struct property descriptors"
  kind: python_call_eq
  category: descriptor_qualname
  id_prefix: st661pqn
  columns: [id, function, args, expected]
  rows:
    - [st661pqn001, struct.Struct.format.__qualname__.__eq__, ["Struct.format"], true]
    - [st661pqn002, struct.Struct.size.__qualname__.__eq__, ["Struct.size"], true]

table struct_extra661.struct_method_names:
  description: "Short __name__ values for Struct pack/unpack methods"
  kind: python_call_eq
  category: method_name
  id_prefix: st661mtn
  columns: [id, function, args, expected]
  rows:
    - [st661mtn001, struct.Struct.pack.__name__.__eq__, ["pack"], true]
    - [st661mtn002, struct.Struct.unpack.__name__.__eq__, ["unpack"], true]
    - [st661mtn003, struct.Struct.pack_into.__name__.__eq__, ["pack_into"], true]
    - [st661mtn004, struct.Struct.unpack_from.__name__.__eq__, ["unpack_from"], true]
    - [st661mtn005, struct.Struct.iter_unpack.__name__.__eq__, ["iter_unpack"], true]

table struct_extra661.struct_repr_qualname:
  description: "Qualified name of Struct.__repr__"
  kind: python_call_eq
  category: method_qualname
  id_prefix: st661rqn
  columns: [id, function, args, expected]
  rows:
    - [st661rqn001, struct.Struct.__repr__.__qualname__.__eq__, ["Struct.__repr__"], true]

table struct_extra661.struct_doc_and_class_identity:
  description: "Struct.__doc__ class name and type identity for Struct and error"
  kind: python_call_eq
  category: class_identity
  id_prefix: st661dci
  columns: [id, function, args, expected]
  rows:
    - [st661dci001, struct.Struct.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [st661dci002, struct.error.__bases__.__class__.__name__.__eq__, ["tuple"], true]
    - [st661dci003, struct.Struct.__class__.__name__.__eq__, ["type"], true]
    - [st661dci004, struct.error.__class__.__name__.__eq__, ["type"], true]
