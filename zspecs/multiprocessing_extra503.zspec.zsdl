spec: multiprocessing_extra503
version: ">=3.9"
backend: python_module(multiprocessing.managers)
docs: https://docs.python.org/3/library/multiprocessing.html#managers
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#managers — multiprocessing.managers class hierarchy"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "BaseManager and BaseProxy both inherit directly from object"
    - "SyncManager inherits from BaseManager"
    - "All classes reside in multiprocessing.managers module"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra503.base_manager_identity:
  description: "multiprocessing.managers.BaseManager class identity invariants"
  kind: python_call_eq
  category: class_identity
  id_prefix: BMI

  columns: [id, function, args, expected]
  rows:
    - [BMI001, multiprocessing.managers.BaseManager.__name__.__eq__, ["BaseManager"], true]
    - [BMI002, multiprocessing.managers.BaseManager.__module__.__eq__, ["multiprocessing.managers"], true]

