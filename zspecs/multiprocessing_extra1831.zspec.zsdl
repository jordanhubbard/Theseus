spec: multiprocessing_extra1831
version: ">=3.9"
backend: python_module(multiprocessing)
error_model: python_exceptions
provenance:
  derived_from:
    - "multiprocessing stdlib documentation"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/pool.py"
  not_derived_from:
    - "third-party process pool libraries"
  notes:
    - "Pool is in multiprocessing.pool submodule and is NOT re-exported at the top-level multiprocessing namespace"
    - "Process.__call__ is absent; processes are started via .start(), not by calling the object"
    - "multiprocessing.Queue, Lock, Event, Semaphore are convenience aliases at the top level"
  created_at: "2026-04-12"

table multiprocessing_extra1831.descriptor_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["mp1831-dp-001", "multiprocessing.Process.__dict__.__contains__", ["__get__"], false]
    - ["mp1831-dp-002", "multiprocessing.Process.__dict__.__contains__", ["__set__"], false]
    - ["mp1831-dp-003", "multiprocessing.pool.Pool.__dict__.__contains__", ["__get__"], false]
    - ["mp1831-dp-004", "multiprocessing.pool.Pool.__dict__.__contains__", ["__set__"], false]
    - ["mp1831-dp-005", "multiprocessing.managers.BaseManager.__dict__.__contains__", ["__get__"], false]
    - ["mp1831-dp-006", "multiprocessing.pool.AsyncResult.__dict__.__contains__", ["__get__"], false]
    - ["mp1831-dp-007", "multiprocessing.Process.__dict__.__contains__", ["__set_name__"], false]
    - ["mp1831-dp-008", "multiprocessing.pool.Pool.__dict__.__contains__", ["__set_name__"], false]

