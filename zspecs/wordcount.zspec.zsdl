spec: wordcount
version: ">=1.1.1"
backend: node(wordcount)

docs: https://www.npmjs.com/package/wordcount

provenance:
  derived_from:
    - "wordcount README — https://www.npmjs.com/package/wordcount"
    - "Test vectors verified with wordcount via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "wordcount source"
  notes:
    - "wordcount is an npm package. Install: npm install wordcount"
    - "Returns the number of words in a string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an integer."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table wordcount.count:
  kind: node_module_call_eq
  function: ~
  category: text
  id_prefix: wrdcnt

  columns: [id, args, expected]
  rows:
    - [two,    ["hello world"],      2]
    - [three,  ["one two three"],    3]
    - [four,   ["the quick brown fox"], 4]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T01:27:41Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
