spec: socket_extra67
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra66.zspec.zsdl — covers socket.accept/__defaults__/__class__/__name__=='NoneType' / socket.makefile/__defaults__/__class__/__name__=='tuple' / socket.makefile/__defaults__/__len__()==2 / socket.setblocking/__defaults__/__class__/__name__=='NoneType' / socket.settimeout/__defaults__/__class__/__name__=='NoneType' / socket.__name__/__module__/__qualname__=='socket' / socket.__bases__[0].__name__=='object' / socket.__mro__.__len__()==2 (table + invariants)."
    - "socket_extra65.zspec.zsdl — covers socket.socket.accept/__code__.co_consts/__class__.__name__=='tuple' / makefile/__code__.co_consts/__class__.__name__=='tuple' / co_nlocals/__class__.__name__=='int' / co_stacksize/__class__.__name__=='int' / AF_INET/__eq__(2) / SOCK_STREAM/__eq__(1) / SOCK_DGRAM/__eq__(2) (table + invariants)."
    - "socket_extra64.zspec.zsdl — covers socket.socket.accept/__code__.co_varnames/__class__.__name__=='tuple' / makefile/__code__.co_varnames/__class__.__name__=='tuple' / accept/__code__.co_varnames[0]=='self' / makefile/__code__.co_varnames[0]=='self' / AF_INET/__class__.__name__=='AddressFamily' / SOCK_STREAM/__class__.__name__=='SocketKind' (table + invariants)."
    - "socket_extra63.zspec.zsdl — covers socket.socket.accept/__code__.co_name ('accept') / makefile/__code__.co_name ('makefile') / accept/__code__.co_argcount==1 / makefile/__code__.co_argcount==3 / gethostbyname/__doc__.__contains__('host') / getfqdn/__doc__.__contains__('hostname') (table + invariants)."
    - "socket_extra62.zspec.zsdl — covers socket.socket.accept/__defaults__/__class__/__name__.__eq__('NoneType') / makefile/__defaults__/__class__/__name__.__eq__('tuple') (table + invariants)."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec extends socket through socket_extra66; it does NOT duplicate invariants present in those files."
    - "Wave 234 theme: __kwdefaults__ for socket.socket Python methods + socket module-level function identity (gethostname/gethostbyname as C builtins, getfqdn as Python function)."
    - "In python_module(socket) backend, 'socket' in the module namespace refers to the socket.socket class. So 'socket.accept' means 'socket.socket.accept'. Module-level functions (gethostname, gethostbyname, getfqdn) are referenced directly by name."
    - "socket.socket.accept.__kwdefaults__.__class__.__name__ == 'NoneType' — accept(self) has no keyword-only parameters; __kwdefaults__ is None. No prior socket spec checks accept.__kwdefaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__kwdefaults__.__class__.__name__ == 'NoneType' — makefile(self, mode='r', buffering=None) has no keyword-only parameters; __kwdefaults__ is None. No prior socket spec checks makefile.__kwdefaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.setblocking.__kwdefaults__.__class__.__name__ == 'NoneType' — setblocking(self, flag) has no keyword-only parameters; __kwdefaults__ is None. No prior socket spec checks setblocking.__kwdefaults__.__class__.__name__ in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__class__.__name__ == 'builtin_function_or_method' — gethostname is a C builtin function from the _socket C extension. No prior socket spec checks gethostname.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostname.__module__ == 'socket' — gethostname is exposed in the socket module namespace; __module__ is 'socket'. No prior socket spec checks gethostname.__module__.__eq__('socket') in call form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__class__.__name__ == 'builtin_function_or_method' — gethostbyname is a C builtin function. No prior socket spec checks gethostbyname.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.gethostbyname.__module__ == 'socket' — __module__ is 'socket'. No prior socket spec checks gethostbyname.__module__.__eq__('socket') in call form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__class__.__name__ == 'function' — getfqdn is a pure-Python function in Lib/socket.py; its class is 'function'. No prior socket spec checks getfqdn.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__module__ == 'socket' — getfqdn is defined in Lib/socket.py; __module__ is 'socket'. No prior socket spec checks getfqdn.__module__.__eq__('socket') in call form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__qualname__ == 'getfqdn' — getfqdn is a top-level function in Lib/socket.py; __qualname__ is 'getfqdn'. No prior socket spec checks getfqdn.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__code__.co_name == 'getfqdn' — the code object co_name is the function name. No prior socket spec checks getfqdn.__code__.co_name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__defaults__.__class__.__name__ == 'tuple' — def getfqdn(name=''): has one positional default; __defaults__ is a tuple. No prior socket spec checks getfqdn.__defaults__.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__defaults__.__len__() == 1 — the defaults tuple has one element (name=''). No prior socket spec checks getfqdn.__defaults__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.accept / makefile / setblocking __kwdefaults__ NoneType
#
# Wave 234 theme: __kwdefaults__ NoneType for socket.socket Python methods.
#
# socket.socket.accept(self), socket.socket.makefile(self, mode='r',
# buffering=None), and socket.socket.setblocking(self, flag) are Python methods
# defined in Lib/socket.py with no keyword-only parameters. __kwdefaults__ is
# None (NoneType) for all three. No prior socket spec checks __kwdefaults__ for
# any socket method in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra67.none_kwdefaults:
  description: "socket.accept/__kwdefaults__/__class__/__name__=='NoneType' / socket.makefile/__kwdefaults__/__class__/__name__=='NoneType' / socket.setblocking/__kwdefaults__/__class__/__name__=='NoneType' — accept/makefile/setblocking are Python methods in Lib/socket.py with no keyword-only parameters; __kwdefaults__ is None (NoneType); no prior socket spec checks __kwdefaults__ for any socket method; first __kwdefaults__ identity anchor for socket.socket methods"
  kind: python_call_eq
  category: kwdefaults
  id_prefix: socketkw67

  columns: [id, function, args, expected]
  rows:
    - [socket_accept_kwdefaults_class_NoneType,    socket.accept.__kwdefaults__.__class__.__name__.__eq__,    ["NoneType"], true]
    - [socket_makefile_kwdefaults_class_NoneType,  socket.makefile.__kwdefaults__.__class__.__name__.__eq__,  ["NoneType"], true]
    - [socket_setblocking_kwdefaults_class_NoneType, socket.setblocking.__kwdefaults__.__class__.__name__.__eq__, ["NoneType"], true]

# ---------------------------------------------------------------------------
# socket.gethostname and gethostbyname class identity and module
#
# Wave 234 theme: gethostname and gethostbyname C builtin identity.
#
# socket.gethostname and socket.gethostbyname are C builtin functions from the
# _socket C extension, exposed in the socket module namespace. Their
# __class__.__name__ is 'builtin_function_or_method' and __module__ is 'socket'.
# No prior socket spec checks __class__.__name__ or __module__.__eq__ in call
# form for gethostname or gethostbyname. Verified Python 3.14.3 macOS/Darwin.
# ---------------------------------------------------------------------------

table socket_extra67.builtin_socket_functions:
  description: "socket.gethostname/__class__/__name__=='builtin_function_or_method' / socket.gethostbyname/__class__/__name__=='builtin_function_or_method' / socket.gethostname/__module__.__eq__('socket')==True / socket.gethostbyname/__module__.__eq__('socket')==True — gethostname and gethostbyname are C builtin functions from _socket extension; __class__.__name__ is 'builtin_function_or_method'; __module__ is 'socket'; no prior socket spec checks __class__/__name__ or __module__.__eq__ for these functions; first C builtin identity anchor for gethostname/gethostbyname"
  kind: python_call_eq
  category: class_identity
  id_prefix: socketkw67

  columns: [id, function, args, expected]
  rows:
    - [gethostname_class_builtin_function,    gethostname.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [gethostbyname_class_builtin_function,  gethostbyname.__class__.__name__.__eq__,  ["builtin_function_or_method"], true]
    - [gethostname_module_socket,             gethostname.__module__.__eq__,            ["socket"],                     true]
    - [gethostbyname_module_socket,           gethostbyname.__module__.__eq__,          ["socket"],                     true]

# ---------------------------------------------------------------------------
# socket.getfqdn identity — class, module, qualname, code co_name
#
# Wave 234 theme: getfqdn is a pure-Python function in Lib/socket.py.
#
# socket.getfqdn is defined in Lib/socket.py (not a C builtin). Its
# __class__.__name__ is 'function', __module__ is 'socket', __qualname__ is
# 'getfqdn', and __code__.co_name is 'getfqdn'. No prior socket spec checks
# any of these for getfqdn. socket_extra63 covers getfqdn.__doc__.__contains__
# ('hostname') but not class/module/qualname/code identity.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra67.getfqdn_identity:
  description: "socket.getfqdn/__class__/__name__=='function' / socket.getfqdn/__module__.__eq__('socket')==True / socket.getfqdn/__qualname__.__eq__('getfqdn')==True / socket.getfqdn/__code__.co_name.__eq__('getfqdn')==True — getfqdn is a pure-Python function in Lib/socket.py; class is 'function'; __module__ and __qualname__ are 'socket'/'getfqdn'; co_name is 'getfqdn'; socket_extra63 covers getfqdn.__doc__.__contains__('hostname') but not these identity attributes; first class/module/qualname/code anchor for socket.getfqdn"
  kind: python_call_eq
  category: function_identity
  id_prefix: socketkw67

  columns: [id, function, args, expected]
  rows:
    - [getfqdn_class_function,      getfqdn.__class__.__name__.__eq__,       ["function"], true]
    - [getfqdn_module_socket,       getfqdn.__module__.__eq__,               ["socket"],   true]
    - [getfqdn_qualname_getfqdn,    getfqdn.__qualname__.__eq__,             ["getfqdn"],  true]
    - [getfqdn_code_co_name,        getfqdn.__code__.co_name.__eq__,         ["getfqdn"],  true]

# ---------------------------------------------------------------------------
# socket.getfqdn __defaults__ structure — class name and length
#
# Wave 234 theme: getfqdn.__defaults__ is a tuple of length 1.
#
# socket.getfqdn is defined as def getfqdn(name=''): with one positional
# default (name=''). __defaults__ is a tuple of length 1. No prior socket spec
# checks getfqdn.__defaults__.__class__.__name__ or getfqdn.__defaults__.__len__
# in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra67.getfqdn_defaults:
  description: "socket.getfqdn/__defaults__/__class__/__name__=='tuple' / socket.getfqdn/__defaults__/__len__()==1 — getfqdn(name='') has one positional default; __defaults__ is a tuple of length 1; no prior socket spec checks getfqdn/__defaults__/__class__/__name__ or getfqdn/__defaults__/__len__(); first defaults structure anchor for socket.getfqdn"
  kind: python_call_eq
  category: defaults
  id_prefix: socketkw67

  columns: [id, function, args, expected]
  rows:
    - [getfqdn_defaults_class_tuple, getfqdn.__defaults__.__class__.__name__.__eq__, ["tuple"], true]
    - [getfqdn_defaults_len_1,       getfqdn.__defaults__.__len__,                   [],        1]

# ---------------------------------------------------------------------------
# socket.socket.accept.__kwdefaults__.__class__.__name__.__eq__('NoneType') — standalone
#
# socket.socket.accept(self) has no keyword-only parameters. __kwdefaults__ is
# None (NoneType). No prior socket spec checks accept.__kwdefaults__ in any form.
# First __kwdefaults__ NoneType anchor for socket.socket.accept.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra67.socket_accept_kwdefaults_NoneType:
  description: "socket.socket.accept.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — accept(self) has no keyword-only parameters; __kwdefaults__ is None (NoneType); no prior socket spec checks accept.__kwdefaults__ in any form; first __kwdefaults__ NoneType anchor for socket.socket.accept"
  category: kwdefaults
  kind: python_call_eq
  function: socket.accept.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostname.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# socket.gethostname is a C builtin function from the _socket C extension. Its
# __class__.__name__ is 'builtin_function_or_method'. No prior socket spec
# checks gethostname.__class__.__name__. First C builtin class identity
# standalone for socket.gethostname. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra67.gethostname_class_builtin:
  description: "socket.gethostname.__class__.__name__.__eq__('builtin_function_or_method') == True — gethostname is a C builtin function from _socket; __class__.__name__ is 'builtin_function_or_method'; no prior socket spec checks gethostname.__class__.__name__; first C builtin class identity standalone for socket.gethostname"
  category: class_identity
  kind: python_call_eq
  function: gethostname.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# socket.gethostname.__module__.__eq__('socket') — standalone
#
# socket.gethostname is exposed in the socket module namespace. __module__ is
# 'socket'. No prior socket spec checks gethostname.__module__.__eq__('socket')
# in call form. First __module__ call-form anchor for socket.gethostname.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra67.gethostname_module_socket:
  description: "socket.gethostname.__module__.__eq__('socket') == True — gethostname is exposed in the socket namespace; __module__ is 'socket'; no prior socket spec checks gethostname.__module__.__eq__('socket') in call form; first __module__ call-form anchor for socket.gethostname"
  category: module_identity
  kind: python_call_eq
  function: gethostname.__module__.__eq__
  args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getfqdn.__class__.__name__.__eq__('function') — standalone
#
# socket.getfqdn is a pure-Python function in Lib/socket.py (unlike gethostname
# and gethostbyname which are C builtins). Its __class__.__name__ is 'function'.
# No prior socket spec checks getfqdn.__class__.__name__. First Python function
# class identity standalone for socket.getfqdn.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra67.getfqdn_class_function:
  description: "socket.getfqdn.__class__.__name__.__eq__('function') == True — getfqdn is a pure-Python function in Lib/socket.py; __class__.__name__ is 'function' (not 'builtin_function_or_method'); no prior socket spec checks getfqdn.__class__.__name__; first Python function class identity standalone for socket.getfqdn"
  category: class_identity
  kind: python_call_eq
  function: getfqdn.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# socket.getfqdn.__defaults__.__class__.__name__.__eq__('tuple') — standalone
#
# socket.getfqdn is defined as def getfqdn(name=''): with one positional
# default. __defaults__ is a tuple of length 1. No prior socket spec checks
# getfqdn.__defaults__.__class__.__name__. First defaults class identity
# standalone for socket.getfqdn. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra67.getfqdn_defaults_tuple:
  description: "socket.getfqdn.__defaults__.__class__.__name__.__eq__('tuple') == True — getfqdn(name='') has one positional default; __defaults__ is a tuple; no prior socket spec checks getfqdn.__defaults__.__class__.__name__; first defaults class identity standalone for socket.getfqdn"
  category: defaults
  kind: python_call_eq
  function: getfqdn.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true
