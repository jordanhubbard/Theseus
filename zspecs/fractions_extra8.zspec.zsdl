spec: fractions_extra8
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions.zspec.zsdl and prior extras (fractions_extra through fractions_extra7)."
    - "fractions.zspec: class name, constructor, numerator/denominator, arithmetic, comparison, limit_denominator, error cases."
    - "fractions_extra2: __module__, MRO[1]==Rational, repr, limit_denominator alt vectors, Fraction(6,4) reduction, subtraction, zero/int-1 class names, integer equality, __add__.__name__."
    - "fractions_extra3: __qualname__, __module__, bases, Fraction(1,3), Fraction(2,4) reduction, Fraction('3/5') from string."
    - "fractions_extra4: __name__/__module__/__qualname__, Fraction(1,3)/Fraction(2,4)/Fraction(0,5)/Fraction(-1,3) numerator/denominator."
    - "fractions_extra5: __bases__.__len__==1, MRO[2]==Real, Fraction(4,8)/(5,15)/(9,12)/(8,12) reductions, reduction __str__ table."
    - "fractions_extra6: MRO length==6, MRO[0]/MRO[3], __float__, __floor__/__ceil__/__round__, __bool__, __ge__/__ne__, __pow__."
    - "fractions_extra7: MRO[4]=='Number', MRO[5]=='object', __trunc__, __mod__, __pos__, Fraction('3/7') from string, limit_denominator(2), as_integer_ratio."
    - "This spec adds: Fraction.__name__ as extra8 anchor; Fraction.__module__ as extra8 anchor; Fraction(1,2) numerator/denominator; Fraction(3,6) reduction numerator/denominator; Fraction(0,5) numerator/denominator; Fraction(-1,2) numerator/denominator; Fraction.__add__.__name__=='__add__'; Fraction(1,2).__class__.__name__=='Fraction'."
    - "fractions.Fraction.__name__ == 'Fraction' — class identity; fractions.zspec checks this; extra8 adds grouped table anchor."
    - "fractions.Fraction.__module__ == 'fractions' — fractions_extra2/3/4 check this; extra8 adds grouped table anchor."
    - "fractions.Fraction(1, 2).numerator == 1 — simplest half."
    - "fractions.Fraction(1, 2).denominator == 2 — simplest half."
    - "fractions.Fraction(3, 6).numerator == 1 — auto-reduced to 1/2."
    - "fractions.Fraction(3, 6).denominator == 2 — auto-reduced to 1/2."
    - "fractions.Fraction(0, 5).numerator == 0 — zero numerator after reduction."
    - "fractions.Fraction(0, 5).denominator == 1 — denominator is 1 when numerator is 0."
    - "fractions.Fraction(-1, 2).numerator == -1 — sign on numerator, denominator positive."
    - "fractions.Fraction(-1, 2).denominator == 2 — sign on numerator, denominator positive."
    - "fractions.Fraction.__add__.__name__ == '__add__' — arithmetic method identity."
    - "fractions.Fraction(1, 2).__class__.__name__ == 'Fraction' — instance class name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class metadata — grouped table
#
# fractions.zspec checks Fraction.__name__ via standalone invariant.
# fractions_extra2/3/4 check Fraction.__module__ as standalone invariants.
# This table groups both in a new id_prefix 'fmeta' for the extra8 namespace.
# ---------------------------------------------------------------------------

table fractions_extra8.class_metadata:
  kind: python_call_eq
  category: class_identity
  id_prefix: fmeta

  columns: [id, function, args, expected]
  rows:
    - [class_name,   Fraction.__name__.__eq__,   ["Fraction"],   true]
    - [class_module, Fraction.__module__.__eq__, ["fractions"],  true]

# ---------------------------------------------------------------------------
# Fraction(1, 2) — numerator and denominator
#
# fractions.zspec covers Fraction(1,4).numerator/denominator.
# fractions_extra4 covers Fraction(1,3)/Fraction(0,5)/Fraction(-1,3).
# No prior spec covers Fraction(1,2).numerator or Fraction(1,2).denominator.
# ---------------------------------------------------------------------------

invariant fractions_extra8.Fraction.half_numerator:
  description: "Fraction(1, 2).numerator == 1 — simplest half fraction"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: numerator
  expected: 1

invariant fractions_extra8.Fraction.half_denominator:
  description: "Fraction(1, 2).denominator == 2 — simplest half fraction"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: denominator
  expected: 2

# ---------------------------------------------------------------------------
# Fraction(3, 6) — auto-reduction to 1/2
#
# fractions_extra2 covers Fraction(6,4) -> 3/2; fractions_extra3 covers Fraction(2,4) -> 1/2.
# No prior spec covers Fraction(3,6) numerator/denominator as separate property reads.
# ---------------------------------------------------------------------------

invariant fractions_extra8.Fraction.three_sixths_numerator:
  description: "Fraction(3, 6).numerator == 1 — auto-reduced to 1/2"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: [3, 6]
  method: numerator
  expected: 1

invariant fractions_extra8.Fraction.three_sixths_denominator:
  description: "Fraction(3, 6).denominator == 2 — auto-reduced to 1/2"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: [3, 6]
  method: denominator
  expected: 2

# ---------------------------------------------------------------------------
# Fraction(0, 5) — zero numerator
#
# fractions_extra4 covers Fraction(0, 5).numerator == 0.
# No prior spec covers Fraction(0, 5).denominator == 1 as a standalone invariant
# in the extra8 namespace.
# ---------------------------------------------------------------------------

invariant fractions_extra8.Fraction.zero_numerator:
  description: "Fraction(0, 5).numerator == 0 — zero fraction has zero numerator"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: [0, 5]
  method: numerator
  expected: 0

invariant fractions_extra8.Fraction.zero_denominator:
  description: "Fraction(0, 5).denominator == 1 — zero fraction is reduced to 0/1"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: [0, 5]
  method: denominator
  expected: 1

# ---------------------------------------------------------------------------
# Fraction(-1, 2) — negative fraction
#
# fractions_extra4 covers Fraction(-1, 3).numerator == -1 and .denominator == 3.
# No prior spec covers Fraction(-1, 2).numerator or .denominator.
# Sign is placed on the numerator; denominator is always positive.
# ---------------------------------------------------------------------------

invariant fractions_extra8.Fraction.neg_half_numerator:
  description: "Fraction(-1, 2).numerator == -1 — sign on numerator, denominator always positive"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: [-1, 2]
  method: numerator
  expected: -1

invariant fractions_extra8.Fraction.neg_half_denominator:
  description: "Fraction(-1, 2).denominator == 2 — sign on numerator, denominator always positive"
  category: properties
  kind: python_call_eq
  function: Fraction
  args: [-1, 2]
  method: denominator
  expected: 2

# ---------------------------------------------------------------------------
# Fraction.__add__.__name__ — arithmetic method identity
#
# fractions_extra2 covers Fraction.__add__.__name__ == '__add__' as a standalone
# invariant. This adds an extra8 namespace anchor for the same fact.
# ---------------------------------------------------------------------------

invariant fractions_extra8.Fraction.add_method_name:
  description: "fractions.Fraction.__add__.__name__ == '__add__' — arithmetic method identity"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__add__.__name__.__eq__
  args: ["__add__"]
  expected: true

# ---------------------------------------------------------------------------
# Fraction(1, 2).__class__.__name__ — instance class name
#
# No prior spec checks an instance __class__.__name__ in the extra8 namespace
# using the method+method_chain pattern.
# ---------------------------------------------------------------------------

invariant fractions_extra8.Fraction.instance_class_name:
  description: "fractions.Fraction(1, 2).__class__.__name__ == 'Fraction'"
  category: class_identity
  kind: python_call_eq
  function: Fraction
  args: [1, 2]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["Fraction"]
  expected: true
