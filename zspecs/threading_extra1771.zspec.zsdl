spec: threading_extra1771
version: ">=3.9"
backend: python_module(threading)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/threading.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 565 (_extra1771): async protocol dict-presence checks."
    - "Theme: which threading stdlib types define __aenter__, __aexit__, __aiter__, __anext__, __await__ in their own __dict__."
    - "threading.Thread: class representing an OS-level thread — synchronous execution model; no async protocol -> all False."
    - "threading.Lock: C-level synchronous mutex lock — note: threading.Lock does NOT define __aenter__/__aexit__ in its own class __dict__. Lock() instances support 'with' via the C-level tp_as_mapping slot, not a Python-level __aenter__/__aexit__. Contrast with asyncio.Lock which DOES define __aenter__/__aexit__ as coroutines."
    - "threading.Event: synchronous coordination primitive — threads wait on a flag; no async protocol -> all False."
    - "threading.Condition: synchronous coordination primitive combining a lock and wait/notify — no async protocol -> all False."
    - "Rationale: threading types implement OS-level synchronous thread synchronization, not the async coroutine protocol. Async equivalents live in asyncio (asyncio.Lock, asyncio.Event, asyncio.Condition)."
    - "Complementary checks confirm class identities of threading module-level utility functions."
    - "threading.current_thread.__class__.__name__ -> 'function' — Python-level function."
    - "threading.active_count.__class__.__name__ -> 'function' — Python-level function."
    - "threading.main_thread.__class__.__name__ -> 'function' — Python-level function."
    - "threading.TIMEOUT_MAX.__class__.__name__ -> 'float' — platform maximum timeout value."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: async protocol dict-presence checks for threading types
#
# Wave 565 theme: which threading types define __aenter__, __aexit__,
# __aiter__, __anext__, __await__ in their own __dict__.
#
# threading.Thread: synchronous OS-thread wrapper. The thread body runs in
#   the OS thread scheduler; no coroutine or async context manager support.
# threading.Lock: C-level synchronous mutex. threading.Lock does NOT expose
#   __aenter__/__aexit__ as Python-level methods in its class __dict__ —
#   context-manager support is via a lower-level C slot. Contrast with
#   asyncio.Lock which defines __aenter__/__aexit__ as coroutines.
# threading.Event: binary flag synchronization primitive. Threads block via
#   Event.wait() (releases GIL but is synchronous); no async protocol.
# threading.Condition: a lock + condition variable. Threads wait via
#   Condition.wait(); no coroutine support; no async protocol.
# ---------------------------------------------------------------------------

table threading_extra1771.async_protocol:
  description: "threading types async protocol dict-presence checks — all False — wave 565 _extra1771"
  kind: python_call_eq
  category: dict_contains
  id_prefix: th1771

  columns: [id, function, args, expected]
  rows:
    - ["th1771001", "threading.Thread.__dict__.__contains__",    ["__aenter__"], false]
    - ["th1771002", "threading.Thread.__dict__.__contains__",    ["__aexit__"],  false]
    - ["th1771003", "threading.Thread.__dict__.__contains__",    ["__aiter__"],  false]
    - ["th1771004", "threading.Thread.__dict__.__contains__",    ["__anext__"],  false]
    - ["th1771005", "threading.Thread.__dict__.__contains__",    ["__await__"],  false]
    - ["th1771006", "threading.Lock.__dict__.__contains__",      ["__aenter__"], false]
    - ["th1771007", "threading.Lock.__dict__.__contains__",      ["__aexit__"],  false]
    - ["th1771008", "threading.Lock.__dict__.__contains__",      ["__aiter__"],  false]
    - ["th1771009", "threading.Lock.__dict__.__contains__",      ["__anext__"],  false]
    - ["th1771010", "threading.Lock.__dict__.__contains__",      ["__await__"],  false]
    - ["th1771011", "threading.Event.__dict__.__contains__",     ["__aenter__"], false]
    - ["th1771012", "threading.Event.__dict__.__contains__",     ["__aexit__"],  false]
    - ["th1771013", "threading.Event.__dict__.__contains__",     ["__aiter__"],  false]
    - ["th1771014", "threading.Event.__dict__.__contains__",     ["__anext__"],  false]
    - ["th1771015", "threading.Event.__dict__.__contains__",     ["__await__"],  false]
    - ["th1771016", "threading.Condition.__dict__.__contains__", ["__aenter__"], false]
    - ["th1771017", "threading.Condition.__dict__.__contains__", ["__aexit__"],  false]
    - ["th1771018", "threading.Condition.__dict__.__contains__", ["__aiter__"],  false]
    - ["th1771019", "threading.Condition.__dict__.__contains__", ["__anext__"],  false]
    - ["th1771020", "threading.Condition.__dict__.__contains__", ["__await__"],  false]

# ---------------------------------------------------------------------------
# Table 2: complementary checks for threading module-level utilities
#
# The async theme is all-False for all threading types (threading is a
# synchronous OS-thread library). Complementary checks confirm genuine
# threading-specific structural properties:
# - threading.current_thread.__class__.__name__ -> 'function': Python-level.
# - threading.active_count.__class__.__name__ -> 'function': Python-level.
# - threading.main_thread.__class__.__name__ -> 'function': Python-level.
# - threading.TIMEOUT_MAX.__class__.__name__ -> 'float': platform timeout limit.
# - threading.Thread.__dict__.__contains__('start') -> True: Thread.start()
#   is defined in Thread's own __dict__.
# - threading.Thread.__dict__.__contains__('run') -> True: Thread.run()
#   is defined in Thread's own __dict__.
# - threading.Condition.__dict__.__contains__('wait') -> True.
# - threading.Event.__dict__.__contains__('wait') -> True.
# ---------------------------------------------------------------------------

table threading_extra1771.complementary_checks:
  description: "threading module-level utility function type names and key dict-presence complementary checks — wave 565 _extra1771"
  kind: python_call_eq
  category: complementary
  id_prefix: th1771

  columns: [id, function, args, expected]
  rows:
    - ["th1771021", "threading.current_thread.__class__.__name__.__eq__", ["function"], true]
    - ["th1771022", "threading.active_count.__class__.__name__.__eq__",   ["function"], true]
    - ["th1771023", "threading.main_thread.__class__.__name__.__eq__",    ["function"], true]
    - ["th1771024", "threading.TIMEOUT_MAX.__class__.__name__.__eq__",    ["float"],    true]
    - ["th1771025", "threading.Thread.__dict__.__contains__",             ["start"],    true]
    - ["th1771026", "threading.Thread.__dict__.__contains__",             ["run"],      true]
    - ["th1771027", "threading.Condition.__dict__.__contains__",          ["wait"],     true]
    - ["th1771028", "threading.Event.__dict__.__contains__",              ["wait"],     true]
