spec: decimal_extra79
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal.zspec.zsdl and all prior decimal_extra specs through decimal_extra78."
    - "Prior specs covered: Decimal arithmetic; exception class __qualname__; getcontext/setcontext identity; Decimal/__dict__ membership; MAX_PREC/MAX_EMAX; exception hierarchy __bases__ and MRO; Decimal C slot wrapper identity; Context identity; Context/__dict__ membership; exception class __name__ identity; Decimal.__dict__.__contains__ for various dunders; Decimal comparison/equality/hash wrapper_descriptor identity; Context/__dict__ class and membership; getcontext/setcontext __class__.__name__ and __module__; Decimal division/power operator wrapper_descriptor identity and __dict__ membership; Context.__init__/__class__.__name__; Context arithmetic method __class__.__name__; Context/__dict__/__class__/__name__ and membership; Context.__bases__[0].__name__; Context.__mro__.__len__(); Decimal arithmetic/string/conversion dunder __qualname__ values and lengths; Decimal comparison operator __qualname__ lengths; Decimal to_*/normalize/quantize/sqrt/compare __qualname__ lengths; Decimal.__dict__.__contains__ for arithmetic/comparison/math operators; Decimal.__dict__.__class__.__name__; Decimal.__name__; Decimal.__module__."
    - "This spec covers: Decimal.__qualname__; Decimal.__qualname__.__len__(); Decimal.__module__.__len__(); Decimal.__bases__[0].__name__; Decimal.__mro__.__len__(); Context.__name__; Context.__module__; Context.__qualname__; Context.__qualname__.__len__(); getcontext.__class__.__name__; setcontext.__class__.__name__; localcontext.__class__.__name__."
    - "Decimal.__qualname__ == 'Decimal' — length 7 (same as __name__ and __module__)."
    - "Decimal.__module__.__len__() == 7 — 'decimal' has 7 characters."
    - "Decimal.__bases__[0].__name__ == 'object' — Decimal is a direct subclass of object."
    - "Decimal.__mro__.__len__() == 2 — [Decimal, object] only, as a C extension type."
    - "Context.__name__ == 'Context' — the C type name."
    - "Context.__module__ == 'decimal' — re-exported under 'decimal', not '_decimal'."
    - "Context.__qualname__ == 'Context' — length 7."
    - "getcontext.__class__.__name__ == 'builtin_function_or_method' — C-level built-in."
    - "setcontext.__class__.__name__ == 'builtin_function_or_method' — C-level built-in."
    - "localcontext.__class__.__name__ == 'builtin_function_or_method' — C-level built-in."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal C-type __qualname__ and string lengths
# Decimal.__qualname__ == 'Decimal' (len 7); __module__ == 'decimal' (len 7).
# Decimal.__bases__[0].__name__ == 'object'; __mro__.__len__() == 2.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra79.Decimal_qualname_and_mro:
  description: "Decimal.__qualname__, __qualname__.__len__(), __module__.__len__(), __bases__[0].__name__, __mro__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalextra79

  columns: [id, function, args, expected]
  rows:
    - [dec_qualname,     Decimal.__qualname__.__eq__,          ["Decimal"], true]
    - [dec_qn_len,       Decimal.__qualname__.__len__,         [],          7]
    - [dec_module_len,   Decimal.__module__.__len__,           [],          7]
    - [dec_base0,        "Decimal.__bases__[0].__name__.__eq__", ["object"], true]
    - [dec_mro_len,      Decimal.__mro__.__len__,              [],          2]

# ---------------------------------------------------------------------------
# decimal.Context class identity: __name__, __module__, __qualname__
# Context is a C extension type re-exported under 'decimal'.
# __qualname__ == 'Context' (len 7).
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra79.Context_identity:
  description: "decimal.Context __name__, __module__, __qualname__, __qualname__.__len__()"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalextra79

  columns: [id, function, args, expected]
  rows:
    - [ctx_name,     Context.__name__.__eq__,          ["Context"], true]
    - [ctx_module,   Context.__module__.__eq__,        ["decimal"], true]
    - [ctx_qualname, Context.__qualname__.__eq__,      ["Context"], true]
    - [ctx_qn_len,   Context.__qualname__.__len__,     [],          7]

# ---------------------------------------------------------------------------
# decimal.getcontext and decimal.setcontext __class__.__name__
# Both are C-level built-in functions; __class__.__name__ == 'builtin_function_or_method'.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra79.getcontext_setcontext_class:
  description: "decimal.getcontext and decimal.setcontext __class__.__name__"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalextra79

  columns: [id, function, args, expected]
  rows:
    - [getctx_cls, getcontext.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [setctx_cls, setcontext.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# decimal.localcontext __class__.__name__; Decimal.__qualname__ equality anchor
# localcontext is a C built-in; also re-anchor Decimal.__qualname__ string equality.
# Not covered in any prior decimal spec at this specific table.
# ---------------------------------------------------------------------------

table decimal_extra79.localcontext_and_decimal_qualname:
  description: "decimal.localcontext __class__.__name__; Decimal.__qualname__ equality anchor"
  kind: python_call_eq
  category: class_identity
  id_prefix: decimalextra79

  columns: [id, function, args, expected]
  rows:
    - [localctx_cls,  localcontext.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [dec_qn_eq,     Decimal.__qualname__.__eq__,             ["Decimal"],                   true]
    - [ctx_qn_eq,     Context.__qualname__.__eq__,             ["Context"],                   true]
    - [dec_module_eq, Decimal.__module__.__eq__,               ["decimal"],                   true]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra79.Decimal.qualname:
  description: "decimal.Decimal.__qualname__ == 'Decimal' (C type; length 7)"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__qualname__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra79.Decimal.mro_len:
  description: "decimal.Decimal.__mro__.__len__() == 2 ([Decimal, object] — direct C subclass of object)"
  category: class_identity
  kind: python_call_eq
  function: Decimal.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra79.Context.name:
  description: "decimal.Context.__name__ == 'Context'"
  category: class_identity
  kind: python_call_eq
  function: Context.__name__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra79.getcontext.class_name:
  description: "decimal.getcontext.__class__.__name__ == 'builtin_function_or_method'"
  category: class_identity
  kind: python_call_eq
  function: getcontext.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant decimal_extra79.localcontext.class_name:
  description: "decimal.localcontext.__class__.__name__ == 'builtin_function_or_method' (C-level built-in)"
  category: class_identity
  kind: python_call_eq
  function: localcontext.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
