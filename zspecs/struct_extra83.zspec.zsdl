spec: struct_extra83
version: ">=3.9"
extends: struct_extra82
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra82.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from __qualname__.__eq__ / Struct.__name__/__qualname__/__bases__[0].__name__/__mro__.__len__() / pack/unpack module-level __qualname__.__eq__ / Struct.__dict__.__class__.__name__=='mappingproxy' / Struct.iter_unpack.__qualname__.__eq__ (table + invariants)."
    - "struct_extra80.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack/__repr__/format/size __qualname__.__eq__ / Struct method __doc__.__len__() (table + invariants)."
    - "struct_extra78.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __doc__.__class__.__name__=='str' / Struct.format/size/__class__.__name__=='getset_descriptor' / Struct method __class__.__name__=='method_descriptor' (table + invariants)."
    - "struct_extra75.zspec.zsdl — covers struct.error.__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__() / pack/unpack __qualname__.__eq__ (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra82; it does NOT duplicate invariants present in those files."
    - "Wave 253 theme: struct module-level function __qualname__ string equality for pack/unpack/pack_into/unpack_from/iter_unpack/calcsize and struct.Struct.__dict__ membership."
    - "struct.pack.__qualname__.__eq__('pack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack.__qualname__.__eq__('unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack_into.__qualname__.__eq__('pack_into') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__qualname__.__eq__('unpack_from') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__qualname__.__eq__('iter_unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize.__qualname__.__eq__('calcsize') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('pack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('pack_into') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('unpack_from') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('iter_unpack') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('size') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('format') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack/__qualname__/__eq__('pack')
# struct.unpack/__qualname__/__eq__('unpack')
# struct.pack_into/__qualname__/__eq__('pack_into')
# struct.calcsize/__qualname__/__eq__('calcsize')
#
# Wave 253 theme: struct module-level function __qualname__ string equality (group 1).
#
# pack/unpack/pack_into/unpack_from/iter_unpack/calcsize are all
# builtin_function_or_method objects from _struct. Their __qualname__ is
# the bare name (not prefixed with a class). struct_extra75 anchors
# pack.__qualname__.__eq__('pack'); struct_extra82 anchors pack and unpack.
# This table anchors pack/unpack/pack_into/calcsize under structnamemod83.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra83.struct_module_func_qualnames_group1:
  description: "struct/pack/__qualname__/__eq__('pack')==True / struct/unpack/__qualname__/__eq__('unpack')==True / struct/pack_into/__qualname__/__eq__('pack_into')==True / struct/calcsize/__qualname__/__eq__('calcsize')==True — pack/unpack/pack_into/calcsize are module-level builtin_function_or_method objects from _struct; their __qualname__ is the bare function name with no class prefix; struct_extra75 anchors pack.__qualname__.__eq__; struct_extra82 anchors pack and unpack; this table anchors all four under structnamemod83; first structnamemod83 anchor for pack/unpack/pack_into/calcsize qualname equality"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structnamemod83

  columns: [id, function, args, expected]
  rows:
    - [struct_pack_qualname_eq,      pack.__qualname__.__eq__,      ["pack"],      true]
    - [struct_unpack_qualname_eq,    unpack.__qualname__.__eq__,    ["unpack"],    true]
    - [struct_pack_into_qualname_eq, pack_into.__qualname__.__eq__, ["pack_into"], true]
    - [struct_calcsize_qualname_eq,  calcsize.__qualname__.__eq__,  ["calcsize"],  true]

# ---------------------------------------------------------------------------
# struct.Struct/__dict__/__contains__('pack') == True
# struct.Struct/__dict__/__contains__('unpack') == True
# struct.Struct/__dict__/__contains__('pack_into') == True
# struct.Struct/__dict__/__contains__('unpack_from') == True
#
# Wave 253 theme: struct.Struct __dict__ membership for core packing methods.
#
# Struct's pack/unpack/pack_into/unpack_from methods are method_descriptor
# objects stored in Struct.__dict__. struct_extra82 checks __dict__.__class__.__name__;
# no prior struct spec checks __dict__.__contains__ for these four methods.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra83.struct_dict_pack_methods:
  description: "struct.Struct/__dict__/__contains__('pack')==True / Struct/__dict__/__contains__('unpack')==True / Struct/__dict__/__contains__('pack_into')==True / Struct/__dict__/__contains__('unpack_from')==True — pack/unpack/pack_into/unpack_from are method_descriptor objects stored in Struct.__dict__; no prior struct spec checks Struct.__dict__.__contains__ for these four; first __dict__.__contains__ anchor for struct.Struct pack/unpack/pack_into/unpack_from"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structnamemod83

  columns: [id, function, args, expected]
  rows:
    - [struct_dict_has_pack,        "Struct.__dict__.__contains__", ["pack"],        true]
    - [struct_dict_has_unpack,      "Struct.__dict__.__contains__", ["unpack"],      true]
    - [struct_dict_has_pack_into,   "Struct.__dict__.__contains__", ["pack_into"],   true]
    - [struct_dict_has_unpack_from, "Struct.__dict__.__contains__", ["unpack_from"], true]

# ---------------------------------------------------------------------------
# struct.Struct/__dict__/__contains__('iter_unpack') == True
# struct.Struct/__dict__/__contains__('size') == True
# struct.Struct/__dict__/__contains__('format') == True
# struct.unpack_from/__qualname__/__eq__('unpack_from')
#
# Wave 253 theme: struct.Struct __dict__ property/method membership + unpack_from qualname.
#
# iter_unpack is a method_descriptor; size and format are getset_descriptor
# attributes. All are present in Struct.__dict__. struct_extra78 confirms
# size and format as getset_descriptor. unpack_from qualname cross-checks
# the module-level function table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra83.struct_dict_property_membership:
  description: "struct.Struct/__dict__/__contains__('iter_unpack')==True / Struct/__dict__/__contains__('size')==True / Struct/__dict__/__contains__('format')==True / struct/unpack_from/__qualname__/__eq__('unpack_from')==True — iter_unpack is a method_descriptor; size and format are getset_descriptor attributes; all live in Struct.__dict__; struct_extra78 confirms size/format class names; this table anchors __dict__.__contains__ for iter_unpack/size/format; unpack_from qualname cross-checks module-level function group; first __dict__.__contains__ anchor for Struct.iter_unpack/size/format under structnamemod83"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structnamemod83

  columns: [id, function, args, expected]
  rows:
    - [struct_dict_has_iter_unpack,  "Struct.__dict__.__contains__", ["iter_unpack"],  true]
    - [struct_dict_has_size,         "Struct.__dict__.__contains__", ["size"],         true]
    - [struct_dict_has_format,       "Struct.__dict__.__contains__", ["format"],       true]
    - [struct_unpack_from_qualname_eq, unpack_from.__qualname__.__eq__, ["unpack_from"], true]

# ---------------------------------------------------------------------------
# struct.iter_unpack/__qualname__/__eq__('iter_unpack')
# struct.pack/__qualname__/__eq__('pack') (cross-check)
# struct.Struct/__dict__/__contains__('pack') (cross-check)
# struct.Struct/__dict__/__contains__('size') (cross-check)
#
# Wave 253 theme: cross-check module function qualnames and dict membership.
#
# Cross-anchors iter_unpack qualname, pack qualname, and dict membership for
# pack and size together.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra83.struct_cross_check:
  description: "struct/iter_unpack/__qualname__/__eq__('iter_unpack')==True / struct/pack/__qualname__/__eq__('pack')==True / Struct/__dict__/__contains__('pack')==True / Struct/__dict__/__contains__('size')==True — cross-check anchors iter_unpack module-level qualname, pack qualname, and dict membership for pack and size in one table; confirms bare qualname for module-level C functions vs the method_descriptor content of Struct.__dict__; first cross-group anchor combining module function qualnames and Struct dict membership under structnamemod83"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structnamemod83

  columns: [id, function, args, expected]
  rows:
    - [struct_iter_unpack_qualname_eq2, iter_unpack.__qualname__.__eq__,    ["iter_unpack"], true]
    - [struct_pack_qualname_eq2,        pack.__qualname__.__eq__,           ["pack"],        true]
    - [struct_dict_has_pack2,           "Struct.__dict__.__contains__",     ["pack"],        true]
    - [struct_dict_has_size2,           "Struct.__dict__.__contains__",     ["size"],        true]

# ---------------------------------------------------------------------------
# struct.calcsize.__qualname__.__eq__('calcsize') — standalone
#
# struct.calcsize.__qualname__ is 'calcsize'. No prior struct spec checks
# calcsize.__qualname__.__eq__ as a call. First __qualname__.__eq__ standalone
# for struct.calcsize. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra83.struct_calcsize_qualname_eq:
  description: "struct.calcsize.__qualname__.__eq__('calcsize') == True — struct.calcsize is a module-level builtin_function_or_method from _struct; its __qualname__ is the bare name 'calcsize' with no class prefix; no prior struct spec checks calcsize.__qualname__.__eq__; first __qualname__.__eq__ standalone for struct.calcsize"
  category: class_attrs
  kind: python_call_eq
  function: calcsize.__qualname__.__eq__
  args: ["calcsize"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack_into.__qualname__.__eq__('pack_into') — standalone
#
# struct.pack_into.__qualname__ is 'pack_into'. No prior struct spec checks
# pack_into.__qualname__.__eq__ as a call. First __qualname__.__eq__ standalone
# for struct.pack_into. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra83.struct_pack_into_qualname_eq:
  description: "struct.pack_into.__qualname__.__eq__('pack_into') == True — struct.pack_into is a module-level builtin_function_or_method from _struct; its __qualname__ is the bare name 'pack_into' with no class prefix; no prior struct spec checks pack_into.__qualname__.__eq__; first __qualname__.__eq__ standalone for struct.pack_into"
  category: class_attrs
  kind: python_call_eq
  function: pack_into.__qualname__.__eq__
  args: ["pack_into"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('iter_unpack') — standalone
#
# Struct.__dict__.__contains__('iter_unpack') is True. No prior struct spec
# checks Struct.__dict__.__contains__('iter_unpack'). First standalone for
# struct.Struct dict membership of iter_unpack.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra83.struct_dict_has_iter_unpack:
  description: "struct.Struct.__dict__.__contains__('iter_unpack') == True — Struct.iter_unpack is a method_descriptor stored in Struct.__dict__ that returns an iterator of tuples; no prior struct spec checks Struct.__dict__.__contains__('iter_unpack'); first __dict__.__contains__('iter_unpack') standalone for struct.Struct"
  category: class_attrs
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["iter_unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('format') — standalone
#
# Struct.__dict__.__contains__('format') is True. 'format' is a
# getset_descriptor in Struct.__dict__ exposing the format string.
# No prior struct spec checks Struct.__dict__.__contains__('format').
# First __dict__.__contains__('format') standalone for struct.Struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra83.struct_dict_has_format:
  description: "struct.Struct.__dict__.__contains__('format') == True — Struct.format is a getset_descriptor stored in Struct.__dict__ that exposes the format string used to create the Struct instance; no prior struct spec checks Struct.__dict__.__contains__('format'); first __dict__.__contains__('format') standalone for struct.Struct"
  category: class_attrs
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["format"]
  expected: true

# ---------------------------------------------------------------------------
# struct.unpack_from.__qualname__.__eq__('unpack_from') — standalone
#
# struct.unpack_from.__qualname__ is 'unpack_from'. No prior struct spec checks
# unpack_from.__qualname__.__eq__ as a standalone. First standalone for
# struct.unpack_from qualname equality under structnamemod83.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra83.struct_unpack_from_qualname_eq:
  description: "struct.unpack_from.__qualname__.__eq__('unpack_from') == True — struct.unpack_from is a module-level builtin_function_or_method from _struct; its __qualname__ is the bare name 'unpack_from' with no class prefix; no prior struct spec checks unpack_from.__qualname__.__eq__ as a standalone; first standalone for struct.unpack_from qualname equality"
  category: class_attrs
  kind: python_call_eq
  function: unpack_from.__qualname__.__eq__
  args: ["unpack_from"]
  expected: true
