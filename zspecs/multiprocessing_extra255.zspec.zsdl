spec: multiprocessing_extra255
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/__init__.py"
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "multiprocessing.Process is a real class; __module__ == 'multiprocessing.context' (context-specific subclass)."
    - "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess' (defined in multiprocessing.process)."
    - "Pool, Queue, Lock, Value, Array, Pipe are bound methods of the default context (BaseContext subclass)."
    - "They are type 'method', not classes; their __module__ == 'multiprocessing.context'."
    - "Pool.__qualname__ == 'BaseContext.Pool'; Queue.__qualname__ == 'BaseContext.Queue'."
    - "Lock.__qualname__ == 'BaseContext.Lock'; Value.__qualname__ == 'BaseContext.Value'."
    - "Array.__qualname__ == 'BaseContext.Array'; Pipe.__qualname__ == 'BaseContext.Pipe'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Process class identity — __name__, __module__, __qualname__
#
# multiprocessing.Process is a real class (a context-specific subclass of
# BaseProcess). It is the primary way to spawn child processes.
# ---------------------------------------------------------------------------

invariant multiprocessing_extra255.Process.name:
  description: "multiprocessing.Process.__name__ == 'Process'"
  category: identity
  kind: python_call_eq
  function: Process.__name__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra255.Process.module:
  description: "multiprocessing.Process.__module__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: Process.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra255.Process.qualname:
  description: "multiprocessing.Process.__qualname__ == 'Process'"
  category: identity
  kind: python_call_eq
  function: Process.__qualname__.__eq__
  args: ["Process"]
  expected: true

invariant multiprocessing_extra255.Process.base:
  description: "multiprocessing.Process.__bases__[0].__name__ == 'BaseProcess'"
  category: identity
  kind: python_call_eq
  function: Process.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseProcess"

# ---------------------------------------------------------------------------
# Context-bound factory __name__ table
#
# Pool, Queue, Lock, Value, Array, and Pipe are bound methods of the default
# multiprocessing context. They are callable factories, not classes.
# Each carries __name__ and __module__ == 'multiprocessing.context'.
# ---------------------------------------------------------------------------

table multiprocessing_extra255.factory_names:
  description: "multiprocessing context-bound factories report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: factname

  columns: [id, function, args, expected, description]
  rows:
    - [Pool,  Pool.__name__.__eq__,  ["Pool"],  true, "multiprocessing.Pool.__name__ == 'Pool'"]
    - [Queue, Queue.__name__.__eq__, ["Queue"], true, "multiprocessing.Queue.__name__ == 'Queue'"]
    - [Lock,  Lock.__name__.__eq__,  ["Lock"],  true, "multiprocessing.Lock.__name__ == 'Lock'"]
    - [Value, Value.__name__.__eq__, ["Value"], true, "multiprocessing.Value.__name__ == 'Value'"]
    - [Array, Array.__name__.__eq__, ["Array"], true, "multiprocessing.Array.__name__ == 'Array'"]

table multiprocessing_extra255.factory_qualnames:
  description: "multiprocessing context-bound factories report BaseContext-prefixed __qualname__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: factqualname

  columns: [id, function, args, expected, description]
  rows:
    - [Pool,  Pool.__qualname__.__eq__,  ["BaseContext.Pool"],  true, "multiprocessing.Pool.__qualname__ == 'BaseContext.Pool'"]
    - [Queue, Queue.__qualname__.__eq__, ["BaseContext.Queue"], true, "multiprocessing.Queue.__qualname__ == 'BaseContext.Queue'"]
    - [Lock,  Lock.__qualname__.__eq__,  ["BaseContext.Lock"],  true, "multiprocessing.Lock.__qualname__ == 'BaseContext.Lock'"]
    - [Value, Value.__qualname__.__eq__, ["BaseContext.Value"], true, "multiprocessing.Value.__qualname__ == 'BaseContext.Value'"]
    - [Array, Array.__qualname__.__eq__, ["BaseContext.Array"], true, "multiprocessing.Array.__qualname__ == 'BaseContext.Array'"]

# ---------------------------------------------------------------------------
# Pipe factory identity — standalone invariants
# ---------------------------------------------------------------------------

invariant multiprocessing_extra255.Pipe.name:
  description: "multiprocessing.Pipe.__name__ == 'Pipe'"
  category: identity
  kind: python_call_eq
  function: Pipe.__name__.__eq__
  args: ["Pipe"]
  expected: true

invariant multiprocessing_extra255.Pipe.module:
  description: "multiprocessing.Pipe.__module__ == 'multiprocessing.context'"
  category: identity
  kind: python_call_eq
  function: Pipe.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra255.Pipe.qualname:
  description: "multiprocessing.Pipe.__qualname__ == 'BaseContext.Pipe'"
  category: identity
  kind: python_call_eq
  function: Pipe.__qualname__.__eq__
  args: ["BaseContext.Pipe"]
  expected: true
