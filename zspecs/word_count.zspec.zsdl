spec: word_count
version: ">=1.0.0"
backend: node(word-count)

docs: https://www.npmjs.com/package/word-count

provenance:
  derived_from:
    - "word-count README — https://www.npmjs.com/package/word-count"
    - "Test vectors verified with word-count via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "word-count source"
  notes:
    - "word-count is an npm package. Install: npm install word-count"
    - "wordCount(str) returns the number of words in the string."
    - "Words are delimited by whitespace; empty/whitespace-only strings return 0."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns integer word count."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table word_count.count:
  kind: node_module_call_eq
  function: ~
  category: count
  id_prefix: wc

  columns: [id, args, expected]
  rows:
    - [two,    ["hello world"],          2]
    - [empty,  [""],                     0]
    - [five,   ["one two three four five"], 5]
    - [single, ["hello"],                1]
