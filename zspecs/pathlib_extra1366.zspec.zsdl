spec: pathlib_extra1366
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks for pathlib module classes."
    - "All pathlib path classes are pure-Python classes (not C extension types); they still carry the C-slot integer attributes __flags__, __basicsize__, and __itemsize__ inherited through the object/type metaclass machinery."
    - "Only the type (int) is checked — exact values are platform-specific and intentionally not tested."
    - "pathlib.PurePath.__flags__.__class__.__name__ == 'int'; pathlib.PurePath.__basicsize__.__class__.__name__ == 'int'; pathlib.PurePath.__itemsize__.__class__.__name__ == 'int'; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "PurePosixPath, PureWindowsPath, Path, and PosixPath are all subclasses of PurePath; all return 'int' for __flags__, __basicsize__, and __itemsize__ class name checks."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table pathlib_extra1366.purepath_flags_basicsize_itemsize:
  description: "pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath __flags__, __basicsize__, __itemsize__ type checks — wave 538 theme: the three pure-path classes carry integer-typed C-slot attributes; only the type name 'int' is checked, not platform-specific values; verified with Python 3.12"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: pl1366pp
  columns: [id, function, args, expected, description]
  rows:
    - [pl1366pp001, pathlib.PurePath.__flags__.__class__.__name__.__eq__,           ["int"], true, "pathlib.PurePath.__flags__.__class__.__name__ == 'int' (C-slot integer attribute); verified with Python 3.12"]
    - [pl1366pp002, pathlib.PurePath.__basicsize__.__class__.__name__.__eq__,       ["int"], true, "pathlib.PurePath.__basicsize__.__class__.__name__ == 'int' (C-slot integer attribute); verified with Python 3.12"]
    - [pl1366pp003, pathlib.PurePath.__itemsize__.__class__.__name__.__eq__,        ["int"], true, "pathlib.PurePath.__itemsize__.__class__.__name__ == 'int' (C-slot integer attribute); verified with Python 3.12"]
    - [pl1366pp004, pathlib.PurePosixPath.__flags__.__class__.__name__.__eq__,      ["int"], true, "pathlib.PurePosixPath.__flags__.__class__.__name__ == 'int' (C-slot integer attribute); verified with Python 3.12"]
    - [pl1366pp005, pathlib.PurePosixPath.__basicsize__.__class__.__name__.__eq__,  ["int"], true, "pathlib.PurePosixPath.__basicsize__.__class__.__name__ == 'int' (C-slot integer attribute); verified with Python 3.12"]
    - [pl1366pp006, pathlib.PurePosixPath.__itemsize__.__class__.__name__.__eq__,   ["int"], true, "pathlib.PurePosixPath.__itemsize__.__class__.__name__ == 'int' (C-slot integer attribute); verified with Python 3.12"]
    - [pl1366pp007, pathlib.PureWindowsPath.__flags__.__class__.__name__.__eq__,    ["int"], true, "pathlib.PureWindowsPath.__flags__.__class__.__name__ == 'int' (C-slot integer attribute); verified with Python 3.12"]
    - [pl1366pp008, pathlib.PureWindowsPath.__basicsize__.__class__.__name__.__eq__, ["int"], true, "pathlib.PureWindowsPath.__basicsize__.__class__.__name__ == 'int' (C-slot integer attribute); verified with Python 3.12"]
    - [pl1366pp009, pathlib.PureWindowsPath.__itemsize__.__class__.__name__.__eq__,  ["int"], true, "pathlib.PureWindowsPath.__itemsize__.__class__.__name__ == 'int' (C-slot integer attribute); verified with Python 3.12"]

