table pathlib_extra1366.flags_basicsize_itemsize_crosscheck:
  description: "pathlib __flags__, __basicsize__, __itemsize__ cross-class consistency checks — wave 538 theme: confirms that all five pathlib path classes (PurePath, PurePosixPath, PureWindowsPath, Path, PosixPath) uniformly return 'int' for all three C-slot attribute type-name checks; verified with Python 3.12"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: pl1366cc
  columns: [id, function, args, expected, description]
  rows:
    - [pl1366cc001, pathlib.PurePath.__flags__.__class__.__name__.__eq__,       ["int"], true, "PurePath.__flags__ is int (cross-check anchor); verified with Python 3.12"]
    - [pl1366cc002, pathlib.PurePosixPath.__flags__.__class__.__name__.__eq__,  ["int"], true, "PurePosixPath.__flags__ is int (consistent with PurePath); verified with Python 3.12"]
    - [pl1366cc003, pathlib.PureWindowsPath.__flags__.__class__.__name__.__eq__, ["int"], true, "PureWindowsPath.__flags__ is int (consistent with PurePath); verified with Python 3.12"]
    - [pl1366cc004, pathlib.Path.__flags__.__class__.__name__.__eq__,           ["int"], true, "Path.__flags__ is int (consistent with PurePath); verified with Python 3.12"]
    - [pl1366cc005, pathlib.PosixPath.__flags__.__class__.__name__.__eq__,      ["int"], true, "PosixPath.__flags__ is int (consistent with PurePath); verified with Python 3.12"]
    - [pl1366cc006, pathlib.PurePath.__basicsize__.__class__.__name__.__eq__,   ["int"], true, "PurePath.__basicsize__ is int (cross-check anchor); verified with Python 3.12"]
    - [pl1366cc007, pathlib.Path.__basicsize__.__class__.__name__.__eq__,       ["int"], true, "Path.__basicsize__ is int (consistent with PurePath); verified with Python 3.12"]
    - [pl1366cc008, pathlib.PurePath.__itemsize__.__class__.__name__.__eq__,    ["int"], true, "PurePath.__itemsize__ is int (cross-check anchor); verified with Python 3.12"]
    - [pl1366cc009, pathlib.Path.__itemsize__.__class__.__name__.__eq__,        ["int"], true, "Path.__itemsize__ is int (consistent with PurePath); verified with Python 3.12"]
