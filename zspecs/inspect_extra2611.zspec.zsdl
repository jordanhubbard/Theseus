spec: inspect_extra2611
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 621 (_extra2611): __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks for inspect module types."
    - "All values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
    - "__init_subclass__ is absent from the own __dict__ of all five inspect types tested: Parameter, BoundArguments, Signature, FullArgSpec, ArgInfo."
    - "__subclasshook__ is an ABCMeta hook; none of these inspect types are ABCs, so all return False for dict-presence."
    - "__class_getitem__ is absent from all five inspect types — none define generic alias support in their own __dict__."
    - "inspect.FullArgSpec and inspect.ArgInfo are namedtuple subclasses; neither defines any of the three dunders in its own __dict__."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __init_subclass__ dict-presence for inspect introspection types
#
# inspect.Parameter, BoundArguments, Signature, FullArgSpec, and ArgInfo
# are Python-level classes. None define __init_subclass__ in their own
# __dict__; the hook is available only through MRO inheritance from object.
# ---------------------------------------------------------------------------

table inspect_extra2611.init_subclass_absent:
  description: "inspect types do not define __init_subclass__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2611

  columns: [id, function, args, expected]
  rows:
    - ["in2611001", "inspect.Parameter.__dict__.__contains__",      ["__init_subclass__"], false]
    - ["in2611002", "inspect.BoundArguments.__dict__.__contains__", ["__init_subclass__"], false]
    - ["in2611003", "inspect.Signature.__dict__.__contains__",      ["__init_subclass__"], false]
    - ["in2611004", "inspect.FullArgSpec.__dict__.__contains__",    ["__init_subclass__"], false]
    - ["in2611005", "inspect.ArgInfo.__dict__.__contains__",        ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# Table 2: __subclasshook__ dict-presence for inspect introspection types
#
# __subclasshook__ is used by ABCMeta to customise virtual subclass checks.
# inspect.Parameter, BoundArguments, Signature, FullArgSpec, and ArgInfo
# are plain Python classes (or namedtuple subclasses) — none use ABCMeta,
# so __subclasshook__ is absent from all of their own __dict__ entries.
# ---------------------------------------------------------------------------

table inspect_extra2611.subclasshook_absent:
  description: "inspect types do not define __subclasshook__ in their own __dict__ — none are ABCs"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2611

  columns: [id, function, args, expected]
  rows:
    - ["in2611006", "inspect.Parameter.__dict__.__contains__",      ["__subclasshook__"], false]
    - ["in2611007", "inspect.BoundArguments.__dict__.__contains__", ["__subclasshook__"], false]
    - ["in2611008", "inspect.Signature.__dict__.__contains__",      ["__subclasshook__"], false]
    - ["in2611009", "inspect.FullArgSpec.__dict__.__contains__",    ["__subclasshook__"], false]
    - ["in2611010", "inspect.ArgInfo.__dict__.__contains__",        ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# Table 3: __class_getitem__ dict-presence for inspect introspection types
#
# __class_getitem__ enables generic alias syntax (e.g. Signature[int]).
# None of the inspect types define it in their own __dict__. Python 3.9+
# did not add PEP 585 support to these inspect classes.
# ---------------------------------------------------------------------------

table inspect_extra2611.class_getitem_checks:
  description: "inspect types do not define __class_getitem__ in their own __dict__ — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: in2611

  columns: [id, function, args, expected]
  rows:
    - ["in2611011", "inspect.Parameter.__dict__.__contains__",      ["__class_getitem__"], false]
    - ["in2611012", "inspect.BoundArguments.__dict__.__contains__", ["__class_getitem__"], false]
    - ["in2611013", "inspect.Signature.__dict__.__contains__",      ["__class_getitem__"], false]
    - ["in2611014", "inspect.FullArgSpec.__dict__.__contains__",    ["__class_getitem__"], false]
    - ["in2611015", "inspect.ArgInfo.__dict__.__contains__",        ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Table 4: Inherited hook accessibility via __qualname__
#
# Although __init_subclass__ is absent from each type's own __dict__, it is
# accessible via normal attribute lookup (MRO inheritance). The bound
# classmethod's __qualname__ reflects the name of the type it is bound to.
# This confirms the hook is live and accessible despite not being stored in
# the class's own dict — a standard pattern for Python-defined classes that
# do not override this hook.
# ---------------------------------------------------------------------------

table inspect_extra2611.object_inherited_hooks:
  description: "inspect types inherit __init_subclass__ via MRO — qualname reflects per-class binding"
  kind: python_call_eq
  category: qualname_eq
  id_prefix: in2611

  columns: [id, function, args, expected]
  rows:
    - ["in2611016", "inspect.Parameter.__init_subclass__.__qualname__.__eq__",      ["Parameter.__init_subclass__"],      true]
    - ["in2611017", "inspect.BoundArguments.__init_subclass__.__qualname__.__eq__", ["BoundArguments.__init_subclass__"], true]
    - ["in2611018", "inspect.Signature.__init_subclass__.__qualname__.__eq__",      ["Signature.__init_subclass__"],      true]
    - ["in2611019", "inspect.FullArgSpec.__init_subclass__.__qualname__.__eq__",    ["FullArgSpec.__init_subclass__"],    true]
    - ["in2611020", "inspect.ArgInfo.__init_subclass__.__qualname__.__eq__",        ["ArgInfo.__init_subclass__"],        true]
