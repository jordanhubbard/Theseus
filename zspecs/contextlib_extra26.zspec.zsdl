spec: contextlib_extra26
version: ">=3.9"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
    - "contextlib_extra25.zspec.zsdl — covers combined __qualname__ table for ten contextlib members; __qualname__.__len__ for AbstractContextManager/AbstractAsyncContextManager; AsyncExitStack.__qualname__.__len__; closing/suppress __mro__.__len__."
    - "contextlib_extra24.zspec.zsdl — covers combined __qualname__ table and __qualname__.__len__ table for contextmanager/asynccontextmanager/suppress/redirect_stdout/redirect_stderr/closing/nullcontext/ExitStack."
    - "contextlib_extra16.zspec.zsdl — covers ExitStack.__qualname__ standalone."
    - "contextlib_extra18.zspec.zsdl — covers __qualname__ for contextmanager/asynccontextmanager/nullcontext/AsyncExitStack/redirect_stdout/redirect_stderr."
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra25.zspec.zsdl."
    - "Focus: method-level __qualname__ values for contextlib not yet recorded — AbstractContextManager.__enter__, AbstractContextManager.__exit__, ExitStack.enter_context, ExitStack.callback — plus top-level class qualnames in a new combined table in the extra26 namespace."
    - "contextlib.contextmanager.__qualname__ == 'contextmanager' — top-level function."
    - "contextlib.asynccontextmanager.__qualname__ == 'asynccontextmanager' — top-level function."
    - "contextlib.AbstractContextManager.__qualname__ == 'AbstractContextManager' — top-level class."
    - "contextlib.AbstractContextManager.__enter__.__qualname__ == 'AbstractContextManager.__enter__' — method qualname includes class; no prior spec records this as a standalone or combined invariant."
    - "contextlib.AbstractContextManager.__exit__.__qualname__ == 'AbstractContextManager.__exit__' — method qualname includes class; no prior spec records this."
    - "contextlib.ExitStack.__qualname__ == 'ExitStack' — top-level class."
    - "contextlib.ExitStack.enter_context.__qualname__ == '_BaseExitStack.enter_context' — method is defined on the internal _BaseExitStack base class; qualname reflects the defining class."
    - "contextlib.ExitStack.callback.__qualname__ == '_BaseExitStack.callback' — method is defined on the internal _BaseExitStack base class."
    - "contextlib.suppress.__qualname__ == 'suppress' — top-level class."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for contextlib members — combined table in extra26 namespace
#
# contextlib_extra25 combines ten top-level members. This extra26 table adds
# method-level qualnames (AbstractContextManager.__enter__/__exit__,
# ExitStack.enter_context/callback) not previously combined into any table.
# ExitStack.enter_context and ExitStack.callback have qualnames referencing
# '_BaseExitStack' — the internal base class where they are defined.
# ---------------------------------------------------------------------------

table contextlib_extra26.qualnames:
  description: "__qualname__ for contextlib class and method members in the extra26 namespace"
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [contextmanager,                 contextmanager.__qualname__.__eq__,                 ["contextmanager"],                     true]
    - [asynccontextmanager,            asynccontextmanager.__qualname__.__eq__,            ["asynccontextmanager"],                true]
    - [AbstractContextManager,         AbstractContextManager.__qualname__.__eq__,         ["AbstractContextManager"],             true]
    - [suppress,                       suppress.__qualname__.__eq__,                       ["suppress"],                           true]
    - [ExitStack,                      ExitStack.__qualname__.__eq__,                      ["ExitStack"],                          true]
    - [ACM_enter,                      "AbstractContextManager.__enter__.__qualname__.__eq__", ["AbstractContextManager.__enter__"], true]
    - [ACM_exit,                       "AbstractContextManager.__exit__.__qualname__.__eq__",  ["AbstractContextManager.__exit__"],  true]
    - [ExitStack_enter_context,        "ExitStack.enter_context.__qualname__.__eq__",      ["_BaseExitStack.enter_context"],        true]
    - [ExitStack_callback,             "ExitStack.callback.__qualname__.__eq__",           ["_BaseExitStack.callback"],             true]

# ---------------------------------------------------------------------------
# AbstractContextManager.__enter__.__qualname__ — standalone invariant
#
# No prior contextlib spec records AbstractContextManager.__enter__.__qualname__
# as a standalone invariant. Method qualnames include the enclosing class.
# ---------------------------------------------------------------------------

invariant contextlib_extra26.AbstractContextManager.enter.qualname:
  description: "contextlib.AbstractContextManager.__enter__.__qualname__ == 'AbstractContextManager.__enter__'"
  category: method_qualnames
  kind: python_call_eq
  function: "AbstractContextManager.__enter__.__qualname__.__eq__"
  args: ["AbstractContextManager.__enter__"]
  expected: true

# ---------------------------------------------------------------------------
# AbstractContextManager.__exit__.__qualname__ — standalone invariant
#
# No prior contextlib spec records AbstractContextManager.__exit__.__qualname__
# as a standalone invariant.
# ---------------------------------------------------------------------------

invariant contextlib_extra26.AbstractContextManager.exit.qualname:
  description: "contextlib.AbstractContextManager.__exit__.__qualname__ == 'AbstractContextManager.__exit__'"
  category: method_qualnames
  kind: python_call_eq
  function: "AbstractContextManager.__exit__.__qualname__.__eq__"
  args: ["AbstractContextManager.__exit__"]
  expected: true

# ---------------------------------------------------------------------------
# ExitStack.enter_context.__qualname__ — standalone invariant
#
# ExitStack.enter_context is defined on _BaseExitStack, the internal base
# class shared with AsyncExitStack. Its qualname is '_BaseExitStack.enter_context'.
# No prior contextlib spec records this method qualname.
# ---------------------------------------------------------------------------

invariant contextlib_extra26.ExitStack.enter_context.qualname:
  description: "contextlib.ExitStack.enter_context.__qualname__ == '_BaseExitStack.enter_context' — defined on internal base class"
  category: method_qualnames
  kind: python_call_eq
  function: "ExitStack.enter_context.__qualname__.__eq__"
  args: ["_BaseExitStack.enter_context"]
  expected: true

# ---------------------------------------------------------------------------
# ExitStack.callback.__qualname__ — standalone invariant
#
# ExitStack.callback is defined on _BaseExitStack. Its qualname is
# '_BaseExitStack.callback'. No prior contextlib spec records this method qualname.
# ---------------------------------------------------------------------------

invariant contextlib_extra26.ExitStack.callback.qualname:
  description: "contextlib.ExitStack.callback.__qualname__ == '_BaseExitStack.callback' — defined on internal base class"
  category: method_qualnames
  kind: python_call_eq
  function: "ExitStack.callback.__qualname__.__eq__"
  args: ["_BaseExitStack.callback"]
  expected: true
