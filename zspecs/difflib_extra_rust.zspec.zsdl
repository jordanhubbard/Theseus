spec: difflib_extra_rust
version: ">=3.9"
backend: rust_module(difflib_extra_rust)

docs: https://docs.python.org/3/library/difflib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/difflib.html — difflib stdlib"
  notes:
    - "difflib provides sequence comparison utilities."
    - "difflib.SequenceMatcher(None, 'abc', 'abc').ratio() == 1.0."
    - "difflib.unified_diff is callable."
    - "difflib.get_close_matches('aple', ['apple','banana']) == ['apple']."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant difflib_extra_rust.ratio_identical:
  description: "SequenceMatcher(None,'abc','abc').ratio() == 1.0"
  category: ratio
  kind: python_call_eq
  function: difflib_extra_ratio_identical
  args: []
  expected: 1.0

invariant difflib_extra_rust.close_matches_apple:
  description: "get_close_matches('aple', ['apple','banana']) == ['apple']"
  category: close_matches
  kind: python_call_eq
  function: difflib_extra_close_matches_apple
  args: []
  expected: ["apple"]

invariant difflib_extra_rust.has_unified_diff:
  description: "difflib.unified_diff is callable"
  category: presence
  kind: python_call_eq
  function: difflib_extra_has_unified_diff
  args: []
  expected: true

