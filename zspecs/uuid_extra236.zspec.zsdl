spec: uuid_extra236
version: ">=3.7"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: uuid_extra235.zspec.zsdl — covers UUID.__slots__ contracts."
  notes:
    - "This spec covers uuid.SafeUUID enum identity; it does NOT duplicate invariants already present in uuid.zspec.zsdl or earlier extras."
    - "uuid.SafeUUID was added in Python 3.7 to indicate whether a UUID was generated safely."
    - "uuid.SafeUUID.__name__ == 'SafeUUID' — the enum class name."
    - "uuid.SafeUUID.__module__ == 'uuid' — defined in the uuid module."
    - "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID directly extends enum.Enum."
    - "uuid.SafeUUID.safe.__class__.__name__ == 'SafeUUID' — enum members are instances of their own class."
    - "uuid.SafeUUID.safe.value == 0 — 'safe' member value is 0."
    - "uuid.SafeUUID.unsafe.value == -1 — 'unsafe' member value is -1."
    - "uuid.SafeUUID has 3 members: safe (0), unsafe (-1), unknown (None)."
    - "uuid.SafeUUID.safe.name == 'safe' — the name attribute of the safe member."
    - "uuid.SafeUUID.unsafe.name == 'unsafe' — the name attribute of the unsafe member."
    - "uuid.SafeUUID.__qualname__ == 'SafeUUID' — top-level enum class."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.SafeUUID — class metadata
# SafeUUID is an Enum subclass defined in the uuid module (added Python 3.7)
# ---------------------------------------------------------------------------

table uuid_extra236.SafeUUID.class_metadata:
  kind: python_call_eq
  category: class_metadata
  id_prefix: uuid236safe

  columns: [id, function, args, expected]
  rows:
    - [class_name,    SafeUUID.__name__.__eq__,                ["SafeUUID"], true]
    - [module,        SafeUUID.__module__.__eq__,              ["uuid"],     true]
    - [qualname,      SafeUUID.__qualname__.__eq__,            ["SafeUUID"], true]
    - [base_name,     SafeUUID.__bases__.__getitem__,          [0],          "Enum"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID — member values
# safe == 0, unsafe == -1 (unknown == None)
# ---------------------------------------------------------------------------

table uuid_extra236.SafeUUID.member_values:
  kind: python_call_eq
  category: member_values
  id_prefix: uuid236safe

  columns: [id, function, args, expected]
  rows:
    - [safe_value,     SafeUUID.safe.value.__eq__,    [0],  true]
    - [unsafe_value,   SafeUUID.unsafe.value.__eq__,  [-1], true]
    - [safe_name,      SafeUUID.safe.name.__eq__,     ["safe"],   true]
    - [unsafe_name,    SafeUUID.unsafe.name.__eq__,   ["unsafe"], true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID — member class identity
# Each SafeUUID member is an instance of SafeUUID itself
# ---------------------------------------------------------------------------

invariant uuid_extra236.SafeUUID.name:
  description: "uuid.SafeUUID.__name__ == 'SafeUUID' — the enum class name"
  category: class_metadata
  kind: python_call_eq
  function: SafeUUID.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

invariant uuid_extra236.SafeUUID.module:
  description: "uuid.SafeUUID.__module__ == 'uuid' — SafeUUID is defined in the uuid module"
  category: class_metadata
  kind: python_call_eq
  function: SafeUUID.__module__.__eq__
  args: ["uuid"]
  expected: true

invariant uuid_extra236.SafeUUID.base_is_Enum:
  description: "uuid.SafeUUID.__bases__[0].__name__ == 'Enum' — SafeUUID directly extends enum.Enum"
  category: class_metadata
  kind: python_call_eq
  function: SafeUUID.__bases__.__getitem__
  args: [0]
  expected: "Enum"

invariant uuid_extra236.SafeUUID.safe_class:
  description: "uuid.SafeUUID.safe.__class__.__name__ == 'SafeUUID' — enum members are instances of their own class"
  category: member_identity
  kind: python_call_eq
  function: SafeUUID.safe.__class__.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

invariant uuid_extra236.SafeUUID.safe_value_eq_0:
  description: "uuid.SafeUUID.safe.value == 0 — 'safe' UUID generation returns value 0"
  category: member_values
  kind: python_call_eq
  function: SafeUUID.safe.value.__eq__
  args: [0]
  expected: true

invariant uuid_extra236.SafeUUID.unsafe_value_eq_neg1:
  description: "uuid.SafeUUID.unsafe.value == -1 — 'unsafe' UUID generation returns value -1"
  category: member_values
  kind: python_call_eq
  function: SafeUUID.unsafe.value.__eq__
  args: [-1]
  expected: true

invariant uuid_extra236.SafeUUID.safe_name:
  description: "uuid.SafeUUID.safe.name == 'safe' — the name attribute of the safe member"
  category: member_identity
  kind: python_call_eq
  function: SafeUUID.safe.name.__eq__
  args: ["safe"]
  expected: true

invariant uuid_extra236.SafeUUID.unsafe_name:
  description: "uuid.SafeUUID.unsafe.name == 'unsafe' — the name attribute of the unsafe member"
  category: member_identity
  kind: python_call_eq
  function: SafeUUID.unsafe.name.__eq__
  args: ["unsafe"]
  expected: true

invariant uuid_extra236.SafeUUID.safe_value_int_class:
  description: "uuid.SafeUUID.safe.value.__class__.__name__ == 'int' — SafeUUID values are integers"
  category: member_values
  kind: python_call_eq
  function: SafeUUID.safe.value.__class__.__name__.__eq__
  args: ["int"]
  expected: true
