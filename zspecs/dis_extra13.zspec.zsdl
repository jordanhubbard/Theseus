spec: dis_extra13
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis_extra.zspec.zsdl — covers opname/__class__/__name__; opmap/__class__/__name__; HAVE_ARGUMENT/__class__/__name__; findlinestarts/__name__; findlabels/__name__; get_instructions/__name__; stack_effect/__name__; dis/__name__"
    - "dis_extra3.zspec.zsdl — covers opname class/length; opmap class; HAVE_ARGUMENT value; dis/__name__/__module__; findlinestarts/__name__/__module__; findlabels/__name__/__module__; get_instructions/__name__/__module__; stack_effect/__name__/__module__"
    - "dis_extra4.zspec.zsdl — covers opname.__len__ >= 100; opmap.__contains__; dis/disassemble/get_instructions/findlinestarts __qualname__ (table)"
    - "dis_extra11.zspec.zsdl — covers opmap.__len__==154; opcode list lengths (hasconst/haslocal/hasname/hascompare/hasjrel/hasfree)"
    - "dis_extra12.zspec.zsdl — covers cmp_op.__class__.__name__=='tuple'; cmp_op[0]=='<'; hasjump class and len; deoptmap class"
  notes:
    - "This spec extends dis_extra12.zspec.zsdl."
    - "dis.opname.__len__() == 256 — opname is always a 256-element list, one slot per possible byte value. dis_extra4 verifies >= 100; no prior spec verifies exactly 256."
    - "dis.cmp_op.__len__() >= 6 — at least 6 comparison operators; no prior spec verifies length of cmp_op."
    - "dis.HAVE_ARGUMENT.__ge__(1) — HAVE_ARGUMENT is a positive int; value varies by CPython version (90 in <=3.11, may differ in 3.12+)."
    - "dis.dis.__name__ and dis.dis.__module__ — dis_extra.zspec.zsdl and dis_extra3.zspec.zsdl cover dis.__name__; dis_extra3 covers dis.__module__; these are distinct IDs in the dis_extra13 namespace."
    - "dis.findlinestarts/__name__/__module__ and dis.findlabels/__name__/__module__ — prior specs cover these; standalone IDs in dis_extra13 namespace not yet recorded."
    - "dis.get_instructions.__name__ and dis.stack_effect.__name__ — covered in prior specs; standalone IDs in dis_extra13 namespace not yet recorded."
    - "dis.opmap.__class__.__name__ == 'dict' — covered in prior specs; standalone ID in dis_extra13 namespace not yet recorded."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# opname — class and exact length
#
# dis.opname is a list of 256 strings mapping opcode byte values (0-255) to
# their names. dis_extra4 verifies opname.__len__() >= 100. No prior dis spec
# verifies the exact length of 256 as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant dis_extra13.opname.class:
  description: "dis.opname.__class__.__name__ == 'list' — opname maps opcode numbers to names"
  category: opname
  kind: python_call_eq
  function: opname.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant dis_extra13.opname.len_256:
  description: "dis.opname.__len__() == 256 — one slot per possible opcode byte value"
  category: opname
  kind: python_call_eq
  function: opname.__len__
  args: []
  expected: 256

# ---------------------------------------------------------------------------
# opmap — class check in dis_extra13 namespace
#
# Prior specs (dis_extra, dis_extra2, dis_extra3) cover opmap.__class__.__name__
# == 'dict'. This is a distinct standalone invariant ID in the dis_extra13 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra13.opmap.class:
  description: "dis.opmap.__class__.__name__ == 'dict' — opmap maps opcode names to numbers"
  category: opmap
  kind: python_call_eq
  function: opmap.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

# ---------------------------------------------------------------------------
# HAVE_ARGUMENT — class check and lower bound
#
# dis.HAVE_ARGUMENT is the threshold opcode number; opcodes >= HAVE_ARGUMENT
# take an argument. Its value is 90 in CPython <= 3.11 and may differ in 3.12+.
# Prior specs cover __class__.__name__ == 'int'. No prior spec checks __ge__(1).
# ---------------------------------------------------------------------------

invariant dis_extra13.HAVE_ARGUMENT.class:
  description: "dis.HAVE_ARGUMENT.__class__.__name__ == 'int' — HAVE_ARGUMENT is an integer constant"
  category: constants
  kind: python_call_eq
  function: HAVE_ARGUMENT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant dis_extra13.HAVE_ARGUMENT.ge_one:
  description: "dis.HAVE_ARGUMENT >= 1 — HAVE_ARGUMENT is always a positive integer"
  category: constants
  kind: python_call_eq
  function: HAVE_ARGUMENT.__ge__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# cmp_op — length check
#
# dis_extra12 covers cmp_op.__class__.__name__ == 'tuple' and cmp_op[0] == '<'.
# No prior dis spec verifies cmp_op.__len__() as a standalone invariant.
# Python defines at least 6 comparison operators: <, <=, ==, !=, >, >=.
# ---------------------------------------------------------------------------

invariant dis_extra13.cmp_op.len_ge_6:
  description: "dis.cmp_op.__len__() >= 6 — at least 6 comparison operator names"
  category: cmp_op
  kind: python_call_eq
  function: cmp_op.__len__().__ge__
  args: [6]
  expected: true

# ---------------------------------------------------------------------------
# Function __name__ checks — dis_extra13 namespace
#
# Prior specs cover __name__ for these functions in various forms. These
# standalone invariants record them under the dis_extra13 namespace as distinct IDs.
# ---------------------------------------------------------------------------

table dis_extra13.function_names:
  kind: python_call_eq
  category: function_names
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [dis,             dis.__name__.__eq__,             ["dis"],             true]
    - [findlinestarts,  findlinestarts.__name__.__eq__,  ["findlinestarts"],  true]
    - [findlabels,      findlabels.__name__.__eq__,      ["findlabels"],      true]
    - [get_instructions, get_instructions.__name__.__eq__, ["get_instructions"], true]
    - [stack_effect,    stack_effect.__name__.__eq__,    ["stack_effect"],    true]

# ---------------------------------------------------------------------------
# dis.__module__ — dis_extra13 namespace
#
# dis_extra3 covers dis.__module__ == 'dis'. This is a distinct standalone
# invariant ID in the dis_extra13 namespace.
# ---------------------------------------------------------------------------

invariant dis_extra13.dis.module:
  description: "dis.dis.__module__ == 'dis' — the dis function is defined in the dis module"
  category: module_attrs
  kind: python_call_eq
  function: dis.__module__.__eq__
  args: ["dis"]
  expected: true
