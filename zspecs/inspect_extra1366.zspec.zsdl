spec: inspect_extra1366
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks for inspect classes."
    - "inspect.Parameter, inspect.Signature, and inspect.BoundArguments are pure Python classes defined in Lib/inspect.py."
    - "Pure Python classes still carry __flags__, __basicsize__, and __itemsize__ as C-level int attributes on their type objects."
    - "inspect.Parameter.__flags__, __basicsize__, and __itemsize__ are all ints (values are platform-specific, only type checked)."
    - "inspect.Signature.__flags__, __basicsize__, and __itemsize__ are all ints."
    - "inspect.BoundArguments.__flags__, __basicsize__, and __itemsize__ are all ints."
    - "__itemsize__ is 0 for all three classes (no variable-length C struct tail for Python-defined classes)."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra1366.parameter_flags_basicsize_itemsize:
  description: "inspect.Parameter __flags__, __basicsize__, __itemsize__ type checks; pure Python class with int-typed C-level type attributes"
  kind: python_call_eq
  category: flags_basicsize_itemsize_checks
  id_prefix: in1366pa
  columns: [id, function, args, expected]
  rows:
    - [in1366pa001, inspect.Parameter.__flags__.__class__.__name__.__eq__,     ["int"],  true]
    - [in1366pa002, inspect.Parameter.__basicsize__.__class__.__name__.__eq__, ["int"],  true]
    - [in1366pa003, inspect.Parameter.__itemsize__.__class__.__name__.__eq__,  ["int"],  true]
    - [in1366pa004, inspect.Signature.__flags__.__class__.__name__.__eq__,     ["int"],  true]
    - [in1366pa005, inspect.Signature.__basicsize__.__class__.__name__.__eq__, ["int"],  true]
    - [in1366pa006, inspect.Signature.__itemsize__.__class__.__name__.__eq__,  ["int"],  true]

table inspect_extra1366.boundarguments_flags_basicsize_itemsize:
  description: "inspect.BoundArguments __flags__, __basicsize__, __itemsize__ type checks; pure Python class carrying int-typed C-level type attributes"
  kind: python_call_eq
  category: flags_basicsize_itemsize_checks
  id_prefix: in1366ba
  columns: [id, function, args, expected]
  rows:
    - [in1366ba001, inspect.BoundArguments.__flags__.__class__.__name__.__eq__,     ["int"],  true]
    - [in1366ba002, inspect.BoundArguments.__basicsize__.__class__.__name__.__eq__, ["int"],  true]
    - [in1366ba003, inspect.BoundArguments.__itemsize__.__class__.__name__.__eq__,  ["int"],  true]
    - [in1366ba004, inspect.Parameter.__flags__.__class__.__name__.__eq__,          ["int"],  true]
    - [in1366ba005, inspect.Signature.__flags__.__class__.__name__.__eq__,          ["int"],  true]
    - [in1366ba006, inspect.BoundArguments.__flags__.__class__.__name__.__eq__,     ["int"],  true]

table inspect_extra1366.all_classes_flags_basicsize_cross_check:
  description: "Cross-check: Parameter, Signature, BoundArguments all confirm __basicsize__ and __itemsize__ are int; all three pure Python classes follow the same C-level type attribute pattern"
  kind: python_call_eq
  category: flags_basicsize_itemsize_checks
  id_prefix: in1366cr
  columns: [id, function, args, expected]
  rows:
    - [in1366cr001, inspect.Parameter.__basicsize__.__class__.__name__.__eq__,     ["int"],  true]
    - [in1366cr002, inspect.Parameter.__itemsize__.__class__.__name__.__eq__,      ["int"],  true]
    - [in1366cr003, inspect.Signature.__basicsize__.__class__.__name__.__eq__,     ["int"],  true]
    - [in1366cr004, inspect.Signature.__itemsize__.__class__.__name__.__eq__,      ["int"],  true]
    - [in1366cr005, inspect.BoundArguments.__basicsize__.__class__.__name__.__eq__, ["int"], true]
    - [in1366cr006, inspect.BoundArguments.__itemsize__.__class__.__name__.__eq__,  ["int"], true]
