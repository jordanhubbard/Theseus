spec: socket_extra246
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 791 — Internet Protocol"
  - "RFC 793 — Transmission Control Protocol"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "RFC 791 — Internet Protocol, DARPA, September 1981"
    - "RFC 793 — Transmission Control Protocol, September 1981"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra245.zspec.zsdl — covers ntohs/ntohl/htons/htonl __module__ and __name__ table; byte-order swap values on little-endian."
    - "socket_extra241.zspec.zsdl — covers socket.socket class identity (__name__/__module__/__qualname__); instance method __name__ and __qualname__ for connect/bind/listen/accept/close/recv/send."
    - "socket_extra24.zspec.zsdl — covers socket.socket __qualname__/__module__/__bases__[0].__name__; AddressFamily/SocketKind qualname/module."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC and SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names."
    - "socket_extra142.zspec.zsdl — covers AF_INET/AF_INET6 enum member .name values; SOCK_STREAM/SOCK_DGRAM .name values."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra through socket_extra245."
    - "socket.socket() default construction produces AF_INET/SOCK_STREAM (IPv4 TCP) socket."
    - "socket.socket().family.__class__.__name__ == 'AddressFamily' — family returns an AddressFamily IntEnum member."
    - "socket.socket().type.__class__.__name__ == 'SocketKind' — type returns a SocketKind IntEnum member."
    - "socket.socket().family.__class__.__module__ == 'socket' — AddressFamily is defined in the socket module."
    - "socket.socket().type.__class__.__module__ == 'socket' — SocketKind is defined in the socket module."
    - "socket.socket().family.__eq__(socket.AF_INET) == True — default socket family is IPv4."
    - "socket.socket().type.__eq__(socket.SOCK_STREAM) == True — default socket type is SOCK_STREAM (TCP)."
    - "socket.socket().family.__int__() == 2 — AF_INET has integer value 2."
    - "socket.socket().type.__int__() == 1 — SOCK_STREAM has integer value 1."
    - "socket.socket().fileno.__name__ == 'fileno' — instance method bare name."
    - "socket.socket().fileno.__qualname__ == 'socket.fileno' — qualified name including class."
    - "socket.socket().settimeout.__name__ == 'settimeout' — timeout control method bare name."
    - "socket.socket().gettimeout.__name__ == 'gettimeout' — timeout query method bare name."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "socket raises OSError for I/O failures. Class identity and method name checks are stateless and never raise."
  stderr: "null"
  stickiness: "N/A — all tested invariants are instance attribute class names or method name checks."
  codes: {}

# ---------------------------------------------------------------------------
# socket.socket() instance — family attribute class name
# family returns an AddressFamily IntEnum member on default construction.
# socket_extra96 covers AF_INET.__class__.__name__ at the module level;
# this spec tests the same via the socket() instance family property.
# ---------------------------------------------------------------------------

invariant sockinst246.family_class_name:
  description: "socket.socket().family.__class__.__name__ == 'AddressFamily'"
  category: instance_attrs
  kind: python_call_eq
  function: socket
  args: []
  method: family.__class__.__name__.__eq__
  method_args: ["AddressFamily"]
  expected: true

invariant sockinst246.family_class_module:
  description: "socket.socket().family.__class__.__module__ == 'socket'"
  category: instance_attrs
  kind: python_call_eq
  function: socket
  args: []
  method: family.__class__.__module__.__eq__
  method_args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket() instance — type attribute class name
# type returns a SocketKind IntEnum member on default construction.
# socket_extra96 covers SOCK_STREAM.__class__.__name__ at the module level.
# ---------------------------------------------------------------------------

invariant sockinst246.type_class_name:
  description: "socket.socket().type.__class__.__name__ == 'SocketKind'"
  category: instance_attrs
  kind: python_call_eq
  function: socket
  args: []
  method: type.__class__.__name__.__eq__
  method_args: ["SocketKind"]
  expected: true

invariant sockinst246.type_class_module:
  description: "socket.socket().type.__class__.__module__ == 'socket'"
  category: instance_attrs
  kind: python_call_eq
  function: socket
  args: []
  method: type.__class__.__module__.__eq__
  method_args: ["socket"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket() instance — family and type integer values
# family.__eq__(AF_INET) and type.__eq__(SOCK_STREAM) confirm default construction.
# family.__int__() == 2 (AF_INET) and type.__int__() == 1 (SOCK_STREAM).
# ---------------------------------------------------------------------------

table sockinst246.family_type_values:
  description: "socket.socket() family/type integer values and AF_INET/SOCK_STREAM equality"
  kind: python_call_eq
  category: instance_attrs
  id_prefix: sockinst246
  function: socket

  columns: [id, args, method, method_args, expected]
  rows:
    - [family_int,      [], family.__int__,             [],  2]
    - [type_int,        [], type.__int__,               [],  1]
    - [family_eq_inet,  [], family.__eq__,              [2], true]
    - [type_eq_stream,  [], type.__eq__,                [1], true]

# ---------------------------------------------------------------------------
# socket.socket() instance method __name__ contracts
# fileno, settimeout, gettimeout, setblocking — bare names.
# socket_extra241 covers connect/bind/listen/accept/close/recv/send __name__.
# ---------------------------------------------------------------------------

table sockinst246.method_names:
  description: "socket.socket() instance method __name__ values — fileno/settimeout/gettimeout/setblocking"
  kind: python_call_eq
  category: method_identity
  id_prefix: sockinst246
  function: socket

  columns: [id, args, method, method_args, expected]
  rows:
    - [fileno_name,      [], fileno.__name__.__eq__,      ["fileno"],      true]
    - [settimeout_name,  [], settimeout.__name__.__eq__,  ["settimeout"],  true]
    - [gettimeout_name,  [], gettimeout.__name__.__eq__,  ["gettimeout"],  true]
    - [setblocking_name, [], setblocking.__name__.__eq__,  ["setblocking"], true]

# ---------------------------------------------------------------------------
# socket.socket() instance method __qualname__ contracts
# socket_extra22/socket_extra241 cover connect/bind etc; this adds fileno.
# 'socket.fileno' has 13 characters.
# ---------------------------------------------------------------------------

invariant sockinst246.fileno_qualname:
  description: "socket.socket().fileno.__qualname__ == 'socket.fileno'"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: fileno.__qualname__.__eq__
  method_args: ["socket.fileno"]
  expected: true

invariant sockinst246.fileno_qualname_len:
  description: "socket.socket().fileno.__qualname__.__len__() == 13 — 'socket.fileno' has 13 characters"
  category: method_identity
  kind: python_call_eq
  function: socket
  args: []
  method: fileno.__qualname__.__len__
  method_args: []
  expected: 13
