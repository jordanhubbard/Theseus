spec: theseus_doctest_cr
version: ">=3.0"
backend: python_cleanroom(theseus_doctest_cr)
blocks: doctest

docs: https://docs.python.org/3/library/doctest.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/doctest.html"
  not_derived_from:
    - "CPython source: Lib/doctest.py"
  notes:
    - "Clean-room doctest module. Do NOT import doctest."

error_model: python_exceptions

invariant theseus_doctest_cr.doctest2_run:
  description: "DocTestRunner can run a simple doctest"
  category: behavior
  kind: python_call_eq
  function: doctest2_run
  args: []
  expected: true

invariant theseus_doctest_cr.doctest2_testmod:
  description: "testmod() works on a module"
  category: behavior
  kind: python_call_eq
  function: doctest2_testmod
  args: []
  expected: true

invariant theseus_doctest_cr.doctest2_example:
  description: "Example class exists"
  category: behavior
  kind: python_call_eq
  function: doctest2_example
  args: []
  expected: true
