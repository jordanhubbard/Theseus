spec: serialize_javascript
version: ">=6.0.0"
backend: node(serialize-javascript)

docs: https://github.com/yahoo/serialize-javascript#readme

provenance:
  derived_from:
    - "serialize-javascript README — https://github.com/yahoo/serialize-javascript#readme"
    - "Test vectors verified with serialize-javascript@7.0.5 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "serialize-javascript source: index.js"
  notes:
    - "serialize-javascript exports the serialize function as the module default (CJS)."
    - "serialize() serializes JS values to a string that can be eval'd back."
    - "Plain objects and arrays serialize like JSON."
    - "RegExp serialization is not specced here as RegExp cannot be expressed in YAML args."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a serialized JS string. No errors for standard inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table serialize_javascript.basic:
  kind: node_module_call_eq
  function: ~
  category: basic
  id_prefix: ser

  columns: [id, args, expected]
  rows:
    - [object,  [{"a": 1, "b": "hello"}],  "{\"a\":1,\"b\":\"hello\"}"]
    - [array,   [[1, 2, 3]],               "[1,2,3]"]
    - [number,  [42],                      "42"]
    - [string,  ["hello"],                 "\"hello\""]
