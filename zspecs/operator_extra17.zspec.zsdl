spec: operator_extra17
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra16.zspec.zsdl."
    - "operator_extra15 covers __name__.__len__ for add/truediv/floordiv/pow/mod/eq/truth/not_/itemgetter/attrgetter/methodcaller/contains and __module__.__len__ for add/itemgetter/attrgetter."
    - "operator_extra13 covers __qualname__.__eq__ for arithmetic operators add/sub/mul/truediv/floordiv/mod/pow."
    - "No prior spec covers __name__.__eq__ assertions for add, sub, mul, truediv, floordiv, mod, or pow."
    - "No prior spec covers __module__.__eq__ assertions for add, sub, mul, truediv, floordiv, mod, or pow."
    - "No prior spec covers operator.add(3, 4) == 7 as a direct call result."
    - "No prior spec covers operator.mul(6, 7) == 42 as a direct call result."
    - "No prior spec covers operator.floordiv(7, 2) == 3 as a direct call result."
    - "operator.add.__module__ == '_operator' — arithmetic operators are implemented in the C extension _operator."
    - "operator.add(3, 4) == 7 — integer addition via operator module."
    - "operator.mul(6, 7) == 42 — integer multiplication via operator module."
    - "operator.floordiv(7, 2) == 3 — floor division discards remainder."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ attributes for arithmetic operator functions
#
# operator_extra13 covers __qualname__.__eq__ for these functions.
# operator_extra15 covers __name__.__len__ for several of them.
# No prior spec records __name__.__eq__ (direct string equality) for any of
# these arithmetic operators.
# ---------------------------------------------------------------------------

table operator_extra17.arithmetic_names:
  kind: python_call_eq
  category: introspection
  id_prefix: aname

  columns: [id, function, args, expected]
  rows:
    - [add_name,      add.__name__.__eq__,      ["add"],      true]
    - [sub_name,      sub.__name__.__eq__,      ["sub"],      true]
    - [mul_name,      mul.__name__.__eq__,      ["mul"],      true]
    - [truediv_name,  truediv.__name__.__eq__,  ["truediv"],  true]
    - [floordiv_name, floordiv.__name__.__eq__, ["floordiv"], true]
    - [mod_name,      mod.__name__.__eq__,      ["mod"],      true]
    - [pow_name,      pow.__name__.__eq__,      ["pow"],      true]

# ---------------------------------------------------------------------------
# __module__ attributes for arithmetic operator functions
#
# All arithmetic operators are implemented in the C extension module _operator,
# not in the pure-Python operator wrapper. Their __module__ is '_operator'.
# operator_extra15 records __module__.__len__ for add (9 == len('_operator')).
# No prior spec records __module__.__eq__ (string equality) for any of these.
# ---------------------------------------------------------------------------

table operator_extra17.arithmetic_modules:
  kind: python_call_eq
  category: introspection
  id_prefix: amod

  columns: [id, function, args, expected]
  rows:
    - [add_mod,      add.__module__.__eq__,      ["_operator"], true]
    - [sub_mod,      sub.__module__.__eq__,      ["_operator"], true]
    - [mul_mod,      mul.__module__.__eq__,      ["_operator"], true]
    - [truediv_mod,  truediv.__module__.__eq__,  ["_operator"], true]
    - [floordiv_mod, floordiv.__module__.__eq__, ["_operator"], true]
    - [mod_mod,      mod.__module__.__eq__,      ["_operator"], true]
    - [pow_mod,      pow.__module__.__eq__,      ["_operator"], true]

# ---------------------------------------------------------------------------
# Direct call results — add, mul, floordiv
#
# No prior operator spec verifies call results for add, mul, or floordiv.
# These are behaviorally distinct from introspection: they exercise the
# operator function as a callable rather than as an object with attributes.
# ---------------------------------------------------------------------------

invariant operator_extra17.add.call_3_4:
  description: "operator.add(3, 4) == 7 — integer addition"
  category: call_results
  kind: python_call_eq
  function: add
  args: [3, 4]
  expected: 7

invariant operator_extra17.mul.call_6_7:
  description: "operator.mul(6, 7) == 42 — integer multiplication"
  category: call_results
  kind: python_call_eq
  function: mul
  args: [6, 7]
  expected: 42

invariant operator_extra17.floordiv.call_7_2:
  description: "operator.floordiv(7, 2) == 3 — floor division of 7 by 2 discards the remainder"
  category: call_results
  kind: python_call_eq
  function: floordiv
  args: [7, 2]
  expected: 3
