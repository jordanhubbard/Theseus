spec: io_extra2671
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
    - "io_extra2656.zspec.zsdl — covers __contains__/__add__/__mul__ dict-presence"
  notes:
    - "Wave 625 (io_extra2671) theme: __sub__, __floordiv__, and __mod__ dict-presence checks."
    - "None of the io classes define __sub__, __floordiv__, or __mod__ in their own __dict__."
    - "__sub__ is the subtraction operator; io stream classes do not implement arithmetic subtraction."
    - "__floordiv__ is the floor-division operator; io stream classes do not implement division semantics."
    - "__mod__ is the modulo operator; io stream classes do not implement modulo semantics."
    - "Covers io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.BytesIO, io.StringIO, io.FileIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, and io.TextIOWrapper."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __sub__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2671.no_sub_in_io_classes:
  description: "__sub__ is absent from all io class __dict__s — io stream classes do not implement the arithmetic subtraction protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2671

  columns: [id, function, args, expected]
  rows:
    - ["io2671001", "io.IOBase.__dict__.__contains__",         ["__sub__"], false]
    - ["io2671002", "io.RawIOBase.__dict__.__contains__",      ["__sub__"], false]
    - ["io2671003", "io.BufferedIOBase.__dict__.__contains__", ["__sub__"], false]
    - ["io2671004", "io.TextIOBase.__dict__.__contains__",     ["__sub__"], false]
    - ["io2671005", "io.BytesIO.__dict__.__contains__",        ["__sub__"], false]
    - ["io2671006", "io.StringIO.__dict__.__contains__",       ["__sub__"], false]

# ---------------------------------------------------------------------------
# __floordiv__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2671.no_floordiv_in_io_classes:
  description: "__floordiv__ is absent from all io class __dict__s — io stream classes do not implement the floor-division protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2671

  columns: [id, function, args, expected]
  rows:
    - ["io2671007", "io.IOBase.__dict__.__contains__",          ["__floordiv__"], false]
    - ["io2671008", "io.FileIO.__dict__.__contains__",          ["__floordiv__"], false]
    - ["io2671009", "io.BufferedReader.__dict__.__contains__",  ["__floordiv__"], false]
    - ["io2671010", "io.BufferedWriter.__dict__.__contains__",  ["__floordiv__"], false]
    - ["io2671011", "io.BufferedRandom.__dict__.__contains__",  ["__floordiv__"], false]
    - ["io2671012", "io.TextIOWrapper.__dict__.__contains__",   ["__floordiv__"], false]

# ---------------------------------------------------------------------------
# __mod__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2671.no_mod_in_io_classes:
  description: "__mod__ is absent from all io class __dict__s — io stream classes do not implement the modulo protocol"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2671

  columns: [id, function, args, expected]
  rows:
    - ["io2671013", "io.IOBase.__dict__.__contains__",         ["__mod__"], false]
    - ["io2671014", "io.BytesIO.__dict__.__contains__",        ["__mod__"], false]
    - ["io2671015", "io.StringIO.__dict__.__contains__",       ["__mod__"], false]
    - ["io2671016", "io.FileIO.__dict__.__contains__",         ["__mod__"], false]
    - ["io2671017", "io.BufferedReader.__dict__.__contains__", ["__mod__"], false]
    - ["io2671018", "io.BufferedWriter.__dict__.__contains__", ["__mod__"], false]

# ---------------------------------------------------------------------------
# Complementary: io stream classes have I/O methods but not arithmetic hooks
# Confirms that io classes are sequential I/O objects, not arithmetic types
# ---------------------------------------------------------------------------

table io_extra2671.io_has_stream_methods_not_arithmetic_hooks:
  description: "io.BytesIO defines read/write/seek/tell but NOT __sub__/__floordiv__/__mod__; io.StringIO similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2671

  columns: [id, function, args, expected]
  rows:
    - ["io2671019", "io.BytesIO.__dict__.__contains__",  ["read"],         true]
    - ["io2671020", "io.BytesIO.__dict__.__contains__",  ["write"],        true]
    - ["io2671021", "io.BytesIO.__dict__.__contains__",  ["seek"],         true]
    - ["io2671022", "io.BytesIO.__dict__.__contains__",  ["tell"],         true]
    - ["io2671023", "io.BytesIO.__dict__.__contains__",  ["__sub__"],      false]
    - ["io2671024", "io.BytesIO.__dict__.__contains__",  ["__floordiv__"], false]
    - ["io2671025", "io.BytesIO.__dict__.__contains__",  ["__mod__"],      false]
    - ["io2671026", "io.StringIO.__dict__.__contains__", ["read"],         true]
    - ["io2671027", "io.StringIO.__dict__.__contains__", ["write"],        true]
    - ["io2671028", "io.StringIO.__dict__.__contains__", ["seek"],         true]
    - ["io2671029", "io.StringIO.__dict__.__contains__", ["tell"],         true]
    - ["io2671030", "io.StringIO.__dict__.__contains__", ["__sub__"],      false]
    - ["io2671031", "io.StringIO.__dict__.__contains__", ["__floordiv__"], false]
    - ["io2671032", "io.StringIO.__dict__.__contains__", ["__mod__"],      false]
