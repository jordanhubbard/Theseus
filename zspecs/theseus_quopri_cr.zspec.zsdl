spec: theseus_quopri_cr
version: ">=3.8"
backend: python_cleanroom(theseus_quopri_cr)
blocks: quopri

docs: https://docs.python.org/3/library/quopri.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/quopri.html"
    - "RFC 2045 — MIME Part One"
  not_derived_from:
    - "CPython source: Lib/quopri.py (internal implementation)"
  notes:
    - "Clean-room quopri module. Do NOT import quopri."
    - "encode(input, output, quotetabs, header): QP encode."
    - "decode(input, output, header): QP decode."
    - "encodestring(s): encode bytes to QP."
    - "decodestring(s): decode QP to bytes."

error_model: python_exceptions

invariant theseus_quopri_cr.quopri2_encode:
  description: "encodestring encodes non-ASCII bytes as =XX sequences"
  category: encodestring
  kind: python_call_eq
  function: quopri2_encode
  args: []
  expected: true

invariant theseus_quopri_cr.quopri2_decode:
  description: "decodestring reverses encodestring"
  category: decodestring
  kind: python_call_eq
  function: quopri2_decode
  args: []
  expected: true

invariant theseus_quopri_cr.quopri2_ascii:
  description: "ASCII printable bytes pass through unchanged"
  category: encodestring
  kind: python_call_eq
  function: quopri2_ascii
  args: []
  expected: true
