spec: functools_extra45
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec extends functools_extra44.zspec.zsdl."
    - "Prior specs covered: __name__.__len__() for wraps/partial/lru_cache/total_ordering/singledispatch/cached_property/reduce/cmp_to_key/partialmethod/singledispatchmethod/update_wrapper; __qualname__.__len__() for update_wrapper/partialmethod/singledispatchmethod/cache/total_ordering/singledispatch/cmp_to_key/cached_property/lru_cache/wraps/reduce/partial; WRAPPER_ASSIGNMENTS/WRAPPER_UPDATES lengths; __all__ lengths and indexed elements; partial/__class__.__name__; cached_property.__set_name__/__get__/__init__.__qualname__; total_ordering.__dict__.__class__.__name__; partial/__new__.__qualname__; class __dict__.__class__.__name__.__len__ for partial/partialmethod/singledispatchmethod/cached_property; partial/__doc__/reduce/__doc__; reduce with initial value; lru_cache(128).__ne__(None)==True; C-extension vs pure-Python __module__ lengths for reduce/cmp_to_key/lru_cache/wraps/update_wrapper; lru_cache(maxsize=2) behavioral; partial.__name__/'partial'; partial.__qualname__/'partial'; partial.__module__/'functools'; WRAPPER_ASSIGNMENTS.__class__.__name__/'tuple'; WRAPPER_ASSIGNMENTS.__len__()==6; WRAPPER_UPDATES.__len__()==1; lru_cache.__name__/'lru_cache'; lru_cache.__module__/'functools'."
    - "This spec covers: reduce.__qualname__ == 'reduce' (string equality, not just length); reduce.__qualname__.__len__() == 6; lru_cache.__qualname__ == 'lru_cache' (string equality); lru_cache.__qualname__.__len__() == 9; cache.__name__ == 'cache'; cache.__qualname__ == 'cache'; cache.__module__ == 'functools'; cached_property.__name__ == 'cached_property'; cached_property.__module__ == 'functools'."
    - "Key findings: functools.reduce.__qualname__ is 'reduce' (6 chars) — the C-extension builtin_function_or_method for reduce has __qualname__ equal to __name__ because it is a top-level C function with no enclosing class scope. functools.lru_cache.__qualname__ is 'lru_cache' (9 chars) — the pure-Python function's __qualname__ matches __name__ because lru_cache is defined at module level in Lib/functools.py, not nested in any class. functools.cache.__name__ is 'cache' (5 chars), functools.cache.__qualname__ is 'cache' (5 chars), and functools.cache.__module__ is 'functools' (9 chars) — cache is a thin wrapper around lru_cache(maxsize=None) defined at module level. functools.cached_property.__name__ is 'cached_property' (15 chars) and functools.cached_property.__module__ is 'functools' (9 chars) — cached_property is a pure-Python descriptor class defined at module level. No prior functools spec records these string equality invariants for reduce.__qualname__, lru_cache.__qualname__, cache.__name__, cache.__qualname__, cache.__module__, cached_property.__name__, or cached_property.__module__ in the extra45 namespace."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.reduce __qualname__ string equality — extra45 namespace
#
# functools.reduce.__qualname__ is 'reduce' (6 chars). The C-extension
# builtin_function_or_method has __qualname__ equal to __name__ because
# reduce is a top-level C function with no enclosing class scope. Prior
# specs recorded reduce.__qualname__.__len__()==6 but not the string equality
# invariant for __qualname__. The __len__() value is also recorded here for
# completeness — both are new to the extra45 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra45.reduce_qualname:
  description: "functools.reduce.__qualname__ == 'reduce' — C-extension builtin; __qualname__ == __name__ (top-level C function, no enclosing class scope); 6 chars"
  category: identity
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra45.reduce_qualname_len:
  description: "len(functools.reduce.__qualname__) == 6 — 'reduce'; same value as __name__.__len__() because __qualname__ == __name__ for top-level C functions"
  category: string_properties
  kind: python_call_eq
  function: reduce.__qualname__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# functools.lru_cache __qualname__ string equality — extra45 namespace
#
# functools.lru_cache.__qualname__ is 'lru_cache' (9 chars). The pure-Python
# function is defined at module level in Lib/functools.py, so __qualname__
# matches __name__ exactly. Prior specs recorded lru_cache.__qualname__.__len__
# ()==9 but not the string equality invariant. Both the equality and length
# invariants are new to the extra45 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra45.lru_cache_qualname:
  description: "functools.lru_cache.__qualname__ == 'lru_cache' — pure-Python function defined at module level; __qualname__ == __name__ (no enclosing class scope); 9 chars"
  category: identity
  kind: python_call_eq
  function: lru_cache.__qualname__.__eq__
  args: ["lru_cache"]
  expected: true

invariant functools_extra45.lru_cache_qualname_len:
  description: "len(functools.lru_cache.__qualname__) == 9 — 'lru_cache'; same length as __name__ and __module__ ('functools'); three 9-char values coincide for lru_cache"
  category: string_properties
  kind: python_call_eq
  function: lru_cache.__qualname__.__len__
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# functools.cache identity metadata — extra45 namespace
#
# functools.cache.__name__ is 'cache' (5 chars), functools.cache.__qualname__
# is 'cache' (5 chars), and functools.cache.__module__ is 'functools' (9 chars).
# functools.cache is a simple wrapper around lru_cache(maxsize=None) defined
# at module level in Lib/functools.py. As a module-level function, __qualname__
# equals __name__. The module is 'functools' (9 chars). No prior functools spec
# records these three equality invariants for cache in the extra45 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra45.cache_name:
  description: "functools.cache.__name__ == 'cache' — thin lru_cache(maxsize=None) wrapper; pure-Python function; 5-char name"
  category: identity
  kind: python_call_eq
  function: cache.__name__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra45.cache_qualname:
  description: "functools.cache.__qualname__ == 'cache' — module-level function; __qualname__ == __name__ (no enclosing class scope); 5 chars"
  category: identity
  kind: python_call_eq
  function: cache.__qualname__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra45.cache_module:
  description: "functools.cache.__module__ == 'functools' — pure-Python function defined in Lib/functools.py; 9-char module name"
  category: module_metadata
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# functools.cached_property identity metadata — extra45 namespace
#
# functools.cached_property.__name__ is 'cached_property' (15 chars) and
# functools.cached_property.__module__ is 'functools' (9 chars). cached_property
# is a pure-Python descriptor class defined at module level in Lib/functools.py.
# Prior specs recorded cached_property.__name__.__len__()==15 and
# cached_property.__module__.__len__()==9, but not the string equality
# invariants. These two equality invariants are new to the extra45 namespace.
# ---------------------------------------------------------------------------

invariant functools_extra45.cached_property_name:
  description: "functools.cached_property.__name__ == 'cached_property' — pure-Python descriptor class; 15-char name; longest __name__ among the major functools objects"
  category: identity
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra45.cached_property_module:
  description: "functools.cached_property.__module__ == 'functools' — pure-Python class defined in Lib/functools.py; 9-char module name"
  category: module_metadata
  kind: python_call_eq
  function: cached_property.__module__.__eq__
  args: ["functools"]
  expected: true
