spec: asyncio_extra243
version: ">=3.4"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-sync.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — Python asyncio synchronization primitives documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec covers asyncio.Condition class identity and method name contracts."
    - "asyncio.Condition.__name__ == 'Condition' — 9 characters."
    - "asyncio.Condition.__module__ == 'asyncio.locks' — defined in the locks submodule (13 chars)."
    - "asyncio.Condition.__bases__[0].__name__ == '_ContextManagerMixin' — Condition inherits from _ContextManagerMixin."
    - "Condition.notify.__name__ == 'notify'; __qualname__ == 'Condition.notify' (16 chars)."
    - "Condition.notify_all.__name__ == 'notify_all'; __qualname__ == 'Condition.notify_all' (20 chars)."
    - "Condition.wait.__name__ == 'wait'; __qualname__ == 'Condition.wait' (14 chars)."
    - "Condition.wait_for.__name__ == 'wait_for'; __qualname__ == 'Condition.wait_for' (18 chars)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.Condition class identity contracts
#
# Verifies __name__, __module__ to confirm the class is defined in
# asyncio.locks and carries the expected identity attributes.
# ---------------------------------------------------------------------------

table asyncio_extra243.condition_class_identity:
  description: "asyncio.Condition class identity: name, module, lengths; new to extra243"
  kind: python_call_eq
  category: class_identity
  id_prefix: aiocond243

  columns: [id, function, args, expected, description]
  rows:
    - [cond_name_eq,
       Condition.__name__.__eq__,
       ["Condition"],
       true,
       "asyncio.Condition.__name__.__eq__('Condition') == True — class carries unqualified name; new to extra243"]
    - [cond_module_eq,
       Condition.__module__.__eq__,
       ["asyncio.locks"],
       true,
       "asyncio.Condition.__module__.__eq__('asyncio.locks') == True — Condition defined in asyncio.locks submodule; new to extra243"]
    - [cond_name_len_9,
       Condition.__name__.__len__,
       [],
       9,
       "asyncio.Condition.__name__.__len__() == 9 — 'Condition' has exactly 9 characters; new to extra243"]
    - [cond_module_len_13,
       Condition.__module__.__len__,
       [],
       13,
       "asyncio.Condition.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters; new to extra243"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.Condition base class contract
#
# Condition.__bases__[0].__name__ == '_ContextManagerMixin'.
# The function path contains '[' so must be double-quoted.
# ---------------------------------------------------------------------------

table asyncio_extra243.condition_base_class:
  description: "asyncio.Condition base class identity; new to extra243"
  kind: python_call_eq
  category: class_identity
  id_prefix: aiocond243b

  columns: [id, function, args, expected, description]
  rows:
    - [cond_base_name_eq,
       "Condition.__bases__[0].__name__.__eq__",
       ["_ContextManagerMixin"],
       true,
       "asyncio.Condition.__bases__[0].__name__.__eq__('_ContextManagerMixin') == True — Condition inherits from _ContextManagerMixin; new to extra243"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Condition method __name__ contracts
#
# notify, notify_all, wait, wait_for each carry their simple __name__.
# ---------------------------------------------------------------------------

table asyncio_extra243.condition_method_names:
  description: "asyncio.Condition method __name__ contracts; new to extra243"
  kind: python_call_eq
  category: method_names
  id_prefix: aiocondm243

  columns: [id, function, args, expected, description]
  rows:
    - [notify_name_eq,
       Condition.notify.__name__.__eq__,
       ["notify"],
       true,
       "asyncio.Condition.notify.__name__.__eq__('notify') == True — method carries its simple name; new to extra243"]
    - [notify_all_name_eq,
       Condition.notify_all.__name__.__eq__,
       ["notify_all"],
       true,
       "asyncio.Condition.notify_all.__name__.__eq__('notify_all') == True — method carries its simple name; new to extra243"]
    - [wait_name_eq,
       Condition.wait.__name__.__eq__,
       ["wait"],
       true,
       "asyncio.Condition.wait.__name__.__eq__('wait') == True — method carries its simple name; new to extra243"]
    - [wait_for_name_eq,
       Condition.wait_for.__name__.__eq__,
       ["wait_for"],
       true,
       "asyncio.Condition.wait_for.__name__.__eq__('wait_for') == True — method carries its simple name; new to extra243"]

# ---------------------------------------------------------------------------
# Table 4: asyncio.Condition method __qualname__ contracts
#
# notify, notify_all, wait, wait_for carry qualname 'Condition.<method>'.
# ---------------------------------------------------------------------------

table asyncio_extra243.condition_method_qualnames:
  description: "asyncio.Condition method __qualname__ contracts; new to extra243"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: aiocondm243

  columns: [id, function, args, expected, description]
  rows:
    - [notify_qualname_eq,
       Condition.notify.__qualname__.__eq__,
       ["Condition.notify"],
       true,
       "asyncio.Condition.notify.__qualname__ == 'Condition.notify' (16 chars); new to extra243"]
    - [notify_all_qualname_eq,
       Condition.notify_all.__qualname__.__eq__,
       ["Condition.notify_all"],
       true,
       "asyncio.Condition.notify_all.__qualname__ == 'Condition.notify_all' (20 chars); new to extra243"]
    - [wait_qualname_eq,
       Condition.wait.__qualname__.__eq__,
       ["Condition.wait"],
       true,
       "asyncio.Condition.wait.__qualname__ == 'Condition.wait' (14 chars); new to extra243"]
    - [wait_for_qualname_eq,
       Condition.wait_for.__qualname__.__eq__,
       ["Condition.wait_for"],
       true,
       "asyncio.Condition.wait_for.__qualname__ == 'Condition.wait_for' (18 chars); new to extra243"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra243
# ---------------------------------------------------------------------------

invariant asyncio_extra243.Condition.name:
  description: "asyncio.Condition.__name__ == 'Condition'; new to extra243"
  category: class_identity
  kind: python_call_eq
  function: Condition.__name__.__eq__
  args: ["Condition"]
  expected: true

invariant asyncio_extra243.Condition.module:
  description: "asyncio.Condition.__module__ == 'asyncio.locks'; new to extra243"
  category: class_identity
  kind: python_call_eq
  function: Condition.__module__.__eq__
  args: ["asyncio.locks"]
  expected: true

invariant asyncio_extra243.Condition.name_len:
  description: "asyncio.Condition.__name__.__len__() == 9 — 'Condition' has 9 characters; new to extra243"
  category: class_identity
  kind: python_call_eq
  function: Condition.__name__.__len__
  args: []
  expected: 9

invariant asyncio_extra243.Condition.module_len:
  description: "asyncio.Condition.__module__.__len__() == 13 — 'asyncio.locks' has 13 characters; new to extra243"
  category: class_identity
  kind: python_call_eq
  function: Condition.__module__.__len__
  args: []
  expected: 13

invariant asyncio_extra243.Condition.base_name:
  description: "asyncio.Condition.__bases__[0].__name__ == '_ContextManagerMixin' — inherits from _ContextManagerMixin; new to extra243"
  category: class_identity
  kind: python_call_eq
  function: "Condition.__bases__[0].__name__.__eq__"
  args: ["_ContextManagerMixin"]
  expected: true

