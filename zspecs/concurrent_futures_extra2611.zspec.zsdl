spec: concurrent_futures_extra2611
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "Wave 621 theme: __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks."
    - "concurrent.futures.Future defines __class_getitem__ in its own __dict__ (PEP 585 generic subscript support). ThreadPoolExecutor, ProcessPoolExecutor, and Executor do NOT define __class_getitem__ in their own __dict__."
    - "None of the concurrent.futures classes define __init_subclass__ or __subclasshook__ in their own __dict__. These are inherited from object."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __init_subclass__ dict-presence — concurrent.futures classes
#
# Future, ThreadPoolExecutor, ProcessPoolExecutor, and Executor none define
# __init_subclass__ in their own __dict__. Inherited from object.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2611.init_subclass_checks:
  description: "concurrent.futures classes do NOT define __init_subclass__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2611
  columns: [id, function, args, expected]
  rows:
    - ["cf2611001", "concurrent.futures.Future.__dict__.__contains__",               ["__init_subclass__"], false]
    - ["cf2611002", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",   ["__init_subclass__"], false]
    - ["cf2611003", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",  ["__init_subclass__"], false]
    - ["cf2611004", "concurrent.futures.Executor.__dict__.__contains__",             ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# __subclasshook__ dict-presence — concurrent.futures classes
#
# None of the concurrent.futures classes define __subclasshook__ in their
# own __dict__. Inherited from object.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2611.subclasshook_checks:
  description: "concurrent.futures classes do NOT define __subclasshook__ in their own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2611
  columns: [id, function, args, expected]
  rows:
    - ["cf2611005", "concurrent.futures.Future.__dict__.__contains__",               ["__subclasshook__"], false]
    - ["cf2611006", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",   ["__subclasshook__"], false]
    - ["cf2611007", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",  ["__subclasshook__"], false]
    - ["cf2611008", "concurrent.futures.Executor.__dict__.__contains__",             ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# __class_getitem__ dict-presence — concurrent.futures classes
#
# concurrent.futures.Future defines __class_getitem__ (PEP 585 support).
# ThreadPoolExecutor, ProcessPoolExecutor, and Executor do NOT.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2611.class_getitem_checks:
  description: "concurrent.futures.Future defines __class_getitem__; executors do not"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2611
  columns: [id, function, args, expected]
  rows:
    - ["cf2611009",  "concurrent.futures.Future.__dict__.__contains__",               ["__class_getitem__"], true]
    - ["cf2611010", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",   ["__class_getitem__"], false]
    - ["cf2611011", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",  ["__class_getitem__"], false]
    - ["cf2611012", "concurrent.futures.Executor.__dict__.__contains__",             ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Cross-checks: __init_subclass__ and __subclasshook__ absent from all four
#
# Consolidating the negative results into a single confirmation table:
# none of the four classes define either dunder in their own __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2611.combined_absent_checks:
  description: "Neither __init_subclass__ nor __subclasshook__ is in any cf class own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2611
  columns: [id, function, args, expected]
  rows:
    - ["cf2611013", "concurrent.futures.Future.__dict__.__contains__",               ["__init_subclass__"], false]
    - ["cf2611014", "concurrent.futures.Future.__dict__.__contains__",               ["__subclasshook__"],  false]
    - ["cf2611015", "concurrent.futures.Executor.__dict__.__contains__",             ["__init_subclass__"], false]
    - ["cf2611016", "concurrent.futures.Executor.__dict__.__contains__",             ["__subclasshook__"],  false]
    - ["cf2611017", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",   ["__init_subclass__"], false]
    - ["cf2611018", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",   ["__subclasshook__"],  false]
    - ["cf2611019", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",  ["__init_subclass__"], false]
    - ["cf2611020", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__",  ["__subclasshook__"],  false]
