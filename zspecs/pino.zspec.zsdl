spec: pino
version: ">=10.0.0"
backend: node(pino)

docs: https://getpino.io

provenance:
  derived_from:
    - "Pino docs — https://getpino.io"
    - "Test vectors verified with pino via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "pino source"
  notes:
    - "Very low overhead Node.js logger — JSON output, named log levels."
    - "Install: npm install pino"
    - "v10 CJS; the module export IS the logger factory; .levels exposes label↔value maps."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Factory throws on invalid options; logger methods never throw at the user level."
  stderr: "null"
  stickiness: "N/A — each logger independent."
  codes: {}

# Static level table
invariant pino.level_value_trace:
  description: "pino.levels.values.trace is 10"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "levels.values.trace"}
  expected: 10

invariant pino.level_value_debug:
  description: "pino.levels.values.debug is 20"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "levels.values.debug"}
  expected: 20

invariant pino.level_value_info:
  description: "pino.levels.values.info is 30"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "levels.values.info"}
  expected: 30

invariant pino.level_value_warn:
  description: "pino.levels.values.warn is 40"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "levels.values.warn"}
  expected: 40

invariant pino.level_value_error:
  description: "pino.levels.values.error is 50"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "levels.values.error"}
  expected: 50

invariant pino.level_value_fatal:
  description: "pino.levels.values.fatal is 60"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "levels.values.fatal"}
  expected: 60

invariant pino.label_30_is_info:
  description: "pino.levels.labels[30] is 'info'"
  category: levels
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "levels.labels.30"}
  expected: "info"

# Default logger has level 'info'
invariant pino.default_level_info:
  description: "pino().level is 'info'"
  category: state
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {get: level}
  expected: "info"

# Level filter: default logger does NOT log debug
invariant pino.default_filters_debug:
  description: "pino().isLevelEnabled('debug') is false"
  category: state
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {method: isLevelEnabled, args: ["debug"]}
  expected: false

invariant pino.default_passes_info:
  description: "pino().isLevelEnabled('info') is true"
  category: state
  kind: node_chain_eq
  entry: module
  entry_args: []
  chain:
    - {method: isLevelEnabled, args: ["info"]}
  expected: true

invariant pino.option_overrides_level:
  description: "pino({level:'debug'}).isLevelEnabled('debug') is true"
  category: options
  kind: node_chain_eq
  entry: module
  entry_args: [{level: "debug"}]
  chain:
    - {method: isLevelEnabled, args: ["debug"]}
  expected: true

invariant pino.option_overrides_level_value:
  description: "pino({level:'warn'}).level is 'warn'"
  category: options
  kind: node_chain_eq
  entry: module
  entry_args: [{level: "warn"}]
  chain:
    - {get: level}
  expected: "warn"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:42:28Z
  iterations: 1
  pass_count: 12
  fail_count: 0
  total_invariants: 12
  notes: Synthesis succeeded in 1 iteration(s). 12 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
