spec: hashlib_extra616
version: ">=3.9"
backend: python_module(hashlib)
docs: "https://docs.python.org/3/library/hashlib.html"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers pbkdf2_hmac and scrypt function identity, plus doc string class checks for common hash constructors"
  created_at: "2026-04-12T00:00:00Z"

table hashlib_extra616.pbkdf2_identity:
  description: "Identity checks for hashlib.pbkdf2_hmac"
  kind: python_call_eq
  category: function_identity
  id_prefix: hl616pb
  columns: [id, function, args, expected]
  rows:
    - [hl616pb001, hashlib.pbkdf2_hmac.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl616pb002, hashlib.pbkdf2_hmac.__name__.__eq__, ["pbkdf2_hmac"], true]
    - [hl616pb003, hashlib.pbkdf2_hmac.__doc__.__class__.__name__.__eq__, ["str"], true]

table hashlib_extra616.scrypt_identity:
  description: "Identity checks for hashlib.scrypt"
  kind: python_call_eq
  category: function_identity
  id_prefix: hl616ps
  columns: [id, function, args, expected]
  rows:
    - [hl616ps001, hashlib.scrypt.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [hl616ps002, hashlib.scrypt.__name__.__eq__, ["scrypt"], true]
    - [hl616ps003, hashlib.scrypt.__doc__.__class__.__name__.__eq__, ["str"], true]

table hashlib_extra616.hash_doc_types:
  description: "Doc string class checks for common hash constructors"
  kind: python_call_eq
  category: function_identity
  id_prefix: hl616dt
  columns: [id, function, args, expected]
  rows:
    - [hl616dt001, hashlib.md5.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl616dt002, hashlib.sha1.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl616dt003, hashlib.sha256.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl616dt004, hashlib.sha512.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl616dt005, hashlib.sha3_256.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [hl616dt006, hashlib.blake2b.__doc__.__class__.__name__.__eq__, ["str"], true]
