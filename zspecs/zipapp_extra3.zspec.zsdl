spec: zipapp_extra3
version: ">=3.9"
backend: python_module(zipapp)

docs: https://docs.python.org/3/library/zipapp.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zipapp.html — Python zipapp documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/zipapp.py"
  notes:
    - "This spec extends zipapp.zspec.zsdl, zipapp_extra.zspec.zsdl, and zipapp_extra2.zspec.zsdl."
    - "zipapp.zspec.zsdl covers: create_archive/__name__/type, get_interpreter/__name__/type, ZipAppError/__name__/__module__/base/type, issubclass."
    - "zipapp_extra.zspec.zsdl covers: create_archive/__name__/__qualname__/type, get_interpreter/__name__/__qualname__/type, ZipAppError/__name__/__module__/__qualname__/type/base."
    - "zipapp_extra2.zspec.zsdl covers: create_archive/__name__/__module__/__qualname__, get_interpreter/__name__/__module__/__qualname__, ZipAppError/__name__/__module__/base via __getitem__."
    - "This spec adds: create_archive/__doc__ class check (str), get_interpreter/__doc__ class check (str), ZipAppError/__doc__ class check (str), ZipAppError/__bases__/__len__ == 1 (exactly one base class)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function __doc__ type checks — create_archive and get_interpreter are documented
# (not covered in any prior zipapp spec; all three prior specs omit __doc__ checks)
# ---------------------------------------------------------------------------

table zipapp_extra3.function_docs:
  kind: python_call_eq
  category: functions
  id_prefix: doc

  columns: [id, function, args, expected]
  rows:
    - [create_archive,  create_archive.__doc__.__class__.__name__.__eq__,  ["str"], true]
    - [get_interpreter, get_interpreter.__doc__.__class__.__name__.__eq__, ["str"], true]

# ---------------------------------------------------------------------------
# ZipAppError.__doc__ — exception class has a docstring (str type)
# (not covered in any prior zipapp spec)
# ---------------------------------------------------------------------------

invariant zipapp_extra3.ZipAppError.has_doc:
  description: "zipapp.ZipAppError.__doc__.__class__.__name__ == 'str' — ZipAppError has a docstring"
  category: ZipAppError
  kind: python_call_eq
  function: ZipAppError.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# ZipAppError.__bases__ length — exactly one base class (ValueError)
# (not covered in any prior zipapp spec; prior specs only check _which_ base it is)
# ---------------------------------------------------------------------------

invariant zipapp_extra3.ZipAppError.bases_len:
  description: "zipapp.ZipAppError.__bases__.__len__() == 1 — ZipAppError has exactly one base class"
  category: ZipAppError
  kind: python_call_eq
  function: ZipAppError.__bases__.__len__
  args: []
  expected: 1
