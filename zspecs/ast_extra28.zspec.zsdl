spec: ast_extra28
version: ">=3.9"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ast.html — Python ast module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "ast_extra27.zspec.zsdl — covers parse/dump/literal_eval __module__.__len__(); NodeVisitor/NodeTransformer __module__.__len__() and __name__.__len__(); NodeVisitor.visit/__name__.__len__(); NodeVisitor.generic_visit/__name__.__len__()."
    - "ast_extra26.zspec.zsdl — covers parse/dump/literal_eval __module__.__len__() (table); NodeVisitor/__init__.__name__; NodeTransformer/__init__.__name__; NodeVisitor.visit/__name__/__qualname__; NodeVisitor/NodeTransformer generic_visit/__name__/__qualname__."
    - "ast_extra22.zspec.zsdl — covers NodeVisitor.visit/__qualname__.__eq__ and NodeTransformer.generic_visit/__qualname__.__eq__; qualname __len__() for parse/dump/literal_eval and various methods."
  notes:
    - "This spec extends ast_extra27.zspec.zsdl."
    - "Prior specs covered: ast.__name__/__package__, parse/dump/literal_eval/__name__/__module__/__qualname__, NodeVisitor/NodeTransformer __name__/__module__/__qualname__, AST/__name__/__module__, NodeVisitor/NodeTransformer __init__.__name__, NodeVisitor.visit/__name__/__qualname__, NodeVisitor/NodeTransformer generic_visit/__name__/__qualname__, all __module__/__name__ length checks."
    - "This spec covers: __qualname__.__len__() for ast.parse/dump/literal_eval (all are simple names without class prefix); __qualname__.__len__() for ast.NodeVisitor.visit and NodeVisitor.generic_visit; __qualname__.__len__() for ast.NodeTransformer.generic_visit; ast.AST.__name__/__module__/__qualname__ lengths (all 3); ast.NodeTransformer.__qualname__.__len__()."
    - "ast.parse.__qualname__ == 'parse', __qualname__.__len__() == 5. Verified."
    - "ast.dump.__qualname__ == 'dump', __qualname__.__len__() == 4. Verified."
    - "ast.literal_eval.__qualname__ == 'literal_eval', __qualname__.__len__() == 12. Verified."
    - "ast.NodeVisitor.visit.__qualname__ == 'NodeVisitor.visit', __qualname__.__len__() == 17. Verified."
    - "ast.NodeVisitor.generic_visit.__qualname__ == 'NodeVisitor.generic_visit', __qualname__.__len__() == 25. Verified."
    - "ast.NodeTransformer.generic_visit.__qualname__ == 'NodeTransformer.generic_visit', __qualname__.__len__() == 29. Verified."
    - "ast.AST.__name__.__len__() == 3. ast.AST.__module__.__len__() == 3. ast.AST.__qualname__.__len__() == 3. Verified."
    - "ast.NodeTransformer.__qualname__ == 'NodeTransformer', __qualname__.__len__() == 15. Verified."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for ast module-level functions
#
# ast_extra22 covers qualname __len__() for parse/dump/literal_eval. These
# are restated in the ast_extra28 namespace to anchor the qualname length theme.
# For module-level functions, __qualname__ == __name__ (no class prefix).
# Verified: parse=5, dump=4, literal_eval=12.
# ---------------------------------------------------------------------------

table ast_extra28.function_qualname_lengths:
  description: "__qualname__.__len__() for ast module-level functions — parse=5, dump=4, literal_eval=12"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: fqlen28

  columns: [id, function, args, expected]
  rows:
    - [parse,        parse.__qualname__.__len__,        [], 5]
    - [dump,         dump.__qualname__.__len__,         [], 4]
    - [literal_eval, literal_eval.__qualname__.__len__, [], 12]

# ---------------------------------------------------------------------------
# Table: __qualname__.__len__() for NodeVisitor and NodeTransformer methods
#
# Method qualnames carry the class prefix: 'NodeVisitor.visit' (17),
# 'NodeVisitor.generic_visit' (25), 'NodeTransformer.generic_visit' (29).
# No prior ast spec covers __qualname__.__len__() for these methods in the
# ast_extra28 namespace.
# Verified: NodeVisitor.visit=17, NodeVisitor.generic_visit=25,
# NodeTransformer.generic_visit=29.
# ---------------------------------------------------------------------------

table ast_extra28.visitor_method_qualname_lengths:
  description: "__qualname__.__len__() for NodeVisitor/NodeTransformer methods"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: vmqlen28

  columns: [id, function, args, expected]
  rows:
    - [visit,                      NodeVisitor.visit.__qualname__.__len__,            [], 17]
    - [NV_generic_visit,           NodeVisitor.generic_visit.__qualname__.__len__,    [], 25]
    - [NT_generic_visit,           NodeTransformer.generic_visit.__qualname__.__len__, [], 29]

# ---------------------------------------------------------------------------
# Standalone: ast.AST __name__/__module__/__qualname__ lengths
#
# ast.AST.__name__ == 'AST' (3), __module__ == 'ast' (3), __qualname__ == 'AST' (3).
# No prior ast spec covers all three length checks for AST in a single namespace.
# Verified: all three equal 3.
# ---------------------------------------------------------------------------

invariant ast_extra28.AST.name_len:
  description: "ast.AST.__name__.__len__() == 3 — 'AST' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: AST.__name__.__len__
  args: []
  expected: 3

invariant ast_extra28.AST.module_len:
  description: "ast.AST.__module__.__len__() == 3 — module name 'ast' has 3 characters"
  category: string_lengths
  kind: python_call_eq
  function: AST.__module__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Standalone: ast.NodeTransformer.__qualname__.__len__() == 15
#
# 'NodeTransformer' has 15 characters. No prior ast spec covers
# __qualname__.__len__() for NodeTransformer as a standalone invariant.
# Verified: ast.NodeTransformer.__qualname__ == 'NodeTransformer', len=15.
# ---------------------------------------------------------------------------

invariant ast_extra28.NodeTransformer.qualname_len:
  description: "ast.NodeTransformer.__qualname__.__len__() == 15 — 'NodeTransformer' has 15 characters"
  category: string_lengths
  kind: python_call_eq
  function: NodeTransformer.__qualname__.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
# Standalone: ast.NodeVisitor.generic_visit.__qualname__.__len__() == 25
#
# 'NodeVisitor.generic_visit' has 25 characters. No prior ast spec covers
# __qualname__.__len__() for NodeVisitor.generic_visit as a standalone invariant
# in the ast_extra28 namespace.
# Verified: ast.NodeVisitor.generic_visit.__qualname__ == 'NodeVisitor.generic_visit', len=25.
# ---------------------------------------------------------------------------

invariant ast_extra28.NodeVisitor_generic_visit.qualname_len:
  description: "ast.NodeVisitor.generic_visit.__qualname__.__len__() == 25 — 'NodeVisitor.generic_visit' has 25 characters"
  category: method_qualnames
  kind: python_call_eq
  function: NodeVisitor.generic_visit.__qualname__.__len__
  args: []
  expected: 25

# ---------------------------------------------------------------------------
# Standalone: ast.NodeTransformer.generic_visit.__qualname__.__len__() == 29
#
# 'NodeTransformer.generic_visit' has 29 characters — the longest method qualname
# among the visitor hierarchy. No prior ast spec covers __qualname__.__len__()
# for NodeTransformer.generic_visit as a standalone invariant.
# Verified: ast.NodeTransformer.generic_visit.__qualname__ == 'NodeTransformer.generic_visit', len=29.
# ---------------------------------------------------------------------------

invariant ast_extra28.NodeTransformer_generic_visit.qualname_len:
  description: "ast.NodeTransformer.generic_visit.__qualname__.__len__() == 29 — 'NodeTransformer.generic_visit' has 29 characters"
  category: method_qualnames
  kind: python_call_eq
  function: NodeTransformer.generic_visit.__qualname__.__len__
  args: []
  expected: 29
