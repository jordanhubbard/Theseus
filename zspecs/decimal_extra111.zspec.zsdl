spec: decimal_extra111
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec extends decimal_extra110.zspec.zsdl."
    - "This spec covers: decimal.Decimal reflected arithmetic and rounding dunder qualnames not previously covered."
    - "decimal_extra101 covered: __add__, __mul__, __sub__, __truediv__, __mod__, __neg__, __abs__, __pos__, __pow__ qualname equality."
    - "decimal_extra103 covered: __sub__, __abs__, __neg__, __pos__, __mod__, __pow__, __mul__, __floordiv__, __radd__ qualnames and types."
    - "This spec covers: __rsub__, __rmul__, __rmod__, __rpow__, __rtruediv__, __rfloordiv__, __rdivmod__, __divmod__, __ceil__, __floor__, __round__, __trunc__ — none previously covered in qualname context."
    - "All arithmetic dunders on Decimal are 'wrapper_descriptor' (C extension slot wrappers); __ceil__/__floor__/__round__/__trunc__ are 'method_descriptor'."
    - "Decimal.__rsub__.__qualname__ == 'Decimal.__rsub__' (len 16); type 'wrapper_descriptor'."
    - "Decimal.__rmul__.__qualname__ == 'Decimal.__rmul__' (len 16); type 'wrapper_descriptor'."
    - "Decimal.__rmod__.__qualname__ == 'Decimal.__rmod__' (len 16); type 'wrapper_descriptor'."
    - "Decimal.__rpow__.__qualname__ == 'Decimal.__rpow__' (len 16); type 'wrapper_descriptor'."
    - "Decimal.__rtruediv__.__qualname__ == 'Decimal.__rtruediv__' (len 20); type 'wrapper_descriptor'."
    - "Decimal.__rfloordiv__.__qualname__ == 'Decimal.__rfloordiv__' (len 21); type 'wrapper_descriptor'."
    - "Decimal.__divmod__.__qualname__ == 'Decimal.__divmod__' (len 18); type 'wrapper_descriptor'."
    - "Decimal.__rdivmod__.__qualname__ == 'Decimal.__rdivmod__' (len 19); type 'wrapper_descriptor'."
    - "Decimal.__ceil__.__qualname__ == 'Decimal.__ceil__' (len 16); type 'method_descriptor'."
    - "Decimal.__floor__.__qualname__ == 'Decimal.__floor__' (len 17); type 'method_descriptor'."
    - "Decimal.__round__.__qualname__ == 'Decimal.__round__' (len 17); type 'method_descriptor'."
    - "Decimal.__trunc__.__qualname__ == 'Decimal.__trunc__' (len 17); type 'method_descriptor'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Decimal reflected arithmetic dunders: __rsub__, __rmul__, __rmod__, __rpow__
# All four have qualname length 16 (same as __radd__ from decimal_extra103).
# All four are 'wrapper_descriptor' (C extension slot wrappers).
# The reflected (right-hand) operators are called when the left operand does not
# support the operation — they implement numeric coercion from the right side.
# None of these four dunders was covered in any prior decimal_extra spec.
# ---------------------------------------------------------------------------

table decimal_extra111.Decimal_reflected_r4_qualnames:
  description: "decimal.Decimal reflected operator qualnames: __rsub__='Decimal.__rsub__'(16), __rmul__='Decimal.__rmul__'(16), __rmod__='Decimal.__rmod__'(16), __rpow__='Decimal.__rpow__'(16); all type 'wrapper_descriptor'; all len=16"
  kind: python_call_eq
  category: qualnames
  id_prefix: decrfl111a

  columns: [id, function, args, expected, description]
  rows:
    - [rsub_type,    "Decimal.__rsub__.__class__.__name__.__eq__",   ["wrapper_descriptor"],  true,  "type(decimal.Decimal.__rsub__).__name__ == 'wrapper_descriptor' (C extension slot wrapper for reflected subtraction)"]
    - [rsub_qn_eq,   "Decimal.__rsub__.__qualname__.__eq__",         ["Decimal.__rsub__"],    true,  "decimal.Decimal.__rsub__.__qualname__ == 'Decimal.__rsub__' (16 chars; reflected subtraction operator)"]
    - [rsub_qn_len,  "Decimal.__rsub__.__qualname__.__len__",        [],                      16,    "decimal.Decimal.__rsub__.__qualname__.__len__() == 16 ('Decimal.__rsub__' has 16 chars; 'Decimal.'(8)+'__rsub__'(8)==16)"]
    - [rmul_type,    "Decimal.__rmul__.__class__.__name__.__eq__",   ["wrapper_descriptor"],  true,  "type(decimal.Decimal.__rmul__).__name__ == 'wrapper_descriptor' (C extension slot wrapper for reflected multiplication)"]
    - [rmul_qn_eq,   "Decimal.__rmul__.__qualname__.__eq__",         ["Decimal.__rmul__"],    true,  "decimal.Decimal.__rmul__.__qualname__ == 'Decimal.__rmul__' (16 chars; reflected multiplication operator)"]
    - [rmod_qn_eq,   "Decimal.__rmod__.__qualname__.__eq__",         ["Decimal.__rmod__"],    true,  "decimal.Decimal.__rmod__.__qualname__ == 'Decimal.__rmod__' (16 chars; reflected modulo operator)"]
    - [rpow_qn_eq,   "Decimal.__rpow__.__qualname__.__eq__",         ["Decimal.__rpow__"],    true,  "decimal.Decimal.__rpow__.__qualname__ == 'Decimal.__rpow__' (16 chars; reflected power operator)"]
    - [rsub_ne_rmul, "Decimal.__rsub__.__qualname__.__eq__",         ["Decimal.__rmul__"],    false, "decimal.Decimal.__rsub__.__qualname__ != 'Decimal.__rmul__' (distinct qualnames despite equal length 16; subtraction vs multiplication)"]
    - [rsub_eq_rmul_len, "Decimal.__rsub__.__qualname__.__len__.__eq__", [16],                true,  "len('Decimal.__rsub__') == len('Decimal.__rmul__') == len('Decimal.__rmod__') == len('Decimal.__rpow__') == 16"]

# ---------------------------------------------------------------------------
# decimal.Decimal __rtruediv__, __rfloordiv__, __divmod__, __rdivmod__ qualnames
# __rtruediv__: 'Decimal.__rtruediv__' (20 chars); type 'wrapper_descriptor'.
# __rfloordiv__: 'Decimal.__rfloordiv__' (21 chars); type 'wrapper_descriptor'.
# __divmod__: 'Decimal.__divmod__' (18 chars); type 'wrapper_descriptor'.
# __rdivmod__: 'Decimal.__rdivmod__' (19 chars); type 'wrapper_descriptor'.
# decimal_extra103 covered __floordiv__(20 chars) and __radd__(16 chars);
# decimal_extra101 covered __truediv__(19 chars) but NOT __rtruediv__.
# None of the four dunders in this table was covered in any prior decimal_extra spec.
# ---------------------------------------------------------------------------

table decimal_extra111.Decimal_division_divmod_qualnames:
  description: "decimal.Decimal __rtruediv__='Decimal.__rtruediv__'(20), __rfloordiv__='Decimal.__rfloordiv__'(21), __divmod__='Decimal.__divmod__'(18), __rdivmod__='Decimal.__rdivmod__'(19); all 'wrapper_descriptor'; __rfloordiv__ longest at 21"
  kind: python_call_eq
  category: qualnames
  id_prefix: decrfl111b

  columns: [id, function, args, expected, description]
  rows:
    - [rtdiv_type,      "Decimal.__rtruediv__.__class__.__name__.__eq__",   ["wrapper_descriptor"],   true,  "type(decimal.Decimal.__rtruediv__).__name__ == 'wrapper_descriptor' (C extension slot wrapper for reflected true division)"]
    - [rtdiv_qn_eq,     "Decimal.__rtruediv__.__qualname__.__eq__",         ["Decimal.__rtruediv__"], true,  "decimal.Decimal.__rtruediv__.__qualname__ == 'Decimal.__rtruediv__' (20 chars; reflected true division)"]
    - [rtdiv_qn_len,    "Decimal.__rtruediv__.__qualname__.__len__",        [],                        20,    "decimal.Decimal.__rtruediv__.__qualname__.__len__() == 20 ('Decimal.__rtruediv__' has 20 chars; 'Decimal.'(8)+'__rtruediv__'(12)==20)"]
    - [rfldiv_type,     "Decimal.__rfloordiv__.__class__.__name__.__eq__",  ["wrapper_descriptor"],   true,  "type(decimal.Decimal.__rfloordiv__).__name__ == 'wrapper_descriptor' (C extension slot wrapper for reflected floor division)"]
    - [rfldiv_qn_eq,    "Decimal.__rfloordiv__.__qualname__.__eq__",        ["Decimal.__rfloordiv__"], true, "decimal.Decimal.__rfloordiv__.__qualname__ == 'Decimal.__rfloordiv__' (21 chars; longest arithmetic dunder qualname on Decimal)"]
    - [rfldiv_qn_len,   "Decimal.__rfloordiv__.__qualname__.__len__",       [],                        21,    "decimal.Decimal.__rfloordiv__.__qualname__.__len__() == 21 ('Decimal.__rfloordiv__' has 21 chars; longest Decimal arithmetic dunder qualname)"]
    - [divmod_qn_eq,    "Decimal.__divmod__.__qualname__.__eq__",           ["Decimal.__divmod__"],   true,  "decimal.Decimal.__divmod__.__qualname__ == 'Decimal.__divmod__' (18 chars; returns (quotient, remainder) as a tuple)"]
    - [divmod_qn_len,   "Decimal.__divmod__.__qualname__.__len__",          [],                        18,    "decimal.Decimal.__divmod__.__qualname__.__len__() == 18 ('Decimal.__divmod__' has 18 chars; 'Decimal.'(8)+'__divmod__'(10)==18)"]
    - [rdivmod_qn_eq,   "Decimal.__rdivmod__.__qualname__.__eq__",          ["Decimal.__rdivmod__"],  true,  "decimal.Decimal.__rdivmod__.__qualname__ == 'Decimal.__rdivmod__' (19 chars; reflected divmod operator)"]
    - [rdivmod_qn_len,  "Decimal.__rdivmod__.__qualname__.__len__",         [],                        19,    "decimal.Decimal.__rdivmod__.__qualname__.__len__() == 19 ('Decimal.__rdivmod__' has 19 chars; one more than __divmod__ at 18)"]
    - [rfldiv_gt_rtdiv, "Decimal.__rfloordiv__.__qualname__.__len__.__gt__", [20],                    true,  "len('Decimal.__rfloordiv__') > len('Decimal.__rtruediv__') (21 > 20; __rfloordiv__ is the longest Decimal arithmetic dunder qualname)"]
    - [rtdiv_ne_rfldiv, "Decimal.__rtruediv__.__qualname__.__eq__",         ["Decimal.__rfloordiv__"], false, "decimal.Decimal.__rtruediv__.__qualname__ != 'Decimal.__rfloordiv__' (distinct qualnames; __rtruediv__(20) vs __rfloordiv__(21))"]

# ---------------------------------------------------------------------------
# decimal.Decimal rounding and truncation dunders: __ceil__, __floor__, __round__, __trunc__
# All four are 'method_descriptor' (not 'wrapper_descriptor') — they are defined
# as explicit C methods (not slot wrappers), implementing the math.ceil(), math.floor(),
# round(), and math.trunc() protocols.
# __ceil__: 'Decimal.__ceil__' (16 chars); type 'method_descriptor'.
# __floor__: 'Decimal.__floor__' (17 chars); type 'method_descriptor'.
# __round__: 'Decimal.__round__' (17 chars); type 'method_descriptor'.
# __trunc__: 'Decimal.__trunc__' (17 chars); type 'method_descriptor'.
# None of these four dunders was covered in any prior decimal_extra spec.
# ---------------------------------------------------------------------------

table decimal_extra111.Decimal_rounding_qualnames:
  description: "decimal.Decimal rounding dunders: __ceil__='Decimal.__ceil__'(16) method_descriptor; __floor__='Decimal.__floor__'(17), __round__='Decimal.__round__'(17), __trunc__='Decimal.__trunc__'(17) all method_descriptor; distinct from wrapper_descriptor arithmetic dunders"
  kind: python_call_eq
  category: qualnames
  id_prefix: decrnd111c

  columns: [id, function, args, expected, description]
  rows:
    - [ceil_type,     "Decimal.__ceil__.__class__.__name__.__eq__",   ["method_descriptor"],  true,  "type(decimal.Decimal.__ceil__).__name__ == 'method_descriptor' (C method, not wrapper_descriptor; implements math.ceil() protocol)"]
    - [ceil_qn_eq,    "Decimal.__ceil__.__qualname__.__eq__",         ["Decimal.__ceil__"],   true,  "decimal.Decimal.__ceil__.__qualname__ == 'Decimal.__ceil__' (16 chars; rounds toward positive infinity)"]
    - [ceil_qn_len,   "Decimal.__ceil__.__qualname__.__len__",        [],                     16,    "decimal.Decimal.__ceil__.__qualname__.__len__() == 16 ('Decimal.__ceil__' has 16 chars; 'Decimal.'(8)+'__ceil__'(8)==16)"]
    - [floor_type,    "Decimal.__floor__.__class__.__name__.__eq__",  ["method_descriptor"],  true,  "type(decimal.Decimal.__floor__).__name__ == 'method_descriptor' (C method; implements math.floor() protocol — rounds toward negative infinity)"]
    - [floor_qn_eq,   "Decimal.__floor__.__qualname__.__eq__",        ["Decimal.__floor__"],  true,  "decimal.Decimal.__floor__.__qualname__ == 'Decimal.__floor__' (17 chars; rounds toward negative infinity)"]
    - [floor_qn_len,  "Decimal.__floor__.__qualname__.__len__",       [],                     17,    "decimal.Decimal.__floor__.__qualname__.__len__() == 17 ('Decimal.__floor__' has 17 chars; 'Decimal.'(8)+'__floor__'(9)==17)"]
    - [round_qn_eq,   "Decimal.__round__.__qualname__.__eq__",        ["Decimal.__round__"],  true,  "decimal.Decimal.__round__.__qualname__ == 'Decimal.__round__' (17 chars; implements built-in round() with optional ndigits argument)"]
    - [round_qn_len,  "Decimal.__round__.__qualname__.__len__",       [],                     17,    "decimal.Decimal.__round__.__qualname__.__len__() == 17 ('Decimal.__round__' has 17 chars; same length as __floor__ and __trunc__)"]
    - [trunc_qn_eq,   "Decimal.__trunc__.__qualname__.__eq__",        ["Decimal.__trunc__"],  true,  "decimal.Decimal.__trunc__.__qualname__ == 'Decimal.__trunc__' (17 chars; implements math.trunc() — truncates toward zero)"]
    - [trunc_qn_len,  "Decimal.__trunc__.__qualname__.__len__",       [],                     17,    "decimal.Decimal.__trunc__.__qualname__.__len__() == 17 ('Decimal.__trunc__' has 17 chars; same length as __floor__ and __round__)"]
    - [floor_gt_ceil, "Decimal.__floor__.__qualname__.__len__.__gt__", [16],                  true,  "len('Decimal.__floor__') > len('Decimal.__ceil__') (17 > 16; __floor__ is one char longer than __ceil__ due to 'floor' vs 'ceil')"]
    - [floor_eq_trunc_len, "Decimal.__floor__.__qualname__.__len__.__eq__", [17],             true,  "len('Decimal.__floor__') == len('Decimal.__round__') == len('Decimal.__trunc__') == 17 (all three share qualname length 17)"]
    - [ceil_ne_floor, "Decimal.__ceil__.__qualname__.__eq__",         ["Decimal.__floor__"],  false, "decimal.Decimal.__ceil__.__qualname__ != 'Decimal.__floor__' (distinct qualnames; ceil(16) rounds up, floor(17) rounds down)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra111.Decimal.__rsub__qualname_eq:
  description: "decimal.Decimal.__rsub__.__qualname__ == 'Decimal.__rsub__' (length 16; type is 'wrapper_descriptor' — a C extension slot wrapper; __rsub__ implements right-hand subtraction: when Python evaluates 'other - decimal_value' and 'other' does not know how to subtract a Decimal, Python calls decimal_value.__rsub__(other); 'Decimal.'(8)+'__rsub__'(8)==16; shares qualname length 16 with __rmul__, __rmod__, __rpow__, __radd__ (covered in decimal_extra103), and __ceil__; no prior decimal spec covers __rsub__ in any qualname context)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__rsub__.__qualname__.__eq__"
  args: ["Decimal.__rsub__"]
  expected: true

invariant decimal_extra111.Decimal.__rfloordiv__qualname_eq:
  description: "decimal.Decimal.__rfloordiv__.__qualname__ == 'Decimal.__rfloordiv__' (length 21; type is 'wrapper_descriptor'; __rfloordiv__ is the reflected floor-division operator: when Python evaluates 'other // decimal_value' and 'other' cannot floor-divide by Decimal, Python calls decimal_value.__rfloordiv__(other); 'Decimal.'(8)+'__rfloordiv__'(13)==21; at 21 chars this is the longest arithmetic dunder qualname on Decimal, surpassing __rfloordiv__ only by comparison — __floordiv__(20) and __rtruediv__(20) are each one char shorter; no prior decimal spec covers __rfloordiv__)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__rfloordiv__.__qualname__.__eq__"
  args: ["Decimal.__rfloordiv__"]
  expected: true

invariant decimal_extra111.Decimal.__divmod__qualname_eq:
  description: "decimal.Decimal.__divmod__.__qualname__ == 'Decimal.__divmod__' (length 18; type is 'wrapper_descriptor'; __divmod__ implements the built-in divmod() function: divmod(a, b) returns the pair (a // b, a % b) as a tuple; 'Decimal.'(8)+'__divmod__'(10)==18; this is distinct from the reflected __rdivmod__(19); Decimal.__divmod__ computes both quotient and remainder in a single operation, which is more efficient than computing them separately; no prior decimal spec covers __divmod__ in any qualname context)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__divmod__.__qualname__.__eq__"
  args: ["Decimal.__divmod__"]
  expected: true

invariant decimal_extra111.Decimal.__ceil__qualname_eq:
  description: "decimal.Decimal.__ceil__.__qualname__ == 'Decimal.__ceil__' (length 16; type is 'method_descriptor' — NOT 'wrapper_descriptor'; this is significant because all the standard binary arithmetic operators on Decimal (__add__, __sub__, __mul__, etc.) are 'wrapper_descriptor', but the rounding protocol methods (__ceil__, __floor__, __round__, __trunc__) are 'method_descriptor'; __ceil__ implements math.ceil(decimal_value) which rounds toward positive infinity; 'Decimal.'(8)+'__ceil__'(8)==16; no prior decimal spec covers __ceil__)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__ceil__.__qualname__.__eq__"
  args: ["Decimal.__ceil__"]
  expected: true

invariant decimal_extra111.Decimal.__trunc__qualname_eq:
  description: "decimal.Decimal.__trunc__.__qualname__ == 'Decimal.__trunc__' (length 17; type is 'method_descriptor'; __trunc__ implements math.trunc(decimal_value) which truncates toward zero (removes the fractional part); 'Decimal.'(8)+'__trunc__'(9)==17; shares qualname length 17 with __floor__ and __round__; __ceil__(16) is one char shorter; the four rounding methods __ceil__/__floor__/__round__/__trunc__ are all 'method_descriptor' unlike the binary arithmetic operators which are 'wrapper_descriptor'; no prior decimal spec covers __trunc__)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.__trunc__.__qualname__.__eq__"
  args: ["Decimal.__trunc__"]
  expected: true

