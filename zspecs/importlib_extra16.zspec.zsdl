spec: importlib_extra16
version: ">=3.9"
backend: python_module(importlib)

docs: https://docs.python.org/3/library/importlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/importlib.html — Python importlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/importlib/__init__.py"
    - "importlib_extra5.zspec.zsdl — covers __qualname__ for util.find_spec/util.module_from_spec/util.spec_from_file_location and abc.Loader.__qualname__."
    - "importlib_extra8.zspec.zsdl — covers util.resolve_name.__qualname__; util.cache_from_source __name__/__module__."
    - "importlib_extra14.zspec.zsdl — covers util.cache_from_source/__qualname__ and util.source_from_cache/__qualname__."
    - "importlib_extra15.zspec.zsdl — covers __class__.__name__ and __class__.__qualname__ for abc.Loader/MetaPathFinder/PathEntryFinder (ABCMeta)."
  notes:
    - "This spec extends importlib.zspec.zsdl through importlib_extra15.zspec.zsdl."
    - "Focus: __module__ attributes for importlib top-level functions (import_module, reload) and util functions; __spec__.__class__ attributes for importlib and importlib.metadata; abc class __module__ attributes."
    - "importlib.import_module.__module__ == 'importlib' — top-level function belongs to its own package; not covered in any prior importlib spec."
    - "importlib.reload.__module__ == 'importlib' — top-level function belongs to its own package; not covered in any prior importlib spec."
    - "importlib.__spec__.__class__.__name__ == 'ModuleSpec' — importlib's module spec object is a ModuleSpec; not covered in any prior importlib spec."
    - "importlib.__spec__.__class__.__qualname__ == 'ModuleSpec' — qualname of ModuleSpec equals its name; not covered in any prior importlib spec."
    - "importlib.metadata.__spec__.__class__.__name__ == 'ModuleSpec' — importlib.metadata also uses ModuleSpec; not covered in any prior importlib spec."
    - "importlib.abc.Loader.__module__ == 'importlib._abc' — Loader lives in the private _abc submodule; not covered in any prior importlib spec."
    - "importlib.abc.MetaPathFinder.__module__ == 'importlib.abc' — MetaPathFinder lives in the abc submodule; not covered in any prior importlib spec."
    - "importlib.abc.PathEntryFinder.__module__ == 'importlib.abc' — PathEntryFinder lives in the abc submodule; not covered in any prior importlib spec."
    - "importlib.util.find_spec.__module__ == 'importlib.util' — defined in the util submodule; not covered in any prior importlib spec."
    - "importlib.util.module_from_spec.__module__ == '_frozen_importlib' — comes from the frozen bootstrap; not covered in any prior importlib spec."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# importlib top-level function __module__ attributes
#
# importlib_extra5 and importlib_extra8 cover __qualname__ for import_module
# and reload but no prior importlib spec checks their __module__ attribute.
# Both functions are defined directly in the importlib package, so their
# __module__ is 'importlib'.
# ---------------------------------------------------------------------------

table importlib_extra16.toplevel_function_modules:
  description: "__module__ for importlib.import_module and importlib.reload is 'importlib'"
  kind: python_call_eq
  category: function_attrs
  id_prefix: fmod16

  columns: [id, function, args, expected]
  rows:
    - [import_module, import_module.__module__.__eq__, ["importlib"], true]
    - [reload,        reload.__module__.__eq__,        ["importlib"], true]

# ---------------------------------------------------------------------------
# importlib.__spec__ class type attributes
#
# importlib.__spec__ is the ModuleSpec object describing the importlib package
# itself. No prior importlib spec checks __spec__.__class__.__name__ or
# __spec__.__class__.__qualname__. ModuleSpec is defined in _frozen_importlib
# but its __name__ and __qualname__ are both 'ModuleSpec'.
# ---------------------------------------------------------------------------

table importlib_extra16.spec_class_attrs:
  description: "__class__.__name__ and __class__.__qualname__ for importlib.__spec__ are both 'ModuleSpec'"
  kind: python_call_eq
  category: type_attrs
  id_prefix: specclass16

  columns: [id, function, args, expected]
  rows:
    - [spec_class_name,     __spec__.__class__.__name__.__eq__,     ["ModuleSpec"], true]
    - [spec_class_qualname, __spec__.__class__.__qualname__.__eq__,  ["ModuleSpec"], true]

# ---------------------------------------------------------------------------
# importlib.abc class __module__ attributes
#
# importlib_extra15 covers __class__.__name__ and __class__.__qualname__
# (the metaclass type) for all three abc classes. No prior importlib spec
# covers the classes' own __module__ attribute. Loader lives in the private
# importlib._abc submodule; MetaPathFinder and PathEntryFinder live in
# importlib.abc.
# ---------------------------------------------------------------------------

table importlib_extra16.abc_class_modules:
  description: "__module__ for importlib.abc abstract base classes"
  kind: python_call_eq
  category: module_attrs
  id_prefix: abcmod16

  columns: [id, function, args, expected]
  rows:
    - [Loader,          abc.Loader.__module__.__eq__,          ["importlib._abc"],  true]
    - [MetaPathFinder,  abc.MetaPathFinder.__module__.__eq__,  ["importlib.abc"],   true]
    - [PathEntryFinder, abc.PathEntryFinder.__module__.__eq__, ["importlib.abc"],   true]

# ---------------------------------------------------------------------------
# importlib.util function __module__ attributes
#
# importlib_extra5 covers util.find_spec/__qualname__. No prior importlib
# spec covers __module__ for util.find_spec or util.module_from_spec.
# find_spec is defined in importlib.util; module_from_spec comes from the
# frozen bootstrap (_frozen_importlib).
# ---------------------------------------------------------------------------

table importlib_extra16.util_function_modules:
  description: "__module__ for importlib.util functions"
  kind: python_call_eq
  category: function_attrs
  id_prefix: utilmod16

  columns: [id, function, args, expected]
  rows:
    - [find_spec,        util.find_spec.__module__.__eq__,        ["importlib.util"],       true]
    - [module_from_spec, util.module_from_spec.__module__.__eq__, ["_frozen_importlib"],     true]

# ---------------------------------------------------------------------------
# Standalone invariants — importlib top-level function modules
# ---------------------------------------------------------------------------

invariant importlib_extra16.import_module.module:
  description: "importlib.import_module.__module__ == 'importlib' — function belongs to the importlib package"
  category: function_attrs
  kind: python_call_eq
  function: import_module.__module__.__eq__
  args: ["importlib"]
  expected: true

invariant importlib_extra16.reload.module:
  description: "importlib.reload.__module__ == 'importlib' — function belongs to the importlib package"
  category: function_attrs
  kind: python_call_eq
  function: reload.__module__.__eq__
  args: ["importlib"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — __spec__ class type
# ---------------------------------------------------------------------------

invariant importlib_extra16.spec.class_name:
  description: "importlib.__spec__.__class__.__name__ == 'ModuleSpec' — module spec object type name"
  category: type_attrs
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant importlib_extra16.spec.class_qualname:
  description: "importlib.__spec__.__class__.__qualname__ == 'ModuleSpec' — module spec object type qualname equals name"
  category: type_attrs
  kind: python_call_eq
  function: __spec__.__class__.__qualname__.__eq__
  args: ["ModuleSpec"]
  expected: true

# ---------------------------------------------------------------------------
# Standalone invariants — abc.Loader module
# ---------------------------------------------------------------------------

invariant importlib_extra16.abc_Loader.module:
  description: "importlib.abc.Loader.__module__ == 'importlib._abc' — Loader is defined in the private _abc submodule"
  category: module_attrs
  kind: python_call_eq
  function: abc.Loader.__module__.__eq__
  args: ["importlib._abc"]
  expected: true
