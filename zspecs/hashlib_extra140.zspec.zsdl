spec: hashlib_extra140
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra139.zspec.zsdl — covers blake2b/blake2s instance method qualnames (__qualname__/__name__/__class__.__name__/__objclass__) / blake2b/blake2s __new__ identity (table + invariants)."
    - "hashlib_extra128.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from __qualname__ equality (struct context; not hashlib)."
    - "hashlib_extra126.zspec.zsdl — covers md5() instance method qualname equality and lengths / md5() instance attribute class names and values (table + invariants)."
    - "hashlib_extra125.zspec.zsdl — covers md5()/sha256()/sha1().__class__.__name__.__eq__('HASH') / md5() instance method __class__.__name__=='builtin_function_or_method' / md5() instance method qualnames (table + invariants)."
    - "hashlib_extra113.zspec.zsdl — covers HASH class-level getset_descriptor attributes (name/block_size/digest_size) qualnames and __objclass__ (table + invariants)."
    - "hashlib_extra110.zspec.zsdl — covers HASH.digest/copy qualname equality at class level / HASH instance method qualnames from sha256 instance (table + invariants)."
    - "hashlib_extra108.zspec.zsdl — covers HASH.update/__qualname__.__eq__('HASH.update') / HASH.hexdigest/__qualname__.__eq__('HASH.hexdigest') (table + invariants)."
    - "hashlib_extra107.zspec.zsdl — covers HASH type identity (__name__=='HASH', __module__=='_hashlib', __mro__.__len__()==2) / HASH method qualname lengths (table + invariants)."
    - "hashlib_extra103.zspec.zsdl — covers sha3_*/shake_* constructor __name__ equality and __name__.__len__() (table + invariants)."
    - "hashlib_extra98.zspec.zsdl — covers sha3_*/shake_* constructor __qualname__/__module__/__class__.__name__ equality (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in prior hashlib spec files."
    - "Wave 361 theme: HASH class-level method_descriptor __name__ equality / HASH method __objclass__.__name__ and __objclass__.__module__ / HASH.name getset_descriptor __name__ equality / HASH method __objclass__.__module__=='_hashlib' as unified anchor."
    - "HASH.copy.__name__ == 'copy'. The short method name without class prefix. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.digest.__name__ == 'digest'. Short method name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.hexdigest.__name__ == 'hexdigest'. Short method name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.update.__name__ == 'update'. Short method name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.copy.__class__.__name__ == 'method_descriptor'. All four HASH instance methods are method_descriptor at class level. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.copy.__objclass__.__name__ == 'HASH'. The owning class of the method_descriptor is HASH. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.copy.__objclass__.__module__ == '_hashlib'. All four HASH methods have __objclass__.__module__=='_hashlib'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.digest.__objclass__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.hexdigest.__objclass__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.update.__objclass__.__name__ == 'HASH'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.name.__name__ == 'name'. The getset_descriptor short attribute name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "HASH.name.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra107 anchors HASH type identity. extra108/110 anchor HASH method qualname equality (qualname not __name__). extra113 anchors getset_descriptor qualname equality for name/block_size/digest_size. This spec is the first to anchor HASH method_descriptor __name__ equality, HASH method __objclass__.__name__ and __objclass__.__module__ together under hashhash140."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HASH.copy.__name__.__eq__('copy')
# HASH.digest.__name__.__eq__('digest')
# HASH.hexdigest.__name__.__eq__('hexdigest')
# HASH.update.__name__.__eq__('update')
# HASH.copy.__class__.__name__.__eq__('method_descriptor')
#
# Wave 361 theme: HASH class-level method_descriptor __name__ equality.
#
# The HASH type from _hashlib.c is the concrete class returned by all
# OpenSSL-backed hash constructors (md5, sha1, sha256, sha3_256, etc.).
# At the class level, HASH.copy, HASH.digest, HASH.hexdigest, and HASH.update
# are method_descriptor objects. Their __name__ attribute is the short method
# name without the 'HASH.' class prefix — 'copy', 'digest', 'hexdigest',
# 'update'. This is analogous to struct.Struct.pack.__name__=='pack'
# (anchored in extra128) and blake2b.copy.__name__=='copy' (extra139).
# Prior hashlib specs anchor __qualname__ ('HASH.copy' etc.) but not __name__
# ('copy' etc.) for these class-level method_descriptors. Extra125 anchors
# __name__ for instance-bound methods at the instance level; this spec anchors
# class-level method_descriptor __name__ for the first time under hashhash140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra140.HASH_method_names:
  description: "HASH.copy/__name__.__eq__('copy')==True / HASH.digest/__name__.__eq__('digest')==True / HASH.hexdigest/__name__.__eq__('hexdigest')==True / HASH.update/__name__.__eq__('update')==True / HASH.copy/__class__/__name__.__eq__('method_descriptor')==True — class-level __name__ is short form without 'HASH.' prefix; extra107 anchors HASH type identity; extra108/110 anchor qualname equality (not __name__); first hashhash140 anchor for HASH method_descriptor __name__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashhash140

  columns: [id, function, args, expected, description]
  rows:
    - [hash_copy_name,      "sha256().__class__.copy.__name__.__eq__",      ["copy"],      true, "HASH.copy.__name__ is 'copy' (short form; qualname is 'HASH.copy' with class prefix)"]
    - [hash_digest_name,    "sha256().__class__.digest.__name__.__eq__",    ["digest"],    true, "HASH.digest.__name__ is 'digest' (returns raw bytes; short form of 'HASH.digest' qualname)"]
    - [hash_hexdigest_name, "sha256().__class__.hexdigest.__name__.__eq__", ["hexdigest"], true, "HASH.hexdigest.__name__ is 'hexdigest' (returns hex string; same logic as digest but hex-encoded)"]
    - [hash_update_name,    "sha256().__class__.update.__name__.__eq__",    ["update"],    true, "HASH.update.__name__ is 'update' (feeds data into the hash; callable multiple times)"]
    - [hash_copy_cls,       "sha256().__class__.copy.__class__.__name__.__eq__", ["method_descriptor"], true, "HASH.copy.__class__.__name__ is 'method_descriptor' (C-level method from _hashlib)"]

# ---------------------------------------------------------------------------
# HASH.copy.__objclass__.__name__.__eq__('HASH')
# HASH.copy.__objclass__.__module__.__eq__('_hashlib')
# HASH.digest.__objclass__.__name__.__eq__('HASH')
# HASH.hexdigest.__objclass__.__name__.__eq__('HASH')
# HASH.update.__objclass__.__name__.__eq__('HASH')
#
# Wave 361 theme: HASH method __objclass__ identity.
#
# The __objclass__ attribute of a method_descriptor reveals the class that
# defines (owns) the method. For all four HASH instance methods (copy,
# digest, hexdigest, update), __objclass__.__name__ is 'HASH' — the C-level
# class from _hashlib.c. __objclass__.__module__ is '_hashlib' (the C extension
# module). This confirms that all four methods are defined by HASH itself
# (not inherited from object), and all originate from the same C extension.
# Prior hashlib specs anchor getset_descriptor __objclass__ (extra113) and
# blake2b method __objclass__ (extra139), but not HASH method __objclass__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra140.HASH_method_objclass:
  description: "HASH.copy/__objclass__/__name__.__eq__('HASH')==True / HASH.copy/__objclass__/__module__.__eq__('_hashlib')==True / HASH.digest/__objclass__/__name__.__eq__('HASH')==True / HASH.hexdigest/__objclass__/__name__.__eq__('HASH')==True / HASH.update/__objclass__/__name__.__eq__('HASH')==True — all four HASH method_descriptors have __objclass__==HASH from _hashlib; analogous to blake2b method __objclass__ in extra139; first hashhash140 anchor for HASH method_descriptor __objclass__ identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashhash140

  columns: [id, function, args, expected, description]
  rows:
    - [copy_obj_name,      "sha256().__class__.copy.__objclass__.__name__.__eq__",      ["HASH"],     true, "HASH.copy.__objclass__.__name__ is 'HASH' (method is defined by HASH class, not inherited from object)"]
    - [copy_obj_mod,       "sha256().__class__.copy.__objclass__.__module__.__eq__",    ["_hashlib"], true, "HASH.copy.__objclass__.__module__ is '_hashlib' (C extension defining HASH type)"]
    - [digest_obj_name,    "sha256().__class__.digest.__objclass__.__name__.__eq__",    ["HASH"],     true, "HASH.digest.__objclass__.__name__ is 'HASH' (digest returns bytes; defined by HASH in _hashlib.c)"]
    - [hexdigest_obj_name, "sha256().__class__.hexdigest.__objclass__.__name__.__eq__", ["HASH"],     true, "HASH.hexdigest.__objclass__.__name__ is 'HASH' (hexdigest returns hex string; defined by HASH in _hashlib.c)"]
    - [update_obj_name,    "sha256().__class__.update.__objclass__.__name__.__eq__",    ["HASH"],     true, "HASH.update.__objclass__.__name__ is 'HASH' (update feeds data; defined by HASH in _hashlib.c)"]

# ---------------------------------------------------------------------------
# HASH.name.__name__.__eq__('name')
# HASH.name.__class__.__name__.__eq__('getset_descriptor')
# HASH.copy.__objclass__.__module__.__eq__('_hashlib')   [cross-check standalone]
# HASH.digest.__objclass__.__module__.__eq__('_hashlib')
# HASH.update.__objclass__.__module__.__eq__('_hashlib')
#
# Wave 361 theme: HASH.name descriptor __name__ and method __objclass__.__module__ cross-check.
#
# HASH.name is a getset_descriptor (PyGetSetDef-based C descriptor) whose __name__
# is 'name' — the short attribute name without the 'HASH.' prefix. Extra113 anchors
# HASH.name.__qualname__=='HASH.name' and HASH.name.__objclass__.__name__=='HASH',
# but not HASH.name.__name__ (the short form). By analogy with struct.Struct.size
# __name__=='size' (extra132) and blake2b.copy.__name__=='copy' (extra139), this
# spec anchors HASH.name.__name__=='name'. Also anchors that all four HASH
# method_descriptors share __objclass__.__module__=='_hashlib'.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra140.HASH_name_descriptor_and_method_module:
  description: "HASH.name/__name__.__eq__('name')==True / HASH.name/__class__/__name__.__eq__('getset_descriptor')==True / HASH.digest/__objclass__/__module__.__eq__('_hashlib')==True / HASH.hexdigest/__objclass__/__module__.__eq__('_hashlib')==True / HASH.update/__objclass__/__module__.__eq__('_hashlib')==True — HASH.name.__name__ is 'name' (short form; extra113 anchors qualname 'HASH.name' but not __name__); all four method_descriptor __objclass__.__module__=='_hashlib'; first hashhash140 anchor for HASH.name.__name__ and method __objclass__.__module__"
  kind: python_call_eq
  category: type_identity
  id_prefix: hashhash140

  columns: [id, function, args, expected, description]
  rows:
    - [name_desc_name,   "sha256().__class__.name.__name__.__eq__",                    ["name"],     true, "HASH.name.__name__ is 'name' (short descriptor name; extra113 anchors qualname 'HASH.name' with prefix)"]
    - [name_desc_cls,    "sha256().__class__.name.__class__.__name__.__eq__",           ["getset_descriptor"], true, "HASH.name.__class__.__name__ is 'getset_descriptor' (PyGetSetDef-based C descriptor from _hashlib)"]
    - [digest_obj_mod,   "sha256().__class__.digest.__objclass__.__module__.__eq__",    ["_hashlib"], true, "HASH.digest.__objclass__.__module__ is '_hashlib' (same C extension as copy/hexdigest/update)"]
    - [hexdig_obj_mod,   "sha256().__class__.hexdigest.__objclass__.__module__.__eq__", ["_hashlib"], true, "HASH.hexdigest.__objclass__.__module__ is '_hashlib' (all HASH method_descriptors from same _hashlib C extension)"]
    - [update_obj_mod,   "sha256().__class__.update.__objclass__.__module__.__eq__",    ["_hashlib"], true, "HASH.update.__objclass__.__module__ is '_hashlib' (all four HASH methods share same __objclass__.__module__)"]

# ---------------------------------------------------------------------------
# HASH.copy.__name__.__eq__('copy') — standalone
#
# HASH.copy.__name__ is 'copy'. The copy() method returns a new HASH object
# with the same state as the current hash, enabling multi-digest branching
# over a common prefix. At the class level (HASH.copy), it is a
# method_descriptor — the same mechanism as struct.Struct.pack and
# blake2b.copy. Its __name__ is 'copy' (4 chars), distinct from its
# __qualname__ 'HASH.copy' (9 chars). Extra107 anchors the qualname length
# (9). Extra108/110 anchor the qualname string equality. This is the first
# standalone for HASH.copy.__name__.__eq__('copy') under hashhash140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra140.HASH_copy_name:
  description: "HASH.copy.__name__.__eq__('copy') == True — copy() returns a new HASH with same state (enables multi-digest branching); method_descriptor from _hashlib; __name__ is short form 'copy' (4 chars) distinct from __qualname__ 'HASH.copy' (9 chars); extra107 anchors qualname length; extra108 anchors qualname equality; first standalone for HASH.copy.__name__.__eq__ under hashhash140"
  category: type_identity
  kind: python_call_eq
  function: "sha256().__class__.copy.__name__.__eq__"
  args: ["copy"]
  expected: true

# ---------------------------------------------------------------------------
# HASH.digest.__name__.__eq__('digest') — standalone
#
# HASH.digest.__name__ is 'digest'. The digest() method returns the current
# hash value as raw bytes. HASH.digest is a method_descriptor with __name__
# 'digest' (6 chars) and __qualname__ 'HASH.digest' (11 chars). Extra107
# anchors the qualname length (11). Extra108/110 anchor qualname string
# equality. The __name__ 'digest' (without 'HASH.' prefix) identifies the
# method by its def-statement name at the C level. This is the first
# standalone for HASH.digest.__name__.__eq__('digest') under hashhash140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra140.HASH_digest_name:
  description: "HASH.digest.__name__.__eq__('digest') == True — digest() returns current hash as raw bytes; method_descriptor from _hashlib; __name__ is 'digest' (6 chars) vs __qualname__ 'HASH.digest' (11 chars); extra107 anchors qualname length; extra108 anchors qualname equality; first standalone for HASH.digest.__name__.__eq__ under hashhash140"
  category: type_identity
  kind: python_call_eq
  function: "sha256().__class__.digest.__name__.__eq__"
  args: ["digest"]
  expected: true

# ---------------------------------------------------------------------------
# HASH.copy.__objclass__.__name__.__eq__('HASH') — standalone
#
# HASH.copy.__objclass__.__name__ is 'HASH'. The __objclass__ of a
# method_descriptor is the class that defines the method. For HASH.copy,
# the owning class is HASH (from _hashlib.c). This confirms that copy()
# is defined by the HASH class itself — not inherited from object. The
# __objclass__ pattern is identical to blake2b.copy.__objclass__.__name__==
# 'blake2b' (anchored in extra139) and struct.Struct.pack.__objclass__.__name__==
# 'Struct' (anchored in extra128). Extra113 anchors __objclass__.__name__ for
# getset_descriptors (name/block_size/digest_size), not for method_descriptors.
# This is the first standalone for HASH.copy.__objclass__.__name__.__eq__('HASH')
# under hashhash140. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra140.HASH_copy_objclass_name:
  description: "HASH.copy.__objclass__.__name__.__eq__('HASH') == True — __objclass__ is the HASH class itself (method defined by HASH, not inherited from object); analogous to blake2b.copy.__objclass__.__name__=='blake2b' (extra139) and Struct.pack.__objclass__.__name__=='Struct' (extra128); extra113 anchors getset_descriptor __objclass__ only; first standalone for HASH.copy.__objclass__.__name__.__eq__ under hashhash140"
  category: type_identity
  kind: python_call_eq
  function: "sha256().__class__.copy.__objclass__.__name__.__eq__"
  args: ["HASH"]
  expected: true

# ---------------------------------------------------------------------------
# HASH.copy.__objclass__.__module__.__eq__('_hashlib') — standalone
#
# HASH.copy.__objclass__.__module__ is '_hashlib'. All four HASH
# method_descriptors (copy, digest, hexdigest, update) share the same
# __objclass__.__module__: '_hashlib'. This is the C extension module that
# implements the HASH type. The leading underscore signals it is a private
# CPython implementation module (not the public 'hashlib' module). This
# parallels struct.Struct.pack.__objclass__.__module__=='_struct' (extra132)
# and blake2b.copy.__objclass__.__module__=='_blake2' (extra139). No prior
# hashlib spec anchors HASH method __objclass__.__module__ as a standalone
# under hashhash140. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra140.HASH_copy_objclass_module:
  description: "HASH.copy.__objclass__.__module__.__eq__('_hashlib') == True — __objclass__.__module__ is '_hashlib' (private C extension implementing HASH; leading underscore signals private implementation); parallels _struct for Struct and _blake2 for blake2b; first standalone for HASH.copy.__objclass__.__module__.__eq__ under hashhash140"
  category: type_identity
  kind: python_call_eq
  function: "sha256().__class__.copy.__objclass__.__module__.__eq__"
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# HASH.name.__name__.__eq__('name') — standalone
#
# HASH.name.__name__ is 'name'. HASH.name is a getset_descriptor providing
# read access to the hash algorithm's name string (e.g., 'sha256', 'md5',
# 'sha3_256'). At the class level (HASH.name), its __name__ attribute is
# 'name' — the short descriptor name without the 'HASH.' class prefix.
# Extra113 anchors HASH.name.__qualname__=='HASH.name' and its __objclass__,
# but not the short __name__. This is analogous to struct.Struct.format
# __name__=='format' (extra132). No prior hashlib spec anchors
# HASH.name.__name__.__eq__('name') as a standalone under hashhash140.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra140.HASH_name_descriptor_name:
  description: "HASH.name.__name__.__eq__('name') == True — HASH.name is a getset_descriptor providing the algorithm name string ('sha256', 'md5', etc.); __name__ is short form 'name' (4 chars) vs __qualname__ 'HASH.name' (9 chars); extra113 anchors qualname but not __name__; analogous to Struct.format.__name__=='format' (extra132); first standalone for HASH.name.__name__.__eq__ under hashhash140"
  category: type_identity
  kind: python_call_eq
  function: "sha256().__class__.name.__name__.__eq__"
  args: ["name"]
  expected: true
