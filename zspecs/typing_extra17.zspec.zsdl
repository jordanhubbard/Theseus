spec: typing_extra17
version: ">=3.9"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html — Python typing module documentation"
    - "PEP 484 — Type Hints"
    - "PEP 612 — Parameter Specification Variables"
    - "PEP 646 — Variadic Generics"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "This spec extends typing.zspec.zsdl through typing_extra16.zspec.zsdl."
    - "typing_extra16 covers: Literal/__name__; Final/__name__; Annotated/__name__; TypeGuard/__name__; special form __module__ table; special form __qualname__ table; runtime_checkable/__qualname__."
    - "typing_extra15 covers: TypeVar/__bases__ len/[0]; Protocol __name__/__module__/__qualname__; NamedTuple/__name__; TypedDict/__name__; get_args/__qualname__; get_origin/__qualname__; cast/__qualname__."
    - "typing_extra13 covers: overload/__module__/__qualname__; runtime_checkable/__module__; ParamSpec/__module__."
    - "typing_extra3 covers: ParamSpec/__name__/__module__/__qualname__."
    - "NOT yet covered: typing.TypeVar.__name__.__len__() == 7 — string length of 'TypeVar'."
    - "NOT yet covered: typing.ParamSpec.__name__.__len__() == 9 — string length of 'ParamSpec'."
    - "NOT yet covered: typing.TypeVarTuple.__name__.__len__() == 12 — string length of 'TypeVarTuple'."
    - "NOT yet covered: typing.Protocol.__name__.__len__() == 8 — string length of 'Protocol'."
    - "NOT yet covered: typing.TypeVarTuple.__mro__.__len__() == 2 — TypeVarTuple has two MRO entries."
    - "NOT yet covered: typing.TypeVarTuple.__mro__[0].__name__ == 'TypeVarTuple' — MRO self-identity."
    - "NOT yet covered: typing.TypeVarTuple.__mro__[1].__name__ == 'object' — last MRO entry."
    - "NOT yet covered: typing.TypeVarTuple.__bases__.__len__() == 1 — TypeVarTuple has one direct base."
    - "NOT yet covered: typing.ParamSpec.__mro__[0].__name__ == 'ParamSpec' — MRO self-identity."
    - "NOT yet covered: typing.ParamSpec.__mro__[1].__name__ == 'object' — last MRO entry."
    - "NOT yet covered: typing.Protocol.__bases__[0].__name__ == 'Generic' — Protocol's direct base."
    - "NOT yet covered: typing.get_type_hints.__qualname__.__len__() == 14 — qualname length."
    - "typing.TypeVar.__name__.__len__() == 7."
    - "typing.ParamSpec.__name__.__len__() == 9."
    - "typing.TypeVarTuple.__name__.__len__() == 12."
    - "typing.Protocol.__name__.__len__() == 8."
    - "typing.TypeVarTuple.__mro__.__len__() == 2."
    - "typing.TypeVarTuple.__mro__[0].__name__ == 'TypeVarTuple'."
    - "typing.TypeVarTuple.__mro__[1].__name__ == 'object'."
    - "typing.TypeVarTuple.__bases__.__len__() == 1."
    - "typing.ParamSpec.__mro__[0].__name__ == 'ParamSpec'."
    - "typing.ParamSpec.__mro__[1].__name__ == 'object'."
    - "typing.Protocol.__bases__[0].__name__ == 'Generic'."
    - "typing.get_type_hints.__qualname__.__len__() == 14."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# TypeVar, ParamSpec, TypeVarTuple, Protocol — __name__ string lengths
#
# Prior specs cover __name__.__eq__ for all four. No prior spec checks
# __name__.__len__() for any of them.
# ---------------------------------------------------------------------------

table typing_extra17.typevar_name_lengths:
  kind: python_call_eq
  category: class_names
  id_prefix: namelen

  columns: [id, function, args, expected]
  rows:
    - [TypeVar,       TypeVar.__name__.__len__,       [], 7]
    - [ParamSpec,     ParamSpec.__name__.__len__,     [], 9]
    - [TypeVarTuple,  TypeVarTuple.__name__.__len__,  [], 12]
    - [Protocol,      Protocol.__name__.__len__,      [], 8]

# ---------------------------------------------------------------------------
# TypeVarTuple __mro__ — length and entries
#
# No prior spec checks TypeVarTuple.__mro__.__len__() or the individual
# MRO entries. TypeVarTuple is a top-level class with MRO [TypeVarTuple, object].
# ---------------------------------------------------------------------------

invariant typing_extra17.TypeVarTuple.mro_len:
  description: "typing.TypeVarTuple.__mro__.__len__() == 2 — TypeVarTuple has exactly two MRO entries"
  category: class_hierarchy
  kind: python_call_eq
  function: TypeVarTuple.__mro__.__len__
  args: []
  expected: 2

invariant typing_extra17.TypeVarTuple.mro_first:
  description: "typing.TypeVarTuple.__mro__[0].__name__ == 'TypeVarTuple' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: TypeVarTuple.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "TypeVarTuple"

invariant typing_extra17.TypeVarTuple.mro_last:
  description: "typing.TypeVarTuple.__mro__[1].__name__ == 'object' — second MRO entry is object"
  category: class_hierarchy
  kind: python_call_eq
  function: TypeVarTuple.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# TypeVarTuple __bases__ length
#
# No prior spec checks TypeVarTuple.__bases__.__len__(). TypeVarTuple has
# one direct base (object).
# ---------------------------------------------------------------------------

invariant typing_extra17.TypeVarTuple.bases_len:
  description: "typing.TypeVarTuple.__bases__.__len__() == 1 — TypeVarTuple has one direct base (object)"
  category: class_hierarchy
  kind: python_call_eq
  function: TypeVarTuple.__bases__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# ParamSpec __mro__ — self-identity and last entry
#
# typing_extra3 covers ParamSpec.__name__/__module__/__qualname__.
# No prior spec checks ParamSpec.__mro__ entries. ParamSpec has two MRO
# entries: [ParamSpec, object].
# ---------------------------------------------------------------------------

invariant typing_extra17.ParamSpec.mro_first:
  description: "typing.ParamSpec.__mro__[0].__name__ == 'ParamSpec' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: ParamSpec.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "ParamSpec"

invariant typing_extra17.ParamSpec.mro_last:
  description: "typing.ParamSpec.__mro__[1].__name__ == 'object' — second MRO entry is object"
  category: class_hierarchy
  kind: python_call_eq
  function: ParamSpec.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Protocol __bases__[0].__name__ == 'Generic'
#
# typing_extra15 covers Protocol.__bases__.__len__() (via __bases__ section),
# and __module__/__qualname__. No prior spec checks Protocol.__bases__[0].__name__.
# Protocol's single direct base is Generic.
# ---------------------------------------------------------------------------

invariant typing_extra17.Protocol.base0_is_Generic:
  description: "typing.Protocol.__bases__[0].__name__ == 'Generic' — Protocol's only direct base is Generic"
  category: class_hierarchy
  kind: python_call_eq
  function: Protocol.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Generic"

# ---------------------------------------------------------------------------
# get_type_hints __qualname__ string length
#
# typing_extra16 covers get_type_hints.__name__ and __module__ as standalone
# invariants. No prior spec checks get_type_hints.__qualname__.__len__().
# 'get_type_hints' is 14 characters; qualname equals name for a top-level fn.
# ---------------------------------------------------------------------------

invariant typing_extra17.get_type_hints.qualname_len:
  description: "typing.get_type_hints.__qualname__.__len__() == 14 — 'get_type_hints' is 14 characters"
  category: qualnames
  kind: python_call_eq
  function: get_type_hints.__qualname__.__len__
  args: []
  expected: 14
