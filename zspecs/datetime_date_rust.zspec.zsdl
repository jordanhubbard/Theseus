spec: datetime_date_rust
version: ">=3.9"
backend: rust_module(datetime_date_rust)

docs: https://docs.python.org/3/library/datetime.html#datetime.date

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime documentation"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
  notes:
    - "Python datetime.date class methods (complements datetime_rust which uses wrapper functions)."
    - "date(2026, 4, 19).weekday() == 6 — Sunday (0=Mon, 6=Sun)."
    - "date(2024, 1, 1).weekday() == 0 — Monday."
    - "date(2024, 2, 29).weekday() == 3 — Thursday (2024 is a leap year)."
    - "date(2026, 4, 19).isoformat() == '2026-04-19'."
    - "date(2026, 4, 19).year == 2026, .month == 4, .day == 19."
    - "date(2026, 4, 19).strftime('%Y/%m/%d') == '2026/04/19'."
    - "All test vectors verified against Python 3.14.3 datetime module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# date.weekday — day of week (0=Mon, 6=Sun)
table datetime_date_rust.weekday.vectors:
  kind: python_call_eq
  category: weekday
  id_prefix: dd_wd
  function: date
  method: weekday
  method_args: []

  columns: [id, args, expected]
  rows:
    - [sunday,   [2026, 4, 19], 6]
    - [monday,   [2024, 1, 1],  0]
    - [thursday, [2024, 2, 29], 3]
    - [wednesday,[2026, 4, 22], 2]

# date.isoformat — ISO 8601 string
table datetime_date_rust.isoformat.vectors:
  kind: python_call_eq
  category: isoformat
  id_prefix: dd_iso
  function: date
  method: isoformat
  method_args: []

  columns: [id, args, expected]
  rows:
    - [today_2026, [2026, 4, 19], "2026-04-19"]
    - [leap_day,   [2024, 2, 29], "2024-02-29"]
    - [new_year,   [2000, 1, 1],  "2000-01-01"]

# date properties — year, month, day
table datetime_date_rust.properties.vectors:
  kind: python_call_eq
  category: properties
  id_prefix: dd_prop

  columns: [id, function, args, method, expected]
  rows:
    - [year_2026,  date, [2026, 4, 19], year,  2026]
    - [month_4,    date, [2026, 4, 19], month, 4]
    - [day_19,     date, [2026, 4, 19], day,   19]
    - [year_2000,  date, [2000, 1, 1],  year,  2000]
    - [month_12,   date, [1999, 12, 31], month, 12]

# date.strftime — format as string
invariant datetime_date_rust.strftime.slash_format:
  description: "date(2026, 4, 19).strftime('%Y/%m/%d') == '2026/04/19'"
  category: strftime
  kind: python_call_eq
  function: date
  args: [2026, 4, 19]
  method: strftime
  method_args: ["%Y/%m/%d"]
  expected: "2026/04/19"

invariant datetime_date_rust.strftime.dot_format:
  description: "date(2026, 4, 19).strftime('%d.%m.%Y') == '19.04.2026'"
  category: strftime
  kind: python_call_eq
  function: date
  args: [2026, 4, 19]
  method: strftime
  method_args: ["%d.%m.%Y"]
  expected: "19.04.2026"

