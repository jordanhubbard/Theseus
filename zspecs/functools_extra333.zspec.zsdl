spec: functools_extra333
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.total_ordering — identity and doc properties
# ---------------------------------------------------------------------------

invariant functools_extra333.total_ordering.__name__:
  description: "functools.total_ordering.__name__ == 'total_ordering'"
  category: identity
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra333.total_ordering.__module__:
  description: "functools.total_ordering.__module__ == 'functools'"
  category: identity
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra333.total_ordering.__class__.__name__:
  description: "functools.total_ordering.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: total_ordering.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra333.total_ordering.__doc__.__class__.__name__:
  description: "functools.total_ordering.__doc__.__class__.__name__ == 'str'"
  category: identity
  kind: python_call_eq
  function: total_ordering.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant functools_extra333.total_ordering.__doc__.__len__:
  description: "functools.total_ordering.__doc__.__len__() == 54"
  category: identity
  kind: python_call_eq
  function: total_ordering.__doc__.__len__
  args: []
  expected: 54

# ---------------------------------------------------------------------------
# functools.update_wrapper — identity
# ---------------------------------------------------------------------------

invariant functools_extra333.update_wrapper.__name__:
  description: "functools.update_wrapper.__name__ == 'update_wrapper'"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__name__.__eq__
  args: ["update_wrapper"]
  expected: true

invariant functools_extra333.update_wrapper.__module__:
  description: "functools.update_wrapper.__module__ == 'functools'"
  category: identity
  kind: python_call_eq
  function: update_wrapper.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# functools.wraps — identity
# ---------------------------------------------------------------------------

invariant functools_extra333.wraps.__name__:
  description: "functools.wraps.__name__ == 'wraps'"
  category: identity
  kind: python_call_eq
  function: wraps.__name__.__eq__
  args: ["wraps"]
  expected: true

invariant functools_extra333.wraps.__module__:
  description: "functools.wraps.__module__ == 'functools'"
  category: identity
  kind: python_call_eq
  function: wraps.__module__.__eq__
  args: ["functools"]
  expected: true

# ---------------------------------------------------------------------------
# Table: module affiliation for all three functions
# ---------------------------------------------------------------------------

table functools_extra333.function_modules:
  kind: python_call_eq
  category: identity
  id_prefix: fmod

  columns: [id, function, args, expected]
  rows:
    - [total_ordering,  total_ordering.__module__.__eq__,  ["functools"], true]
    - [update_wrapper,  update_wrapper.__module__.__eq__,  ["functools"], true]
    - [wraps,           wraps.__module__.__eq__,           ["functools"], true]
