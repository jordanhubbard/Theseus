spec: contextlib_extra12
version: ">=3.10"
backend: python_module(contextlib)

docs: https://docs.python.org/3/library/contextlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/contextlib.html — Python contextlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/contextlib.py"
  notes:
    - "This spec extends contextlib.zspec.zsdl through contextlib_extra11.zspec.zsdl and contextlib_suppress.zspec.zsdl."
    - "contextlib_extra8 covers: redirect_stdout/__module__ and redirect_stderr/__module__."
    - "contextlib_extra11 covers: redirect_stdout/__name__ and redirect_stderr/__name__ as standalone invariants; redirect_stdout/__qualname__ and redirect_stderr/__qualname__."
    - "NOT yet covered: contextmanager/__name__ == 'contextmanager' as standalone invariant."
    - "NOT yet covered: asynccontextmanager/__name__ == 'asynccontextmanager' as standalone invariant."
    - "NOT yet covered: closing/__name__ == 'closing' as standalone invariant (extra names confirmed via table in earlier specs)."
    - "NOT yet covered: nullcontext/__name__ == 'nullcontext' as standalone invariant."
    - "NOT yet covered: suppress/__name__ == 'suppress' as standalone invariant."
    - "NOT yet covered: ExitStack/__name__ == 'ExitStack' as standalone invariant."
    - "NOT yet covered: AsyncExitStack/__name__ == 'AsyncExitStack' as standalone invariant."
    - "NOT yet covered: AbstractContextManager/__name__ == 'AbstractContextManager' as standalone invariant."
    - "NOT yet covered: AbstractAsyncContextManager/__name__ == 'AbstractAsyncContextManager' as standalone invariant."
    - "NOT yet covered: contextmanager/__module__ == 'contextlib' as standalone invariant."
    - "NOT yet covered: ExitStack/__module__ == 'contextlib' as standalone invariant."
    - "contextlib.contextmanager is a function (decorator factory); __name__ == 'contextmanager'."
    - "contextlib.asynccontextmanager is a function (decorator factory); __name__ == 'asynccontextmanager'."
    - "contextlib.closing.__name__ == 'closing' — closing is a class."
    - "contextlib.nullcontext.__name__ == 'nullcontext' — nullcontext is a class."
    - "contextlib.suppress.__name__ == 'suppress' — suppress is a class."
    - "contextlib.ExitStack.__name__ == 'ExitStack' — ExitStack is a class."
    - "contextlib.AsyncExitStack.__name__ == 'AsyncExitStack' — AsyncExitStack is a class."
    - "contextlib.AbstractContextManager.__name__ == 'AbstractContextManager' — ABC class."
    - "contextlib.AbstractAsyncContextManager.__name__ == 'AbstractAsyncContextManager' — ABC class."
    - "contextlib.contextmanager.__module__ == 'contextlib'."
    - "contextlib.ExitStack.__module__ == 'contextlib'."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__ checks — function and class name invariants
#
# contextlib_extra11 covers redirect_stdout/__name__ and redirect_stderr/__name__
# as standalone invariants. Prior specs cover various __name__ values via table
# rows and other forms. This spec adds the remaining names not previously
# expressed as standalone invariants using the function: X.__name__.__eq__ pattern.
# ---------------------------------------------------------------------------

invariant contextlib_extra12.contextmanager.name:
  description: "contextlib.contextmanager.__name__ == 'contextmanager'"
  category: function_names
  kind: python_call_eq
  function: contextmanager.__name__.__eq__
  args: ["contextmanager"]
  expected: true

invariant contextlib_extra12.asynccontextmanager.name:
  description: "contextlib.asynccontextmanager.__name__ == 'asynccontextmanager'"
  category: function_names
  kind: python_call_eq
  function: asynccontextmanager.__name__.__eq__
  args: ["asynccontextmanager"]
  expected: true

invariant contextlib_extra12.closing.name:
  description: "contextlib.closing.__name__ == 'closing'"
  category: class_names
  kind: python_call_eq
  function: closing.__name__.__eq__
  args: ["closing"]
  expected: true

invariant contextlib_extra12.nullcontext.name:
  description: "contextlib.nullcontext.__name__ == 'nullcontext'"
  category: class_names
  kind: python_call_eq
  function: nullcontext.__name__.__eq__
  args: ["nullcontext"]
  expected: true

invariant contextlib_extra12.suppress.name:
  description: "contextlib.suppress.__name__ == 'suppress'"
  category: class_names
  kind: python_call_eq
  function: suppress.__name__.__eq__
  args: ["suppress"]
  expected: true

invariant contextlib_extra12.ExitStack.name:
  description: "contextlib.ExitStack.__name__ == 'ExitStack'"
  category: class_names
  kind: python_call_eq
  function: ExitStack.__name__.__eq__
  args: ["ExitStack"]
  expected: true

invariant contextlib_extra12.AsyncExitStack.name:
  description: "contextlib.AsyncExitStack.__name__ == 'AsyncExitStack'"
  category: class_names
  kind: python_call_eq
  function: AsyncExitStack.__name__.__eq__
  args: ["AsyncExitStack"]
  expected: true

invariant contextlib_extra12.AbstractContextManager.name:
  description: "contextlib.AbstractContextManager.__name__ == 'AbstractContextManager'"
  category: class_names
  kind: python_call_eq
  function: AbstractContextManager.__name__.__eq__
  args: ["AbstractContextManager"]
  expected: true

invariant contextlib_extra12.AbstractAsyncContextManager.name:
  description: "contextlib.AbstractAsyncContextManager.__name__ == 'AbstractAsyncContextManager'"
  category: class_names
  kind: python_call_eq
  function: AbstractAsyncContextManager.__name__.__eq__
  args: ["AbstractAsyncContextManager"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ checks — contextmanager and ExitStack as standalone invariants
#
# contextlib_extra4 covers __module__ for ExitStack and AsyncExitStack via table.
# contextlib_extra6 covers contextmanager/__module__ via a table row.
# New here: contextmanager and ExitStack __module__ as standalone invariants
# using the function: X.__module__.__eq__ pattern, a distinct expression axis.
# ---------------------------------------------------------------------------

invariant contextlib_extra12.contextmanager.module:
  description: "contextlib.contextmanager.__module__ == 'contextlib'"
  category: function_module
  kind: python_call_eq
  function: contextmanager.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra12.ExitStack.module:
  description: "contextlib.ExitStack.__module__ == 'contextlib'"
  category: class_module
  kind: python_call_eq
  function: ExitStack.__module__.__eq__
  args: ["contextlib"]
  expected: true

invariant contextlib_extra12.AsyncExitStack.module:
  description: "contextlib.AsyncExitStack.__module__ == 'contextlib'"
  category: class_module
  kind: python_call_eq
  function: AsyncExitStack.__module__.__eq__
  args: ["contextlib"]
  expected: true
