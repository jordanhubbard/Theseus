spec: ccount
version: ">=2.0.1"
backend: node(ccount)

docs: https://www.npmjs.com/package/ccount

provenance:
  derived_from:
    - "ccount README — https://www.npmjs.com/package/ccount"
    - "Test vectors verified with ccount via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "ccount source"
  notes:
    - "ccount is an npm package. Install: npm install ccount"
    - "Counts occurrences of a character in a string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table ccount.ccount:
  kind: node_module_call_eq
  function: ccount
  category: string
  id_prefix: ccount

  columns: [id, args, expected]
  rows:
    - [mississippi_s, ["mississippi", "s"], 4]
    - [hello_l,       ["hello", "l"],       2]
    - [hello_o,       ["hello", "o"],       1]
    - [no_match,      ["hi", "z"],          0]
