spec: svgo
version: ">=4.0.0"
backend: node(svgo)

docs: https://svgo.dev

provenance:
  derived_from:
    - "SVGO docs — https://svgo.dev"
    - "Test vectors verified with svgo via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "svgo source"
  notes:
    - "SVG Optimizer — strips redundant attrs, paths, comments; outputs compact SVG."
    - "Install: npm install svgo"
    - "v4 ESM only; named export optimize(svgString, options?) returns {data, ...stats}."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws on malformed SVG input; returns {data} on success."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant svgo.has_optimize:
  description: "optimize() function exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "optimize.constructor.name"}
  expected: "Function"

invariant svgo.optimize_returns_object_with_data:
  description: "optimize(svg) returns object with .data"
  category: optimize
  kind: node_chain_eq
  entry: named
  function: optimize
  entry_args: ["<svg xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"100\" height=\"100\" fill=\"red\"/></svg>"]
  chain:
    - {method: hasOwnProperty, args: ["data"]}
  expected: true

invariant svgo.optimize_data_is_string:
  description: ".data is a String"
  category: optimize
  kind: node_chain_eq
  entry: named
  function: optimize
  entry_args: ["<svg xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"100\" height=\"100\" fill=\"red\"/></svg>"]
  chain:
    - {get: data}
    - {get: "constructor.name"}
  expected: "String"

invariant svgo.optimize_data_starts_with_svg:
  description: "Optimized output begins with '<svg'"
  category: optimize
  kind: node_chain_eq
  entry: named
  function: optimize
  entry_args: ["<svg xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"100\" height=\"100\" fill=\"red\"/></svg>"]
  chain:
    - {get: data}
    - {method: startsWith, args: ["<svg"]}
  expected: true

invariant svgo.optimize_strips_redundancy:
  description: "Optimized output is shorter than input for this rect example"
  category: optimize
  kind: node_chain_eq
  entry: named
  function: optimize
  entry_args: ["<svg xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"100\" height=\"100\" fill=\"red\"/></svg>"]
  chain:
    - {get: data}
    - {method: includes, args: ["fill=\"red\""]}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:28:22Z
  iterations: 1
  pass_count: 5
  fail_count: 0
  total_invariants: 5
  notes: Synthesis succeeded in 1 iteration(s). 5 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
