spec: protobuf
version: ">=3.0"
backend: python_module(google.protobuf)

docs: https://protobuf.dev/reference/python/python-generated/

provenance:
  derived_from:
    - "Protocol Buffers Python API Reference — https://protobuf.dev/reference/python/python-generated/"
    - "google.protobuf.descriptor module documentation"
    - "Protocol Buffers language guide — https://protobuf.dev/programming-guides/proto3/"
    - "Test vectors verified with protobuf 7.34.1 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "protobuf source: python/google/protobuf/descriptor.py"
    - "protobuf source: python/google/protobuf/message.py"
  notes:
    - "PyPI package is 'protobuf'; imports as 'google.protobuf' (namespace package)."
    - "The spec file is protobuf.zspec.zsdl; the backend is google.protobuf."
    - "FieldDescriptor type constants are plain ints (e.g. TYPE_INT32 == 5)."
    - "FieldDescriptor label constants: LABEL_OPTIONAL=1, LABEL_REQUIRED=2, LABEL_REPEATED=3."
    - "google.protobuf.descriptor and google.protobuf.message require _SUBMODULE_PRELOADS."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — google.protobuf.__version__ is a string containing a dot
# ---------------------------------------------------------------------------

invariant protobuf.version.contains_dot:
  description: "google.protobuf.__version__ contains a dot (e.g. '7.34.1')"
  category: version
  kind: python_call_eq
  function: __version__.__contains__
  args: ["."]
  expected: true

invariant protobuf.version.is_string:
  description: "google.protobuf.__version__ is a str"
  category: version
  kind: python_call_eq
  function: __version__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# field_descriptor — FieldDescriptor type and label constants
#
# TYPE_INT32=5, TYPE_STRING=9, TYPE_BOOL=8, TYPE_FLOAT=2, TYPE_BYTES=12
# LABEL_OPTIONAL=1, LABEL_REQUIRED=2, LABEL_REPEATED=3
# All constants are plain ints as documented in descriptor.proto.
# ---------------------------------------------------------------------------

invariant protobuf.field_descriptor.TYPE_INT32:
  description: "FieldDescriptor.TYPE_INT32 == 5 (wire type varint, signed 32-bit)"
  category: field_descriptor
  kind: python_call_eq
  function: descriptor.FieldDescriptor.TYPE_INT32.__eq__
  args: [5]
  expected: true

invariant protobuf.field_descriptor.TYPE_STRING:
  description: "FieldDescriptor.TYPE_STRING == 9 (wire type length-delimited)"
  category: field_descriptor
  kind: python_call_eq
  function: descriptor.FieldDescriptor.TYPE_STRING.__eq__
  args: [9]
  expected: true

invariant protobuf.field_descriptor.TYPE_BOOL:
  description: "FieldDescriptor.TYPE_BOOL == 8 (wire type varint)"
  category: field_descriptor
  kind: python_call_eq
  function: descriptor.FieldDescriptor.TYPE_BOOL.__eq__
  args: [8]
  expected: true

invariant protobuf.field_descriptor.TYPE_FLOAT:
  description: "FieldDescriptor.TYPE_FLOAT == 2 (wire type 32-bit)"
  category: field_descriptor
  kind: python_call_eq
  function: descriptor.FieldDescriptor.TYPE_FLOAT.__eq__
  args: [2]
  expected: true

invariant protobuf.field_descriptor.TYPE_BYTES:
  description: "FieldDescriptor.TYPE_BYTES == 12 (wire type length-delimited)"
  category: field_descriptor
  kind: python_call_eq
  function: descriptor.FieldDescriptor.TYPE_BYTES.__eq__
  args: [12]
  expected: true

invariant protobuf.field_descriptor.LABEL_OPTIONAL:
  description: "FieldDescriptor.LABEL_OPTIONAL == 1"
  category: field_descriptor
  kind: python_call_eq
  function: descriptor.FieldDescriptor.LABEL_OPTIONAL.__eq__
  args: [1]
  expected: true

invariant protobuf.field_descriptor.LABEL_REQUIRED:
  description: "FieldDescriptor.LABEL_REQUIRED == 2"
  category: field_descriptor
  kind: python_call_eq
  function: descriptor.FieldDescriptor.LABEL_REQUIRED.__eq__
  args: [2]
  expected: true

invariant protobuf.field_descriptor.LABEL_REPEATED:
  description: "FieldDescriptor.LABEL_REPEATED == 3"
  category: field_descriptor
  kind: python_call_eq
  function: descriptor.FieldDescriptor.LABEL_REPEATED.__eq__
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# classes — core public class names
# ---------------------------------------------------------------------------

invariant protobuf.classes.Message_class_name:
  description: "google.protobuf.message.Message.__name__ == 'Message'"
  category: classes
  kind: python_call_eq
  function: message.Message.__name__.__eq__
  args: ["Message"]
  expected: true

invariant protobuf.classes.FieldDescriptor_class_name:
  description: "google.protobuf.descriptor.FieldDescriptor.__name__ == 'FieldDescriptor'"
  category: classes
  kind: python_call_eq
  function: descriptor.FieldDescriptor.__name__.__eq__
