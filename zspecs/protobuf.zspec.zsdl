  expected: true

invariant protobuf.classes.descriptor_pool_module_name:
  description: "google.protobuf.descriptor_pool.__name__ == 'google.protobuf.descriptor_pool'"
  category: classes
  kind: python_call_eq
  function: descriptor_pool.__name__.__eq__
  args: ["google.protobuf.descriptor_pool"]
  expected: true

