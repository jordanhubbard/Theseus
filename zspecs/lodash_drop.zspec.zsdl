spec: lodash_drop
version: ">=4.0.0"
backend: node(lodash.drop)

docs: https://lodash.com/docs/#drop

provenance:
  derived_from:
    - "lodash.drop README — https://www.npmjs.com/package/lodash.drop"
    - "Test vectors verified with lodash.drop@4.0.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "lodash source"
  notes:
    - "lodash.drop exports the _.drop function directly as module.exports."
    - "drop(array, n) returns a slice with n elements dropped from the beginning."
    - "Defaults to n=1 if omitted."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns an array slice. Returns [] if n >= array length."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table lodash_drop.drop:
  kind: node_module_call_eq
  function: ~
  category: drop
  id_prefix: ldrop

  columns: [id, args, expected]
  rows:
    - [drop2,  [[1, 2, 3, 4, 5], 2],  [3, 4, 5]]
    - [drop1,  [[1, 2, 3], 1],        [2, 3]]
    - [drop0,  [[1, 2, 3], 0],        [1, 2, 3]]
    - [all,    [[1, 2, 3], 3],        []]
