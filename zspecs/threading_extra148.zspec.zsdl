spec: threading_extra148
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Timer — __name__ 'Timer' len 5, __doc__ len 171, __init__.__qualname__ 'Timer.__init__' len 14, __init__.__code__.co_argcount 5, run.__qualname__ 'Timer.run' len 9, cancel.__qualname__ 'Timer.cancel' len 12, __bases__[0].__name__ 'Thread'; threading.Barrier — __doc__ len 200, __init__.__qualname__ 'Barrier.__init__', wait.__qualname__ 'Barrier.wait'; threading.Semaphore — __doc__ len 307, __name__ 'Semaphore', acquire.__qualname__ 'Semaphore.acquire', release.__qualname__ 'Semaphore.release'; threading.Thread — __name__ 'Thread', __module__ 'threading', __bases__[0].__name__ 'object', MRO len 2, __doc__ len 247, __init__.__code__.co_argcount 6 (Wave 271)."
    - "threading.Timer.__name__ == 'Timer' (len 5); __doc__ len == 171; __init__.__qualname__ == 'Timer.__init__' (len 14); __init__.__code__.co_argcount == 5; Timer.run.__qualname__ == 'Timer.run' (len 9); Timer.cancel.__qualname__ == 'Timer.cancel' (len 12); __bases__[0].__name__ == 'Thread'. Verified with Python 3.14.3."
    - "threading.Barrier.__doc__ len == 200; Barrier.__init__.__qualname__ == 'Barrier.__init__'; Barrier.wait.__qualname__ == 'Barrier.wait'. Verified with Python 3.14.3."
    - "threading.Semaphore.__doc__ len == 307; Semaphore.__name__ == 'Semaphore'; Semaphore.acquire.__qualname__ == 'Semaphore.acquire'; Semaphore.release.__qualname__ == 'Semaphore.release'. Verified with Python 3.14.3."
    - "threading.Thread.__name__ == 'Thread'; __module__ == 'threading'; __bases__[0].__name__ == 'object'; len(__mro__) == 2; len(__doc__) == 247; __init__.__code__.co_argcount == 6. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Timer — method qualnames and code attrs
#
# Wave 271 theme: threading.Timer — a Thread subclass that runs a function
# after a delay, cancellable before the function is called.
#
# threading.Timer.__name__ == 'Timer' (len 5)
# len(threading.Timer.__doc__) == 171
# threading.Timer.__init__.__qualname__ == 'Timer.__init__' (len 14)
# threading.Timer.__init__.__code__.co_argcount == 5
# threading.Timer.run.__qualname__ == 'Timer.run' (len 9)
# threading.Timer.cancel.__qualname__ == 'Timer.cancel' (len 12)
#
# Timer is defined as 'class Timer(Thread):' in Lib/threading.py.
# __init__ takes self, interval, function, args, kwargs (5 args total).
# New to extra148.
# ---------------------------------------------------------------------------

table threading_extra148.timer_method_attrs:
  description: "threading.Timer: __name__ 'Timer' len 5, __doc__ len 171, __init__ qualname len 14 co_argcount 5, run qualname len 9, cancel qualname len 12; wave 271; new to extra148"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingtimer148

  columns: [id, function, args, expected, description]
  rows:
    - [timer_name_eq,
       "Timer.__name__.__eq__",
       ["Timer"],
       true,
       "threading.Timer.__name__.__eq__('Timer') == True — Timer is a Python class defined in Lib/threading.py; its __name__ is 'Timer'; str.__eq__('Timer') returns True; new to extra148"]
    - [timer_name_len_eq_5,
       "Timer.__name__.__len__",
       [],
       5,
       "threading.Timer.__name__.__len__() == 5 — __name__ is 'Timer' which has 5 characters; len('Timer') == 5; new to extra148"]
    - [timer_doc_len_eq_171,
       "Timer.__doc__.__len__",
       [],
       171,
       "threading.Timer.__doc__.__len__() == 171 — the Timer class docstring has 171 characters; it describes how to call a function after a specified number of seconds; len(__doc__) == 171; verified with Python 3.14.3; new to extra148"]
    - [timer_init_qualname_eq,
       "Timer.__init__.__qualname__.__eq__",
       ["Timer.__init__"],
       true,
       "threading.Timer.__init__.__qualname__.__eq__('Timer.__init__') == True — the Timer initializer's __qualname__ is 'Timer.__init__'; str.__eq__('Timer.__init__') returns True; new to extra148"]
    - [timer_init_qualname_len_eq_14,
       "Timer.__init__.__qualname__.__len__",
       [],
       14,
       "threading.Timer.__init__.__qualname__.__len__() == 14 — __qualname__ is 'Timer.__init__' which has 14 characters; len('Timer.__init__') == 14; new to extra148"]
    - [timer_init_co_argcount_eq_5,
       "Timer.__init__.__code__.co_argcount.__eq__",
       [5],
       true,
       "threading.Timer.__init__.__code__.co_argcount.__eq__(5) == True — Timer.__init__ takes 5 positional-or-keyword arguments: self, interval, function, args, kwargs; co_argcount is 5; int.__eq__(5) returns True; new to extra148"]
    - [timer_run_qualname_eq,
       "Timer.run.__qualname__.__eq__",
       ["Timer.run"],
       true,
       "threading.Timer.run.__qualname__.__eq__('Timer.run') == True — Timer.run is the method that calls the stored function after the interval; its __qualname__ is 'Timer.run'; str.__eq__('Timer.run') returns True; new to extra148"]
    - [timer_run_qualname_len_eq_9,
       "Timer.run.__qualname__.__len__",
       [],
       9,
       "threading.Timer.run.__qualname__.__len__() == 9 — __qualname__ is 'Timer.run' which has 9 characters; len('Timer.run') == 9; new to extra148"]
    - [timer_cancel_qualname_eq,
       "Timer.cancel.__qualname__.__eq__",
       ["Timer.cancel"],
       true,
       "threading.Timer.cancel.__qualname__.__eq__('Timer.cancel') == True — Timer.cancel stops the timer and prevents the function from being called; its __qualname__ is 'Timer.cancel'; str.__eq__('Timer.cancel') returns True; new to extra148"]
    - [timer_cancel_qualname_len_eq_12,
       "Timer.cancel.__qualname__.__len__",
       [],
       12,
       "threading.Timer.cancel.__qualname__.__len__() == 12 — __qualname__ is 'Timer.cancel' which has 12 characters; len('Timer.cancel') == 12; new to extra148"]

# ---------------------------------------------------------------------------
# Table 2: threading.Barrier and Semaphore — doc lengths and method qualnames
#
# Wave 271 theme: threading.Barrier and Semaphore docstring lengths and
# key method qualnames.
#
# len(threading.Barrier.__doc__) == 200
# threading.Barrier.__init__.__qualname__ == 'Barrier.__init__'
# threading.Barrier.wait.__qualname__ == 'Barrier.wait'
# len(threading.Semaphore.__doc__) == 307
# threading.Semaphore.__name__ == 'Semaphore'
# threading.Semaphore.acquire.__qualname__ == 'Semaphore.acquire'
# threading.Semaphore.release.__qualname__ == 'Semaphore.release'
#
# Barrier and Semaphore are pure-Python synchronization primitives
# defined in Lib/threading.py. New to extra148.
# ---------------------------------------------------------------------------

table threading_extra148.barrier_semaphore_attrs:
  description: "threading.Barrier __doc__ len 200, __init__/__wait qualnames; threading.Semaphore __doc__ len 307, acquire/release qualnames; wave 271; new to extra148"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingbarrsem148

  columns: [id, function, args, expected, description]
  rows:
    - [barrier_doc_len_eq_200,
       "Barrier.__doc__.__len__",
       [],
       200,
       "threading.Barrier.__doc__.__len__() == 200 — the Barrier class docstring has 200 characters; it describes the barrier synchronization primitive for a fixed number of threads; len(__doc__) == 200; verified with Python 3.14.3; new to extra148"]
    - [barrier_init_qualname_eq,
       "Barrier.__init__.__qualname__.__eq__",
       ["Barrier.__init__"],
       true,
       "threading.Barrier.__init__.__qualname__.__eq__('Barrier.__init__') == True — the Barrier initializer's __qualname__ is 'Barrier.__init__'; str.__eq__('Barrier.__init__') returns True; new to extra148"]
    - [barrier_wait_qualname_eq,
       "Barrier.wait.__qualname__.__eq__",
       ["Barrier.wait"],
       true,
       "threading.Barrier.wait.__qualname__.__eq__('Barrier.wait') == True — Barrier.wait is the method that blocks until all parties have called wait; its __qualname__ is 'Barrier.wait'; str.__eq__('Barrier.wait') returns True; new to extra148"]
    - [semaphore_doc_len_eq_307,
       "Semaphore.__doc__.__len__",
       [],
       307,
       "threading.Semaphore.__doc__.__len__() == 307 — the Semaphore class docstring has 307 characters; it describes semaphore objects that manage a counter representing the number of available resources; len(__doc__) == 307; verified with Python 3.14.3; new to extra148"]
    - [semaphore_name_eq,
       "Semaphore.__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — the Semaphore class's __name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra148"]
    - [semaphore_acquire_qualname_eq,
       "Semaphore.acquire.__qualname__.__eq__",
       ["Semaphore.acquire"],
       true,
       "threading.Semaphore.acquire.__qualname__.__eq__('Semaphore.acquire') == True — Semaphore.acquire decrements the counter (blocking if zero); its __qualname__ is 'Semaphore.acquire'; str.__eq__('Semaphore.acquire') returns True; new to extra148"]
    - [semaphore_release_qualname_eq,
       "Semaphore.release.__qualname__.__eq__",
       ["Semaphore.release"],
       true,
       "threading.Semaphore.release.__qualname__.__eq__('Semaphore.release') == True — Semaphore.release increments the counter; its __qualname__ is 'Semaphore.release'; str.__eq__('Semaphore.release') returns True; new to extra148"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread — class identity and code attrs
#
# Wave 271 theme: threading.Thread — the base class for threads; Timer inherits
# from Thread, so understanding Thread's structure underpins Timer.
#
# threading.Thread.__name__ == 'Thread'
# threading.Thread.__module__ == 'threading'
# threading.Thread.__bases__[0].__name__ == 'object'
# len(threading.Thread.__mro__) == 2
# len(threading.Thread.__doc__) == 247
# threading.Thread.__init__.__code__.co_argcount == 6
# threading.Thread.__init__.__qualname__ == 'Thread.__init__' (len 15)
#
# Thread is defined in Lib/threading.py; __init__ takes self, group, target,
# name, args, kwargs (6 positional-or-keyword arguments). New to extra148.
# ---------------------------------------------------------------------------

table threading_extra148.thread_class_attrs:
  description: "threading.Thread: __name__ 'Thread', __module__ 'threading', MRO len 2, __doc__ len 247, __init__ qualname len 15, co_argcount 6; wave 271; new to extra148"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthread148

  columns: [id, function, args, expected, description]
  rows:
    - [thread_name_eq,
       "Thread.__name__.__eq__",
       ["Thread"],
       true,
       "threading.Thread.__name__.__eq__('Thread') == True — Thread is a Python class defined in Lib/threading.py; its __name__ is 'Thread'; str.__eq__('Thread') returns True; new to extra148"]
    - [thread_module_eq_threading,
       "Thread.__module__.__eq__",
       ["threading"],
       true,
       "threading.Thread.__module__.__eq__('threading') == True — Thread is defined in Lib/threading.py; __module__ is 'threading'; str.__eq__('threading') returns True; new to extra148"]
    - [thread_bases_first_eq_object,
       "Thread.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "threading.Thread.__bases__[0].__name__.__eq__('object') == True — Thread inherits directly from object; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra148"]
    - [thread_mro_len_eq_2,
       "Thread.__mro__.__len__",
       [],
       2,
       "threading.Thread.__mro__.__len__() == 2 — the MRO of Thread is [Thread, object]; Thread has no intermediate base; len(__mro__) == 2; new to extra148"]
    - [thread_doc_len_eq_247,
       "Thread.__doc__.__len__",
       [],
       247,
       "threading.Thread.__doc__.__len__() == 247 — the Thread class docstring has 247 characters; it documents the thread class and notes that the daemon attribute can be set; len(__doc__) == 247; verified with Python 3.14.3; new to extra148"]
    - [thread_init_qualname_eq,
       "Thread.__init__.__qualname__.__eq__",
       ["Thread.__init__"],
       true,
       "threading.Thread.__init__.__qualname__.__eq__('Thread.__init__') == True — the Thread initializer's __qualname__ is 'Thread.__init__'; str.__eq__('Thread.__init__') returns True; new to extra148"]
    - [thread_init_qualname_len_eq_15,
       "Thread.__init__.__qualname__.__len__",
       [],
       15,
       "threading.Thread.__init__.__qualname__.__len__() == 15 — __qualname__ is 'Thread.__init__' which has 15 characters; len('Thread.__init__') == 15; new to extra148"]
    - [thread_init_co_argcount_eq_6,
       "Thread.__init__.__code__.co_argcount.__eq__",
       [6],
       true,
       "threading.Thread.__init__.__code__.co_argcount.__eq__(6) == True — Thread.__init__ takes 6 positional-or-keyword arguments: self, group, target, name, args, kwargs; co_argcount is 6; int.__eq__(6) returns True; new to extra148"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra148
# ---------------------------------------------------------------------------

invariant threading_extra148.timer_name_len:
  description: "len(threading.Timer.__name__) == 5 — __name__ is 'Timer'; wave 271; new to extra148"
  kind: python_call_eq
  function: Timer.__name__.__len__
  args: []
  expected: 5

invariant threading_extra148.timer_doc_len:
  description: "len(threading.Timer.__doc__) == 171 — the Timer class docstring has 171 characters; wave 271; new to extra148"
  kind: python_call_eq
  function: Timer.__doc__.__len__
  args: []
  expected: 171

invariant threading_extra148.timer_init_co_argcount:
  description: "threading.Timer.__init__.__code__.co_argcount == 5 — takes self, interval, function, args, kwargs; wave 271; new to extra148"
  kind: python_call_eq
  function: Timer.__init__.__code__.co_argcount.__eq__
  args: [5]
  expected: true

invariant threading_extra148.timer_run_qualname_len:
  description: "len(threading.Timer.run.__qualname__) == 9 — __qualname__ is 'Timer.run'; wave 271; new to extra148"
  kind: python_call_eq
  function: Timer.run.__qualname__.__len__
  args: []
  expected: 9

invariant threading_extra148.timer_cancel_qualname_len:
  description: "len(threading.Timer.cancel.__qualname__) == 12 — __qualname__ is 'Timer.cancel'; wave 271; new to extra148"
  kind: python_call_eq
  function: Timer.cancel.__qualname__.__len__
  args: []
  expected: 12

invariant threading_extra148.timer_bases_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread; wave 271; new to extra148"
  kind: python_call_eq
  function: "Timer.__bases__[0].__name__.__eq__"
  args: ["Thread"]
  expected: true

invariant threading_extra148.barrier_doc_len:
  description: "len(threading.Barrier.__doc__) == 200 — the Barrier class docstring has 200 characters; wave 271; new to extra148"
  kind: python_call_eq
  function: Barrier.__doc__.__len__
  args: []
  expected: 200

invariant threading_extra148.semaphore_doc_len:
  description: "len(threading.Semaphore.__doc__) == 307 — the Semaphore class docstring has 307 characters; wave 271; new to extra148"
  kind: python_call_eq
  function: Semaphore.__doc__.__len__
  args: []
  expected: 307

invariant threading_extra148.thread_mro_len:
  description: "len(threading.Thread.__mro__) == 2 — MRO is [Thread, object]; wave 271; new to extra148"
  kind: python_call_eq
  function: Thread.__mro__.__len__
  args: []
  expected: 2

invariant threading_extra148.thread_doc_len:
  description: "len(threading.Thread.__doc__) == 247 — the Thread class docstring has 247 characters; wave 271; new to extra148"
  kind: python_call_eq
  function: Thread.__doc__.__len__
  args: []
  expected: 247

invariant threading_extra148.thread_init_co_argcount:
  description: "threading.Thread.__init__.__code__.co_argcount == 6 — takes self, group, target, name, args, kwargs; wave 271; new to extra148"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_argcount.__eq__
  args: [6]
  expected: true
