spec: is_mergeable_object
version: ">=1.1.1"
backend: node(is-mergeable-object)

docs: https://www.npmjs.com/package/is-mergeable-object

provenance:
  derived_from:
    - "is-mergeable-object README — https://www.npmjs.com/package/is-mergeable-object"
    - "Test vectors verified with is-mergeable-object via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-mergeable-object source"
  notes:
    - "is-mergeable-object is an npm package. Install: npm install is-mergeable-object"
    - "Returns true if the value can be merged (is a plain object or array, not null)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_mergeable_object.check:
  kind: node_module_call_eq
  function: ~
  category: validation
  id_prefix: ismrg

  columns: [id, args, expected]
  rows:
    - [object,  [{}],     true]
    - [array,   [[]],     true]
    - [null_val, [null],  false]
