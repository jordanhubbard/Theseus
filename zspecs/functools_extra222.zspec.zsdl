spec: functools_extra222
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools __annotations__, __kwdefaults__, and WRAPPER_ASSIGNMENTS / WRAPPER_UPDATES checks (wave 383)."
    - "lru_cache.__annotations__ == {}; len == 0; type == dict. __kwdefaults__ is None. Verified with Python 3.14.3."
    - "wraps.__annotations__ == {}; __kwdefaults__ is None. Verified with Python 3.14.3."
    - "update_wrapper.__annotations__ == {}; __kwdefaults__ is None. Verified with Python 3.14.3."
    - "singledispatch.__annotations__ == {}; __kwdefaults__ is None. Verified with Python 3.14.3."
    - "WRAPPER_ASSIGNMENTS in Python 3.14 is a 6-element tuple: ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'). Note: __annotations__ is NOT in it (replaced by __annotate__ in 3.14). Verified with Python 3.14.3."
    - "WRAPPER_UPDATES == ('__dict__',); len == 1. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools __annotations__ — empty dict checks
#
# lru_cache, wraps, update_wrapper, singledispatch, and cache are all
# pure-Python functions defined without any PEP-3107 return or parameter
# annotations. Their __annotations__ dicts are empty.
#
# Verified with Python 3.14.3:
#   lru_cache.__annotations__ == {}
#   len(lru_cache.__annotations__) == 0
#   type(lru_cache.__annotations__).__name__ == 'dict'
#   wraps.__annotations__ == {}
#   update_wrapper.__annotations__ == {}
#   singledispatch.__annotations__ == {}
# ---------------------------------------------------------------------------

table functools_extra222.annotations_empty:
  description: "functools key functions have empty __annotations__ dicts; wave 383; new to extra222"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra222ann

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_annotations_len_eq_0,
       lru_cache.__annotations__.__len__,
       [],
       0,
       "functools.lru_cache.__annotations__.__len__() == 0 — lru_cache is defined without any type annotations on its parameters or return value; __annotations__ is an empty dict; __len__() returns 0; new to extra222"]
    - [wraps_annotations_len_eq_0,
       wraps.__annotations__.__len__,
       [],
       0,
       "functools.wraps.__annotations__.__len__() == 0 — wraps() is defined without any type annotations; its __annotations__ dict is empty; __len__() returns 0; new to extra222"]
    - [update_wrapper_annotations_len_eq_0,
       update_wrapper.__annotations__.__len__,
       [],
       0,
       "functools.update_wrapper.__annotations__.__len__() == 0 — update_wrapper() has no type annotations; __annotations__ is an empty dict; __len__() returns 0; new to extra222"]
    - [singledispatch_annotations_len_eq_0,
       singledispatch.__annotations__.__len__,
       [],
       0,
       "functools.singledispatch.__annotations__.__len__() == 0 — singledispatch() has no type annotations; __annotations__ is an empty dict; __len__() returns 0; new to extra222"]
    - [lru_cache_annotations_type_is_dict,
       lru_cache.__annotations__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "functools.lru_cache.__annotations__.__class__.__name__.__eq__('dict') == True — __annotations__ is always a dict object; its class name is 'dict'; str.__eq__('dict') returns True; new to extra222"]

# ---------------------------------------------------------------------------
# Table 2: functools __kwdefaults__ — None checks
#
# lru_cache, wraps, update_wrapper, singledispatch, and cache have no
# keyword-only parameters with defaults, so __kwdefaults__ is None.
#
# Verified with Python 3.14.3:
#   lru_cache.__kwdefaults__ is None   (None is not callable; use __eq__)
#   wraps.__kwdefaults__ is None
#   update_wrapper.__kwdefaults__ is None
#   singledispatch.__kwdefaults__ is None
# ---------------------------------------------------------------------------

table functools_extra222.kwdefaults_none:
  description: "functools key functions have __kwdefaults__ == None; wave 383; new to extra222"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra222kwd

  columns: [id, function, args, expected, description]
  rows:
    - [lru_cache_kwdefaults_is_none,
       lru_cache.__kwdefaults__.__eq__,
       [null],
       true,
       "functools.lru_cache.__kwdefaults__.__eq__(None) == True — lru_cache has no keyword-only parameters (maxsize and typed are positional-or-keyword); __kwdefaults__ is None; None.__eq__(None) returns True; new to extra222"]
    - [wraps_kwdefaults_is_none,
       wraps.__kwdefaults__.__eq__,
       [null],
       true,
       "functools.wraps.__kwdefaults__.__eq__(None) == True — wraps() has no keyword-only parameters; its parameters 'wrapped', 'assigned', 'updated' are all positional-or-keyword with defaults; __kwdefaults__ is None; None.__eq__(None) returns True; new to extra222"]
    - [update_wrapper_kwdefaults_is_none,
       update_wrapper.__kwdefaults__.__eq__,
       [null],
       true,
       "functools.update_wrapper.__kwdefaults__.__eq__(None) == True — update_wrapper() has no keyword-only parameters; all four parameters are positional-or-keyword; __kwdefaults__ is None; None.__eq__(None) returns True; new to extra222"]
    - [singledispatch_kwdefaults_is_none,
       singledispatch.__kwdefaults__.__eq__,
       [null],
       true,
       "functools.singledispatch.__kwdefaults__.__eq__(None) == True — singledispatch() takes a single parameter 'func' with no keyword-only parameters; __kwdefaults__ is None; None.__eq__(None) returns True; new to extra222"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_ASSIGNMENTS — membership checks
#
# In Python 3.14, functools.WRAPPER_ASSIGNMENTS is:
#   ('__module__', '__name__', '__qualname__', '__doc__', '__annotate__',
#    '__type_params__')
# That is 6 elements. Note: __annotations__ was replaced by __annotate__ in
# Python 3.14 (PEP 749). __dict__ moved to WRAPPER_UPDATES.
#
# Verified with Python 3.14.3:
#   len(WRAPPER_ASSIGNMENTS) == 6
#   WRAPPER_ASSIGNMENTS.__contains__('__module__') == True
#   WRAPPER_ASSIGNMENTS.__contains__('__name__') == True
#   WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True
#   WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True
#   WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True
#   WRAPPER_ASSIGNMENTS.__contains__('__type_params__') == True
#   WRAPPER_ASSIGNMENTS.__contains__('__dict__') == False
# ---------------------------------------------------------------------------

table functools_extra222.wrapper_assignments_members:
  description: "functools.WRAPPER_ASSIGNMENTS membership checks (6 elements in Python 3.14); wave 383; new to extra222"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra222wa

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_len_eq_6,
       WRAPPER_ASSIGNMENTS.__len__,
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — in Python 3.14 WRAPPER_ASSIGNMENTS has 6 elements: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; tuple.__len__() returns 6; new to extra222"]
    - [wrapper_assignments_contains_module,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — __module__ is the first element of WRAPPER_ASSIGNMENTS; wraps() copies it from the wrapped function to the wrapper so the wrapper appears to belong to the same module; tuple.__contains__ returns True; new to extra222"]
    - [wrapper_assignments_contains_name,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True — __name__ is copied by wraps() so the wrapper's __name__ matches the wrapped function's __name__; tuple.__contains__ returns True; new to extra222"]
    - [wrapper_assignments_contains_qualname,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__qualname__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__qualname__') == True — __qualname__ is copied by wraps() so the wrapper's qualified name matches the wrapped function; tuple.__contains__ returns True; new to extra222"]
    - [wrapper_assignments_contains_doc,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__doc__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True — __doc__ is copied by wraps() so the wrapper's docstring matches the wrapped function's docstring; tuple.__contains__ returns True; new to extra222"]
    - [wrapper_assignments_contains_annotate,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__annotate__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True — in Python 3.14 (PEP 749), __annotate__ replaces __annotations__ in WRAPPER_ASSIGNMENTS; it is a callable that returns annotations lazily; tuple.__contains__ returns True; new to extra222"]
    - [wrapper_assignments_contains_type_params,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__type_params__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__type_params__') == True — __type_params__ holds the type parameter objects for generic functions (PEP 695); it was added to WRAPPER_ASSIGNMENTS in Python 3.12+; tuple.__contains__ returns True; new to extra222"]
    - [wrapper_assignments_not_contains_dict,
       WRAPPER_ASSIGNMENTS.__contains__,
       ["__dict__"],
       false,
       "functools.WRAPPER_ASSIGNMENTS.__contains__('__dict__') == False — __dict__ is NOT in WRAPPER_ASSIGNMENTS; it is instead in WRAPPER_UPDATES because it is merged rather than assigned outright; tuple.__contains__ returns False; new to extra222"]

# ---------------------------------------------------------------------------
# Table 4: functools.WRAPPER_UPDATES — membership and length checks
#
# functools.WRAPPER_UPDATES is ('__dict__',) — a one-element tuple.
# wraps() merges (updates) these attributes rather than assigning them.
#
# Verified with Python 3.14.3:
#   len(WRAPPER_UPDATES) == 1
#   WRAPPER_UPDATES.__contains__('__dict__') == True
#   type(WRAPPER_UPDATES).__name__ == 'tuple'
# ---------------------------------------------------------------------------

table functools_extra222.wrapper_updates_members:
  description: "functools.WRAPPER_UPDATES == ('__dict__',); len==1; wave 383; new to extra222"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra222wu

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_updates_len_eq_1,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains only '__dict__'; wraps() updates (merges) __dict__ rather than replacing it outright; tuple.__len__() returns 1; new to extra222"]
    - [wrapper_updates_contains_dict,
       WRAPPER_UPDATES.__contains__,
       ["__dict__"],
       true,
       "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — __dict__ is the only element of WRAPPER_UPDATES; wraps() calls wrapper.__dict__.update(wrapped.__dict__) to merge attribute dictionaries rather than assigning; tuple.__contains__ returns True; new to extra222"]
    - [wrapper_updates_type_is_tuple,
       WRAPPER_UPDATES.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a tuple constant just like WRAPPER_ASSIGNMENTS; str.__eq__('tuple') returns True; new to extra222"]
    - [wrapper_updates_not_contains_module,
       WRAPPER_UPDATES.__contains__,
       ["__module__"],
       false,
       "functools.WRAPPER_UPDATES.__contains__('__module__') == False — __module__ is assigned (not merged) so it belongs in WRAPPER_ASSIGNMENTS, not WRAPPER_UPDATES; tuple.__contains__ returns False; new to extra222"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra222
# ---------------------------------------------------------------------------

invariant functools_extra222.lru_cache_annotations_empty:
  description: "functools.lru_cache.__annotations__.__len__() == 0 — lru_cache has no type annotations; wave 383; new to extra222"
  kind: python_call_eq
  function: lru_cache.__annotations__.__len__
  args: []
  expected: 0

invariant functools_extra222.wraps_annotations_empty:
  description: "functools.wraps.__annotations__.__len__() == 0 — wraps has no type annotations; wave 383; new to extra222"
  kind: python_call_eq
  function: wraps.__annotations__.__len__
  args: []
  expected: 0

invariant functools_extra222.lru_cache_kwdefaults_none:
  description: "functools.lru_cache.__kwdefaults__.__eq__(None) == True — no keyword-only params so __kwdefaults__ is None; wave 383; new to extra222"
  kind: python_call_eq
  function: lru_cache.__kwdefaults__.__eq__
  args: [null]
  expected: true

invariant functools_extra222.wraps_kwdefaults_none:
  description: "functools.wraps.__kwdefaults__.__eq__(None) == True — wraps has no keyword-only params; wave 383; new to extra222"
  kind: python_call_eq
  function: wraps.__kwdefaults__.__eq__
  args: [null]
  expected: true

invariant functools_extra222.wrapper_assignments_len:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — 6 elements in Python 3.14; wave 383; new to extra222"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra222.wrapper_assignments_has_module:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True; wave 383; new to extra222"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__module__"]
  expected: true

invariant functools_extra222.wrapper_assignments_has_annotate:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__annotate__') == True — Python 3.14 replaced __annotations__ with __annotate__; wave 383; new to extra222"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__annotate__"]
  expected: true

invariant functools_extra222.wrapper_assignments_no_dict:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__dict__') == False — __dict__ is in WRAPPER_UPDATES, not WRAPPER_ASSIGNMENTS; wave 383; new to extra222"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__dict__"]
  expected: false

invariant functools_extra222.wrapper_updates_has_dict:
  description: "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — __dict__ is merged (not assigned); wave 383; new to extra222"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true

invariant functools_extra222.wrapper_updates_len:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — only __dict__ is updated; wave 383; new to extra222"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1
