spec: dataclasses_extra7
version: ">=3.9"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses.zspec.zsdl through dataclasses_extra6.zspec.zsdl and dataclasses_field.zspec.zsdl."
    - "Focus: __qualname__ attributes and sentinel/constant class names."
    - "dataclasses.dataclass.__name__ == 'dataclass'."
    - "dataclasses.dataclass.__module__ == 'dataclasses'."
    - "dataclasses.dataclass.__qualname__ == 'dataclass'."
    - "dataclasses.asdict.__qualname__ == 'asdict'."
    - "dataclasses.astuple.__qualname__ == 'astuple'."
    - "dataclasses.replace.__qualname__ == 'replace'."
    - "dataclasses.make_dataclass.__qualname__ == 'make_dataclass'."
    - "dataclasses.fields.__qualname__ == 'fields'."
    - "dataclasses.MISSING.__class__.__name__ == '_MISSING_TYPE' — the sentinel object."
    - "dataclasses.HAS_DEFAULT.__class__.__name__ == 'int' — bitmask constant is an int."
    - "dataclasses.KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' — Python 3.10+ sentinel."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — dataclass, field, fields, asdict, astuple, replace
# dataclasses_extra6 covers __name__ for all these; this spec adds __qualname__.
# ---------------------------------------------------------------------------

table dataclasses_extra7.qualnames:
  kind: python_call_eq
  category: qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [dataclass,      dataclass.__qualname__.__eq__,      ["dataclass"],      true]
    - [field,          field.__qualname__.__eq__,          ["field"],          true]
    - [fields,         fields.__qualname__.__eq__,         ["fields"],         true]
    - [asdict,         asdict.__qualname__.__eq__,         ["asdict"],         true]
    - [astuple,        astuple.__qualname__.__eq__,        ["astuple"],        true]
    - [replace,        replace.__qualname__.__eq__,        ["replace"],        true]
    - [make_dataclass, make_dataclass.__qualname__.__eq__, ["make_dataclass"], true]

# ---------------------------------------------------------------------------
# dataclasses.dataclass — __name__ and __module__
# dataclasses_extra6 covers __name__ for asdict, astuple, replace, etc.,
# but not for dataclass itself via __name__.__eq__.
# ---------------------------------------------------------------------------

invariant dataclasses_extra7.dataclass.name:
  description: "dataclasses.dataclass.__name__ == 'dataclass'"
  category: function_names
  kind: python_call_eq
  function: dataclass.__name__.__eq__
  args: ["dataclass"]
  expected: true

invariant dataclasses_extra7.dataclass.module:
  description: "dataclasses.dataclass.__module__ == 'dataclasses'"
  category: module
  kind: python_call_eq
  function: dataclass.__module__.__eq__
  args: ["dataclasses"]
  expected: true

# ---------------------------------------------------------------------------
# dataclasses.MISSING — sentinel for missing default values
# MISSING.__class__.__name__ == '_MISSING_TYPE'
# ---------------------------------------------------------------------------

invariant dataclasses_extra7.MISSING.class_name:
  description: "dataclasses.MISSING.__class__.__name__ == '_MISSING_TYPE'"
  category: sentinels
  kind: python_call_eq
  function: MISSING.__class__.__name__.__eq__
  args: ["_MISSING_TYPE"]
  expected: true

# ---------------------------------------------------------------------------
# dataclasses.HAS_DEFAULT — bitmask integer constant
# HAS_DEFAULT.__class__.__name__ == 'int'
# ---------------------------------------------------------------------------

invariant dataclasses_extra7.HAS_DEFAULT.class_name:
  description: "dataclasses.HAS_DEFAULT.__class__.__name__ == 'int'"
  category: constants
  kind: python_call_eq
  function: HAS_DEFAULT.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# dataclasses.KW_ONLY — sentinel for keyword-only fields (Python 3.10+)
# KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE'
# ---------------------------------------------------------------------------

invariant dataclasses_extra7.KW_ONLY.class_name:
  description: "dataclasses.KW_ONLY.__class__.__name__ == '_KW_ONLY_TYPE' (Python 3.10+)"
  category: sentinels
  kind: python_call_eq
  function: KW_ONLY.__class__.__name__.__eq__
  args: ["_KW_ONLY_TYPE"]
  expected: true
