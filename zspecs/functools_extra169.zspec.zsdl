spec: functools_extra169
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.partial.func.__class__.__name__ 'member_descriptor'; functools.partial.args.__class__.__name__ 'member_descriptor'; functools.partial.keywords.__class__.__name__ 'member_descriptor'; functools.partial.__doc__.__class__.__name__ 'str'; functools.partial.__name__ 'partial'; functools.partial.__module__ 'functools'; functools.partial.__bases__[0].__name__ 'object' (Wave 293)."
    - "functools.partial.func.__class__.__name__ == 'member_descriptor' — functools.partial is a C extension type (defined in Modules/_functoolsmodule.c); its .func slot is exposed as a member_descriptor on the class object (not a getset_descriptor); accessing partial.func on the class returns the descriptor object whose __class__.__name__ is 'member_descriptor'. Verified with Python 3.14.3."
    - "functools.partial.args.__class__.__name__ == 'member_descriptor' — the .args slot on the functools.partial class is a member_descriptor that exposes the tuple of positional arguments frozen into the partial object; __class__.__name__ is 'member_descriptor'. Verified with Python 3.14.3."
    - "functools.partial.keywords.__class__.__name__ == 'member_descriptor' — the .keywords slot on the functools.partial class is a member_descriptor that exposes the dict of keyword arguments frozen into the partial object; __class__.__name__ is 'member_descriptor'. Verified with Python 3.14.3."
    - "functools.partial.__doc__.__class__.__name__ == 'str' — functools.partial has a C-level docstring; its __doc__ attribute is a plain Python str object; __class__.__name__ is 'str'. Verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial' — functools.partial is a C extension type; its type __name__ attribute is 'partial'. Verified with Python 3.14.3."
    - "functools.partial.__module__ == 'functools' — functools.partial is declared in the functools C extension module; its __module__ is 'functools'. Verified with Python 3.14.3."
    - "functools.partial.__bases__[0].__name__ == 'object' — functools.partial is a C extension type that inherits directly from object; its single base class __name__ is 'object'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial class attribute descriptor types
#
# Wave 293 theme: functools.partial C extension type — the .func, .args, and
# .keywords class-level slot descriptors are all member_descriptor objects.
#
# functools.partial.func.__class__.__name__ == 'member_descriptor'
# functools.partial.args.__class__.__name__ == 'member_descriptor'
# functools.partial.keywords.__class__.__name__ == 'member_descriptor'
# functools.partial.__doc__.__class__.__name__ == 'str'
#
# functools.partial(func, /, *args, **keywords) creates a new partial object
# that behaves like func called with the positional arguments args and keyword
# arguments keywords. It is implemented as a C extension type in
# Modules/_functoolsmodule.c. Accessing .func, .args, and .keywords on the
# class (not an instance) returns the underlying C member descriptors; each
# has __class__.__name__ == 'member_descriptor'. The class docstring is a
# plain Python str. New to extra169.
# ---------------------------------------------------------------------------

table functools_extra169.partial_class_attribute_descriptor_types:
  description: "functools.partial: func/args/keywords __class__.__name__ 'member_descriptor'; __doc__.__class__.__name__ 'str'; wave 293; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspcadt169

  columns: [id, function, args, expected, description]
  rows:
    - [partial_func_desc_cls,
       "partial.func.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "functools.partial.func.__class__.__name__.__eq__('member_descriptor') == True — partial.func accessed on the class (not an instance) is the C member descriptor that exposes the wrapped callable frozen into the partial; its __class__.__name__ is 'member_descriptor'; str.__eq__('member_descriptor') returns True; new to extra169"]
    - [partial_args_desc_cls,
       "partial.args.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "functools.partial.args.__class__.__name__.__eq__('member_descriptor') == True — partial.args accessed on the class is the C member descriptor that exposes the tuple of frozen positional arguments; its __class__.__name__ is 'member_descriptor'; str.__eq__('member_descriptor') returns True; new to extra169"]
    - [partial_keywords_desc_cls,
       "partial.keywords.__class__.__name__.__eq__",
       ["member_descriptor"],
       true,
       "functools.partial.keywords.__class__.__name__.__eq__('member_descriptor') == True — partial.keywords accessed on the class is the C member descriptor that exposes the dict of frozen keyword arguments; its __class__.__name__ is 'member_descriptor'; str.__eq__('member_descriptor') returns True; new to extra169"]
    - [partial_doc_cls_str,
       "partial.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "functools.partial.__doc__.__class__.__name__.__eq__('str') == True — functools.partial has a C-level docstring; its __doc__ attribute on the class is a plain Python str object; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra169"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial class identity — name, module, and base class
#
# Wave 293 theme: functools.partial C extension type identity attributes —
# __name__, __module__, and __bases__[0].
#
# functools.partial.__name__ == 'partial'
# functools.partial.__module__ == 'functools'
# functools.partial.__bases__[0].__name__ == 'object'
# functools.partial.__class__.__name__ == 'type'
#
# functools.partial is a C extension class (type) implemented in
# Modules/_functoolsmodule.c. It wraps a callable together with frozen
# positional and keyword arguments. As a class object its __name__ is
# 'partial', its __module__ is 'functools' (the public module), its base
# class is object, and its own __class__ is the metaclass 'type'. New to extra169.
# ---------------------------------------------------------------------------

table functools_extra169.partial_class_identity:
  description: "functools.partial: __name__ 'partial', __module__ 'functools', __bases__[0].__name__ 'object', __class__.__name__ 'type'; wave 293; new to extra169"
  kind: python_call_eq
  category: identity
  id_prefix: functoolspcid169

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_eq_partial,
       "partial.__name__.__eq__",
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — functools.partial is a C extension type (class) in Modules/_functoolsmodule.c; its type __name__ is 'partial'; str.__eq__('partial') returns True; new to extra169"]
    - [partial_module_eq_functools,
       "partial.__module__.__eq__",
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — functools.partial is declared in the functools C extension module; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra169"]
    - ["partial_bases_0_name_eq_object",
       "partial.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partial.__bases__[0].__name__.__eq__('object') == True — functools.partial is a C extension type that inherits directly from object; its __bases__ tuple has a single element whose __name__ is 'object'; str.__eq__('object') returns True; new to extra169"]
    - [partial_class_name_eq_type,
       "partial.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — functools.partial is a class object; its metaclass is the standard 'type'; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra169"]

