spec: cmd_extra2
version: ">=3.9"
backend: python_module(cmd)

docs: https://docs.python.org/3/library/cmd.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/cmd.html — Python cmd module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/cmd.py"
  notes:
    - "Extends cmd.zspec.zsdl and cmd_extra.zspec.zsdl; does NOT duplicate invariants already present there."
    - "cmd.zspec.zsdl covers: Cmd.__name__, Cmd.__module__; Cmd() instance attrs prompt/intro/use_rawinput/cmdqueue/ruler/doc_header/misc_header/undoc_header; IDENTCHARS contains 'a'/'A'/'0'/'_'."
    - "cmd_extra.zspec.zsdl covers: Cmd.__name__, Cmd.__module__; cmdloop/onecmd/default/do_help/emptyline/precmd/postcmd/parseline method names; IDENTCHARS type check, nonempty, contains '_'/'a'."
    - "This spec adds: Cmd.__bases__[0].__name__, Cmd.__qualname__; class-level attr types for PROMPT/identchars/ruler/lastcmd/doc_header; class-level value for PROMPT and ruler."
    - "cmd.Cmd.PROMPT is the class-level attribute (string '(Cmd) '); distinct from the instance attribute cmd.Cmd().prompt also == '(Cmd) '."
    - "cmd.Cmd.identchars is the per-instance copy of IDENTCHARS; its class is 'str'."
    - "cmd.Cmd.ruler is a class-level string attribute defaulting to '='; instances inherit it unless overridden."
    - "cmd.Cmd.lastcmd is a class-level string attribute defaulting to ''."
    - "cmd.Cmd.doc_header is a class-level string attribute giving the header for documented commands."
    - "cmd.Cmd.__bases__[0].__name__ == 'object' — Cmd inherits directly from object."
    - "cmd.Cmd.__qualname__ == 'Cmd' — no enclosing class scope."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Cmd — base class hierarchy (not in cmd.zspec or cmd_extra.zspec)
# ---------------------------------------------------------------------------

invariant cmd_extra2.Cmd.base_is_object:
  description: "cmd.Cmd.__bases__[0].__name__ == 'object' — Cmd inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Cmd.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Cmd — __qualname__ (not in cmd.zspec or cmd_extra.zspec)
# ---------------------------------------------------------------------------

invariant cmd_extra2.Cmd.qualname:
  description: "cmd.Cmd.__qualname__ == 'Cmd' — no enclosing class scope"
  category: class_names
  kind: python_call_eq
  function: Cmd.__qualname__.__eq__
  args: ["Cmd"]
  expected: true

# ---------------------------------------------------------------------------
# Cmd class-level attribute types
# cmd.zspec.zsdl tests instance attrs via Cmd(); we test class-level attrs directly.
# ---------------------------------------------------------------------------

invariant cmd_extra2.Cmd.PROMPT.class_is_str:
  description: "cmd.Cmd.PROMPT.__class__.__name__ == 'str' — PROMPT class attribute is a string"
  category: class_attrs
  kind: python_call_eq
  function: Cmd.PROMPT.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant cmd_extra2.Cmd.PROMPT.value:
  description: "cmd.Cmd.PROMPT == '(Cmd) '"
  category: class_attrs
  kind: python_call_eq
  function: Cmd.PROMPT.__eq__
  args: ["(Cmd) "]
  expected: true

invariant cmd_extra2.Cmd.identchars.class_is_str:
  description: "cmd.Cmd.identchars.__class__.__name__ == 'str' — identchars class attribute is a string"
  category: class_attrs
  kind: python_call_eq
  function: Cmd.identchars.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant cmd_extra2.Cmd.ruler.class_is_str:
  description: "cmd.Cmd.ruler.__class__.__name__ == 'str' — ruler class attribute is a string"
  category: class_attrs
  kind: python_call_eq
  function: Cmd.ruler.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant cmd_extra2.Cmd.ruler.value:
  description: "cmd.Cmd.ruler == '='"
  category: class_attrs
  kind: python_call_eq
  function: Cmd.ruler.__eq__
  args: ["="]
  expected: true

invariant cmd_extra2.Cmd.lastcmd.class_is_str:
  description: "cmd.Cmd.lastcmd.__class__.__name__ == 'str' — lastcmd class attribute is a string"
  category: class_attrs
  kind: python_call_eq
  function: Cmd.lastcmd.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant cmd_extra2.Cmd.doc_header.class_is_str:
  description: "cmd.Cmd.doc_header.__class__.__name__ == 'str' — doc_header class attribute is a string"
  category: class_attrs
  kind: python_call_eq
  function: Cmd.doc_header.__class__.__name__.__eq__
  args: ["str"]
  expected: true
