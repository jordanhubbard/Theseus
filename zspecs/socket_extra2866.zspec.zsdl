spec: sk2866
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 638 (_extra2866): __rand__, __ror__, __rxor__ dict-presence checks for socket types."
    - "socket.socket is the main socket class (network I/O); it defines no reflected bitwise operators."
    - "socket.AddressFamily and socket.SocketKind are IntFlag subclasses but do NOT define __rand__/__ror__/__rxor__ in their own __dict__."
    - "socket.AddressInfo and socket.MsgFlag are IntFlag subclasses that DO define __rand__, __ror__, and __rxor__ in their own __dict__ (verified True)."
    - "socket.error, socket.herror, socket.gaierror, socket.timeout are exception subclasses with no bitwise operator definitions."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk2866.rand:
  description: "socket types __rand__ dict-presence checks; wave 638"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2866
  columns: [id, function, args, expected]
  rows:
    - ["sk2866001", "socket.socket.__dict__.__contains__",        ["__rand__"], false]
    - ["sk2866002", "socket.AddressFamily.__dict__.__contains__", ["__rand__"], false]
    - ["sk2866003", "socket.SocketKind.__dict__.__contains__",    ["__rand__"], false]
    - ["sk2866004", "socket.AddressInfo.__dict__.__contains__",   ["__rand__"], true]
    - ["sk2866005", "socket.MsgFlag.__dict__.__contains__",       ["__rand__"], true]
    - ["sk2866006", "socket.error.__dict__.__contains__",         ["__rand__"], false]

