spec: multiprocessing_extra247
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "multiprocessing.Queue at the top level is a bound method (factory), not a class; the class is multiprocessing.queues.Queue accessed via the queues submodule attribute."
    - "multiprocessing.queues.Queue.__name__ == 'Queue' (len=5); __module__ == 'multiprocessing.queues' (len=22); __bases__[0].__name__ == 'object' (len=6)."
    - "Queue.put/get share name length 3 and qualname length 9; Queue.empty/qsize/close share name length 5 and qualname length 11; Queue.join_thread has the longest name (len=11) and qualname (len=17)."
    - "multiprocessing.queues.SimpleQueue.__name__ == 'SimpleQueue' (len=11); __module__ == 'multiprocessing.queues' (len=22); __bases__[0].__name__ == 'object' (len=6)."
    - "SimpleQueue.put/get share name length 3 and qualname length 15; SimpleQueue.empty/close share name length 5 and qualname length 17."
    - "SimpleQueue.__module__ and Queue.__module__ are identical: 'multiprocessing.queues' (len=22)."
    - "Queue has 6 methods (put, get, empty, qsize, close, join_thread); SimpleQueue has 4 (put, get, empty, close) — SimpleQueue omits qsize and join_thread."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

