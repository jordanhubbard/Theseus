table multiprocessing_extra247.queue_class_identity:
  description: "multiprocessing.queues.Queue(len=5) class identity — inherits from object(len=6); defined in multiprocessing.queues(len=22); put/get share qualname length 9; empty/qsize/close share qualname length 11; join_thread is longest qualname (len=17); verified with Python 3.14.3"
