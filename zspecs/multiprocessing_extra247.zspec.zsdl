invariant multiprocessing_extra247.queue_join_thread_longest_qualname:
  description: "multiprocessing.queues.Queue.join_thread.__qualname__.__len__() == 17 — 'Queue.join_thread' (len=17) is the longest method qualname among all Queue methods; empty/qsize/close tie at 11; put/get tie at 9; join_thread is also absent from SimpleQueue which provides only 4 methods (put, get, empty, close); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: queues.Queue.join_thread.__qualname__.__len__
  args: []
  expected: 17

invariant multiprocessing_extra247.both_queues_share_module:
  description: "multiprocessing.queues.SimpleQueue.__module__.__eq__('multiprocessing.queues') returns True — both Queue and SimpleQueue are defined in the same submodule 'multiprocessing.queues' (len=22); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: queues.SimpleQueue.__module__.__eq__
  args: ["multiprocessing.queues"]
  expected: true
