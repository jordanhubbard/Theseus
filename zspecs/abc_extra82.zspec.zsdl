spec: abc_extra82
version: ">=3.9"
backend: python_module(abc)
extends: abc_extra81

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra81.zspec.zsdl."
    - "This spec covers: wave 247 theme — abc.ABCMeta method __qualname__ string equality, abc.ABC.__dict__ membership, and qualname equality for module-level functions. NEW in extra82: ABCMeta.register.__qualname__=='ABCMeta.register'; ABCMeta.__dict__.__contains__('register')==True; ABCMeta.__dict__.__contains__('__instancecheck__')==True; ABCMeta.__dict__.__contains__('__subclasscheck__')==True; ABC.__dict__.__contains__('__abstractmethods__')==True; ABC.__dict__.__contains__('_abc_impl')==True; ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (accessible via class but not in ABC.__dict__); update_abstractmethods.__qualname__=='update_abstractmethods'; get_cache_token.__qualname__=='get_cache_token'; ABCMeta.__dict__.__class__.__name__=='mappingproxy'; ABC.__dict__.__class__.__name__=='mappingproxy'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register'. register is a method on ABCMeta with qualname prefixed by class name. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('register') == True. register is defined directly on ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('__instancecheck__') == True. __instancecheck__ is defined directly on ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__contains__('__subclasscheck__') == True. __subclasscheck__ is defined directly on ABCMeta. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__contains__('__abstractmethods__') == True. __abstractmethods__ is set directly on ABC (as an empty frozenset). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__contains__('_abc_impl') == True. _abc_impl is set directly on ABC by the ABCMeta metaclass. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__'. __subclasshook__ is accessible on the ABC class with this qualname, though it is not in ABC.__dict__ directly. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__qualname__ == 'update_abstractmethods'. Module-level function. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token'. C extension function in _abc. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'. Class __dict__ is always a mappingproxy in CPython. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__dict__.__class__.__name__ == 'mappingproxy'. Class __dict__ is always a mappingproxy in CPython. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc ABCMeta __dict__ membership — extra82
#
# Wave 247 theme: abc.ABCMeta method __qualname__ string equality,
# abc.ABC.__dict__ membership, and qualname equality for module-level functions.
#
# ABCMeta.__dict__.__contains__('register') == True
# ABCMeta.__dict__.__contains__('__instancecheck__') == True
# ABCMeta.__dict__.__contains__('__subclasscheck__') == True
# ABCMeta.register.__qualname__ == 'ABCMeta.register'
# ---------------------------------------------------------------------------

table abc_extra82.ABCMeta_dict_membership:
  description: "abc ABCMeta __dict__ membership and register __qualname__ checks in abcmethodid82 namespace — wave 247 theme: abc.ABCMeta method __qualname__ string equality and __dict__ membership; ABCMeta.__dict__.__contains__('register')==True; ABCMeta.__dict__.__contains__('__instancecheck__')==True; ABCMeta.__dict__.__contains__('__subclasscheck__')==True; ABCMeta.register.__qualname__=='ABCMeta.register' (qualname includes class prefix); all are class-level methods defined directly on ABCMeta; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmethodid82

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_has_register,          "ABCMeta.__dict__.__contains__", ["register"],          true, "ABCMeta.__dict__.__contains__('register') == True — register is defined directly on ABCMeta; verified with Python 3.14.3"]
    - [abcmeta_has_instancecheck,     "ABCMeta.__dict__.__contains__", ["__instancecheck__"], true, "ABCMeta.__dict__.__contains__('__instancecheck__') == True — __instancecheck__ is defined directly on ABCMeta; verified with Python 3.14.3"]
    - [abcmeta_has_subclasscheck,     "ABCMeta.__dict__.__contains__", ["__subclasscheck__"], true, "ABCMeta.__dict__.__contains__('__subclasscheck__') == True — __subclasscheck__ is defined directly on ABCMeta; verified with Python 3.14.3"]
    - [abcmeta_register_qualname,     ABCMeta.register.__qualname__.__eq__,                  ["ABCMeta.register"], true, "ABCMeta.register.__qualname__ == 'ABCMeta.register' — qualname includes class prefix; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc ABC __dict__ membership — extra82
#
# ABC.__dict__.__contains__('__abstractmethods__') == True
# ABC.__dict__.__contains__('_abc_impl') == True
# ---------------------------------------------------------------------------

table abc_extra82.ABC_dict_membership:
  description: "abc ABC __dict__ membership checks in abcmethodid82 namespace — wave 247 theme: abc.ABC.__dict__ membership; ABC.__dict__.__contains__('__abstractmethods__')==True (__abstractmethods__ is set directly on ABC as an empty frozenset by ABCMeta); ABC.__dict__.__contains__('_abc_impl')==True (_abc_impl is the C-level ABC implementation state, set by ABCMeta on all ABC subclasses); ABCMeta.__dict__.__contains__('register')==True (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmethodid82a

  columns: [id, function, args, expected, description]
  rows:
    - [abc_has_abstractmethods, "ABC.__dict__.__contains__", ["__abstractmethods__"], true, "ABC.__dict__.__contains__('__abstractmethods__') == True — __abstractmethods__ is set directly on ABC as an empty frozenset; verified with Python 3.14.3"]
    - [abc_has_abc_impl,        "ABC.__dict__.__contains__", ["_abc_impl"],           true, "ABC.__dict__.__contains__('_abc_impl') == True — _abc_impl is the C-level ABC implementation state set by ABCMeta; verified with Python 3.14.3"]
    - [abcmeta_has_reg_cross,   "ABCMeta.__dict__.__contains__", ["register"],        true, "ABCMeta.__dict__.__contains__('register') == True — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc module-level function __qualname__ equality — extra82
#
# ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__'
# update_abstractmethods.__qualname__ == 'update_abstractmethods'
# get_cache_token.__qualname__ == 'get_cache_token'
# ABCMeta.register.__qualname__ == 'ABCMeta.register' (cross-check)
# ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'
# ---------------------------------------------------------------------------

table abc_extra82.module_function_qualnames:
  description: "abc module function __qualname__ equality checks in abcmethodid82 namespace — wave 247 theme: qualname equality for module-level functions; ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (accessible via class with this qualname); update_abstractmethods.__qualname__=='update_abstractmethods' (simple module-level function name); get_cache_token.__qualname__=='get_cache_token' (C extension function); ABCMeta.register.__qualname__=='ABCMeta.register' (cross-check); ABCMeta.__instancecheck__.__qualname__=='ABCMeta.__instancecheck__'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmethodid82b

  columns: [id, function, args, expected, description]
  rows:
    - [abc_subclasshook_qualname,   ABC.__subclasshook__.__qualname__.__eq__,      ["ABC.__subclasshook__"],      true, "ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' — accessible via class with this qualname; verified with Python 3.14.3"]
    - [uam_qualname,                update_abstractmethods.__qualname__.__eq__,    ["update_abstractmethods"],   true, "update_abstractmethods.__qualname__ == 'update_abstractmethods' — simple module-level function name; verified with Python 3.14.3"]
    - [gct_qualname_cross,          get_cache_token.__qualname__.__eq__,           ["get_cache_token"],          true, "get_cache_token.__qualname__ == 'get_cache_token' — C extension function qualname; verified with Python 3.14.3"]
    - [abcmeta_reg_qualname_cross,  ABCMeta.register.__qualname__.__eq__,          ["ABCMeta.register"],         true, "ABCMeta.register.__qualname__ == 'ABCMeta.register' — cross-check; verified with Python 3.14.3"]
    - [abcmeta_ic_qualname,         ABCMeta.__instancecheck__.__qualname__.__eq__, ["ABCMeta.__instancecheck__"], true, "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — qualname includes class prefix; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc mappingproxy identity for ABCMeta and ABC — extra82
#
# ABCMeta.__dict__.__class__.__name__ == 'mappingproxy'
# ABC.__dict__.__class__.__name__ == 'mappingproxy'
# ABCMeta.__dict__.__contains__('__instancecheck__') == True (cross-check)
# ABCMeta.__dict__.__contains__('__subclasscheck__') == True (cross-check)
# ABC.__dict__.__contains__('__abstractmethods__') == True (cross-check)
# ---------------------------------------------------------------------------

table abc_extra82.mappingproxy_identity:
  description: "abc ABCMeta and ABC __dict__.__class__.__name__ mappingproxy identity checks in abcmethodid82 namespace — wave 247 theme: abc.ABCMeta method __qualname__ string equality; ABCMeta.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is always a mappingproxy in CPython); ABC.__dict__.__class__.__name__=='mappingproxy'; ABCMeta.__dict__.__contains__('__instancecheck__')==True (cross-check); ABCMeta.__dict__.__contains__('__subclasscheck__')==True (cross-check); ABC.__dict__.__contains__('__abstractmethods__')==True (cross-check); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmethodid82c

  columns: [id, function, args, expected, description]
  rows:
    - [abcmeta_dict_cls_name, "ABCMeta.__dict__.__class__.__name__.__eq__", ["mappingproxy"],       true, "ABCMeta.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [abc_dict_cls_name,     "ABC.__dict__.__class__.__name__.__eq__",     ["mappingproxy"],       true, "ABC.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [abcmeta_ic_cross,      "ABCMeta.__dict__.__contains__",              ["__instancecheck__"],  true, "ABCMeta.__dict__.__contains__('__instancecheck__') == True — cross-check; verified with Python 3.14.3"]
    - [abcmeta_sc_cross,      "ABCMeta.__dict__.__contains__",              ["__subclasscheck__"],  true, "ABCMeta.__dict__.__contains__('__subclasscheck__') == True — cross-check; verified with Python 3.14.3"]
    - [abc_am_cross,          "ABC.__dict__.__contains__",                  ["__abstractmethods__"], true, "ABC.__dict__.__contains__('__abstractmethods__') == True — cross-check; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra82
# ---------------------------------------------------------------------------

invariant abc_extra82.ABCMeta_has_register:
  description: "abc.ABCMeta.__dict__.__contains__('register') returns True — register is a class-level method defined directly on ABCMeta that allows registering virtual subclasses; NEW in extra82: first standalone __dict__.__contains__ invariant for ABCMeta.register in abcmethodid82 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__dict__.__contains__
  args: ["register"]
  expected: true

invariant abc_extra82.ABCMeta_has_instancecheck:
  description: "abc.ABCMeta.__dict__.__contains__('__instancecheck__') returns True — __instancecheck__ is defined directly on ABCMeta to customize isinstance() behavior; NEW in extra82: first standalone __dict__.__contains__ invariant for ABCMeta.__instancecheck__ in abcmethodid82 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__dict__.__contains__
  args: ["__instancecheck__"]
  expected: true

invariant abc_extra82.ABC_has_abstractmethods:
  description: "abc.ABC.__dict__.__contains__('__abstractmethods__') returns True — __abstractmethods__ is set directly on ABC as an empty frozenset by the ABCMeta metaclass; NEW in extra82: first standalone __dict__.__contains__ invariant for ABC.__abstractmethods__ in abcmethodid82 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABC.__dict__.__contains__
  args: ["__abstractmethods__"]
  expected: true

invariant abc_extra82.ABCMeta_register_qualname:
  description: "abc.ABCMeta.register.__qualname__.__eq__('ABCMeta.register') returns True — the __qualname__ for class methods includes the class name as a prefix; NEW in extra82: first standalone __qualname__ equality invariant for ABCMeta.register in abcmethodid82 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.register.__qualname__.__eq__
  args: ["ABCMeta.register"]
  expected: true

invariant abc_extra82.ABCMeta_dict_is_mappingproxy:
  description: "abc.ABCMeta.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — class __dict__ is always a mappingproxy in CPython; this confirms ABCMeta follows standard metaclass dict conventions; NEW in extra82: first standalone mappingproxy identity invariant for ABCMeta in abcmethodid82 namespace; wave 247; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: ABCMeta.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true
