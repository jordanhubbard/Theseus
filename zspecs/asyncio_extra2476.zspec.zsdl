    - "https://docs.python.org/3/library/asyncio-sync.html — Lock, Event, Semaphore"
    - "https://docs.python.org/3/library/asyncio-queue.html — Queue"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/asyncio/"
  notes:
    - "Theme: __contains__ and __getitem__ dict-presence — checking whether asyncio classes define membership test and item access protocol in their class __dict__."
    - "asyncio.Queue.__dict__.__contains__('__contains__') == False — Queue does not define __contains__; verified Python 3.14.4."
    - "asyncio.Queue.__dict__.__contains__('__getitem__') == False — Queue does not define __getitem__; verified Python 3.14.4."
    - "asyncio.Task.__dict__.__contains__('__contains__') == False — Task does not define __contains__; verified Python 3.14.4."
    - "asyncio.Future.__dict__.__contains__('__contains__') == False — Future does not define __contains__; verified Python 3.14.4."
    - "asyncio.Lock.__dict__.__contains__('__contains__') == False — Lock does not define __contains__; verified Python 3.14.4."
    - "asyncio.Event.__dict__.__contains__('__contains__') == False — Event does not define __contains__; verified Python 3.14.4."
    - "asyncio.Semaphore.__dict__.__contains__('__contains__') == False — Semaphore does not define __contains__; verified Python 3.14.4."
    - "Accessing a missing key via __dict__.__getitem__ raises KeyError for all asyncio classes; verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio class __dict__ __contains__ checks — __contains__ and __getitem__
# dict-presence theme
#
# None of the core asyncio synchronization/task classes define __contains__
# or __getitem__ in their own class __dict__. Keys that ARE present include
# standard slots like __init__, __repr__, __doc__, __module__.
# ---------------------------------------------------------------------------

table asyncio_extra2476.queue_dict_contains:
  description: "asyncio.Queue.__dict__.__contains__ checks — Queue defines __init__, __doc__, __repr__, _get, _put but NOT __contains__ or __getitem__; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2476

  columns: [id, function, args, expected]
  rows:
    - ["as2476001", asyncio.Queue.__dict__.__contains__, ["__init__"],      true]
    - ["as2476002", asyncio.Queue.__dict__.__contains__, ["__doc__"],       true]
    - ["as2476003", asyncio.Queue.__dict__.__contains__, ["__repr__"],      true]
    - ["as2476004", asyncio.Queue.__dict__.__contains__, ["__contains__"],  false]
    - ["as2476005", asyncio.Queue.__dict__.__contains__, ["__getitem__"],   false]

table asyncio_extra2476.task_dict_contains:
  description: "asyncio.Task.__dict__.__contains__ checks — Task defines __new__, __repr__, __iter__, __await__ but NOT __contains__ or __getitem__; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2476

  columns: [id, function, args, expected]
  rows:
    - ["as2476006", asyncio.Task.__dict__.__contains__, ["__new__"],       true]
    - ["as2476007", asyncio.Task.__dict__.__contains__, ["__repr__"],      true]
    - ["as2476008", asyncio.Task.__dict__.__contains__, ["__iter__"],      true]
    - ["as2476009", asyncio.Task.__dict__.__contains__, ["__contains__"],  false]
    - ["as2476010", asyncio.Task.__dict__.__contains__, ["__getitem__"],   false]

table asyncio_extra2476.future_dict_contains:
