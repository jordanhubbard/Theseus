  rows:
    - ["as2476011", asyncio.Future.__dict__.__contains__, ["__new__"],       true]
    - ["as2476012", asyncio.Future.__dict__.__contains__, ["__iter__"],      true]
    - ["as2476013", asyncio.Future.__dict__.__contains__, ["__repr__"],      true]
    - ["as2476014", asyncio.Future.__dict__.__contains__, ["__contains__"],  false]
    - ["as2476015", asyncio.Future.__dict__.__contains__, ["__getitem__"],   false]

table asyncio_extra2476.lock_event_semaphore_dict_contains:
  description: "asyncio.Lock, Event, Semaphore __dict__.__contains__ checks — none define __contains__ or __getitem__; all define __init__, __repr__, __doc__; verified Python 3.14.4"
  kind: python_call_eq
  category: dict_presence
  id_prefix: as2476

  columns: [id, function, args, expected]
  rows:
    - ["as2476016", asyncio.Lock.__dict__.__contains__,      ["__init__"],      true]
    - ["as2476017", asyncio.Lock.__dict__.__contains__,      ["acquire"],       true]
    - ["as2476018", asyncio.Lock.__dict__.__contains__,      ["__contains__"],  false]
    - ["as2476019", asyncio.Lock.__dict__.__contains__,      ["__getitem__"],   false]
    - ["as2476020", asyncio.Event.__dict__.__contains__,     ["__init__"],      true]
    - ["as2476021", asyncio.Event.__dict__.__contains__,     ["wait"],          true]
    - ["as2476022", asyncio.Event.__dict__.__contains__,     ["__contains__"],  false]
    - ["as2476023", asyncio.Event.__dict__.__contains__,     ["__getitem__"],   false]
    - ["as2476024", asyncio.Semaphore.__dict__.__contains__, ["__init__"],      true]
    - ["as2476025", asyncio.Semaphore.__dict__.__contains__, ["locked"],        true]
    - ["as2476026", asyncio.Semaphore.__dict__.__contains__, ["__contains__"],  false]
    - ["as2476027", asyncio.Semaphore.__dict__.__contains__, ["__getitem__"],   false]

# ---------------------------------------------------------------------------
# __getitem__ on class __dict__ raises KeyError for missing keys
# ---------------------------------------------------------------------------

table asyncio_extra2476.dict_getitem_raises:
  description: "asyncio class __dict__.__getitem__ raises KeyError for absent __contains__ and __getitem__ keys — none of these classes define those special methods; verified Python 3.14.4"
  kind: python_call_raises
  category: dict_presence
  id_prefix: as2476

  columns: [id, function, args, raises]
  rows:
    - ["as2476028", asyncio.Queue.__dict__.__getitem__,     ["__contains__"],  KeyError]
    - ["as2476029", asyncio.Queue.__dict__.__getitem__,     ["__getitem__"],   KeyError]
    - ["as2476030", asyncio.Task.__dict__.__getitem__,      ["__contains__"],  KeyError]
    - ["as2476031", asyncio.Future.__dict__.__getitem__,    ["__contains__"],  KeyError]
    - ["as2476032", asyncio.Lock.__dict__.__getitem__,      ["__contains__"],  KeyError]
    - ["as2476033", asyncio.Event.__dict__.__getitem__,     ["__getitem__"],   KeyError]
    - ["as2476034", asyncio.Semaphore.__dict__.__getitem__, ["__nonexistent__"], KeyError]
