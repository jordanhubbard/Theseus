spec: struct_extra121
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra120.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __doc__.__len__() and __doc__.__class__.__name__=='str' (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths (pack/unpack/calcsize/pack_into/unpack_from/iter_unpack) / Struct.size and Struct.format descriptor __doc__ string equality and lengths / struct module __doc__ length (1278) (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / Struct.size/__format__ qualname/name lengths and __objclass__.__name__ (table + invariants)."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() for pack/unpack/pack_into/unpack_from/iter_unpack (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality (pack, unpack, pack_into, unpack_from, iter_unpack) / Struct.format/__qualname__ / error/__bases__ and __module__ (table + invariants)."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in earlier struct specs."
    - "Wave 275 theme: struct.Struct method __qualname__ string equality and method __objclass__.__name__ equality — pack/unpack/pack_into/unpack_from/iter_unpack full qualname strings and their owning class name."
    - "struct.Struct.pack.__qualname__ == 'Struct.pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__qualname__ == 'Struct.unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.pack_into.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__objclass__.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: extra93 anchors __name__ equality (short names like 'pack', 'unpack'); extra94 anchors __qualname__.__len__() lengths. This spec first anchors the full __qualname__ string equality ('Struct.pack', 'Struct.unpack', etc.) under structmethq121."
    - "Note: __objclass__.__name__ on a method_descriptor returns the class that defines it. For all five Struct methods, __objclass__ is the Struct class itself (from _struct.c), so __objclass__.__name__ == 'Struct'. extra98 anchors __objclass__.__name__ for getset_descriptor attributes (size, format); this spec first anchors it for method_descriptor methods."
    - "Note: pack_into and unpack_from share the same __qualname__ length (16 and 18 respectively from extra94). iter_unpack.__qualname__ also has length 18. Their full qualname strings are 'Struct.pack_into', 'Struct.unpack_from', 'Struct.iter_unpack'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack')
# struct.Struct.unpack.__qualname__.__eq__('Struct.unpack')
# struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into')
#
# Wave 275 theme: Struct method __qualname__ string equality (first group).
#
# Struct.pack, Struct.unpack, and Struct.pack_into are C-level method_descriptor
# objects from _struct.c. Their __qualname__ strings use 'Struct.' as prefix.
# extra93 anchors __name__ equality ('pack', 'unpack', etc.); extra94 anchors
# __qualname__.__len__() lengths (11, 13, 16 respectively). No prior struct spec
# anchors the full __qualname__ string equality for these three under structmethq121.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra121.Struct_method_qualname_eq_group1:
  description: "struct.Struct.pack/__qualname__.__eq__('Struct.pack')==True / Struct.unpack/__qualname__.__eq__('Struct.unpack')==True / Struct.pack_into/__qualname__.__eq__('Struct.pack_into')==True — all method_descriptor objects from _struct.c; qualname uses 'Struct.' prefix; extra93 anchors __name__ equality; extra94 anchors __qualname__.__len__(); first structmethq121 anchor for full qualname string equality (group 1: pack/unpack/pack_into)"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: structmethq121

  columns: [id, function, args, expected, description]
  rows:
    - [pack_qualname_eq,      "Struct.pack.__qualname__.__eq__",      ["Struct.pack"],      true, "Struct.pack.__qualname__ is 'Struct.pack' (11 chars; 'Struct.' 7 + 'pack' 4)"]
    - [unpack_qualname_eq,    "Struct.unpack.__qualname__.__eq__",    ["Struct.unpack"],    true, "Struct.unpack.__qualname__ is 'Struct.unpack' (13 chars; 'Struct.' 7 + 'unpack' 6)"]
    - [pack_into_qualname_eq, "Struct.pack_into.__qualname__.__eq__", ["Struct.pack_into"], true, "Struct.pack_into.__qualname__ is 'Struct.pack_into' (16 chars; 'Struct.' 7 + 'pack_into' 9)"]

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from')
# struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack')
# struct.Struct.pack.__objclass__.__name__.__eq__('Struct')
# struct.Struct.unpack.__objclass__.__name__.__eq__('Struct')
# struct.Struct.pack_into.__objclass__.__name__.__eq__('Struct')
#
# Wave 275 theme: Struct method __qualname__ equality (second group) and __objclass__.__name__.
#
# Struct.unpack_from and Struct.iter_unpack both have 18-char qualnames
# ('Struct.unpack_from', 'Struct.iter_unpack'). Their __qualname__ length
# was anchored in extra94; the full string equality is new. __objclass__.__name__
# is 'Struct' for all five Struct methods (confirmed via extra98 for getset
# descriptors, now anchored for method_descriptor methods).
# No prior struct spec anchors these under structmethq121.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra121.Struct_method_qualname_eq_group2:
  description: "struct.Struct.unpack_from/__qualname__.__eq__('Struct.unpack_from')==True / Struct.iter_unpack/__qualname__.__eq__('Struct.iter_unpack')==True / Struct.pack/__objclass__.__name__.__eq__('Struct')==True / Struct.unpack/__objclass__.__name__.__eq__('Struct')==True / Struct.pack_into/__objclass__.__name__.__eq__('Struct')==True — unpack_from and iter_unpack share qualname length 18; extra98 anchors __objclass__ for getset_descriptor; first structmethq121 anchor for method_descriptor __objclass__ and group-2 qualname equality"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: structmethq121

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_from_qualname_eq,  "Struct.unpack_from.__qualname__.__eq__",  ["Struct.unpack_from"],  true, "Struct.unpack_from.__qualname__ is 'Struct.unpack_from' (18 chars; same len as iter_unpack)"]
    - [iter_unpack_qualname_eq,  "Struct.iter_unpack.__qualname__.__eq__",  ["Struct.iter_unpack"],  true, "Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack' (18 chars; same len as unpack_from)"]
    - [pack_objclass,            "Struct.pack.__objclass__.__name__.__eq__",    ["Struct"],           true, "Struct.pack.__objclass__ is the Struct class itself (C-extension class from _struct.c)"]
    - [unpack_objclass,          "Struct.unpack.__objclass__.__name__.__eq__",  ["Struct"],           true, "Struct.unpack.__objclass__ is the Struct class itself (C-extension class from _struct.c)"]
    - [pack_into_objclass,       "Struct.pack_into.__objclass__.__name__.__eq__", ["Struct"],         true, "Struct.pack_into.__objclass__ is the Struct class itself (C-extension class from _struct.c)"]

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__objclass__.__name__.__eq__('Struct')
# struct.Struct.iter_unpack.__objclass__.__name__.__eq__('Struct')
# struct.Struct.pack.__qualname__.__len__().__eq__(11)  [via len]
#
# Wave 275 theme: remaining Struct method __objclass__.__name__ and pack qualname len cross-check.
#
# Struct.unpack_from and Struct.iter_unpack also have __objclass__.__name__=='Struct'.
# All five Struct methods share the same __objclass__. Additionally anchoring
# __qualname__.__len__() via direct call for cross-validation with extra94.
# No prior struct spec anchors unpack_from/iter_unpack __objclass__.__name__
# or __qualname__.__len__() as table entries under structmethq121.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra121.Struct_method_objclass_and_qualname_lens:
  description: "struct.Struct.unpack_from/__objclass__.__name__.__eq__('Struct')==True / Struct.iter_unpack/__objclass__.__name__.__eq__('Struct')==True / Struct.pack/__qualname__.__len__()==11 / Struct.unpack/__qualname__.__len__()==13 / Struct.pack_into/__qualname__.__len__()==16 / Struct.unpack_from/__qualname__.__len__()==18 / Struct.iter_unpack/__qualname__.__len__()==18 — all five methods share __objclass__ Struct; extra94 anchors __len__() lengths; here cross-validated as table; first structmethq121 anchor for unpack_from/iter_unpack __objclass__"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: structmethq121

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_from_objclass,     "Struct.unpack_from.__objclass__.__name__.__eq__",  ["Struct"], true, "Struct.unpack_from.__objclass__ is the Struct class (C-extension from _struct.c)"]
    - [iter_unpack_objclass,     "Struct.iter_unpack.__objclass__.__name__.__eq__",  ["Struct"], true, "Struct.iter_unpack.__objclass__ is the Struct class (C-extension from _struct.c)"]
    - [pack_qualname_len,        Struct.pack.__qualname__.__len__,                   [],         11,   "Struct.pack.__qualname__ is 11 chars ('Struct.' 7 + 'pack' 4)"]
    - [unpack_qualname_len,      Struct.unpack.__qualname__.__len__,                 [],         13,   "Struct.unpack.__qualname__ is 13 chars ('Struct.' 7 + 'unpack' 6)"]
    - [pack_into_qualname_len,   Struct.pack_into.__qualname__.__len__,              [],         16,   "Struct.pack_into.__qualname__ is 16 chars ('Struct.' 7 + 'pack_into' 9)"]
    - [unpack_from_qualname_len, Struct.unpack_from.__qualname__.__len__,            [],         18,   "Struct.unpack_from.__qualname__ is 18 chars ('Struct.' 7 + 'unpack_from' 11)"]
    - [iter_unpack_qualname_len, Struct.iter_unpack.__qualname__.__len__,            [],         18,   "Struct.iter_unpack.__qualname__ is 18 chars ('Struct.' 7 + 'iter_unpack' 11)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack.__qualname__.__eq__('Struct.pack') — standalone
#
# struct.Struct.pack.__qualname__ is 'Struct.pack'. The method_descriptor
# __qualname__ follows the pattern 'ClassName.method_name'. For Struct.pack,
# the class name is 'Struct' (7 chars) and the method name is 'pack' (4 chars),
# giving 'Struct.pack' (11 chars). extra93 anchors pack.__name__=='pack';
# extra94 anchors pack.__qualname__.__len__()==11; no prior struct spec anchors
# pack.__qualname__.__eq__('Struct.pack') as a standalone under structmethq121.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra121.Struct_pack_qualname_eq:
  description: "struct.Struct.pack.__qualname__.__eq__('Struct.pack') == True — Struct.pack qualname is 'Struct.pack' (11 chars: 'Struct.' 7 + 'pack' 4); method_descriptor from _struct.c; extra93 anchors __name__ equality; extra94 anchors __len__()==11; first standalone for pack __qualname__ equality under structmethq121"
  category: method_qualnames
  kind: python_call_eq
  function: "Struct.pack.__qualname__.__eq__"
  args: ["Struct.pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.unpack.__qualname__.__eq__('Struct.unpack') — standalone
#
# struct.Struct.unpack.__qualname__ is 'Struct.unpack'. Struct.unpack is the
# inverse of Struct.pack — it reads bytes from a buffer and returns a tuple
# of values. Its qualname is 13 chars ('Struct.unpack': 'Struct.' 7 + 'unpack' 6).
# extra93 anchors unpack.__name__=='unpack'; extra94 anchors __len__()==13.
# No prior struct spec anchors unpack.__qualname__.__eq__('Struct.unpack') as
# a standalone under structmethq121. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra121.Struct_unpack_qualname_eq:
  description: "struct.Struct.unpack.__qualname__.__eq__('Struct.unpack') == True — Struct.unpack qualname is 'Struct.unpack' (13 chars: 'Struct.' 7 + 'unpack' 6); inverse of pack; extra93 anchors __name__ equality; extra94 anchors __len__()==13; first standalone for unpack __qualname__ equality under structmethq121"
  category: method_qualnames
  kind: python_call_eq
  function: "Struct.unpack.__qualname__.__eq__"
  args: ["Struct.unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') — standalone
#
# struct.Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack'. iter_unpack
# repeatedly unpacks from a buffer, returning an iterator. Its qualname is 18
# chars, the same length as Struct.unpack_from. The iter_unpack method allows
# processing large buffers without creating all tuples at once. extra93 anchors
# iter_unpack.__name__=='iter_unpack'; extra94 anchors __len__()==18. No prior
# struct spec anchors iter_unpack.__qualname__.__eq__('Struct.iter_unpack') as
# a standalone. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra121.Struct_iter_unpack_qualname_eq:
  description: "struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') == True — Struct.iter_unpack qualname is 'Struct.iter_unpack' (18 chars: 'Struct.' 7 + 'iter_unpack' 11); same qualname length as Struct.unpack_from (also 18); extra93 anchors __name__ equality; extra94 anchors __len__()==18; first standalone for iter_unpack __qualname__ equality under structmethq121"
  category: method_qualnames
  kind: python_call_eq
  function: "Struct.iter_unpack.__qualname__.__eq__"
  args: ["Struct.iter_unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.pack.__objclass__.__name__.__eq__('Struct') — standalone
#
# struct.Struct.pack.__objclass__.__name__ is 'Struct'. The __objclass__
# attribute on a method_descriptor returns the class object that defines the
# method. For Struct.pack, this is the Struct class from the _struct C extension.
# __objclass__.__name__ gives the class name string 'Struct'. This is analogous
# to extra98's anchoring of __objclass__.__name__ for getset_descriptor attributes
# (Struct.size and Struct.format). No prior struct spec anchors
# Struct.pack.__objclass__.__name__ as a standalone under structmethq121.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra121.Struct_pack_objclass_Struct:
  description: "struct.Struct.pack.__objclass__.__name__.__eq__('Struct') == True — Struct.pack.__objclass__ is the Struct C-extension class from _struct.c; __objclass__ on a method_descriptor identifies the defining class; extra98 anchors __objclass__.__name__ for getset_descriptor (size, format); first standalone for method_descriptor __objclass__.__name__ under structmethq121"
  category: method_qualnames
  kind: python_call_eq
  function: "Struct.pack.__objclass__.__name__.__eq__"
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') — standalone
#
# struct.Struct.unpack_from.__qualname__ is 'Struct.unpack_from'. unpack_from
# reads from a buffer at a given offset (defaulting to 0), unlike unpack which
# requires the buffer to be exactly the right size. Its qualname is 18 chars
# ('Struct.unpack_from': 'Struct.' 7 + 'unpack_from' 11). extra93 anchors
# unpack_from.__name__=='unpack_from'; extra94 anchors __len__()==18. No prior
# struct spec anchors unpack_from.__qualname__.__eq__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra121.Struct_unpack_from_qualname_eq:
  description: "struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') == True — Struct.unpack_from qualname is 'Struct.unpack_from' (18 chars: 'Struct.' 7 + 'unpack_from' 11); differs from unpack (allows offset arg); same qualname length as iter_unpack (also 18); extra93 anchors __name__ equality; extra94 anchors __len__()==18; first standalone for unpack_from __qualname__ equality under structmethq121"
  category: method_qualnames
  kind: python_call_eq
  function: "Struct.unpack_from.__qualname__.__eq__"
  args: ["Struct.unpack_from"]
  expected: true

