spec: wrapt_rust
version: ">=3.9"
backend: rust_module(wrapt_rust)

docs: https://wrapt.readthedocs.io/en/latest/

provenance:
  derived_from:
    - "https://wrapt.readthedocs.io/ — wrapt documentation"
  not_derived_from:
    - "wrapt source: src/wrapt/wrappers.py"
  notes:
    - "wrapt.ObjectProxy wraps a Python object, delegating most attribute access to the wrapped object."
    - "ObjectProxy(42).__wrapped__ == 42 — access the wrapped value."
    - "ObjectProxy('hello').__wrapped__ == 'hello'."
    - "ObjectProxy(42) == 42 — comparison delegates to wrapped value."
    - "ObjectProxy([1,2,3]).__wrapped__ == [1,2,3]."
    - "Expose object_proxy_wrapped(value) -> wrapped value for safe __wrapped__ access."
    - "Expose object_proxy_eq(value, other) -> bool for equality testing."
    - "All test vectors verified against wrapt 1.17.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# ObjectProxy.__wrapped__ — access wrapped value
table wrapt_rust.ObjectProxy.wrapped:
  kind: python_call_eq
  category: wrapped
  id_prefix: wr_wp
  function: ObjectProxy
  method: __wrapped__

  columns: [id, args, expected]
  rows:
    - [int_42,    [42],          42]
    - [str_hello, ["hello"],     "hello"]
    - [float_pi,  [3.14],        3.14]
    - [list_123,  [[1, 2, 3]],  [1, 2, 3]]
    - [bool_true, [true],        true]
    - [zero,      [0],           0]

# ObjectProxy equality — delegates to wrapped value
table wrapt_rust.ObjectProxy.equality:
  kind: python_call_eq
  category: equality
  id_prefix: wr_eq
  function: ObjectProxy
  method: __eq__
  method_args: [42]

  columns: [id, args, expected]
  rows:
    - [int_equal,   [42],  true]
    - [int_unequal, [99],  false]
    - [zero,        [0],   false]

