spec: io_extra96
version: ">=3.9"
backend: python_module(io)
extends: io_extra95

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/_pyio.py"
  notes:
    - "This spec extends io.zspec.zsdl and all prior io_extra specs through io_extra95."
    - "Prior specs covered: class names/modules/bases; DEFAULT_BUFFER_SIZE; SEEK_* constants; UnsupportedOperation; StringIO/BytesIO instance methods; open.__name__/__module__; IOBase/RawIOBase/BufferedIOBase/TextIOBase method descriptor checks; IOBase/__dict__ membership; FileIO/BytesIO/StringIO __bases__[0].__name__ and MRO lengths; FileIO/BytesIO/StringIO __dict__/__class__.__name__ and membership; BufferedReader/BufferedWriter/TextIOWrapper identity and MRO; BufferedRandom/__name__/__module__/bases/MRO; BufferedRWPair identity and hierarchy; IncrementalNewlineDecoder identity; TextIOWrapper/__name__/__module__/bases/MRO; StringIO/__name__/__module__/bases/MRO; FileIO/__name__/__module__/bases/MRO; BytesIO/__name__/__module__/bases/MRO; __mro__.__len__() for all classes; __name__ and __module__ string equality for all io classes; BytesIO/StringIO __dict__ membership for read/write/readable/writable/seekable/truncate/readline; io_extra93 covered __bases__[0].__name__ for IOBase, RawIOBase, FileIO, BufferedReader."
    - "This spec covers: __bases__[0].__name__ for the remaining io classes not covered in io_extra93: BufferedIOBase, TextIOBase, BufferedWriter, BytesIO, StringIO, TextIOWrapper."
    - "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' — BufferedIOBase inherits from the C-level _BufferedIOBase type."
    - "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' — TextIOBase inherits from the C-level _TextIOBase type."
    - "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' — BufferedWriter is a C-level class inheriting directly from _BufferedIOBase."
    - "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' — BytesIO is a C-level class inheriting directly from _BufferedIOBase."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — StringIO is a C-level class inheriting directly from _TextIOBase."
    - "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' — TextIOWrapper is a C-level class inheriting directly from _TextIOBase."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io abstract base class __bases__[0].__name__: BufferedIOBase and TextIOBase
# These are the Python-level ABC wrappers; they inherit from their C-level
# counterparts (_BufferedIOBase and _TextIOBase) as first base.
# io_extra93 already covered IOBase and RawIOBase; this covers the remaining ABCs.
# ---------------------------------------------------------------------------

table io_extra96.abstract_base_bases_names:
  description: "io.BufferedIOBase/TextIOBase __bases__[0].__name__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobasehier96

  columns: [id, function, args, expected]
  rows:
    - [bufiobase_base0,   "BufferedIOBase.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true]
    - [textiobase_base0,  "TextIOBase.__bases__[0].__name__.__eq__",     ["_TextIOBase"],     true]
    - [iobase_base0_neg,  "BufferedIOBase.__bases__[0].__name__.__eq__", ["_TextIOBase"],     false]
    - [textiobase_not_buf, "TextIOBase.__bases__[0].__name__.__eq__",    ["_BufferedIOBase"], false]

# ---------------------------------------------------------------------------
# io.BufferedReader/BufferedWriter/BufferedRandom __bases__[0].__name__
# All three concrete buffered classes inherit directly from _BufferedIOBase.
# BufferedReader is covered in io_extra93; BufferedWriter is new here.
# ---------------------------------------------------------------------------

table io_extra96.buffered_rw_bases_names:
  description: "io.BufferedReader/BufferedWriter __bases__[0].__name__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobasehier96

  columns: [id, function, args, expected]
  rows:
    - [bufreader_base0,   "BufferedReader.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true]
    - [bufwriter_base0,   "BufferedWriter.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true]
    - [bufwriter_not_raw, "BufferedWriter.__bases__[0].__name__.__eq__", ["_RawIOBase"],      false]
    - [bufreader_not_text, "BufferedReader.__bases__[0].__name__.__eq__", ["_TextIOBase"],    false]

# ---------------------------------------------------------------------------
# io.BytesIO/StringIO __bases__[0].__name__
# BytesIO inherits from _BufferedIOBase; StringIO from _TextIOBase.
# These concrete classes skip the Python ABC wrappers entirely.
# ---------------------------------------------------------------------------

table io_extra96.bytesio_stringio_bases_names:
  description: "io.BytesIO/StringIO __bases__[0].__name__ string equality"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobasehier96

  columns: [id, function, args, expected]
  rows:
    - [bytesio_base0,         "BytesIO.__bases__[0].__name__.__eq__",   ["_BufferedIOBase"], true]
    - [stringio_base0,        "StringIO.__bases__[0].__name__.__eq__",  ["_TextIOBase"],     true]
    - [bytesio_not_textbase,  "BytesIO.__bases__[0].__name__.__eq__",   ["_TextIOBase"],     false]
    - [stringio_not_bufbase,  "StringIO.__bases__[0].__name__.__eq__",  ["_BufferedIOBase"], false]

# ---------------------------------------------------------------------------
# io.TextIOWrapper __bases__[0].__name__ + cross-checks
# TextIOWrapper inherits from _TextIOBase (same as StringIO).
# Cross-check: BytesIO and StringIO have different base class names.
# ---------------------------------------------------------------------------

table io_extra96.textiowrapper_bases_cross_checks:
  description: "io.TextIOWrapper __bases__[0].__name__; cross-checks with BytesIO/StringIO"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobasehier96

  columns: [id, function, args, expected]
  rows:
    - [textwrapper_base0,      "TextIOWrapper.__bases__[0].__name__.__eq__", ["_TextIOBase"],     true]
    - [textwrapper_same_as_stringio, "TextIOWrapper.__bases__[0].__name__.__eq__", ["_TextIOBase"], true]
    - [textwrapper_not_bufbase, "TextIOWrapper.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], false]
    - [textwrapper_not_rawbase, "TextIOWrapper.__bases__[0].__name__.__eq__", ["_RawIOBase"],      false]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra96.BufferedIOBase.base0_name:
  description: "io.BufferedIOBase.__bases__[0].__name__ == '_BufferedIOBase' (Python ABC wrapper over C-level _BufferedIOBase)"
  category: class_identity
  kind: python_call_eq
  function: "BufferedIOBase.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra96.TextIOBase.base0_name:
  description: "io.TextIOBase.__bases__[0].__name__ == '_TextIOBase' (Python ABC wrapper over C-level _TextIOBase)"
  category: class_identity
  kind: python_call_eq
  function: "TextIOBase.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra96.BufferedWriter.base0_name:
  description: "io.BufferedWriter.__bases__[0].__name__ == '_BufferedIOBase' (concrete C-level class; inherits directly from _BufferedIOBase)"
  category: class_identity
  kind: python_call_eq
  function: "BufferedWriter.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra96.BytesIO.base0_name:
  description: "io.BytesIO.__bases__[0].__name__ == '_BufferedIOBase' (concrete C-level class; skips Python ABC layer)"
  category: class_identity
  kind: python_call_eq
  function: "BytesIO.__bases__[0].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true

invariant io_extra96.TextIOWrapper.base0_name:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (concrete C-level class; same base as StringIO)"
  category: class_identity
  kind: python_call_eq
  function: "TextIOWrapper.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true
