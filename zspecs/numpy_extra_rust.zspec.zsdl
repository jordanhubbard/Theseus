spec: numpy_extra_rust
version: ">=3.9"
backend: rust_module(numpy_extra_rust)

docs: https://numpy.org/doc/stable/reference/ufuncs.html

provenance:
  derived_from:
    - "https://numpy.org/doc/stable/reference/ufuncs.html — NumPy ufunc documentation"
  not_derived_from:
    - "NumPy source: numpy/core/src/"
  notes:
    - "Additional NumPy scalar ufuncs: sign, clip, log2, log10, isfinite, isinf, isnan."
    - "sign(-5) == -1, sign(0) == 0, sign(3) == 1."
    - "clip(5, 1, 10) == 5, clip(-1, 0, 10) == 0, clip(15, 0, 10) == 10."
    - "log2(8) == 3.0, log2(1) == 0.0."
    - "log10(1000) == 3.0, log10(1) == 0.0."
    - "isfinite(1.0) == True, isinf(1.0) == False, isnan(1.0) == False."
    - "numpy bool_ compares equal to Python True/False via ==."
    - "All test vectors verified against numpy 2.4.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# sign — return -1, 0, or 1
table numpy_extra_rust.sign.vectors:
  kind: python_call_eq
  category: sign
  id_prefix: np_sign
  function: sign

  columns: [id, args, expected]
  rows:
    - [negative, [-5],  -1]
    - [zero,     [0],   0]
    - [positive, [3],   1]
    - [neg_flt,  [-2.5], -1]
    - [pos_flt,  [7.0],  1]

# clip — clamp value to [min, max]
table numpy_extra_rust.clip.vectors:
  kind: python_call_eq
  category: clip
  id_prefix: np_clip
  function: clip

  columns: [id, args, expected]
  rows:
    - [in_range,  [5,  1, 10], 5]
    - [below_min, [-1, 0, 10], 0]
    - [above_max, [15, 0, 10], 10]
    - [at_min,    [0,  0, 10], 0]
    - [at_max,    [10, 0, 10], 10]

# log2 and log10
table numpy_extra_rust.log2.vectors:
  kind: python_call_eq
  category: log2
  id_prefix: np_log2
  function: log2

  columns: [id, args, expected]
  rows:
    - [log2_8, [8.0], 3.0]
    - [log2_1, [1.0], 0.0]
    - [log2_2, [2.0], 1.0]

table numpy_extra_rust.log10.vectors:
  kind: python_call_eq
  category: log10
  id_prefix: np_log10
  function: log10

  columns: [id, args, expected]
  rows:
    - [log10_1000, [1000.0], 3.0]
    - [log10_1,    [1.0],    0.0]
    - [log10_100,  [100.0],  2.0]

# Boolean ufuncs — finite values only
table numpy_extra_rust.isfinite.vectors:
  kind: python_call_eq
  category: isfinite
  id_prefix: np_isfinite
  function: isfinite

  columns: [id, args, expected]
  rows:
    - [finite_one,  [1.0],  true]
    - [finite_zero, [0.0],  true]
    - [finite_neg,  [-5.0], true]

table numpy_extra_rust.isinf.vectors:
  kind: python_call_eq
  category: isinf
  id_prefix: np_isinf
  function: isinf

  columns: [id, args, expected]
  rows:
    - [finite_one,  [1.0],  false]
    - [finite_zero, [0.0],  false]

table numpy_extra_rust.isnan.vectors:
  kind: python_call_eq
  category: isnan
  id_prefix: np_isnan
  function: isnan

  columns: [id, args, expected]
  rows:
    - [finite_one,  [1.0],  false]
    - [finite_zero, [0.0],  false]

