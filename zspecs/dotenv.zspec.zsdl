spec: dotenv
version: ">=0.19"
backend: python_module(dotenv)

docs: https://pypi.org/project/python-dotenv/

provenance:
  derived_from:
    - "python-dotenv documentation — https://saurabh-kumar.com/python-dotenv/"
    - "PyPI package page — https://pypi.org/project/python-dotenv/"
    - "Test vectors verified with python-dotenv 1.2.2 on Python 3.14 / macOS Darwin 25.4.0, 2026-04-05"
  not_derived_from:
    - "python-dotenv source: dotenv/main.py"
    - "python-dotenv source: dotenv/parser.py"
  notes:
    - "The PyPI package is 'python-dotenv' but imported as 'dotenv'."
    - "dotenv has no __version__ attribute; version is accessed via importlib.metadata."
    - "dotenv_values('/nonexistent') returns an empty OrderedDict without raising."
    - "get_key('/nonexistent', 'KEY') returns None without raising."
    - "__all__ lists the public API: load_dotenv, dotenv_values, find_dotenv, get_key, set_key, unset_key, find_dotenv."
  created_at: "2026-04-05T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# version — module name check via __name__
# ---------------------------------------------------------------------------

invariant dotenv.version.module_name:
  description: "dotenv.__name__ == 'dotenv' — module imported under expected name"
  category: version
  kind: python_call_eq
  function: __name__.__eq__
  args: ["dotenv"]
  expected: true

# ---------------------------------------------------------------------------
# api — public functions present in __all__
# ---------------------------------------------------------------------------

invariant dotenv.api.all_contains_load_dotenv:
  description: "__all__ contains 'load_dotenv'"
  category: api
  kind: python_call_eq
  function: __all__.__contains__
  args: ["load_dotenv"]
  expected: true

invariant dotenv.api.all_contains_dotenv_values:
  description: "__all__ contains 'dotenv_values'"
  category: api
  kind: python_call_eq
  function: __all__.__contains__
  args: ["dotenv_values"]
  expected: true

invariant dotenv.api.all_contains_find_dotenv:
  description: "__all__ contains 'find_dotenv'"
  category: api
  kind: python_call_eq
  function: __all__.__contains__
  args: ["find_dotenv"]
  expected: true

invariant dotenv.api.all_contains_get_key:
  description: "__all__ contains 'get_key'"
  category: api
  kind: python_call_eq
  function: __all__.__contains__
  args: ["get_key"]
  expected: true

invariant dotenv.api.all_contains_set_key:
  description: "__all__ contains 'set_key'"
  category: api
  kind: python_call_eq
  function: __all__.__contains__
  args: ["set_key"]
  expected: true

invariant dotenv.api.all_contains_unset_key:
  description: "__all__ contains 'unset_key'"
  category: api
  kind: python_call_eq
  function: __all__.__contains__
  args: ["unset_key"]
  expected: true

# ---------------------------------------------------------------------------
# function names — callable identity check via __name__ attribute
# ---------------------------------------------------------------------------

invariant dotenv.function_names.load_dotenv:
  description: "load_dotenv.__name__ == 'load_dotenv'"
  category: function_names
  kind: python_call_eq
  function: load_dotenv.__name__.__eq__
  args: ["load_dotenv"]
  expected: true

invariant dotenv.function_names.dotenv_values:
  description: "dotenv_values.__name__ == 'dotenv_values'"
  category: function_names
  kind: python_call_eq
  function: dotenv_values.__name__.__eq__
  args: ["dotenv_values"]
  expected: true

invariant dotenv.function_names.find_dotenv:
  description: "find_dotenv.__name__ == 'find_dotenv'"
  category: function_names
  kind: python_call_eq
  function: find_dotenv.__name__.__eq__
  args: ["find_dotenv"]
  expected: true

# ---------------------------------------------------------------------------
# parse — dotenv_values with nonexistent path returns empty mapping
# ---------------------------------------------------------------------------

invariant dotenv.parse.nonexistent_path_empty:
  description: "dotenv_values('/nonexistent/.env') returns empty mapping (len == 0)"
  category: parse
  kind: python_call_eq
  function: dotenv_values
  args: ["/nonexistent/.env"]
  method: __len__
  expected: 0

invariant dotenv.parse.nonexistent_path_get_returns_none:
  description: "dotenv_values('/nonexistent/.env').get('KEY') returns None"
  category: parse
  kind: python_call_eq
  function: dotenv_values
  args: ["/nonexistent/.env"]
  method: get
  method_args: ["ANY_KEY"]
  expected: ~
