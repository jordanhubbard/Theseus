spec: pathlib_extra70
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "pathlib_extra69.zspec.zsdl — covers Path.open/__defaults__.__class__.__name__.__eq__('tuple') and __len__()==5; Path.read_text/__defaults__.__class__.__name__.__eq__('tuple') and __len__()==3; Path.open/__code__.__class__.__name__.__eq__('code'); Path.__init__/__code__.__class__.__name__.__eq__('code'); Path.__doc__.__contains__('PurePath') and __contains__('system')."
    - "pathlib_extra68.zspec.zsdl — covers Path.open/__annotations__/__globals__ class identity; PurePath.__doc__.__contains__('path') and __contains__('Base')."
    - "pathlib_extra67.zspec.zsdl — covers PurePath/__str__/__repr__/__fspath__/__eq__/__hash__ __qualname__.__eq__(); Path.open/read_text/write_text __qualname__.__eq__()."
    - "pathlib_extra66.zspec.zsdl — covers pathlib.__loader__/__spec__ class identity checks."
    - "pathlib_extra65.zspec.zsdl — covers pathlib.__loader__/__spec__/__file__/__cached__ class identity."
  notes:
    - "This spec extends pathlib_extra69.zspec.zsdl."
    - "Wave 230 theme: __code__ deep chains for Python functions + docstring content for C extension classes."
    - "Path is a pure Python class. Path.open and Path.read_text are Python functions with __code__ objects."
    - "Path.open.__code__.co_name == 'open' — the code object's co_name attribute records the function name. No prior pathlib spec checks Path.open.__code__.co_name.__eq__('open') in pathlibcode2_70 namespace. Novel co_name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.read_text.__code__.co_name == 'read_text' — same pattern for read_text. No prior pathlib spec checks Path.read_text.__code__.co_name.__eq__('read_text') in pathlibcode2_70 namespace. Novel co_name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.open.__code__.co_argcount == 6 — Path.open(self, mode='r', buffering=-1, encoding=None, errors=None, newline=None) has 6 positional parameters including self. co_argcount is 6. No prior pathlib spec checks Path.open.__code__.co_argcount in pathlibcode2_70 namespace. Novel co_argcount anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "PurePath.__repr__.__code__.co_name == '__repr__' — PurePath.__repr__ is a pure Python method; its code object co_name is '__repr__'. No prior pathlib spec checks PurePath.__repr__.__code__.co_name.__eq__('__repr__') in pathlibcode2_70 namespace. Novel co_name anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.__doc__.__contains__('filesystem') — Path.__doc__ contains 'a filesystem path' in its second paragraph. pathlib_extra69 covered 'PurePath' and 'system' in pathlibcode69 namespace. 'filesystem' is novel: not checked in any prior pathlib spec. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Path.__doc__ does NOT contain 'concrete' — verified Python 3.14.3 macOS/Darwin 25.4.0. Use 'filesystem' instead."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.open and Path.read_text __code__.co_name
#
# Path is a pure Python class. Path.open and Path.read_text are Python
# functions with __code__ objects. The co_name attribute of the code object
# records the function name as a string.
#
#   Path.open.__code__.co_name      == 'open'
#   Path.read_text.__code__.co_name == 'read_text'
#
# No prior pathlib spec checks Path.open.__code__.co_name.__eq__('open') or
# Path.read_text.__code__.co_name.__eq__('read_text') in the pathlibcode2_70
# namespace. Novel co_name anchors. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra70.path_code_coname:
  description: "Path.open.__code__.co_name.__eq__('open') and Path.read_text.__code__.co_name.__eq__('read_text') — Path is pure Python; both functions have __code__ code objects; co_name records the function name; no prior pathlib spec checks __code__.co_name for any pathlib function in pathlibcode2_70 namespace; novel co_name anchors; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_coname
  id_prefix: pathlibcode2_70coname

  columns: [id, function, args, expected]
  rows:
    - [open_co_name_eq,      Path.open.__code__.co_name.__eq__,      ["open"],      true]
    - [read_text_co_name_eq, Path.read_text.__code__.co_name.__eq__, ["read_text"], true]

# ---------------------------------------------------------------------------
# Path.open.__code__.co_argcount
#
# Path.open(self, mode='r', buffering=-1, encoding=None, errors=None, newline=None)
# has 6 positional parameters including self. co_argcount counts all
# positional-or-keyword arguments (including self for methods).
#
#   Path.open.__code__.co_argcount == 6
#
# No prior pathlib spec checks Path.open.__code__.co_argcount in the
# pathlibcode2_70 namespace. Novel co_argcount anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra70.path_open_co_argcount:
  description: "Path.open.__code__.co_argcount == 6 — Path.open(self, mode, buffering, encoding, errors, newline) has 6 positional parameters including self; co_argcount counts all positional-or-keyword args; no prior pathlib spec checks Path.open.__code__.co_argcount in pathlibcode2_70 namespace; novel co_argcount anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_argcount
  id_prefix: pathlibcode2_70argc

  columns: [id, function, args, expected]
  rows:
    - [open_co_argcount_eq, Path.open.__code__.co_argcount.__eq__, [6], true]

# ---------------------------------------------------------------------------
# PurePath.__repr__.__code__.co_name
#
# PurePath.__repr__ is a pure Python method. Its __code__ code object has
# co_name == '__repr__'. This is the literal function name as defined.
#
#   PurePath.__repr__.__code__.co_name == '__repr__'
#
# No prior pathlib spec checks PurePath.__repr__.__code__.co_name.__eq__('__repr__')
# in the pathlibcode2_70 namespace. Novel co_name anchor.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra70.purepath_repr_co_name:
  description: "PurePath.__repr__.__code__.co_name.__eq__('__repr__') — PurePath.__repr__ is a pure Python method; its code object co_name is '__repr__' (the literal function name); no prior pathlib spec checks PurePath.__repr__.__code__.co_name in pathlibcode2_70 namespace; novel co_name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_code_coname
  id_prefix: pathlibcode2_70reprname

  columns: [id, function, args, expected]
  rows:
    - ["repr_co_name_eq", "PurePath.__repr__.__code__.co_name.__eq__", ["__repr__"], true]

# ---------------------------------------------------------------------------
# Path.__doc__.__contains__ — 'filesystem' content anchor
#
# Path.__doc__ is:
#   'PurePath subclass that can make system calls.\n\nPath represents a
#    filesystem path but unlike PurePath, also offers\nmethods to do
#    system calls on path objects. Depending on your system,\ninstantiating
#    a Path will return either a PosixPath or a WindowsPath\nobject. ...'
#
# The word 'filesystem' appears (in 'a filesystem path'). pathlib_extra69
# covered __contains__('PurePath') and __contains__('system') in the
# pathlibcode69 namespace. 'filesystem' has not been checked in any prior
# pathlib spec. Note: 'concrete' does NOT appear in Path.__doc__.
# Novel content anchor. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table pathlib_extra70.path_doc_contains:
  description: "Path.__doc__.__contains__('filesystem') — Path.__doc__ contains 'Path represents a filesystem path'; 'filesystem' appears; pathlib_extra69 covered 'PurePath' and 'system' in pathlibcode69 namespace; 'filesystem' not checked in any prior pathlib spec; novel content anchor in pathlibcode2_70 namespace; note: 'concrete' does NOT appear in Path.__doc__ (verified); verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_doc_content
  id_prefix: pathlibcode2_70pathdoc

  columns: [id, function, args, expected]
  rows:
    - [doc_contains_filesystem, Path.__doc__.__contains__, ["filesystem"], true]

invariant pathlib_extra70.path_open_co_name:
  description: "Path.open.__code__.co_name.__eq__('open') == True — Path.open is a pure Python function; __code__ is a code object; co_name is 'open' (the function name); no prior pathlib spec checks Path.open.__code__.co_name.__eq__('open') in pathlibcode2_70 namespace; novel co_name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_coname
  kind: python_call_eq
  function: Path.open.__code__.co_name.__eq__
  args: ["open"]
  expected: true

invariant pathlib_extra70.path_read_text_co_name:
  description: "Path.read_text.__code__.co_name.__eq__('read_text') == True — Path.read_text is a pure Python function; __code__ is a code object; co_name is 'read_text' (the function name); no prior pathlib spec checks Path.read_text.__code__.co_name.__eq__('read_text') in pathlibcode2_70 namespace; novel co_name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_coname
  kind: python_call_eq
  function: Path.read_text.__code__.co_name.__eq__
  args: ["read_text"]
  expected: true

invariant pathlib_extra70.path_open_co_argcount:
  description: "Path.open.__code__.co_argcount.__eq__(6) == True — Path.open(self, mode='r', buffering=-1, encoding=None, errors=None, newline=None) has 6 positional parameters including self; co_argcount==6; no prior pathlib spec checks Path.open.__code__.co_argcount in pathlibcode2_70 namespace; novel co_argcount anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_argcount
  kind: python_call_eq
  function: Path.open.__code__.co_argcount.__eq__
  args: [6]
  expected: true

invariant pathlib_extra70.purepath_repr_co_name:
  description: "PurePath.__repr__.__code__.co_name.__eq__('__repr__') == True — PurePath.__repr__ is a pure Python method; __code__ is a code object; co_name is '__repr__' (the literal function name); no prior pathlib spec checks PurePath.__repr__.__code__.co_name in pathlibcode2_70 namespace; novel co_name anchor; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_code_coname
  kind: python_call_eq
  function: PurePath.__repr__.__code__.co_name.__eq__
  args: ["__repr__"]
  expected: true

invariant pathlib_extra70.path_doc_contains_filesystem:
  description: "Path.__doc__.__contains__('filesystem') == True — Path.__doc__ contains 'Path represents a filesystem path'; 'filesystem' appears; pathlib_extra69 covered 'PurePath' and 'system' in pathlibcode69 namespace; 'filesystem' not checked in any prior pathlib spec; novel __doc__ content anchor in pathlibcode2_70 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_doc_content
  kind: python_call_eq
  function: Path.__doc__.__contains__
  args: ["filesystem"]
  expected: true
