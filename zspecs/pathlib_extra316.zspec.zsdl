spec: pathlib_extra316
version: ">=3.4"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "pathlib.Path('/usr/bin').joinpath('python') and pathlib.Path('/usr/bin') / 'python' both yield Path('/usr/bin/python')."
    - "pathlib.Path('/usr/bin/python').parent.parent is Path('/usr'), not Path('/usr/bin')."
    - "pathlib.Path('/usr/bin/python').parents.__len__() == 3: the sequence is [PosixPath('/usr/bin'), PosixPath('/usr'), PosixPath('/')]."
    - "pathlib.Path('/usr/bin/python').parts == ('/', 'usr', 'bin', 'python') — four elements including the root '/'."
    - "pathlib.Path('a/b/c').parts == ('a', 'b', 'c') — three elements, no root since path is relative."
    - "pathlib.PurePosixPath('/a/b').with_name('c') yields PurePosixPath('/a/c')."
    - "pathlib.PurePosixPath('/a/b.txt').with_suffix('.py') yields PurePosixPath('/a/b.py')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path.joinpath — string form
# ---------------------------------------------------------------------------

invariant pathlib_extra316.Path.joinpath.str:
  description: "pathlib.Path('/usr/bin').joinpath('python').__str__() == '/usr/bin/python'; verified with Python 3.14.3"
  category: joining
  kind: python_call_eq
  function: Path
  args: ["/usr/bin"]
  method: joinpath
  method_args: ["python"]
  method_chain: __str__
  expected: "/usr/bin/python"

# ---------------------------------------------------------------------------
# Path.__truediv__ (/ operator) — string form
# ---------------------------------------------------------------------------

invariant pathlib_extra316.Path.truediv.str:
  description: "pathlib.Path('/usr/bin') / 'python' == Path('/usr/bin/python'); verified with Python 3.14.3"
  category: joining
  kind: python_call_eq
  function: Path
  args: ["/usr/bin"]
  method: __truediv__
  method_args: ["python"]
  method_chain: __str__
  expected: "/usr/bin/python"

# ---------------------------------------------------------------------------
# Path.parent.parent — grandparent traversal
# ---------------------------------------------------------------------------

invariant pathlib_extra316.Path.parent.parent.str:
  description: "pathlib.Path('/usr/bin/python').parent.parent.__str__() == '/usr'; verified with Python 3.14.3"
  category: components
  kind: python_call_eq
  function: "Path('/usr/bin/python').parent.parent.__str__"
  args: []
  expected: "/usr"

# ---------------------------------------------------------------------------
# Path.parents.__len__() — number of ancestor paths
# ---------------------------------------------------------------------------

invariant pathlib_extra316.Path.parents.len:
  description: "pathlib.Path('/usr/bin/python').parents.__len__() == 3: ancestors are /usr/bin, /usr, /; verified with Python 3.14.3"
  category: components
  kind: python_call_eq
  function: "Path('/usr/bin/python').parents.__len__"
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Path.parts — absolute path
# ---------------------------------------------------------------------------

invariant pathlib_extra316.Path.parts.absolute:
  description: "pathlib.Path('/usr/bin/python').parts == ('/', 'usr', 'bin', 'python'); verified with Python 3.14.3"
  category: components
  kind: python_call_eq
  function: Path
  args: ["/usr/bin/python"]
  method: parts
  expected: ["/", "usr", "bin", "python"]

# ---------------------------------------------------------------------------
# Path.parts — relative path
# ---------------------------------------------------------------------------

invariant pathlib_extra316.Path.parts.relative:
  description: "pathlib.Path('a/b/c').parts == ('a', 'b', 'c'); no root for relative paths; verified with Python 3.14.3"
  category: components
  kind: python_call_eq
  function: Path
  args: ["a/b/c"]
  method: parts
  expected: ["a", "b", "c"]

# ---------------------------------------------------------------------------
# PurePosixPath.with_name
# ---------------------------------------------------------------------------

invariant pathlib_extra316.PurePosixPath.with_name.str:
  description: "pathlib.PurePosixPath('/a/b').with_name('c').__str__() == '/a/c'; verified with Python 3.14.3"
  category: manipulation
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b"]
  method: with_name
  method_args: ["c"]
  method_chain: __str__
  expected: "/a/c"

# ---------------------------------------------------------------------------
# PurePosixPath.with_suffix
# ---------------------------------------------------------------------------

invariant pathlib_extra316.PurePosixPath.with_suffix.str:
  description: "pathlib.PurePosixPath('/a/b.txt').with_suffix('.py').__str__() == '/a/b.py'; verified with Python 3.14.3"
  category: manipulation
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b.txt"]
  method: with_suffix
  method_args: [".py"]
  method_chain: __str__
  expected: "/a/b.py"
