spec: concurrent_futures_extra2446
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2446: __enter__/__exit__ context manager protocol dict-presence checks."
    - "concurrent.futures.Executor defines __enter__ and __exit__ directly in its own __dict__."
    - "concurrent.futures.ThreadPoolExecutor and ProcessPoolExecutor do NOT define __enter__/__exit__ in their own __dict__; they inherit from Executor."
    - "concurrent.futures.InterpreterPoolExecutor (Python 3.14+) also inherits __enter__/__exit__ from Executor, not defined in own __dict__."
    - "concurrent.futures.Future does not define __enter__ or __exit__ in its own __dict__."
    - "No concurrent.futures public class defines __aenter__ or __aexit__ (async context manager protocol)."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table concurrent_futures_extra2446.executor_sync_cm:
  description: "concurrent.futures.Executor __enter__/__exit__ dict-presence — Executor defines own, subclasses inherit"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2446

  columns: [id, function, args, expected]
  rows:
    - ["cf2446001", "concurrent.futures.Executor.__dict__.__contains__", ["__enter__"], true]
    - ["cf2446002", "concurrent.futures.Executor.__dict__.__contains__", ["__exit__"], true]
    - ["cf2446003", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__enter__"], false]
    - ["cf2446004", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__exit__"], false]
    - ["cf2446005", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__enter__"], false]
    - ["cf2446006", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__exit__"], false]

table concurrent_futures_extra2446.future_sync_cm:
  description: "concurrent.futures.Future __enter__/__exit__ dict-presence — Future is not a context manager"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2446

  columns: [id, function, args, expected]
  rows:
    - ["cf2446007", "concurrent.futures.Future.__dict__.__contains__", ["__enter__"], false]
    - ["cf2446008", "concurrent.futures.Future.__dict__.__contains__", ["__exit__"], false]

table concurrent_futures_extra2446.async_cm_absent:
  description: "concurrent.futures classes __aenter__/__aexit__ async context manager protocol — all absent"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2446

  columns: [id, function, args, expected]
  rows:
    - ["cf2446009", "concurrent.futures.Executor.__dict__.__contains__", ["__aenter__"], false]
    - ["cf2446010", "concurrent.futures.Executor.__dict__.__contains__", ["__aexit__"], false]
    - ["cf2446011", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__aenter__"], false]
    - ["cf2446012", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__", ["__aexit__"], false]
    - ["cf2446013", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__aenter__"], false]
    - ["cf2446014", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__aexit__"], false]
    - ["cf2446015", "concurrent.futures.Future.__dict__.__contains__", ["__aenter__"], false]
    - ["cf2446016", "concurrent.futures.Future.__dict__.__contains__", ["__aexit__"], false]

table concurrent_futures_extra2446.interpreter_pool_cm:
  description: "concurrent.futures.InterpreterPoolExecutor context manager dict-presence (Python 3.14+)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf2446

  columns: [id, function, args, expected]
  rows:
    - ["cf2446017", "concurrent.futures.InterpreterPoolExecutor.__dict__.__contains__", ["__enter__"], false]
    - ["cf2446018", "concurrent.futures.InterpreterPoolExecutor.__dict__.__contains__", ["__exit__"], false]
    - ["cf2446019", "concurrent.futures.InterpreterPoolExecutor.__dict__.__contains__", ["__aenter__"], false]
    - ["cf2446020", "concurrent.futures.InterpreterPoolExecutor.__dict__.__contains__", ["__aexit__"], false]
