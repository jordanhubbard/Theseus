spec: threading_extra276
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.RLock is a factory function (__class__.__name__ == 'function'), NOT a class."
    - "threading.RLock().__class__.__name__ == 'RLock'; the instance's class lives in _thread (C extension)."
    - "threading.RLock().__class__.__module__ == '_thread' — the actual RLock type is C-level."
    - "threading.RLock().__class__.__bases__[0].__name__ == 'object' — _thread.RLock subclasses object."
    - "threading.Semaphore is a pure-Python class; __module__ == 'threading', __bases__[0].__name__ == 'object'."
    - "threading.get_ident is a C builtin from _thread; __module__ == '_thread', __class__.__name__ == 'builtin_function_or_method'."
    - "threading.active_count is a pure-Python function; __module__ == 'threading', __class__.__name__ == 'function'."
    - "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.RLock — factory function and instance class identity
#
# threading.RLock is a FUNCTION (factory), not a class.
# RLock() returns an instance of _thread.RLock (C-level type).
# RLock.__module__ == 'threading'; RLock.__class__.__name__ == 'function'.
# RLock().__class__.__name__ == 'RLock'; instance class module == '_thread'.
# ---------------------------------------------------------------------------

table threading_extra276.rlock_identity:
  description: "threading.RLock factory function vs. _thread.RLock instance class identity; RLock is a function, not a type; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex276rl

  columns: [id, function, args, expected, description]
  rows:
    - [rl_name_eq,   RLock.__name__.__eq__,                             ["RLock"],    true,  "threading.RLock.__name__ == 'RLock'; verified with Python 3.14.3"]
    - [rl_mod_eq,    RLock.__module__.__eq__,                           ["threading"], true,  "threading.RLock.__module__ == 'threading'; verified with Python 3.14.3"]
    - [rl_cls_eq,    RLock.__class__.__name__.__eq__,                   ["function"], true,  "threading.RLock.__class__.__name__ == 'function' — RLock is a factory function, not a class; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading.Semaphore, threading.get_ident, threading.active_count, threading.Timer
#
# Semaphore: pure-Python class; __module__ == 'threading'; __bases__[0] == object.
# get_ident: C builtin; __module__ == '_thread'; __class__.__name__ == 'builtin_function_or_method'.
# active_count: pure-Python function; __module__ == 'threading'; __class__.__name__ == 'function'.
# Timer: pure-Python class; __module__ == 'threading'; __bases__[0].__name__ == 'Thread'.
# ---------------------------------------------------------------------------

table threading_extra276.semaphore_getident_activecount_timer:
  description: "threading.Semaphore, get_ident, active_count, Timer identity; C vs pure-Python; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex276sg

  columns: [id, function, args, expected, description]
  rows:
    - [se_name_eq,   Semaphore.__name__.__eq__,                             ["Semaphore"],                   true, "threading.Semaphore.__name__ == 'Semaphore'; verified with Python 3.14.3"]
    - [se_mod_eq,    Semaphore.__module__.__eq__,                           ["threading"],                   true, "threading.Semaphore.__module__ == 'threading' (pure-Python class); verified with Python 3.14.3"]
    - [se_cls_eq,    Semaphore.__class__.__name__.__eq__,                   ["type"],                        true, "threading.Semaphore.__class__.__name__ == 'type' (class, not function); verified with Python 3.14.3"]
    - [se_base_name, Semaphore.__bases__.__getitem__(0).__name__.__eq__,    ["object"],                      true, "threading.Semaphore.__bases__[0].__name__ == 'object' — Semaphore directly subclasses object; verified with Python 3.14.3"]
    - [gi_name_eq,   get_ident.__name__.__eq__,                             ["get_ident"],                   true, "threading.get_ident.__name__ == 'get_ident'; verified with Python 3.14.3"]
    - [gi_mod_eq,    get_ident.__module__.__eq__,                           ["_thread"],                     true, "threading.get_ident.__module__ == '_thread' (C builtin, not 'threading'); verified with Python 3.14.3"]
    - [gi_cls_eq,    get_ident.__class__.__name__.__eq__,                   ["builtin_function_or_method"],  true, "threading.get_ident.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]
    - [ac_name_eq,   active_count.__name__.__eq__,                          ["active_count"],                true, "threading.active_count.__name__ == 'active_count'; verified with Python 3.14.3"]
    - [ac_mod_eq,    active_count.__module__.__eq__,                        ["threading"],                   true, "threading.active_count.__module__ == 'threading' (pure-Python function); verified with Python 3.14.3"]
    - [ac_cls_eq,    active_count.__class__.__name__.__eq__,                ["function"],                    true, "threading.active_count.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [ti_name_eq,   Timer.__name__.__eq__,                                 ["Timer"],                       true, "threading.Timer.__name__ == 'Timer'; verified with Python 3.14.3"]
    - [ti_mod_eq,    Timer.__module__.__eq__,                               ["threading"],                   true, "threading.Timer.__module__ == 'threading'; verified with Python 3.14.3"]
    - [ti_base_name, Timer.__bases__.__getitem__(0).__name__.__eq__,        ["Thread"],                      true, "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer subclasses Thread; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra276
# ---------------------------------------------------------------------------

invariant threading_extra276.rlock_is_function_not_type:
  description: "threading.RLock.__class__.__name__ == 'function' — RLock is a factory function, not a class; instantiation returns a _thread.RLock object"
  category: identity
  kind: python_call_eq
  function: RLock.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra276.rlock_module_is_threading:
  description: "threading.RLock.__module__ == 'threading' — the RLock factory function is defined in the threading module"
  category: identity
  kind: python_call_eq
  function: RLock.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra276.semaphore_base_is_object:
  description: "threading.Semaphore.__bases__[0].__name__ == 'object' — Semaphore directly subclasses object with no intermediate base"
  category: identity
  kind: python_call_eq
  function: Semaphore.__bases__.__getitem__(0).__name__.__eq__
  args: ["object"]
  expected: true

invariant threading_extra276.semaphore_module_is_threading:
  description: "threading.Semaphore.__module__ == 'threading' — Semaphore is a pure-Python class in threading"
  category: identity
  kind: python_call_eq
  function: Semaphore.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra276.get_ident_module_is_c_thread:
  description: "threading.get_ident.__module__ == '_thread' — get_ident is a C builtin from _thread, re-exported by threading"
  category: identity
  kind: python_call_eq
  function: get_ident.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra276.active_count_module_is_threading:
  description: "threading.active_count.__module__ == 'threading' — active_count is a pure-Python wrapper defined in threading (contrast with get_ident)"
  category: identity
  kind: python_call_eq
  function: active_count.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra276.get_ident_is_builtin:
  description: "threading.get_ident.__class__.__name__ == 'builtin_function_or_method' — get_ident is a C builtin, not a Python function"
  category: identity
  kind: python_call_eq
  function: get_ident.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant threading_extra276.active_count_is_function:
  description: "threading.active_count.__class__.__name__ == 'function' — active_count is a pure-Python function, unlike get_ident which is a C builtin"
  category: identity
  kind: python_call_eq
  function: active_count.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra276.timer_subclasses_thread:
  description: "threading.Timer.__bases__[0].__name__ == 'Thread' — Timer inherits from Thread to run a function after a delay"
  category: identity
  kind: python_call_eq
  function: Timer.__bases__.__getitem__(0).__name__.__eq__
  args: ["Thread"]
  expected: true
