spec: uuid_extra226
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra220.zspec.zsdl — covers UUID.__name__/__module__/__qualname__ and uuid3/uuid5 function identity"
    - "uuid_extra221.zspec.zsdl — covers getnode identity; uuid1/uuid4 identity"
    - "uuid_extra222.zspec.zsdl — covers UUID dunder method names and str len 36"
    - "uuid_extra223.zspec.zsdl — covers UUID comparison operator names and qualnames"
    - "uuid_extra224.zspec.zsdl — covers UUID property fget qualname and __name__ contracts"
    - "uuid_extra225.zspec.zsdl — covers UUID field bit_length contracts and field class name"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org') == UUID('6fa459ea-ee8a-3ca4-894e-db77e160355e') — RFC 4122 test vector."
    - "uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org') == UUID('886313e1-3b8a-5372-9b90-0c9aee199e5d') — RFC 4122 test vector."
    - "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').version == 3 — version attribute equals 3 for uuid3."
    - "uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org').version == 5 — version attribute equals 5 for uuid5."
    - "uuid.uuid3(uuid.NAMESPACE_URL, 'http://example.com').__class__.__name__ == 'UUID' — uuid3 always returns a UUID instance."
    - "uuid.uuid5(uuid.NAMESPACE_URL, 'http://example.com').__class__.__name__ == 'UUID' — uuid5 always returns a UUID instance."
    - "str(uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org')).__len__() == 36 — UUID string is always 36 characters."
    - "str(uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org')).__len__() == 36 — UUID string is always 36 characters."
    - "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').int.__class__.__name__ == 'int' — .int attribute is a plain Python int."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid3/uuid5 deterministic output contracts — str() known values
#
# uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org') == '6fa459ea-ee8a-3ca4-894e-db77e160355e'
# uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org') == '886313e1-3b8a-5372-9b90-0c9aee199e5d'
#
# uuid3 uses MD5 (RFC 4122 §4.3); uuid5 uses SHA-1 (RFC 4122 §4.3).
# Both are deterministic: same namespace + name → same UUID always.
# These are the canonical RFC 4122 example test vectors. Novel to uuid_extra226:
# no prior uuid_extra spec records the actual string value of uuid3/uuid5 output.
# ---------------------------------------------------------------------------

table uuid_extra226.uuid3_uuid5_dns_python_org_str:
  description: "uuid3(NAMESPACE_DNS,'python.org') str=='6fa459ea-ee8a-3ca4-894e-db77e160355e'; uuid5(NAMESPACE_DNS,'python.org') str=='886313e1-3b8a-5372-9b90-0c9aee199e5d'; RFC 4122 deterministic output contracts; new to uuid_extra226"
  kind: python_call_eq
  category: deterministic_output
  id_prefix: uuid226

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_dns_pythonorg_str,
       "uuid3(NAMESPACE_DNS, 'python.org').__str__",
       [],
       "6fa459ea-ee8a-3ca4-894e-db77e160355e",
       "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').__str__() == '6fa459ea-ee8a-3ca4-894e-db77e160355e' — RFC 4122 §4.3 example test vector for version-3 UUID; uses MD5 hash of NAMESPACE_DNS + 'python.org'; deterministic: same inputs always produce same output; novel str value anchor; new to uuid_extra226; verified Python 3.14.3"]
    - [uuid5_dns_pythonorg_str,
       "uuid5(NAMESPACE_DNS, 'python.org').__str__",
       [],
       "886313e1-3b8a-5372-9b90-0c9aee199e5d",
       "uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org').__str__() == '886313e1-3b8a-5372-9b90-0c9aee199e5d' — RFC 4122 §4.3 example test vector for version-5 UUID; uses SHA-1 hash of NAMESPACE_DNS + 'python.org'; deterministic; novel str value anchor; new to uuid_extra226; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid3/uuid5 version attribute contracts
#
# uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').version == 3
# uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org').version == 5
#
# The .version attribute of a UUID instance reports the UUID version number
# (1-5) as defined in RFC 4122. uuid3 always has version==3; uuid5 has version==5.
# Novel to uuid_extra226: no prior spec checks the .version attribute value.
# ---------------------------------------------------------------------------

table uuid_extra226.uuid3_uuid5_version_attr:
  description: "uuid3(NAMESPACE_DNS,'python.org').version==3; uuid5(NAMESPACE_DNS,'python.org').version==5; UUID version attribute contracts; new to uuid_extra226"
  kind: python_call_eq
  category: version_attr
  id_prefix: uuid226a

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_version_eq_3,
       "uuid3(NAMESPACE_DNS, 'python.org').version.__eq__",
       [3],
       true,
       "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').version.__eq__(3) == True — uuid3 UUIDs always have version==3 per RFC 4122 §4.3; the version field occupies bits 12-15 of time_hi_and_version; novel version attribute anchor; new to uuid_extra226; verified Python 3.14.3"]
    - [uuid5_version_eq_5,
       "uuid5(NAMESPACE_DNS, 'python.org').version.__eq__",
       [5],
       true,
       "uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org').version.__eq__(5) == True — uuid5 UUIDs always have version==5 per RFC 4122 §4.3; the version field is SHA-1 based; novel version attribute anchor; new to uuid_extra226; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid3/uuid5 result class name contracts
#
# uuid.uuid3(uuid.NAMESPACE_URL, 'http://example.com').__class__.__name__ == 'UUID'
# uuid.uuid5(uuid.NAMESPACE_URL, 'http://example.com').__class__.__name__ == 'UUID'
#
# Both functions return an instance of uuid.UUID. The __class__.__name__
# confirms the concrete type of the return value. Novel to uuid_extra226.
# ---------------------------------------------------------------------------

table uuid_extra226.uuid3_uuid5_class_name:
  description: "uuid3(NAMESPACE_URL,'http://example.com').__class__.__name__=='UUID'; uuid5(NAMESPACE_URL,'http://example.com').__class__.__name__=='UUID'; result class name contracts; new to uuid_extra226"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuid226b

  columns: [id, function, args, expected, description]
  rows:
    - [uuid3_url_class_name,
       "uuid3(NAMESPACE_URL, 'http://example.com').__class__.__name__.__eq__",
       ["UUID"],
       true,
       "uuid.uuid3(uuid.NAMESPACE_URL, 'http://example.com').__class__.__name__.__eq__('UUID') == True — uuid3 returns a uuid.UUID instance; __class__.__name__ is 'UUID' (4 characters); confirms type identity of uuid3 return value; novel class name anchor; new to uuid_extra226; verified Python 3.14.3"]
    - [uuid5_url_class_name,
       "uuid5(NAMESPACE_URL, 'http://example.com').__class__.__name__.__eq__",
       ["UUID"],
       true,
       "uuid.uuid5(uuid.NAMESPACE_URL, 'http://example.com').__class__.__name__.__eq__('UUID') == True — uuid5 returns a uuid.UUID instance; __class__.__name__ is 'UUID' (4 characters); confirms type identity of uuid5 return value; novel class name anchor; new to uuid_extra226; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# uuid3/uuid5 str() length contract
#
# str(uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org')).__len__() == 36
# str(uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org')).__len__() == 36
#
# All UUID string representations are exactly 36 characters:
# 8-4-4-4-12 groups separated by hyphens: 8+1+4+1+4+1+4+1+12 = 36.
# This is the same for uuid3 and uuid5 (and all UUID versions).
# Novel: uuid_extra222 covers UUID('...').str.__len__() but not uuid3/uuid5 output.
# ---------------------------------------------------------------------------

invariant uuid_extra226.uuid3_dns_pythonorg_str_len:
  description: "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').__str__().__len__() == 36 — all UUID string representations are 36 characters in canonical 8-4-4-4-12 hex format with hyphens: 8+1+4+1+4+1+4+1+12=36; uuid3 output is identical in length to any other UUID version; novel str length anchor for uuid3 output; uuid_extra226 is the first namespace to anchor this for a named uuid3 call; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: string_length
  kind: python_call_eq
  function: "uuid3(NAMESPACE_DNS, 'python.org').__str__().__len__"
  args: []
  expected: 36

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant uuid_extra226.uuid3_dns_pythonorg_str_value:
  description: "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').__str__() == '6fa459ea-ee8a-3ca4-894e-db77e160355e' — this is the canonical RFC 4122 §4.3 example test vector for version-3 UUIDs; uuid3 computes an MD5 hash of the namespace identifier bytes concatenated with the name bytes, then formats the result as a UUID with version bits set to 3 and variant bits set per RFC 4122; the output is deterministic: the same namespace and name always yield the same UUID; no prior uuid spec anchors any uuid3 hexdigest/string output value; uuid_extra226 is the first namespace to record this as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: deterministic_output
  kind: python_call_eq
  function: "uuid3(NAMESPACE_DNS, 'python.org').__str__"
  args: []
  expected: "6fa459ea-ee8a-3ca4-894e-db77e160355e"

invariant uuid_extra226.uuid5_dns_pythonorg_str_value:
  description: "uuid.uuid5(uuid.NAMESPACE_DNS, 'python.org').__str__() == '886313e1-3b8a-5372-9b90-0c9aee199e5d' — this is the canonical RFC 4122 §4.3 example test vector for version-5 UUIDs; uuid5 uses SHA-1 instead of MD5; the first 128 bits of the SHA-1 hash are used with version bits set to 5; the output is deterministic: same namespace and name always yield the same UUID; no prior uuid spec anchors any uuid5 string output value; uuid_extra226 is the first namespace to record this as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: deterministic_output
  kind: python_call_eq
  function: "uuid5(NAMESPACE_DNS, 'python.org').__str__"
  args: []
  expected: "886313e1-3b8a-5372-9b90-0c9aee199e5d"

invariant uuid_extra226.uuid3_version_3:
  description: "uuid.uuid3(uuid.NAMESPACE_DNS, 'python.org').version.__eq__(3) == True — the .version property of a UUID instance returns the version number as an int; for uuid3 UUIDs this is always 3 (per RFC 4122 §4.3, the version is encoded in bits 12-15 of the time_hi_and_version field and set to 3 for name-based MD5 UUIDs); no prior uuid spec anchors .version == 3 for uuid3; uuid_extra226 is the first namespace to record this as a standalone; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: version_attr
  kind: python_call_eq
  function: "uuid3(NAMESPACE_DNS, 'python.org').version.__eq__"
  args: [3]
  expected: true
