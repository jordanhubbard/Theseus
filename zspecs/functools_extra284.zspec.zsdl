spec: functools_extra284
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.reduce is a C-level builtin_function_or_method: __module__ == '_functools' (C extension), not 'functools'."
    - "reduce.__name__ == 'reduce' (6 chars); __module__ == '_functools' (10 chars)."
    - "reduce() on empty iterable without initializer raises TypeError: 'reduce() of empty iterable with no initial value'."
    - "reduce() on a single-element iterable without initializer returns that element (no reduction step)."
    - "functools.singledispatch is a pure-Python function: __class__.__name__ == 'function', __module__ == 'functools'."
    - "singledispatch.__name__ == 'singledispatch' (14 chars); __qualname__ == 'singledispatch' (top-level)."
    - "A dispatched function's .dispatch closure method: __name__ == 'dispatch', __qualname__ == 'singledispatch.<locals>.dispatch' (32 chars)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.reduce — builtin identity
#
# reduce is a C-level builtin_function_or_method from the _functools extension.
# __name__ == 'reduce' (6 chars); __module__ == '_functools' (not 'functools').
# ---------------------------------------------------------------------------

table functools_extra284.reduce_identity:
  description: "functools.reduce builtin identity — __name__, __module__, __class__.__name__; name and module lengths; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex284ri

  columns: [id, function, args, expected, description]
  rows:
    - [ri_name_eq,  reduce.__name__.__eq__,          ["reduce"],      true, "functools.reduce.__name__ == 'reduce'; verified with Python 3.14.3"]
    - [ri_name_len, reduce.__name__.__len__,           [],             6,    "functools.reduce.__name__.__len__() == 6; verified with Python 3.14.3"]
    - [ri_mod_eq,   reduce.__module__.__eq__,          ["_functools"], true, "functools.reduce.__module__ == '_functools' (C extension, not 'functools'); verified with Python 3.14.3"]
    - [ri_mod_len,  reduce.__module__.__len__,          [],            10,   "functools.reduce.__module__.__len__() == 10; verified with Python 3.14.3"]
    - [ri_cls_eq,   reduce.__class__.__name__.__eq__,  ["builtin_function_or_method"], true, "functools.reduce.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools.singledispatch — pure-Python function identity
#
# singledispatch is a pure-Python decorator factory.
# __name__ == 'singledispatch' (14 chars); __module__ == 'functools'.
# __qualname__ == 'singledispatch' (top-level function).
# The .dispatch closure method inside a dispatched function has
# __qualname__ == 'singledispatch.<locals>.dispatch' (32 chars).
# ---------------------------------------------------------------------------

table functools_extra284.singledispatch_identity:
  description: "functools.singledispatch function identity — __name__, __module__, __qualname__, __class__.__name__; name length; dispatch closure qualname; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex284sd

  columns: [id, function, args, expected, description]
  rows:
    - [sd_name_eq,  singledispatch.__name__.__eq__,           ["singledispatch"], true,  "functools.singledispatch.__name__ == 'singledispatch'; verified with Python 3.14.3"]
    - [sd_name_len, singledispatch.__name__.__len__,           [],                14,    "functools.singledispatch.__name__.__len__() == 14; verified with Python 3.14.3"]
    - [sd_mod_eq,   singledispatch.__module__.__eq__,          ["functools"],      true,  "functools.singledispatch.__module__ == 'functools'; verified with Python 3.14.3"]
    - [sd_qn_eq,    singledispatch.__qualname__.__eq__,        ["singledispatch"], true,  "functools.singledispatch.__qualname__ == 'singledispatch' (top-level); verified with Python 3.14.3"]
    - [sd_cls_eq,   singledispatch.__class__.__name__.__eq__,  ["function"],       true,  "functools.singledispatch.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [sd_doc_none, singledispatch.__doc__.__eq__,             [null],             false, "functools.singledispatch.__doc__ is not None — singledispatch ships with a docstring; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# functools.reduce error cases
#
# reduce() on an empty iterable without an initializer raises TypeError.
# The error message is: "reduce() of empty iterable with no initial value"
# ---------------------------------------------------------------------------

invariant functools_extra284.reduce_empty_raises_typeerror:
  description: "functools.reduce(lambda a,b: a+b, []) raises TypeError — no initial value for empty iterable"
  category: error_cases
  kind: python_call_raises
  function: reduce
  args: ["lambda:a,b:a+b", []]
  raises: TypeError

invariant functools_extra284.reduce_is_builtin:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C builtin, not a pure-Python function"
  category: identity
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra284.reduce_module_is_c_extension:
  description: "functools.reduce.__module__ == '_functools' — reduce is implemented in the C extension _functools, not the pure-Python functools module"
  category: identity
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra284.reduce_name_length_is_6:
  description: "functools.reduce.__name__.__len__() == 6 — 'reduce' has 6 characters"
  category: identity
  kind: python_call_eq
  function: reduce.__name__.__len__
  args: []
  expected: 6

invariant functools_extra284.singledispatch_is_function:
  description: "functools.singledispatch.__class__.__name__ == 'function' — singledispatch is a pure-Python function, not a C builtin or class"
  category: identity
  kind: python_call_eq
  function: singledispatch.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant functools_extra284.singledispatch_module_is_functools:
  description: "functools.singledispatch.__module__ == 'functools' — singledispatch is defined in the pure-Python functools module"
  category: identity
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra284.singledispatch_name_length_is_14:
  description: "functools.singledispatch.__name__.__len__() == 14 — 'singledispatch' has 14 characters"
  category: identity
  kind: python_call_eq
  function: singledispatch.__name__.__len__
  args: []
  expected: 14

invariant functools_extra284.singledispatch_has_docstring:
  description: "functools.singledispatch.__doc__.__eq__(None) == False — singledispatch ships with a non-None docstring"
  category: behavior
  kind: python_call_eq
  function: singledispatch.__doc__.__eq__
  args: [null]
  expected: false
