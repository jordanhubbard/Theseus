spec: functools_extra248
version: ">=3.2"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "functools_extra247.zspec.zsdl — covers cmp_to_key and WRAPPER_ASSIGNMENTS identity"
    - "functools_extra246.zspec.zsdl — covers wraps and update_wrapper identity"
    - "functools_extra.zspec.zsdl — covers reduce/partial/cached_property/cmp_to_key/total_ordering/singledispatch names and modules"
    - "functools.zspec.zsdl — covers WRAPPER_ASSIGNMENTS, WRAPPER_UPDATES, and callable type checks"
  notes:
    - "This spec covers functools.partialmethod class identity and functools.WRAPPER_UPDATES constant contracts."
    - "functools.partialmethod.__name__ == 'partialmethod' (len=13) — partialmethod is a Python class in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.partialmethod.__module__ == 'functools' (len=9) — partialmethod is defined in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.partialmethod.__qualname__ == 'partialmethod' (len=13) — same as __name__ for top-level class. Verified with Python 3.14.3."
    - "functools.partialmethod.__class__.__name__ == 'type' — partialmethod is a class; its metaclass is type. Verified with Python 3.14.3."
    - "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod inherits directly from object. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is a tuple constant in functools. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__len__() == 1 — Python 3.14 WRAPPER_UPDATES has exactly one element: ('__dict__',). Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is the sole element of WRAPPER_UPDATES. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__contains__('__weakref__') == False — '__weakref__' was removed from WRAPPER_UPDATES in Python 3.x; only '__dict__' remains. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__getitem__(0) == '__dict__' — first (and only) element of WRAPPER_UPDATES is '__dict__'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partialmethod class identity contracts
#
# functools.partialmethod.__name__ == 'partialmethod' (len=13)
# functools.partialmethod.__module__ == 'functools' (len=9)
# functools.partialmethod.__qualname__ == 'partialmethod' (len=13)
# functools.partialmethod.__class__.__name__ == 'type'
# functools.partialmethod.__name__.__len__() == 13
#
# partialmethod is a Python class in Lib/functools.py. New to extra248.
# ---------------------------------------------------------------------------

table functools_extra248.partmeth248_identity:
  description: "functools.partialmethod class identity: name, module, qualname, class; new to extra248"
  kind: python_call_eq
  category: identity
  id_prefix: partmeth248

  columns: [id, function, args, expected, description]
  rows:
    - [pm_name_eq,
       partialmethod.__name__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — partialmethod is a Python class in Lib/functools.py; __name__ is 'partialmethod' (len=13); new to extra248"]
    - [pm_name_len_13,
       partialmethod.__name__.__len__,
       [],
       13,
       "functools.partialmethod.__name__.__len__() == 13 — 'partialmethod' has exactly 13 characters; str.__len__() returns 13; new to extra248"]
    - [pm_module_eq,
       partialmethod.__module__.__eq__,
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod is defined in Lib/functools.py; __module__ is 'functools' (len=9); new to extra248"]
    - [pm_module_len_9,
       partialmethod.__module__.__len__,
       [],
       9,
       "functools.partialmethod.__module__.__len__() == 9 — 'functools' has exactly 9 characters; str.__len__() returns 9; new to extra248"]
    - [pm_qualname_eq,
       partialmethod.__qualname__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__qualname__.__eq__('partialmethod') == True — __qualname__ is 'partialmethod' (len=13); same as __name__ for top-level class; new to extra248"]

# ---------------------------------------------------------------------------
# Table 2: functools.partialmethod bases and class type contracts
#
# functools.partialmethod.__bases__[0].__name__ == 'object'
# functools.partialmethod.__class__.__name__ == 'type'
# functools.partialmethod.__qualname__.__len__() == 13
# functools.partialmethod.__module__.__contains__('functools') == True
# functools.partialmethod.__name__.__contains__('partial') == True
#
# New to extra248.
# ---------------------------------------------------------------------------

table functools_extra248.partmeth248_bases:
  description: "functools.partialmethod bases, class type, qualname len, content checks; new to extra248"
  kind: python_call_eq
  category: identity
  id_prefix: partmeth248b

  columns: [id, function, args, expected, description]
  rows:
    - [pm_bases_0_is_object,
       "partialmethod.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.partialmethod.__bases__[0].__name__.__eq__('object') == True — partialmethod inherits directly from object; __bases__[0] is object; new to extra248"]
    - [pm_class_is_type,
       partialmethod.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partialmethod.__class__.__name__.__eq__('type') == True — partialmethod is a class; its metaclass is the built-in type; new to extra248"]
    - [pm_qualname_len_13,
       partialmethod.__qualname__.__len__,
       [],
       13,
       "functools.partialmethod.__qualname__.__len__() == 13 — 'partialmethod' has exactly 13 characters; str.__len__() returns 13; new to extra248"]
    - [pm_module_contains_functools,
       partialmethod.__module__.__contains__,
       ["functools"],
       true,
       "functools.partialmethod.__module__.__contains__('functools') == True — 'functools' contains the substring 'functools'; new to extra248"]
    - [pm_name_contains_partial,
       partialmethod.__name__.__contains__,
       ["partial"],
       true,
       "functools.partialmethod.__name__.__contains__('partial') == True — 'partialmethod' contains the prefix 'partial'; new to extra248"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_UPDATES identity contracts
#
# functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'
# functools.WRAPPER_UPDATES.__len__() == 1
# functools.WRAPPER_UPDATES.__contains__('__dict__') == True
# functools.WRAPPER_UPDATES.__contains__('__weakref__') == False
# functools.WRAPPER_UPDATES.__getitem__(0) == '__dict__'
#
# WRAPPER_UPDATES is a tuple constant in functools. New to extra248.
# ---------------------------------------------------------------------------

table functools_extra248.wrapperupd248_identity:
  description: "functools.WRAPPER_UPDATES class, length, and content checks; new to extra248"
  kind: python_call_eq
  category: identity
  id_prefix: wrapperupd248

  columns: [id, function, args, expected, description]
  rows:
    - [wu_class_is_tuple,
       WRAPPER_UPDATES.__class__.__name__.__eq__,
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a tuple constant in functools; new to extra248"]
    - [wu_len_1,
       WRAPPER_UPDATES.__len__,
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — Python 3.14 WRAPPER_UPDATES has exactly one element: ('__dict__',); new to extra248"]
    - [wu_contains_dict,
       WRAPPER_UPDATES.__contains__,
       ["__dict__"],
       true,
       "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is the sole element of WRAPPER_UPDATES; new to extra248"]
    - [wu_not_contains_weakref,
       WRAPPER_UPDATES.__contains__,
       ["__weakref__"],
       false,
       "functools.WRAPPER_UPDATES.__contains__('__weakref__') == False — '__weakref__' was removed from WRAPPER_UPDATES; only '__dict__' remains in Python 3.14; new to extra248"]
    - [wu_item0_is_dict,
       WRAPPER_UPDATES.__getitem__,
       [0],
       "__dict__",
       "functools.WRAPPER_UPDATES.__getitem__(0) == '__dict__' — first and only element of WRAPPER_UPDATES is '__dict__'; new to extra248"]

# ---------------------------------------------------------------------------
# Table 4: functools.WRAPPER_UPDATES class module and partialmethod doc checks
#
# functools.WRAPPER_UPDATES.__class__.__module__ == 'builtins'
# functools.partialmethod.__name__.__contains__('method') == True
# functools.partialmethod.__bases__[0].__name__.__len__() == 6
# functools.WRAPPER_UPDATES.__class__.__name__.__len__() == 5
# functools.partialmethod.__module__.__len__() == 9
#
# New to extra248.
# ---------------------------------------------------------------------------

table functools_extra248.wrapperupd248_extra:
  description: "functools.WRAPPER_UPDATES class module; partialmethod name/base checks; new to extra248"
  kind: python_call_eq
  category: identity
  id_prefix: wrapperupd248x

  columns: [id, function, args, expected, description]
  rows:
    - [wu_class_module_builtins,
       WRAPPER_UPDATES.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__module__.__eq__('builtins') == True — tuple is defined in the builtins module; new to extra248"]
    - [pm_name_contains_method,
       partialmethod.__name__.__contains__,
       ["method"],
       true,
       "functools.partialmethod.__name__.__contains__('method') == True — 'partialmethod' contains the suffix 'method'; new to extra248"]
    - [pm_bases_0_len_6,
       "partialmethod.__bases__[0].__name__.__len__",
       [],
       6,
       "functools.partialmethod.__bases__[0].__name__.__len__() == 6 — 'object' has exactly 6 characters; new to extra248"]
    - [wu_class_name_len_5,
       WRAPPER_UPDATES.__class__.__name__.__len__,
       [],
       5,
       "functools.WRAPPER_UPDATES.__class__.__name__.__len__() == 5 — 'tuple' has exactly 5 characters; str.__len__() returns 5; new to extra248"]
    - [pm_module_len_9,
       partialmethod.__module__.__len__,
       [],
       9,
       "functools.partialmethod.__module__.__len__() == 9 — 'functools' has exactly 9 characters; str.__len__() returns 9; new to extra248 (cross-check)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra248
# ---------------------------------------------------------------------------

invariant functools_extra248.pm_name_eq:
  description: "functools.partialmethod.__name__ == 'partialmethod' (len=13); new to extra248"
  kind: python_call_eq
  function: partialmethod.__name__.__eq__
  args: ["partialmethod"]
  expected: true

invariant functools_extra248.pm_module_eq:
  description: "functools.partialmethod.__module__ == 'functools' — defined in Lib/functools.py; new to extra248"
  kind: python_call_eq
  function: partialmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra248.pm_bases_0_is_object:
  description: "functools.partialmethod.__bases__[0].__name__ == 'object' — partialmethod inherits from object; new to extra248"
  kind: python_call_eq
  function: "partialmethod.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant functools_extra248.pm_class_is_type:
  description: "functools.partialmethod.__class__.__name__ == 'type' — partialmethod is a class; new to extra248"
  kind: python_call_eq
  function: partialmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant functools_extra248.pm_qualname_eq:
  description: "functools.partialmethod.__qualname__ == 'partialmethod' (len=13); new to extra248"
  kind: python_call_eq
  function: partialmethod.__qualname__.__eq__
  args: ["partialmethod"]
  expected: true

invariant functools_extra248.wu_class_is_tuple:
  description: "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'; new to extra248"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant functools_extra248.wu_len_1:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — single element ('__dict__',) in Python 3.14; new to extra248"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra248.wu_contains_dict:
  description: "functools.WRAPPER_UPDATES contains '__dict__'; new to extra248"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true

invariant functools_extra248.wu_not_contains_weakref:
  description: "functools.WRAPPER_UPDATES does not contain '__weakref__' in Python 3.14; new to extra248"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__weakref__"]
  expected: false

invariant functools_extra248.wu_item0_is_dict:
  description: "functools.WRAPPER_UPDATES.__getitem__(0) == '__dict__' — sole element; new to extra248"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__getitem__
  args: [0]
  expected: "__dict__"

invariant functools_extra248.pm_name_len_13:
  description: "functools.partialmethod.__name__.__len__() == 13; new to extra248"
  kind: python_call_eq
  function: partialmethod.__name__.__len__
  args: []
  expected: 13

invariant functools_extra248.wu_class_module_builtins:
  description: "functools.WRAPPER_UPDATES.__class__.__module__ == 'builtins'; new to extra248"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__class__.__module__.__eq__
  args: ["builtins"]
  expected: true
