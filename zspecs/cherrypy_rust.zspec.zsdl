spec: cherrypy_rust
version: ">=3.9"
backend: rust_module(cherrypy_rust)

docs: https://docs.cherrypy.dev/

provenance:
  derived_from:
    - "https://docs.cherrypy.dev/ — CherryPy web framework"
  notes:
    - "CherryPy is a minimalist Python web framework."
    - "cherrypy.Application is a class."
    - "cherrypy.engine is a Bus instance."
    - "cherrypy.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant cherrypy_rust.has_application:
  description: "cherrypy.Application is a class"
  category: presence
  kind: python_call_eq
  function: cherrypy_has_application
  args: []
  expected: true

invariant cherrypy_rust.has_engine:
  description: "cherrypy.engine is not None"
  category: presence
  kind: python_call_eq
  function: cherrypy_has_engine
  args: []
  expected: true

invariant cherrypy_rust.version_nonempty:
  description: "cherrypy.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: cherrypy_version_nonempty
  args: []
  expected: true

