spec: fractions_extra13
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions.zspec.zsdl and prior extras (fractions_extra through fractions_extra12)."
    - "fractions.zspec covers Fraction(5,4).__sub__(1)=='1/4', Fraction(3,4).__truediv__(3)=='1/4', Fraction(3,4).__neg__()=='-3/4'."
    - "fractions_extra6 covers Fraction(3,4).__round__()==1, Fraction(1,2).__round__()==0, Fraction(0).__bool__()==False, Fraction(1,3).__bool__()==True."
    - "fractions_extra7 covers Fraction(3,4).__pos__().__str__()==3/4."
    - "fractions_extra12 covers __add__, __mul__, __gt__, __lt__, __abs__, __floor__, __ceil__."
    - "No prior spec covers Fraction(3,4).__sub__(1) yielding -1/4."
    - "No prior spec covers Fraction(2,3).__truediv__(2) yielding 1/3."
    - "No prior spec covers Fraction(-1,2).__neg__().__str__() == '1/2'."
    - "No prior spec covers Fraction(-5,3).__pos__().__str__() == '-5/3' (pos of negative)."
    - "No prior spec covers Fraction(-5,6).__bool__() == True (negative nonzero is truthy)."
    - "No prior spec covers Fraction(7,4).__round__() == 2 (rounding 1.75 to nearest even is 2)."
    - "No prior spec covers Fraction(3,4).__sub__(1).numerator == -1 or denominator == 4."
    - "No prior spec covers Fraction(2,3).__truediv__(2).numerator == 1 or denominator == 3."
    - "Fraction(3,4).__sub__(1) == -1/4: 3/4 - 4/4 = -1/4, numerator -1, denominator 4."
    - "Fraction(2,3).__truediv__(2) == 1/3: (2/3) / 2 = (2/3) * (1/2) = 1/3."
    - "Fraction(-1,2).__neg__() == 1/2: negating a negative fraction gives positive."
    - "Fraction(-5,3).__pos__() == -5/3: unary plus preserves the sign, including negative."
    - "Fraction(-5,6).__bool__() == True: any nonzero Fraction is truthy regardless of sign."
    - "Fraction(7,4).__round__() == 2: 7/4 = 1.75, rounds to nearest even which is 2."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __sub__ — subtraction yielding a negative fraction
#
# fractions.zspec covers Fraction(5,4).__sub__(1) == '1/4' (positive result).
# New: Fraction(3,4).__sub__(1) == '-1/4': 3/4 - 4/4 = -1/4.
# Verified as numerator==-1 and denominator==4.
# ---------------------------------------------------------------------------

invariant fractions_extra13.Fraction.sub_three_quarters_minus_one_numerator:
  description: "Fraction(3,4).__sub__(1).numerator == -1 — 3/4 - 1 = -1/4, numerator is -1"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: __sub__
  method_args: [1]
  method_chain: numerator
  expected: -1

invariant fractions_extra13.Fraction.sub_three_quarters_minus_one_denominator:
  description: "Fraction(3,4).__sub__(1).denominator == 4 — 3/4 - 1 = -1/4, denominator is 4"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: __sub__
  method_args: [1]
  method_chain: denominator
  expected: 4

# ---------------------------------------------------------------------------
# __truediv__ — division by an integer yielding a reduced fraction
#
# fractions.zspec covers Fraction(3,4).__truediv__(3) == '1/4'.
# New: Fraction(2,3).__truediv__(2) == 1/3: (2/3)/2 = (2/3)*(1/2) = 1/3.
# ---------------------------------------------------------------------------

invariant fractions_extra13.Fraction.truediv_two_thirds_by_two_numerator:
  description: "Fraction(2,3).__truediv__(2).numerator == 1 — (2/3)/2 = 1/3, numerator is 1"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [2, 3]
  method: __truediv__
  method_args: [2]
  method_chain: numerator
  expected: 1

invariant fractions_extra13.Fraction.truediv_two_thirds_by_two_denominator:
  description: "Fraction(2,3).__truediv__(2).denominator == 3 — (2/3)/2 = 1/3, denominator is 3"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [2, 3]
  method: __truediv__
  method_args: [2]
  method_chain: denominator
  expected: 3

# ---------------------------------------------------------------------------
# __neg__ — negation of a negative fraction yields positive
#
# fractions.zspec covers Fraction(3,4).__neg__() == '-3/4' (positive to negative).
# New: Fraction(-1,2).__neg__().__str__() == '1/2' (negative to positive).
# ---------------------------------------------------------------------------

invariant fractions_extra13.Fraction.neg_of_negative:
  description: "Fraction(-1,2).__neg__().__str__() == '1/2' — negating a negative fraction gives positive"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [-1, 2]
  method: __neg__
  method_chain: __str__
  expected: "1/2"

# ---------------------------------------------------------------------------
# __pos__ — unary plus preserves value including sign
#
# fractions_extra7 covers Fraction(3,4).__pos__().__str__() == '3/4' (positive input).
# New: Fraction(-5,3).__pos__().__str__() == '-5/3' (negative input, sign preserved).
# ---------------------------------------------------------------------------

invariant fractions_extra13.Fraction.pos_of_negative:
  description: "Fraction(-5,3).__pos__().__str__() == '-5/3' — unary plus preserves negative sign"
  category: arithmetic
  kind: python_call_eq
  function: Fraction
  args: [-5, 3]
  method: __pos__
  method_chain: __str__
  expected: "-5/3"

# ---------------------------------------------------------------------------
# __bool__ — truthiness of a negative nonzero Fraction
#
# fractions_extra6 covers Fraction(0).__bool__()==False and Fraction(1,3).__bool__()==True.
# New: Fraction(-5,6).__bool__() == True — negative nonzero fraction is truthy.
# ---------------------------------------------------------------------------

invariant fractions_extra13.Fraction.bool_negative_nonzero:
  description: "Fraction(-5,6).__bool__() == True — negative nonzero Fraction is truthy"
  category: bool
  kind: python_call_eq
  function: Fraction
  args: [-5, 6]
  method: __bool__
  expected: true

# ---------------------------------------------------------------------------
# __round__ — banker's rounding for a new input
#
# fractions_extra6 covers Fraction(3,4).__round__()==1 and Fraction(1,2).__round__()==0.
# New: Fraction(7,4).__round__() == 2 — 1.75 rounds to nearest even integer 2.
# ---------------------------------------------------------------------------

invariant fractions_extra13.Fraction.round_seven_quarters:
  description: "Fraction(7,4).__round__() == 2 — 1.75 rounds to nearest even integer 2"
  category: rounding
  kind: python_call_eq
  function: Fraction
  args: [7, 4]
  method: __round__
  expected: 2

# ---------------------------------------------------------------------------
# __float__ — convert Fraction to float with a new input
#
# fractions_extra6 covers Fraction(1,2).__float__()==0.5 and Fraction(1,4).__float__()==0.25.
# New: Fraction(3,4).__float__() == 0.75 — exact binary float for 3/4.
# ---------------------------------------------------------------------------

invariant fractions_extra13.Fraction.float_three_quarters:
  description: "Fraction(3,4).__float__() == 0.75 — exact binary float conversion for 3/4"
  category: conversion
  kind: python_call_eq
  function: Fraction
  args: [3, 4]
  method: __float__
  expected: 0.75

# ---------------------------------------------------------------------------
# __int__ — truncate Fraction toward zero
#
# No prior spec covers Fraction.__int__() (integer truncation).
# Fraction(7,4).__int__() == 1 — truncates 1.75 toward zero to 1.
# Fraction(-7,4).__int__() == -1 — truncates -1.75 toward zero to -1.
# ---------------------------------------------------------------------------

invariant fractions_extra13.Fraction.int_seven_quarters:
  description: "Fraction(7,4).__int__() == 1 — 1.75 truncates toward zero to 1"
  category: conversion
  kind: python_call_eq
  function: Fraction
  args: [7, 4]
  method: __int__
  expected: 1

invariant fractions_extra13.Fraction.int_neg_seven_quarters:
  description: "Fraction(-7,4).__int__() == -1 — -1.75 truncates toward zero to -1"
  category: conversion
  kind: python_call_eq
  function: Fraction
  args: [-7, 4]
  method: __int__
  expected: -1
