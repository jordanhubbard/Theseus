spec: theseus_base64
version: ">=3.9"
backend: python_cleanroom(theseus_base64)
blocks: base64

docs: https://www.rfc-editor.org/rfc/rfc4648

provenance:
  derived_from:
    - "https://www.rfc-editor.org/rfc/rfc4648 — Base64 RFC"
  notes:
    - "Clean-room Base64 codec. Do NOT import base64 or binascii."
    - "Implement RFC 4648 Base64 encoding/decoding from scratch using only string/bytes ops."
    - "b64encode(b'hello') == b'aGVsbG8='."
    - "b64decode(b'aGVsbG8=') == b'hello'."
    - "round-trip: b64decode(b64encode(b'theseus')) == b'theseus'."
    - "Export: b64encode(data: bytes) -> bytes, b64decode(data: bytes) -> bytes."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_base64.encode_hello:
  description: "b64encode(b'hello') == b'aGVsbG8='"
  category: encode
  kind: python_call_eq
  function: b64encode_hello
  args: []
  expected: true

invariant theseus_base64.decode_hello:
  description: "b64decode(b'aGVsbG8=') == b'hello'"
  category: decode
  kind: python_call_eq
  function: b64decode_hello
  args: []
  expected: true

invariant theseus_base64.round_trip:
  description: "b64decode(b64encode(b'theseus')) == b'theseus'"
  category: round_trip
  kind: python_call_eq
  function: b64_round_trip
  args: []
  expected: true
