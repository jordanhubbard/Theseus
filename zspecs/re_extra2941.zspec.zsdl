spec: re2941
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re class __dict__ unary operator presence"
    - "Test vectors verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
  notes:
    - "re.Pattern and re.Match are regex engine types; they do not define numeric unary operators."
    - "re.RegexFlag is an IntFlag subclass and inherits unary operators from int, but does NOT define them in its own __dict__."
    - "operator.contains(re.RegexFlag.__dict__, '__neg__') is False — inherited, not defined in own dict."
    - "operator.contains(re.RegexFlag.__dict__, '__pos__') is False — inherited, not defined in own dict."
    - "operator.contains(re.RegexFlag.__dict__, '__abs__') is False — inherited, not defined in own dict."
    - "type(re.compile('')) is the Pattern class; type(re.match('', '')) is the Match class."
    - "All values verified with Python 3.13 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — unary negation operator in own __dict__
#
# re.Pattern and re.Match are not numeric. re.RegexFlag is IntFlag but does
# NOT define __neg__ in its own __dict__ — it inherits it from int via MRO.
# ---------------------------------------------------------------------------

table re2941.neg:
  description: "operator.contains(cls.__dict__, '__neg__') is False for all re classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: ren2941

  columns: [id, function, args, expected]
  rows:
    - ["ren2941_001", operator.contains, [re.Pattern.__dict__,   "__neg__"], false]
    - ["ren2941_002", operator.contains, [re.Match.__dict__,     "__neg__"], false]
    - ["ren2941_003", operator.contains, [re.RegexFlag.__dict__, "__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — unary positive operator in own __dict__
#
# None of the re classes define __pos__ in their own __dict__.
# re.RegexFlag inherits __pos__ from int but does not own it.
# ---------------------------------------------------------------------------

table re2941.pos:
  description: "operator.contains(cls.__dict__, '__pos__') is False for all re classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: rep2941

  columns: [id, function, args, expected]
  rows:
    - ["rep2941_001", operator.contains, [re.Pattern.__dict__,   "__pos__"], false]
    - ["rep2941_002", operator.contains, [re.Match.__dict__,     "__pos__"], false]
    - ["rep2941_003", operator.contains, [re.RegexFlag.__dict__, "__pos__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — absolute value operator in own __dict__
#
# None of the re classes define __abs__ in their own __dict__.
# re.RegexFlag inherits __abs__ from int but does not own it.
# ---------------------------------------------------------------------------

table re2941.abs:
  description: "operator.contains(cls.__dict__, '__abs__') is False for all re classes"
  kind: python_call_eq
  category: dict_presence
  id_prefix: rea2941

  columns: [id, function, args, expected]
  rows:
    - ["rea2941_001", operator.contains, [re.Pattern.__dict__,   "__abs__"], false]
    - ["rea2941_002", operator.contains, [re.Match.__dict__,     "__abs__"], false]
    - ["rea2941_003", operator.contains, [re.RegexFlag.__dict__, "__abs__"], false]

# ---------------------------------------------------------------------------
# combined — all three operators across all re classes
#
# Cross-check confirming that Pattern, Match, and RegexFlag each fail all
# three dict-presence checks. RegexFlag's inherited unary ops do not appear
# in its own __dict__.
# ---------------------------------------------------------------------------

table re2941.combined:
  description: "Combined: no re class defines __neg__, __pos__, or __abs__ in its own __dict__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: rex2941

  columns: [id, function, args, expected]
  rows:
    - ["rex2941_001", operator.contains, [re.Pattern.__dict__,   "__neg__"], false]
    - ["rex2941_002", operator.contains, [re.Pattern.__dict__,   "__pos__"], false]
    - ["rex2941_003", operator.contains, [re.Pattern.__dict__,   "__abs__"], false]
    - ["rex2941_004", operator.contains, [re.Match.__dict__,     "__neg__"], false]
    - ["rex2941_005", operator.contains, [re.Match.__dict__,     "__pos__"], false]
    - ["rex2941_006", operator.contains, [re.Match.__dict__,     "__abs__"], false]
    - ["rex2941_007", operator.contains, [re.RegexFlag.__dict__, "__neg__"], false]
    - ["rex2941_008", operator.contains, [re.RegexFlag.__dict__, "__pos__"], false]
    - ["rex2941_009", operator.contains, [re.RegexFlag.__dict__, "__abs__"], false]
