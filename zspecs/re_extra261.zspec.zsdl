spec: re_extra261
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re.zspec.zsdl — covers sub, findall, split, escape, compile error cases"
    - "re_extra.zspec.zsdl — covers Pattern/Match class names, flag equality table, match/search/sub/split/findall"
  notes:
    - "re.IGNORECASE==2, re.MULTILINE==8, re.DOTALL==16, re.VERBOSE==64 — verified integer values."
    - "re.I, re.M, re.S, re.X are aliases: I==IGNORECASE, M==MULTILINE, S==DOTALL, X==VERBOSE."
    - "re.escape.__name__ == 'escape', __qualname__ == 'escape', __module__ == 're', __class__.__name__ == 'function'."
    - "re.purge.__name__ == 'purge', __qualname__ == 'purge' — cache-clearing utility function."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Flag integer values
# ---------------------------------------------------------------------------

table re_extra261.flag_values:
  description: "re flag constants have specific integer values per the re documentation"
  kind: python_call_eq
  category: flags
  id_prefix: flag_val

  columns: [id, function, args, expected]
  rows:
    - [IGNORECASE, IGNORECASE.__eq__, [2],  true]
    - [MULTILINE,  MULTILINE.__eq__,  [8],  true]
    - [DOTALL,     DOTALL.__eq__,     [16], true]
    - [VERBOSE,    VERBOSE.__eq__,    [64], true]

# ---------------------------------------------------------------------------
# Alias equality — re.I/M/S/X equal their full-name counterparts
# ---------------------------------------------------------------------------

table re_extra261.flag_aliases:
  description: "Short aliases re.I/M/S/X are equal to their full-name flag counterparts"
  kind: python_call_eq
  category: flags
  id_prefix: alias

  columns: [id, function, args, expected]
  rows:
    - [I_eq_IGNORECASE, I.__eq__, [IGNORECASE], true]
    - [M_eq_MULTILINE,  M.__eq__, [MULTILINE],  true]
    - [S_eq_DOTALL,     S.__eq__, [DOTALL],     true]
    - [X_eq_VERBOSE,    X.__eq__, [VERBOSE],    true]

# ---------------------------------------------------------------------------
# re.escape — function identity
# ---------------------------------------------------------------------------

invariant re_extra261.escape.name:
  description: "re.escape.__name__ == 'escape'"
  category: function_identity
  kind: python_call_eq
  function: escape.__name__.__eq__
  args: ["escape"]
  expected: true

invariant re_extra261.escape.qualname:
  description: "re.escape.__qualname__ == 'escape'"
  category: function_identity
  kind: python_call_eq
  function: escape.__qualname__.__eq__
  args: ["escape"]
  expected: true

invariant re_extra261.escape.module:
  description: "re.escape.__module__ == 're'"
  category: function_identity
  kind: python_call_eq
  function: escape.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra261.escape.class_name:
  description: "re.escape.__class__.__name__ == 'function'"
  category: function_identity
  kind: python_call_eq
  function: escape.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# re.purge — function identity
# ---------------------------------------------------------------------------

invariant re_extra261.purge.name:
  description: "re.purge.__name__ == 'purge'"
  category: function_identity
  kind: python_call_eq
  function: purge.__name__.__eq__
  args: ["purge"]
  expected: true

invariant re_extra261.purge.qualname:
  description: "re.purge.__qualname__ == 'purge'"
  category: function_identity
  kind: python_call_eq
  function: purge.__qualname__.__eq__
  args: ["purge"]
  expected: true
