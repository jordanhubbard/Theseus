spec: decimal_extra2041
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/decimal.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2041): __lshift__, __rlshift__, __ilshift__, __rshift__, __rrshift__, __irshift__, __and__, __rand__, __iand__, __or__, __ror__, __ior__, __xor__, __rxor__, __ixor__, __invert__ dict-presence checks."
    - "decimal.Decimal is a decimal floating-point type, not an integer type; it does not define any bitwise operators."
    - "decimal.Context is a configuration object for decimal arithmetic; no bitwise operators are defined in its own __dict__."
    - "decimal.DecimalException is an exception class; no bitwise operators are defined in its own __dict__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# __lshift__ / __rlshift__ / __ilshift__ — left shift dict-presence
# ---------------------------------------------------------------------------

table decimal_extra2041.lshift_protocol:
  description: "decimal types __lshift__/__rlshift__/__ilshift__ dict-presence — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2041

  columns: [id, function, args, expected]
  rows:
    - ["dc2041001", "decimal.Decimal.__dict__.__contains__",          ["__lshift__"],  false]
    - ["dc2041002", "decimal.Decimal.__dict__.__contains__",          ["__rlshift__"], false]
    - ["dc2041003", "decimal.Decimal.__dict__.__contains__",          ["__ilshift__"], false]
    - ["dc2041004", "decimal.Context.__dict__.__contains__",          ["__lshift__"],  false]
    - ["dc2041005", "decimal.Context.__dict__.__contains__",          ["__rlshift__"], false]
    - ["dc2041006", "decimal.Context.__dict__.__contains__",          ["__ilshift__"], false]
    - ["dc2041007", "decimal.DecimalException.__dict__.__contains__", ["__lshift__"],  false]
    - ["dc2041008", "decimal.DecimalException.__dict__.__contains__", ["__rlshift__"], false]
    - ["dc2041009", "decimal.DecimalException.__dict__.__contains__", ["__ilshift__"], false]

