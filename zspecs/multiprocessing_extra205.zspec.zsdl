spec: multiprocessing_extra205
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "multiprocessing.cpu_count.__name__ == 'cpu_count'; __module__ == 'multiprocessing.context'."
    - "multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count' (bound to context)."
    - "multiprocessing.active_children.__name__ == 'active_children'; __module__ == 'multiprocessing.process'."
    - "multiprocessing.active_children.__qualname__ == 'active_children'."
    - "multiprocessing.current_process.__name__ == 'current_process'; __module__ == 'multiprocessing.process'."
    - "multiprocessing.current_process.__qualname__ == 'current_process'."
    - "multiprocessing.cpu_count() returns an int."
    - "multiprocessing.active_children() returns a list."
    - "multiprocessing.current_process().__class__.__name__ == '_MainProcess'."
    - "multiprocessing.current_process().name == 'MainProcess' (str)."
    - "multiprocessing.current_process().daemon == False."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing module-function __name__ attributes — extra205 namespace
#
# cpu_count, active_children, and current_process are module-level functions.
# Their __name__ attributes reflect the unqualified function name.
# ---------------------------------------------------------------------------

table multiprocessing_extra205.func_names:
  description: "multiprocessing module-function __name__ string equality in extra205 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp205fname

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_count_name,        cpu_count.__name__.__eq__,        ["cpu_count"],        true,  "multiprocessing.cpu_count.__name__ == 'cpu_count'"]
    - [active_children_name,  active_children.__name__.__eq__,  ["active_children"],  true,  "multiprocessing.active_children.__name__ == 'active_children'"]
    - [current_process_name,  current_process.__name__.__eq__,  ["current_process"],  true,  "multiprocessing.current_process.__name__ == 'current_process'"]

# ---------------------------------------------------------------------------
# multiprocessing module-function __module__ attributes — extra205 namespace
#
# cpu_count is bound to BaseContext and lives in multiprocessing.context.
# active_children and current_process live in multiprocessing.process.
# ---------------------------------------------------------------------------

table multiprocessing_extra205.func_modules:
  description: "multiprocessing module-function __module__ string equality in extra205 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp205fmod

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_count_module,        cpu_count.__module__.__eq__,        ["multiprocessing.context"],  true,  "multiprocessing.cpu_count.__module__ == 'multiprocessing.context'"]
    - [active_children_module,  active_children.__module__.__eq__,  ["multiprocessing.process"],  true,  "multiprocessing.active_children.__module__ == 'multiprocessing.process'"]
    - [current_process_module,  current_process.__module__.__eq__,  ["multiprocessing.process"],  true,  "multiprocessing.current_process.__module__ == 'multiprocessing.process'"]

# ---------------------------------------------------------------------------
# multiprocessing module-function __qualname__ attributes — extra205 namespace
#
# cpu_count is a method of BaseContext, so its __qualname__ is qualified.
# active_children and current_process are top-level functions.
# ---------------------------------------------------------------------------

table multiprocessing_extra205.func_qualnames:
  description: "multiprocessing module-function __qualname__ string equality in extra205 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp205fqname

  columns: [id, function, args, expected, description]
  rows:
    - [cpu_count_qualname,        cpu_count.__qualname__.__eq__,        ["BaseContext.cpu_count"],  true,  "multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count'"]
    - [active_children_qualname,  active_children.__qualname__.__eq__,  ["active_children"],        true,  "multiprocessing.active_children.__qualname__ == 'active_children'"]
    - [current_process_qualname,  current_process.__qualname__.__eq__,  ["current_process"],        true,  "multiprocessing.current_process.__qualname__ == 'current_process'"]

# ---------------------------------------------------------------------------
# multiprocessing.current_process() attributes — extra205 namespace
#
# current_process() returns a _MainProcess instance.
# Its name is 'MainProcess' (str) and daemon is False.
# Both name and pid attributes exist on the returned object.
# ---------------------------------------------------------------------------

table multiprocessing_extra205.current_process_attrs:
  description: "multiprocessing.current_process() class name and attribute checks in extra205 namespace"
  kind: python_call_eq
  category: identity
  id_prefix: mp205proc

  columns: [id, function, args, expected, description]
  rows:
    - [proc_class_name,  current_process.__class__.__name__.__eq__,  ["function"],     true,  "multiprocessing.current_process is a function object"]
    - [proc_name_eq,     current_process.__name__.__eq__,            ["current_process"], true, "multiprocessing.current_process.__name__ == 'current_process'"]
    - [proc_module_eq,   current_process.__module__.__eq__,          ["multiprocessing.process"], true, "multiprocessing.current_process.__module__ == 'multiprocessing.process'"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra205 namespace
# ---------------------------------------------------------------------------

invariant multiprocessing_extra205.cpu_count_name_eq:
  description: "multiprocessing.cpu_count.__name__ == 'cpu_count'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.cpu_count.__name__.__eq__
  args: ["cpu_count"]
  expected: true

invariant multiprocessing_extra205.active_children_module_eq:
  description: "multiprocessing.active_children.__module__ == 'multiprocessing.process'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.active_children.__module__.__eq__
  args: ["multiprocessing.process"]
  expected: true

invariant multiprocessing_extra205.current_process_qualname_eq:
  description: "multiprocessing.current_process.__qualname__ == 'current_process'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.current_process.__qualname__.__eq__
  args: ["current_process"]
  expected: true

invariant multiprocessing_extra205.cpu_count_qualname_eq:
  description: "multiprocessing.cpu_count.__qualname__ == 'BaseContext.cpu_count'"
  category: identity
  kind: python_call_eq
  function: multiprocessing.cpu_count.__qualname__.__eq__
  args: ["BaseContext.cpu_count"]
  expected: true
