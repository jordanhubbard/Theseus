spec: sk3016
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket: Low-level networking interface"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 648 (sk3016): __iter__, __next__, __reversed__ dict-presence checks for socket types."
    - "socket.socket is a networking file descriptor wrapper — not a sequence or iterator; no iterator protocol is defined in its own __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses; socket.AddressInfo and socket.MsgFlag are IntFlag subclasses — integral enum types do not expose iterator protocol in their own __dict__."
    - "socket.error, socket.herror, socket.gaierror, and socket.timeout are exception classes — none are sequences or iterators."
    - "None of the socket types define __iter__, __next__, or __reversed__ in their own __dict__."
    - "Verified types: socket.socket, socket.AddressFamily, socket.SocketKind, socket.AddressInfo, socket.MsgFlag, socket.error, socket.herror, socket.gaierror, socket.timeout."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk3016.iter:
  description: "socket types __iter__ dict-presence checks; wave 648"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk3016
  columns: [id, function, args, expected]
  rows:
    - ["sk3016001", operator.contains, [socket.socket.__dict__,        "__iter__"], false]
    - ["sk3016002", operator.contains, [socket.AddressFamily.__dict__, "__iter__"], false]
    - ["sk3016003", operator.contains, [socket.SocketKind.__dict__,    "__iter__"], false]
