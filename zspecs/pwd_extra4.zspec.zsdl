spec: pwd_extra4
version: ">=3.9"
backend: python_module(pwd)

docs: https://docs.python.org/3/library/pwd.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pwd.html — Python pwd module documentation"
    - "POSIX.1-2017 — IEEE Std 1003.1, passwd database access"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/pwdmodule.c"
  notes:
    - "This spec extends pwd.zspec.zsdl through pwd_extra3.zspec.zsdl with new, non-duplicate invariants."
    - "pwd.zspec.zsdl covers: getpwuid/getpwnam/getpwall __name__/type; struct_passwd __name__/__module__/n_sequence_fields/n_fields; getpwall returns list."
    - "pwd_extra covers: function __name__ (table); struct_passwd __name__/__module__; __match_args__ is tuple/len/all 7 indices."
    - "pwd_extra2 covers: n_unnamed_fields==0; __bases__[0] is tuple; __match_args__ __contains__ for all 7 fields; function __qualname__; function is_builtin; getpwall()[0] class."
    - "pwd_extra3 covers: module __name__; struct_passwd __qualname__; function __module__; function __doc__ type; struct_passwd __bases__.__len__==1; struct_passwd __mro__ len/positions 1 and 2."
    - "New here: module __package__; struct_passwd __doc__ type and non-empty check; struct_passwd __mro__[0] is itself; n_sequence_fields == n_fields cross-check; getpwuid/getpwnam KeyError behavior."
    - "pwd is a POSIX-only module; it is available on macOS and Linux but NOT on Windows."
    - "struct_passwd.__doc__.__class__.__name__ == 'str' — C struct-sequence types expose a class docstring."
    - "struct_passwd.__mro__[0].__name__ == 'struct_passwd' — first MRO position is the class itself."
    - "n_sequence_fields and n_fields are both 7; verifying their equality (via subtraction) is new."
    - "pwd.__package__ == '' — pwd is a C extension module at the top level, no parent package."
    - "getpwuid(999999999) and getpwnam('__no_such_user__') always raise KeyError on any POSIX system."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module __package__ — pwd is a top-level C extension, __package__ == ''
# Not covered in any prior pwd spec (pwd_extra3 covers __name__ only).
# ---------------------------------------------------------------------------

invariant pwd_extra4.module.package:
  description: "pwd.__package__ == '' — top-level C extension module, no parent package"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

# ---------------------------------------------------------------------------
# struct_passwd.__doc__ — C struct-sequence types expose a class docstring
# pwd_extra3 covers __qualname__ and __module__ for struct_passwd but not __doc__.
# ---------------------------------------------------------------------------

invariant pwd_extra4.struct_passwd.doc_type:
  description: "pwd.struct_passwd.__doc__.__class__.__name__ == 'str' — struct_passwd has a class docstring"
  category: class_identity
  kind: python_call_eq
  function: struct_passwd.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant pwd_extra4.struct_passwd.doc_nonempty:
  description: "len(pwd.struct_passwd.__doc__) > 0 — struct_passwd docstring is non-empty"
  category: class_identity
  kind: python_call_eq
  function: struct_passwd.__doc__.__len__
  args: []
  method: __gt__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# struct_passwd.__mro__[0] is the class itself
# pwd_extra3 covers __mro__ len, position 1 (tuple), and position 2 (object).
# Position 0 — the class itself — is new here.
# ---------------------------------------------------------------------------

invariant pwd_extra4.struct_passwd.mro_0_is_self:
  description: "pwd.struct_passwd.__mro__[0].__name__ == 'struct_passwd' — first MRO entry is the class itself"
  category: class_hierarchy
  kind: python_call_eq
  function: struct_passwd.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "struct_passwd"

# ---------------------------------------------------------------------------
# n_sequence_fields == n_fields cross-check
# pwd.zspec.zsdl pins each to 7 individually; their equality (confirmed via
# subtraction yielding 0) is a new structural invariant.
# ---------------------------------------------------------------------------

invariant pwd_extra4.struct_passwd.n_seq_eq_n_fields:
  description: "pwd.struct_passwd.n_sequence_fields - pwd.struct_passwd.n_fields == 0 — both counts are equal"
  category: struct
  kind: python_call_eq
  function: struct_passwd.n_sequence_fields.__sub__
  args: [7]
  expected: 0

# ---------------------------------------------------------------------------
# getpwuid and getpwnam raise KeyError for invalid lookups
# pwd.zspec.zsdl does not have any python_call_raises invariants.
# A UID that cannot exist (very large int) and a name that cannot exist are
# safe, portable choices that always raise KeyError on POSIX.
# ---------------------------------------------------------------------------

invariant pwd_extra4.getpwuid.raises_on_invalid_uid:
  description: "pwd.getpwuid(999999999) raises KeyError — UID not found"
  category: error_behavior
  kind: python_call_raises
  function: getpwuid
  args: [999999999]
  expected: KeyError

invariant pwd_extra4.getpwnam.raises_on_invalid_name:
  description: "pwd.getpwnam('__no_such_user__') raises KeyError — username not found"
  category: error_behavior
  kind: python_call_raises
  function: getpwnam
  args: ["__no_such_user__"]
  expected: KeyError
