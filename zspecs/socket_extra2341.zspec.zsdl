spec: socket_extra2341
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 603 (_extra2341): __slots__ content and absence checks."
    - "All values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "socket.socket is a pure-Python subclass of the C type _socket.socket; it DOES define __slots__ = ['__weakref__', '_io_refs', '_closed']."
    - "socket.socket.__slots__ is a list (not a tuple) of length 3."
    - "socket.socket.__slots__ does NOT contain 'family', 'type', or 'proto' — those come from the C base type."
    - "socket.error, socket.herror, socket.gaierror, socket.timeout are all pure-Python exception subclasses without __slots__."
    - "socket.AddressFamily and socket.SocketKind are IntEnum subclasses without __slots__ in their own __dict__."
  created_at: "2026-04-12"

table socket_extra2341.socket_has_slots:
  description: "socket.socket defines __slots__ — confirmed via __dict__ and direct slot presence"
  kind: python_call_eq
  category: slots_content
  id_prefix: sk2341
  columns: [id, function, args, expected]
  rows:
    - ["sk2341001", "socket.socket.__dict__.__contains__", ["__slots__"], true]
    - ["sk2341002", "socket.socket.__slots__.__len__", [], 3]
    - ["sk2341003", "socket.socket.__slots__.__contains__", ["__weakref__"], true]
    - ["sk2341004", "socket.socket.__slots__.__contains__", ["_io_refs"], true]
    - ["sk2341005", "socket.socket.__slots__.__contains__", ["_closed"], true]

table socket_extra2341.socket_slots_absent:
  description: "socket.socket.__slots__ does NOT contain C-base-type attributes"
  kind: python_call_eq
  category: slots_absence
  id_prefix: sk2341
  columns: [id, function, args, expected]
  rows:
    - ["sk2341006", "socket.socket.__slots__.__contains__", ["family"], false]
    - ["sk2341007", "socket.socket.__slots__.__contains__", ["type"], false]
    - ["sk2341008", "socket.socket.__slots__.__contains__", ["proto"], false]
    - ["sk2341009", "socket.socket.__slots__.__contains__", ["fileno"], false]
    - ["sk2341010", "socket.socket.__slots__.__contains__", ["timeout"], false]

table socket_extra2341.exception_classes_no_slots:
  description: "socket exception subclasses are pure-Python without __slots__"
  kind: python_call_eq
  category: slots_absence
  id_prefix: sk2341
  columns: [id, function, args, expected]
  rows:
    - ["sk2341011", "socket.error.__dict__.__contains__", ["__slots__"], false]
    - ["sk2341012", "socket.herror.__dict__.__contains__", ["__slots__"], false]
    - ["sk2341013", "socket.gaierror.__dict__.__contains__", ["__slots__"], false]
    - ["sk2341014", "socket.timeout.__dict__.__contains__", ["__slots__"], false]

table socket_extra2341.enum_classes_no_slots:
  description: "socket.AddressFamily and socket.SocketKind are IntEnum subclasses without __slots__"
  kind: python_call_eq
  category: slots_absence
  id_prefix: sk2341
  columns: [id, function, args, expected]
  rows:
    - ["sk2341015", "socket.AddressFamily.__dict__.__contains__", ["__slots__"], false]
    - ["sk2341016", "socket.SocketKind.__dict__.__contains__", ["__slots__"], false]

table socket_extra2341.cross_check:
  description: "Cross-check: slot count is exact and non-slots are absent"
  kind: python_call_eq
  category: slots_content
  id_prefix: sk2341
  columns: [id, function, args, expected]
  rows:
    - ["sk2341017", "socket.socket.__slots__.__len__", [], 3]
    - ["sk2341018", "socket.socket.__slots__.__contains__", ["__weakref__"], true]
    - ["sk2341019", "socket.socket.__slots__.__contains__", ["_io_refs"], true]
    - ["sk2341020", "socket.socket.__slots__.__contains__", ["_closed"], true]
    - ["sk2341021", "socket.socket.__slots__.__contains__", ["nonexistent"], false]
    - ["sk2341022", "socket.socket.__slots__.__contains__", ["connect"], false]
