    - [ef_name_len, asyncio.ensure_future.__name__.__len__,   [],                 13,    "ensure_future.__name__.__len__() == 13 (same len as module 'asyncio.tasks'=13 — coincidence); verified with Python 3.14.3"]
    - [ef_mod_eq,   asyncio.ensure_future.__module__.__eq__,  ["asyncio.tasks"],  true,  "ensure_future.__module__ == 'asyncio.tasks' (len=13; same module as create_task); verified with Python 3.14.3"]
