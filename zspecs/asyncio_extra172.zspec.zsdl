table asyncio_extra172.asyncio_sleep_and_gather_identity:
  description: "asyncio.sleep and asyncio.gather function name and module identity checks in asynciosg172 namespace — asyncio.sleep.__name__.__eq__('sleep')==True (sleep.__name__=='sleep' (len=5: 'sleep'=5); asyncio.sleep(delay, result=None) is a coroutine that suspends execution for delay seconds, yielding control back to the event loop so other tasks can run; asyncio.sleep(0) is the canonical way to yield control immediately — it is the asyncio equivalent of time.sleep but event-loop-safe); asyncio.sleep.__name__.__len__()==5 ('sleep'=5; 2nd shortest among the five functions in this spec: wait=4 < sleep=5 < gather=6 < create_task=11 < ensure_future=13); asyncio.sleep.__module__.__eq__('asyncio.tasks')==True (sleep.__module__=='asyncio.tasks' (len=13)); asyncio.gather.__name__.__eq__('gather')==True (gather.__name__=='gather' (len=6: 'gather'=6); asyncio.gather(*awaitables, return_exceptions=False) runs multiple awaitables concurrently and returns a list of results in input order; if return_exceptions=False, the first exception cancels all remaining tasks and propagates; the list of futures must all be scheduled on the same event loop); asyncio.gather.__module__.__eq__('asyncio.tasks')==True (gather.__module__=='asyncio.tasks' (len=13); same module as all five functions); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciosg172

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_name_eq,   asyncio.sleep.__name__.__eq__,    ["sleep"],          true,  "sleep.__name__ == 'sleep' (len=5: 2nd shortest in this spec; wait=4 < sleep=5); verified with Python 3.14.3"]
    - [sleep_name_len,  asyncio.sleep.__name__.__len__,   [],                 5,     "sleep.__name__.__len__() == 5 ('sleep'=5; 2nd shortest after wait=4); verified with Python 3.14.3"]
    - [sleep_mod_eq,    asyncio.sleep.__module__.__eq__,  ["asyncio.tasks"],  true,  "sleep.__module__ == 'asyncio.tasks' (len=13; same module as all five functions); verified with Python 3.14.3"]
    - [gather_name_eq,  asyncio.gather.__name__.__eq__,   ["gather"],         true,  "gather.__name__ == 'gather' (len=6; 3rd shortest in this spec: wait=4 < sleep=5 < gather=6); verified with Python 3.14.3"]
    - [gather_name_len, asyncio.gather.__name__.__len__,  [],                 6,     "gather.__name__.__len__() == 6 ('gather'=6; 3rd in ordering: wait=4 < sleep=5 < gather=6); verified with Python 3.14.3"]
    - [gather_mod_eq,   asyncio.gather.__module__.__eq__, ["asyncio.tasks"],  true,  "gather.__module__ == 'asyncio.tasks' (len=13; same as sleep, create_task, ensure_future, wait); verified with Python 3.14.3"]

