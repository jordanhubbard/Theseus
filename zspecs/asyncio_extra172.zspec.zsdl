spec: asyncio_extra172
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio tasks documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
  notes:
    - "This spec covers: asyncio.create_task.__name__=='create_task' and __module__=='asyncio.tasks'; asyncio.ensure_future.__name__=='ensure_future' and __module__=='asyncio.tasks'; asyncio.sleep.__name__=='sleep' and __module__=='asyncio.tasks'; asyncio.gather.__name__=='gather' and __module__=='asyncio.tasks'; asyncio.wait.__name__=='wait' and __module__=='asyncio.tasks'. KEY FINDING: all five functions share __module__=='asyncio.tasks' (len=13: 'asyncio'=7+'.'=1+'tasks'=5=13); all are Python-level functions defined in Lib/asyncio/tasks.py (NOT C builtins unlike get_event_loop/__module__=='_asyncio'). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.create_task.__name__=='create_task' (len=11: 'create'=6+'_'=1+'task'=4=11); __module__=='asyncio.tasks' (len=13: 'asyncio'=7+'.'=1+'tasks'=5=13); asyncio.create_task(coro, *, name=None, context=None) wraps a coroutine in a Task and schedules it for execution; requires a running event loop. Verified with Python 3.14.3."
    - "asyncio.ensure_future.__name__=='ensure_future' (len=13: 'ensure'=6+'_'=1+'future'=6=13); __module__=='asyncio.tasks' (len=13; same len as name: coincidence); asyncio.ensure_future() wraps a coroutine or future in a Task; broader than create_task since it also accepts pre-existing Futures. Verified with Python 3.14.3."
    - "asyncio.sleep.__name__=='sleep' (len=5: 'sleep'=5); __module__=='asyncio.tasks' (len=13); asyncio.sleep(delay, result=None) suspends a coroutine for delay seconds without blocking the event loop. Verified with Python 3.14.3."
    - "asyncio.gather.__name__=='gather' (len=6: 'gather'=6); __module__=='asyncio.tasks' (len=13); asyncio.gather(*awaitables, return_exceptions=False) runs multiple awaitables concurrently and collects results. Verified with Python 3.14.3."
    - "asyncio.wait.__name__=='wait' (len=4: 'wait'=4); __module__=='asyncio.tasks' (len=13); asyncio.wait(aws, timeout=None, return_when=ALL_COMPLETED) waits for a set of futures. Verified with Python 3.14.3."
    - "NAME LENGTH ORDERING: wait(4) < sleep(5) < gather(6) < create_task(11) < ensure_future(13). All five share __module__=='asyncio.tasks'(13). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.create_task function name and module identity — extra172
#
# asyncio.create_task.__name__.__eq__('create_task')       == True
# asyncio.create_task.__name__.__len__()                   == 11
# asyncio.create_task.__module__.__eq__('asyncio.tasks')   == True
# asyncio.create_task.__module__.__len__()                 == 13
# ---------------------------------------------------------------------------

table asyncio_extra172.asyncio_create_task_identity:
  description: "asyncio.create_task function name and module identity checks in asyncioct172 namespace — asyncio.create_task.__name__.__eq__('create_task')==True (create_task.__name__=='create_task' (len=11: 'create'=6+'_'=1+'task'=4=11); asyncio.create_task(coro, *, name=None, context=None) schedules a coroutine as a Task on the running event loop and returns the Task; it is the primary high-level API for concurrent task creation; requires a running event loop — unlike ensure_future it does not accept raw Futures); asyncio.create_task.__name__.__len__()==11 ('create_task'=11; 2 shorter than 'ensure_future'=13; 6 longer than 'sleep'=5); asyncio.create_task.__module__.__eq__('asyncio.tasks')==True (create_task.__module__=='asyncio.tasks' (len=13: 'asyncio'=7+'.'=1+'tasks'=5=13); defined in Lib/asyncio/tasks.py — a Python-level function, NOT a C builtin like get_event_loop); asyncio.create_task.__module__.__len__()==13 ('asyncio.tasks'=13; 1 shorter than 'asyncio.events'=14 from extra171; 2 shorter than 'asyncio.runners'=15); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioct172

  columns: [id, function, args, expected, description]
  rows:
    - [ct_name_eq,  asyncio.create_task.__name__.__eq__,    ["create_task"],     true,  "create_task.__name__ == 'create_task' (len=11: 'create'=6+'_task'=5=11); verified with Python 3.14.3"]
    - [ct_name_len, asyncio.create_task.__name__.__len__,   [],                  11,    "create_task.__name__.__len__() == 11 ('create_task'=11; 2 shorter than ensure_future=13); verified with Python 3.14.3"]
    - [ct_mod_eq,   asyncio.create_task.__module__.__eq__,  ["asyncio.tasks"],   true,  "create_task.__module__ == 'asyncio.tasks' (len=13; Python function in asyncio/tasks.py); verified with Python 3.14.3"]
    - [ct_mod_len,  asyncio.create_task.__module__.__len__, [],                  13,    "create_task.__module__.__len__() == 13 ('asyncio.tasks'=13; 1 shorter than asyncio.events=14); verified with Python 3.14.3"]

