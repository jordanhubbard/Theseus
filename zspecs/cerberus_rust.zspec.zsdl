spec: cerberus_rust
version: ">=3.9"
backend: rust_module(cerberus_rust)

docs: https://docs.python-cerberus.org/

provenance:
  derived_from:
    - "https://docs.python-cerberus.org/ — cerberus validation library"
  notes:
    - "cerberus provides schema-based validation."
    - "cerberus.Validator({'name': {'type': 'string'}}).validate({'name': 'Alice'}) is True."
    - "cerberus.Validator is a class."
    - "cerberus.__version__ is non-empty."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant cerberus_rust.validate_string:
  description: "Validator({'name':{'type':'string'}}).validate({'name':'Alice'}) is True"
  category: validate
  kind: python_call_eq
  function: cerberus_validate_string
  args: []
  expected: true

invariant cerberus_rust.has_validator_class:
  description: "cerberus.Validator is a class"
  category: presence
  kind: python_call_eq
  function: cerberus_has_validator
  args: []
  expected: true

invariant cerberus_rust.version_nonempty:
  description: "cerberus.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: cerberus_version_nonempty
  args: []
  expected: true

