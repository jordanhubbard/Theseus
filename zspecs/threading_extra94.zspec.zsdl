spec: threading_extra94
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra93

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra93.zspec.zsdl."
    - "This spec covers: threading Lock and _RLock method class names, Thread method class names, and Lock/_RLock class identity (Wave 253)."
    - "threading.Lock is the C extension lock type from _threadmodule.c; its methods are 'method_descriptor' except __repr__ which is 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "threading.Lock.acquire.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "threading.Lock.release.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "threading.Lock.locked.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "threading.Lock.__enter__.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "threading.Lock.__exit__.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "threading.Lock.__repr__.__class__.__name__ == 'wrapper_descriptor'. Verified with Python 3.14.3."
    - "threading._RLock is the pure-Python RLock wrapper class defined in Lib/threading.py; its methods are 'function'. threading.RLock is a factory function that returns a _thread.RLock instance. Verified with Python 3.14.3."
    - "threading._RLock.acquire/__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Thread.start/run/join/is_alive are all pure-Python functions, __class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Lock.__class__.__name__ == 'type' and __module__ == '_thread'. Verified with Python 3.14.3."
    - "threading._RLock.__class__.__name__ == 'type' and __module__ == 'threading'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Lock method class names
#
# Wave 253 theme: threading.Lock is a C extension type; its methods are method_descriptor or wrapper_descriptor.
#
# threading.Lock.acquire.__class__.__name__.__eq__('method_descriptor')   == True
# threading.Lock.release.__class__.__name__.__eq__('method_descriptor')   == True
# threading.Lock.locked.__class__.__name__.__eq__('method_descriptor')    == True
# threading.Lock.__enter__.__class__.__name__.__eq__('method_descriptor') == True
# threading.Lock.__exit__.__class__.__name__.__eq__('method_descriptor')  == True
# threading.Lock.__repr__.__class__.__name__.__eq__('wrapper_descriptor') == True
#
# Lock is a C extension type (lock_type) from Modules/_threadmodule.c.
# All regular methods are method_descriptor; __repr__ is wrapper_descriptor (slot wrapper). New to extra94.
# ---------------------------------------------------------------------------

table threading_extra94.lock_method_class_names:
  description: "threading.Lock method class names — acquire/release/locked/__enter__/__exit__ are method_descriptor; __repr__ is wrapper_descriptor; C type from _threadmodule.c; wave 253; new to extra94"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglockmethod94

  columns: [id, function, args, expected, description]
  rows:
    - [lock_acquire_class_name,
       "Lock.acquire.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.acquire.__class__.__name__.__eq__('method_descriptor') == True — Lock is a C extension type from Modules/_threadmodule.c; acquire is a C method slot defined in the PyMethodDef table; unbound C methods are method_descriptor objects; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; prior spec extra93 checked __module__; this spec (extra94) checks method class names; new to extra94"]
    - [lock_release_class_name,
       "Lock.release.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.release.__class__.__name__.__eq__('method_descriptor') == True — release is a C method slot on the Lock C extension type; unbound it is a method_descriptor; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra94"]
    - [lock_locked_class_name,
       "Lock.locked.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.locked.__class__.__name__.__eq__('method_descriptor') == True — locked is a C method on the Lock type; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra94"]
    - ["Lock.__enter___class_name",
       "Lock.__enter__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.__enter__.__class__.__name__.__eq__('method_descriptor') == True — __enter__ is a C method on the Lock type implementing the context manager protocol; unbound it is a method_descriptor; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra94"]
    - ["Lock.__exit___class_name",
       "Lock.__exit__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "threading.Lock.__exit__.__class__.__name__.__eq__('method_descriptor') == True — __exit__ is a C method on the Lock type; unbound it is a method_descriptor; __class__.__name__ is 'method_descriptor'; str.__eq__('method_descriptor') returns True; new to extra94"]
    - ["Lock.__repr___class_name",
       "Lock.__repr__.__class__.__name__.__eq__",
       ["wrapper_descriptor"],
       true,
       "threading.Lock.__repr__.__class__.__name__.__eq__('wrapper_descriptor') == True — __repr__ on C extension types is exposed through the tp_repr slot as a slot wrapper (wrapper_descriptor); this is distinct from method_descriptor which comes from PyMethodDef entries; __class__.__name__ is 'wrapper_descriptor'; str.__eq__('wrapper_descriptor') returns True; new to extra94"]

# ---------------------------------------------------------------------------
# Table 2: threading._RLock method class names
#
# Wave 253 theme: threading._RLock is a pure-Python class; its methods are 'function'.
#
# threading._RLock.acquire.__class__.__name__.__eq__('function')   == True
# threading._RLock.release.__class__.__name__.__eq__('function')   == True
# threading._RLock.locked.__class__.__name__.__eq__('function')    == True
# threading._RLock.__enter__.__class__.__name__.__eq__('function') == True
# threading._RLock.__exit__.__class__.__name__.__eq__('function')  == True
# threading._RLock.__repr__.__class__.__name__.__eq__('function')  == True
#
# threading._RLock is defined in Lib/threading.py with pure-Python methods.
# threading.RLock is a factory function — threading._RLock is the actual class. New to extra94.
# ---------------------------------------------------------------------------

table threading_extra94.rlock_method_class_names:
  description: "threading._RLock method class names — all are 'function'; pure-Python class in Lib/threading.py; wave 253; new to extra94"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglockmethod94

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_acquire_class_name,
       "_RLock.acquire.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.acquire.__class__.__name__.__eq__('function') == True — _RLock is a pure-Python class defined in Lib/threading.py; acquire is defined with 'def acquire' in the class body; unbound Python methods are plain functions so __class__.__name__ is 'function'; str.__eq__('function') returns True; note threading.RLock is a factory function not a class; new to extra94"]
    - [rlock_release_class_name,
       "_RLock.release.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.release.__class__.__name__.__eq__('function') == True — release is a pure-Python method in _RLock; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra94"]
    - [rlock_locked_class_name,
       "_RLock.locked.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.locked.__class__.__name__.__eq__('function') == True — locked is a pure-Python method in _RLock; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra94"]
    - ["_RLock.__enter___class_name",
       "_RLock.__enter__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.__enter__.__class__.__name__.__eq__('function') == True — __enter__ is a pure-Python method in _RLock; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra94"]
    - ["_RLock.__exit___class_name",
       "_RLock.__exit__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.__exit__.__class__.__name__.__eq__('function') == True — __exit__ is a pure-Python method in _RLock; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra94"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread method class names
#
# Wave 253 theme: threading.Thread is a pure-Python class; its methods are 'function'.
#
# threading.Thread.start.__class__.__name__.__eq__('function')    == True
# threading.Thread.run.__class__.__name__.__eq__('function')      == True
# threading.Thread.join.__class__.__name__.__eq__('function')     == True
# threading.Thread.is_alive.__class__.__name__.__eq__('function') == True
#
# Thread is defined in Lib/threading.py; all four public methods are pure-Python functions. New to extra94.
# ---------------------------------------------------------------------------

table threading_extra94.thread_method_class_names:
  description: "threading.Thread start/run/join/is_alive method class names == 'function'; pure-Python class in Lib/threading.py; wave 253; new to extra94"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglockmethod94

  columns: [id, function, args, expected, description]
  rows:
    - [thread_start_class_name,
       "Thread.start.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.start.__class__.__name__.__eq__('function') == True — Thread is a pure-Python class defined in Lib/threading.py; start is defined with 'def start' in the class body; unbound Python methods are plain functions; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra94"]
    - [thread_run_class_name,
       "Thread.run.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.run.__class__.__name__.__eq__('function') == True — run is the target invocation method on Thread; it is a pure-Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra94"]
    - [thread_join_class_name,
       "Thread.join.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.join.__class__.__name__.__eq__('function') == True — join is a pure-Python method on Thread; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra94"]
    - [thread_is_alive_class_name,
       "Thread.is_alive.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.is_alive.__class__.__name__.__eq__('function') == True — is_alive is a pure-Python method on Thread; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra94"]

# ---------------------------------------------------------------------------
# Table 4: Lock and _RLock class identity
#
# Wave 253 theme: threading.Lock and threading._RLock identity checks.
#
# threading.Lock.__class__.__name__.__eq__('type')         == True
# threading.Lock.__module__.__eq__('_thread')              == True
# threading._RLock.__class__.__name__.__eq__('type')       == True
# threading._RLock.__module__.__eq__('threading')          == True
#
# Lock is a C extension type with __module__ == '_thread'.
# _RLock is a Python class with __module__ == 'threading'. New to extra94.
# ---------------------------------------------------------------------------

table threading_extra94.lock_rlock_class_identity:
  description: "threading.Lock and _RLock __class__.__name__ and __module__; Lock is C type from '_thread'; _RLock is Python class from 'threading'; wave 253; new to extra94"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadinglockmethod94

  columns: [id, function, args, expected, description]
  rows:
    - [lock_class_name_eq_type,
       "Lock.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading.Lock.__class__.__name__.__eq__('type') == True — Lock is a C extension type registered in Modules/_threadmodule.c as a PyTypeObject; its metaclass is <class 'type'>; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra94"]
    - [lock_module_eq_thread,
       "Lock.__module__.__eq__",
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — Lock is a C extension type from _threadmodule.c; the type's __module__ is set to '_thread' where it is originally registered; threading re-exports it but the __module__ attribute is unchanged; str.__eq__('_thread') returns True; new to extra94"]
    - [rlock_class_name_eq_type,
       "_RLock.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading._RLock.__class__.__name__.__eq__('type') == True — _RLock is a pure-Python class defined in Lib/threading.py using a class statement; its metaclass is <class 'type'>; __class__.__name__ is 'type'; str.__eq__('type') returns True; note threading.RLock is a factory function (not a class); new to extra94"]
    - [rlock_module_eq_threading,
       "_RLock.__module__.__eq__",
       ["threading"],
       true,
       "threading._RLock.__module__.__eq__('threading') == True — _RLock is defined in Lib/threading.py; its __module__ attribute is 'threading'; this distinguishes it from Lock whose __module__ is '_thread'; str.__eq__('threading') returns True; new to extra94"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra94
# ---------------------------------------------------------------------------

invariant threading_extra94.lock_acquire_method_descriptor:
  description: "threading.Lock.acquire.__class__.__name__ == 'method_descriptor' — C extension type method; wave 253; new to extra94"
  kind: python_call_eq
  function: Lock.acquire.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant threading_extra94.lock_repr_wrapper_descriptor:
  description: "threading.Lock.__repr__.__class__.__name__ == 'wrapper_descriptor' — Lock __repr__ is a slot wrapper; wave 253; new to extra94"
  kind: python_call_eq
  function: Lock.__repr__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant threading_extra94.rlock_acquire_function:
  description: "threading._RLock.acquire.__class__.__name__ == 'function' — _RLock is a pure-Python class; wave 253; new to extra94"
  kind: python_call_eq
  function: _RLock.acquire.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra94.thread_start_function:
  description: "threading.Thread.start.__class__.__name__ == 'function' — Thread is a pure-Python class; wave 253; new to extra94"
  kind: python_call_eq
  function: Thread.start.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra94.lock_module_eq_thread:
  description: "threading.Lock.__module__ == '_thread' — Lock is a C type from _threadmodule.c; wave 253; new to extra94"
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true
