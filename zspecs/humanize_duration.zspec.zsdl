spec: humanize_duration
version: ">=3.0.0"
backend: node(humanize-duration)

docs: https://github.com/EvanHahn/HumanizeDuration.js#readme

provenance:
  derived_from:
    - "humanize-duration README — https://github.com/EvanHahn/HumanizeDuration.js#readme"
    - "Test vectors verified with humanize-duration@3.32.1 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "humanize-duration source"
  notes:
    - "humanize-duration exports the humanizeDuration function as module.exports."
    - "humanizeDuration(ms) converts milliseconds to a human-readable English string."
    - "Uses largest fitting unit: 3600000ms = '1 hour', 60000ms = '1 minute'."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns human-readable string. No errors for numeric inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table humanize_duration.format:
  kind: node_module_call_eq
  function: ~
  category: format
  id_prefix: hd

  columns: [id, args, expected]
  rows:
    - [one_hour,   [3600000],  "1 hour"]
    - [one_minute, [60000],    "1 minute"]
    - [one_second, [1000],     "1 second"]
    - [two_hours,  [7200000],  "2 hours"]
