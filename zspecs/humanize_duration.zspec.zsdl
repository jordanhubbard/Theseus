spec: humanize_duration
version: ">=3.0.0"
backend: node(humanize-duration)

docs: https://www.npmjs.com/package/humanize-duration

provenance:
  derived_from:
    - "humanize-duration README — https://www.npmjs.com/package/humanize-duration"
    - "Test vectors verified with humanize-duration via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "humanize-duration source"
  notes:
    - "humanize-duration is an npm package. Install: npm install humanize-duration"
    - "humanizeDuration(ms) converts milliseconds to a human-readable duration string."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns human-readable duration string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table humanize_duration.humanize:
  kind: node_module_call_eq
  function: ~
  category: format
  id_prefix: hd

  columns: [id, args, expected]
  rows:
    - [one_hour,       [3600000],  "1 hour"]
    - [one_hour_30min, [5400000],  "1 hour, 30 minutes"]
    - [one_day,        [86400000], "1 day"]
