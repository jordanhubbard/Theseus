spec: theseus_mimetypes_cr
version: ">=3.0"
backend: python_cleanroom(theseus_mimetypes_cr)
blocks: mimetypes

docs: https://docs.python.org/3/library/mimetypes.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/mimetypes.html"
  not_derived_from:
    - "CPython source: Lib/mimetypes.py"
  notes:
    - "Clean-room mimetypes module. Do NOT import mimetypes."

error_model: python_exceptions

invariant theseus_mimetypes_cr.mimetypes2_guess_type:
  description: "guess_type('foo.html') returns text/html"
  category: behavior
  kind: python_call_eq
  function: mimetypes2_guess_type
  args: []
  expected: true

invariant theseus_mimetypes_cr.mimetypes2_guess_extension:
  description: "guess_extension('text/html') returns a .html extension"
  category: behavior
  kind: python_call_eq
  function: mimetypes2_guess_extension
  args: []
  expected: true

invariant theseus_mimetypes_cr.mimetypes2_types_map:
  description: "types_map dict is non-empty"
  category: behavior
  kind: python_call_eq
  function: mimetypes2_types_map
  args: []
  expected: true
