spec: io_extra841
version: ">=3.9"
error_model: python_exceptions

provenance:
  derived_from:
    - "cpython/Lib/io.py"
    - "cpython/Lib/_pyio.py"
  not_derived_from:
    - "any third-party io library"
  notes:
    - "Covers __qualname__ invariants for StringIO and BytesIO methods"
    - "All qualnames are stable across CPython 3.9+"
  created_at: "2026-04-12"

table io_extra841.stringio_qualnames:
  description: "io.StringIO method __qualname__ equality checks"
  kind: python_call_eq
  category: qualname
  id_prefix: io841si
  columns: [id, function, args, expected]
  rows:
    - [io841si001, io.StringIO.__init__.__qualname__.__eq__, ["StringIO.__init__"], true]
    - [io841si002, io.StringIO.read.__qualname__.__eq__, ["StringIO.read"], true]
    - [io841si003, io.StringIO.write.__qualname__.__eq__, ["StringIO.write"], true]
    - [io841si004, io.StringIO.getvalue.__qualname__.__eq__, ["StringIO.getvalue"], true]
    - [io841si005, io.StringIO.seek.__qualname__.__eq__, ["StringIO.seek"], true]
    - [io841si006, io.StringIO.tell.__qualname__.__eq__, ["StringIO.tell"], true]

table io_extra841.bytesio_qualnames:
  description: "io.BytesIO method __qualname__ equality checks"
  kind: python_call_eq
  category: qualname
  id_prefix: io841bi
  columns: [id, function, args, expected]
  rows:
    - [io841bi001, io.BytesIO.__init__.__qualname__.__eq__, ["BytesIO.__init__"], true]
    - [io841bi002, io.BytesIO.read.__qualname__.__eq__, ["BytesIO.read"], true]
    - [io841bi003, io.BytesIO.write.__qualname__.__eq__, ["BytesIO.write"], true]
    - [io841bi004, io.BytesIO.getvalue.__qualname__.__eq__, ["BytesIO.getvalue"], true]
    - [io841bi005, io.BytesIO.seek.__qualname__.__eq__, ["BytesIO.seek"], true]
    - [io841bi006, io.BytesIO.tell.__qualname__.__eq__, ["BytesIO.tell"], true]
