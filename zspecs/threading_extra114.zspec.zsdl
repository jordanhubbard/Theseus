spec: threading_extra114
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra113.zspec.zsdl."
    - "This spec covers: threading primitives class identity — Lock, RLock, Event, Semaphore, Condition __name__ and __qualname__; __module__ attributes; wave 264."
    - "threading.Lock.__name__ == 'lock' (len 4; lowercase; C-extension from _thread). Verified with Python 3.14.3."
    - "threading.Lock.__module__ == '_thread'. Verified with Python 3.14.3."
    - "threading.RLock.__name__ == 'RLock' (len 5; RLock is a factory function, not a class). Verified with Python 3.14.3."
    - "threading.RLock() instance __class__.__name__ == 'RLock'. Verified with Python 3.14.3."
    - "threading.Event.__name__ == 'Event' (len 5). Verified with Python 3.14.3."
    - "threading.Event.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Semaphore.__name__ == 'Semaphore' (len 9). Verified with Python 3.14.3."
    - "threading.Semaphore.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Condition.__name__ == 'Condition' (len 9). Verified with Python 3.14.3."
    - "threading.Condition.__module__ == 'threading'. Verified with Python 3.14.3."
    - "threading.Barrier.__name__ == 'Barrier' (len 7). Verified with Python 3.14.3."
    - "threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len 16). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading primitives __name__ and __qualname__
#
# Wave 264 theme: threading.Lock is actually the C-extension type _thread.lock
# (re-exported from _thread); its __name__ is lowercase 'lock' (len 4) and
# its __module__ is '_thread'. threading.Event, threading.Semaphore, and
# threading.Condition are pure-Python classes in Lib/threading.py; their
# __module__ is 'threading'. threading.RLock is a factory function (type
# 'function'), not a class; RLock().__class__.__name__ is 'RLock'. Note:
# Lock.__name__ is 'lock' (lowercase) while Event/Semaphore/Condition use
# CamelCase. threading.Barrier.__name__ == 'Barrier' (len 7).
# threading.BoundedSemaphore.__name__ == 'BoundedSemaphore' (len 16).
#
# threading.Lock.__name__ == 'lock'
# threading.Event.__name__ == 'Event'
# threading.Semaphore.__name__ == 'Semaphore'
# threading.Condition.__name__ == 'Condition'
# threading.Barrier.__name__ == 'Barrier'
# threading.BoundedSemaphore.__name__ == 'BoundedSemaphore'
#
# New to extra114.
# ---------------------------------------------------------------------------

table threading_extra114.primitive_names:
  description: "threading primitives __name__: Lock='lock'(4,lowercase,_thread), Event='Event'(5), Semaphore='Semaphore'(9), Condition='Condition'(9), Barrier='Barrier'(7), BoundedSemaphore(16); wave 264; new to extra114"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingpn114

  columns: [id, function, args, expected, description]
  rows:
    - [lock_name_eq,
       "Lock.__name__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__name__.__eq__('lock') == True — threading.Lock is the C-extension type _thread.lock from Modules/_threadmodule.c; its __name__ is lowercase 'lock' (not 'Lock'); this is different from the capitalized names of pure-Python threading classes; str.__eq__('lock') returns True; new to extra114"]
    - [lock_name_len_4,
       "Lock.__name__.__len__",
       [],
       4,
       "threading.Lock.__name__.__len__() == 4 — 'lock' has 4 characters: l-o-c-k; the shortest primitive name in this spec; str.__len__() returns 4; int.__eq__(4) returns True; new to extra114"]
    - [event_name_eq,
       "Event.__name__.__eq__",
       ["Event"],
       true,
       "threading.Event.__name__.__eq__('Event') == True — threading.Event is a pure-Python class in Lib/threading.py; its __name__ is 'Event' (CamelCase); str.__eq__('Event') returns True; new to extra114"]
    - [event_name_len_5,
       "Event.__name__.__len__",
       [],
       5,
       "threading.Event.__name__.__len__() == 5 — 'Event' has 5 characters: E-v-e-n-t; the same length as 'RLock' (5); str.__len__() returns 5; int.__eq__(5) returns True; new to extra114"]
    - [semaphore_name_eq,
       "Semaphore.__name__.__eq__",
       ["Semaphore"],
       true,
       "threading.Semaphore.__name__.__eq__('Semaphore') == True — threading.Semaphore is a pure-Python class in Lib/threading.py; its __name__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra114"]
    - [semaphore_name_len_9,
       "Semaphore.__name__.__len__",
       [],
       9,
       "threading.Semaphore.__name__.__len__() == 9 — 'Semaphore' has 9 characters: S-e-m-a-p-h-o-r-e; the same length as 'Condition' (9); str.__len__() returns 9; int.__eq__(9) returns True; new to extra114"]
    - [condition_name_eq,
       "Condition.__name__.__eq__",
       ["Condition"],
       true,
       "threading.Condition.__name__.__eq__('Condition') == True — threading.Condition is a pure-Python class in Lib/threading.py; its __name__ is 'Condition'; str.__eq__('Condition') returns True; new to extra114"]
    - [barrier_name_eq,
       "Barrier.__name__.__eq__",
       ["Barrier"],
       true,
       "threading.Barrier.__name__.__eq__('Barrier') == True — threading.Barrier is a pure-Python class in Lib/threading.py; its __name__ is 'Barrier'; str.__eq__('Barrier') returns True; new to extra114"]
    - [boundedsemaphore_name_eq,
       "BoundedSemaphore.__name__.__eq__",
       ["BoundedSemaphore"],
       true,
       "threading.BoundedSemaphore.__name__.__eq__('BoundedSemaphore') == True — threading.BoundedSemaphore is a subclass of Semaphore that raises ValueError if the counter exceeds its initial value; its __name__ is 'BoundedSemaphore'; str.__eq__('BoundedSemaphore') returns True; new to extra114"]
    - [boundedsemaphore_name_len_16,
       "BoundedSemaphore.__name__.__len__",
       [],
       16,
       "threading.BoundedSemaphore.__name__.__len__() == 16 — 'BoundedSemaphore' has 16 characters: B-o-u-n-d-e-d-S-e-m-a-p-h-o-r-e; the longest primitive name in this spec; str.__len__() returns 16; int.__eq__(16) returns True; new to extra114"]

# ---------------------------------------------------------------------------
# Table 2: threading primitives __module__ attributes
#
# Wave 264 theme: threading.Lock is from _thread (a C-extension module) so
# threading.Lock.__module__ == '_thread'. threading.Event, threading.Semaphore,
# threading.Condition, threading.Barrier, and threading.BoundedSemaphore are
# all defined in Lib/threading.py, so their __module__ == 'threading'.
# threading.RLock is a factory function in Lib/threading.py but RLock()
# instances have __class__.__module__ == '_thread' (the actual RLock class
# is in C). The key distinction: Lock's __module__ == '_thread' while
# the pure-Python classes have __module__ == 'threading'.
#
# threading.Lock.__module__ == '_thread'
# threading.Event.__module__ == 'threading'
# threading.Semaphore.__module__ == 'threading'
# threading.Condition.__module__ == 'threading'
# threading.Barrier.__module__ == 'threading'
#
# New to extra114.
# ---------------------------------------------------------------------------

table threading_extra114.primitive_modules:
  description: "threading primitive __module__: Lock='_thread' (C-extension); Event/Semaphore/Condition/Barrier='threading' (pure-Python); module source distinction; wave 264; new to extra114"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingpm114

  columns: [id, function, args, expected, description]
  rows:
    - [lock_module_thread,
       "Lock.__module__.__eq__",
       ["_thread"],
       true,
       "threading.Lock.__module__.__eq__('_thread') == True — threading.Lock is the C-extension type _thread.lock; it is defined in Modules/_threadmodule.c and registered under the _thread module; its __module__ is '_thread' (not 'threading'); str.__eq__('_thread') returns True; new to extra114"]
    - [event_module_threading,
       "Event.__module__.__eq__",
       ["threading"],
       true,
       "threading.Event.__module__.__eq__('threading') == True — threading.Event is a pure-Python class defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra114"]
    - [semaphore_module_threading,
       "Semaphore.__module__.__eq__",
       ["threading"],
       true,
       "threading.Semaphore.__module__.__eq__('threading') == True — threading.Semaphore is a pure-Python class defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra114"]
    - [condition_module_threading,
       "Condition.__module__.__eq__",
       ["threading"],
       true,
       "threading.Condition.__module__.__eq__('threading') == True — threading.Condition is a pure-Python class defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra114"]
    - [barrier_module_threading,
       "Barrier.__module__.__eq__",
       ["threading"],
       true,
       "threading.Barrier.__module__.__eq__('threading') == True — threading.Barrier is a pure-Python class defined in Lib/threading.py; its __module__ is 'threading'; str.__eq__('threading') returns True; new to extra114"]
    - [lock_module_len_7,
       "Lock.__module__.__len__",
       [],
       7,
       "threading.Lock.__module__.__len__() == 7 — '_thread' has 7 characters: _-t-h-r-e-a-d; str.__len__() returns 7; int.__eq__(7) returns True; new to extra114"]
    - [event_module_len_9,
       "Event.__module__.__len__",
       [],
       9,
       "threading.Event.__module__.__len__() == 9 — 'threading' has 9 characters: t-h-r-e-a-d-i-n-g; the same length for all pure-Python threading class __module__ values; str.__len__() returns 9; int.__eq__(9) returns True; new to extra114"]

# ---------------------------------------------------------------------------
# Table 3: threading primitives __qualname__ attributes and name lengths
#
# Wave 264 theme: threading.Lock.__qualname__ == 'lock' (matches __name__,
# no dotted prefix — it is a top-level C-extension type). threading.Event,
# threading.Semaphore, threading.Condition, threading.Barrier all have
# __qualname__ == __name__ (top-level pure-Python classes). The name lengths
# form an ordered sequence: lock(4) < Event(5) == RLock(5) < Barrier(7) <
# Semaphore(9) == Condition(9) < BoundedSemaphore(16).
#
# threading.Lock.__qualname__ == 'lock'
# threading.Event.__qualname__ == 'Event'
# threading.Semaphore.__qualname__ == 'Semaphore'
# threading.Condition.__qualname__ == 'Condition'
# threading.Barrier.__qualname__ == 'Barrier'
# len('BoundedSemaphore') == 16
#
# New to extra114.
# ---------------------------------------------------------------------------

table threading_extra114.primitive_qualnames:
  description: "threading primitive __qualname__: Lock='lock', Event='Event', Semaphore='Semaphore'(9), Condition='Condition'(9), Barrier='Barrier'(7), BoundedSemaphore(16); all __qualname__==__name__; wave 264; new to extra114"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingpq114

  columns: [id, function, args, expected, description]
  rows:
    - [lock_qualname_eq,
       "Lock.__qualname__.__eq__",
       ["lock"],
       true,
       "threading.Lock.__qualname__.__eq__('lock') == True — threading.Lock is the C-extension type _thread.lock; its __qualname__ is 'lock' (same as __name__; top-level type with no enclosing scope); str.__eq__('lock') returns True; new to extra114"]
    - [event_qualname_eq,
       "Event.__qualname__.__eq__",
       ["Event"],
       true,
       "threading.Event.__qualname__.__eq__('Event') == True — threading.Event is defined at module scope in Lib/threading.py; its __qualname__ is 'Event' (same as __name__); str.__eq__('Event') returns True; new to extra114"]
    - [semaphore_qualname_eq,
       "Semaphore.__qualname__.__eq__",
       ["Semaphore"],
       true,
       "threading.Semaphore.__qualname__.__eq__('Semaphore') == True — threading.Semaphore is defined at module scope; its __qualname__ is 'Semaphore'; str.__eq__('Semaphore') returns True; new to extra114"]
    - [condition_qualname_eq,
       "Condition.__qualname__.__eq__",
       ["Condition"],
       true,
       "threading.Condition.__qualname__.__eq__('Condition') == True — threading.Condition is defined at module scope; its __qualname__ is 'Condition'; str.__eq__('Condition') returns True; new to extra114"]
    - [barrier_qualname_eq,
       "Barrier.__qualname__.__eq__",
       ["Barrier"],
       true,
       "threading.Barrier.__qualname__.__eq__('Barrier') == True — threading.Barrier is defined at module scope; its __qualname__ is 'Barrier' (len 7); str.__eq__('Barrier') returns True; new to extra114"]
    - [barrier_name_len_7,
       "Barrier.__name__.__len__",
       [],
       7,
       "threading.Barrier.__name__.__len__() == 7 — 'Barrier' has 7 characters: B-a-r-r-i-e-r; str.__len__() returns 7; int.__eq__(7) returns True; new to extra114"]
    - [semaphore_name_len_eq_condition_name_len,
       "Semaphore.__name__.__len__",
       [],
       9,
       "threading.Semaphore.__name__.__len__() == 9 — 'Semaphore' has 9 characters; the same length as 'Condition' (9); both are 9-character threading synchronization primitive names; str.__len__() returns 9; int.__eq__(9) returns True; new to extra114"]
    - [boundedsemaphore_name_len_16,
       "BoundedSemaphore.__name__.__len__",
       [],
       16,
       "threading.BoundedSemaphore.__name__.__len__() == 16 — 'BoundedSemaphore' has 16 characters; the longest primitive name; 7 more than Semaphore (9) because of the 'Bounded' prefix; str.__len__() returns 16; int.__eq__(16) returns True; new to extra114"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra114
# ---------------------------------------------------------------------------

invariant threading_extra114.lock_name_lowercase:
  description: "threading.Lock.__name__ == 'lock' — lowercase; C-extension from _thread; contrasts with CamelCase pure-Python classes; wave 264; new to extra114"
  kind: python_call_eq
  function: Lock.__name__.__eq__
  args: ["lock"]
  expected: true

invariant threading_extra114.lock_module_thread:
  description: "threading.Lock.__module__ == '_thread' — C-extension type; different module from pure-Python threading classes; wave 264; new to extra114"
  kind: python_call_eq
  function: Lock.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra114.event_module_threading:
  description: "threading.Event.__module__ == 'threading' — pure-Python class; contrasts with Lock which is from '_thread'; wave 264; new to extra114"
  kind: python_call_eq
  function: Event.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra114.semaphore_name_len:
  description: "len(threading.Semaphore.__name__) == 9 — 'Semaphore' is 9 characters; same length as Condition; wave 264; new to extra114"
  kind: python_call_eq
  function: Semaphore.__name__.__len__
  args: []
  expected: 9

invariant threading_extra114.boundedsemaphore_name_len:
  description: "len(threading.BoundedSemaphore.__name__) == 16 — 'BoundedSemaphore' is 16 characters; longest threading primitive name; wave 264; new to extra114"
  kind: python_call_eq
  function: BoundedSemaphore.__name__.__len__
  args: []
  expected: 16
