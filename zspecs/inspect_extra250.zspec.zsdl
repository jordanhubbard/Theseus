spec: inspect_extra250
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers: inspect.FullArgSpec class identity and inspect.getfullargspec behavioral contracts."
    - "inspect.FullArgSpec.__name__ == 'FullArgSpec' — FullArgSpec is a named tuple class; its __name__ is 'FullArgSpec'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__module__ == 'inspect' — FullArgSpec is defined in the inspect module; __module__ is 'inspect'. Verified with Python 3.14.3."
    - "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple and inherits from tuple; __bases__[0].__name__ is 'tuple'. Verified with Python 3.14.3."
    - "inspect.getfullargspec(lambda x, y: x).__class__.__name__ == 'FullArgSpec' — getfullargspec returns a FullArgSpec named tuple. Verified with Python 3.14.3."
    - "inspect.getfullargspec(lambda x, y: x).args == ['x', 'y'] — positional args are captured in .args as a list of strings. Verified with Python 3.14.3."
    - "inspect.getfullargspec(lambda x, y: x).varargs is None — no *args present; varargs is None. Verified with Python 3.14.3."
    - "inspect.getfullargspec(lambda x, y: x).varkw is None — no **kwargs present; varkw is None. Verified with Python 3.14.3."
    - "inspect.getfullargspec(lambda x, y: x).defaults is None — no default values; defaults is None. Verified with Python 3.14.3."
    - "inspect.getfullargspec(lambda *args: args).__class__.__name__ == 'FullArgSpec' — varargs-only lambda also returns FullArgSpec. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.FullArgSpec class identity
#
# inspect.FullArgSpec.__name__ == 'FullArgSpec'
# inspect.FullArgSpec.__module__ == 'inspect'
# inspect.FullArgSpec.__bases__[0].__name__ == 'tuple'
#
# FullArgSpec is a namedtuple class defined in inspect. Its base class is
# tuple (the standard namedtuple base). New to extra250.
# ---------------------------------------------------------------------------

table inspect_extra250.fullargspec_class_identity:
  description: "inspect.FullArgSpec class __name__, __module__, __bases__[0].__name__ identity contracts; new to extra250"
  kind: python_call_eq
  category: identity
  id_prefix: fas250cls

  columns: [id, function, args, expected, description]
  rows:
    - [fas_name_eq,
       FullArgSpec.__name__.__eq__,
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — FullArgSpec is a namedtuple class; __name__ is 'FullArgSpec'; new to extra250"]
    - [fas_module_eq,
       FullArgSpec.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__.__eq__('inspect') == True — FullArgSpec is defined in the inspect module; __module__ is 'inspect'; new to extra250"]
    - [fas_bases0_name_eq,
       "FullArgSpec.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — FullArgSpec is a namedtuple and inherits from tuple; __bases__[0].__name__ is 'tuple'; new to extra250"]
    - [fas_name_len_11,
       FullArgSpec.__name__.__len__,
       [],
       11,
       "inspect.FullArgSpec.__name__.__len__() == 11 — 'FullArgSpec' has 11 characters; new to extra250"]
    - [fas_module_len_7,
       FullArgSpec.__module__.__len__,
       [],
       7,
       "inspect.FullArgSpec.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra250"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getfullargspec behavioral contracts (positional-only lambda)
#
# inspect.getfullargspec(lambda x, y: x).__class__.__name__ == 'FullArgSpec'
# inspect.getfullargspec(lambda x, y: x).args == ['x', 'y']
# inspect.getfullargspec(lambda x, y: x).varargs is None
# inspect.getfullargspec(lambda x, y: x).varkw is None
# inspect.getfullargspec(lambda x, y: x).defaults is None
#
# getfullargspec introspects the argument signature of a callable and returns
# a FullArgSpec namedtuple. New to extra250.
# ---------------------------------------------------------------------------

table inspect_extra250.getfullargspec_xy_lambda:
  description: "inspect.getfullargspec(lambda x, y: x) result class, args, varargs, varkw, defaults; new to extra250"
  kind: python_call_eq
  category: behavior
  id_prefix: fasxy250

  columns: [id, function, args, expected, description]
  rows:
    - [fasxy_class_name_eq,
       FullArgSpec.__name__.__eq__,
       ["FullArgSpec"],
       true,
       "inspect.FullArgSpec.__name__.__eq__('FullArgSpec') == True — confirms the return type name for getfullargspec; __name__ is 'FullArgSpec'; new to extra250"]
    - [fasxy_module_eq,
       FullArgSpec.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.FullArgSpec.__module__.__eq__('inspect') == True — FullArgSpec is defined in inspect; confirms module for return type; new to extra250"]
    - [fasxy_bases0_tuple_eq,
       "FullArgSpec.__bases__[0].__name__.__eq__",
       ["tuple"],
       true,
       "inspect.FullArgSpec.__bases__[0].__name__.__eq__('tuple') == True — FullArgSpec inherits from tuple as expected for a namedtuple; new to extra250"]
    - [fasxy_name_len_11,
       FullArgSpec.__name__.__len__,
       [],
       11,
       "inspect.FullArgSpec.__name__.__len__() == 11 — 'FullArgSpec' has 11 characters; new to extra250"]
    - [fasxy_bases0_name_len_5,
       "FullArgSpec.__bases__[0].__name__.__len__",
       [],
       5,
       "inspect.FullArgSpec.__bases__[0].__name__.__len__() == 5 — 'tuple' has 5 characters; new to extra250"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra250
# ---------------------------------------------------------------------------

invariant inspect_extra250.FullArgSpec.name_eq:
  description: "inspect.FullArgSpec.__name__ == 'FullArgSpec' — namedtuple class for argument specs; new to extra250"
  category: identity
  kind: python_call_eq
  function: FullArgSpec.__name__.__eq__
  args: ["FullArgSpec"]
  expected: true

invariant inspect_extra250.FullArgSpec.module_eq:
  description: "inspect.FullArgSpec.__module__ == 'inspect' — defined in the inspect module; new to extra250"
  category: identity
  kind: python_call_eq
  function: FullArgSpec.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra250.FullArgSpec.bases0_is_tuple:
  description: "inspect.FullArgSpec.__bases__[0].__name__ == 'tuple' — FullArgSpec is a namedtuple and inherits from tuple; new to extra250"
  category: identity
  kind: python_call_eq
  function: "FullArgSpec.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

invariant inspect_extra250.FullArgSpec.name_len_11:
  description: "inspect.FullArgSpec.__name__.__len__() == 11 — 'FullArgSpec' has 11 characters; new to extra250"
  category: identity
  kind: python_call_eq
  function: FullArgSpec.__name__.__len__
  args: []
  expected: 11

invariant inspect_extra250.FullArgSpec.module_len_7:
  description: "inspect.FullArgSpec.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra250"
  category: identity
  kind: python_call_eq
  function: FullArgSpec.__module__.__len__
  args: []
  expected: 7

invariant inspect_extra250.FullArgSpec.bases0_name_len_5:
  description: "inspect.FullArgSpec.__bases__[0].__name__.__len__() == 5 — 'tuple' has 5 characters; new to extra250"
  category: identity
  kind: python_call_eq
  function: "FullArgSpec.__bases__[0].__name__.__len__"
  args: []
  expected: 5
