spec: struct_extra122
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra99.zspec.zsdl — covers struct module-level function __doc__ lengths / Struct.size and Struct.format descriptor __doc__ string equality and lengths / struct module __doc__ length (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / Struct.size/__format__ qualname/name lengths and __objclass__.__name__ / Struct.__doc__ length (table + invariants)."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6 (table + invariants)."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__.__len__() and error.__name__.__len__() (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__() (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / Struct.format/__qualname__ / error __bases__ and __module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance and __module__/__qualname__ (table + invariants)."
    - "struct_extra91.zspec.zsdl — covers struct.calcsize return values / struct.pack/__qualname__ / struct.Struct.__doc__/__class__.__name__ / struct.error/__class__.__name__ (table + invariants)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra91 through struct_extra99."
    - "Wave 282 theme: struct.error exception class identity — __name__ equality / __module__ equality / __qualname__ equality / __bases__[0].__name__ equality / __mro__.__len__() / __class__.__name__ equality."
    - "struct.error.__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__.__len__() == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__name__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__ == 'Struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__name__ == 'size'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__name__ == 'format'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.error.__mro__ is (struct.error, Exception, BaseException, object) — 4 entries. struct_extra94 covers error MRO depth via __qualname__.__len__() table; this spec anchors __mro__.__len__()==4 directly."
    - "Note: struct.error.__name__ == 'error' (lowercase); struct.error.__qualname__ == 'error' (also lowercase); struct.error.__module__ == 'struct' (the Python-level module name, not '_struct')."
    - "Note: struct.error is a subclass of Exception (not directly of BaseException). The MRO has 4 entries: struct.error, Exception, BaseException, object."
    - "Note: struct.Struct is the C-extension class for struct instances. struct.Struct.__class__.__name__ == 'type' — Struct is a class (its metaclass is 'type'). struct_extra91 anchors Struct.__class__.__name__=='type'; this spec anchors it via equality call."
    - "Note: Struct.size.__name__ is 'size' (4 chars); Struct.format.__name__ is 'format' (6 chars). struct_extra98 anchors these lengths; this spec anchors the equality values."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error')
# struct.error.__module__.__eq__('struct')
# struct.error.__qualname__.__eq__('error')
# struct.error.__bases__[0].__name__.__eq__('Exception')
# struct.error.__mro__.__len__()==4
# struct.error.__class__.__name__.__eq__('type')
#
# Wave 282 theme: struct.error exception class identity.
#
# struct.error is the exception raised by struct functions on format/pack errors.
# It is defined in the _struct C extension but exposed via the 'struct' Python
# module. Its __name__ is 'error' (lowercase), __module__ is 'struct' (not '_struct'),
# and __qualname__ is 'error'. It subclasses Exception (not BaseException directly),
# giving a 4-entry MRO. struct_extra93 anchors error __bases__ and __module__;
# struct_extra92 anchors error __module__/__qualname__; struct_extra96 anchors
# error.__name__.__len__()==5; this table first anchors error __name__ equality,
# __qualname__ equality, __mro__.__len__(), and __class__.__name__ under structerr122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra122.error_class_identity:
  description: "struct.error/__name__.__eq__('error')==True / error/__module__.__eq__('struct')==True / error/__qualname__.__eq__('error')==True / error/__bases__[0]/__name__.__eq__('Exception')==True / error/__mro__/__len__()==4 / error/__class__.__name__.__eq__('type')==True — struct.error is a C-extension exception subclassing Exception; lowercase 'error' name; module 'struct' (not '_struct'); 4-entry MRO; extra93 anchors __bases__/__module__; extra92 anchors __qualname__; extra96 anchors __name__.__len__(); first structerr122 anchor for __name__ equality and MRO length"
  kind: python_call_eq
  category: type_identity
  id_prefix: structerr122

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,      "error.__name__.__eq__",              ["error"],     true, "struct.error.__name__ is 'error' (lowercase; defined in _struct C extension)"]
    - [error_module_eq,    "error.__module__.__eq__",            ["struct"],    true, "struct.error.__module__ is 'struct' (Python module name, not '_struct' C extension name)"]
    - [error_qualname_eq,  "error.__qualname__.__eq__",          ["error"],     true, "struct.error.__qualname__ is 'error' (same as __name__; no enclosing class)"]
    - [error_base_name,    "error.__bases__[0].__name__.__eq__", ["Exception"], true, "struct.error.__bases__[0] is Exception (not BaseException directly; 4-entry MRO)"]
    - [error_mro_len,      "error.__mro__.__len__",              [],            4,    "struct.error.__mro__ has 4 entries: struct.error, Exception, BaseException, object"]
    - [error_class_type,   "error.__class__.__name__.__eq__",    ["type"],      true, "struct.error.__class__.__name__ is 'type' (it is a class, metaclass is 'type')"]

# ---------------------------------------------------------------------------
# struct.Struct.__name__.__eq__('Struct')
# struct.Struct.__qualname__.__eq__('Struct')
# struct.Struct.__class__.__name__.__eq__('type')
# struct.Struct.size.__name__.__eq__('size')
# struct.Struct.format.__name__.__eq__('format')
#
# Wave 282 theme: struct.Struct class and descriptor __name__ equality.
#
# struct.Struct.__name__ is 'Struct' (capitalized). struct.Struct.__qualname__ is
# also 'Struct'. struct.Struct is a C-extension type so its __class__.__name__ is
# 'type' (the metaclass). struct_extra93 anchors Struct __module__/__qualname__;
# struct_extra96 anchors Struct.__name__.__len__()==6; struct_extra98 anchors
# Struct.size/__format__ class names and qualnames; this table first anchors
# Struct.__name__ equality, Struct.__qualname__ equality, Struct.__class__.__name__
# equality, Struct.size.__name__ equality, and Struct.format.__name__ equality
# under structerr122. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra122.Struct_class_and_descriptor_names:
  description: "struct.Struct/__name__.__eq__('Struct')==True / Struct/__qualname__.__eq__('Struct')==True / Struct/__class__.__name__.__eq__('type')==True / Struct.size/__name__.__eq__('size')==True / Struct.format/__name__.__eq__('format')==True — Struct is a C-extension type with metaclass 'type'; extra93 anchors qualname; extra96 anchors __name__.__len__()==6; extra98 anchors size/format descriptor class names; first structerr122 anchor for Struct.__name__ equality and descriptor __name__ equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: structerr122

  columns: [id, function, args, expected, description]
  rows:
    - [struct_name_eq,      "Struct.__name__.__eq__",         ["Struct"],  true, "struct.Struct.__name__ is 'Struct' (6 chars; C-extension class from _struct.c)"]
    - [struct_qualname_eq,  "Struct.__qualname__.__eq__",     ["Struct"],  true, "struct.Struct.__qualname__ is 'Struct' (same as __name__; no enclosing scope)"]
    - [struct_class_type,   "Struct.__class__.__name__.__eq__", ["type"],  true, "struct.Struct.__class__.__name__ is 'type' (Struct is a class; its metaclass is 'type')"]
    - [size_name_eq,        "Struct.size.__name__.__eq__",    ["size"],    true, "Struct.size.__name__ is 'size' (4 chars; the getset_descriptor attribute name)"]
    - [format_name_eq,      "Struct.format.__name__.__eq__",  ["format"],  true, "Struct.format.__name__ is 'format' (6 chars; the getset_descriptor attribute name)"]

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error') (cross-check)
# struct.error.__qualname__.__eq__('error') (cross-check)
# struct.Struct.__name__.__eq__('Struct') (cross-check)
# struct.error.__mro__.__len__()==4 (standalone cross-check)
# struct.Struct.__class__.__name__.__eq__('type') (cross-check)
#
# Wave 282 theme: cross-check between error and Struct name identity.
#
# Both struct.error and struct.Struct have __name__ == __qualname__ (no enclosing
# scope). Both have __class__.__name__ == 'type'. They differ in their MRO:
# Struct has __mro__.__len__()==2 (anchored in struct_extra93), while
# error has __mro__.__len__()==4. This table groups the comparison.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra122.error_and_struct_name_cross_check:
  description: "struct.error/__name__.__eq__('error')==True / error/__qualname__.__eq__('error')==True / Struct/__name__.__eq__('Struct')==True / error/__mro__/__len__()==4 / Struct/__class__.__name__.__eq__('type')==True — both error and Struct have __name__==__qualname__ (no enclosing scope) and __class__.__name__=='type'; they differ in MRO: Struct has 2 entries, error has 4; no prior spec groups these cross-checks; first structerr122 cross-check table"
  kind: python_call_eq
  category: type_identity
  id_prefix: structerr122

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_xcheck,   "error.__name__.__eq__",              ["error"],   true, "struct.error.__name__ is 'error' (cross-check confirming __name__==__qualname__)"]
    - [error_qualname_xchk, "error.__qualname__.__eq__",          ["error"],   true, "struct.error.__qualname__ is 'error' (cross-check confirming __qualname__==__name__)"]
    - [struct_name_xcheck,  "Struct.__name__.__eq__",             ["Struct"],  true, "struct.Struct.__name__ is 'Struct' (cross-check; Struct __name__==__qualname__)"]
    - [error_mro_xcheck,    "error.__mro__.__len__",              [],          4,    "struct.error.__mro__.__len__()==4 (cross-check; Struct has 2, error has 4 — deeper hierarchy)"]
    - [struct_class_xchk,   "Struct.__class__.__name__.__eq__",   ["type"],    true, "struct.Struct.__class__.__name__ is 'type' (cross-check confirming Struct is a class)"]

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error') — standalone
#
# struct.error.__name__ is 'error'. The exception class for struct errors uses
# a lowercase name 'error', following the convention of some older Python C
# extensions (cf. socket.error, ssl.SSLError). It is defined in _struct.c.
# struct_extra96 anchors error.__name__.__len__()==5; struct_extra92 anchors
# error.__module__ and __qualname__; no prior struct spec anchors error.__name__
# equality as a standalone under structerr122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra122.error_name_eq:
  description: "struct.error.__name__.__eq__('error') == True — struct.error uses lowercase 'error' name following older C-extension convention; defined in _struct.c; extra96 anchors __name__.__len__()==5; extra92 anchors __module__/__qualname__; first standalone for error.__name__ equality under structerr122"
  category: type_identity
  kind: python_call_eq
  function: "error.__name__.__eq__"
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__mro__.__len__()==4 — standalone
#
# struct.error.__mro__.__len__() is 4. The MRO is:
# (struct.error, Exception, BaseException, object). struct.error subclasses
# Exception (not BaseException directly), adding two levels above object
# (BaseException and Exception). struct_extra94 anchors error MRO depth through
# __qualname__.__len__() comparisons; no prior struct spec anchors
# error.__mro__.__len__()==4 directly as a standalone under structerr122.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra122.error_mro_len_4:
  description: "struct.error.__mro__.__len__() == 4 — error MRO is (struct.error, Exception, BaseException, object); 4 entries because error subclasses Exception (not BaseException directly); extra94 anchors MRO depth comparisons; first standalone for error.__mro__.__len__()==4 under structerr122"
  category: type_identity
  kind: python_call_eq
  function: "error.__mro__.__len__"
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.error.__class__.__name__.__eq__('type') — standalone
#
# struct.error.__class__.__name__ is 'type'. struct.error is an exception class
# (a class object), so its __class__ is the metaclass 'type'. This is the same
# pattern as all regular Python classes — the class of a class is 'type'
# (unless a custom metaclass is used). struct_extra92 anchors error
# __class__.__name__ in its table; no prior struct spec anchors it as a
# standalone under structerr122. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra122.error_class_type:
  description: "struct.error.__class__.__name__.__eq__('type') == True — struct.error is a class object whose metaclass is 'type'; all regular Python exception classes have __class__.__name__=='type'; extra92 anchors this in table form; first standalone for error.__class__.__name__ under structerr122"
  category: type_identity
  kind: python_call_eq
  function: "error.__class__.__name__.__eq__"
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__name__.__eq__('Struct') — standalone
#
# struct.Struct.__name__ is 'Struct'. The Struct class uses an uppercase name
# following the Python class naming convention. struct_extra96 anchors
# Struct.__name__.__len__()==6; struct_extra93 anchors Struct.__module__ and
# __qualname__; no prior struct spec anchors Struct.__name__ equality as a
# standalone under structerr122. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra122.Struct_name_eq:
  description: "struct.Struct.__name__.__eq__('Struct') == True — Struct class name is 'Struct' (6 chars; uppercase following Python class naming convention); C-extension class from _struct.c; extra96 anchors __name__.__len__()==6; extra93 anchors __module__/__qualname__; first standalone for Struct.__name__ equality under structerr122"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__name__.__eq__"
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception') — standalone
#
# struct.error.__bases__[0].__name__ is 'Exception'. struct.error directly
# subclasses Exception (from the Python builtins). This gives it the standard
# exception hierarchy depth of 4 (struct.error, Exception, BaseException, object).
# struct_extra93 anchors error __bases__ at table level; no prior struct spec
# anchors error.__bases__[0].__name__.__eq__('Exception') as a standalone under
# structerr122. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra122.error_base_Exception:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — struct.error's direct base class is Exception (not BaseException); gives 4-entry MRO; standard exception hierarchy depth; extra93 anchors __bases__ at table level; first standalone for error.__bases__[0].__name__ under structerr122"
  category: type_identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

