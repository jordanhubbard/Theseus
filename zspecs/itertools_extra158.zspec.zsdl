       ["itertools"],
       true,
       "itertools.chain.__module__.__eq__('itertools') == True — chain is a C extension type in itertoolsmodule.c that chains multiple iterables end-to-end; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra158"]
    - [cycle_module_eq_itertools,
       "cycle.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.cycle.__module__.__eq__('itertools') == True — cycle is a C extension type in itertoolsmodule.c that cycles through an iterable indefinitely; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra158"]
    - [count_module_eq_itertools,
       "count.__module__.__eq__",
       ["itertools"],
       true,
       "itertools.count.__module__.__eq__('itertools') == True — count is a C extension type in itertoolsmodule.c that counts up from a start value with a step; its __module__ is 'itertools'; str.__eq__('itertools') returns True; new to extra158"]
    - [itertools_spec_submodule_search_locations_is_none,
       "__spec__.submodule_search_locations.__eq__",
       [null],
       true,
       "itertools.__spec__.submodule_search_locations.__eq__(None) == True — itertools is a leaf module with no subpackages; its ModuleSpec submodule_search_locations is None; None.__eq__(None) returns True; new to extra158"]

