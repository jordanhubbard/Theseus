  notes:
    - "This spec covers: itertools.__name__.__eq__('itertools') True; itertools.__name__.__len__() 9; itertools.__loader__.__class__.__name__ 'type' (BuiltinImporter is a type not an instance); itertools.__spec__.origin.__eq__('built-in') True; itertools.__spec__.submodule_search_locations is None (leaf module); itertools.chain.__module__.__eq__('itertools') True; itertools.cycle.__module__.__eq__('itertools') True; itertools.count.__module__.__eq__('itertools') True (Wave 287)."
    - "itertools.__name__ == 'itertools' — the module's __name__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.__name__.__len__() == 9 — 'itertools' has 9 characters: i-t-e-r-t-o-o-l-s. Verified with Python 3.14.3."
    - "itertools.__loader__.__class__.__name__ == 'type' — itertools is a C extension module; its __loader__ is the BuiltinImporter class itself (not an instance); its __class__.__name__ is 'type' (the metaclass). Verified with Python 3.14.3."
    - "itertools.__spec__.origin == 'built-in' — itertools is a built-in C extension module; its ModuleSpec origin is 'built-in'. Verified with Python 3.14.3."
    - "itertools.__spec__.submodule_search_locations is None — itertools is a leaf module with no subpackages; submodule_search_locations is None. Verified with Python 3.14.3."
    - "itertools.chain.__module__ == 'itertools' — chain is a C extension type; its __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.cycle.__module__ == 'itertools' — cycle is a C extension type; its __module__ is 'itertools'. Verified with Python 3.14.3."
    - "itertools.count.__module__ == 'itertools' — count is a C extension type; its __module__ is 'itertools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools module __name__ and __loader__ attributes
#
# Wave 287 theme: itertools module identity via __name__, __loader__, and
# __spec__ attributes.
#
# itertools.__name__ == 'itertools'
# itertools.__name__.__len__() == 9
# itertools.__loader__.__class__.__name__ == 'type'
# itertools.__spec__.origin == 'built-in'
#
# itertools is a C extension module built into the interpreter. Its __name__
# is 'itertools' (9 characters). Its __loader__ is the BuiltinImporter class
# object itself (not an instance), so its __class__ is the metaclass 'type'.
# The ModuleSpec for built-in modules has origin == 'built-in'. New to extra158.
# ---------------------------------------------------------------------------

table itertools_extra158.module_name_and_loader_attrs:
  description: "itertools: __name__ 'itertools', __name__ len 9, __loader__.__class__.__name__ 'type', __spec__.origin 'built-in'; wave 287; new to extra158"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsmnla158

  columns: [id, function, args, expected, description]
  rows:
    - [itertools_name_eq,
       "__name__.__eq__",
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the itertools module's __name__ attribute is 'itertools'; it is a C extension module built into CPython; str.__eq__('itertools') returns True; new to extra158"]
    - [itertools_name_len_eq_9,
       "__name__.__len__",
       [],
       9,
       "itertools.__name__.__len__() == 9 — the string 'itertools' has exactly 9 characters: i-t-e-r-t-o-o-l-s; str.__len__() returns 9; new to extra158"]
    - [itertools_loader_class_eq_type,
       "__loader__.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — itertools is a built-in C extension module; its __loader__ is the BuiltinImporter class object itself (not an instance of it); as a class object its own __class__ is the metaclass 'type'; str.__eq__('type') returns True; new to extra158"]
    - [itertools_spec_origin_eq_builtin,
       "__spec__.origin.__eq__",
       ["built-in"],
       true,
       "itertools.__spec__.origin.__eq__('built-in') == True — itertools is a built-in C extension module compiled into the interpreter; its ModuleSpec has origin == 'built-in'; str.__eq__('built-in') returns True; new to extra158"]

# ---------------------------------------------------------------------------
# Table 2: itertools C type __module__ attributes (chain, cycle, count)
#
# Wave 287 theme: itertools C extension type __module__ attributes confirming
# all types belong to the itertools module.
#
# itertools.chain.__module__ == 'itertools'
# itertools.cycle.__module__ == 'itertools'
# itertools.count.__module__ == 'itertools'
# itertools.__spec__.submodule_search_locations is None
#
# chain, cycle, and count are all C extension types defined in
# itertoolsmodule.c. Their __module__ attribute is 'itertools', reflecting
# the module they are declared in. itertools has no subpackages, so
# __spec__.submodule_search_locations is None. New to extra158.
# ---------------------------------------------------------------------------

table itertools_extra158.c_type_module_attrs:
  description: "itertools: chain/__module__ 'itertools', cycle/__module__ 'itertools', count/__module__ 'itertools'; __spec__.submodule_search_locations None; wave 287; new to extra158"
