spec: functools_extra140
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.wraps function qualname, module, code attributes; functools.WRAPPER_ASSIGNMENTS and WRAPPER_UPDATES tuple identity (Wave 263)."
    - "functools.wraps.__qualname__ == 'wraps' (len 5) — wraps is defined at module scope in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.wraps.__module__ == 'functools' (len 9). Verified with Python 3.14.3."
    - "functools.wraps.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_argcount == 3 — takes wrapped, assigned, updated. Verified with Python 3.14.3."
    - "len(functools.wraps.__code__.co_varnames) == 3 — co_varnames is ('wrapped', 'assigned', 'updated'). Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_varnames[0] == 'wrapped'. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_varnames[1] == 'assigned'. Verified with Python 3.14.3."
    - "functools.wraps.__code__.co_varnames[2] == 'updated'. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple' — WRAPPER_ASSIGNMENTS is a module-level tuple constant. Verified with Python 3.14.3."
    - "len(functools.WRAPPER_ASSIGNMENTS) == 6 — contains: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS[0] == '__module__'. Verified with Python 3.14.3."
    - "functools.WRAPPER_ASSIGNMENTS[1] == '__name__'. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple' — WRAPPER_UPDATES is a module-level tuple constant. Verified with Python 3.14.3."
    - "len(functools.WRAPPER_UPDATES) == 1 — contains only '__dict__'. Verified with Python 3.14.3."
    - "functools.WRAPPER_UPDATES[0] == '__dict__'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.wraps function identity
#
# Wave 263 theme: functools.wraps function qualname, module, and class.
#
# functools.wraps.__qualname__ == 'wraps' (len 5)
# functools.wraps.__module__ == 'functools' (len 9)
# functools.wraps.__class__.__name__ == 'function'
#
# wraps is a Python function defined at module scope in Lib/functools.py.
# It is a decorator factory that updates the wrapper function to look like
# the wrapped function. New to extra140.
# ---------------------------------------------------------------------------

table functools_extra140.wraps_function_identity:
  description: "functools.wraps function identity: __qualname__ len 5, __module__ len 9, __class__.__name__=='function'; wave 263; new to extra140"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswraps140

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_qualname_eq,
       "wraps.__qualname__.__eq__",
       ["wraps"],
       true,
       "functools.wraps.__qualname__.__eq__('wraps') == True — wraps is defined at module scope in Lib/functools.py; its __qualname__ is 'wraps'; str.__eq__('wraps') returns True; new to extra140"]
    - [wraps_qualname_len_eq_5,
       "wraps.__qualname__.__len__",
       [],
       5,
       "functools.wraps.__qualname__.__len__() == 5 — __qualname__ is 'wraps' which has 5 characters; len('wraps') == 5; new to extra140"]
    - [wraps_module_eq_functools,
       "wraps.__module__.__eq__",
       ["functools"],
       true,
       "functools.wraps.__module__.__eq__('functools') == True — wraps is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra140"]
    - [wraps_module_len_eq_9,
       "wraps.__module__.__len__",
       [],
       9,
       "functools.wraps.__module__.__len__() == 9 — __module__ is 'functools' which has 9 characters; len('functools') == 9; new to extra140"]
    - [wraps_class_name_eq_function,
       "wraps.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.wraps.__class__.__name__.__eq__('function') == True — wraps is a regular Python function defined at module scope in Lib/functools.py; its __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra140"]

# ---------------------------------------------------------------------------
# Table 2: functools.wraps code attributes
#
# Wave 263 theme: functools.wraps co_argcount and co_varnames.
#
# functools.wraps.__code__.co_argcount == 3
# len(functools.wraps.__code__.co_varnames) == 3
# functools.wraps.__code__.co_varnames[0] == 'wrapped'
# functools.wraps.__code__.co_varnames[1] == 'assigned'
# functools.wraps.__code__.co_varnames[2] == 'updated'
#
# wraps takes (wrapped, assigned=WRAPPER_ASSIGNMENTS, updated=WRAPPER_UPDATES).
# All three are positional-or-keyword with defaults; co_argcount is 3.
# New to extra140.
# ---------------------------------------------------------------------------

table functools_extra140.wraps_code_attrs:
  description: "functools.wraps.__code__: co_argcount==3, co_varnames len 3, co_varnames==(wrapped, assigned, updated); wave 263; new to extra140"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswrapscode140

  columns: [id, function, args, expected, description]
  rows:
    - [wraps_co_argcount_eq_3,
       "wraps.__code__.co_argcount.__eq__",
       [3],
       true,
       "functools.wraps.__code__.co_argcount.__eq__(3) == True — wraps takes 3 positional-or-keyword arguments: wrapped, assigned, updated; co_argcount is 3; int.__eq__(3) returns True; new to extra140"]
    - [wraps_co_varnames_len_eq_3,
       "wraps.__code__.co_varnames.__len__",
       [],
       3,
       "functools.wraps.__code__.co_varnames.__len__() == 3 — wraps has 3 local variables: wrapped, assigned, updated; len(co_varnames) == 3; new to extra140"]
    - [wraps_co_varnames_0_eq_wrapped,
       "wraps.__code__.co_varnames[0].__eq__",
       ["wrapped"],
       true,
       "functools.wraps.__code__.co_varnames[0].__eq__('wrapped') == True — the first local variable of wraps is 'wrapped', the callable being decorated; str.__eq__('wrapped') returns True; new to extra140"]
    - [wraps_co_varnames_1_eq_assigned,
       "wraps.__code__.co_varnames[1].__eq__",
       ["assigned"],
       true,
       "functools.wraps.__code__.co_varnames[1].__eq__('assigned') == True — the second local variable of wraps is 'assigned', the tuple of attributes to assign from wrapped to wrapper (defaults to WRAPPER_ASSIGNMENTS); str.__eq__('assigned') returns True; new to extra140"]
    - [wraps_co_varnames_2_eq_updated,
       "wraps.__code__.co_varnames[2].__eq__",
       ["updated"],
       true,
       "functools.wraps.__code__.co_varnames[2].__eq__('updated') == True — the third local variable of wraps is 'updated', the tuple of attributes to update on the wrapper (defaults to WRAPPER_UPDATES); str.__eq__('updated') returns True; new to extra140"]

# ---------------------------------------------------------------------------
# Table 3: functools.WRAPPER_ASSIGNMENTS tuple identity and elements
#
# Wave 263 theme: WRAPPER_ASSIGNMENTS type, length, and element access.
#
# functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'
# len(functools.WRAPPER_ASSIGNMENTS) == 6
# functools.WRAPPER_ASSIGNMENTS[0] == '__module__'
# functools.WRAPPER_ASSIGNMENTS[1] == '__name__'
#
# WRAPPER_ASSIGNMENTS is a module-level tuple of attribute names that are
# copied from the wrapped function to the wrapper function. In Python 3.14
# it has 6 elements: __module__, __name__, __qualname__, __doc__,
# __annotate__, __type_params__. New to extra140.
# ---------------------------------------------------------------------------

table functools_extra140.wrapper_assignments_identity:
  description: "functools.WRAPPER_ASSIGNMENTS: __class__.__name__=='tuple', len==6, [0]=='__module__', [1]=='__name__'; wave 263; new to extra140"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswrapperasgn140

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_assignments_class_eq_tuple,
       "WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__('tuple') == True — WRAPPER_ASSIGNMENTS is a module-level tuple constant in Lib/functools.py; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra140"]
    - [wrapper_assignments_len_eq_6,
       "WRAPPER_ASSIGNMENTS.__len__",
       [],
       6,
       "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — WRAPPER_ASSIGNMENTS contains 6 elements: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__; len() == 6; new to extra140"]
    - [wrapper_assignments_0_eq_module,
       "WRAPPER_ASSIGNMENTS[0].__eq__",
       ["__module__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS[0].__eq__('__module__') == True — the first element of WRAPPER_ASSIGNMENTS is '__module__', the first attribute copied from wrapped to wrapper; str.__eq__('__module__') returns True; new to extra140"]
    - [wrapper_assignments_1_eq_name,
       "WRAPPER_ASSIGNMENTS[1].__eq__",
       ["__name__"],
       true,
       "functools.WRAPPER_ASSIGNMENTS[1].__eq__('__name__') == True — the second element of WRAPPER_ASSIGNMENTS is '__name__', the function name attribute copied from wrapped to wrapper; str.__eq__('__name__') returns True; new to extra140"]

# ---------------------------------------------------------------------------
# Table 4: functools.WRAPPER_UPDATES tuple identity and elements
#
# Wave 263 theme: WRAPPER_UPDATES type, length, and element access.
#
# functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'
# len(functools.WRAPPER_UPDATES) == 1
# functools.WRAPPER_UPDATES[0] == '__dict__'
#
# WRAPPER_UPDATES is a module-level tuple containing only '__dict__'.
# The wrapper's __dict__ is updated (merged) from the wrapped function's
# __dict__ rather than replaced. New to extra140.
# ---------------------------------------------------------------------------

table functools_extra140.wrapper_updates_identity:
  description: "functools.WRAPPER_UPDATES: __class__.__name__=='tuple', len==1, [0]=='__dict__'; wave 263; new to extra140"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolswrapperupd140

  columns: [id, function, args, expected, description]
  rows:
    - [wrapper_updates_class_eq_tuple,
       "WRAPPER_UPDATES.__class__.__name__.__eq__",
       ["tuple"],
       true,
       "functools.WRAPPER_UPDATES.__class__.__name__.__eq__('tuple') == True — WRAPPER_UPDATES is a module-level tuple constant in Lib/functools.py; its __class__.__name__ is 'tuple'; str.__eq__('tuple') returns True; new to extra140"]
    - [wrapper_updates_len_eq_1,
       "WRAPPER_UPDATES.__len__",
       [],
       1,
       "functools.WRAPPER_UPDATES.__len__() == 1 — WRAPPER_UPDATES contains exactly 1 element: '__dict__'; len() == 1; new to extra140"]
    - [wrapper_updates_0_eq_dict,
       "WRAPPER_UPDATES[0].__eq__",
       ["__dict__"],
       true,
       "functools.WRAPPER_UPDATES[0].__eq__('__dict__') == True — the sole element of WRAPPER_UPDATES is '__dict__'; the wrapper's __dict__ is updated (via dict.update) from the wrapped function's __dict__; str.__eq__('__dict__') returns True; new to extra140"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra140
# ---------------------------------------------------------------------------

invariant functools_extra140.wraps_qualname_len:
  description: "len(functools.wraps.__qualname__) == 5 — __qualname__ is 'wraps'; wave 263; new to extra140"
  kind: python_call_eq
  function: wraps.__qualname__.__len__
  args: []
  expected: 5

invariant functools_extra140.wraps_co_argcount:
  description: "functools.wraps.__code__.co_argcount == 3 — takes wrapped, assigned, updated; wave 263; new to extra140"
  kind: python_call_eq
  function: wraps.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant functools_extra140.wraps_co_varnames_len:
  description: "len(functools.wraps.__code__.co_varnames) == 3 — co_varnames is (wrapped, assigned, updated); wave 263; new to extra140"
  kind: python_call_eq
  function: wraps.__code__.co_varnames.__len__
  args: []
  expected: 3

invariant functools_extra140.wrapper_assignments_len:
  description: "len(functools.WRAPPER_ASSIGNMENTS) == 6 — contains 6 attribute names; wave 263; new to extra140"
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra140.wrapper_updates_len:
  description: "len(functools.WRAPPER_UPDATES) == 1 — contains only '__dict__'; wave 263; new to extra140"
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

