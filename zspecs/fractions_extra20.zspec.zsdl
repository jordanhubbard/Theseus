invariant fractions_extra20.denominator.fget_qualname_len:
  description: "len(fractions.Fraction.denominator.fget.__qualname__) == 20 — 'Fraction.denominator' is 20 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.denominator.fget.__qualname__.__len__
  args: []
  expected: 20
