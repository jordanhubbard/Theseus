spec: fractions_extra20
version: ">=3.9"
backend: python_module(fractions)

docs: https://docs.python.org/3/library/fractions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/fractions.html — Python fractions module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/fractions.py"
  notes:
    - "This spec extends fractions_extra through fractions_extra19."
    - "fractions_extra19 covers __qualname__.__len__ for Fraction.__neg__, __abs__, and closure operators __sub__, __mul__, __truediv__."
    - "No prior spec covers __qualname__ for Fraction.__hash__, __bool__, __floor__, __ceil__, __round__, __int__."
    - "No prior spec covers __qualname__ for Fraction comparison methods __eq__, __lt__, __le__, __gt__, __ge__."
    - "No prior spec covers __qualname__ for Fraction property fget functions (numerator, denominator)."
    - "All these methods are defined directly on Fraction; qualname follows 'Fraction.<name>'."
    - "Exception: Fraction.__float__ delegates to Rational.__float__; its __qualname__ is 'Rational.__float__'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Fraction utility method __qualname__ values
#
# No prior spec records __qualname__ for __hash__, __bool__, __floor__,
# __ceil__, __round__, __int__.  All are defined directly on Fraction.
# ---------------------------------------------------------------------------

table fractions_extra20.utility_method_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [hash,  Fraction.__hash__.__qualname__.__eq__,  ["Fraction.__hash__"],  true, "Fraction.__hash__.__qualname__ == 'Fraction.__hash__'"]
    - [bool,  Fraction.__bool__.__qualname__.__eq__,  ["Fraction.__bool__"],  true, "Fraction.__bool__.__qualname__ == 'Fraction.__bool__'"]
    - [floor, Fraction.__floor__.__qualname__.__eq__, ["Fraction.__floor__"], true, "Fraction.__floor__.__qualname__ == 'Fraction.__floor__'"]
    - [ceil,  Fraction.__ceil__.__qualname__.__eq__,  ["Fraction.__ceil__"],  true, "Fraction.__ceil__.__qualname__ == 'Fraction.__ceil__'"]
    - [round, Fraction.__round__.__qualname__.__eq__, ["Fraction.__round__"], true, "Fraction.__round__.__qualname__ == 'Fraction.__round__'"]
    - [int,   Fraction.__int__.__qualname__.__eq__,   ["Fraction.__int__"],   true, "Fraction.__int__.__qualname__ == 'Fraction.__int__'"]

# ---------------------------------------------------------------------------
# Fraction comparison method __qualname__ values
#
# No prior spec records __qualname__ for __eq__, __lt__, __le__, __gt__, __ge__.
# ---------------------------------------------------------------------------

table fractions_extra20.comparison_method_qualnames:
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected, description]
  rows:
    - [eq, Fraction.__eq__.__qualname__.__eq__, ["Fraction.__eq__"], true, "Fraction.__eq__.__qualname__ == 'Fraction.__eq__'"]
    - [lt, Fraction.__lt__.__qualname__.__eq__, ["Fraction.__lt__"], true, "Fraction.__lt__.__qualname__ == 'Fraction.__lt__'"]
    - [le, Fraction.__le__.__qualname__.__eq__, ["Fraction.__le__"], true, "Fraction.__le__.__qualname__ == 'Fraction.__le__'"]
    - [gt, Fraction.__gt__.__qualname__.__eq__, ["Fraction.__gt__"], true, "Fraction.__gt__.__qualname__ == 'Fraction.__gt__'"]
    - [ge, Fraction.__ge__.__qualname__.__eq__, ["Fraction.__ge__"], true, "Fraction.__ge__.__qualname__ == 'Fraction.__ge__'"]

# ---------------------------------------------------------------------------
# Fraction property fget __qualname__ values
#
# No prior spec records __qualname__ for the numerator and denominator
# property getter functions.  Their __qualname__ follows 'Fraction.<attr>'.
# ---------------------------------------------------------------------------

invariant fractions_extra20.numerator.fget_qualname:
  description: "fractions.Fraction.numerator.fget.__qualname__ == 'Fraction.numerator'"
  category: method_identity
  kind: python_call_eq
  function: Fraction.numerator.fget.__qualname__.__eq__
  args: ["Fraction.numerator"]
  expected: true

invariant fractions_extra20.denominator.fget_qualname:
  description: "fractions.Fraction.denominator.fget.__qualname__ == 'Fraction.denominator'"
  category: method_identity
  kind: python_call_eq
  function: Fraction.denominator.fget.__qualname__.__eq__
  args: ["Fraction.denominator"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ length invariants for newly covered methods
# ---------------------------------------------------------------------------

invariant fractions_extra20.hash.qualname_len:
  description: "len(fractions.Fraction.__hash__.__qualname__) == 17 — 'Fraction.__hash__' is 17 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__hash__.__qualname__.__len__
  args: []
  expected: 17

invariant fractions_extra20.bool.qualname_len:
  description: "len(fractions.Fraction.__bool__.__qualname__) == 17 — 'Fraction.__bool__' is 17 chars"
  category: method_identity
  kind: python_call_eq
  function: Fraction.__bool__.__qualname__.__len__
