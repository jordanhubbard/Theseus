spec: pathlib_extra1606
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "behavioral invariants for __slots__ and slot descriptor protocol"
    - "pathlib.PurePath uses __slots__ with 8 named slots; subclasses PurePosixPath and PureWindowsPath define empty __slots__ to participate in the hierarchy"
    - "pathlib.Path defines __slots__ = ('_info',); PosixPath defines empty __slots__"
    - "slot descriptors in pathlib classes are of type member_descriptor — a data descriptor implementing __get__, __set__, and __delete__"
    - "PurePath instances cannot have arbitrary attributes set; __slots__ prevents __dict__ creation on instances"
    - "All slot names in PurePath are private (leading underscore), used for caching parsed path components"
    - "Slot names: _raw_paths, _drv, _root, _tail_cached, _str, _str_normcase_cached, _parts_normcase_cached, _hash"
    - "PurePath does NOT expose __dict__ or __weakref__ in its class dict — slots fully control instance layout"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: PurePath slot declarations and slot descriptor types
# ---------------------------------------------------------------------------

table pathlib_extra1606.purepath_slots:
  description: "pathlib.PurePath declares __slots__ with 8 private cache slots; PurePosixPath and PureWindowsPath declare empty __slots__; slot descriptors are member_descriptor type"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1606pp

  columns: [id, function, args, expected]
  rows:
    - ["pl1606pp001", pathlib.PurePath.__dict__.__contains__,        ["__slots__"],                true]
    - ["pl1606pp002", pathlib.PurePosixPath.__dict__.__contains__,   ["__slots__"],                true]
    - ["pl1606pp003", pathlib.PureWindowsPath.__dict__.__contains__,  ["__slots__"],                true]
    - ["pl1606pp004", pathlib.PurePath.__dict__.__contains__,        ["__dict__"],                 false]
    - ["pl1606pp005", pathlib.PurePath.__dict__.__contains__,        ["__weakref__"],               false]
    - ["pl1606pp006", pathlib.PurePosixPath.__dict__.__contains__,   ["__dict__"],                 false]
    - ["pl1606pp007", pathlib.PureWindowsPath.__dict__.__contains__,  ["__dict__"],                 false]
    - ["pl1606pp008", pathlib.PurePath.__dict__.__contains__,        ["_raw_paths"],               true]
    - ["pl1606pp009", pathlib.PurePath.__dict__.__contains__,        ["_drv"],                     true]
    - ["pl1606pp010", pathlib.PurePath.__dict__.__contains__,        ["_root"],                    true]
    - ["pl1606pp011", pathlib.PurePath.__dict__.__contains__,        ["_tail_cached"],             true]
    - ["pl1606pp012", pathlib.PurePath.__dict__.__contains__,        ["_str"],                     true]
    - ["pl1606pp013", pathlib.PurePath.__dict__.__contains__,        ["_str_normcase_cached"],     true]
    - ["pl1606pp014", pathlib.PurePath.__dict__.__contains__,        ["_parts_normcase_cached"],   true]
    - ["pl1606pp015", pathlib.PurePath.__dict__.__contains__,        ["_hash"],                    true]
    - ["pl1606pp016", type(pathlib.PurePath.__dict__["_raw_paths"]).__name__.__eq__,  ["member_descriptor"], true]
    - ["pl1606pp017", type(pathlib.PurePath.__dict__["_drv"]).__name__.__eq__,        ["member_descriptor"], true]
    - ["pl1606pp018", type(pathlib.PurePath.__dict__["_root"]).__name__.__eq__,       ["member_descriptor"], true]
    - ["pl1606pp019", type(pathlib.PurePath.__dict__["_tail_cached"]).__name__.__eq__, ["member_descriptor"], true]
    - ["pl1606pp020", type(pathlib.PurePath.__dict__["_str"]).__name__.__eq__,        ["member_descriptor"], true]
    - ["pl1606pp021", type(pathlib.PurePath.__dict__["_str_normcase_cached"]).__name__.__eq__, ["member_descriptor"], true]
    - ["pl1606pp022", type(pathlib.PurePath.__dict__["_parts_normcase_cached"]).__name__.__eq__, ["member_descriptor"], true]
    - ["pl1606pp023", type(pathlib.PurePath.__dict__["_hash"]).__name__.__eq__,       ["member_descriptor"], true]
    - ["pl1606pp024", pathlib.PurePosixPath.__dict__.__contains__,   ["_drv"],        false]
    - ["pl1606pp025", pathlib.PureWindowsPath.__dict__.__contains__,  ["_drv"],        false]
    - ["pl1606pp026", pathlib.PurePath.__dict__.__contains__,        ["_info"],       false]
    - ["pl1606pp027", pathlib.PurePosixPath.__dict__.__contains__,   ["_info"],       false]

# ---------------------------------------------------------------------------
# Table 2: Path slot declaration and slot descriptor type
# ---------------------------------------------------------------------------

table pathlib_extra1606.path_slots:
  description: "pathlib.Path declares __slots__ = ('_info',); PosixPath and WindowsPath define empty __slots__; the _info slot descriptor is a member_descriptor"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl1606pa

  columns: [id, function, args, expected]
  rows:
    - ["pl1606pa001", pathlib.Path.__dict__.__contains__,     ["__slots__"],  true]
    - ["pl1606pa002", pathlib.PosixPath.__dict__.__contains__, ["__slots__"],  true]
    - ["pl1606pa003", pathlib.Path.__dict__.__contains__,     ["__dict__"],   false]
    - ["pl1606pa004", pathlib.Path.__dict__.__contains__,     ["__weakref__"], false]
    - ["pl1606pa005", pathlib.PosixPath.__dict__.__contains__, ["__dict__"],   false]
    - ["pl1606pa006", pathlib.PosixPath.__dict__.__contains__, ["__weakref__"], false]
    - ["pl1606pa007", pathlib.Path.__dict__.__contains__,     ["_info"],      true]
    - ["pl1606pa008", pathlib.PosixPath.__dict__.__contains__, ["_info"],      false]
    - ["pl1606pa009", type(pathlib.Path.__dict__["_info"]).__name__.__eq__, ["member_descriptor"], true]
    - ["pl1606pa010", pathlib.Path.__dict__.__contains__,     ["_raw_paths"], false]
    - ["pl1606pa011", pathlib.Path.__dict__.__contains__,     ["_drv"],       false]
    - ["pl1606pa012", pathlib.Path.__dict__.__contains__,     ["_root"],      false]
    - ["pl1606pa013", pathlib.Path.__dict__.__contains__,     ["_hash"],      false]
    - ["pl1606pa014", pathlib.Path.__dict__.__contains__,     ["open"],       true]
    - ["pl1606pa015", pathlib.Path.__dict__.__contains__,     ["stat"],       true]
    - ["pl1606pa016", pathlib.Path.__dict__.__contains__,     ["exists"],     true]
    - ["pl1606pa017", pathlib.Path.__dict__.__contains__,     ["is_file"],    true]
    - ["pl1606pa018", pathlib.Path.__dict__.__contains__,     ["is_dir"],     true]
    - ["pl1606pa019", pathlib.Path.__dict__.__contains__,     ["mkdir"],      true]
    - ["pl1606pa020", pathlib.Path.__dict__.__contains__,     ["__new__"],    true]
    - ["pl1606pa021", pathlib.PosixPath.__dict__.__contains__, ["_raw_paths"], false]
    - ["pl1606pa022", pathlib.PosixPath.__dict__.__contains__, ["open"],       false]
    - ["pl1606pa023", pathlib.PosixPath.__dict__.__contains__, ["__new__"],    false]
    - ["pl1606pa024", pathlib.PurePath.__dict__.__contains__,  ["_info"],      false]
    - ["pl1606pa025", pathlib.Path.__dict__.__contains__,     ["iterdir"],    true]
    - ["pl1606pa026", pathlib.Path.__dict__.__contains__,     ["glob"],       true]
    - ["pl1606pa027", pathlib.Path.__dict__.__contains__,     ["read_text"],  true]
    - ["pl1606pa028", pathlib.Path.__dict__.__contains__,     ["write_text"], true]
