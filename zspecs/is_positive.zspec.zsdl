spec: is_positive
version: ">=3.1.0"
backend: node(is-positive)

docs: https://www.npmjs.com/package/is-positive

provenance:
  derived_from:
    - "is-positive README — https://www.npmjs.com/package/is-positive"
    - "Test vectors verified with is-positive via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-positive source"
  notes:
    - "is-positive is an npm package. Install: npm install is-positive"
    - "Returns true if the number is greater than zero."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_positive.check:
  kind: node_module_call_eq
  function: ~
  category: math
  id_prefix: ispos

  columns: [id, args, expected]
  rows:
    - [positive,  [5],    true]
    - [zero,      [0],    false]
    - [negative,  [-5],   false]
