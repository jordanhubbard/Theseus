spec: decimal_extra2566
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2566 (_extra2566): __getattr__, __setattr__, __delattr__ dict-presence checks for decimal module classes."
    - "decimal.Decimal defines none of the three attribute-access dunders in its class __dict__."
    - "decimal.Context is the notable exception: it defines both __setattr__ and __delattr__ (but NOT __getattr__) in its class __dict__, used to validate and coerce trap and rounding mode assignments."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table decimal_extra2566.getattr_protocol:
  description: "decimal classes __getattr__ dict-presence — all False (neither Decimal nor Context defines __getattr__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2566

  columns: [id, function, args, expected]
  rows:
    - ["dc2566001", "decimal.Decimal.__dict__.__contains__", ["__getattr__"], false]
    - ["dc2566002", "decimal.Context.__dict__.__contains__", ["__getattr__"], false]

table decimal_extra2566.setattr_protocol:
  description: "decimal classes __setattr__ dict-presence — False for Decimal, True for Context"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2566s

  columns: [id, function, args, expected]
  rows:
    - ["dc2566s001", "decimal.Decimal.__dict__.__contains__", ["__setattr__"], false]
    - ["dc2566s002", "decimal.Context.__dict__.__contains__", ["__setattr__"], true]

table decimal_extra2566.delattr_protocol:
  description: "decimal classes __delattr__ dict-presence — False for Decimal, True for Context"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2566d

  columns: [id, function, args, expected]
  rows:
    - ["dc2566d001", "decimal.Decimal.__dict__.__contains__", ["__delattr__"], false]
    - ["dc2566d002", "decimal.Context.__dict__.__contains__", ["__delattr__"], true]

table decimal_extra2566.all_three_combined:
  description: "decimal classes: full matrix of all three attr-access dunders for both classes"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2566x

  columns: [id, function, args, expected]
  rows:
    - ["dc2566x001", "decimal.Decimal.__dict__.__contains__", ["__getattr__"], false]
    - ["dc2566x002", "decimal.Decimal.__dict__.__contains__", ["__setattr__"], false]
    - ["dc2566x003", "decimal.Decimal.__dict__.__contains__", ["__delattr__"], false]
    - ["dc2566x004", "decimal.Context.__dict__.__contains__", ["__getattr__"], false]
    - ["dc2566x005", "decimal.Context.__dict__.__contains__", ["__setattr__"], true]
    - ["dc2566x006", "decimal.Context.__dict__.__contains__", ["__delattr__"], true]
    - ["dc2566x007", "decimal.Context.__dict__.__contains__", ["__getattribute__"], true]
    - ["dc2566x008", "decimal.Decimal.__dict__.__contains__", ["__getattribute__"], true]
    - ["dc2566x009", "decimal.Context.__dict__.__contains__", ["__getattr__"], false]
    - ["dc2566x010", "decimal.Decimal.__dict__.__contains__", ["__hash__"], true]
