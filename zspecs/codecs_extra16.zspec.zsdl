spec: codecs_extra16
version: ">=3.9"
backend: python_module(codecs)

docs: https://docs.python.org/3/library/codecs.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/codecs.html — Python codecs module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/codecs.py"
    - "codecs_extra15.zspec.zsdl — covers encode/decode with error handlers; lookup canonical names table; getincrementalencoder/getincrementaldecoder __name__."
    - "codecs_extra14.zspec.zsdl — covers encode('hello','utf-8') value; decode(b'hello','utf-8') value; encode('hello','ascii') value; encode('\\u00e9','utf-8') value; lookup('utf-8') class name."
    - "codecs_extra13.zspec.zsdl — covers encode/decode/lookup/open/register __name__/__module__; CodecInfo.__qualname__."
    - "codecs_extra6.zspec.zsdl — covers getincrementalencoder/getincrementaldecoder __name__/__qualname__/__module__."
  notes:
    - "This spec extends codecs through codecs_extra15 with class hierarchy / __bases__ vectors."
    - "codecs.CodecInfo.__bases__[0].__name__ == 'tuple': CodecInfo is a namedtuple; its sole base is tuple."
    - "codecs.Codec.__bases__[0].__name__ == 'object': Codec is a plain new-style class; its sole base is object."
    - "codecs.IncrementalEncoder.__bases__[0].__name__ == 'object': abstract base, derives directly from object."
    - "codecs.IncrementalDecoder.__bases__[0].__name__ == 'object': abstract base, derives directly from object."
    - "codecs.StreamWriter.__bases__[0].__name__ == 'Codec': StreamWriter mixes in the Codec base class."
    - "codecs.StreamReader.__bases__[0].__name__ == 'Codec': StreamReader mixes in the Codec base class."
    - "codecs.StreamRecoder.__bases__[0].__name__ == 'object': StreamRecoder derives directly from object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# CodecInfo.__bases__[0].__name__ == 'tuple' (extra16 namespace)
#
# CodecInfo is constructed as a namedtuple in Lib/codecs.py. Its single base
# class is therefore tuple. No prior codecs spec covers CodecInfo.__bases__[0].
# Verified: codecs.CodecInfo.__bases__[0].__name__ == 'tuple'.
# ---------------------------------------------------------------------------

invariant codecs_extra16.CodecInfo.bases0.name:
  description: "codecs.CodecInfo.__bases__[0].__name__ == 'tuple' — CodecInfo is a namedtuple, base is tuple"
  category: class_hierarchy
  kind: python_call_eq
  function: "CodecInfo.__bases__[0].__name__.__eq__"
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# Codec.__bases__[0].__name__ == 'object' (extra16 namespace)
#
# Codec is a plain new-style class with no explicit parent other than object.
# No prior codecs spec covers Codec.__bases__[0].
# Verified: codecs.Codec.__bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant codecs_extra16.Codec.bases0.name:
  description: "codecs.Codec.__bases__[0].__name__ == 'object' — Codec derives directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: "Codec.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# IncrementalEncoder.__bases__[0].__name__ == 'object' (extra16 namespace)
#
# IncrementalEncoder is an abstract base with no intermediate parent.
# No prior codecs spec covers IncrementalEncoder.__bases__[0].
# Verified: codecs.IncrementalEncoder.__bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant codecs_extra16.IncrementalEncoder.bases0.name:
  description: "codecs.IncrementalEncoder.__bases__[0].__name__ == 'object' — abstract base derives from object"
  category: class_hierarchy
  kind: python_call_eq
  function: "IncrementalEncoder.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# IncrementalDecoder.__bases__[0].__name__ == 'object' (extra16 namespace)
#
# Symmetric with IncrementalEncoder.
# No prior codecs spec covers IncrementalDecoder.__bases__[0].
# Verified: codecs.IncrementalDecoder.__bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant codecs_extra16.IncrementalDecoder.bases0.name:
  description: "codecs.IncrementalDecoder.__bases__[0].__name__ == 'object' — abstract base derives from object"
  category: class_hierarchy
  kind: python_call_eq
  function: "IncrementalDecoder.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# StreamRecoder.__bases__[0].__name__ == 'object' (extra16 namespace)
#
# StreamRecoder wraps a stream but does not inherit from Codec.
# No prior codecs spec covers StreamRecoder.__bases__[0].
# Verified: codecs.StreamRecoder.__bases__[0].__name__ == 'object'.
# ---------------------------------------------------------------------------

invariant codecs_extra16.StreamRecoder.bases0.name:
  description: "codecs.StreamRecoder.__bases__[0].__name__ == 'object' — StreamRecoder derives directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: "StreamRecoder.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

# ---------------------------------------------------------------------------
# Table: Stream{Writer,Reader} base names (extra16 namespace)
#
# Both StreamWriter and StreamReader derive from Codec. Grouping them in a
# single table makes the shared inheritance pattern explicit. No prior spec
# covers StreamWriter.__bases__[0] or StreamReader.__bases__[0].
# ---------------------------------------------------------------------------

table codecs_extra16.stream_class_bases:
  description: "codecs StreamWriter and StreamReader both derive from Codec"
  kind: python_call_eq
  category: class_hierarchy

  columns: [id, function, args, expected]
  rows:
    - [StreamWriter, "StreamWriter.__bases__[0].__name__.__eq__", ["Codec"], true]
    - [StreamReader, "StreamReader.__bases__[0].__name__.__eq__", ["Codec"], true]
