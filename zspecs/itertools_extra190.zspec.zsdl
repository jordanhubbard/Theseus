       ["object"],
       true,
       "itertools.takewhile.__bases__[0].__name__.__eq__('object') == True — takewhile is a C extension type; only base is object; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra190"]
    - [dropwhile_base,
       "dropwhile.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.dropwhile.__bases__[0].__name__.__eq__('object') == True — dropwhile is a C extension type; only base is object; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra190"]

# ---------------------------------------------------------------------------
# Table 2: itertools filterfalse/zip_longest/groupby __bases__ identity
#
# itertools.filterfalse.__bases__[0].__name__  == 'object'
# itertools.zip_longest.__bases__[0].__name__  == 'object'
# itertools.groupby.__bases__[0].__name__      == 'object'
#
# filterfalse, zip_longest, and groupby are C extension types with object
# as their sole base. zip_longest handles unequal-length iterables with a
# fillvalue; groupby groups consecutive matching elements. New to extra190.
# ---------------------------------------------------------------------------

table itertools_extra190.filterfalse_ziplongest_groupby_bases:
  description: "itertools filterfalse/zip_longest/groupby __bases__[0].__name__=='object'; all are C extension types inheriting directly from object; new to extra190"
  kind: python_call_eq
  category: identity
  id_prefix: iterbases2190

  columns: [id, function, args, expected, description]
  rows:
    - [filterfalse_base,
       "filterfalse.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.filterfalse.__bases__[0].__name__.__eq__('object') == True — filterfalse is a C extension type; only base is object; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra190"]
    - [ziplongest_base,
       "zip_longest.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.zip_longest.__bases__[0].__name__.__eq__('object') == True — zip_longest is a C extension type; only base is object; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra190"]
    - [groupby_base,
       "groupby.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.groupby.__bases__[0].__name__.__eq__('object') == True — groupby is a C extension type; only base is object; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra190"]

# ---------------------------------------------------------------------------
# Table 3: itertools.tee is a builtin_function_or_method (not a type)
#
# itertools.tee.__class__.__name__ == 'builtin_function_or_method'
#
# Unlike accumulate, starmap etc., tee is a C-level function rather than
# a type. It creates independent iterators from a single iterable. Its
# __class__.__name__ is 'builtin_function_or_method' confirming it is not
# instantiated like the other itertools types. New to extra190.
# ---------------------------------------------------------------------------

table itertools_extra190.tee_is_function_not_type:
  description: "itertools.tee.__class__.__name__=='builtin_function_or_method'; tee is a C-level function not an iterator type; new to extra190"
  kind: python_call_eq
  category: identity
  id_prefix: iterbases2190

  columns: [id, function, args, expected, description]
  rows:
    - [tee_class_name,
       tee.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "itertools.tee.__class__.__name__.__eq__('builtin_function_or_method') == True — tee is a C builtin function that returns a tuple of independent iterators; unlike accumulate/starmap it is not a type; str.__eq__('builtin_function_or_method') returns True; verified with Python 3.14.3; new to extra190"]

