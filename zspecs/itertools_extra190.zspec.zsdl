# ---------------------------------------------------------------------------
# Table 1: itertools accumulate/starmap/takewhile/dropwhile __bases__ identity
#
# itertools.accumulate.__bases__[0].__name__  == 'object'
# itertools.starmap.__bases__[0].__name__     == 'object'
# itertools.takewhile.__bases__[0].__name__   == 'object'
# itertools.dropwhile.__bases__[0].__name__   == 'object'
#
# All four are C extension types implemented in Modules/itertoolsmodule.c.
# They inherit directly from object with no intermediary base. New to extra190.
# ---------------------------------------------------------------------------

table itertools_extra190.accumulate_starmap_takewhile_dropwhile_bases:
  description: "itertools accumulate/starmap/takewhile/dropwhile __bases__[0].__name__=='object'; all are C extension types inheriting directly from object; new to extra190"
  kind: python_call_eq
  category: identity
  id_prefix: iterbases2190

  columns: [id, function, args, expected, description]
  rows:
    - [accum_base,
       "accumulate.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.accumulate.__bases__[0].__name__.__eq__('object') == True — accumulate is a C extension type; only base is object; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra190"]
    - [starmap_base,
       "starmap.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "itertools.starmap.__bases__[0].__name__.__eq__('object') == True — starmap is a C extension type; only base is object; str.__eq__('object') returns True; verified with Python 3.14.3; new to extra190"]
    - [takewhile_base,
