spec: concurrent_futures_extra418
version: ">=3.9"
backend: python_module(concurrent.futures._base)
docs: https://docs.python.org/3/library/concurrent.futures.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "concurrent.futures._base.CANCELLED_AND_NOTIFIED == 'CANCELLED_AND_NOTIFIED' (a string constant)"
    - "concurrent.futures._base.__name__ == 'concurrent.futures._base'"
    - "concurrent.futures._base.__package__ == 'concurrent.futures'"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table concurrent_futures_extra418.cancelled_and_notified:
  description: "Verify the value of the CANCELLED_AND_NOTIFIED internal state constant in concurrent.futures._base"
  kind: python_call_eq
  category: identity
  id_prefix: cf418can

  columns: [id, function, args, expected]
  rows:
    - [cf418can001, concurrent.futures._base.CANCELLED_AND_NOTIFIED.__eq__, ["CANCELLED_AND_NOTIFIED"], true]

table concurrent_futures_extra418.module_identity:
  description: "Verify __name__ and __package__ of the concurrent.futures._base internal module"
