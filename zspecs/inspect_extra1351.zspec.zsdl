spec: inspect_extra1351
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "Wave 537 (_extra1351): focuses on __slots__ and __weakref__ attribute checks for inspect module classes."
    - "inspect.Parameter.__dict__.__contains__('__slots__') == True — Parameter defines __slots__ to reduce memory overhead; it is a value-object with fixed attributes."
    - "inspect.Parameter.__dict__.__contains__('__weakref__') == False — __slots__ without '__weakref__' in the slot list suppresses the weakref descriptor."
    - "inspect.Signature.__dict__.__contains__('__slots__') == True — Signature also uses __slots__ for efficiency."
    - "inspect.BoundArguments.__dict__.__contains__('__slots__') == True — BoundArguments defines __slots__."
    - "inspect.BoundArguments.__dict__.__contains__('__weakref__') == True — BoundArguments includes '__weakref__' in its __slots__ list, enabling weakref support."
    - "inspect.FullArgSpec.__dict__.__contains__('__slots__') == True — FullArgSpec is a namedtuple subclass with __slots__."
    - "inspect.ArgInfo.__dict__.__contains__('__slots__') == True — ArgInfo is a namedtuple-based class with __slots__."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table inspect_extra1351.parameter_signature_slot_checks:
  description: "inspect.Parameter and Signature __dict__ containment checks for __slots__, __weakref__, and __dict__; both define __slots__ without __weakref__, so no weakref descriptor is added"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: in1351ps
  columns: [id, function, args, expected]
  rows:
    - [in1351ps001, inspect.Parameter.__dict__.__contains__, ["__slots__"],    true]
    - [in1351ps002, inspect.Parameter.__dict__.__contains__, ["__weakref__"],  false]
    - [in1351ps003, inspect.Parameter.__dict__.__contains__, ["__dict__"],     false]
    - [in1351ps004, inspect.Signature.__dict__.__contains__, ["__slots__"],    true]
    - [in1351ps005, inspect.Signature.__dict__.__contains__, ["__weakref__"],  false]
    - [in1351ps006, inspect.Signature.__dict__.__contains__, ["__dict__"],     false]

table inspect_extra1351.boundarguments_slot_checks:
  description: "inspect.BoundArguments __dict__ containment checks for __slots__, __weakref__, and __dict__; BoundArguments defines __slots__ and includes '__weakref__' in the slot list enabling weakref support"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: in1351ba
  columns: [id, function, args, expected]
  rows:
    - [in1351ba001, inspect.BoundArguments.__dict__.__contains__, ["__slots__"],    true]
    - [in1351ba002, inspect.BoundArguments.__dict__.__contains__, ["__weakref__"],  true]
    - [in1351ba003, inspect.BoundArguments.__dict__.__contains__, ["__dict__"],     false]
    - [in1351ba004, inspect.FullArgSpec.__dict__.__contains__,    ["__slots__"],    true]
    - [in1351ba005, inspect.FullArgSpec.__dict__.__contains__,    ["__weakref__"],  false]
    - [in1351ba006, inspect.FullArgSpec.__dict__.__contains__,    ["__dict__"],     false]

table inspect_extra1351.arginfo_closurevars_slot_checks:
  description: "inspect.ArgInfo and ClosureVars __dict__ containment checks for __slots__, __weakref__, and __dict__; both are namedtuple-based classes that define __slots__ without __weakref__"
  kind: python_call_eq
  category: slot_weakref_dict_checks
  id_prefix: in1351ac
  columns: [id, function, args, expected]
  rows:
    - [in1351ac001, inspect.ArgInfo.__dict__.__contains__,     ["__slots__"],    true]
    - [in1351ac002, inspect.ArgInfo.__dict__.__contains__,     ["__weakref__"],  false]
    - [in1351ac003, inspect.ArgInfo.__dict__.__contains__,     ["__dict__"],     false]
    - [in1351ac004, inspect.ClosureVars.__dict__.__contains__, ["__slots__"],    true]
    - [in1351ac005, inspect.ClosureVars.__dict__.__contains__, ["__weakref__"],  false]
    - [in1351ac006, inspect.ClosureVars.__dict__.__contains__, ["__dict__"],     false]
