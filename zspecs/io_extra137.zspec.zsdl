# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra137.StringIO.read_qualname:
  description: "io.StringIO.read.__qualname__ == 'StringIO.read' (C extension methods use 'ClassName.method_name' as qualname; StringIO is defined in the _io extension, so its method qualnames use the bare class name without module prefix)"
  category: method_qualnames
  kind: python_call_eq
  function: StringIO.read.__qualname__.__eq__
  args: ["StringIO.read"]
  expected: true

invariant io_extra137.StringIO.getvalue_qualname_len:
  description: "io.StringIO.getvalue.__qualname__.__len__() == 17 ('StringIO.getvalue' is 17 characters: 8 for 'StringIO' + 1 for '.' + 8 for 'getvalue')"
  category: method_qualnames
  kind: python_call_eq
  function: StringIO.getvalue.__qualname__.__len__
  args: []
  expected: 17

invariant io_extra137.BytesIO.read_qualname:
  description: "io.BytesIO.read.__qualname__ == 'BytesIO.read' (BytesIO.read is shorter than StringIO.read because 'BytesIO' is 7 characters vs 'StringIO' which is 8 characters)"
  category: method_qualnames
  kind: python_call_eq
  function: BytesIO.read.__qualname__.__eq__
  args: ["BytesIO.read"]
  expected: true

invariant io_extra137.BytesIO.getvalue_qualname_len:
  description: "io.BytesIO.getvalue.__qualname__.__len__() == 16 ('BytesIO.getvalue' is 16 characters: 7 for 'BytesIO' + 1 for '.' + 8 for 'getvalue')"
  category: method_qualnames
  kind: python_call_eq
  function: BytesIO.getvalue.__qualname__.__len__
  args: []
  expected: 16

invariant io_extra137.BytesIO.write_qualname_len:
  description: "io.BytesIO.write.__qualname__.__len__() == 13 ('BytesIO.write' is 13 characters: 7 for 'BytesIO' + 1 for '.' + 5 for 'write')"
  category: method_qualnames
  kind: python_call_eq
  function: BytesIO.write.__qualname__.__len__
  args: []
  expected: 13

