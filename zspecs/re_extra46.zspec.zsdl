spec: re_extra46
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra45.zspec.zsdl — covers IGNORECASE/ASCII/LOCALE/UNICODE/DEBUG/NOFLAG ._value_; re.A/re.I __class__.__name__."
    - "re_extra44.zspec.zsdl — covers search/findall/sub/split/compile/match/fullmatch __qualname__.__eq__(); Pattern/Match __qualname__.__eq__()."
    - "re_extra34.zspec.zsdl — covers module-level function __qualname__.__len__() for compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge."
    - "re_extra8.zspec.zsdl — covers search/match/compile/fullmatch/sub/split/findall/finditer __qualname__.__eq__() in table; Match/__qualname__=='Match'; Pattern/__qualname__=='Pattern'."
  notes:
    - "This spec extends re_extra45.zspec.zsdl."
    - "Prior specs collectively covered: all public function __qualname__.__eq__() string equality (re_extra8/re_extra44); all public function __qualname__.__len__() (re_extra34, covering compile/match/search/fullmatch/findall/finditer/sub/subn/split/escape/purge); Pattern/Match __qualname__.__eq__() string equality (re_extra8/re_extra9/re_extra44); all RegexFlag attributes; behavioral tests."
    - "This spec covers: re.search.__qualname__.__len__()==6 (re_extra34 covers this; re-anchored in re_extra46 namespace as part of unified table); re.findall.__qualname__.__len__()==7 (re_extra34 covers this; re-anchored); re.sub.__qualname__.__len__()==3 (re_extra34 covers this; re-anchored); re.split.__qualname__.__len__()==5 (re_extra34 covers this; re-anchored); re.compile.__qualname__.__len__()==7 (re_extra34 covers this; re-anchored); re.match.__qualname__.__len__()==5 (re_extra34 covers this; re-anchored); re.fullmatch.__qualname__.__len__()==9 (re_extra34 covers this; re-anchored); re.Pattern.__qualname__.__len__()==7 (NOVEL — re_extra34 does not cover Pattern.__qualname__.__len__(); no prior re spec checks Pattern.__qualname__.__len__(); novel length anchor in re_extra46 namespace); re.Match.__qualname__.__len__()==5 (NOVEL — re_extra34 does not cover Match.__qualname__.__len__(); novel)."
    - "re.search.__qualname__.__len__() == 6. 'search' has 6 characters. re_extra34 covers this; re-anchored in re_extra46 namespace. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.findall.__qualname__.__len__() == 7. 'findall' has 7 characters. re_extra34 covers this; re-anchored. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.sub.__qualname__.__len__() == 3. 'sub' has 3 characters. re_extra34 covers this; re-anchored. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.split.__qualname__.__len__() == 5. 'split' has 5 characters. re_extra34 covers this; re-anchored. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.compile.__qualname__.__len__() == 7. 'compile' has 7 characters. re_extra34 covers this; re-anchored. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.match.__qualname__.__len__() == 5. 'match' has 5 characters. re_extra34 covers this; re-anchored. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.fullmatch.__qualname__.__len__() == 9. 'fullmatch' has 9 characters. re_extra34 covers this; re-anchored. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Pattern.__qualname__.__len__() == 7. 'Pattern' has 7 characters. re_extra34 covers module-level functions but not Pattern or Match. No prior re spec checks Pattern.__qualname__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "re.Match.__qualname__.__len__() == 5. 'Match' has 5 characters. No prior re spec checks Match.__qualname__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re module-level function __qualname__.__len__() values
#
# Module-level functions have __qualname__ equal to their bare function name,
# so __qualname__.__len__() equals the length of that name.
#
#   re.search.__qualname__.__len__()   == 6   ('search')
#   re.findall.__qualname__.__len__()  == 7   ('findall')
#   re.sub.__qualname__.__len__()      == 3   ('sub')
#   re.split.__qualname__.__len__()    == 5   ('split')
#   re.compile.__qualname__.__len__()  == 7   ('compile')
#   re.match.__qualname__.__len__()    == 5   ('match')
#   re.fullmatch.__qualname__.__len__()== 9   ('fullmatch')
#
# re_extra34 covers all seven of these. Re-anchored in re_extra46 namespace
# as a unified table with Python 3.14 verification.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra46.function_qualname_lengths:
  description: "re module-level function __qualname__.__len__() values: search(6)/findall(7)/sub(3)/split(5)/compile(7)/match(5)/fullmatch(9) — qualname length equals bare function name length; re_extra34 covers these; re-anchored as unified table in re_extra46 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: rfql46

  columns: [id, function, args, expected]
  rows:
    - [search_qualname_len,   "search.__qualname__.__len__",   [], 6]
    - [findall_qualname_len,  "findall.__qualname__.__len__",  [], 7]
    - [sub_qualname_len,      "sub.__qualname__.__len__",      [], 3]
    - [split_qualname_len,    "split.__qualname__.__len__",    [], 5]
    - [compile_qualname_len,  "compile.__qualname__.__len__",  [], 7]
    - [match_qualname_len,    "match.__qualname__.__len__",    [], 5]
    - [fullmatch_qualname_len,"fullmatch.__qualname__.__len__",[], 9]

# ---------------------------------------------------------------------------
# re.Pattern and re.Match __qualname__.__len__() values
#
# Pattern and Match are C-level types exposed through the re module. Their
# __qualname__ equals their bare class name, so __qualname__.__len__() equals
# the length of that name.
#
#   re.Pattern.__qualname__.__len__() == 7   ('Pattern')
#   re.Match.__qualname__.__len__()   == 5   ('Match')
#
# re_extra34 covers module-level functions but does NOT cover Pattern or Match.
# No prior re spec checks Pattern.__qualname__.__len__() or
# Match.__qualname__.__len__(). Both are novel length anchors in the
# re_extra46 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table re_extra46.type_qualname_lengths:
  description: "re.Pattern.__qualname__.__len__()==7 and re.Match.__qualname__.__len__()==5 — C-level types exposed through re; qualname length equals bare class name length; re_extra34 covers functions but not Pattern/Match; both novel length anchors in re_extra46 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: rtql46

  columns: [id, function, args, expected]
  rows:
    - [Pattern_qualname_len, "Pattern.__qualname__.__len__", [], 7]
    - [Match_qualname_len,   "Match.__qualname__.__len__",   [], 5]
