spec: inspect_extra2296
version: ">=3.9"
backend: python_module(inspect)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/inspect.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "Subjects: inspect.Parameter, inspect.Signature, inspect.BoundArguments, inspect.FullArgSpec, inspect.FrameInfo, inspect.BlockFinder, inspect.EndOfBlock."
    - "All subjects are pure Python; every subject reports __module__ == 'inspect'."
    - "inspect.Signature.empty is the same object as inspect._empty; __qualname__ == '_empty' (private sentinel class)."
    - "inspect.Parameter.empty.__qualname__ == '_empty' (same sentinel, accessed via Parameter.empty)."
    - "inspect._ParameterKind.__qualname__ == '_ParameterKind' (private enum)."
    - "All top-level public classes have __qualname__ matching their unqualified name."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table inspect_extra2296.parameter_module:
  description: "inspect.Parameter __module__ and __qualname__"
  kind: python_call_eq
  category: module_identity
  id_prefix: in2296

  columns: [id, function, args, expected]
  rows:
    - ["in2296001", "inspect.Parameter.__module__", [], "inspect"]
    - ["in2296002", "inspect.Parameter.__qualname__", [], "Parameter"]

table inspect_extra2296.signature_module:
  description: "inspect.Signature __module__ and __qualname__"
  kind: python_call_eq
