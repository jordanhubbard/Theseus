spec: inspect_extra469
version: ">=3.9"
backend: python_module(inspect)
docs: https://docs.python.org/3/library/inspect.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "All inspect predicates are plain Python functions defined in the inspect module"
    - "isasyncgenfunction added in Python 3.6; all targets here are 3.9+"
    - "getfile, getsource, getdoc, getcomments are utility functions in inspect"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table inspect_extra469.predicate_names:
  description: "Name attribute identity for inspect predicate functions"
  kind: python_call_eq
  category: identity
  id_prefix: IN469N

  columns: [id, function, args, expected]
  rows:
    - [IN469N001, inspect.isbuiltin.__name__.__eq__, ["isbuiltin"], true]
    - [IN469N002, inspect.ismodule.__name__.__eq__, ["ismodule"], true]
    - [IN469N003, inspect.isgeneratorfunction.__name__.__eq__, ["isgeneratorfunction"], true]
    - [IN469N004, inspect.iscoroutinefunction.__name__.__eq__, ["iscoroutinefunction"], true]
    - [IN469N005, inspect.isasyncgenfunction.__name__.__eq__, ["isasyncgenfunction"], true]
    - [IN469N006, inspect.isfunction.__name__.__eq__, ["isfunction"], true]
    - [IN469N007, inspect.isclass.__name__.__eq__, ["isclass"], true]
    - [IN469N008, inspect.ismethod.__name__.__eq__, ["ismethod"], true]
    - [IN469N009, inspect.ismethoddescriptor.__name__.__eq__, ["ismethoddescriptor"], true]
    - [IN469N010, inspect.isroutine.__name__.__eq__, ["isroutine"], true]

table inspect_extra469.predicate_modules:
  description: "Module attribute identity for inspect predicate functions"
  kind: python_call_eq
  category: identity
  id_prefix: IN469M

  columns: [id, function, args, expected]
  rows:
    - [IN469M001, inspect.isbuiltin.__module__.__eq__, ["inspect"], true]
    - [IN469M002, inspect.ismodule.__module__.__eq__, ["inspect"], true]
    - [IN469M003, inspect.isgeneratorfunction.__module__.__eq__, ["inspect"], true]
    - [IN469M004, inspect.iscoroutinefunction.__module__.__eq__, ["inspect"], true]
    - [IN469M005, inspect.isasyncgenfunction.__module__.__eq__, ["inspect"], true]
    - [IN469M006, inspect.isfunction.__module__.__eq__, ["inspect"], true]
    - [IN469M007, inspect.isclass.__module__.__eq__, ["inspect"], true]
    - [IN469M008, inspect.ismethod.__module__.__eq__, ["inspect"], true]

table inspect_extra469.utility_names:
  description: "Name attribute identity for inspect utility functions"
  kind: python_call_eq
  category: identity
  id_prefix: IN469U

  columns: [id, function, args, expected]
  rows:
    - [IN469U001, inspect.getfile.__name__.__eq__, ["getfile"], true]
    - [IN469U002, inspect.getsource.__name__.__eq__, ["getsource"], true]
    - [IN469U003, inspect.getdoc.__name__.__eq__, ["getdoc"], true]
    - [IN469U004, inspect.getcomments.__name__.__eq__, ["getcomments"], true]
    - [IN469U005, inspect.getmodule.__name__.__eq__, ["getmodule"], true]
    - [IN469U006, inspect.getmembers.__name__.__eq__, ["getmembers"], true]
    - [IN469U007, inspect.signature.__name__.__eq__, ["signature"], true]

table inspect_extra469.utility_modules:
  description: "Module attribute identity for inspect utility functions"
  kind: python_call_eq
  category: identity
  id_prefix: IN469V

  columns: [id, function, args, expected]
  rows:
    - [IN469V001, inspect.getfile.__module__.__eq__, ["inspect"], true]
    - [IN469V002, inspect.getsource.__module__.__eq__, ["inspect"], true]
    - [IN469V003, inspect.getdoc.__module__.__eq__, ["inspect"], true]
    - [IN469V004, inspect.getcomments.__module__.__eq__, ["inspect"], true]
    - [IN469V005, inspect.getmodule.__module__.__eq__, ["inspect"], true]
    - [IN469V006, inspect.getmembers.__module__.__eq__, ["inspect"], true]
    - [IN469V007, inspect.signature.__module__.__eq__, ["inspect"], true]
