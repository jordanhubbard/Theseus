spec: concurrent_futures_extra1456
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
    - "concurrent_futures_extra1441.zspec.zsdl — covers __subclasshook__ and __instancecheck__ for concurrent.futures classes"
  notes:
    - "Wave 544 (_extra1456): focuses on __contains__, __iter__, and __next__ method presence and type checks for concurrent.futures classes."
    - "concurrent.futures.Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor do NOT define __contains__ in their own __dict__."
    - "concurrent.futures.Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor do NOT define __iter__ in their own __dict__."
    - "concurrent.futures.Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor do NOT define __next__ in their own __dict__."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table concurrent_futures_extra1456.contains_not_in_dict:
  description: "concurrent.futures.__dict__ membership for __contains__ — Future, Executor, ThreadPoolExecutor, and ProcessPoolExecutor do not define __contains__ in their own __dict__; all return False; verified with Python 3.14.3"
  kind: python_call_eq
  category: contains_dict_membership
  id_prefix: cf1456cd
  columns: [id, function, args, expected]
  rows:
    - [cf1456cd001, concurrent.futures.Future.__dict__.__contains__,              ["__contains__"], false]
    - [cf1456cd002, concurrent.futures.Executor.__dict__.__contains__,            ["__contains__"], false]
    - [cf1456cd003, concurrent.futures.ThreadPoolExecutor.__dict__.__contains__,  ["__contains__"], false]
