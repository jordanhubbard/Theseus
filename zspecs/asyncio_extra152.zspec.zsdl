spec: asyncio_extra152
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-protocol.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-protocol.html — Python asyncio protocol and transport documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/protocols.py"
    - "CPython source: Lib/asyncio/transports.py"
  notes:
    - "This spec covers: asyncio protocol/transport class identity. asyncio.BaseProtocol.__name__=='BaseProtocol' (len=12); asyncio.BaseProtocol.__module__=='asyncio.protocols'; asyncio.Protocol.__bases__[0].__name__=='BaseProtocol' (Protocol inherits from BaseProtocol); asyncio.DatagramProtocol.__bases__[0].__name__=='BaseProtocol' (DatagramProtocol also inherits directly from BaseProtocol); asyncio.BaseTransport.__name__=='BaseTransport' (len=13); asyncio.BaseTransport.__module__=='asyncio.transports' (len=18); asyncio.Transport.__bases__[0].__name__=='ReadTransport' (Transport inherits from ReadTransport, not directly from BaseTransport — the MRO is Transport > ReadTransport > BaseTransport > object via multiple inheritance with WriteTransport). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.BaseProtocol.__module__=='asyncio.protocols' (len=17) — BaseProtocol, Protocol, and DatagramProtocol are all defined in Lib/asyncio/protocols.py and re-exported through asyncio/__init__.py. asyncio.BaseTransport.__module__=='asyncio.transports' (len=18) — BaseTransport, ReadTransport, WriteTransport, and Transport are defined in Lib/asyncio/transports.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Transport.__bases__[0].__name__=='ReadTransport' — Transport uses multiple inheritance (Transport(ReadTransport, WriteTransport)) making ReadTransport appear as __bases__[0]; the MRO chains: Transport > ReadTransport > WriteTransport > BaseTransport > object. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio protocol class identity — extra152
#
# asyncio.BaseProtocol.__name__.__eq__('BaseProtocol')       == True
# asyncio.BaseProtocol.__module__.__eq__('asyncio.protocols') == True
# asyncio.Protocol.__name__.__eq__('Protocol')               == True
# asyncio.Protocol.__bases__[0].__name__.__eq__('BaseProtocol') == True
# asyncio.DatagramProtocol.__name__.__eq__('DatagramProtocol') == True
# asyncio.DatagramProtocol.__bases__[0].__name__.__eq__('BaseProtocol') == True
# ---------------------------------------------------------------------------

table asyncio_extra152.asyncio_protocol_class_identity:
  description: "asyncio protocol class identity checks in asyncioproto152 namespace — asyncio.BaseProtocol.__name__=='BaseProtocol' (len=12; the root of the asyncio protocol hierarchy; all protocol classes inherit from BaseProtocol); asyncio.BaseProtocol.__module__=='asyncio.protocols' (len=17; defined in Lib/asyncio/protocols.py); asyncio.Protocol.__name__=='Protocol' (len=8; stream protocol class inheriting from BaseProtocol; provides data_received and connection_made callbacks); asyncio.Protocol.__bases__[0].__name__=='BaseProtocol' (Protocol directly inherits from BaseProtocol — single inheritance); asyncio.DatagramProtocol.__name__=='DatagramProtocol' (len=16; datagram/UDP protocol class inheriting from BaseProtocol); asyncio.DatagramProtocol.__bases__[0].__name__=='BaseProtocol' (DatagramProtocol also directly inherits from BaseProtocol — single inheritance parallel to Protocol); all three classes defined in asyncio.protocols (module len=17); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioproto152

  columns: [id, function, args, expected, description]
  rows:
    - [baseprot_name_eq,    asyncio.BaseProtocol.__name__.__eq__,                          ["BaseProtocol"],    true, "asyncio.BaseProtocol.__name__ == 'BaseProtocol' (len=12); verified with Python 3.14.3"]
    - [baseprot_mod_eq,     asyncio.BaseProtocol.__module__.__eq__,                        ["asyncio.protocols"], true, "asyncio.BaseProtocol.__module__ == 'asyncio.protocols' (len=17); verified with Python 3.14.3"]
    - [prot_name_eq,        asyncio.Protocol.__name__.__eq__,                              ["Protocol"],        true, "asyncio.Protocol.__name__ == 'Protocol' (len=8); verified with Python 3.14.3"]
    - [prot_base_eq,        "asyncio.Protocol.__bases__[0].__name__.__eq__",               ["BaseProtocol"],    true, "asyncio.Protocol.__bases__[0].__name__ == 'BaseProtocol' — Protocol inherits directly from BaseProtocol; verified with Python 3.14.3"]
    - [dgprot_name_eq,      asyncio.DatagramProtocol.__name__.__eq__,                      ["DatagramProtocol"], true, "asyncio.DatagramProtocol.__name__ == 'DatagramProtocol' (len=16); verified with Python 3.14.3"]
    - [dgprot_base_eq,      "asyncio.DatagramProtocol.__bases__[0].__name__.__eq__",       ["BaseProtocol"],    true, "asyncio.DatagramProtocol.__bases__[0].__name__ == 'BaseProtocol' — DatagramProtocol also inherits directly from BaseProtocol; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio transport class identity — extra152
#
# asyncio.BaseTransport.__name__.__eq__('BaseTransport')         == True
# asyncio.BaseTransport.__module__.__eq__('asyncio.transports') == True
# asyncio.Transport.__bases__[0].__name__.__eq__('ReadTransport') == True
# ---------------------------------------------------------------------------

table asyncio_extra152.asyncio_transport_class_identity:
  description: "asyncio transport class identity checks in asynciotransport152 namespace — asyncio.BaseTransport.__name__=='BaseTransport' (len=13; the root of the asyncio transport hierarchy; provides close, is_closing, get_extra_info, set_protocol, get_protocol); asyncio.BaseTransport.__module__=='asyncio.transports' (len=18; defined in Lib/asyncio/transports.py; longer module name than asyncio.protocols at 17); asyncio.Transport.__name__=='Transport' (len=9; the bidirectional transport class using multiple inheritance); asyncio.Transport.__bases__[0].__name__=='ReadTransport' (Transport is defined as Transport(ReadTransport, WriteTransport) so ReadTransport is __bases__[0]; Transport uses multiple inheritance unlike Protocol which uses single inheritance); asyncio.Transport.__module__=='asyncio.transports' (same submodule as BaseTransport); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asynciotransport152

  columns: [id, function, args, expected, description]
  rows:
    - [basetrans_name_eq,   asyncio.BaseTransport.__name__.__eq__,                         ["BaseTransport"],   true, "asyncio.BaseTransport.__name__ == 'BaseTransport' (len=13); verified with Python 3.14.3"]
    - [basetrans_mod_eq,    asyncio.BaseTransport.__module__.__eq__,                       ["asyncio.transports"], true, "asyncio.BaseTransport.__module__ == 'asyncio.transports' (len=18); verified with Python 3.14.3"]
    - [trans_name_eq,       asyncio.Transport.__name__.__eq__,                             ["Transport"],       true, "asyncio.Transport.__name__ == 'Transport' (len=9); verified with Python 3.14.3"]
    - [trans_base_eq,       "asyncio.Transport.__bases__[0].__name__.__eq__",              ["ReadTransport"],   true, "asyncio.Transport.__bases__[0].__name__ == 'ReadTransport' — Transport uses multiple inheritance (ReadTransport, WriteTransport); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio protocol module name lengths — extra152
#
# asyncio.BaseProtocol.__name__.__len__() == 12  ('BaseProtocol')
# asyncio.BaseTransport.__module__.__len__() == 18 ('asyncio.transports')
# asyncio.BaseProtocol.__module__.__len__() == 17 ('asyncio.protocols')
# ---------------------------------------------------------------------------

table asyncio_extra152.asyncio_proto_transport_name_lengths:
  description: "asyncio protocol and transport class name and module name length checks in asyncioprotolen152 namespace — asyncio.BaseProtocol.__name__.__len__()==12 ('BaseProtocol': 'Base'=4+'Protocol'=8=12); asyncio.DatagramProtocol.__name__.__len__()==16 ('DatagramProtocol': 'Datagram'=8+'Protocol'=8=16; longest protocol class name); asyncio.BaseTransport.__name__.__len__()==13 ('BaseTransport': 'Base'=4+'Transport'=9=13); asyncio.BaseTransport.__module__.__len__()==18 ('asyncio.transports': 'asyncio'=7+'.'=1+'transports'=10=18); asyncio.BaseProtocol.__module__.__len__()==17 ('asyncio.protocols': 'asyncio'=7+'.'=1+'protocols'=9=17; one char shorter than transports); module name ordering: transports(18) > protocols(17); class name ordering: DatagramProtocol(16) > BaseTransport(13) > BaseProtocol(12) > Transport(9) > Protocol(8); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: asyncioprotolen152

  columns: [id, function, args, expected, description]
  rows:
    - [baseprot_name_len,   asyncio.BaseProtocol.__name__.__len__,                         [],  12,  "asyncio.BaseProtocol.__name__.__len__() == 12 ('BaseProtocol'); verified with Python 3.14.3"]
    - [dgprot_name_len,     asyncio.DatagramProtocol.__name__.__len__,                     [],  16,  "asyncio.DatagramProtocol.__name__.__len__() == 16 ('DatagramProtocol'; longest protocol class name); verified with Python 3.14.3"]
    - [basetrans_name_len,  asyncio.BaseTransport.__name__.__len__,                        [],  13,  "asyncio.BaseTransport.__name__.__len__() == 13 ('BaseTransport'); verified with Python 3.14.3"]
    - [transmod_len,        asyncio.BaseTransport.__module__.__len__,                      [],  18,  "asyncio.BaseTransport.__module__.__len__() == 18 ('asyncio.transports'); verified with Python 3.14.3"]
    - [protmod_len,         asyncio.BaseProtocol.__module__.__len__,                       [],  17,  "asyncio.BaseProtocol.__module__.__len__() == 17 ('asyncio.protocols'); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra152
# ---------------------------------------------------------------------------

invariant asyncio_extra152.asyncio_BaseProtocol_name_eq:
  description: "asyncio.BaseProtocol.__name__.__eq__('BaseProtocol') returns True — asyncio.BaseProtocol is the root of the asyncio protocol class hierarchy; it is defined in Lib/asyncio/protocols.py and re-exported through asyncio/__init__.py; BaseProtocol.__name__=='BaseProtocol' (len=12); BaseProtocol.__module__=='asyncio.protocols' (len=17); BaseProtocol defines connection_made, connection_lost, and pause_writing/resume_writing callbacks that are shared by all protocol types; both asyncio.Protocol and asyncio.DatagramProtocol inherit directly from BaseProtocol (single inheritance); NEW in extra152: first standalone asyncio.BaseProtocol.__name__ identity invariant in asyncioproto152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.BaseProtocol.__name__.__eq__
  args: ["BaseProtocol"]
  expected: true

invariant asyncio_extra152.asyncio_BaseProtocol_module_eq:
  description: "asyncio.BaseProtocol.__module__.__eq__('asyncio.protocols') returns True — asyncio.BaseProtocol is defined in Lib/asyncio/protocols.py; its __module__ attribute is 'asyncio.protocols' (len=17); this is the submodule that defines the entire asyncio protocol hierarchy: BaseProtocol, Protocol, DatagramProtocol, SubprocessProtocol, and BufferedProtocol; compare: BaseTransport.__module__=='asyncio.transports' (len=18, one char longer); asyncio.protocols.__name__=='asyncio.protocols' confirms the submodule name; NEW in extra152: first standalone asyncio.BaseProtocol.__module__ identity invariant in asyncioproto152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.BaseProtocol.__module__.__eq__
  args: ["asyncio.protocols"]
  expected: true

invariant asyncio_extra152.asyncio_Protocol_bases0_name_eq:
  description: "asyncio.Protocol.__bases__[0].__name__.__eq__('BaseProtocol') returns True — asyncio.Protocol inherits directly from asyncio.BaseProtocol using single inheritance (Protocol.__bases__ == (BaseProtocol,)); Protocol.__bases__[0].__name__=='BaseProtocol' (len=12); Protocol adds data_received, eof_received, and connection_made/connection_lost (overriding BaseProtocol stubs) for stream-oriented transports; compare: asyncio.DatagramProtocol.__bases__[0].__name__=='BaseProtocol' (parallel single inheritance); asyncio.Transport.__bases__[0].__name__=='ReadTransport' (transport hierarchy uses multiple inheritance unlike protocol hierarchy); NEW in extra152: first standalone asyncio.Protocol.__bases__[0] name identity invariant in asyncioproto152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Protocol.__bases__[0].__name__.__eq__"
  args: ["BaseProtocol"]
  expected: true

invariant asyncio_extra152.asyncio_BaseTransport_module_eq:
  description: "asyncio.BaseTransport.__module__.__eq__('asyncio.transports') returns True — asyncio.BaseTransport is defined in Lib/asyncio/transports.py; its __module__ attribute is 'asyncio.transports' (len=18); this submodule defines the entire asyncio transport hierarchy: BaseTransport, ReadTransport, WriteTransport, Transport, and DatagramTransport; BaseTransport is the root class providing close(), is_closing(), get_extra_info(), set_protocol(), and get_protocol(); Transport inherits from both ReadTransport and WriteTransport (multiple inheritance), so Transport.__bases__[0].__name__=='ReadTransport' (not BaseTransport directly); NEW in extra152: first standalone asyncio.BaseTransport.__module__ identity invariant in asyncioproto152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: asyncio.BaseTransport.__module__.__eq__
  args: ["asyncio.transports"]
  expected: true

invariant asyncio_extra152.asyncio_Transport_bases0_name_eq:
  description: "asyncio.Transport.__bases__[0].__name__.__eq__('ReadTransport') returns True — asyncio.Transport is defined as Transport(ReadTransport, WriteTransport) using multiple inheritance; therefore Transport.__bases__[0].__name__=='ReadTransport' (not 'BaseTransport'); the MRO is Transport > ReadTransport > WriteTransport > BaseTransport > object; Transport provides full bidirectional communication by combining the reading side (ReadTransport: pause_reading, resume_reading, is_reading) with the writing side (WriteTransport: write, write_eof, can_write_eof, set_write_buffer_limits); this contrasts with the protocol hierarchy where both Protocol and DatagramProtocol use single inheritance from BaseProtocol; NEW in extra152: first standalone asyncio.Transport.__bases__[0] name identity invariant in asyncioproto152 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: "asyncio.Transport.__bases__[0].__name__.__eq__"
  args: ["ReadTransport"]
  expected: true
