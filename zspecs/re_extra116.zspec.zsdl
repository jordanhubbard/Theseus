spec: re_extra116
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "This spec extends re_extra115.zspec.zsdl."
    - "This spec covers: re.Match descriptor attribute __qualname__ STRING EQUALITY via direct attribute access."
    - "re_extra37 covered Match descriptor __qualname__.__len__() via Match.__dict__['name'].__qualname__.__len__() bracket notation."
    - "re_extra115 covered Pattern descriptor qualname string equality via direct attribute access."
    - "This spec applies the same direct-access approach to Match descriptors: Match.string, Match.re, Match.pos, Match.endpos, Match.lastindex, Match.lastgroup."
    - "Match.string.__qualname__ == 'Match.string' (len 12); type 'member_descriptor'."
    - "Match.re.__qualname__ == 'Match.re' (len 8); shortest Match descriptor qualname."
    - "Match.pos.__qualname__ == 'Match.pos' (len 9); type 'member_descriptor'."
    - "Match.endpos.__qualname__ == 'Match.endpos' (len 12); type 'member_descriptor'."
    - "Match.lastindex.__qualname__ == 'Match.lastindex' (len 15); type 'getset_descriptor'."
    - "Match.lastgroup.__qualname__ == 'Match.lastgroup' (len 15); type 'getset_descriptor'."
    - "string/re/pos/endpos are 'member_descriptor'; lastindex/lastgroup are 'getset_descriptor'."
    - "re_extra11 covered runtime match object attribute VALUES (e.g. match.string == 'hello'); this spec covers DESCRIPTOR QUALNAME strings on the type object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match.string and re.Match.re descriptor qualname string equality
# Both are 'member_descriptor' (direct C struct member slots in _sre.c).
# string: 'Match.string' (12 chars); stores the original subject string.
# re: 'Match.re' (8 chars); stores the compiled Pattern used for the match.
# 'Match.re' is the shortest qualname among all six Match descriptor attributes.
# re_extra37 covered these qualname LENGTHS via Match.__dict__[] bracket notation.
# This spec covers the qualname STRING EQUALITY via direct attribute access.
# ---------------------------------------------------------------------------

table re_extra116.Match_string_re_qualname_equality:
  description: "re.Match.string qualname='Match.string'(12) type='member_descriptor'; re.Match.re qualname='Match.re'(8) type='member_descriptor'; 'Match.re' is the shortest Match descriptor qualname; string equality via direct attribute access"
  kind: python_call_eq
  category: qualnames
  id_prefix: rematdesc116a

  columns: [id, function, args, expected, description]
  rows:
    - [str_type,     "Match.string.__class__.__name__.__eq__",  ["member_descriptor"],  true,  "type(re.Match.string).__name__ == 'member_descriptor' (direct C struct member slot storing the original subject string)"]
    - [str_qn_eq,    "Match.string.__qualname__.__eq__",        ["Match.string"],       true,  "re.Match.string.__qualname__ == 'Match.string' (12 chars; 'Match.'(6)+'string'(6)==12; stores the string passed to match/search/fullmatch)"]
    - [str_qn_len,   "Match.string.__qualname__.__len__",       [],                     12,    "re.Match.string.__qualname__.__len__() == 12 ('Match.string' has 12 chars; same length as Match.endpos)"]
    - [re_type,      "Match.re.__class__.__name__.__eq__",      ["member_descriptor"],  true,  "type(re.Match.re).__name__ == 'member_descriptor' (direct C struct member slot storing the compiled Pattern)"]
    - [re_qn_eq,     "Match.re.__qualname__.__eq__",            ["Match.re"],           true,  "re.Match.re.__qualname__ == 'Match.re' (8 chars; shortest Match descriptor qualname; 'Match.'(6)+'re'(2)==8)"]
    - [re_qn_len,    "Match.re.__qualname__.__len__",           [],                     8,     "re.Match.re.__qualname__.__len__() == 8 ('Match.re' has 8 chars; shortest among the six Match descriptor qualnames)"]
    - [str_gt_re,    "Match.string.__qualname__.__len__.__gt__", [8],                   true,  "len('Match.string') > len('Match.re') (12 > 8; string is 4 chars longer than re)"]
    - [str_ne_re,    "Match.string.__qualname__.__eq__",        ["Match.re"],           false, "re.Match.string.__qualname__ != 'Match.re' (distinct qualnames: string(12) stores the subject, re(8) stores the Pattern)"]

# ---------------------------------------------------------------------------
# re.Match.pos and re.Match.endpos descriptor qualname string equality
# Both are 'member_descriptor' (direct C struct member slots in _sre.c).
# pos: 'Match.pos' (9 chars); stores the start index of the search region.
# endpos: 'Match.endpos' (12 chars); stores the end index of the search region.
# For match() called without pos/endpos args, pos==0 and endpos==len(string).
# re_extra37 covered these qualname LENGTHS via Match.__dict__[] bracket notation.
# This spec covers the qualname STRING EQUALITY via direct attribute access.
# ---------------------------------------------------------------------------

table re_extra116.Match_pos_endpos_qualname_equality:
  description: "re.Match.pos qualname='Match.pos'(9) type='member_descriptor'; re.Match.endpos qualname='Match.endpos'(12) type='member_descriptor'; pos is the search start index, endpos is the search end index"
  kind: python_call_eq
  category: qualnames
  id_prefix: rematdesc116b

  columns: [id, function, args, expected, description]
  rows:
    - [pos_type,     "Match.pos.__class__.__name__.__eq__",    ["member_descriptor"],  true,  "type(re.Match.pos).__name__ == 'member_descriptor' (direct C struct member slot for the search start index)"]
    - [pos_qn_eq,    "Match.pos.__qualname__.__eq__",          ["Match.pos"],          true,  "re.Match.pos.__qualname__ == 'Match.pos' (9 chars; 'Match.'(6)+'pos'(3)==9; default is 0 when match() called without pos argument)"]
    - [pos_qn_len,   "Match.pos.__qualname__.__len__",         [],                     9,     "re.Match.pos.__qualname__.__len__() == 9 ('Match.pos' has 9 chars; second shortest Match descriptor qualname after Match.re)"]
    - [ep_type,      "Match.endpos.__class__.__name__.__eq__", ["member_descriptor"],  true,  "type(re.Match.endpos).__name__ == 'member_descriptor' (direct C struct member slot for the search end index)"]
    - [ep_qn_eq,     "Match.endpos.__qualname__.__eq__",       ["Match.endpos"],       true,  "re.Match.endpos.__qualname__ == 'Match.endpos' (12 chars; 'Match.'(6)+'endpos'(6)==12; same length as Match.string)"]
    - [ep_qn_len,    "Match.endpos.__qualname__.__len__",      [],                     12,    "re.Match.endpos.__qualname__.__len__() == 12 ('Match.endpos' has 12 chars; same length as Match.string)"]
    - [ep_gt_pos,    "Match.endpos.__qualname__.__len__.__gt__", [9],                  true,  "len('Match.endpos') > len('Match.pos') (12 > 9; endpos is 3 chars longer than pos)"]
    - [ep_ne_pos,    "Match.endpos.__qualname__.__eq__",       ["Match.pos"],          false, "re.Match.endpos.__qualname__ != 'Match.pos' (distinct qualnames; endpos(12) stores end index, pos(9) stores start index)"]
    - [ep_eq_str_len, "Match.endpos.__qualname__.__len__.__eq__", [12],                true,  "len('Match.endpos') == len('Match.string') == 12 (endpos and string share identical qualname length 12)"]

# ---------------------------------------------------------------------------
# re.Match.lastindex and re.Match.lastgroup descriptor qualname string equality
# Both are 'getset_descriptor' (tp_getset entries in _sre.c) — distinct from the
# four 'member_descriptor' attributes above.
# lastindex: 'Match.lastindex' (15 chars); index of the last matched group (or None).
# lastgroup: 'Match.lastgroup' (15 chars); name of the last matched group (or None).
# Both share qualname length 15, matching Pattern.flags/groups lengths from re_extra115.
# re_extra37 covered these qualname LENGTHS via Match.__dict__[] bracket notation.
# This spec covers the qualname STRING EQUALITY via direct attribute access.
# ---------------------------------------------------------------------------

table re_extra116.Match_lastindex_lastgroup_qualname_equality:
  description: "re.Match.lastindex qualname='Match.lastindex'(15) type='getset_descriptor'; re.Match.lastgroup qualname='Match.lastgroup'(15) type='getset_descriptor'; both are getset_descriptor unlike string/re/pos/endpos which are member_descriptor"
  kind: python_call_eq
  category: qualnames
  id_prefix: rematdesc116c

  columns: [id, function, args, expected, description]
  rows:
    - [li_type,      "Match.lastindex.__class__.__name__.__eq__",      ["getset_descriptor"],   true,  "type(re.Match.lastindex).__name__ == 'getset_descriptor' (tp_getset entry; distinct from member_descriptor for string/re/pos/endpos)"]
    - [li_qn_eq,     "Match.lastindex.__qualname__.__eq__",            ["Match.lastindex"],     true,  "re.Match.lastindex.__qualname__ == 'Match.lastindex' (15 chars; integer index of last matched capturing group, or None if no groups)"]
    - [li_qn_len,    "Match.lastindex.__qualname__.__len__",           [],                      15,    "re.Match.lastindex.__qualname__.__len__() == 15 ('Match.lastindex' has 15 chars; 'Match.'(6)+'lastindex'(9)==15)"]
    - [lg_type,      "Match.lastgroup.__class__.__name__.__eq__",      ["getset_descriptor"],   true,  "type(re.Match.lastgroup).__name__ == 'getset_descriptor' (tp_getset entry; same descriptor type as lastindex)"]
    - [lg_qn_eq,     "Match.lastgroup.__qualname__.__eq__",            ["Match.lastgroup"],     true,  "re.Match.lastgroup.__qualname__ == 'Match.lastgroup' (15 chars; name of last matched capturing group, or None if unnamed/no groups)"]
    - [lg_qn_len,    "Match.lastgroup.__qualname__.__len__",           [],                      15,    "re.Match.lastgroup.__qualname__.__len__() == 15 ('Match.lastgroup' has 15 chars; same length as lastindex)"]
    - [li_eq_lg_len, "Match.lastindex.__qualname__.__len__.__eq__",    [15],                    true,  "len('Match.lastindex') == len('Match.lastgroup') == 15 (lastindex and lastgroup share identical qualname length)"]
    - [li_ne_lg,     "Match.lastindex.__qualname__.__eq__",            ["Match.lastgroup"],     false, "re.Match.lastindex.__qualname__ != 'Match.lastgroup' (distinct qualnames despite same length; index stores int position, group stores str name)"]
    - [li_gt_str,    "Match.lastindex.__qualname__.__len__.__gt__",    [12],                    true,  "len('Match.lastindex') > len('Match.string') (15 > 12; lastindex is 3 chars longer than string)"]
    - [li_type_ne_md, "Match.lastindex.__class__.__name__.__eq__",     ["member_descriptor"],   false, "type(re.Match.lastindex).__name__ != 'member_descriptor' (it is 'getset_descriptor'; distinct from the four member_descriptor Match attributes)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra116.Match.string_qualname_eq:
  description: "re.Match.string.__qualname__ == 'Match.string' (length 12; type is 'member_descriptor' — a direct C struct member slot; 'Match.'(6)+'string'(6)==12; the .string attribute stores the original subject string that was passed to match/search/fullmatch; re_extra37 covered this length via Match.__dict__['string'].__qualname__.__len__(); this spec verifies the string equality via direct attribute access Match.string.__qualname__.__eq__()"
  category: qualnames
  kind: python_call_eq
  function: "Match.string.__qualname__.__eq__"
  args: ["Match.string"]
  expected: true

invariant re_extra116.Match.re_qualname_eq:
  description: "re.Match.re.__qualname__ == 'Match.re' (length 8; type is 'member_descriptor'; 'Match.'(6)+'re'(2)==8; 'Match.re' is the shortest qualname among all six Match descriptor attributes: re(8) < pos(9) < string(12) == endpos(12) < lastindex(15) == lastgroup(15); the .re attribute stores the compiled Pattern object that produced the match; re_extra37 covered this length via Match.__dict__['re'].__qualname__.__len__(); this spec verifies the equality via Match.re.__qualname__.__eq__())"
  category: qualnames
  kind: python_call_eq
  function: "Match.re.__qualname__.__eq__"
  args: ["Match.re"]
  expected: true

invariant re_extra116.Match.pos_qualname_eq:
  description: "re.Match.pos.__qualname__ == 'Match.pos' (length 9; type is 'member_descriptor'; 'Match.'(6)+'pos'(3)==9; the .pos attribute stores the index in the subject string where the search began — defaults to 0 when match/search is called without a pos argument; it is the second shortest Match descriptor qualname after Match.re(8) and before Match.endpos(12); re_extra37 covered this length via Match.__dict__['pos'].__qualname__.__len__()"
  category: qualnames
  kind: python_call_eq
  function: "Match.pos.__qualname__.__eq__"
  args: ["Match.pos"]
  expected: true

invariant re_extra116.Match.lastindex_qualname_eq:
  description: "re.Match.lastindex.__qualname__ == 'Match.lastindex' (length 15; type is 'getset_descriptor' — unlike string/re/pos/endpos which are 'member_descriptor'; lastindex stores the integer index of the last matched capturing group, or None if no groups matched; 'Match.'(6)+'lastindex'(9)==15; it shares qualname length 15 with lastgroup; re_extra37 covered this length via Match.__dict__['lastindex'].__qualname__.__len__()"
  category: qualnames
  kind: python_call_eq
  function: "Match.lastindex.__qualname__.__eq__"
  args: ["Match.lastindex"]
  expected: true

invariant re_extra116.Match.lastgroup_qualname_eq:
  description: "re.Match.lastgroup.__qualname__ == 'Match.lastgroup' (length 15; type is 'getset_descriptor'; lastgroup stores the name of the last matched capturing group, or None if the group had no name or if no groups matched; 'Match.'(6)+'lastgroup'(9)==15; it shares qualname length 15 with lastindex; both lastindex and lastgroup are 'getset_descriptor' rather than 'member_descriptor' because they require computed access — they involve looking up the last matched group index and then optionally resolving its name from the pattern's groupindex dict)"
  category: qualnames
  kind: python_call_eq
  function: "Match.lastgroup.__qualname__.__eq__"
  args: ["Match.lastgroup"]
  expected: true

