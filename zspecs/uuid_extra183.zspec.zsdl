spec: uuid_extra183
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 9562 — Universally Unique IDentifiers (UUID) — https://www.rfc-editor.org/rfc/rfc9562"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "CPython source: internal PRNG or MAC address resolution"
  notes:
    - "uuid.NAMESPACE_DNS, NAMESPACE_URL, NAMESPACE_OID, NAMESPACE_X500 are UUID instances; __class__.__name__ == 'UUID'; __class__.__module__ == 'uuid'."
    - "uuid.RFC_4122 is a plain str with value 'specified in RFC 4122'; __class__.__name__ == 'str'; __class__.__module__ == 'builtins'."
    - "uuid.SafeUUID is an Enum class; RFC_4122 is NOT a SafeUUID instance — it is a legacy str constant."
    - "uuid.RFC_4122.__class__.__name__.__eq__('SafeUUID') == False — RFC_4122 is str, not SafeUUID."
    - "NAMESPACE_DNS.__class__.__module__ == 'uuid' — UUID class lives in the uuid module; len('uuid')==4."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: NAMESPACE_* constants — __class__.__name__ identity
#
# uuid.NAMESPACE_DNS.__class__.__name__   == 'UUID'  (len=4)
# uuid.NAMESPACE_URL.__class__.__name__   == 'UUID'
# uuid.NAMESPACE_OID.__class__.__name__   == 'UUID'
# uuid.NAMESPACE_X500.__class__.__name__  == 'UUID'
#
# All four namespace constants are pre-defined UUID instances; their
# __class__.__name__ must be 'UUID' on any Python version that defines them.
# ---------------------------------------------------------------------------

