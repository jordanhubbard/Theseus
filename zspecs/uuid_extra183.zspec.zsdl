       true,
       "RFC_4122.__class__.__name__.__eq__('str') == True — RFC_4122 is a plain str, not SafeUUID; new to extra183"]
    - [rfc4122_class_module_eq,
       RFC_4122.__class__.__module__.__eq__,
       ["builtins"],
       true,
       "RFC_4122.__class__.__module__.__eq__('builtins') == True — str class lives in builtins; new to extra183"]
    - [rfc4122_class_module_len,
       RFC_4122.__class__.__module__.__len__,
       [],
       8,
       "RFC_4122.__class__.__module__.__len__() == 8 — 'builtins' has 8 characters; new to extra183"]
    - [rfc4122_not_safeuuid,
       RFC_4122.__class__.__name__.__eq__,
       ["SafeUUID"],
       false,
       "RFC_4122.__class__.__name__.__eq__('SafeUUID') == False — RFC_4122 is str, not SafeUUID enum; new to extra183"]

