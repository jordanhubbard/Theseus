# ---------------------------------------------------------------------------
# Table 3: RFC_4122 constant — class identity
#
# uuid.RFC_4122 == 'specified in RFC 4122' (a plain str, not SafeUUID)
# uuid.RFC_4122.__class__.__name__ == 'str'    (len=3)
# uuid.RFC_4122.__class__.__module__ == 'builtins' (len=8)
# uuid.RFC_4122.__class__.__name__.__eq__('SafeUUID') == False
#
# In Python 3.x, uuid.RFC_4122 was a legacy str constant describing
# the variant; it is NOT a SafeUUID enum value despite the name.
# ---------------------------------------------------------------------------

table uuid_extra183.rfc4122_class_identity:
  description: "uuid.RFC_4122 is a plain str, not SafeUUID; class identity checks; new to extra183"
  kind: python_call_eq
