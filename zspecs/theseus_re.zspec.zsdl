spec: theseus_re
version: ">=3.9"
backend: python_cleanroom(theseus_re)

docs: https://www.regular-expressions.info/

provenance:
  derived_from:
    - "https://www.regular-expressions.info/ — regex theory"
  notes:
    - "Clean-room regex subset. Do NOT import re, regex, or any regex library."
    - "Implement pattern matching from scratch using only Python stdlib."
    - "re_match_digit: match pattern r'\\d+' against '123abc' — return True if match found at start."
    - "re_search_digit: search for r'\\d+' in 'abc123def' — return True if found anywhere."
    - "re_sub_basic: replace first occurrence of r'\\d+' in 'abc123def' with 'NUM' — return 'abcNUMdef'."
    - "Only need to support: \\d (digit), \\w (word char), . (any), + (one or more), * (zero or more), ^ $ anchors, basic character classes."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_re.match_digit:
  description: "match r'\\d+' against '123abc' returns True"
  category: match
  kind: python_call_eq
  function: re_match_digit
  args: []
  expected: true

invariant theseus_re.search_digit:
  description: "search r'\\d+' in 'abc123def' returns True"
  category: search
  kind: python_call_eq
  function: re_search_digit
  args: []
  expected: true

invariant theseus_re.sub_basic:
  description: "sub r'\\d+' with 'NUM' in 'abc123def' returns 'abcNUMdef'"
  category: sub
  kind: python_call_eq
  function: re_sub_basic
  args: []
  expected: "abcNUMdef"
