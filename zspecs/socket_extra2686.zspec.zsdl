spec: socket_extra2686
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 626: checks socket.socket, socket.AddressFamily, socket.SocketKind __dict__ for __and__, __or__, __xor__ presence. AddressFamily and SocketKind are IntFlag subclasses — IntFlag defines __and__/__or__/__xor__ — but these are inherited, not defined in AddressFamily or SocketKind's own __dict__. All three classes return False for all three dunders."]
  created_at: "2026-04-13"
error_model: python_exceptions

table socket_extra2686.socket_dict_presence:
  description: "socket.socket __dict__ does not contain __and__, __or__, or __xor__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2686sc
  columns: [id, function, args, expected]
  rows:
    - ["sk2686sc001", socket.socket.__dict__.__contains__, ["__and__"], false]
    - ["sk2686sc002", socket.socket.__dict__.__contains__, ["__or__"],  false]
    - ["sk2686sc003", socket.socket.__dict__.__contains__, ["__xor__"], false]

table socket_extra2686.AddressFamily_dict_presence:
