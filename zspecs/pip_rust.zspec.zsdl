spec: pip_rust
version: ">=3.9"
backend: rust_module(pip_rust)

docs: https://pip.pypa.io/en/stable/

provenance:
  derived_from:
    - "https://pip.pypa.io/en/stable/ — pip documentation"
  not_derived_from:
    - "pip source: pip/__init__.py"
  notes:
    - "pip is the package installer for Python."
    - "pip.__version__ is a non-empty string."
    - "int(pip.__version__.split('.')[0]) >= 24."
    - "pip._internal is available."
    - "Expose pip_version_nonempty() -> bool: len(pip.__version__) > 0."
    - "Expose pip_version_major() -> int: int(pip.__version__.split('.')[0])."
    - "Expose pip_has_internal() -> bool: hasattr(pip, '_internal')."
    - "All test vectors verified against pip 25.0.1."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# pip_version_nonempty — version non-empty
invariant pip_rust.version.nonempty:
  description: "pip.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: pip_version_nonempty
  args: []
  expected: true

# pip_version_major — major version >= 24
invariant pip_rust.version.major_ge24:
  description: "pip major version >= 24"
  category: version
  kind: python_call_eq
  function: pip_version_major
  args: []
  expected: 25

# pip_has_internal — _internal module present
invariant pip_rust.module.has_internal:
  description: "pip._internal is available"
  category: module
  kind: python_call_eq
  function: pip_has_internal
  args: []
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T02:13:27Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
