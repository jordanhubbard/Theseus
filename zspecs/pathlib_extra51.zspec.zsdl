spec: pathlib_extra51
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib_extra50.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__len__(); Path.cwd/__qualname__.__len__()==8; Path.home/__qualname__.__len__()==9."
    - "pathlib_extra49.zspec.zsdl — covers Path/PurePath/PurePosixPath/PureWindowsPath/PosixPath/WindowsPath __qualname__.__eq__(); Path.cwd/__qualname__.__eq__(); Path.home/__qualname__.__eq__()."
    - "pathlib_extra44.zspec.zsdl — covers UnsupportedOperation __module__.__len__()==7/__bases__[0].__name__.__len__()==19/__mro__.__len__()==6; Path.readlink/__qualname__.__len__()==13; PurePath.full_match/__qualname__.__len__()==19."
    - "pathlib_extra41.zspec.zsdl — covers PurePath property fget __qualname__.__len__() for drive(14)/root(13)/anchor(15)/parents(16)."
    - "pathlib_extra39.zspec.zsdl — covers PurePath property fget __qualname__.__len__() for name(13)/parent(15)/suffix(15)/stem(13)/parts(14)."
    - "pathlib_extra32.zspec.zsdl — covers PurePath.suffixes.fget.__qualname__.__eq__('PurePath.suffixes') and fget.__module__.__eq__('pathlib') equality checks (NOT __len__())."
    - "pathlib_extra38.zspec.zsdl — covers PurePath.with_name/__qualname__.__len__()==18; PurePath.with_suffix/__qualname__.__len__()==20."
  notes:
    - "This spec extends pathlib_extra50.zspec.zsdl."
    - "Prior specs collectively covered: all six pathlib class __qualname__.__eq__() and __qualname__.__len__(); all major Path/PurePath method __qualname__.__len__(); PurePath property fget __qualname__.__len__() for name/parent/suffix/stem/parts/drive/root/anchor/parents (9 of the 10 named properties — suffixes.__len__() was NOT explicitly verified); UnsupportedOperation __name__.__len__()==20/__module__.__len__()==7/__mro__.__len__()==6 (but NOT __qualname__.__len__()); PurePath.with_name(18)/with_suffix(20)/with_stem(18) qualname lengths; NO prior pathlib spec covers with_segments.__qualname__.__len__(); NO prior pathlib spec covers Path.info.fget.__qualname__.__len__() (info is a new Python 3.14 property)."
    - "This spec covers: pathlib.PurePath.suffixes.fget.__qualname__.__len__()==17 (NOVEL — pathlib_extra32 covers the __qualname__.__eq__('PurePath.suffixes') equality; pathlib_extra41 covers drive/root/anchor/parents fget lengths; pathlib_extra39 covers name/parent/suffix/stem/parts fget lengths; but NO prior pathlib spec checks suffixes fget __qualname__.__len__()); pathlib.PurePath.with_segments.__qualname__.__len__()==22 (NOVEL — with_segments added in Python 3.12; no prior pathlib spec covers with_segments at all); pathlib.Path.info.fget.__qualname__.__len__()==9 (NOVEL — Path.info is a new property in Python 3.14 providing filesystem metadata; no prior pathlib spec covers it); pathlib.UnsupportedOperation.__qualname__.__len__()==20 (NOVEL — pathlib_extra40 covers __name__.__len__()==20; pathlib_extra44 covers __module__/__mro__ lengths; but no prior pathlib spec checks UnsupportedOperation.__qualname__.__len__(); __qualname__==__name__=='UnsupportedOperation' for top-level classes)."
    - "pathlib.PurePath.suffixes.fget.__qualname__.__len__() == 17. The property getter's __qualname__ is 'PurePath.suffixes' — 17 characters. pathlib_extra32 covers the equality check; no prior pathlib spec checks the length. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.PurePath.with_segments.__qualname__.__len__() == 22. 'PurePath.with_segments' has 22 characters. with_segments() creates a new path from path segments and was added in Python 3.12. No prior pathlib spec covers with_segments at all. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.Path.info.fget.__qualname__.__len__() == 9. Path.info is a property introduced in Python 3.14 that returns a PathInfo object with filesystem metadata. Its fget.__qualname__ is 'Path.info' (9 characters). Novel — no prior pathlib spec covers Path.info. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "pathlib.UnsupportedOperation.__qualname__.__len__() == 20. 'UnsupportedOperation' has 20 characters. __qualname__ equals __name__ for top-level classes. pathlib_extra40 covers __name__.__len__()==20 but no prior pathlib spec checks __qualname__.__len__(). Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath.suffixes property fget __qualname__.__len__()
#
# PurePath.suffixes is the property that returns a list of all file
# extensions (e.g. ['.tar', '.gz'] for 'a.tar.gz'). Its getter function's
# __qualname__ follows the standard pattern:
#
#   PurePath.suffixes.fget.__qualname__ == 'PurePath.suffixes'   -> len 17
#
# pathlib_extra32 covers the equality check for suffixes fget.__qualname__
# and fget.__module__. pathlib_extra39 covers name/parent/suffix/stem/parts
# fget __qualname__.__len__(). pathlib_extra41 covers drive/root/anchor/parents.
# No prior pathlib spec checks suffixes fget __qualname__.__len__().
# NOVEL in pathlib_extra51 namespace. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra51.suffixes_fget_qualname_len:
  description: "pathlib.PurePath.suffixes.fget.__qualname__.__len__() == 17 — 'PurePath.suffixes' has 17 characters; pathlib_extra32 covers equality check; pathlib_extra39/41 cover other property fget lengths but not suffixes; novel length anchor in pathlib_extra51 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: property_identity
  kind: python_call_eq
  function: "PurePath.suffixes.fget.__qualname__.__len__"
  args: []
  expected: 17

# ---------------------------------------------------------------------------
# pathlib.PurePath.with_segments __qualname__.__len__()
#
# PurePath.with_segments() is a classmethod added in Python 3.12 that creates
# a new path by joining segment strings, using the same class as the receiver.
# Its __qualname__ follows the class.method pattern:
#
#   PurePath.with_segments.__qualname__ == 'PurePath.with_segments'  -> len 22
#
# pathlib_extra38 covers with_name(18)/with_suffix(20) qualname lengths.
# No prior pathlib spec covers with_segments at all.
# NOVEL in pathlib_extra51 namespace. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra51.with_segments_qualname_len:
  description: "pathlib.PurePath.with_segments.__qualname__.__len__() == 22 — 'PurePath.with_segments' has 22 characters; with_segments added in Python 3.12; pathlib_extra38 covers with_name(18)/with_suffix(20) but not with_segments; novel in pathlib_extra51 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: PurePath.with_segments.__qualname__.__len__
  args: []
  expected: 22

# ---------------------------------------------------------------------------
# pathlib.Path.info property fget __qualname__.__len__()
#
# Path.info is a property introduced in Python 3.14 that provides access to
# a PathInfo object containing filesystem metadata (stat-like information)
# without triggering a system call unless accessed. Its getter's __qualname__
# follows the standard class.property pattern:
#
#   Path.info.fget.__qualname__ == 'Path.info'   -> len 9
#
# No prior pathlib spec covers Path.info (it is new in Python 3.14).
# NOVEL in pathlib_extra51 namespace. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra51.Path_info_fget_qualname_len:
  description: "pathlib.Path.info.fget.__qualname__.__len__() == 9 — 'Path.info' has 9 characters; Path.info is a new property in Python 3.14 providing filesystem metadata; no prior pathlib spec covers Path.info; novel in pathlib_extra51 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: property_identity
  kind: python_call_eq
  function: "Path.info.fget.__qualname__.__len__"
  args: []
  expected: 9

# ---------------------------------------------------------------------------
# pathlib.UnsupportedOperation.__qualname__.__len__()
#
# UnsupportedOperation is defined at module scope in pathlib, so its
# __qualname__ equals its __name__. Both are 'UnsupportedOperation' (20 chars).
#
#   UnsupportedOperation.__qualname__.__len__() == 20
#
# pathlib_extra40 covers UnsupportedOperation.__name__.__len__()==20.
# pathlib_extra44 covers __module__.__len__()==7/__bases__[0].__name__.__len__()==19/
# __mro__.__len__()==6. No prior pathlib spec checks __qualname__.__len__().
# NOVEL in pathlib_extra51 namespace. Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant pathlib_extra51.UnsupportedOperation_qualname_len:
  description: "pathlib.UnsupportedOperation.__qualname__.__len__() == 20 — 'UnsupportedOperation' has 20 characters; __qualname__==__name__ for top-level classes; pathlib_extra40 covers __name__.__len__()==20 but not __qualname__.__len__(); novel in pathlib_extra51 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: UnsupportedOperation.__qualname__.__len__
  args: []
  expected: 20
