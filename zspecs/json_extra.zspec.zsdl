spec: json_extra
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html

provenance:
  derived_from:
    - "RFC 8259 — The JavaScript Object Notation (JSON) Data Interchange Format, December 2017"
    - "https://docs.python.org/3/library/json.html — Python json module documentation"
    - "Test vectors verified by running Python 3.12 json module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl with deeper behaviors not covered there."
    - "json.loads with nested structures: nested dicts and lists are decoded recursively."
    - "json.dumps with indent=2 inserts newlines and two-space indentation."
    - "json.dumps with sort_keys=True emits object keys in ascending lexicographic order."
    - "json.dumps with indent and sort_keys can be combined."
    - "json.JSONDecodeError is a subclass of ValueError; it carries .msg, .doc, and .pos attributes."
    - "json.JSONEncoder is the default encoder class; json.JSONDecoder is the default decoder class."
    - "JSONEncoder.__name__ == 'JSONEncoder' and JSONDecoder.__name__ == 'JSONDecoder'."
    - "Both classes live in the 'json' module (json.encoder and json.decoder are sub-modules, but __module__ reflects the import path set by CPython — confirmed 'json.encoder'/'json.decoder' on Python 3.12)."
    - "json.dumps(obj, indent=2) — a single-key object {'a': 1} produces '{\\n  \"a\": 1\\n}'."
    - "json.dumps({'b': 2, 'a': 1}, sort_keys=True) == '{\"a\": 1, \"b\": 2}'."
    - "All expected values verified by running Python 3.12 json module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# json.loads — nested structures
# ---------------------------------------------------------------------------

invariant json_extra.loads.nested_dict:
  description: "json.loads('{\"a\": {\"b\": 1}}') == {'a': {'b': 1}} — nested object decodes recursively"
  category: loads_nested
  rfc: "RFC 8259 §4"
  kind: python_call_eq
  function: loads
  args: ["{\"a\": {\"b\": 1}}"]
  expected: {a: {b: 1}}

invariant json_extra.loads.nested_list:
  description: "json.loads('[[1, 2], [3, 4]]') == [[1, 2], [3, 4]] — nested array decodes recursively"
  category: loads_nested
  rfc: "RFC 8259 §5"
  kind: python_call_eq
  function: loads
  args: ["[[1, 2], [3, 4]]"]
  expected: [[1, 2], [3, 4]]

invariant json_extra.loads.mixed_nesting:
  description: "json.loads('{\"k\": [1, true, null]}') == {'k': [1, True, None]}"
  category: loads_nested
  rfc: "RFC 8259 §4"
  kind: python_call_eq
  function: loads
  args: ["{\"k\": [1, true, null]}"]
  expected: {k: [1, true, ~]}

# ---------------------------------------------------------------------------
# json.dumps — indent and sort_keys options
# ---------------------------------------------------------------------------

invariant json_extra.dumps.indent_single_key:
  description: "json.dumps({'a': 1}, indent=2) == '{\\n  \"a\": 1\\n}'"
  category: dumps_formatting
  kind: python_call_eq
  function: dumps
  args: [{a: 1}]
  kwargs: {indent: 2}
  expected: "{\n  \"a\": 1\n}"

invariant json_extra.dumps.sort_keys:
  description: "json.dumps({'b': 2, 'a': 1}, sort_keys=True) == '{\"a\": 1, \"b\": 2}' — keys in ascending order"
  category: dumps_formatting
  kind: python_call_eq
  function: dumps
  args: [{b: 2, a: 1}]
  kwargs: {sort_keys: true}
  expected: "{\"a\": 1, \"b\": 2}"

invariant json_extra.dumps.indent_and_sort_keys:
  description: "json.dumps({'b': 2, 'a': 1}, indent=2, sort_keys=True) starts with '{\\n  \"a\"'"
  category: dumps_formatting
  kind: python_call_eq
  function: dumps
  args: [{b: 2, a: 1}]
  kwargs: {indent: 2, sort_keys: true}
  expected: "{\n  \"a\": 1,\n  \"b\": 2\n}"

invariant json_extra.dumps.empty_object_indent:
  description: "json.dumps({}, indent=2) == '{}' — empty object is not indented"
  category: dumps_formatting
  kind: python_call_eq
  function: dumps
  args: [{}]
  kwargs: {indent: 2}
  expected: "{}"

# ---------------------------------------------------------------------------
# json.JSONDecodeError — raised on malformed input
# ---------------------------------------------------------------------------

invariant json_extra.JSONDecodeError.class_name:
  description: "json.JSONDecodeError.__name__ == 'JSONDecodeError'"
  category: classnames
  kind: python_call_eq
  function: JSONDecodeError.__name__.__eq__
  args: ["JSONDecodeError"]
  expected: true

invariant json_extra.JSONDecodeError.module:
  description: "json.JSONDecodeError.__module__ == 'json.decoder'"
  category: classnames
  kind: python_call_eq
  function: JSONDecodeError.__module__.__eq__
  args: ["json.decoder"]
  expected: true

invariant json_extra.JSONDecodeError.base_is_ValueError:
  description: "json.JSONDecodeError.__bases__[0].__name__ == 'ValueError'"
  category: classnames
  kind: python_call_eq
  function: JSONDecodeError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "ValueError"

table json_extra.JSONDecodeError.raises:
  kind: python_call_raises
  category: error
  id_prefix: loads
  function: loads
  expected_exception: json.JSONDecodeError

  columns: [id, args, description]
  rows:
    - [bare_key_raises,   ["{key: 1}"],          "unquoted key raises JSONDecodeError"]
    - [single_quote_raises, ["{'a': 1}"],         "single-quoted key raises JSONDecodeError"]
    - [unclosed_array_raises, ["[1, 2"],           "unclosed array raises JSONDecodeError"]

# ---------------------------------------------------------------------------
# json.JSONEncoder — encoder class identity
# ---------------------------------------------------------------------------

invariant json_extra.JSONEncoder.class_name:
  description: "json.JSONEncoder.__name__ == 'JSONEncoder'"
  category: classnames
  kind: python_call_eq
  function: JSONEncoder.__name__.__eq__
  args: ["JSONEncoder"]
  expected: true

invariant json_extra.JSONEncoder.module:
  description: "json.JSONEncoder.__module__ == 'json.encoder'"
  category: classnames
  kind: python_call_eq
  function: JSONEncoder.__module__.__eq__
  args: ["json.encoder"]
  expected: true

# ---------------------------------------------------------------------------
# json.JSONDecoder — decoder class identity
# ---------------------------------------------------------------------------

invariant json_extra.JSONDecoder.class_name:
  description: "json.JSONDecoder.__name__ == 'JSONDecoder'"
  category: classnames
  kind: python_call_eq
  function: JSONDecoder.__name__.__eq__
  args: ["JSONDecoder"]
  expected: true

invariant json_extra.JSONDecoder.module:
  description: "json.JSONDecoder.__module__ == 'json.decoder'"
  category: classnames
  kind: python_call_eq
  function: JSONDecoder.__module__.__eq__
  args: ["json.decoder"]
  expected: true
