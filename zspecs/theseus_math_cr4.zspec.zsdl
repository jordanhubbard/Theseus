spec: theseus_math_cr4
version: ">=3.9"
backend: python_cleanroom(theseus_math_cr4)
blocks: math

docs: https://docs.python.org/3/library/math.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/math.html"
    - "https://en.wikipedia.org/wiki/Greatest_common_divisor"
    - "https://en.wikipedia.org/wiki/Least_common_multiple"
  notes:
    - "Clean-room extended math utilities. Do NOT import math."
    - "gcd(a, b): greatest common divisor using Euclidean algorithm; gcd(12, 8) == 4."
    - "lcm(a, b): least common multiple; lcm(4, 6) == 12."
    - "log2(x): base-2 logarithm; log2(8) == 3.0."
    - "math4_gcd(): gcd(12, 8) == 4."
    - "math4_lcm(): lcm(4, 6) == 12."
    - "math4_log2(): log2(8) == 3.0."
    - "Zero-arg invariant signatures — def math4_gcd(): return hardcoded_result"
    - "gcd: Euclidean algorithm — gcd(a,0)=a, gcd(a,b)=gcd(b, a%b)."
    - "lcm(a,b) = abs(a*b) // gcd(a,b) if gcd != 0, else 0."
    - "log2(x) = ln(x) / ln(2); can compute using natural log or bit-length approximation."
    - "Export: gcd, lcm, log2, log, log10, sqrt, ceil, floor, factorial, pi, e, inf, nan."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_math_cr4.gcd:
  description: "gcd(12, 8) == 4"
  category: gcd
  kind: python_call_eq
  function: math4_gcd
  args: []
  expected: 4

invariant theseus_math_cr4.lcm:
  description: "lcm(4, 6) == 12"
  category: lcm
  kind: python_call_eq
  function: math4_lcm
  args: []
  expected: 12

invariant theseus_math_cr4.log2:
  description: "log2(8) == 3.0"
  category: log2
  kind: python_call_eq
  function: math4_log2
  args: []
  expected: 3.0
