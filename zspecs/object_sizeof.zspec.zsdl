spec: object_sizeof
version: ">=2.6.5"
backend: node(object-sizeof)

docs: https://www.npmjs.com/package/object-sizeof

provenance:
  derived_from:
    - "object-sizeof README — https://www.npmjs.com/package/object-sizeof"
    - "Test vectors verified with object-sizeof via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "object-sizeof source"
  notes:
    - "object-sizeof is an npm package. Install: npm install object-sizeof"
    - "Returns the approximate byte size of a JavaScript object."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a number (byte count)."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_sizeof.measure:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: objsz

  columns: [id, args, expected]
  rows:
    - [two_keys,  [{"a": 1, "b": 2}],  13]
    - [one_key,   [{"a": 1}],           7]
    - [empty,     [{}],                 2]
