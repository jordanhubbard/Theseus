spec: asyncio_extra203
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/__init__.py"
  notes:
    - "This spec covers asyncio.__spec__ deeper attributes: name, has_location, parent, __class__.__name__, submodule_search_locations.__class__.__name__."
    - "asyncio.__spec__.name == 'asyncio' — the ModuleSpec's name attribute matches the module name. Verified with Python 3.14.3."
    - "asyncio.__spec__.has_location == True — asyncio is loaded from disk; has_location is True for file-backed packages. Verified with Python 3.14.3."
    - "asyncio.__spec__.parent == 'asyncio' — asyncio is a top-level package; __spec__.parent equals __spec__.name. Verified with Python 3.14.3."
    - "asyncio.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an importlib.machinery.ModuleSpec instance. Verified with Python 3.14.3."
    - "asyncio.__spec__.submodule_search_locations.__class__.__name__ == 'list' — asyncio is a package; submodule_search_locations is a list of directory paths. Verified with Python 3.14.3."
    - "asyncio.__spec__.has_location.__class__.__name__ == 'bool' — has_location is a plain Python bool. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.__spec__.name identity
#
# asyncio.__spec__.name == 'asyncio' (len 7)
# asyncio is a top-level package; its ModuleSpec.name is 'asyncio'.
# New to asyncio_extra203.
# ---------------------------------------------------------------------------

table asyncio_extra203.spec_name:
  description: "asyncio.__spec__.name == 'asyncio' and its length is 7; new to asyncio_extra203"
  kind: python_call_eq
  category: spec_attrs
  id_prefix: asynciospec203

  columns: [id, function, args, expected, description]
  rows:
    - [spec_name_eq,
       "__spec__.name.__eq__",
       ["asyncio"],
       true,
       "asyncio.__spec__.name.__eq__('asyncio') == True — ModuleSpec.name equals 'asyncio'; new to asyncio_extra203"]
    - [spec_name_len_eq_7,
       "__spec__.name.__len__",
       [],
       7,
       "asyncio.__spec__.name.__len__() == 7 — 'asyncio' has 7 characters; new to asyncio_extra203"]
    - [spec_name_class_eq,
       "__spec__.name.__class__.__name__.__eq__",
       ["str"],
       true,
       "asyncio.__spec__.name.__class__.__name__.__eq__('str') == True — ModuleSpec.name is a str; new to asyncio_extra203"]
    - [spec_name_startswith,
       "__spec__.name.__contains__",
       ["asyncio"],
       true,
       "asyncio.__spec__.name.__contains__('asyncio') == True — name contains the package name; new to asyncio_extra203"]

# ---------------------------------------------------------------------------
# Table 2: asyncio.__spec__.has_location and asyncio.__spec__.parent
#
# asyncio.__spec__.has_location == True — file-backed package
# asyncio.__spec__.parent == 'asyncio' — top-level package; parent == name
# New to asyncio_extra203.
# ---------------------------------------------------------------------------

table asyncio_extra203.spec_has_location_parent:
  description: "asyncio.__spec__.has_location == True; asyncio.__spec__.parent == 'asyncio'; new to asyncio_extra203"
  kind: python_call_eq
  category: spec_attrs
  id_prefix: asynciospec203

  columns: [id, function, args, expected, description]
  rows:
    - [spec_hasloc_eq_true,
       "__spec__.has_location.__eq__",
       [true],
       true,
       "asyncio.__spec__.has_location.__eq__(True) == True — asyncio is disk-backed; has_location is True; new to asyncio_extra203"]
    - [spec_hasloc_class_eq_bool,
       "__spec__.has_location.__class__.__name__.__eq__",
       ["bool"],
       true,
       "asyncio.__spec__.has_location.__class__.__name__.__eq__('bool') == True — has_location is a bool; new to asyncio_extra203"]
    - [spec_parent_eq,
       "__spec__.parent.__eq__",
       ["asyncio"],
       true,
       "asyncio.__spec__.parent.__eq__('asyncio') == True — top-level package; parent equals name; new to asyncio_extra203"]
    - [spec_parent_len_eq_7,
       "__spec__.parent.__len__",
       [],
       7,
       "asyncio.__spec__.parent.__len__() == 7 — 'asyncio' has 7 characters; new to asyncio_extra203"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.__spec__.__class__.__name__ and submodule_search_locations
#
# asyncio.__spec__.__class__.__name__ == 'ModuleSpec' (len 10)
# asyncio.__spec__.submodule_search_locations.__class__.__name__ == 'list'
# New to asyncio_extra203.
# ---------------------------------------------------------------------------

table asyncio_extra203.spec_class_and_search_locations:
  description: "asyncio.__spec__.__class__.__name__ == 'ModuleSpec'; submodule_search_locations.__class__.__name__ == 'list'; new to asyncio_extra203"
  kind: python_call_eq
  category: spec_attrs
  id_prefix: asynciospec203

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_eq,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "asyncio.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — spec is a ModuleSpec instance; new to asyncio_extra203"]
    - [spec_class_name_len_eq_10,
       "__spec__.__class__.__name__.__len__",
       [],
       10,
       "asyncio.__spec__.__class__.__name__.__len__() == 10 — 'ModuleSpec' has 10 characters; new to asyncio_extra203"]
    - [submodule_search_locs_class_eq,
       "__spec__.submodule_search_locations.__class__.__name__.__eq__",
       ["list"],
       true,
       "asyncio.__spec__.submodule_search_locations.__class__.__name__.__eq__('list') == True — asyncio is a package; search locations is a list; new to asyncio_extra203"]
    - [submodule_search_locs_class_len_eq_4,
       "__spec__.submodule_search_locations.__class__.__name__.__len__",
       [],
       4,
       "asyncio.__spec__.submodule_search_locations.__class__.__name__.__len__() == 4 — 'list' has 4 characters; new to asyncio_extra203"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra203
# ---------------------------------------------------------------------------

invariant asyncio_extra203.spec_name_eq:
  description: "asyncio.__spec__.name == 'asyncio' — the ModuleSpec name attribute equals the canonical module name; new to asyncio_extra203; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra203.spec_has_location_true:
  description: "asyncio.__spec__.has_location == True — asyncio is a file-backed package; has_location is True; new to asyncio_extra203; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.has_location.__eq__
  args: [true]
  expected: true

invariant asyncio_extra203.spec_parent_eq:
  description: "asyncio.__spec__.parent == 'asyncio' — asyncio is a top-level package; parent equals name; new to asyncio_extra203; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.parent.__eq__
  args: ["asyncio"]
  expected: true

invariant asyncio_extra203.spec_class_name_eq:
  description: "asyncio.__spec__.__class__.__name__ == 'ModuleSpec' — the spec object is an importlib.machinery.ModuleSpec instance; new to asyncio_extra203; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant asyncio_extra203.spec_submodule_search_locations_class_eq:
  description: "asyncio.__spec__.submodule_search_locations.__class__.__name__ == 'list' — asyncio is a package; submodule_search_locations is a list of directory paths; new to asyncio_extra203; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant asyncio_extra203.spec_has_location_class_eq:
  description: "asyncio.__spec__.has_location.__class__.__name__ == 'bool' — has_location is a plain Python bool; new to asyncio_extra203; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.has_location.__class__.__name__.__eq__
  args: ["bool"]
  expected: true

invariant asyncio_extra203.spec_name_len_eq_7:
  description: "asyncio.__spec__.name.__len__() == 7 — 'asyncio' has 7 characters; new to asyncio_extra203; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.name.__len__
  args: []
  expected: 7

invariant asyncio_extra203.spec_parent_len_eq_7:
  description: "asyncio.__spec__.parent.__len__() == 7 — parent is 'asyncio' which has 7 characters; new to asyncio_extra203; verified Python 3.14.3"
  category: spec_attrs
  kind: python_call_eq
  function: __spec__.parent.__len__
  args: []
  expected: 7
