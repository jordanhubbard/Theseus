spec: uuid_extra1081
version: ">=3.9"
backend: python_module(uuid)
docs: https://docs.python.org/3/library/uuid.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks UUID.__init__, __eq__, __ne__, __lt__, __le__, __gt__, __ge__ dunder qualnames and module"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table uuid_extra1081.uuid_init_qualname:
  description: "uuid.UUID.__init__ qualname and class name identity"
  kind: python_call_eq
  category: uuid_init_qualname
  id_prefix: uu1081in
  columns: [id, function, args, expected]
  rows:
    - [uu1081in001, uuid.UUID.__init__.__qualname__.__eq__,              ["UUID.__init__"],   true]
    - [uu1081in002, uuid.UUID.__init__.__qualname__.__class__.__name__.__eq__, ["str"],       true]
    - [uu1081in003, uuid.UUID.__init__.__class__.__name__.__eq__,        ["function"],        true]
    - [uu1081in004, uuid.UUID.__init__.__module__.__eq__,                ["uuid"],            true]
    - [uu1081in005, uuid.UUID.__init__.__module__.__class__.__name__.__eq__, ["str"],         true]
    - [uu1081in006, uuid.UUID.__ne__.__qualname__.__eq__,                ["UUID.__ne__"],     true]
    - [uu1081in007, uuid.UUID.__ne__.__qualname__.__class__.__name__.__eq__, ["str"],         true]
    - [uu1081in008, uuid.UUID.__ne__.__class__.__name__.__eq__,          ["function"],        true]

table uuid_extra1081.uuid_comparison_qualnames:
  description: "uuid.UUID comparison dunder __qualname__ identity: __lt__, __le__, __gt__, __ge__, __eq__"
  kind: python_call_eq
  category: uuid_comparison_qualnames
  id_prefix: uu1081cq
  columns: [id, function, args, expected]
  rows:
    - [uu1081cq001, uuid.UUID.__eq__.__qualname__.__eq__,   ["UUID.__eq__"],  true]
    - [uu1081cq002, uuid.UUID.__lt__.__qualname__.__eq__,   ["UUID.__lt__"],  true]
    - [uu1081cq003, uuid.UUID.__le__.__qualname__.__eq__,   ["UUID.__le__"],  true]
    - [uu1081cq004, uuid.UUID.__gt__.__qualname__.__eq__,   ["UUID.__gt__"],  true]
    - [uu1081cq005, uuid.UUID.__ge__.__qualname__.__eq__,   ["UUID.__ge__"],  true]
    - [uu1081cq006, uuid.UUID.__eq__.__class__.__name__.__eq__,  ["function"], true]
    - [uu1081cq007, uuid.UUID.__lt__.__class__.__name__.__eq__,  ["function"], true]
    - [uu1081cq008, uuid.UUID.__le__.__class__.__name__.__eq__,  ["function"], true]
    - [uu1081cq009, uuid.UUID.__gt__.__class__.__name__.__eq__,  ["function"], true]
    - [uu1081cq010, uuid.UUID.__ge__.__class__.__name__.__eq__,  ["function"], true]

table uuid_extra1081.uuid_comparison_modules:
  description: "uuid.UUID comparison dunder __module__ identity"
  kind: python_call_eq
  category: uuid_comparison_modules
  id_prefix: uu1081cm
  columns: [id, function, args, expected]
  rows:
    - [uu1081cm001, uuid.UUID.__eq__.__module__.__eq__,  ["uuid"], true]
    - [uu1081cm002, uuid.UUID.__ne__.__module__.__eq__,  ["uuid"], true]
    - [uu1081cm003, uuid.UUID.__lt__.__module__.__eq__,  ["uuid"], true]
    - [uu1081cm004, uuid.UUID.__le__.__module__.__eq__,  ["uuid"], true]
    - [uu1081cm005, uuid.UUID.__gt__.__module__.__eq__,  ["uuid"], true]
    - [uu1081cm006, uuid.UUID.__ge__.__module__.__eq__,  ["uuid"], true]
    - [uu1081cm007, uuid.UUID.__eq__.__module__.__class__.__name__.__eq__, ["str"], true]
    - [uu1081cm008, uuid.UUID.__lt__.__module__.__class__.__name__.__eq__, ["str"], true]
