spec: threading_extra98
version: ">=3.9"
backend: python_module(threading)
extends: threading_extra97

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra97.zspec.zsdl."
    - "This spec covers: threading.Thread lifecycle method class names (all 'function'); Thread property class names (all 'property'); Thread.__dict__ membership for methods and properties (Wave 254)."
    - "threading.Thread.__init__.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Thread.__repr__.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Thread.start.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Thread.run.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Thread.join.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Thread.is_alive.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Thread._bootstrap.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Thread._bootstrap_inner.__class__.__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.Thread.__enter__ and __exit__: NOT FOUND — Thread does not implement the context manager protocol directly. Verified with Python 3.14.3."
    - "threading.Thread.daemon.__class__.__name__ == 'property'. Verified with Python 3.14.3."
    - "threading.Thread.name.__class__.__name__ == 'property'. Verified with Python 3.14.3."
    - "threading.Thread.ident.__class__.__name__ == 'property'. Verified with Python 3.14.3."
    - "threading.Thread.native_id.__class__.__name__ == 'property'. Verified with Python 3.14.3."
    - "All Thread.__dict__.__contains__ checks for methods and properties return True. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: Thread method class names for lifecycle methods (all 'function')
#
# Wave 254 theme: threading.Thread lifecycle Python method class names.
#
# threading.Thread.__init__.__class__.__name__ == 'function'
# threading.Thread.__repr__.__class__.__name__ == 'function'
# threading.Thread.start.__class__.__name__ == 'function'
# threading.Thread.run.__class__.__name__ == 'function'
# threading.Thread.join.__class__.__name__ == 'function'
# threading.Thread.is_alive.__class__.__name__ == 'function'
#
# Thread is a pure-Python class in Lib/threading.py; all lifecycle methods
# are Python functions. __enter__/__exit__ are NOT FOUND. New to extra98.
# ---------------------------------------------------------------------------

table threading_extra98.thread_lifecycle_method_class_names:
  description: "threading.Thread lifecycle method class names: __init__/__repr__/start/run/join/is_alive all 'function'; pure-Python class; wave 254; new to extra98"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthreadmethods98

  columns: [id, function, args, expected, description]
  rows:
    - [thread_init_class_name_eq_function,
       "Thread.__init__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.__init__.__class__.__name__.__eq__('function') == True — Thread is a pure-Python class defined in Lib/threading.py; __init__ initializes the thread with group, target, name, args, kwargs, and daemon; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra98"]
    - [thread_repr_class_name_eq_function,
       "Thread.__repr__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.__repr__.__class__.__name__.__eq__('function') == True — Thread.__repr__ is a Python function that returns a string representation showing the thread name and state; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra98"]
    - [thread_start_class_name_eq_function,
       "Thread.start.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.start.__class__.__name__.__eq__('function') == True — Thread.start arranges for the thread's run() method to be invoked in a separate thread of control; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra98"]
    - [thread_run_class_name_eq_function,
       "Thread.run.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.run.__class__.__name__.__eq__('function') == True — Thread.run represents the thread's activity and may be overridden in a subclass; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra98"]
    - [thread_join_class_name_eq_function,
       "Thread.join.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.join.__class__.__name__.__eq__('function') == True — Thread.join waits until the thread terminates; it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra98"]
    - [thread_is_alive_class_name_eq_function,
       "Thread.is_alive.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.Thread.is_alive.__class__.__name__.__eq__('function') == True — Thread.is_alive returns True if the thread is alive (between start() and termination); it is a Python function; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra98"]

# ---------------------------------------------------------------------------
# Table 2: Thread property __class__.__name__ (all 'property')
#
# Wave 254 theme: threading.Thread descriptor attribute class names.
#
# threading.Thread.daemon.__class__.__name__ == 'property'
# threading.Thread.name.__class__.__name__ == 'property'
# threading.Thread.ident.__class__.__name__ == 'property'
# threading.Thread.native_id.__class__.__name__ == 'property'
#
# Thread exposes daemon, name, ident, and native_id as Python properties.
# New to extra98.
# ---------------------------------------------------------------------------

table threading_extra98.thread_property_class_names:
  description: "threading.Thread property class names: daemon/name/ident/native_id all 'property'; Python descriptor attributes; wave 254; new to extra98"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthreadmethods98

  columns: [id, function, args, expected, description]
  rows:
    - [thread_daemon_class_name_eq_property,
       "Thread.daemon.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Thread.daemon.__class__.__name__.__eq__('property') == True — Thread.daemon is a Python property controlling whether the thread is a daemon thread (which does not prevent the interpreter from exiting); __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra98"]
    - [thread_name_class_name_eq_property,
       "Thread.name.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Thread.name.__class__.__name__.__eq__('property') == True — Thread.name is a Python property for the thread name (string used for identification); __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra98"]
    - [thread_ident_class_name_eq_property,
       "Thread.ident.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Thread.ident.__class__.__name__.__eq__('property') == True — Thread.ident is a Python property returning the thread identifier (an integer assigned by the OS); __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra98"]
    - [thread_native_id_class_name_eq_property,
       "Thread.native_id.__class__.__name__.__eq__",
       ["property"],
       true,
       "threading.Thread.native_id.__class__.__name__.__eq__('property') == True — Thread.native_id is a Python property returning the OS-level native thread ID (added in Python 3.8); __class__.__name__ is 'property'; str.__eq__('property') returns True; new to extra98"]

# ---------------------------------------------------------------------------
# Table 3: Thread.__dict__ membership for methods
#
# Wave 254 theme: threading.Thread type __dict__ membership for methods.
#
# threading.Thread.__dict__.__contains__('__init__') == True
# threading.Thread.__dict__.__contains__('__repr__') == True
# threading.Thread.__dict__.__contains__('start') == True
# threading.Thread.__dict__.__contains__('run') == True
# threading.Thread.__dict__.__contains__('join') == True
# threading.Thread.__dict__.__contains__('is_alive') == True
#
# All lifecycle methods are defined on Thread itself. New to extra98.
# ---------------------------------------------------------------------------

table threading_extra98.thread_dict_methods_membership:
  description: "threading.Thread.__dict__ membership for __init__/__repr__/start/run/join/is_alive (all True); lifecycle methods in type __dict__; wave 254; new to extra98"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthreadmethods98

  columns: [id, function, args, expected, description]
  rows:
    - [thread_dict_contains_init,
       "Thread.__dict__.__contains__",
       ["__init__"],
       true,
       "threading.Thread.__dict__.__contains__('__init__') == True — Thread defines its own __init__ in Lib/threading.py; it appears in the type __dict__; mappingproxy.__contains__('__init__') returns True; new to extra98"]
    - [thread_dict_contains_repr,
       "Thread.__dict__.__contains__",
       ["__repr__"],
       true,
       "threading.Thread.__dict__.__contains__('__repr__') == True — Thread defines its own __repr__; it appears in the type __dict__; mappingproxy.__contains__('__repr__') returns True; new to extra98"]
    - [thread_dict_contains_start,
       "Thread.__dict__.__contains__",
       ["start"],
       true,
       "threading.Thread.__dict__.__contains__('start') == True — Thread.start is defined in Lib/threading.py; it appears in the type __dict__; mappingproxy.__contains__('start') returns True; new to extra98"]
    - [thread_dict_contains_run,
       "Thread.__dict__.__contains__",
       ["run"],
       true,
       "threading.Thread.__dict__.__contains__('run') == True — Thread.run is defined in Lib/threading.py as the overridable activity method; it appears in the type __dict__; mappingproxy.__contains__('run') returns True; new to extra98"]
    - [thread_dict_contains_join,
       "Thread.__dict__.__contains__",
       ["join"],
       true,
       "threading.Thread.__dict__.__contains__('join') == True — Thread.join is defined in Lib/threading.py; it appears in the type __dict__; mappingproxy.__contains__('join') returns True; new to extra98"]
    - [thread_dict_contains_is_alive,
       "Thread.__dict__.__contains__",
       ["is_alive"],
       true,
       "threading.Thread.__dict__.__contains__('is_alive') == True — Thread.is_alive is defined in Lib/threading.py; it appears in the type __dict__; mappingproxy.__contains__('is_alive') returns True; new to extra98"]

# ---------------------------------------------------------------------------
# Table 4: Thread.__dict__ membership for properties
#
# Wave 254 theme: threading.Thread type __dict__ membership for properties.
#
# threading.Thread.__dict__.__contains__('daemon') == True
# threading.Thread.__dict__.__contains__('name') == True
# threading.Thread.__dict__.__contains__('ident') == True
# threading.Thread.__dict__.__contains__('native_id') == True
#
# All four descriptor properties are defined on Thread itself. New to extra98.
# ---------------------------------------------------------------------------

table threading_extra98.thread_dict_properties_membership:
  description: "threading.Thread.__dict__ membership for daemon/name/ident/native_id (all True); property descriptors in type __dict__; wave 254; new to extra98"
  kind: python_call_eq
  category: string_identity
  id_prefix: threadingthreadmethods98

  columns: [id, function, args, expected, description]
  rows:
    - [thread_dict_contains_daemon,
       "Thread.__dict__.__contains__",
       ["daemon"],
       true,
       "threading.Thread.__dict__.__contains__('daemon') == True — Thread.daemon is a property defined in Lib/threading.py controlling daemon thread behavior; it appears in the type __dict__; mappingproxy.__contains__('daemon') returns True; new to extra98"]
    - [thread_dict_contains_name,
       "Thread.__dict__.__contains__",
       ["name"],
       true,
       "threading.Thread.__dict__.__contains__('name') == True — Thread.name is a property defined in Lib/threading.py for the thread name; it appears in the type __dict__; mappingproxy.__contains__('name') returns True; new to extra98"]
    - [thread_dict_contains_ident,
       "Thread.__dict__.__contains__",
       ["ident"],
       true,
       "threading.Thread.__dict__.__contains__('ident') == True — Thread.ident is a property defined in Lib/threading.py returning the OS thread identifier; it appears in the type __dict__; mappingproxy.__contains__('ident') returns True; new to extra98"]
    - [thread_dict_contains_native_id,
       "Thread.__dict__.__contains__",
       ["native_id"],
       true,
       "threading.Thread.__dict__.__contains__('native_id') == True — Thread.native_id is a property added in Python 3.8 returning the native OS thread ID; it appears in the type __dict__; mappingproxy.__contains__('native_id') returns True; new to extra98"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra98
# ---------------------------------------------------------------------------

invariant threading_extra98.thread_start_class_name_eq_function:
  description: "threading.Thread.start.__class__.__name__ == 'function' — pure-Python lifecycle method; wave 254; new to extra98"
  kind: python_call_eq
  function: Thread.start.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant threading_extra98.thread_daemon_class_name_eq_property:
  description: "threading.Thread.daemon.__class__.__name__ == 'property' — Python property descriptor for daemon flag; wave 254; new to extra98"
  kind: python_call_eq
  function: Thread.daemon.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant threading_extra98.thread_dict_contains_join:
  description: "threading.Thread.__dict__.__contains__('join') == True — join method defined on Thread itself; wave 254; new to extra98"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["join"]
  expected: true

invariant threading_extra98.thread_dict_contains_native_id:
  description: "threading.Thread.__dict__.__contains__('native_id') == True — native_id property defined on Thread (added Python 3.8); wave 254; new to extra98"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["native_id"]
  expected: true

invariant threading_extra98.thread_is_alive_class_name_eq_function:
  description: "threading.Thread.is_alive.__class__.__name__ == 'function' — pure-Python state query method; wave 254; new to extra98"
  kind: python_call_eq
  function: Thread.is_alive.__class__.__name__.__eq__
  args: ["function"]
  expected: true
