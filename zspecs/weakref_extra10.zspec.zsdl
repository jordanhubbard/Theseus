spec: weakref_extra10
version: ">=3.9"
backend: python_module(weakref)

docs: https://docs.python.org/3/library/weakref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/weakref.html — Python weakref module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_weakref.c"
    - "CPython source: Lib/weakref.py"
  notes:
    - "This spec extends weakref.zspec.zsdl through weakref_extra9.zspec.zsdl."
    - "weakref_extra9 covers __name__ and __module__ for ref/proxy/WeakSet/WeakKeyDictionary/WeakValueDictionary/WeakMethod/finalize/ReferenceType/ProxyType/CallableProxyType via __eq__ method chain."
    - "weakref_extra6 covers __qualname__ for ref/ReferenceType/proxy/ProxyType/CallableProxyType/WeakMethod."
    - "No prior weakref spec covers __qualname__ for WeakValueDictionary, WeakSet, WeakKeyDictionary, or finalize."
    - "weakref.WeakValueDictionary.__qualname__ == 'WeakValueDictionary' — pure-Python class; qualname equals name."
    - "weakref.WeakSet.__qualname__ == 'WeakSet' — pure-Python class defined in _weakrefset; qualname equals name."
    - "weakref.WeakKeyDictionary.__qualname__ == 'WeakKeyDictionary' — pure-Python class; qualname equals name."
    - "weakref.finalize.__qualname__ == 'finalize' — C-level type re-exported via weakref; qualname equals name."
    - "For all top-level (non-nested) classes, __qualname__ == __name__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __qualname__ — WeakValueDictionary, WeakSet, WeakKeyDictionary, finalize
#
# weakref_extra6 covers __qualname__ for ref, ReferenceType, proxy, ProxyType,
# CallableProxyType, and WeakMethod. No prior spec covers __qualname__ for
# WeakValueDictionary, WeakSet, WeakKeyDictionary, or finalize. For top-level
# classes, __qualname__ == __name__, so the expected values match __name__.
# ---------------------------------------------------------------------------

invariant weakref_extra10.WeakValueDictionary.qualname:
  description: "weakref.WeakValueDictionary.__qualname__ == 'WeakValueDictionary' — top-level class; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: WeakValueDictionary.__qualname__.__eq__
  args: ["WeakValueDictionary"]
  expected: true

invariant weakref_extra10.WeakSet.qualname:
  description: "weakref.WeakSet.__qualname__ == 'WeakSet' — top-level class; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: WeakSet.__qualname__.__eq__
  args: ["WeakSet"]
  expected: true

invariant weakref_extra10.WeakKeyDictionary.qualname:
  description: "weakref.WeakKeyDictionary.__qualname__ == 'WeakKeyDictionary' — top-level class; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: WeakKeyDictionary.__qualname__.__eq__
  args: ["WeakKeyDictionary"]
  expected: true

invariant weakref_extra10.finalize.qualname:
  description: "weakref.finalize.__qualname__ == 'finalize' — top-level C type; qualname equals name"
  category: class_qualnames
  kind: python_call_eq
  function: finalize.__qualname__.__eq__
  args: ["finalize"]
  expected: true
