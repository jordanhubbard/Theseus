invariant functools_extra199.singledispatchmethod_module_eq:
  description: "functools.singledispatchmethod.__module__.__eq__('functools') == True — singledispatchmethod is defined at top level in functools.py; __module__ is 'functools' (len=9); verified with Python 3.14.3; new to extra199"
  category: identity
