spec: functools_extra199
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.singledispatch.__name__ == 'singledispatch' (len=14); singledispatch is a Python function that transforms a plain function into a single-dispatch generic function; verified with Python 3.14.3."
    - "functools.singledispatch.__module__ == 'functools' (len=9); defined at top level in functools.py; verified with Python 3.14.3."
    - "functools.singledispatch.__class__.__name__ == 'function' (len=8); singledispatch is a regular Python function so its __class__ is the built-in function type; verified with Python 3.14.3."
    - "functools.singledispatch.__qualname__ == 'singledispatch' (len=14); top-level function so qualname equals name; verified with Python 3.14.3."
    - "functools.singledispatchmethod.__name__ == 'singledispatchmethod' (len=20); singledispatchmethod is a descriptor class that wraps a singledispatch function for use inside a class; verified with Python 3.14.3."
    - "functools.singledispatchmethod.__module__ == 'functools' (len=9); defined at top level in functools.py; verified with Python 3.14.3."
    - "functools.singledispatchmethod.__bases__[0].__name__ == 'object' (len=6); singledispatchmethod inherits directly from object; verified with Python 3.14.3."
    - "functools.singledispatchmethod.__class__.__name__ == 'type' (len=4); singledispatchmethod is a class so its metaclass is the builtin type; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.singledispatch name, module, and class identity
#
# functools.singledispatch.__name__        == 'singledispatch' (len=14)
# functools.singledispatch.__module__      == 'functools' (len=9)
# functools.singledispatch.__class__.__name__ == 'function' (len=8)
#
# singledispatch is a decorator factory defined as a plain Python function
# in functools.py. New to extra199.
# ---------------------------------------------------------------------------

table functools_extra199.singledispatch_name_module_class:
  description: "functools.singledispatch identity: __name__=='singledispatch'(len=14); __module__=='functools'(len=9); __class__.__name__=='function'(len=8); new to extra199"
  kind: python_call_eq
  category: identity
  id_prefix: functsingledispatch199

  columns: [id, function, args, expected, description]
  rows:
    - [sd_name_eq,
       singledispatch.__name__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__name__.__eq__('singledispatch') == True — singledispatch is a Python function that transforms a plain function into a single-dispatch generic function; __name__ is 'singledispatch' (len=14); str.__eq__('singledispatch') returns True; verified with Python 3.14.3; new to extra199"]
    - [sd_name_len,
       singledispatch.__name__.__len__,
       [],
       14,
       "functools.singledispatch.__name__.__len__() == 14 — 'singledispatch' has 14 characters; str.__len__() returns 14; verified with Python 3.14.3; new to extra199"]
    - [sd_module_eq,
       singledispatch.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined at top level in functools.py; __module__ is 'functools' (len=9); str.__eq__('functools') returns True; verified with Python 3.14.3; new to extra199"]
    - [sd_module_len,
       singledispatch.__module__.__len__,
       [],
       9,
       "functools.singledispatch.__module__.__len__() == 9 — 'functools' has 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra199"]
    - [sd_class_name_eq,
       singledispatch.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.singledispatch.__class__.__name__.__eq__('function') == True — singledispatch is a regular Python function so its __class__ is the built-in function type; __class__.__name__ is 'function' (len=8); str.__eq__('function') returns True; verified with Python 3.14.3; new to extra199"]

# ---------------------------------------------------------------------------
# Table 2: functools.singledispatch qualname and singledispatchmethod identity
#
# functools.singledispatch.__qualname__         == 'singledispatch' (len=14)
# functools.singledispatchmethod.__name__       == 'singledispatchmethod' (len=20)
# functools.singledispatchmethod.__module__     == 'functools' (len=9)
#
# singledispatch is a top-level function so qualname equals name.
# singledispatchmethod is a class (descriptor) wrapping singledispatch
# for use inside a class body. New to extra199.
# ---------------------------------------------------------------------------

table functools_extra199.singledispatch_qualname_sdmethod_identity:
  description: "functools.singledispatch.__qualname__=='singledispatch'(len=14); singledispatchmethod.__name__=='singledispatchmethod'(len=20); singledispatchmethod.__module__=='functools'(len=9); new to extra199"
  kind: python_call_eq
  category: identity
  id_prefix: functsingledispatch199

  columns: [id, function, args, expected, description]
  rows:
    - [sd_qualname_eq,
       singledispatch.__qualname__.__eq__,
       ["singledispatch"],
       true,
       "functools.singledispatch.__qualname__.__eq__('singledispatch') == True — singledispatch is a top-level function so its qualname equals its name; __qualname__ is 'singledispatch' (len=14); str.__eq__('singledispatch') returns True; verified with Python 3.14.3; new to extra199"]
    - [sd_qualname_len,
       singledispatch.__qualname__.__len__,
       [],
       14,
       "functools.singledispatch.__qualname__.__len__() == 14 — 'singledispatch' has 14 characters; str.__len__() returns 14; verified with Python 3.14.3; new to extra199"]
    - [sdm_name_eq,
       singledispatchmethod.__name__.__eq__,
       ["singledispatchmethod"],
       true,
       "functools.singledispatchmethod.__name__.__eq__('singledispatchmethod') == True — singledispatchmethod is a descriptor class wrapping singledispatch for use inside a class body; __name__ is 'singledispatchmethod' (len=20); str.__eq__('singledispatchmethod') returns True; verified with Python 3.14.3; new to extra199"]
    - [sdm_name_len,
       singledispatchmethod.__name__.__len__,
       [],
       20,
       "functools.singledispatchmethod.__name__.__len__() == 20 — 'singledispatchmethod' has 20 characters; str.__len__() returns 20; verified with Python 3.14.3; new to extra199"]
    - [sdm_module_eq,
       singledispatchmethod.__module__.__eq__,
       ["functools"],
       true,
       "functools.singledispatchmethod.__module__.__eq__('functools') == True — singledispatchmethod is defined at top level in functools.py; __module__ is 'functools' (len=9); str.__eq__('functools') returns True; verified with Python 3.14.3; new to extra199"]

# ---------------------------------------------------------------------------
# Table 3: functools.singledispatchmethod base class and metaclass identity
#
# functools.singledispatchmethod.__bases__[0].__name__ == 'object' (len=6)
# functools.singledispatchmethod.__class__.__name__    == 'type' (len=4)
#
# singledispatchmethod inherits directly from object with no special
# superclass. As a class, its metaclass is the builtin type. New to extra199.
# ---------------------------------------------------------------------------

table functools_extra199.singledispatchmethod_base_class:
  description: "functools.singledispatchmethod base and metaclass: __bases__[0].__name__=='object'(len=6); __class__.__name__=='type'(len=4); new to extra199"
  kind: python_call_eq
  category: identity
  id_prefix: functsingledispatch199

  columns: [id, function, args, expected, description]
  rows:
    - [sdm_base_name_eq,
       "singledispatchmethod.__bases__.__getitem__(0).__name__.__eq__",
       ["object"],
       true,
       "functools.singledispatchmethod.__bases__[0].__name__.__eq__('object') == True — singledispatchmethod inherits directly from object with no special superclass; __bases__[0].__name__ is 'object' (len=6); str.__eq__('object') returns True; verified with Python 3.14.3; new to extra199"]
    - [sdm_base_name_len,
       "singledispatchmethod.__bases__.__getitem__(0).__name__.__len__",
       [],
       6,
       "functools.singledispatchmethod.__bases__[0].__name__.__len__() == 6 — 'object' has 6 characters: o-b-j-e-c-t; str.__len__() returns 6; verified with Python 3.14.3; new to extra199"]
    - [sdm_class_name_eq,
       singledispatchmethod.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.singledispatchmethod.__class__.__name__.__eq__('type') == True — singledispatchmethod is a class so its metaclass is the builtin type; __class__.__name__ is 'type' (len=4); str.__eq__('type') returns True; verified with Python 3.14.3; new to extra199"]
    - [sdm_class_name_len,
       singledispatchmethod.__class__.__name__.__len__,
       [],
       4,
       "functools.singledispatchmethod.__class__.__name__.__len__() == 4 — 'type' has 4 characters: t-y-p-e; str.__len__() returns 4; verified with Python 3.14.3; new to extra199"]
    - [sdm_module_len,
       singledispatchmethod.__module__.__len__,
       [],
       9,
       "functools.singledispatchmethod.__module__.__len__() == 9 — 'functools' has 9 characters: f-u-n-c-t-o-o-l-s; str.__len__() returns 9; verified with Python 3.14.3; new to extra199"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra199
# ---------------------------------------------------------------------------

invariant functools_extra199.singledispatch_name_eq:
  description: "functools.singledispatch.__name__.__eq__('singledispatch') == True — singledispatch is a Python function that transforms a plain function into a single-dispatch generic function; __name__ is 'singledispatch' (len=14); verified with Python 3.14.3; new to extra199"
  category: identity
  kind: python_call_eq
  function: singledispatch.__name__.__eq__
  args: ["singledispatch"]
  expected: true

invariant functools_extra199.singledispatch_module_eq:
  description: "functools.singledispatch.__module__.__eq__('functools') == True — singledispatch is defined at top level in functools.py; __module__ is 'functools' (len=9); verified with Python 3.14.3; new to extra199"
  category: identity
  kind: python_call_eq
  function: singledispatch.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra199.singledispatch_class_name_eq:
