spec: struct_extra1141
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks struct.__package__/__loader__ class attrs, struct.error.__weakref__ class attrs, struct.error qualname/module identity, struct.Struct class qualname/module identity, struct.pack/unpack/calcsize qualname and module identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table struct_extra1141.package_and_loader_attrs:
  description: "struct.__package__ and struct.__loader__ class identity"
  kind: python_call_eq
  category: package_loader_attrs
  id_prefix: st1141pl
  columns: [id, function, args, expected]
  rows:
    - [st1141pl001, struct.__package__.__eq__,                                  [""],                            true]
    - [st1141pl002, struct.__package__.__class__.__name__.__eq__,               ["str"],                         true]
    - [st1141pl003, struct.__package__.__class__.__qualname__.__eq__,           ["str"],                         true]
    - [st1141pl004, struct.__package__.__class__.__module__.__eq__,             ["builtins"],                    true]
    - [st1141pl005, struct.__loader__.__class__.__name__.__eq__,                ["SourceFileLoader"],             true]
    - [st1141pl006, struct.__loader__.__class__.__qualname__.__eq__,            ["SourceFileLoader"],             true]
    - [st1141pl007, struct.__loader__.__class__.__module__.__eq__,              ["_frozen_importlib_external"],   true]
    - [st1141pl008, struct.__package__.__class__.__name__.__class__.__name__.__eq__, ["str"],                    true]

table struct_extra1141.error_weakref_and_identity:
  description: "struct.error.__weakref__ class attrs and struct.error qualname/module identity"
  kind: python_call_eq
  category: error_weakref_identity
  id_prefix: st1141ew
  columns: [id, function, args, expected]
  rows:
    - [st1141ew001, struct.error.__weakref__.__class__.__name__.__eq__,         ["getset_descriptor"], true]
    - [st1141ew002, struct.error.__weakref__.__class__.__qualname__.__eq__,     ["getset_descriptor"], true]
    - [st1141ew003, struct.error.__weakref__.__class__.__module__.__eq__,       ["builtins"],           true]
    - [st1141ew004, struct.error.__weakref__.__qualname__.__eq__,               ["error.__weakref__"],  true]
    - [st1141ew005, struct.error.__qualname__.__eq__,                           ["error"],              true]
    - [st1141ew006, struct.error.__module__.__eq__,                             ["struct"],             true]
    - [st1141ew007, struct.error.__name__.__eq__,                               ["error"],              true]
    - [st1141ew008, struct.error.__qualname__.__class__.__name__.__eq__,        ["str"],                true]
    - [st1141ew009, struct.error.__module__.__class__.__name__.__eq__,          ["str"],                true]
    - [st1141ew010, struct.error.__weakref__.__class__.__name__.__class__.__name__.__eq__, ["str"],     true]

table struct_extra1141.struct_class_and_pack_unpack_qualnames:
  description: "struct.Struct class qualname/module identity and struct.pack/unpack/calcsize qualname and module"
  kind: python_call_eq
  category: struct_class_pack_qualnames
  id_prefix: st1141sq
  columns: [id, function, args, expected]
  rows:
    - [st1141sq001, struct.Struct.__qualname__.__eq__,                          ["Struct"],    true]
    - [st1141sq002, struct.Struct.__name__.__eq__,                              ["Struct"],    true]
    - [st1141sq003, struct.Struct.__module__.__eq__,                            ["_struct"],   true]
    - [st1141sq004, struct.Struct.__qualname__.__class__.__name__.__eq__,       ["str"],       true]
    - [st1141sq005, struct.Struct.__module__.__class__.__name__.__eq__,         ["str"],       true]
    - [st1141sq006, struct.pack.__qualname__.__eq__,                            ["pack"],      true]
    - [st1141sq007, struct.unpack.__qualname__.__eq__,                          ["unpack"],    true]
    - [st1141sq008, struct.calcsize.__qualname__.__eq__,                        ["calcsize"],  true]
    - [st1141sq009, struct.pack.__module__.__eq__,                              ["_struct"],   true]
    - [st1141sq010, struct.unpack.__module__.__eq__,                            ["_struct"],   true]
    - [st1141sq011, struct.calcsize.__module__.__eq__,                          ["_struct"],   true]
    - [st1141sq012, struct.calcsize.__class__.__name__.__eq__,                  ["builtin_function_or_method"], true]
    - [st1141sq013, struct.pack.__class__.__name__.__eq__,                      ["builtin_function_or_method"], true]
