spec: asyncio_extra223
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-queue.html — asyncio Queues documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/queues.py"
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Lib/asyncio/futures.py"
  notes:
    - "asyncio.Queue.__class__.__name__ == 'type' — Queue is an ordinary Python class; metaclass is 'type'; verified with Python 3.14.3."
    - "asyncio.Lock.__class__.__name__ == 'type' — Lock is an ordinary Python class; metaclass is 'type'; verified with Python 3.14.3."
    - "asyncio.Event.__class__.__name__ == 'type' — Event is an ordinary Python class; metaclass is 'type'; verified with Python 3.14.3."
    - "asyncio.Semaphore.__class__.__name__ == 'type' — Semaphore is an ordinary Python class; metaclass is 'type'; verified with Python 3.14.3."
    - "asyncio.Task.__class__.__name__ == 'type' — Task is an ordinary Python class; metaclass is 'type'; verified with Python 3.14.3."
    - "asyncio.Future.__class__.__name__ == 'type' — Future is an ordinary Python class; metaclass is 'type'; verified with Python 3.14.3."
    - "asyncio.Queue.__mro__.__len__() == 3 — MRO is [Queue, _LoopBoundMixin, object]; three-element tuple; verified with Python 3.14.3."
    - "asyncio.Lock.__mro__.__len__() == 4 — MRO is [Lock, _ContextManagerMixin, _LoopBoundMixin, object]; four-element tuple; verified with Python 3.14.3."
    - "asyncio.Task.__mro__.__len__() == 3 — MRO is [Task, Future, object]; three-element tuple; verified with Python 3.14.3."
    - "asyncio.Future.__mro__.__len__() == 2 — MRO is [Future, object]; two-element tuple; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio class __class__.__name__ type checks — extra223 namespace
#
# Queue, Lock, Event, Semaphore, Task, Future are all ordinary Python classes
# whose metaclass is the built-in 'type'.
# ---------------------------------------------------------------------------

table asyncio_extra223.class_type_checks:
  description: "asyncio class __class__.__name__.__eq__('type') checks in extra223 namespace"
  kind: python_call_eq
  category: class_types
  id_prefix: aio223classtypes

  columns: [id, function, args, expected, description]
  rows:
    - [queue_class_type,     Queue.__class__.__name__.__eq__,     ["type"], true, "asyncio.Queue.__class__.__name__ == 'type'; Queue is an ordinary Python class with metaclass type; verified with Python 3.14.3"]
    - [lock_class_type,      Lock.__class__.__name__.__eq__,      ["type"], true, "asyncio.Lock.__class__.__name__ == 'type'; Lock is an ordinary Python class with metaclass type; verified with Python 3.14.3"]
    - [event_class_type,     Event.__class__.__name__.__eq__,     ["type"], true, "asyncio.Event.__class__.__name__ == 'type'; Event is an ordinary Python class with metaclass type; verified with Python 3.14.3"]
    - [semaphore_class_type, Semaphore.__class__.__name__.__eq__, ["type"], true, "asyncio.Semaphore.__class__.__name__ == 'type'; Semaphore is an ordinary Python class with metaclass type; verified with Python 3.14.3"]
    - [task_class_type,      Task.__class__.__name__.__eq__,      ["type"], true, "asyncio.Task.__class__.__name__ == 'type'; Task is an ordinary Python class with metaclass type; verified with Python 3.14.3"]
    - [future_class_type,    Future.__class__.__name__.__eq__,    ["type"], true, "asyncio.Future.__class__.__name__ == 'type'; Future is an ordinary Python class with metaclass type; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio class MRO length checks — extra223 namespace
#
# Queue MRO: [Queue, _LoopBoundMixin, object] — len 3
# Lock MRO:  [Lock, _ContextManagerMixin, _LoopBoundMixin, object] — len 4
# Task MRO:  [Task, Future, object] — len 3
# Future MRO: [Future, object] — len 2
# ---------------------------------------------------------------------------

table asyncio_extra223.class_mro_lengths:
  description: "asyncio class __mro__.__len__() checks in extra223 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: aio223mrolens

  columns: [id, function, args, expected, description]
  rows:
    - [queue_mro_len,  Queue.__mro__.__len__,  [], 3, "asyncio.Queue.__mro__.__len__() == 3 — MRO is [Queue, _LoopBoundMixin, object]; verified with Python 3.14.3"]
    - [lock_mro_len,   Lock.__mro__.__len__,   [], 4, "asyncio.Lock.__mro__.__len__() == 4 — MRO is [Lock, _ContextManagerMixin, _LoopBoundMixin, object]; verified with Python 3.14.3"]
    - [task_mro_len,   Task.__mro__.__len__,   [], 3, "asyncio.Task.__mro__.__len__() == 3 — MRO is [Task, Future, object]; verified with Python 3.14.3"]
    - [future_mro_len, Future.__mro__.__len__, [], 2, "asyncio.Future.__mro__.__len__() == 2 — MRO is [Future, object]; verified with Python 3.14.3"]
