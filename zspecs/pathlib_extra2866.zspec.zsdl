spec: pp2866
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "zspecs/pathlib_extra2851.zspec.zsdl — wave 637 predecessor (covered __rlshift__, __rrshift__, __rpow__)"
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_abc.py"
  notes:
    - "Wave 638 theme: __rand__, __ror__, __rxor__ dict-presence checks (reflected bitwise AND, OR, XOR operators)."
    - "pathlib classes represent filesystem paths — they do not define any bitwise operators, reflected or otherwise."
    - "pathlib.PurePath, PurePosixPath, PureWindowsPath, and Path do NOT define __rand__, __ror__, or __rxor__."
    - "The path division operator (/) is implemented via __truediv__/__rtruediv__, NOT via bitwise operators."
    - "Absence is consistent across all four pathlib classes tested — path objects have no bitwise semantics."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table: __rand__ dict-presence — absent from all pathlib path classes
# ---------------------------------------------------------------------------

table pp2866.rand:
  description: "__rand__ is absent from all pathlib class __dict__s — path objects are not bitwise-AND operands"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pp2866

  columns: [id, function, args, expected]
  rows:
    - ["pp2866001", "pathlib.PurePath.__dict__.__contains__",        ["__rand__"], false]
    - ["pp2866002", "pathlib.PurePosixPath.__dict__.__contains__",   ["__rand__"], false]
    - ["pp2866003", "pathlib.PureWindowsPath.__dict__.__contains__", ["__rand__"], false]
    - ["pp2866004", "pathlib.Path.__dict__.__contains__",            ["__rand__"], false]
    - ["pp2866005", "pathlib.PurePath.__dict__.__contains__",        ["__and__"],  false]
    - ["pp2866006", "pathlib.Path.__dict__.__contains__",            ["__and__"],  false]

