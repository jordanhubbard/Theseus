spec: struct_extra347
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "struct.error.__name__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('i') == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('d') == 8. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('c') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.calcsize('?') == 1. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.error is defined in the Python struct wrapper (Lib/struct.py), not the C extension. Its __module__ is 'struct' (not '_struct')."
    - "Note: struct.error is a direct subclass of Exception — it is not a ValueError or TypeError subclass."
    - "Note: struct.calcsize('i') returns 4 on all modern 32-bit and 64-bit platforms (native int size)."
    - "Note: struct.calcsize('d') returns 8 on all platforms (IEEE 754 double-precision float is always 8 bytes)."
    - "Note: struct.calcsize('c') returns 1 on all platforms (a C char is always 1 byte by definition)."
    - "Note: struct.calcsize('?') returns 1 on all platforms (a C _Bool is always 1 byte in C99+)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error')
# struct.error.__module__.__eq__('struct')
# struct.error.__bases__[0].__name__.__eq__('Exception')
#
# Wave 347 theme: struct.error exception class identity.
#
# struct.error is the exception class raised by struct.pack, struct.unpack,
# and struct.calcsize when the format string or value is invalid. Its __name__
# is 'error' (lowercase — an unconventional convention inherited from C).
# Its __module__ is 'struct' (defined in the Python wrapper, not the _struct
# C extension). Its base class is Exception — a direct subclass with no
# intermediate standard exception class between it and Exception.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra347.struct_error_class_identity:
  description: "error.__name__.__eq__('error')==True / error.__module__.__eq__('struct')==True / error.__bases__[0].__name__.__eq__('Exception')==True — struct.error __name__ is lowercase 'error' (C convention); __module__ is 'struct' (Python wrapper, not _struct C extension); base class is Exception (direct subclass, not ValueError/TypeError); first structerrid347 anchor for error class identity"
  kind: python_call_eq
  category: error_class_identity
  id_prefix: structerrid347

  columns: [id, function, args, expected, description]
  rows:
    - [error_name,     "error.__name__.__eq__",              ["error"],     true, "struct.error.__name__ is 'error' — lowercase unconventional name inherited from C implementation"]
    - [error_module,   "error.__module__.__eq__",            ["struct"],    true, "struct.error.__module__ is 'struct' — defined in Python wrapper (Lib/struct.py), not _struct C extension"]
    - [error_base,     "error.__bases__[0].__name__.__eq__", ["Exception"], true, "struct.error.__bases__[0].__name__ is 'Exception' — direct subclass; not ValueError/TypeError"]

# ---------------------------------------------------------------------------
# struct.calcsize('i') == 4
# struct.calcsize('d') == 8
# struct.calcsize('c') == 1
# struct.calcsize('?') == 1
#
# Wave 347 theme: struct.calcsize for native format characters.
#
# struct.calcsize returns the number of bytes needed to pack a value using
# the given format character. Without a byte-order prefix, native sizes are
# used. 'i' (int) is 4 bytes on all modern platforms. 'd' (double) is 8
# bytes (IEEE 754 double-precision, universal). 'c' (char) is always 1 byte
# by C definition. '?' (bool/_Bool) is 1 byte per C99. These values are
# stable across platforms because they reflect C ABI sizes for standard types.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra347.calcsize_native_formats:
  description: "calcsize('i')==4 / calcsize('d')==8 / calcsize('c')==1 / calcsize('?')==1 — native format sizes: 'i' int is 4 bytes (modern platforms), 'd' double is 8 bytes (IEEE 754 universal), 'c' char is 1 byte (C definition), '?' bool is 1 byte (C99 _Bool); all stable cross-platform; first structerrid347 anchor for calcsize native format sizes"
  kind: python_call_eq
  category: calcsize
  id_prefix: structerrid347

  columns: [id, function, args, expected, description]
  rows:
    - [calcsize_int,    calcsize, ["i"], 4, "struct.calcsize('i') == 4 — native int is 4 bytes on all modern 32-bit and 64-bit platforms"]
    - [calcsize_double, calcsize, ["d"], 8, "struct.calcsize('d') == 8 — double is 8 bytes (IEEE 754 double-precision, universal across all platforms)"]
    - [calcsize_char,   calcsize, ["c"], 1, "struct.calcsize('c') == 1 — char is 1 byte by C definition (always, on all platforms)"]
    - [calcsize_bool,   calcsize, ["?"], 1, "struct.calcsize('?') == 1 — bool/_Bool is 1 byte per C99 standard"]

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error') — standalone
#
# struct.error.__name__ is 'error'. The struct module uses a lowercase
# exception class name — an unconventional choice that reflects the original
# C implementation convention (similar to how socket.error and select.error
# historically used lowercase names). In Python 3, socket.error became an
# alias for OSError, but struct.error remained its own distinct class.
# Callers must use `except struct.error` explicitly.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra347.error_name_is_error:
  description: "struct.error.__name__.__eq__('error') == True — struct.error uses lowercase 'error' (unconventional for exception classes; inherited from C implementation convention); distinct from socket.error (now an OSError alias); callers use 'except struct.error'; first standalone for error.__name__ under structerrid347"
  category: error_class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__module__.__eq__('struct') — standalone
#
# struct.error.__module__ is 'struct'. Unlike struct.pack and struct.Struct
# which are defined in the _struct C extension (their __module__ is '_struct'),
# struct.error is defined in the Python-level struct wrapper (Lib/struct.py).
# This is confirmed by its __module__ being 'struct' (not '_struct'). The
# separation exists because exception classes are easier to define in Python
# than in C, while performance-critical functions like pack/unpack are in C.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra347.error_module_is_struct:
  description: "struct.error.__module__.__eq__('struct') == True — struct.error is defined in the Python wrapper (Lib/struct.py), __module__ is 'struct' (not '_struct'); contrast with pack.__module__=='_struct' (C extension); exception defined in Python while performance-critical functions are in C; first standalone for error.__module__ under structerrid347"
  category: error_class_identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.calcsize('i') == 4 — standalone
#
# struct.calcsize('i') is 4. The 'i' format character represents a native
# C int. On all modern 32-bit and 64-bit platforms (x86, x86-64, ARM,
# ARM64), a C int is 4 bytes. The C standard guarantees sizeof(int) >= 2,
# but in practice it is universally 4 on all platforms Python supports.
# calcsize uses the native byte order and alignment when no prefix is given.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra347.calcsize_i_is_4:
  description: "struct.calcsize('i') == 4 — 'i' format is native C int; 4 bytes on all modern platforms (x86, x86-64, ARM, ARM64); C standard guarantees >=2 but universally 4; native byte order used without prefix; first standalone for calcsize('i') under structerrid347"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["i"]
  expected: 4

# ---------------------------------------------------------------------------
# struct.calcsize('d') == 8 — standalone
#
# struct.calcsize('d') is 8. The 'd' format character represents a C double
# (IEEE 754 double-precision floating-point). IEEE 754 double-precision is
# universally 8 bytes (64 bits) on all platforms and architectures. Unlike
# 'f' (float, 4 bytes), 'd' always yields 8. This makes 'd' the safest
# format for floating-point values when precision and portability matter.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra347.calcsize_d_is_8:
  description: "struct.calcsize('d') == 8 — 'd' format is C double (IEEE 754 double-precision); universally 8 bytes (64 bits) on all architectures; contrast with 'f' (float, 4 bytes); most precise and portable floating-point struct format; first standalone for calcsize('d') under structerrid347"
  category: calcsize
  kind: python_call_eq
  function: calcsize
  args: ["d"]
  expected: 8
