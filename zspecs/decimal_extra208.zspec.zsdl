spec: decimal_extra208
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers decimal module constants, context, and Decimal class metadata"
    - "decimal_extra207.zspec.zsdl — covers decimal rounding constant class names and string values"
  notes:
    - "decimal.Decimal.__qualname__ == 'Decimal'; confirmed Python 3.14.3 macOS."
    - "decimal.Context.__qualname__ == 'Context'; confirmed Python 3.14.3 macOS."
    - "decimal.DecimalException.__qualname__ == 'DecimalException'; confirmed Python 3.14.3 macOS."
    - "decimal.InvalidOperation.__qualname__ == 'InvalidOperation'; confirmed Python 3.14.3 macOS."
    - "decimal.DivisionByZero.__qualname__ == 'DivisionByZero'; confirmed Python 3.14.3 macOS."
    - "decimal.Overflow.__qualname__ == 'Overflow'; confirmed Python 3.14.3 macOS."
    - "__qualname__ is a plain str attribute on all decimal classes; __qualname__.__class__.__name__ == 'str'."
    - "For top-level (non-nested) classes, __qualname__ equals __name__; both are 'Decimal', 'Context', etc."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __qualname__ equality for decimal core classes
# Decimal and Context __qualname__ attribute checks
# ---------------------------------------------------------------------------

table decimal_extra208.core_classes_qualname:
  description: "decimal.Decimal and decimal.Context __qualname__ attributes equal their class names"
  kind: python_call_eq
  category: class_metadata
  id_prefix: decimalqualname208

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_qualname,          decimal.Decimal.__qualname__.__eq__,  ["Decimal"],  true,   "decimal.Decimal.__qualname__.__eq__('Decimal') == True; Decimal is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [context_qualname,          decimal.Context.__qualname__.__eq__,  ["Context"],  true,   "decimal.Context.__qualname__.__eq__('Context') == True; Context is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [decimal_qualname_false,    decimal.Decimal.__qualname__.__eq__,  ["decimal"],  false,  "decimal.Decimal.__qualname__.__eq__('decimal') == False; qualname is case-sensitive; confirmed Python 3.14.3 macOS"]
    - [decimal_qualname_dotted,   decimal.Decimal.__qualname__.__eq__,  ["decimal.Decimal"], false, "decimal.Decimal.__qualname__.__eq__('decimal.Decimal') == False; qualname does not include the module prefix; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: __qualname__ equality for decimal exception hierarchy classes
# DecimalException, InvalidOperation, DivisionByZero, Overflow __qualname__ checks
# ---------------------------------------------------------------------------

table decimal_extra208.exception_classes_qualname:
  description: "decimal exception hierarchy classes __qualname__ attributes equal their class names"
  kind: python_call_eq
  category: class_metadata
  id_prefix: decimalqualname208

  columns: [id, function, args, expected, description]
  rows:
    - [decimalexception_qualname,  decimal.DecimalException.__qualname__.__eq__,  ["DecimalException"],  true,  "decimal.DecimalException.__qualname__.__eq__('DecimalException') == True; DecimalException is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [invalidoperation_qualname,  decimal.InvalidOperation.__qualname__.__eq__,  ["InvalidOperation"],  true,  "decimal.InvalidOperation.__qualname__.__eq__('InvalidOperation') == True; InvalidOperation is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [divisionbyzero_qualname,    decimal.DivisionByZero.__qualname__.__eq__,    ["DivisionByZero"],    true,  "decimal.DivisionByZero.__qualname__.__eq__('DivisionByZero') == True; DivisionByZero is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]
    - [overflow_qualname,          decimal.Overflow.__qualname__.__eq__,          ["Overflow"],          true,  "decimal.Overflow.__qualname__.__eq__('Overflow') == True; Overflow is a top-level class so qualname equals name; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: __qualname__ is a str — type checks for decimal classes
# __qualname__ on all decimal classes is a plain str object
# ---------------------------------------------------------------------------

table decimal_extra208.qualname_type_checks:
  description: "decimal class __qualname__ attributes are plain str objects"
  kind: python_call_eq
  category: class_metadata
  id_prefix: decimalqualname208

  columns: [id, function, args, expected, description]
  rows:
    - [decimal_qualname_type,          decimal.Decimal.__qualname__.__class__.__name__,          [],  "str",  "decimal.Decimal.__qualname__.__class__.__name__ == 'str'; __qualname__ is a plain str on Decimal; confirmed Python 3.14.3 macOS"]
    - [context_qualname_type,          decimal.Context.__qualname__.__class__.__name__,          [],  "str",  "decimal.Context.__qualname__.__class__.__name__ == 'str'; __qualname__ is a plain str on Context; confirmed Python 3.14.3 macOS"]
    - [invalidoperation_qualname_type, decimal.InvalidOperation.__qualname__.__class__.__name__,  [],  "str",  "decimal.InvalidOperation.__qualname__.__class__.__name__ == 'str'; __qualname__ is a plain str on InvalidOperation; confirmed Python 3.14.3 macOS"]
    - [overflow_qualname_type,         decimal.Overflow.__qualname__.__class__.__name__,         [],  "str",  "decimal.Overflow.__qualname__.__class__.__name__ == 'str'; __qualname__ is a plain str on Overflow; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra208.decimal_qualname:
  description: "decimal.Decimal.__qualname__.__eq__('Decimal') == True — Decimal is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: decimal.Decimal.__qualname__.__eq__
  args: ["Decimal"]
  expected: true

invariant decimal_extra208.context_qualname:
  description: "decimal.Context.__qualname__.__eq__('Context') == True — Context is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: decimal.Context.__qualname__.__eq__
  args: ["Context"]
  expected: true

invariant decimal_extra208.decimalexception_qualname:
  description: "decimal.DecimalException.__qualname__.__eq__('DecimalException') == True — DecimalException is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: decimal.DecimalException.__qualname__.__eq__
  args: ["DecimalException"]
  expected: true

invariant decimal_extra208.invalidoperation_qualname:
  description: "decimal.InvalidOperation.__qualname__.__eq__('InvalidOperation') == True — InvalidOperation is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: decimal.InvalidOperation.__qualname__.__eq__
  args: ["InvalidOperation"]
  expected: true

invariant decimal_extra208.divisionbyzero_qualname:
  description: "decimal.DivisionByZero.__qualname__.__eq__('DivisionByZero') == True — DivisionByZero is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: decimal.DivisionByZero.__qualname__.__eq__
  args: ["DivisionByZero"]
  expected: true

invariant decimal_extra208.overflow_qualname:
  description: "decimal.Overflow.__qualname__.__eq__('Overflow') == True — Overflow is a top-level class so __qualname__ equals __name__; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: decimal.Overflow.__qualname__.__eq__
  args: ["Overflow"]
  expected: true

invariant decimal_extra208.decimal_qualname_type:
  description: "decimal.Decimal.__qualname__.__class__.__name__ == 'str' — __qualname__ is a plain str attribute on Decimal; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: decimal.Decimal.__qualname__.__class__.__name__
  args: []
  expected: "str"

invariant decimal_extra208.decimal_qualname_not_dotted:
  description: "decimal.Decimal.__qualname__.__eq__('decimal.Decimal') == False — __qualname__ does not include the module prefix for top-level classes; confirmed Python 3.14.3 macOS"
  category: class_metadata
  kind: python_call_eq
  function: decimal.Decimal.__qualname__.__eq__
  args: ["decimal.Decimal"]
  expected: false
