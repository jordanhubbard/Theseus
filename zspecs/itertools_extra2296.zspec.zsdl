spec: itertools_extra2296
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 600 (_extra2296): __module__ and __qualname__ attribute value checks."
    - "Subjects: itertools.chain, itertools.cycle, itertools.count, itertools.combinations, itertools.permutations, itertools.product, itertools.islice, itertools.repeat, itertools.groupby, itertools.compress, itertools.takewhile, itertools.dropwhile, itertools.starmap, itertools.zip_longest, itertools.accumulate."
    - "All itertools types are C extension types; every subject reports __module__ == 'itertools'."
    - "__qualname__ matches the unqualified class name for every subject (no nesting)."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

