spec: re_extra1006
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module error, Pattern, and Match documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks re.error, re.Pattern, and re.Match method qualnames"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table re_extra1006.re_error_qualnames:
  description: "re.error method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: re1006e
  columns: [id, function, args, expected]
  rows:
    - [re1006e001, re.error.__init__.__qualname__.__eq__,          ["error.__init__"],          true]
    - [re1006e002, re.error.__str__.__qualname__.__eq__,           ["error.__str__"],           true]
    - [re1006e003, re.error.__repr__.__qualname__.__eq__,          ["error.__repr__"],          true]
    - [re1006e004, re.error.with_traceback.__qualname__.__eq__,    ["BaseException.with_traceback"], true]
    - [re1006e005, re.error.__class__.__name__.__eq__,             ["type"],                    true]
    - [re1006e006, re.error.__module__.__eq__,                     ["re"],                      true]

table re_extra1006.re_pattern_qualnames:
  description: "re.Pattern method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: re1006p
  columns: [id, function, args, expected]
  rows:
    - [re1006p001, re.Pattern.__init__.__qualname__.__eq__,   ["Pattern.__init__"],   true]
    - [re1006p002, re.Pattern.__repr__.__qualname__.__eq__,   ["Pattern.__repr__"],   true]
    - [re1006p003, re.Pattern.__hash__.__qualname__.__eq__,   ["Pattern.__hash__"],   true]
    - [re1006p004, re.Pattern.__eq__.__qualname__.__eq__,     ["Pattern.__eq__"],     true]
    - [re1006p005, re.Pattern.match.__qualname__.__eq__,      ["Pattern.match"],      true]
    - [re1006p006, re.Pattern.search.__qualname__.__eq__,     ["Pattern.search"],     true]

table re_extra1006.re_match_qualnames:
  description: "re.Match method __qualname__ identity"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: re1006m
  columns: [id, function, args, expected]
  rows:
    - [re1006m001, re.Match.__init__.__qualname__.__eq__,     ["Match.__init__"],     true]
    - [re1006m002, re.Match.__repr__.__qualname__.__eq__,     ["Match.__repr__"],     true]
    - [re1006m003, re.Match.group.__qualname__.__eq__,        ["Match.group"],        true]
    - [re1006m004, re.Match.groups.__qualname__.__eq__,       ["Match.groups"],       true]
    - [re1006m005, re.Match.start.__qualname__.__eq__,        ["Match.start"],        true]
    - [re1006m006, re.Match.end.__qualname__.__eq__,          ["Match.end"],          true]
