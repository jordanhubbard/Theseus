spec: ansi_regex
version: ">=6.0.0"
backend: node(ansi-regex)

docs: https://github.com/chalk/ansi-regex#readme

provenance:
  derived_from:
    - "ansi-regex README — https://github.com/chalk/ansi-regex#readme"
    - "ECMA-48 Control Functions for Coded Character Sets"
    - "Test vectors verified with ansi-regex via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "ansi-regex source"
  notes:
    - "Supplies a RegExp that matches ANSI escape sequences — the core primitive used by chalk, strip-ansi, and most CLI styling tools."
    - "Install: npm install ansi-regex"
    - "v6 is ESM with a CJS shim; default export is the regex factory."
    - "Pattern: const re = require('ansi-regex').default(); re.test('\\x1b[31mtext\\x1b[0m')"
    - "{onlyFirst: true} returns a regex without /g — only matches the first occurrence."
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Returns a RegExp; pure function with no side effects."
  stderr: "null"
  stickiness: "N/A — each call returns a fresh regex."
  codes: {}

# default().test(input)
table ansi_regex.test:
  kind: node_chain_eq
  category: test
  entry: named
  function: default
  entry_args: []
  id_prefix: test

  columns: [id, chain, expected]
  rows:
    - [colored_text,
       [{method: test, args: ["\u001b[31mhi\u001b[0m"]}],
       true]

    - [bold_text,
       [{method: test, args: ["\u001b[1mhi\u001b[22m"]}],
       true]

    - [reset_only,
       [{method: test, args: ["\u001b[0m"]}],
       true]

    - [plain_no_match,
       [{method: test, args: ["plain text"]}],
       false]

    - [empty_no_match,
       [{method: test, args: [""]}],
       false]

    - [escape_in_middle,
       [{method: test, args: ["before \u001b[31mred\u001b[0m after"]}],
       true]

# {onlyFirst: true} — match without /g
invariant ansi_regex.only_first_returns_first_match:
  description: "{onlyFirst: true} returns a regex without /g flag"
  category: only_first
  kind: node_chain_eq
  entry: named
  function: default
  entry_args: [{onlyFirst: true}]
  chain:
    - {get: global}
  expected: false

invariant ansi_regex.default_is_global:
  description: "Default ansi-regex regex has global flag set"
  category: only_first
  kind: node_chain_eq
  entry: named
  function: default
  entry_args: []
  chain:
    - {get: global}
  expected: true

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:32:35Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
  notes: Synthesis succeeded in 1 iteration(s). 8 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
