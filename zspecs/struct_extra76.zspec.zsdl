spec: struct_extra76
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra75.zspec.zsdl — covers struct.error/__name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__()/__bases__.__len__() and pack/unpack __qualname__.__eq__ (table + invariants)."
    - "struct_extra74.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack __qualname__.__len__() / module-level pack/unpack/pack_into/unpack_from/iter_unpack/calcsize __qualname__.__len__() (table + invariants)."
    - "struct_extra73.zspec.zsdl — covers Struct.__repr__/__class__/__name__ / Struct.format/__qualname__.__len__() / Struct.__bases__.__len__() / calcsize+pack_into qualname cross-check (table + invariants)."
    - "struct_extra71.zspec.zsdl — covers Struct/__dict__.__contains__('__doc__') / pack/unpack/calcsize/pack_into/unpack_from/iter_unpack/__module__=='_struct' (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec extends struct through struct_extra75; it does NOT duplicate invariants present in those files."
    - "Wave 247 theme: struct.Struct class __dict__ key membership."
    - "struct.Struct.__dict__.__contains__('pack') == True — 'pack' is a key in Struct.__dict__. No prior struct spec checks Struct.__dict__.__contains__('pack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('unpack') == True — 'unpack' is a key. No prior struct spec checks Struct.__dict__.__contains__('unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('pack_into') == True — 'pack_into' is a key. No prior struct spec checks Struct.__dict__.__contains__('pack_into'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('unpack_from') == True — 'unpack_from' is a key. No prior struct spec checks Struct.__dict__.__contains__('unpack_from'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('iter_unpack') == True — 'iter_unpack' is a key. No prior struct spec checks Struct.__dict__.__contains__('iter_unpack'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('format') == True — 'format' is a key. No prior struct spec checks Struct.__dict__.__contains__('format'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('size') == True — 'size' is a key. No prior struct spec checks Struct.__dict__.__contains__('size'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('__init__') == True — '__init__' is a key. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('__new__') == True — '__new__' is a key. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__contains__('__repr__') == True — '__repr__' is a key. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__dict__.__class__.__name__ == 'mappingproxy' — __dict__ is a mappingproxy. No prior struct spec checks Struct.__dict__.__class__.__name__ (struct_extra71 checks __contains__('__doc__') only). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__name__ == 'Struct' — Struct class name. No prior struct spec checks Struct.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__ == 'Struct' — Struct class qualname. No prior struct spec checks Struct.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct' — Struct is a C extension type from _struct. No prior struct spec checks Struct.__module__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__ for pack/unpack/pack_into/unpack_from
#
# Wave 247 theme: Struct.__dict__ key membership for core methods.
#
# pack/unpack/pack_into/unpack_from are all keys in Struct.__dict__.
# No prior struct spec checks Struct.__dict__.__contains__ for these keys
# (struct_extra71 covers only '__doc__'). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra76.struct_dict_pack_unpack:
  description: "struct.Struct/__dict__/__contains__('pack')==True / __contains__('unpack')==True / __contains__('pack_into')==True / __contains__('unpack_from')==True — pack/unpack/pack_into/unpack_from are all present in Struct.__dict__; no prior struct spec checks these __contains__ calls (struct_extra71 only covers '__doc__'); first __dict__ membership anchor for Struct methods pack/unpack/pack_into/unpack_from"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra76

  columns: [id, function, args, expected]
  rows:
    - [struct_dict_has_pack,        "Struct.__dict__.__contains__", ["pack"],        true]
    - [struct_dict_has_unpack,      "Struct.__dict__.__contains__", ["unpack"],      true]
    - [struct_dict_has_pack_into,   "Struct.__dict__.__contains__", ["pack_into"],   true]
    - [struct_dict_has_unpack_from, "Struct.__dict__.__contains__", ["unpack_from"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__ for iter_unpack/format/size
#
# Wave 247 theme: Struct.__dict__ key membership for iter_unpack, format, size.
#
# iter_unpack/format/size are all keys in Struct.__dict__.
# No prior struct spec checks these __contains__ calls.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra76.struct_dict_iter_format_size:
  description: "struct.Struct/__dict__/__contains__('iter_unpack')==True / __contains__('format')==True / __contains__('size')==True — iter_unpack/format/size are present in Struct.__dict__; no prior struct spec checks these __contains__ calls; first __dict__ membership anchor for Struct iter_unpack/format/size"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra76

  columns: [id, function, args, expected]
  rows:
    - [struct_dict_has_iter_unpack, "Struct.__dict__.__contains__", ["iter_unpack"], true]
    - [struct_dict_has_format,      "Struct.__dict__.__contains__", ["format"],      true]
    - [struct_dict_has_size,        "Struct.__dict__.__contains__", ["size"],        true]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__ for __init__/__new__/__repr__
# struct.Struct.__dict__.__class__.__name__
#
# Wave 247 theme: Struct.__dict__ special method membership and proxy class name.
#
# __init__/__new__/__repr__ are keys in Struct.__dict__. Struct.__dict__.__class__.__name__
# is 'mappingproxy'. No prior struct spec checks any of these.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra76.struct_dict_special_methods_class:
  description: "struct.Struct/__dict__/__contains__('__init__')==True / __contains__('__new__')==True / __contains__('__repr__')==True / __dict__/__class__/__name__.__eq__('mappingproxy')==True — __init__/__new__/__repr__ are in Struct.__dict__; __dict__ is a mappingproxy; no prior struct spec checks these __contains__ calls or __dict__.__class__.__name__; first special method membership and proxy class name anchor for Struct.__dict__"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra76

  columns: [id, function, args, expected]
  rows:
    - [struct_dict_has_init,        "Struct.__dict__.__contains__",           ["__init__"], true]
    - [struct_dict_has_new,         "Struct.__dict__.__contains__",           ["__new__"],  true]
    - [struct_dict_has_repr,        "Struct.__dict__.__contains__",           ["__repr__"], true]
    - [struct_dict_class_mappingproxy, Struct.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__name__ / __qualname__ / __module__
#
# Wave 247 theme: Struct class name/qualname/module identity.
#
# Struct.__name__ == 'Struct', __qualname__ == 'Struct', __module__ == '_struct'.
# No prior struct spec checks Struct.__name__, __qualname__, or __module__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra76.struct_class_name_qualname_module:
  description: "struct.Struct/__name__.__eq__('Struct')==True / Struct/__qualname__.__eq__('Struct')==True / Struct/__module__.__eq__('_struct')==True — Struct is a C extension type from _struct; __name__/__qualname__/__module__ are all simple strings; no prior struct spec checks Struct.__name__/__qualname__/__module__; first name/qualname/module anchor for struct.Struct"
  kind: python_call_eq
  category: class_attrs
  id_prefix: structextra76

  columns: [id, function, args, expected]
  rows:
    - [struct_name_eq_struct,     Struct.__name__.__eq__,     ["Struct"],  true]
    - [struct_qualname_eq_struct, Struct.__qualname__.__eq__,  ["Struct"],  true]
    - [struct_module_eq_struct,   Struct.__module__.__eq__,    ["_struct"], true]

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('pack') — standalone
#
# 'pack' is in Struct.__dict__. No prior struct spec checks this __contains__ call.
# First __dict__.__contains__('pack') standalone for struct.Struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra76.struct_dict_has_pack:
  description: "struct.Struct.__dict__.__contains__('pack') == True — 'pack' is a method present in Struct.__dict__; no prior struct spec checks Struct.__dict__.__contains__('pack'); first __dict__ membership standalone for 'pack'"
  category: class_attrs
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__contains__('format') — standalone
#
# 'format' is in Struct.__dict__. No prior struct spec checks this __contains__ call.
# First __dict__.__contains__('format') standalone for struct.Struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra76.struct_dict_has_format:
  description: "struct.Struct.__dict__.__contains__('format') == True — 'format' is an attribute present in Struct.__dict__; no prior struct spec checks Struct.__dict__.__contains__('format'); first __dict__ membership standalone for 'format'"
  category: class_attrs
  kind: python_call_eq
  function: "Struct.__dict__.__contains__"
  args: ["format"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__dict__.__class__.__name__.__eq__('mappingproxy') — standalone
#
# Struct.__dict__.__class__.__name__ == 'mappingproxy'. No prior struct spec checks this.
# First __dict__.__class__.__name__ standalone for struct.Struct.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra76.struct_dict_class_mappingproxy:
  description: "struct.Struct.__dict__.__class__.__name__.__eq__('mappingproxy') == True — Struct.__dict__ is a mappingproxy object; no prior struct spec checks Struct.__dict__.__class__.__name__; first __dict__.__class__.__name__ standalone for struct.Struct"
  category: class_attrs
  kind: python_call_eq
  function: Struct.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__name__.__eq__('Struct') — standalone
#
# Struct.__name__ is 'Struct'. No prior struct spec checks Struct.__name__.
# First __name__ standalone for struct.Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra76.struct_name_struct:
  description: "struct.Struct.__name__.__eq__('Struct') == True — Struct is a C extension type; its __name__ is 'Struct'; no prior struct spec checks Struct.__name__; first __name__ standalone for struct.Struct"
  category: class_attrs
  kind: python_call_eq
  function: Struct.__name__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__module__.__eq__('_struct') — standalone
#
# Struct.__module__ is '_struct'. No prior struct spec checks Struct.__module__.
# First __module__ standalone for struct.Struct. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra76.struct_module_struct:
  description: "struct.Struct.__module__.__eq__('_struct') == True — Struct is defined in the _struct C extension; its __module__ is '_struct'; no prior struct spec checks Struct.__module__; first __module__ standalone for struct.Struct"
  category: class_attrs
  kind: python_call_eq
  function: Struct.__module__.__eq__
  args: ["_struct"]
  expected: true
