spec: mmap
version: ">=3.0"
backend: python_module(mmap)

docs: https://docs.python.org/3/library/mmap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mmap.html — Python mmap module documentation"
    - "POSIX.1-2017 — mmap(2) and related system calls"
    - "Test vectors verified by running Python 3.14.3 mmap module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/mmapmodule.c"
  notes:
    - "mmap.mmap is the class used to create memory-mapped file objects; instantiation requires a valid file descriptor and is not exercised in this spec."
    - "mmap.error is an alias for OSError on Python 3 (since 3.3)."
    - "ACCESS_READ=1, ACCESS_WRITE=2, ACCESS_COPY=3 — access mode constants are defined on all platforms."
    - "PAGESIZE and ALLOCATIONGRANULARITY are positive integers whose exact values are OS-dependent."
    - "PROT_READ, PROT_WRITE are POSIX-only (macOS, Linux); not present on Windows."
    - "MAP_SHARED and MAP_PRIVATE are POSIX-only (macOS, Linux); not present on Windows."
    - "Method names on the mmap class (read, write, seek, tell, close, find, flush) are verified via __name__ attribute access."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# class names
# ---------------------------------------------------------------------------

invariant mmap.class.mmap_name:
  description: "mmap.mmap.__name__ == 'mmap'"
  category: class_names
  kind: python_call_eq
  function: mmap.__name__.__eq__
  args: ["mmap"]
  expected: true

invariant mmap.class.error_name:
  description: "mmap.error.__name__ == 'OSError' — mmap.error is an alias for OSError on Python 3"
  category: class_names
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# access mode constants
# ---------------------------------------------------------------------------

invariant mmap.constants.access_read:
  description: "mmap.ACCESS_READ == 1"
  category: constants
  kind: python_call_eq
  function: ACCESS_READ.__eq__
  args: [1]
  expected: true

invariant mmap.constants.access_write:
  description: "mmap.ACCESS_WRITE == 2"
  category: constants
  kind: python_call_eq
  function: ACCESS_WRITE.__eq__
  args: [2]
  expected: true

invariant mmap.constants.access_copy:
  description: "mmap.ACCESS_COPY == 3"
  category: constants
  kind: python_call_eq
  function: ACCESS_COPY.__eq__
  args: [3]
  expected: true

# ---------------------------------------------------------------------------
# platform-size constants (type checks only — values are OS-dependent)
# ---------------------------------------------------------------------------

invariant mmap.constants.pagesize_is_int:
  description: "mmap.PAGESIZE is an int (value is OS-dependent)"
  category: constants
  kind: python_call_eq
  function: PAGESIZE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant mmap.constants.allocationgranularity_is_int:
  description: "mmap.ALLOCATIONGRANULARITY is an int (value is OS-dependent)"
  category: constants
  kind: python_call_eq
  function: ALLOCATIONGRANULARITY.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant mmap.constants.pagesize_positive:
  description: "mmap.PAGESIZE > 0"
  category: constants
  kind: python_call_eq
  function: PAGESIZE.__gt__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# POSIX-only protection and mapping constants
# (macOS and Linux; not present on Windows)
# ---------------------------------------------------------------------------

invariant mmap.constants.prot_read_is_int:
  description: "mmap.PROT_READ is an int — POSIX-only (macOS, Linux)"
  category: constants
  platform: posix
  kind: python_call_eq
  function: PROT_READ.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant mmap.constants.map_shared_is_int:
  description: "mmap.MAP_SHARED is an int — POSIX-only (macOS, Linux)"
  category: constants
  platform: posix
  kind: python_call_eq
  function: MAP_SHARED.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant mmap.constants.map_private_is_int:
  description: "mmap.MAP_PRIVATE is an int — POSIX-only (macOS, Linux)"
  category: constants
  platform: posix
  kind: python_call_eq
  function: MAP_PRIVATE.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# method names on mmap.mmap
# ---------------------------------------------------------------------------

table mmap.mmap.method_names:
  kind: python_call_eq
  category: method_names
  id_prefix: method

  columns: [id, function, args, expected]
  rows:
    - [read,  mmap.read.__name__.__eq__,  ["read"],  true]
    - [write, mmap.write.__name__.__eq__, ["write"], true]
    - [seek,  mmap.seek.__name__.__eq__,  ["seek"],  true]
    - [tell,  mmap.tell.__name__.__eq__,  ["tell"],  true]
    - [close, mmap.close.__name__.__eq__, ["close"], true]
    - [find,  mmap.find.__name__.__eq__,  ["find"],  true]
    - [flush, mmap.flush.__name__.__eq__, ["flush"], true]
