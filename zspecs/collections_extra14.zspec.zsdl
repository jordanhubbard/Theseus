spec: collections_extra14
version: ">=3.9"
backend: python_module(collections)

docs: https://docs.python.org/3/library/collections.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.html — Python collections documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/collections/__init__.py"
    - "CPython source: Modules/_collectionsmodule.c"
  notes:
    - "This spec extends collections.zspec.zsdl and prior extras through collections_extra13.zspec.zsdl."
    - "collections_extra13 covers: deque.__contains__ present/absent; deque.count(); Counter.most_common(1)[0]; defaultdict(int)['missing']==0; defaultdict(list)['k'].__len__()==0; ChainMap.new_child() len and maps len; OrderedDict.move_to_end() returns None."
    - "collections_extra12 covers: namedtuple._make first/second field and len; deque.popleft; UserString/__add__; UserList/__add__; UserDict.__getitem__."
    - "NOT yet covered: namedtuple._fields attribute (tuple of field names); namedtuple._asdict() method (returns dict); namedtuple._replace() with new field value; ChainMap first-map priority (key in both maps uses first map value); Counter.__add__ (combines two Counters); Counter.elements() (yields each element count times)."
    - "namedtuple('Point',['x','y'])._fields[0] == 'x' — first field name."
    - "namedtuple('Point',['x','y'])._fields[1] == 'y' — second field name."
    - "namedtuple('Point',['x','y'])._fields.__len__() == 2 — two fields."
    - "namedtuple('Point',['x','y'])._make([10,20])._asdict().__len__() == 2 — _asdict dict has two keys."
    - "namedtuple('Point',['x','y'])._make([10,20])._asdict().__class__.__name__ == 'dict'."
    - "ChainMap({'a':1,'b':2},{'b':99,'c':3})['b'] == 2 — first map wins for key 'b' (priority)."
    - "ChainMap({'a':1,'b':2},{'b':99,'c':3}).__len__() == 3 — unique keys across both maps."
    - "Counter(a=3,b=1).__add__(Counter(a=1,b=2))['a'] == 4 — element-wise addition."
    - "Counter(a=3,b=1).elements().__class__.__name__ — elements() yields keys repeated by count."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# namedtuple._fields — tuple of field name strings
#
# collections_extra12 covers namedtuple._make() as an alternative constructor.
# No prior spec tests the _fields attribute, which holds a tuple of field names
# in definition order. namedtuple('Point', ['x','y'])._fields == ('x', 'y').
# We access the type directly (before constructing an instance) using method:
# _fields.__getitem__ to read individual names, and _fields.__len__ for count.
# ---------------------------------------------------------------------------

invariant collections_extra14.namedtuple.fields_first:
  description: "namedtuple('Point',['x','y'])._fields[0] == 'x' — first field name"
  category: namedtuple_fields
  kind: python_call_eq
  function: namedtuple
  args: ["Point", ["x", "y"]]
  method: _fields.__getitem__
  method_args: [0]
  expected: "x"

invariant collections_extra14.namedtuple.fields_second:
  description: "namedtuple('Point',['x','y'])._fields[1] == 'y' — second field name"
  category: namedtuple_fields
  kind: python_call_eq
  function: namedtuple
  args: ["Point", ["x", "y"]]
  method: _fields.__getitem__
  method_args: [1]
  expected: "y"

invariant collections_extra14.namedtuple.fields_len:
  description: "namedtuple('Point',['x','y'])._fields.__len__() == 2 — two fields defined"
  category: namedtuple_fields
  kind: python_call_eq
  function: namedtuple
  args: ["Point", ["x", "y"]]
  method: _fields.__len__
  expected: 2

# ---------------------------------------------------------------------------
# namedtuple._asdict — converts instance to an ordered dict
#
# No prior spec tests _asdict(). Called on a namedtuple instance it returns a
# regular dict mapping field names to their values (Python 3.8+ returns dict,
# not OrderedDict). We test the class name and length of the returned dict.
# namedtuple('Point',['x','y'])._make([10,20])._asdict() → {'x':10,'y':20}.
# ---------------------------------------------------------------------------

invariant collections_extra14.namedtuple.asdict_class:
  description: "namedtuple('Point',['x','y'])._make([10,20])._asdict().__class__.__name__ == 'dict'"
  category: namedtuple_asdict
  kind: python_call_eq
  function: namedtuple
  args: ["Point", ["x", "y"]]
  method: _make
  method_args: [[10, 20]]
  method_chain: _asdict.__class__.__name__.__eq__
  method_chain_args: ["dict"]
  expected: true

invariant collections_extra14.namedtuple.asdict_len:
  description: "namedtuple('Point',['x','y'])._make([10,20])._asdict().__len__() == 2 — dict has one key per field"
  category: namedtuple_asdict
  kind: python_call_eq
  function: namedtuple
  args: ["Point", ["x", "y"]]
  method: _make
  method_args: [[10, 20]]
  method_chain: _asdict.__len__
  expected: 2

# ---------------------------------------------------------------------------
# ChainMap first-map priority — key present in both maps returns first value
#
# collections_extra11 covers ChainMap.__contains__ and ChainMap.get().
# No prior spec tests priority lookup when the same key exists in multiple maps.
# ChainMap({'a':1,'b':2},{'b':99,'c':3}).__getitem__('b') == 2: the first map
# takes precedence over the second for key 'b'.
# ---------------------------------------------------------------------------

invariant collections_extra14.ChainMap.priority_first_wins:
  description: "ChainMap({'a':1,'b':2},{'b':99,'c':3}).__getitem__('b') == 2 — first map wins on overlap"
  category: chainmap_ops
  kind: python_call_eq
  function: ChainMap
  args: [{"a": 1, "b": 2}, {"b": 99, "c": 3}]
  method: __getitem__
  method_args: ["b"]
  expected: 2

invariant collections_extra14.ChainMap.priority_unique_key_second:
  description: "ChainMap({'a':1,'b':2},{'b':99,'c':3}).__getitem__('c') == 3 — key only in second map is reachable"
  category: chainmap_ops
  kind: python_call_eq
  function: ChainMap
  args: [{"a": 1, "b": 2}, {"b": 99, "c": 3}]
  method: __getitem__
  method_args: ["c"]
  expected: 3

invariant collections_extra14.ChainMap.two_map_unique_len:
  description: "ChainMap({'a':1,'b':2},{'b':99,'c':3}).__len__() == 3 — three unique keys across two maps"
  category: chainmap_ops
  kind: python_call_eq
  function: ChainMap
  args: [{"a": 1, "b": 2}, {"b": 99, "c": 3}]
  method: __len__
  expected: 3

# ---------------------------------------------------------------------------
# Counter.__add__ — element-wise addition of two Counters
#
# No prior spec tests Counter.__add__ which adds element counts from two Counters.
# Counter(a=3,b=1) + Counter(a=1,b=2) == Counter(a=4, b=3).
# We test the sum via __getitem__ on the result.
# ---------------------------------------------------------------------------

invariant collections_extra14.Counter.add_a_count:
  description: "Counter(a=3,b=1).__add__(Counter(a=1,b=2))['a'] == 4 — element-wise addition of 'a' count"
  category: counter_ops
  kind: python_call_eq
  function: Counter
  args: [{"a": 3, "b": 1}]
  method: __add__
  method_args: [{"a": 1, "b": 2}]
  method_chain: __getitem__
  method_chain_args: ["a"]
  expected: 4

invariant collections_extra14.Counter.add_b_count:
  description: "Counter(a=3,b=1).__add__(Counter(a=1,b=2))['b'] == 3 — element-wise addition of 'b' count"
  category: counter_ops
  kind: python_call_eq
  function: Counter
  args: [{"a": 3, "b": 1}]
  method: __add__
  method_args: [{"a": 1, "b": 2}]
  method_chain: __getitem__
  method_chain_args: ["b"]
  expected: 3

invariant collections_extra14.Counter.add_result_class:
  description: "Counter(a=3)__add__(Counter(a=1)).__class__.__name__ == 'Counter' — result is a Counter"
  category: counter_ops
  kind: python_call_eq
  function: Counter
  args: [{"a": 3}]
  method: __add__
  method_args: [{"a": 1}]
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["Counter"]
  expected: true
