spec: io_extra706
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers FileIO, BytesIO, StringIO, BufferedReader, BufferedWriter, BufferedRandom class identity"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra706.class_identity:
  description: "Identity checks for io module classes: qualname, module, and doc type"
  kind: python_call_eq
  category: class_identity
  id_prefix: io706ci
  columns: [id, function, args, expected]
  rows:
    - [io706ci001, io.FileIO.__qualname__.__eq__, ["FileIO"], true]
    - [io706ci002, io.FileIO.__module__.__eq__, ["io"], true]
    - [io706ci003, io.FileIO.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [io706ci004, io.BytesIO.__qualname__.__eq__, ["BytesIO"], true]
    - [io706ci005, io.BytesIO.__module__.__eq__, ["io"], true]
    - [io706ci006, io.BytesIO.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [io706ci007, io.StringIO.__qualname__.__eq__, ["StringIO"], true]
    - [io706ci008, io.StringIO.__module__.__eq__, ["io"], true]
    - [io706ci009, io.StringIO.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [io706ci010, io.BufferedReader.__qualname__.__eq__, ["BufferedReader"], true]
    - [io706ci011, io.BufferedWriter.__qualname__.__eq__, ["BufferedWriter"], true]
    - [io706ci012, io.BufferedRandom.__qualname__.__eq__, ["BufferedRandom"], true]
