spec: concurrent_futures_extra203
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/"
  notes:
    - "concurrent.futures.wait.__defaults__ is (None, 'ALL_COMPLETED') — a 2-tuple; defaults are for the timeout (None=no timeout) and return_when ('ALL_COMPLETED') parameters."
    - "concurrent.futures.as_completed.__defaults__ is (None,) — a 1-tuple; the single default is timeout=None (no timeout)."
    - "concurrent.futures.ThreadPoolExecutor.__init__.__defaults__ is (None, '', None, ()) — a 4-tuple covering max_workers, thread_name_prefix, initializer, initargs."
    - "wait.__defaults__[1] == 'ALL_COMPLETED' has length 13: A-L-L-_-C-O-M-P-L-E-T-E-D."
    - "ThreadPoolExecutor.__init__.__defaults__[1] == '' (empty string) — thread_name_prefix defaults to the empty string."
    - "ThreadPoolExecutor.__init__.__defaults__[3] == () (empty tuple) — initargs defaults to an empty tuple."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

