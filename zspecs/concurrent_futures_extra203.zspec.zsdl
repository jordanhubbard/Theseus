invariant concurrent_futures_extra203.wait_defaults_is_tuple:
  description: "concurrent.futures.wait.__defaults__.__class__.__name__.__eq__('tuple') == True — wait.__defaults__ is (None, 'ALL_COMPLETED'); both timeout and return_when have positional defaults; __defaults__ is a tuple when present; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: wait_defaults
  kind: python_call_eq
  function: concurrent.futures.wait.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant concurrent_futures_extra203.wait_defaults_len_2:
  description: "concurrent.futures.wait.__defaults__.__len__() == 2 — wait(fs, timeout=None, return_when=ALL_COMPLETED) has two defaults; wait.__defaults__.__len__(2) > as_completed.__defaults__.__len__(1) by 1 — wait has one more default parameter than as_completed; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: wait_defaults
  kind: python_call_eq
  function: concurrent.futures.wait.__defaults__.__len__
  args: []
  expected: 2

invariant concurrent_futures_extra203.wait_defaults1_len_13:
  description: "concurrent.futures.wait.__defaults__[1].__len__() == 13 — 'ALL_COMPLETED' has 13 characters: A(1)L(2)L(3)_(4)C(5)O(6)M(7)P(8)L(9)E(10)T(11)E(12)D(13); this is the return_when default; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: wait_defaults
  kind: python_call_eq
  function: "concurrent.futures.wait.__defaults__.__getitem__(1).__len__"
  args: []
  expected: 13

invariant concurrent_futures_extra203.as_completed_defaults_is_tuple:
  description: "concurrent.futures.as_completed.__defaults__.__class__.__name__.__eq__('tuple') == True — as_completed.__defaults__ is (None,); the single default is timeout=None; __defaults__ is a tuple when present; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: as_completed_defaults
  kind: python_call_eq
  function: concurrent.futures.as_completed.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant concurrent_futures_extra203.as_completed_defaults_len_1:
  description: "concurrent.futures.as_completed.__defaults__.__len__() == 1 — as_completed has exactly one default (timeout=None); as_completed.__defaults__.__len__(1) < wait.__defaults__.__len__(2) by 1 — as_completed has fewer defaults than wait; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: as_completed_defaults
  kind: python_call_eq
  function: concurrent.futures.as_completed.__defaults__.__len__
  args: []
  expected: 1

invariant concurrent_futures_extra203.tpe_init_defaults_is_tuple:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__defaults__.__class__.__name__.__eq__('tuple') == True — __init__.__defaults__ is (None, '', None, ()); ThreadPoolExecutor's constructor has four parameters with defaults; __defaults__ is always a tuple when present; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: threadpoolexecutor_defaults
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__init__.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant concurrent_futures_extra203.tpe_init_defaults_len_4:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__defaults__.__len__() == 4 — the four defaults are max_workers=None, thread_name_prefix='', initializer=None, initargs=(); ThreadPoolExecutor.__init__.__defaults__.__len__(4) > wait.__defaults__.__len__(2) by 2; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: threadpoolexecutor_defaults
  kind: python_call_eq
  function: concurrent.futures.ThreadPoolExecutor.__init__.__defaults__.__len__
  args: []
  expected: 4

invariant concurrent_futures_extra203.tpe_init_defaults3_is_tuple:
  description: "concurrent.futures.ThreadPoolExecutor.__init__.__defaults__[3].__class__.__name__.__eq__('tuple') == True — initargs defaults to () (an empty tuple); the initargs parameter holds arguments passed to the initializer callable; default is empty tuple meaning no initializer args; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: threadpoolexecutor_defaults
