spec: functools_extra1741
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/functools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol dict-presence checks."
    - "functools.partial implements __get__ (C descriptor, tp_descr_get) but not __set__ or __delete__ — non-data descriptor."
    - "functools.cached_property implements __get__ and __set_name__ but not __set__ or __delete__ — non-data descriptor that stores attr name."
    - "functools.partialmethod implements __get__ (descriptor for binding methods) but not __set__ or __delete__."
    - "functools._lru_cache_wrapper implements __get__ (C wrapper, can be used as instance method) but not __set_name__."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: descriptor protocol dict-presence checks for functools types
#
# Wave 563 theme: which functools types define __get__, __set__, __delete__,
# __set_name__ in their own __dict__.
#
# functools.partial: C extension type with tp_descr_get → __get__ in __dict__
#   __set__: False (non-data descriptor), __delete__: False, __set_name__: False
# functools.cached_property: __get__: True, __set__: False, __delete__: False,
#   __set_name__: True (stores attribute name for later use)
# functools.partialmethod: __get__: True, __set__: False, __delete__: False,
#   __set_name__: False
# functools._lru_cache_wrapper: __get__: True, __set_name__: False
# ---------------------------------------------------------------------------

table functools_extra1741.descriptor_protocol:
  description: "functools types descriptor protocol dict-presence checks — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1741

  columns: [id, function, args, expected]
  rows:
    - ["fu1741001", "functools.partial.__dict__.__contains__", ["__get__"], true]
    - ["fu1741002", "functools.partial.__dict__.__contains__", ["__set__"], false]
    - ["fu1741003", "functools.partial.__dict__.__contains__", ["__delete__"], false]
    - ["fu1741004", "functools.partial.__dict__.__contains__", ["__set_name__"], false]
    - ["fu1741005", "functools.cached_property.__dict__.__contains__", ["__get__"], true]
    - ["fu1741006", "functools.cached_property.__dict__.__contains__", ["__set__"], false]
    - ["fu1741007", "functools.cached_property.__dict__.__contains__", ["__delete__"], false]
    - ["fu1741008", "functools.cached_property.__dict__.__contains__", ["__set_name__"], true]
    - ["fu1741009", "functools.partialmethod.__dict__.__contains__", ["__get__"], true]
    - ["fu1741010", "functools.partialmethod.__dict__.__contains__", ["__set__"], false]
    - ["fu1741011", "functools.partialmethod.__dict__.__contains__", ["__delete__"], false]
    - ["fu1741012", "functools.partialmethod.__dict__.__contains__", ["__set_name__"], false]
    - ["fu1741013", "functools._lru_cache_wrapper.__dict__.__contains__", ["__get__"], true]
    - ["fu1741014", "functools._lru_cache_wrapper.__dict__.__contains__", ["__set__"], false]
    - ["fu1741015", "functools._lru_cache_wrapper.__dict__.__contains__", ["__delete__"], false]
    - ["fu1741016", "functools._lru_cache_wrapper.__dict__.__contains__", ["__set_name__"], false]

# ---------------------------------------------------------------------------
# Table 2: non-descriptor functools attributes — contrasting checks
#
# These non-descriptor checks contrast with the descriptor-implementing types
# above. functools.reduce, functools.wraps, functools.total_ordering are
# functions/builtins, not descriptor types — none define the descriptor
# dunder methods in their own __dict__ (or have no __dict__ at all).
# Also checks that partial/cached_property __dict__ contains other expected
# entries (__init__, __new__, __doc__) to confirm __dict__ access works.
# ---------------------------------------------------------------------------

table functools_extra1741.non_descriptor_contrast:
  description: "functools non-descriptor contrast checks — confirming non-descriptor types and __dict__ contents — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: fu1741

  columns: [id, function, args, expected]
  rows:
    - ["fu1741017", "functools.partial.__dict__.__contains__", ["__init__"], true]
    - ["fu1741018", "functools.partial.__dict__.__contains__", ["__new__"], true]
    - ["fu1741019", "functools.partial.__dict__.__contains__", ["__doc__"], true]
    - ["fu1741020", "functools.cached_property.__dict__.__contains__", ["__init__"], true]
    - ["fu1741021", "functools.cached_property.__dict__.__contains__", ["__doc__"], true]
    - ["fu1741022", "functools.partialmethod.__dict__.__contains__", ["__init__"], true]
    - ["fu1741023", "functools.partialmethod.__dict__.__contains__", ["__doc__"], true]
    - ["fu1741024", "functools.partialmethod.__dict__.__contains__", ["__get__"], true]
