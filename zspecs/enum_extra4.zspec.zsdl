spec: enum_extra4
version: ">=3.9"
backend: python_module(enum)

docs: https://docs.python.org/3/library/enum.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/enum.html — Python enum module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/enum.py"
  notes:
    - "This spec extends enum.zspec.zsdl, enum_extra.zspec.zsdl, enum_extra2.zspec.zsdl, enum_extra3.zspec.zsdl, and enum_flags.zspec.zsdl."
    - "It does NOT duplicate invariants present in those files."
    - "enum.EnumType is the canonical metaclass name in Python 3.11+; enum.EnumMeta is a backward-compat alias."
    - "Both EnumType.__name__ and EnumMeta.__name__ resolve to 'EnumType' in Python 3.11+ (alias shares the same type object)."
    - "enum.EnumMeta.__name__ == 'EnumType' is already in enum_extra.zspec.zsdl; here we verify the __qualname__ of EnumType."
    - "enum.StrEnum.__name__ == 'StrEnum' is in enum.zspec.zsdl; here we verify StrEnum.__qualname__ and its metaclass."
    - "enum.IntFlag.__name__ == 'IntFlag' is in enum.zspec.zsdl; here we verify IntFlag.__qualname__ and StrEnum.__qualname__."
    - "enum.Flag.__name__ == 'Flag' is in enum.zspec.zsdl; here we verify Flag.__qualname__ and its first base."
    - "enum.global_enum.__name__ is in enum_extra2.zspec.zsdl; here we verify global_enum.__module__ (not yet covered)."
    - "enum.global_enum is a plain function: global_enum.__class__.__name__ == 'function'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# EnumType — qualname and module checks not covered in prior specs
#
# enum_flags.zspec.zsdl covered EnumType.__name__, EnumType.__module__,
# EnumType.__bases__[0].__name__. enum_extra.zspec.zsdl covered EnumMeta.__name__
# and EnumMeta.__module__. Here we cover EnumType.__qualname__.
# ---------------------------------------------------------------------------

invariant enum_extra4.EnumType.qualname:
  description: "enum.EnumType.__qualname__ == 'EnumType' (Python 3.11+)"
  category: enumtype
  version: ">=3.11"
  kind: python_call_eq
  function: EnumType.__qualname__.__eq__
  args: ["EnumType"]
  expected: true

invariant enum_extra4.EnumMeta.qualname:
  description: "enum.EnumMeta.__qualname__ == 'EnumType' — alias shares qualname with EnumType (Python 3.11+)"
  category: enumtype
  version: ">=3.11"
  kind: python_call_eq
  function: EnumMeta.__qualname__.__eq__
  args: ["EnumType"]
  expected: true

invariant enum_extra4.EnumMeta.name_3_9:
  description: "enum.EnumMeta.__name__ == 'EnumMeta' (Python 3.9/3.10 — before EnumType alias)"
  category: enumtype
  version: ">=3.9,<3.11"
  kind: python_call_eq
  function: EnumMeta.__name__.__eq__
  args: ["EnumMeta"]
  expected: true

invariant enum_extra4.EnumMeta.module:
  description: "enum.EnumMeta.__module__ == 'enum'"
  category: enumtype
  kind: python_call_eq
  function: EnumMeta.__module__.__eq__
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# StrEnum — qualname, metaclass, and module (Python 3.11+)
#
# enum.zspec.zsdl covered StrEnum.__name__; enum_extra.zspec.zsdl covered
# StrEnum.__module__ and StrEnum.__bases__[0].__name__.
# Here we cover StrEnum.__qualname__ and StrEnum's metaclass name.
# ---------------------------------------------------------------------------

invariant enum_extra4.StrEnum.name:
  description: "enum.StrEnum.__name__ == 'StrEnum' (Python 3.11+)"
  category: strenum
  version: ">=3.11"
  kind: python_call_eq
  function: StrEnum.__name__.__eq__
  args: ["StrEnum"]
  expected: true

invariant enum_extra4.StrEnum.qualname:
  description: "enum.StrEnum.__qualname__ == 'StrEnum' (Python 3.11+)"
  category: strenum
  version: ">=3.11"
  kind: python_call_eq
  function: StrEnum.__qualname__.__eq__
  args: ["StrEnum"]
  expected: true

invariant enum_extra4.StrEnum.module:
  description: "enum.StrEnum.__module__ == 'enum' (Python 3.11+)"
  category: strenum
  version: ">=3.11"
  kind: python_call_eq
  function: StrEnum.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_extra4.StrEnum.metaclass_name:
  description: "type(enum.StrEnum).__name__ == 'EnumType' — StrEnum's metaclass is EnumType (Python 3.11+)"
  category: strenum
  version: ">=3.11"
  kind: python_call_eq
  function: StrEnum.__class__.__name__.__eq__
  args: ["EnumType"]
  expected: true

# ---------------------------------------------------------------------------
# IntFlag — qualname check
#
# enum.zspec.zsdl covered IntFlag.__name__; enum_flags.zspec.zsdl covered
# IntFlag.__module__ and IntFlag.__bases__[0].__name__; enum_extra3.zspec.zsdl
# covered IntFlag.__name__ again. Here we cover IntFlag.__qualname__.
# ---------------------------------------------------------------------------

invariant enum_extra4.IntFlag.name:
  description: "enum.IntFlag.__name__ == 'IntFlag'"
  category: intflag
  kind: python_call_eq
  function: IntFlag.__name__.__eq__
  args: ["IntFlag"]
  expected: true

invariant enum_extra4.IntFlag.qualname:
  description: "enum.IntFlag.__qualname__ == 'IntFlag'"
  category: intflag
  kind: python_call_eq
  function: IntFlag.__qualname__.__eq__
  args: ["IntFlag"]
  expected: true

invariant enum_extra4.IntFlag.module:
  description: "enum.IntFlag.__module__ == 'enum'"
  category: intflag
  kind: python_call_eq
  function: IntFlag.__module__.__eq__
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# Flag — qualname check
#
# enum.zspec.zsdl covered Flag.__name__; enum_flags.zspec.zsdl covered
# Flag.__module__ and Flag metaclass. Here we cover Flag.__qualname__.
# ---------------------------------------------------------------------------

invariant enum_extra4.Flag.name:
  description: "enum.Flag.__name__ == 'Flag'"
  category: flag
  kind: python_call_eq
  function: Flag.__name__.__eq__
  args: ["Flag"]
  expected: true

invariant enum_extra4.Flag.qualname:
  description: "enum.Flag.__qualname__ == 'Flag'"
  category: flag
  kind: python_call_eq
  function: Flag.__qualname__.__eq__
  args: ["Flag"]
  expected: true

invariant enum_extra4.Flag.module:
  description: "enum.Flag.__module__ == 'enum'"
  category: flag
  kind: python_call_eq
  function: Flag.__module__.__eq__
  args: ["enum"]
  expected: true

# ---------------------------------------------------------------------------
# global_enum — module and type checks (Python 3.11+)
#
# enum_extra2.zspec.zsdl covered global_enum.__name__ == 'global_enum'.
# Here we add global_enum.__module__ and its runtime type identity.
# ---------------------------------------------------------------------------

invariant enum_extra4.global_enum.module:
  description: "enum.global_enum.__module__ == 'enum' (Python 3.11+)"
  category: decorators
  version: ">=3.11"
  kind: python_call_eq
  function: global_enum.__module__.__eq__
  args: ["enum"]
  expected: true

invariant enum_extra4.global_enum.is_function:
  description: "type(enum.global_enum).__name__ == 'function' — global_enum is a plain Python function (Python 3.11+)"
  category: decorators
  version: ">=3.11"
  kind: python_call_eq
  function: global_enum.__class__.__name__.__eq__
  args: ["function"]
  expected: true
