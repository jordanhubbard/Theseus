spec: content_disposition
version: ">=1.0.0"
backend: node(content-disposition)

docs: https://github.com/jshttp/content-disposition#readme

provenance:
  derived_from:
    - "content-disposition README — https://github.com/jshttp/content-disposition#readme"
    - "Test vectors verified with content-disposition@1.1.0 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "content-disposition source: index.js"
  notes:
    - "content-disposition exports the contentDisposition function as the module default (CJS)."
    - "contentDisposition() with no args returns 'attachment'."
    - "contentDisposition(filename) returns 'attachment; filename=\"...\"'."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a Content-Disposition header value string. No errors for valid inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table content_disposition.basic:
  kind: node_module_call_eq
  function: ~
  category: basic
  id_prefix: cd

  columns: [id, args, expected]
  rows:
    - [no_filename,    [],                    "attachment"]
    - [with_filename,  ["report.pdf"],        "attachment; filename=\"report.pdf\""]
    - [simple_name,    ["file.txt"],          "attachment; filename=\"file.txt\""]
