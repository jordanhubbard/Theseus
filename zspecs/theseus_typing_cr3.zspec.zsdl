spec: theseus_typing_cr3
version: ">=3.9"
backend: python_cleanroom(theseus_typing_cr3)
blocks: typing

docs: https://docs.python.org/3/library/typing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/typing.html"
    - "PEP 484 — Type Hints"
    - "PEP 604 — Union syntax"
  notes:
    - "Clean-room extended typing utilities. Do NOT import typing."
    - "Union[X, Y]: type alias representing X or Y; has .__args__ = (X, Y)."
    - "Optional[X]: equivalent to Union[X, None]; .__args__ = (X, type(None))."
    - "get_args(tp): return type arguments of a generic alias."
    - "typing3_union(): Union[int, str].__args__ == (int, str)."
    - "typing3_optional(): Optional[int].__args__ == (int, type(None))."
    - "typing3_get_args(): get_args(Optional[int]) == (int, type(None))."
    - "Zero-arg invariant signatures — def typing3_union(): return bool"
    - "Union is a special form; Union[A, B].__args__ stores the type arguments."
    - "Optional[X] is sugar for Union[X, None]; type(None) is NoneType."
    - "get_args returns the __args__ of a parameterized generic."
    - "Export: Union, Optional, get_args, get_origin, Any, List, Dict, Tuple, Set, Callable."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_typing_cr3.union:
  description: "Union[int, str].__args__ == (int, str)"
  category: Union
  kind: python_call_eq
  function: typing3_union
  args: []
  expected: true

invariant theseus_typing_cr3.optional:
  description: "Optional[int].__args__ == (int, type(None))"
  category: Optional
  kind: python_call_eq
  function: typing3_optional
  args: []
  expected: true

invariant theseus_typing_cr3.get_args:
  description: "get_args(Optional[int]) == (int, type(None))"
  category: get_args
  kind: python_call_eq
  function: typing3_get_args
  args: []
  expected: true
