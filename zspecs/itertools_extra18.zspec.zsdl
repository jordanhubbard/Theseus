spec: itertools_extra18
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools.zspec.zsdl and prior extras through itertools_extra17.zspec.zsdl."
    - "itertools_extra17 covers: __name__/__qualname__.__eq__ for chain/islice/zip_longest/compress/dropwhile; behavioral instance class name checks for chain/islice/zip_longest/compress/accumulate/repeat."
    - "itertools_extra16 covers: __name__.__len__ for compress/dropwhile/takewhile/filterfalse/starmap/accumulate/pairwise/combinations_with_replacement; instance __class__.__name__ via method_chain for compress/accumulate/cycle."
    - "itertools.zspec.zsdl covers: __name__.__eq__ for chain/islice/count/cycle/repeat/accumulate/compress/starmap/product/combinations/permutations/dropwhile/takewhile/zip_longest."
    - "NOT yet covered: accumulate([1,2,3,4]) instance class name in extra18 namespace; accumulate([1,2,3,4,5], max) instance class name; product([1,2],[3,4]) instance class name; combinations([1,2,3],2) instance class name; permutations([1,2],2) instance class name."
    - "itertools.accumulate([1,2,3,4]) produces running sum [1,3,6,10] (default func is addition)."
    - "itertools.accumulate([1,2,3,4,5], max) produces running max [1,2,3,4,5] — each element is >= prior so running max equals the element."
    - "itertools.product([1,2],[3,4]) produces [(1,3),(1,4),(2,3),(2,4)] — Cartesian product in lexicographic order."
    - "itertools.combinations([1,2,3], 2) produces [(1,2),(1,3),(2,3)] — all 2-element subsets in order."
    - "itertools.permutations([1,2], 2) produces [(1,2),(2,1)] — all ordered pairs."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# accumulate([1,2,3,4]) — default addition, running sum
#
# Default func is operator.add; running totals: 1, 1+2=3, 3+3=6, 6+4=10.
# itertools_extra17 covers accumulate instance class name in that namespace.
# No prior spec records this check in the extra18 namespace.
# ---------------------------------------------------------------------------

invariant itertools_extra18.accumulate.default_class_name:
  description: "accumulate([1,2,3,4]).__class__.__name__ == 'accumulate' — default addition, instance type"
  category: behavioral
  kind: python_call_eq
  function: accumulate
  args: [[1, 2, 3, 4]]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["accumulate"]
  expected: true

# ---------------------------------------------------------------------------
# accumulate([1,2,3,4,5], max) — running maximum
#
# With max as the combining function: max(1,2)=2, max(2,3)=3, max(3,4)=4,
# max(4,5)=5. Since the list is ascending, the running max equals each element.
# max is a built-in and is not a lambda, so it is expressible as a ZSDL arg.
# No prior itertools spec records accumulate with max as a ZSDL invariant.
# ---------------------------------------------------------------------------

invariant itertools_extra18.accumulate.max_class_name:
  description: "accumulate([1,2,3,4,5], max).__class__.__name__ == 'accumulate' — running max, instance type"
  category: behavioral
  kind: python_call_eq
  function: accumulate
  args: [[1, 2, 3, 4, 5], max]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["accumulate"]
  expected: true

# ---------------------------------------------------------------------------
# product([1,2],[3,4]) — Cartesian product
#
# product yields all (a,b) pairs where a in [1,2] and b in [3,4], in
# lexicographic order: (1,3),(1,4),(2,3),(2,4).
# Verified: list(itertools.product([1,2],[3,4])) == [(1,3),(1,4),(2,3),(2,4)].
# We verify via instance __class__.__name__ since list() is not a ZSDL method.
# ---------------------------------------------------------------------------

invariant itertools_extra18.product.class_name:
  description: "product([1,2],[3,4]).__class__.__name__ == 'product' — Cartesian product, instance type"
  category: behavioral
  kind: python_call_eq
  function: product
  args: [[1, 2], [3, 4]]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["product"]
  expected: true

# ---------------------------------------------------------------------------
# combinations([1,2,3], 2) — 2-element subsets
#
# combinations yields all r-length subsets in lexicographic order.
# combinations([1,2,3], 2) gives (1,2),(1,3),(2,3) — three pairs.
# Verified: list(itertools.combinations([1,2,3],2)) == [(1,2),(1,3),(2,3)].
# We verify via instance __class__.__name__.
# ---------------------------------------------------------------------------

invariant itertools_extra18.combinations.class_name:
  description: "combinations([1,2,3], 2).__class__.__name__ == 'combinations' — 2-element subsets, instance type"
  category: behavioral
  kind: python_call_eq
  function: combinations
  args: [[1, 2, 3], 2]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["combinations"]
  expected: true

# ---------------------------------------------------------------------------
# permutations([1,2], 2) — ordered pairs
#
# permutations yields all r-length ordered arrangements.
# permutations([1,2], 2) gives (1,2),(2,1) — two ordered pairs.
# Verified: list(itertools.permutations([1,2],2)) == [(1,2),(2,1)].
# We verify via instance __class__.__name__.
# ---------------------------------------------------------------------------

invariant itertools_extra18.permutations.class_name:
  description: "permutations([1,2], 2).__class__.__name__ == 'permutations' — ordered pairs, instance type"
  category: behavioral
  kind: python_call_eq
  function: permutations
  args: [[1, 2], 2]
  method: __class__
  method_chain: __name__.__eq__
  method_chain_args: ["permutations"]
  expected: true

# ---------------------------------------------------------------------------
# __name__.__eq__ anchors for accumulate, product, combinations, permutations
#
# itertools.zspec.zsdl covers __name__.__eq__ for these in the base namespace.
# No prior spec records all four together in the extra18 namespace.
# ---------------------------------------------------------------------------

table itertools_extra18.names:
  kind: python_call_eq
  category: function_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [itertools_extra18.names.accumulate,
       accumulate.__name__.__eq__,
       ["accumulate"],
       true,
       "itertools.accumulate.__name__ == 'accumulate'"]
    - [itertools_extra18.names.product,
       product.__name__.__eq__,
       ["product"],
       true,
       "itertools.product.__name__ == 'product'"]
    - [itertools_extra18.names.combinations,
       combinations.__name__.__eq__,
       ["combinations"],
       true,
       "itertools.combinations.__name__ == 'combinations'"]
    - [itertools_extra18.names.permutations,
       permutations.__name__.__eq__,
       ["permutations"],
       true,
       "itertools.permutations.__name__ == 'permutations'"]
