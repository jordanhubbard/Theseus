spec: struct_extra182
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/struct.py"
  notes:
    - "struct.Struct.__init__.__name__ == '__init__' — len=8; C wrapper for Struct initializer."
    - "struct.Struct.__repr__.__name__ == '__repr__' — len=8; C wrapper."
    - "struct.Struct.__sizeof__.__name__ == '__sizeof__' — len=10; C wrapper."
    - "struct.Struct.__class__.__name__ == 'type' — Struct is a C type (metaclass is 'type')."
    - "struct.Struct.__module__ == '_struct' — Struct is defined in the _struct C extension."
    - "struct.error.__class__.__name__ == 'type' — error is a Python exception class."
    - "struct.error.__module__ == 'struct' — error is defined in the struct Python wrapper module."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor' — size is a C-level computed attribute."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: struct.Struct dunder method name identity
#
# struct.Struct.__init__.__name__    == '__init__'    (len=8)
# struct.Struct.__repr__.__name__    == '__repr__'    (len=8)
# struct.Struct.__sizeof__.__name__  == '__sizeof__'  (len=10)
#
# All three are C-level wrappers on the Struct type defined in _struct.
# ---------------------------------------------------------------------------

table struct_extra182.struct_dunder_method_names:
  description: "struct.Struct dunder method name identity for __init__, __repr__, __sizeof__; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: structclassattrs182

  columns: [id, function, args, expected, description]
  rows:
    - [init_name_eq,
       struct.Struct.__init__.__name__.__eq__,
       ["__init__"],
       true,
       "struct.Struct.__init__.__name__.__eq__('__init__') == True — C wrapper is named '__init__'; len=8; new to extra182"]
    - [init_name_len,
       struct.Struct.__init__.__name__.__len__,
       [],
       8,
       "struct.Struct.__init__.__name__.__len__() == 8 — '__init__' has 8 characters; new to extra182"]
    - [repr_name_eq,
       struct.Struct.__repr__.__name__.__eq__,
       ["__repr__"],
       true,
       "struct.Struct.__repr__.__name__.__eq__('__repr__') == True — C wrapper is named '__repr__'; len=8; new to extra182"]
    - [repr_name_len,
       struct.Struct.__repr__.__name__.__len__,
       [],
       8,
       "struct.Struct.__repr__.__name__.__len__() == 8 — '__repr__' has 8 characters; new to extra182"]
    - [sizeof_name_eq,
       struct.Struct.__sizeof__.__name__.__eq__,
       ["__sizeof__"],
       true,
       "struct.Struct.__sizeof__.__name__.__eq__('__sizeof__') == True — C wrapper is named '__sizeof__'; len=10; new to extra182"]
    - [sizeof_name_len,
       struct.Struct.__sizeof__.__name__.__len__,
       [],
       10,
       "struct.Struct.__sizeof__.__name__.__len__() == 10 — '__sizeof__' has 10 characters; new to extra182"]

# ---------------------------------------------------------------------------
# Table 2: struct.Struct class and module identity
#
# struct.Struct.__class__.__name__ == 'type'    — Struct is a C type
# struct.Struct.__module__         == '_struct' — defined in _struct C extension
# struct.Struct.__name__           == 'Struct'  — class name
#
# Struct is implemented entirely in C (_struct extension); its metaclass
# is the built-in 'type'.
# ---------------------------------------------------------------------------

table struct_extra182.struct_class_and_module:
  description: "struct.Struct class metaclass and module identity; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: structclassattrs182

  columns: [id, function, args, expected, description]
  rows:
    - [struct_class_name_eq,
       struct.Struct.__class__.__name__.__eq__,
       ["type"],
       true,
       "struct.Struct.__class__.__name__.__eq__('type') == True — Struct is a C type; metaclass is 'type'; new to extra182"]
    - [struct_module_eq,
       struct.Struct.__module__.__eq__,
       ["_struct"],
       true,
       "struct.Struct.__module__.__eq__('_struct') == True — Struct is defined in the _struct C extension; new to extra182"]
    - [struct_name_eq,
       struct.Struct.__name__.__eq__,
       ["Struct"],
       true,
       "struct.Struct.__name__.__eq__('Struct') == True — class name is 'Struct'; new to extra182"]

# ---------------------------------------------------------------------------
# Table 3: struct.error class identity and struct.Struct.size descriptor type
#
# struct.error.__class__.__name__       == 'type'    — error is a type (exception class)
# struct.error.__module__               == 'struct'  — defined in the struct Python wrapper
# struct.Struct.size.__class__.__name__ == 'getset_descriptor' — C-level computed attr
#
# struct.error is defined in struct.py (the Python wrapper around _struct).
# struct.Struct.size is a C-level getset_descriptor providing the compiled format size.
# ---------------------------------------------------------------------------

table struct_extra182.error_and_size_descriptor:
  description: "struct.error class identity and struct.Struct.size descriptor type; new to extra182"
  kind: python_call_eq
  category: identity
  id_prefix: structclassattrs182

  columns: [id, function, args, expected, description]
  rows:
    - [error_class_name_eq,
       struct.error.__class__.__name__.__eq__,
       ["type"],
       true,
       "struct.error.__class__.__name__.__eq__('type') == True — error is an exception class; metaclass is 'type'; new to extra182"]
    - [error_module_eq,
       struct.error.__module__.__eq__,
       ["struct"],
       true,
       "struct.error.__module__.__eq__('struct') == True — error is defined in the struct Python wrapper module; new to extra182"]
    - [size_descriptor_class_eq,
       struct.Struct.size.__class__.__name__.__eq__,
       ["getset_descriptor"],
       true,
       "struct.Struct.size.__class__.__name__.__eq__('getset_descriptor') == True — size is a C-level computed attribute; new to extra182"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra182
# ---------------------------------------------------------------------------

invariant struct_extra182.init_name_is_init:
  description: "struct.Struct.__init__.__name__ == '__init__' — C wrapper method identity; len=8; new to extra182"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__init__.__name__.__eq__
  args: ["__init__"]
  expected: true

invariant struct_extra182.repr_name_is_repr:
  description: "struct.Struct.__repr__.__name__ == '__repr__' — C wrapper method identity; len=8; new to extra182"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__repr__.__name__.__eq__
  args: ["__repr__"]
  expected: true

invariant struct_extra182.sizeof_name_is_sizeof:
  description: "struct.Struct.__sizeof__.__name__ == '__sizeof__' — C wrapper method identity; len=10; new to extra182"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__sizeof__.__name__.__eq__
  args: ["__sizeof__"]
  expected: true

invariant struct_extra182.struct_class_is_type:
  description: "struct.Struct.__class__.__name__ == 'type' — Struct is a C type; metaclass is built-in 'type'; new to extra182"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant struct_extra182.struct_module_is_c_struct:
  description: "struct.Struct.__module__ == '_struct' — Struct is defined in the _struct C extension; new to extra182"
  category: identity
  kind: python_call_eq
  function: struct.Struct.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra182.error_class_is_type:
  description: "struct.error.__class__.__name__ == 'type' — error is an exception class; metaclass is 'type'; new to extra182"
  category: identity
  kind: python_call_eq
  function: struct.error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant struct_extra182.error_module_is_struct:
  description: "struct.error.__module__ == 'struct' — error is defined in the struct Python wrapper, not _struct; new to extra182"
  category: identity
  kind: python_call_eq
  function: struct.error.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra182.size_is_getset_descriptor:
  description: "struct.Struct.size.__class__.__name__ == 'getset_descriptor' — size is a C-level computed attribute; new to extra182"
  category: identity
  kind: python_call_eq
  function: struct.Struct.size.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

