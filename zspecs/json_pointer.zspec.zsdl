spec: json_pointer
version: ">=0.6.0"
backend: node(json-pointer)

docs: https://github.com/manuelstofer/json-pointer#readme

provenance:
  derived_from:
    - "json-pointer README — https://github.com/manuelstofer/json-pointer#readme"
    - "RFC 6901 — JavaScript Object Notation (JSON) Pointer"
    - "Test vectors verified with json-pointer via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "json-pointer source"
  notes:
    - "Implements RFC 6901 JSON Pointer — get / set / has / remove on nested object data."
    - "Install: npm install json-pointer"
    - "v0.6 CJS; module export IS get(); named utilities set/has/remove/escape/unescape/parse/compile attached."
    - "Escape: '/' → '~1', '~' → '~0'."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws TypeError on malformed pointers; returns undefined for missing paths."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant json_pointer.module_is_function:
  description: "Module export is a function (alias of get)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant json_pointer.has_get:
  description: "named .get exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "get.constructor.name"}
  expected: "Function"

invariant json_pointer.has_set:
  description: "named .set exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "set.constructor.name"}
  expected: "Function"

invariant json_pointer.has_has:
  description: "named .has exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "has.constructor.name"}
  expected: "Function"

invariant json_pointer.get_nested_value:
  description: "get({a:{b:'val'}}, '/a/b') returns 'val'"
  category: get
  kind: node_chain_eq
  entry: named
  function: get
  entry_args: [{"a": {"b": "val"}}, "/a/b"]
  chain: []
  expected: "val"

invariant json_pointer.has_returns_true_for_existing:
  description: "has({a:{b:'v'}}, '/a/b') is true"
  category: has
  kind: node_chain_eq
  entry: named
  function: has
  entry_args: [{"a": {"b": "v"}}, "/a/b"]
  chain: []
  expected: true

invariant json_pointer.has_returns_false_for_missing:
  description: "has({a:{b:'v'}}, '/a/c') is false"
  category: has
  kind: node_chain_eq
  entry: named
  function: has
  entry_args: [{"a": {"b": "v"}}, "/a/c"]
  chain: []
  expected: false

invariant json_pointer.escape_slash_and_tilde:
  description: "escape('a/b~c') is 'a~1b~0c' (RFC 6901)"
  category: escape
  kind: node_chain_eq
  entry: named
  function: escape
  entry_args: ["a/b~c"]
  chain: []
  expected: "a~1b~0c"

invariant json_pointer.compile_array_to_pointer:
  description: "compile(['a','b','c']) is '/a/b/c'"
  category: compile
  kind: node_chain_eq
  entry: named
  function: compile
  entry_args: [["a", "b", "c"]]
  chain: []
  expected: "/a/b/c"

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T19:58:25Z
  iterations: 1
  pass_count: 9
  fail_count: 0
  total_invariants: 9
  notes: Synthesis succeeded in 1 iteration(s). 9 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
