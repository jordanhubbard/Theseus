spec: inspect_extra273
version: ">=3.11"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "isclass, isfunction, isbuiltin, ismethod, ismodule are all pure-Python functions in inspect."
    - "inspect.isclass(int)==True; inspect.isclass(42)==False; inspect.isfunction(len)==False (len is builtin)."
    - "inspect.isbuiltin(len)==True; inspect.isbuiltin(print)==True; inspect.isbuiltin(lambda: None)==False."
    - "inspect.getmembers_static is available from Python 3.11+; __module__ == 'inspect'."
    - "Name lengths: isclass=7, ismethod=8, isbuiltin=9, isfunction=10."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect predicate functions — isclass, isfunction, isbuiltin, ismodule
#
# These are pure-Python boolean predicates; all __module__ == 'inspect'.
# isclass(int)  == True;  isclass(42)   == False
# isfunction(lambda: None) == True; isfunction(len) == False (builtin, not function)
# isbuiltin(len) == True; isbuiltin(print) == True; isbuiltin(lambda:None) == False
# ismodule(os) == True; ismodule(42) == False
# ---------------------------------------------------------------------------

table inspect_extra273.predicate_returns:
  description: "inspect predicate functions — isclass, isfunction, isbuiltin, ismodule return values for canonical inputs; all pure-Python, __module__=='inspect'; verified with Python 3.14.3"
  kind: python_call_eq
  category: behavior
  id_prefix: inex273pr

  columns: [id, function, args, expected, description]
  rows:
    - [ic_int_true,    isclass,   [int],          true,  "inspect.isclass(int) == True — int is a class; verified with Python 3.14.3"]
    - [ic_list_true,   isclass,   [list],         true,  "inspect.isclass(list) == True — list is a class; verified with Python 3.14.3"]
    - [ic_int_false,   isclass,   [42],           false, "inspect.isclass(42) == False — 42 is an int instance, not a class; verified with Python 3.14.3"]
    - [if_fn_true,     isfunction, ["<lambda>"],  true,  "inspect.isfunction(lambda: None) == True — lambda is a Python function; verified with Python 3.14.3"]
    - [if_int_false,   isfunction, [int],         false, "inspect.isfunction(int) == False — int is a type, not a function; verified with Python 3.14.3"]
    - [if_len_false,   isfunction, [len],         false, "inspect.isfunction(len) == False — len is a C builtin, not a Python function; verified with Python 3.14.3"]
    - [ib_len_true,    isbuiltin,  [len],         true,  "inspect.isbuiltin(len) == True — len is a C builtin; verified with Python 3.14.3"]
    - [ib_print_true,  isbuiltin,  [print],       true,  "inspect.isbuiltin(print) == True — print is a C builtin; verified with Python 3.14.3"]
    - [ib_fn_false,    isbuiltin,  ["<lambda>"],  false, "inspect.isbuiltin(lambda: None) == False — lambda is a Python function, not a builtin; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# inspect predicate functions — function identity
#
# All are pure-Python functions defined in inspect.
# Name lengths: isclass=7, ismethod=8, isbuiltin=9, isfunction=10.
# getmembers_static is available from Python 3.11+.
# ---------------------------------------------------------------------------

table inspect_extra273.predicate_identity:
  description: "inspect predicate function identity — __name__, __module__, __class__.__name__; name lengths isclass=7, ismethod=8, isbuiltin=9, isfunction=10; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: inex273pi

  columns: [id, function, args, expected, description]
  rows:
    - [ic_name_eq,   isclass.__name__.__eq__,             ["isclass"],    true, "inspect.isclass.__name__ == 'isclass' (len=7); verified with Python 3.14.3"]
    - [ic_name_len,  isclass.__name__.__len__,            [],             7,    "inspect.isclass.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [ic_mod_eq,    isclass.__module__.__eq__,           ["inspect"],    true, "inspect.isclass.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [ic_cls_eq,    isclass.__class__.__name__.__eq__,   ["function"],   true, "inspect.isclass.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [if_name_eq,   isfunction.__name__.__eq__,          ["isfunction"], true, "inspect.isfunction.__name__ == 'isfunction' (len=10); verified with Python 3.14.3"]
    - [if_name_len,  isfunction.__name__.__len__,         [],             10,   "inspect.isfunction.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [if_mod_eq,    isfunction.__module__.__eq__,        ["inspect"],    true, "inspect.isfunction.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [ib_name_eq,   isbuiltin.__name__.__eq__,           ["isbuiltin"],  true, "inspect.isbuiltin.__name__ == 'isbuiltin' (len=9); verified with Python 3.14.3"]
    - [ib_name_len,  isbuiltin.__name__.__len__,          [],             9,    "inspect.isbuiltin.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [ib_mod_eq,    isbuiltin.__module__.__eq__,         ["inspect"],    true, "inspect.isbuiltin.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [im_name_eq,   ismethod.__name__.__eq__,            ["ismethod"],   true, "inspect.ismethod.__name__ == 'ismethod' (len=8); verified with Python 3.14.3"]
    - [im_name_len,  ismethod.__name__.__len__,           [],             8,    "inspect.ismethod.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [im_mod_eq,    ismethod.__module__.__eq__,          ["inspect"],    true, "inspect.ismethod.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gms_name_eq,  getmembers_static.__name__.__eq__,   ["getmembers_static"], true, "inspect.getmembers_static.__name__ == 'getmembers_static' (3.11+); verified with Python 3.14.3"]
    - [gms_mod_eq,   getmembers_static.__module__.__eq__, ["inspect"],    true, "inspect.getmembers_static.__module__ == 'inspect'; verified with Python 3.14.3"]
    - [gms_cls_eq,   getmembers_static.__class__.__name__.__eq__, ["function"], true, "inspect.getmembers_static.__class__.__name__ == 'function' (pure-Python, 3.11+); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — inspect_extra273
# ---------------------------------------------------------------------------

invariant inspect_extra273.isclass_int_is_true:
  description: "inspect.isclass(int) == True — int is a built-in class"
  category: behavior
  kind: python_call_eq
  function: isclass
  args: [int]
  expected: true

invariant inspect_extra273.isclass_instance_is_false:
  description: "inspect.isclass(42) == False — 42 is an int instance, not a class"
  category: behavior
  kind: python_call_eq
  function: isclass
  args: [42]
  expected: false

invariant inspect_extra273.isfunction_lambda_is_true:
  description: "inspect.isfunction(lambda: None) == True — lambdas are Python functions"
  category: behavior
  kind: python_call_eq
  function: isfunction
  args: ["<lambda>"]
  expected: true

invariant inspect_extra273.isfunction_builtin_is_false:
  description: "inspect.isfunction(len) == False — len is a C builtin, not a Python function object"
  category: behavior
  kind: python_call_eq
  function: isfunction
  args: [len]
  expected: false

invariant inspect_extra273.isbuiltin_len_is_true:
  description: "inspect.isbuiltin(len) == True — len is implemented as a C builtin function"
  category: behavior
  kind: python_call_eq
  function: isbuiltin
  args: [len]
  expected: true

invariant inspect_extra273.isbuiltin_lambda_is_false:
  description: "inspect.isbuiltin(lambda: None) == False — lambda is a Python function, not a C builtin"
  category: behavior
  kind: python_call_eq
  function: isbuiltin
  args: ["<lambda>"]
  expected: false

invariant inspect_extra273.isfunction_name_length_longest_predicate:
  description: "inspect.isfunction.__name__.__len__() == 10 — 'isfunction' is the longest name among isclass(7), ismethod(8), isbuiltin(9), isfunction(10)"
  category: identity
  kind: python_call_eq
  function: isfunction.__name__.__len__
  args: []
  expected: 10

invariant inspect_extra273.all_predicates_module_is_inspect:
  description: "inspect.ismodule.__module__ == 'inspect' — all inspect predicate functions are defined in the inspect module"
  category: identity
  kind: python_call_eq
  function: ismodule.__module__.__eq__
  args: ["inspect"]
  expected: true
