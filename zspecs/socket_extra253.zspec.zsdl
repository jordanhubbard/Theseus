spec: socket_extra253
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "Wave 253 theme: socket.SocketIO class identity and socket.socket dunder method identity."
    - "socket.SocketIO.__name__ == 'SocketIO'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketIO.__module__ == 'socket'. SocketIO is defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketIO.__bases__[0].__name__ == 'RawIOBase'. SocketIO inherits from io.RawIOBase. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.SocketIO.__bases__[0].__module__ == 'io'. RawIOBase is from the io module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__name__ == '__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__init__.__qualname__ == 'socket.__init__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__repr__.__name__ == '__repr__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__enter__.__name__ == '__enter__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__exit__.__name__ == '__exit__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.fileno.__name__ == 'fileno'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.makefile.__name__ == 'makefile'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.detach.__name__ == 'detach'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: SocketIO wraps a socket object as a Python io.RawIOBase stream. It is used internally by socket.makefile() to provide file-like I/O on sockets."
    - "Note: socket.socket is a Python class defined in Lib/socket.py wrapping the C _socket.socket type. Its methods are Python-level functions; __qualname__ follows the 'socket.<method>' pattern."
    - "Note: socket.socket.__init__.__qualname__ is 'socket.__init__' (not 'socket.socket.__init__') because the Python-level socket class is named 'socket' (same as the module), so qualname uses just 'socket'."
    - "Note: socket.socket.fileno, makefile, and detach are Python methods. fileno() returns the integer file descriptor; makefile() returns a SocketIO object; detach() detaches the fd from the socket object."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.SocketIO.__name__.__eq__('SocketIO')
# socket.SocketIO.__module__.__eq__('socket')
# socket.SocketIO.__bases__[0].__name__.__eq__('RawIOBase')
#
# Wave 253 theme: socket.SocketIO class identity.
#
# socket.SocketIO is a Python class defined in Lib/socket.py that wraps a
# socket object as an io.RawIOBase stream. It is used by socket.makefile()
# to provide file-like I/O on sockets. SocketIO.__name__ is 'SocketIO',
# __module__ is 'socket', and its single base class is io.RawIOBase
# (__bases__[0].__name__ == 'RawIOBase', __module__ == 'io').
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra253.SocketIO_class_identity:
  description: "socket.SocketIO class identity — SocketIO.__name__.__eq__('SocketIO')==True / SocketIO.__module__.__eq__('socket')==True / SocketIO.__bases__[0].__name__.__eq__('RawIOBase')==True — SocketIO wraps a socket as an io.RawIOBase stream; used by socket.makefile(); defined in Lib/socket.py; base class is io.RawIOBase (from the 'io' module); wave 253 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockio253

  columns: [id, function, args, expected, description]
  rows:
    - [sio_name,    SocketIO.__name__.__eq__,                    ["SocketIO"], true, "socket.SocketIO.__name__ == 'SocketIO'; Python class wrapping socket as RawIOBase stream"]
    - [sio_module,  SocketIO.__module__.__eq__,                  ["socket"],   true, "socket.SocketIO.__module__ == 'socket'; defined in Lib/socket.py"]
    - [sio_base,    "SocketIO.__bases__[0].__name__.__eq__",     ["RawIOBase"], true, "socket.SocketIO.__bases__[0].__name__ == 'RawIOBase'; inherits from io.RawIOBase for buffered I/O"]

# ---------------------------------------------------------------------------
# socket.socket.__init__.__name__.__eq__('__init__')
# socket.socket.__init__.__qualname__.__eq__('socket.__init__')
# socket.socket.__repr__.__name__.__eq__('__repr__')
# socket.socket.__enter__.__name__.__eq__('__enter__')
# socket.socket.__exit__.__name__.__eq__('__exit__')
#
# Wave 253 theme: socket.socket dunder method __name__ identity.
#
# socket.socket is the Python socket class defined in Lib/socket.py. Its
# dunder methods (__init__, __repr__, __enter__, __exit__) are Python functions.
# __init__.__qualname__ is 'socket.__init__' (the class is named 'socket',
# same as the module, so the qualname uses just 'socket'). __enter__ and
# __exit__ implement the context manager protocol for use in 'with' statements.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra253.socket_dunder_method_names:
  description: "socket.socket dunder method __name__ identity — socket.__init__/__name__.__eq__('__init__')==True / socket.__init__/__qualname__.__eq__('socket.__init__')==True / socket.__repr__/__name__.__eq__('__repr__')==True / socket.__enter__/__name__.__eq__('__enter__')==True / socket.__exit__/__name__.__eq__('__exit__')==True — socket is defined in Lib/socket.py; __qualname__ uses 'socket.' prefix (class named 'socket'); wave 253 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: sockdunder253

  columns: [id, function, args, expected, description]
  rows:
    - [init_name,      socket.__init__.__name__.__eq__,      ["__init__"],          true, "socket.socket.__init__.__name__ == '__init__'; Python constructor method"]
    - [init_qualname,  socket.__init__.__qualname__.__eq__,  ["socket.__init__"],   true, "socket.socket.__init__.__qualname__ == 'socket.__init__'; class is named 'socket' in qualname"]
    - [repr_name,      socket.__repr__.__name__.__eq__,      ["__repr__"],          true, "socket.socket.__repr__.__name__ == '__repr__'; Python repr method"]
    - [enter_name,     socket.__enter__.__name__.__eq__,     ["__enter__"],         true, "socket.socket.__enter__.__name__ == '__enter__'; context manager entry (with statement)"]
    - [exit_name,      socket.__exit__.__name__.__eq__,      ["__exit__"],          true, "socket.socket.__exit__.__name__ == '__exit__'; context manager exit, calls socket.close()"]

# ---------------------------------------------------------------------------
# socket.socket.fileno.__name__.__eq__('fileno')
# socket.socket.makefile.__name__.__eq__('makefile')
# socket.socket.detach.__name__.__eq__('detach')
#
# Wave 253 theme: socket.socket utility method __name__ identity.
#
# socket.socket.fileno returns the integer file descriptor of the socket.
# socket.socket.makefile returns a SocketIO file-like object wrapping the socket.
# socket.socket.detach detaches the underlying file descriptor from the socket
# object and returns it, leaving the socket in a closed state. All are Python
# methods defined in Lib/socket.py. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra253.socket_utility_method_names:
  description: "socket.socket utility method __name__ identity — socket.fileno/__name__.__eq__('fileno')==True / socket.makefile/__name__.__eq__('makefile')==True / socket.detach/__name__.__eq__('detach')==True — fileno() returns integer file descriptor; makefile() returns SocketIO file-like object; detach() removes fd from socket leaving it closed; all Python methods in Lib/socket.py; wave 253 theme; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_identity
  id_prefix: sockdunder253

  columns: [id, function, args, expected, description]
  rows:
    - [fileno_name,    socket.fileno.__name__.__eq__,    ["fileno"],    true, "socket.socket.fileno.__name__ == 'fileno'; returns integer file descriptor of the socket"]
    - [makefile_name,  socket.makefile.__name__.__eq__,  ["makefile"],  true, "socket.socket.makefile.__name__ == 'makefile'; returns SocketIO wrapping the socket for file-like I/O"]
    - [detach_name,    socket.detach.__name__.__eq__,    ["detach"],    true, "socket.socket.detach.__name__ == 'detach'; detaches fd from socket (socket becomes closed), returns fd"]

# ---------------------------------------------------------------------------
# socket.SocketIO.__name__.__eq__('SocketIO') — standalone
#
# socket.SocketIO.__name__ is 'SocketIO'. SocketIO is a Python class defined
# in Lib/socket.py that adapts a socket object to the io.RawIOBase interface.
# socket.socket.makefile() uses SocketIO internally to return a file-like
# object for reading and writing to a socket. SocketIO inherits from io.RawIOBase
# (not io.BufferedIOBase), so it performs unbuffered raw I/O. It is not usually
# instantiated directly by users. This is the first standalone anchor for
# SocketIO.__name__ under sockio253. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra253.SocketIO_name:
  description: "socket.SocketIO.__name__.__eq__('SocketIO') == True — SocketIO adapts a socket to the io.RawIOBase interface; used internally by socket.makefile() to return a file-like socket object; inherits from RawIOBase (unbuffered raw I/O, not BufferedIOBase); defined in Lib/socket.py; not usually instantiated directly; first standalone for SocketIO.__name__ under sockio253; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: type_identity
  kind: python_call_eq
  function: SocketIO.__name__.__eq__
  args: ["SocketIO"]
  expected: true

# ---------------------------------------------------------------------------
# socket.SocketIO.__bases__[0].__name__.__eq__('RawIOBase') — standalone
#
# socket.SocketIO.__bases__[0].__name__ is 'RawIOBase'. SocketIO inherits from
# io.RawIOBase, which is the abstract base class for raw binary I/O in Python's
# io module. RawIOBase defines the read(), readinto(), and write() interface
# for unbuffered binary I/O. SocketIO overrides these methods to delegate to the
# underlying socket object. The base class RawIOBase is from the 'io' module
# (its __module__ is 'io'). SocketIO has exactly one base class.
# This is the first standalone anchor for SocketIO base class identity under
# sockio253. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra253.SocketIO_base_is_RawIOBase:
  description: "socket.SocketIO.__bases__[0].__name__.__eq__('RawIOBase') == True — SocketIO inherits from io.RawIOBase (unbuffered raw binary I/O ABC); RawIOBase defines read/readinto/write interface; SocketIO delegates these to the underlying socket; base class __module__ is 'io'; SocketIO has exactly one base class; first standalone for SocketIO base class identity under sockio253; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: type_identity
  kind: python_call_eq
  function: "SocketIO.__bases__[0].__name__.__eq__"
  args: ["RawIOBase"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__enter__.__name__.__eq__('__enter__') — standalone
#
# socket.socket.__enter__.__name__ is '__enter__'. socket.socket implements the
# context manager protocol via __enter__ and __exit__, allowing sockets to be
# used in 'with' statements. socket.__enter__ returns the socket itself (self),
# while socket.__exit__ calls socket.close() to ensure the socket is closed when
# the with block exits, regardless of exceptions. This pattern is the recommended
# way to manage socket lifetimes and ensure proper resource cleanup. socket.__enter__
# is a Python function defined in Lib/socket.py. This is the first standalone
# anchor for socket.__enter__.__name__ under sockdunder253.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra253.socket_enter_name:
  description: "socket.socket.__enter__.__name__.__eq__('__enter__') == True — socket.__enter__ implements the context manager entry for use in 'with' statements; returns self (the socket); paired with __exit__ which calls socket.close(); recommended pattern for socket resource management; Python function in Lib/socket.py; first standalone for socket.__enter__.__name__ under sockdunder253; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: method_identity
  kind: python_call_eq
  function: socket.__enter__.__name__.__eq__
  args: ["__enter__"]
  expected: true
