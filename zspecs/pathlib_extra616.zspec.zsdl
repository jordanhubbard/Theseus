spec: pathlib_extra616
version: ">=3.9"
backend: python_module(pathlib)
docs: "Behavioral specs for pathlib.PurePath property descriptors and pathlib.Path method qualnames."
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module PurePath and Path classes"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers __class__.__name__ of PurePath property descriptors and __qualname__ of Path methods"
  created_at: "2026-04-12T00:00:00Z"

table pathlib_extra616.purepath_property_descriptors:
  description: "PurePath attributes that are property descriptors (class-level __class__.__name__ checks)"
  kind: python_call_eq
  category: property_descriptors
  id_prefix: pl616qn
  columns: [id, function, args, expected]
  rows:
    - [pl616qn001, pathlib.PurePath.name.__class__.__name__.__eq__, ["property"], true]
    - [pl616qn002, pathlib.PurePath.suffix.__class__.__name__.__eq__, ["property"], true]
    - [pl616qn003, pathlib.PurePath.suffixes.__class__.__name__.__eq__, ["property"], true]
    - [pl616qn004, pathlib.PurePath.stem.__class__.__name__.__eq__, ["property"], true]
    - [pl616qn005, pathlib.PurePath.parent.__class__.__name__.__eq__, ["property"], true]
    - [pl616qn006, pathlib.PurePath.parents.__class__.__name__.__eq__, ["property"], true]
    - [pl616qn007, pathlib.PurePath.parts.__class__.__name__.__eq__, ["property"], true]
    - [pl616qn008, pathlib.PurePath.root.__class__.__name__.__eq__, ["property"], true]
    - [pl616qn009, pathlib.PurePath.drive.__class__.__name__.__eq__, ["property"], true]
    - [pl616qn010, pathlib.PurePath.anchor.__class__.__name__.__eq__, ["property"], true]

table pathlib_extra616.path_method_qualnames:
  description: "Path method __qualname__ attributes"
  kind: python_call_eq
  category: method_metadata
  id_prefix: pl616dc
  columns: [id, function, args, expected]
  rows:
    - [pl616dc001, pathlib.Path.stat.__qualname__.__eq__, ["Path.stat"], true]
    - [pl616dc002, pathlib.Path.lstat.__qualname__.__eq__, ["Path.lstat"], true]
    - [pl616dc003, pathlib.Path.resolve.__qualname__.__eq__, ["Path.resolve"], true]
    - [pl616dc004, pathlib.Path.absolute.__qualname__.__eq__, ["Path.absolute"], true]
