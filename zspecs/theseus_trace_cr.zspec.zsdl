spec: theseus_trace_cr
version: ">=3.8"
backend: python_cleanroom(theseus_trace_cr)
blocks: trace

docs: https://docs.python.org/3/library/trace.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/trace.html"
  not_derived_from:
    - "CPython source: Lib/trace.py"
  notes:
    - "Clean-room trace module. Do NOT import trace."

error_model: python_exceptions

invariant theseus_trace_cr.trace2_create:
  description: "Trace() can be created with count=True"
  category: behavior
  kind: python_call_eq
  function: trace2_create
  args: []
  expected: true

invariant theseus_trace_cr.trace2_runfunc:
  description: "runfunc() executes a function and returns its result"
  category: behavior
  kind: python_call_eq
  function: trace2_runfunc
  args: []
  expected: true

invariant theseus_trace_cr.trace2_results:
  description: "results() returns a CoverageResults after runfunc()"
  category: behavior
  kind: python_call_eq
  function: trace2_results
  args: []
  expected: true
