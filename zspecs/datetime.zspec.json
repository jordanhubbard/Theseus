  "provenance": {
    "derived_from": [
      "Python 3 datetime documentation — https://docs.python.org/3/library/datetime.html",
      "ISO 8601 date/time format specification",
      "Test vectors verified with Python 3.12 on macOS/Darwin 25.3.0, 2026-04-02"
    ],
    "not_derived_from": ["CPython datetime source: Modules/_datetimemodule.c"],
    "spec_authors": ["Theseus Z-layer"],
    "created_at": "2026-04-02T00:00:00Z",
    "notes": [
      "All invariants use fixed dates/times to avoid non-determinism. date.today() and datetime.now() are not tested.",
      "Dotted function names (e.g. 'date.fromisoformat') are resolved by the harness via chained getattr from the module root.",
      "date objects compare equal to other date objects with the same year/month/day; isoformat() is used for serialisable comparison.",
      "timedelta arithmetic is tested via date + timedelta → isoformat() since the harness needs a serialisable result.",
      "weekday() returns 0=Monday through 6=Sunday (ISO convention)."
    ]
  },

  "library": {
    "backend": "python_module",
    "module_name": "datetime",
    "soname_patterns": []
  },

  "constants": {},
  "types": {},
  "wire_formats": {},

  "functions": {
    "date": {
      "description": "Construct a date from year, month, day.",
      "parameters": [
        {"name": "year",  "type": "int", "direction": "in"},
        {"name": "month", "type": "int", "direction": "in"},
        {"name": "day",   "type": "int", "direction": "in"}
      ],
      "return_type": "date"
    },
    "date.fromisoformat": {
      "description": "Parse an ISO 8601 date string (YYYY-MM-DD) into a date object.",
      "parameters": [{"name": "date_string", "type": "str", "direction": "in"}],
      "return_type": "date"
    },
    "datetime.fromisoformat": {
      "description": "Parse an ISO 8601 datetime string into a datetime object.",
      "parameters": [{"name": "datetime_string", "type": "str", "direction": "in"}],
      "return_type": "datetime"
    },
    "timedelta": {
      "description": "Represent a duration.",
      "parameters": [
        {"name": "days",    "type": "int", "direction": "in"},
        {"name": "seconds", "type": "int", "direction": "in"}
      ],
      "return_type": "timedelta"
    }
  },

