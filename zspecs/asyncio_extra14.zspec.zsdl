spec: asyncio_extra14
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-eventloop.html — asyncio event loop"
    - "https://docs.python.org/3/library/asyncio-protocol.html — asyncio Protocols"
    - "https://docs.python.org/3/library/asyncio-transport.html — asyncio Transports"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/asyncio/transports.py"
    - "CPython source: Lib/asyncio/events.py"
    - "CPython source: Lib/asyncio/protocols.py"
  notes:
    - "Extends asyncio.zspec.zsdl, asyncio_events.zspec.zsdl, asyncio_extra.zspec.zsdl through asyncio_extra13.zspec.zsdl."
    - "asyncio_events covers: AbstractEventLoop/__name__, BaseEventLoop/__name__, Handle/__name__, TimerHandle/__name__, Protocol/__name__, DatagramProtocol/__name__, Handle/__module__, TimerHandle/__module__, BaseProtocol/__module__, TimerHandle.__bases__[0].__name__, Protocol.__bases__[0].__name__."
    - "asyncio_extra2 covers: AbstractEventLoop/__module__, BaseEventLoop/__module__, AbstractEventLoop/__name__ (repeated), BaseEventLoop/__name__ (repeated)."
    - "asyncio_extra7 covers: AbstractEventLoop/__qualname__, BaseEventLoop/__qualname__, AbstractEventLoopPolicy/__qualname__."
    - "NOT yet covered in any prior spec: Transport.__name__ == 'Transport' — transport class identity."
    - "NOT yet covered: Transport.__qualname__ == 'Transport'."
    - "NOT yet covered: Transport.__module__ == 'asyncio.transports'."
    - "NOT yet covered: BaseTransport.__name__ == 'BaseTransport'."
    - "NOT yet covered: BaseTransport.__qualname__ == 'BaseTransport'."
    - "NOT yet covered: BaseTransport.__module__ == 'asyncio.transports'."
    - "NOT yet covered: ReadTransport.__name__ == 'ReadTransport'."
    - "NOT yet covered: ReadTransport.__module__ == 'asyncio.transports'."
    - "NOT yet covered: WriteTransport.__name__ == 'WriteTransport'."
    - "NOT yet covered: WriteTransport.__module__ == 'asyncio.transports'."
    - "NOT yet covered: AbstractServer.__name__ == 'AbstractServer'."
    - "NOT yet covered: AbstractServer.__qualname__ == 'AbstractServer'."
    - "NOT yet covered: AbstractServer.__module__ == 'asyncio.events'."
    - "NOT yet covered: AbstractServer.__bases__[0].__name__ == 'object'."
    - "NOT yet covered: Transport.__class__.__name__ == 'type'."
    - "NOT yet covered: BaseTransport.__class__.__name__ == 'type'."
    - "NOT yet covered: AbstractServer.__class__.__name__ == 'type'."
    - "NOT yet covered: BaseTransport.__bases__[0].__name__ == 'object'."
    - "asyncio.Transport.__module__ == 'asyncio.transports' — Transport is defined in asyncio/transports.py."
    - "asyncio.BaseTransport.__module__ == 'asyncio.transports'."
    - "asyncio.Transport.__mro__ is [Transport, ReadTransport, WriteTransport, BaseTransport, object]."
    - "asyncio.AbstractServer.__bases__[0].__name__ == 'object' — AbstractServer inherits directly from object."
    - "asyncio.BaseTransport.__bases__[0].__name__ == 'object' — BaseTransport is the root transport ABC."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Transport and BaseTransport class identity — __name__, __qualname__, __module__
#
# asyncio_events covers Handle/TimerHandle/Protocol/DatagramProtocol/__name__
# and their __module__. No prior asyncio spec checks Transport, BaseTransport,
# ReadTransport, or WriteTransport __name__/__qualname__/__module__. These four
# classes are defined in asyncio/transports.py.
# ---------------------------------------------------------------------------

table asyncio_extra14.transport_class_names:
  description: "asyncio transport classes have correct __name__ values"
  kind: python_call_eq
  category: class_names
  id_prefix: tpcname

  columns: [id, function, args, expected]
  rows:
    - [Transport,      Transport.__name__.__eq__,      ["Transport"],      true]
    - [BaseTransport,  BaseTransport.__name__.__eq__,  ["BaseTransport"],  true]
    - [ReadTransport,  ReadTransport.__name__.__eq__,  ["ReadTransport"],  true]
    - [WriteTransport, WriteTransport.__name__.__eq__, ["WriteTransport"], true]

table asyncio_extra14.transport_class_qualnames:
  description: "asyncio transport classes have correct __qualname__ values"
  kind: python_call_eq
  category: class_names
  id_prefix: tpcqname

  columns: [id, function, args, expected]
  rows:
    - [Transport,      Transport.__qualname__.__eq__,      ["Transport"],      true]
    - [BaseTransport,  BaseTransport.__qualname__.__eq__,  ["BaseTransport"],  true]
    - [ReadTransport,  ReadTransport.__qualname__.__eq__,  ["ReadTransport"],  true]
    - [WriteTransport, WriteTransport.__qualname__.__eq__, ["WriteTransport"], true]

table asyncio_extra14.transport_class_modules:
  description: "asyncio transport classes have __module__ == 'asyncio.transports'"
  kind: python_call_eq
  category: class_modules
  id_prefix: tpcmod

  columns: [id, function, args, expected]
  rows:
    - [Transport,      Transport.__module__.__eq__,      ["asyncio.transports"], true]
    - [BaseTransport,  BaseTransport.__module__.__eq__,  ["asyncio.transports"], true]
    - [ReadTransport,  ReadTransport.__module__.__eq__,  ["asyncio.transports"], true]
    - [WriteTransport, WriteTransport.__module__.__eq__, ["asyncio.transports"], true]

# ---------------------------------------------------------------------------
# AbstractServer class identity — __name__, __qualname__, __module__
#
# asyncio_events covers AbstractEventLoop and BaseEventLoop names. No prior
# spec checks AbstractServer. AbstractServer is defined in asyncio/events.py,
# inherits directly from object, and is the ABC used as the return type
# of loop.create_server() calls.
# ---------------------------------------------------------------------------

invariant asyncio_extra14.AbstractServer.name:
  description: "asyncio.AbstractServer.__name__ == 'AbstractServer'"
  category: class_names
  kind: python_call_eq
  function: AbstractServer.__name__.__eq__
  args: ["AbstractServer"]
  expected: true

invariant asyncio_extra14.AbstractServer.qualname:
  description: "asyncio.AbstractServer.__qualname__ == 'AbstractServer'"
  category: class_names
  kind: python_call_eq
  function: AbstractServer.__qualname__.__eq__
  args: ["AbstractServer"]
  expected: true

invariant asyncio_extra14.AbstractServer.module:
  description: "asyncio.AbstractServer.__module__ == 'asyncio.events'"
  category: class_modules
  kind: python_call_eq
  function: AbstractServer.__module__.__eq__
  args: ["asyncio.events"]
  expected: true

invariant asyncio_extra14.AbstractServer.base:
  description: "asyncio.AbstractServer.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: AbstractServer.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Class-level __class__.__name__ — metaclass checks for transport/server ABCs
#
# asyncio_extra12/13 cover metaclass checks for Task/Future/Lock/Queue and
# stream/sync primitives. No prior spec checks __class__.__name__ for
# Transport, BaseTransport, or AbstractServer.
# ---------------------------------------------------------------------------

table asyncio_extra14.transport_metaclass_names:
  description: "asyncio transport and server ABCs have __class__.__name__ == 'type'"
  kind: python_call_eq
  category: class_types
  id_prefix: tpmeta

  columns: [id, function, args, expected]
  rows:
    - [Transport,      Transport.__class__.__name__.__eq__,      ["type"], true]
    - [BaseTransport,  BaseTransport.__class__.__name__.__eq__,  ["type"], true]
    - [AbstractServer, AbstractServer.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# BaseTransport hierarchy — base class check
#
# No prior asyncio spec checks BaseTransport.__bases__[0].__name__. BaseTransport
# is the root of the transport hierarchy and inherits directly from object.
# ---------------------------------------------------------------------------

invariant asyncio_extra14.BaseTransport.base:
  description: "asyncio.BaseTransport.__bases__[0].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: BaseTransport.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
