spec: subprocess_extra15
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
    - "subprocess_extra6.zspec.zsdl — covers __qualname__ equality for Popen/CompletedProcess/CalledProcessError/TimeoutExpired/SubprocessError/run/call/check_call/check_output/getoutput/getstatusoutput"
    - "subprocess_extra.zspec.zsdl — covers PIPE/STDOUT/DEVNULL __class__.__name__ == 'int' in a table"
    - "subprocess_extra14.zspec.zsdl — covers CalledProcessError/TimeoutExpired/SubprocessError/Popen __bases__[0].__name__; run/check_output/check_call/call __module__"
  notes:
    - "This spec extends subprocess.zspec.zsdl and all prior subprocess_extra specs through subprocess_extra14.zspec.zsdl."
    - "Focus: __qualname__ string lengths for subprocess classes and functions — a new axis not covered in any prior subprocess spec."
    - "subprocess.Popen.__qualname__.__len__() == 5 — 'Popen' has 5 characters."
    - "subprocess.CompletedProcess.__qualname__.__len__() == 16 — 'CompletedProcess' has 16 characters."
    - "subprocess.CalledProcessError.__qualname__.__len__() == 18 — 'CalledProcessError' has 18 characters."
    - "subprocess.TimeoutExpired.__qualname__.__len__() == 14 — 'TimeoutExpired' has 14 characters."
    - "subprocess.run.__qualname__.__len__() == 3 — 'run' has 3 characters."
    - "subprocess.call.__qualname__.__len__() == 4 — 'call' has 4 characters."
    - "subprocess.check_output.__qualname__.__len__() == 12 — 'check_output' has 12 characters."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ length table — Popen, CompletedProcess, CalledProcessError,
# TimeoutExpired, run, call, check_output
#
# subprocess_extra6 covers __qualname__ equality for all these names.
# No prior subprocess spec covers the __len__() of any __qualname__ string.
# This table anchors qualname-length facts for the seven most-used subprocess
# classes and functions in the extra15 namespace.
# ---------------------------------------------------------------------------

table subprocess_extra15.qualname_lengths:
  description: "__qualname__ string length for core subprocess classes and functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: qlen15

  columns: [id, function, args, expected]
  rows:
    - [Popen,              Popen.__qualname__.__len__,              [], 5]
    - [CompletedProcess,   CompletedProcess.__qualname__.__len__,   [], 16]
    - [CalledProcessError, CalledProcessError.__qualname__.__len__, [], 18]
    - [TimeoutExpired,     TimeoutExpired.__qualname__.__len__,     [], 14]
    - [run,                run.__qualname__.__len__,                [], 3]
    - [call,               call.__qualname__.__len__,               [], 4]
    - [check_output,       check_output.__qualname__.__len__,       [], 12]

# ---------------------------------------------------------------------------
# Standalone qualname length invariants
#
# Each invariant below provides an individually addressable check for one
# name's qualname length — separate from the table above, anchored in the
# extra15 standalone namespace.
# ---------------------------------------------------------------------------

invariant subprocess_extra15.Popen.qualname_length:
  description: "subprocess.Popen.__qualname__.__len__() == 5 — 'Popen' has 5 characters"
  category: function_identity
  kind: python_call_eq
  function: Popen.__qualname__.__len__
  args: []
  expected: 5

invariant subprocess_extra15.CompletedProcess.qualname_length:
  description: "subprocess.CompletedProcess.__qualname__.__len__() == 16 — 'CompletedProcess' has 16 characters"
  category: function_identity
  kind: python_call_eq
  function: CompletedProcess.__qualname__.__len__
  args: []
  expected: 16

invariant subprocess_extra15.CalledProcessError.qualname_length:
  description: "subprocess.CalledProcessError.__qualname__.__len__() == 18 — 'CalledProcessError' has 18 characters"
  category: function_identity
  kind: python_call_eq
  function: CalledProcessError.__qualname__.__len__
  args: []
  expected: 18

invariant subprocess_extra15.TimeoutExpired.qualname_length:
  description: "subprocess.TimeoutExpired.__qualname__.__len__() == 14 — 'TimeoutExpired' has 14 characters"
  category: function_identity
  kind: python_call_eq
  function: TimeoutExpired.__qualname__.__len__
  args: []
  expected: 14

invariant subprocess_extra15.run.qualname_length:
  description: "subprocess.run.__qualname__.__len__() == 3 — 'run' has 3 characters"
  category: function_identity
  kind: python_call_eq
  function: run.__qualname__.__len__
  args: []
  expected: 3

invariant subprocess_extra15.call.qualname_length:
  description: "subprocess.call.__qualname__.__len__() == 4 — 'call' has 4 characters"
  category: function_identity
  kind: python_call_eq
  function: call.__qualname__.__len__
  args: []
  expected: 4

invariant subprocess_extra15.check_output.qualname_length:
  description: "subprocess.check_output.__qualname__.__len__() == 12 — 'check_output' has 12 characters"
  category: function_identity
  kind: python_call_eq
  function: check_output.__qualname__.__len__
  args: []
  expected: 12
