spec: io_extra2611
version: ">=3.9"
backend: python_module(io)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 io documentation — https://docs.python.org/3/library/io.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Modules/_io/bytesio.c"
    - "CPython source: Modules/_io/stringio.c"
    - "io_extra.zspec.zsdl — covers existing io invariants"
    - "io_extra2596.zspec.zsdl — covers __get__/__set__/__delete__ dict-presence"
  notes:
    - "Wave 621 (io_extra2611) theme: __init_subclass__, __subclasshook__, and __class_getitem__ dict-presence checks."
    - "None of the io classes define __init_subclass__, __subclasshook__, or __class_getitem__ in their own __dict__."
    - "io.IOBase is an abstract base class (ABCMeta); it does NOT define __subclasshook__ in its own __dict__ — ABCMeta provides __subclasshook__ on the metaclass, not the class."
    - "io stream classes (BytesIO, StringIO, FileIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper) are I/O objects, not generic aliases — they do not define __class_getitem__."
    - "Abstract base classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase) similarly lack __init_subclass__ and __class_getitem__ in their own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __init_subclass__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2611.no_init_subclass_in_io_classes:
  description: "__init_subclass__ is absent from all io class __dict__s — io stream classes do not override __init_subclass__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2611

  columns: [id, function, args, expected]
  rows:
    - ["io2611001", "io.IOBase.__dict__.__contains__",         ["__init_subclass__"], false]
    - ["io2611002", "io.RawIOBase.__dict__.__contains__",      ["__init_subclass__"], false]
    - ["io2611003", "io.BufferedIOBase.__dict__.__contains__", ["__init_subclass__"], false]
    - ["io2611004", "io.TextIOBase.__dict__.__contains__",     ["__init_subclass__"], false]
    - ["io2611005", "io.BytesIO.__dict__.__contains__",        ["__init_subclass__"], false]
    - ["io2611006", "io.StringIO.__dict__.__contains__",       ["__init_subclass__"], false]

# ---------------------------------------------------------------------------
# __subclasshook__ dict-presence — io abstract base classes and concrete classes
# ---------------------------------------------------------------------------

table io_extra2611.no_subclasshook_in_io_classes:
  description: "__subclasshook__ is absent from all io class __dict__s — ABCMeta provides __subclasshook__ on the metaclass, not on IOBase or its subclasses"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2611

  columns: [id, function, args, expected]
  rows:
    - ["io2611007", "io.IOBase.__dict__.__contains__",        ["__subclasshook__"], false]
    - ["io2611008", "io.BytesIO.__dict__.__contains__",       ["__subclasshook__"], false]
    - ["io2611009", "io.StringIO.__dict__.__contains__",      ["__subclasshook__"], false]
    - ["io2611010", "io.FileIO.__dict__.__contains__",        ["__subclasshook__"], false]
    - ["io2611011", "io.BufferedReader.__dict__.__contains__", ["__subclasshook__"], false]
    - ["io2611012", "io.BufferedWriter.__dict__.__contains__", ["__subclasshook__"], false]

# ---------------------------------------------------------------------------
# __class_getitem__ dict-presence — io concrete I/O classes
# ---------------------------------------------------------------------------

table io_extra2611.no_class_getitem_in_io_classes:
  description: "__class_getitem__ is absent from all io class __dict__s — io stream classes are not generic aliases"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2611

  columns: [id, function, args, expected]
  rows:
    - ["io2611013", "io.IOBase.__dict__.__contains__",         ["__class_getitem__"], false]
    - ["io2611014", "io.BytesIO.__dict__.__contains__",        ["__class_getitem__"], false]
    - ["io2611015", "io.StringIO.__dict__.__contains__",       ["__class_getitem__"], false]
    - ["io2611016", "io.FileIO.__dict__.__contains__",         ["__class_getitem__"], false]
    - ["io2611017", "io.BufferedRandom.__dict__.__contains__", ["__class_getitem__"], false]
    - ["io2611018", "io.TextIOWrapper.__dict__.__contains__",  ["__class_getitem__"], false]

# ---------------------------------------------------------------------------
# Complementary: io.BytesIO and io.StringIO HAVE normal I/O methods but NOT subclassing protocol methods
# Confirms that io classes define domain-specific methods, never subclass customization hooks
# ---------------------------------------------------------------------------

table io_extra2611.io_has_stream_methods_not_subclass_hooks:
  description: "io.BytesIO and io.StringIO define read/write/getvalue but NOT __init_subclass__/__subclasshook__/__class_getitem__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: io2611

  columns: [id, function, args, expected]
  rows:
    - ["io2611019", "io.BytesIO.__dict__.__contains__",  ["read"],               true]
    - ["io2611020", "io.BytesIO.__dict__.__contains__",  ["write"],              true]
    - ["io2611021", "io.BytesIO.__dict__.__contains__",  ["getvalue"],           true]
    - ["io2611022", "io.BytesIO.__dict__.__contains__",  ["__init_subclass__"],  false]
    - ["io2611023", "io.BytesIO.__dict__.__contains__",  ["__subclasshook__"],   false]
    - ["io2611024", "io.BytesIO.__dict__.__contains__",  ["__class_getitem__"],  false]
