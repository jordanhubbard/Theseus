spec: functools_extra1936
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 576 (_extra1936): __get__/__set__/__delete__ descriptor protocol dict-presence checks, __set_name__ dict presence, __class__ attribute value checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "functools.cached_property defines __get__ and __set_name__ but not __set__ or __delete__."
    - "functools.partial and functools.partialmethod define __get__ but not __set__ or __delete__."
    - "_lru_cache_wrapper (result of applying lru_cache) defines __get__ but not __set__ or __delete__."
  created_at: "2026-04-12"
error_model: python_exceptions

table functools_extra1936.descriptor_protocol:
  description: "functools types __get__/__set__/__delete__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft1936
  columns: [id, function, args, expected]
  rows:
    - ["ft1936001", "functools.partial.__dict__.__contains__",           ["__get__"],    true]
    - ["ft1936002", "functools.partial.__dict__.__contains__",           ["__set__"],    false]
    - ["ft1936003", "functools.partial.__dict__.__contains__",           ["__delete__"], false]
    - ["ft1936004", "functools.partialmethod.__dict__.__contains__",     ["__get__"],    true]
    - ["ft1936005", "functools.partialmethod.__dict__.__contains__",     ["__set__"],    false]
    - ["ft1936006", "functools.partialmethod.__dict__.__contains__",     ["__delete__"], false]
    - ["ft1936007", "functools.cached_property.__dict__.__contains__",   ["__get__"],    true]
    - ["ft1936008", "functools.cached_property.__dict__.__contains__",   ["__set__"],    false]
    - ["ft1936009", "functools.cached_property.__dict__.__contains__",   ["__delete__"], false]

table functools_extra1936.set_name_presence:
  description: "functools types __set_name__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft1936
  columns: [id, function, args, expected]
  rows:
    - ["ft1936010", "functools.partial.__dict__.__contains__",           ["__set_name__"], false]
    - ["ft1936011", "functools.partialmethod.__dict__.__contains__",     ["__set_name__"], false]
    - ["ft1936012", "functools.cached_property.__dict__.__contains__",   ["__set_name__"], true]

table functools_extra1936.lru_cache_wrapper_descriptor:
  description: "_lru_cache_wrapper descriptor dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft1936
  columns: [id, function, args, expected]
  rows:
    - ["ft1936013", "functools.lru_cache.__class__.__name__.__eq__",     ["function"],   true]
    - ["ft1936014", "functools.lru_cache.__class__.__name__.__contains__", ["function"], true]

table functools_extra1936.class_name_checks:
  description: "functools type __class__.__name__ identity checks"
  kind: python_call_eq
  category: class_name
  id_prefix: ft1936
  columns: [id, function, args, expected]
  rows:
    - ["ft1936015", "functools.reduce.__class__.__name__.__eq__",           ["builtin_function_or_method"], true]
    - ["ft1936016", "functools.partial.__class__.__name__.__eq__",          ["type"],                       true]
    - ["ft1936017", "functools.partialmethod.__class__.__name__.__eq__",    ["type"],                       true]
    - ["ft1936018", "functools.cached_property.__class__.__name__.__eq__",  ["type"],                       true]
    - ["ft1936019", "functools.lru_cache.__class__.__name__.__eq__",        ["function"],                   true]
    - ["ft1936020", "functools.__class__.__name__.__eq__",                  ["module"],                     true]
    - ["ft1936021", "functools.WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__", ["tuple"],                   true]

table functools_extra1936.instance_class_name_checks:
  description: "functools instance __class__.__name__ identity checks"
  kind: python_call_eq
  category: class_name
  id_prefix: ft1936
  columns: [id, function, args, expected]
  rows:
    - ["ft1936022", "functools.partial.__name__.__eq__",                    ["partial"],        true]
    - ["ft1936023", "functools.partialmethod.__name__.__eq__",              ["partialmethod"],  true]
    - ["ft1936024", "functools.cached_property.__name__.__eq__",            ["cached_property"], true]
    - ["ft1936025", "functools.partial.__qualname__.__eq__",                ["partial"],        true]
    - ["ft1936026", "functools.partialmethod.__qualname__.__eq__",          ["partialmethod"],  true]
    - ["ft1936027", "functools.cached_property.__qualname__.__eq__",        ["cached_property"], true]

table functools_extra1936.descriptor_get_qualnames:
  description: "functools descriptor __get__ and __set_name__ qualname checks"
  kind: python_call_eq
  category: qualname
  id_prefix: ft1936
  columns: [id, function, args, expected]
  rows:
    - ["ft1936028", "functools.partial.__get__.__qualname__.__eq__",        ["partial.__get__"],                 true]
    - ["ft1936029", "functools.partialmethod.__get__.__qualname__.__eq__",  ["partialmethod.__get__"],           true]
    - ["ft1936030", "functools.cached_property.__get__.__qualname__.__eq__", ["cached_property.__get__"],       true]
    - ["ft1936031", "functools.cached_property.__set_name__.__qualname__.__eq__", ["cached_property.__set_name__"], true]
    - ["ft1936032", "functools.partial.__module__.__eq__",                  ["functools"],                       true]
    - ["ft1936033", "functools.partialmethod.__module__.__eq__",            ["functools"],                       true]
    - ["ft1936034", "functools.cached_property.__module__.__eq__",          ["functools"],                       true]
