spec: asyncio_extra117
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-task.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-task.html — Python asyncio task documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py"
    - "CPython source: Modules/_asyncio.c"
  notes:
    - "This spec extends asyncio_extra116.zspec.zsdl."
    - "This spec covers: wave 257 theme — asyncio.Task class method __qualname__ string equality for the name-based accessor methods not previously covered as equality checks. Prior specs covered: extra103 covered cancel/result/done/exception/add_done_callback __qualname__ equality; extra96 covered ALL method __qualname__ lengths; extra13 covered get_name/set_name __qualname__ equality. NOT previously covered as __qualname__.__eq__ checks: Task.get_coro (len=13), Task.get_context (len=16), Task.remove_done_callback (len=25). NEW in extra117: Task.get_coro.__qualname__.__eq__('Task.get_coro')==True; Task.get_context.__qualname__.__eq__('Task.get_context')==True; Task.remove_done_callback.__qualname__.__eq__('Task.remove_done_callback')==True; plus Task class-level __qualname__.__class__.__name__=='str', Task.__mro__.__len__()==3, Task.__bases__[0].__name__=='Future'. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Task.get_coro.__qualname__ == 'Task.get_coro' (len=13: 'Task.'=5+'get_coro'=8=13). Task.get_name.__qualname__ == 'Task.get_name' (len=13, same). Task.set_name.__qualname__ == 'Task.set_name' (len=13, same). All three get_*/set_* accessor methods share qualname length=13. Task.get_context.__qualname__ == 'Task.get_context' (len=16). Task.remove_done_callback.__qualname__ == 'Task.remove_done_callback' (len=25, longest Task qualname). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "asyncio.Task.__mro__.__len__() == 3: [Task, Future, object]. Task inherits from Future (Task.__bases__[0].__name__=='Future'). Task.__module__=='_asyncio' (C extension). Task.__qualname__.__class__.__name__=='str' (qualname is a string). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.Task accessor method __qualname__ equality — extra117
#
# Wave 257 theme: get_coro, get_context, remove_done_callback __qualname__ equality.
#
# asyncio.Task.get_coro.__qualname__              == 'Task.get_coro'              (len=13)
# asyncio.Task.get_name.__qualname__              == 'Task.get_name'              (len=13, covered extra13)
# asyncio.Task.set_name.__qualname__              == 'Task.set_name'              (len=13, covered extra13)
# asyncio.Task.get_context.__qualname__           == 'Task.get_context'           (len=16)
# asyncio.Task.remove_done_callback.__qualname__  == 'Task.remove_done_callback'  (len=25, longest)
# ---------------------------------------------------------------------------

table asyncio_extra117.task_accessor_qualname_eq:
  description: "asyncio.Task accessor method __qualname__ equality checks in taskacc117 namespace — wave 257 theme: Task.get_coro/__qualname__/__eq__('Task.get_coro')==True (len=13: 'Task.'=5+'get_coro'=8=13; get_coro returns the coroutine object wrapped by the Task; it is a method_descriptor from the C extension _asyncio, yet __qualname__ is a plain str); Task.get_name/__qualname__/__eq__('Task.get_name')==True (len=13, tied with get_coro; get_name returns the task name set via Task(name=...) or set_name); Task.set_name/__qualname__/__eq__('Task.set_name')==True (len=13, three-way tie at 13: get_coro==get_name==set_name; set_name assigns a new name to the task); Task.get_context/__qualname__/__eq__('Task.get_context')==True (len=16: 'Task.'=5+'get_context'=11=16; get_context returns the contextvars.Context object the task runs in); Task.remove_done_callback/__qualname__/__eq__('Task.remove_done_callback')==True (len=25: 'Task.'=5+'remove_done_callback'=20=25; longest Task method qualname; removes a callback registered with add_done_callback); compare qualname lengths: get_coro==get_name==set_name=13 (tied, shortest accessor group) < get_context=16 < remove_done_callback=25 (longest); all five are method_descriptor objects in the C extension _asyncio; their __qualname__ is a str (type='str'); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: taskacc117

  columns: [id, function, args, expected, description]
  rows:
    - [getcoro_eq,   Task.get_coro.__qualname__.__eq__,              ["Task.get_coro"],              true, "Task.get_coro.__qualname__ == 'Task.get_coro' (len=13); verified with Python 3.14.3"]
    - [getcoro_len,  Task.get_coro.__qualname__.__len__,             [],                             13,   "Task.get_coro.__qualname__.__len__() == 13 ('Task.get_coro'=13); verified with Python 3.14.3"]
    - [getname_eq,   Task.get_name.__qualname__.__eq__,              ["Task.get_name"],              true, "Task.get_name.__qualname__ == 'Task.get_name' (len=13, tied with get_coro); verified with Python 3.14.3"]
    - [setname_eq,   Task.set_name.__qualname__.__eq__,              ["Task.set_name"],              true, "Task.set_name.__qualname__ == 'Task.set_name' (len=13, three-way tie: get_coro==get_name==set_name=13); verified with Python 3.14.3"]
    - [getctx_eq,    Task.get_context.__qualname__.__eq__,           ["Task.get_context"],           true, "Task.get_context.__qualname__ == 'Task.get_context' (len=16); verified with Python 3.14.3"]
    - [getctx_len,   Task.get_context.__qualname__.__len__,          [],                             16,   "Task.get_context.__qualname__.__len__() == 16 ('Task.get_context'=16); verified with Python 3.14.3"]
    - [rdc_eq,       Task.remove_done_callback.__qualname__.__eq__,  ["Task.remove_done_callback"],  true, "Task.remove_done_callback.__qualname__ == 'Task.remove_done_callback' (len=25, longest Task method qualname); verified with Python 3.14.3"]
    - [rdc_len,      Task.remove_done_callback.__qualname__.__len__, [],                             25,   "Task.remove_done_callback.__qualname__.__len__() == 25 (longest Task method qualname); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Task class __qualname__ type and __mro__ — extra117
#
# Wave 257 theme: Task class __qualname__.__class__.__name__ and __mro__ length.
#
# asyncio.Task.__qualname__.__class__.__name__  == 'str'  (qualname is a string)
# asyncio.Task.__mro__.__len__()                == 3      ([Task, Future, object])
# asyncio.Task.__bases__[0].__name__            == 'Future'
# asyncio.Task.__name__.__len__()               == 4
# asyncio.Task.__module__.__len__()             == 8
# ---------------------------------------------------------------------------

table asyncio_extra117.task_class_identity:
  description: "asyncio.Task class __qualname__ type and __mro__ checks in taskacc117 namespace — wave 257 theme: Task.__qualname__.__class__.__name__.__eq__('str')==True (Task.__qualname__=='Task', and 'Task' is a str; all class __qualname__ values are str in Python; len=4); Task.__qualname__.__len__()==4 ('Task'=4; also equal to Task.__name__.__len__()==4); Task.__mro__.__len__()==3 ([asyncio.Task, asyncio.Future, object]: Task inherits from Future which inherits from object; the MRO has 3 entries); Task.__bases__[0].__name__.__eq__('Future')==True (Task has a single base class Future; Task.__bases__ is a tuple of length 1; Task extends Future by adding cancellation, name, coroutine tracking); Task.__name__.__len__()==4 ('Task'=4, tied with Task.__qualname__.__len__()==4); Task.__module__.__eq__('_asyncio')==True (C extension module; Task and Future are C-accelerated in CPython 3.10+); Task.__module__.__len__()==8 ('_asyncio'=8); compare: Task.__qualname__.__len__()==4 == Task.__name__.__len__()==4 (tied); __module__.__len__()==8 is 4 more than __name__.__len__()==4; __mro__.__len__()==3 matches the 3-class hierarchy [Task, Future, object]; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: taskacc117a

  columns: [id, function, args, expected, description]
  rows:
    - [qn_cls_eq,    Task.__qualname__.__class__.__name__.__eq__,  ["str"],     true, "Task.__qualname__.__class__.__name__ == 'str' (qualname is a plain string); verified with Python 3.14.3"]
    - [qn_len,       Task.__qualname__.__len__,                    [],          4,    "Task.__qualname__.__len__() == 4 ('Task'=4); verified with Python 3.14.3"]
    - [mro_len,      Task.__mro__.__len__,                        [],          3,    "Task.__mro__.__len__() == 3 ([Task, Future, object]); verified with Python 3.14.3"]
    - [base_eq,      "Task.__bases__[0].__name__.__eq__",         ["Future"],  true, "Task.__bases__[0].__name__ == 'Future' (Task inherits from Future); verified with Python 3.14.3"]
    - [name_len,     Task.__name__.__len__,                       [],          4,    "Task.__name__.__len__() == 4 ('Task'=4, tied with __qualname__ len); verified with Python 3.14.3"]
    - [mod_eq,       Task.__module__.__eq__,                      ["_asyncio"], true, "Task.__module__ == '_asyncio' (C extension, len=8); verified with Python 3.14.3"]
    - [mod_len,      Task.__module__.__len__,                     [],          8,    "Task.__module__.__len__() == 8 ('_asyncio'=8, double __name__ len=4); verified with Python 3.14.3"]
    - [can_qn_cls,   Task.cancel.__qualname__.__class__.__name__.__eq__, ["str"], true, "Task.cancel.__qualname__.__class__.__name__ == 'str' (method __qualname__ is also str); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# asyncio.Task method qualname ordering cross-checks — extra117
#
# Wave 257 theme: compare qualname lengths across all Task methods.
#
# done=9 < cancel=result=11 (tied) < cancelled=exception=14 (tied)
# < get_coro=get_name=set_name=13 (tied) < get_context=16
# < add_done_callback=22 < remove_done_callback=25 (longest)
# ---------------------------------------------------------------------------

table asyncio_extra117.task_qualname_ordering:
  description: "asyncio.Task method qualname length ordering cross-checks in taskacc117 namespace — wave 257 theme: all Task method qualnames from done (shortest=9) to remove_done_callback (longest=25); Task.done.__qualname__.__len__()==9 ('Task.done'=9, shortest Task method qualname); Task.cancel.__qualname__.__len__()==11 (tied with Task.result: cancel==result==11); Task.get_coro.__qualname__.__len__()==13 (tied with get_name==set_name==13; three-way tie at 13); Task.cancelled.__qualname__.__len__()==14 (tied with Task.exception: cancelled==exception==14); Task.get_context.__qualname__.__len__()==16 (unique length in 15-24 range); Task.add_done_callback.__qualname__.__len__()==22 (second longest); Task.remove_done_callback.__qualname__.__len__()==25 (longest, 3 more than add_done_callback=22); length ordering: done=9 < cancel==result==11 < get_coro==get_name==set_name==13 < cancelled==exception==14 < get_context=16 < add_done_callback=22 < remove_done_callback=25; note the groupings: 9 (1 method), 11 (2 tied), 13 (3 tied), 14 (2 tied), 16 (1), 22 (1), 25 (1); total 11 distinct methods; Task.__module__=='_asyncio' (all 11 methods are C extension method_descriptors); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_names
  id_prefix: taskacc117b

  columns: [id, function, args, expected, description]
  rows:
    - [done_9,    Task.done.__qualname__.__len__,              [], 9,  "Task.done qualname len=9 (shortest Task method qualname); verified with Python 3.14.3"]
    - [cancel_11, Task.cancel.__qualname__.__len__,            [], 11, "Task.cancel qualname len=11 (tied with result); verified with Python 3.14.3"]
    - [result_11, Task.result.__qualname__.__len__,            [], 11, "Task.result qualname len=11 (tied with cancel); verified with Python 3.14.3"]
    - [gcoro_13,  Task.get_coro.__qualname__.__len__,          [], 13, "Task.get_coro qualname len=13 (three-way tie: get_coro==get_name==set_name); verified with Python 3.14.3"]
    - [gname_13,  Task.get_name.__qualname__.__len__,          [], 13, "Task.get_name qualname len=13 (tied with get_coro and set_name); verified with Python 3.14.3"]
    - [sname_13,  Task.set_name.__qualname__.__len__,          [], 13, "Task.set_name qualname len=13 (tied with get_coro and get_name); verified with Python 3.14.3"]
    - [cld_14,    Task.cancelled.__qualname__.__len__,         [], 14, "Task.cancelled qualname len=14 (tied with exception); verified with Python 3.14.3"]
    - [exc_14,    Task.exception.__qualname__.__len__,         [], 14, "Task.exception qualname len=14 (tied with cancelled); verified with Python 3.14.3"]
    - [gctx_16,   Task.get_context.__qualname__.__len__,       [], 16, "Task.get_context qualname len=16 (unique in 15-24 range); verified with Python 3.14.3"]
    - [adc_22,    Task.add_done_callback.__qualname__.__len__, [], 22, "Task.add_done_callback qualname len=22 (second longest); verified with Python 3.14.3"]
    - [rdc_25,    Task.remove_done_callback.__qualname__.__len__, [], 25, "Task.remove_done_callback qualname len=25 (longest Task method qualname); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra117
# ---------------------------------------------------------------------------

invariant asyncio_extra117.task_get_coro_qualname_eq:
  description: "asyncio.Task.get_coro.__qualname__.__eq__('Task.get_coro') returns True — 'Task.get_coro' has len=13: 'Task.'=5+'get_coro'=8=13; Task.get_coro is a method_descriptor (C extension from _asyncio) that returns the coroutine object originally passed to asyncio.create_task() or the Task constructor; despite being C-level, it still exposes __qualname__ as a str; asyncio.Task.get_coro.__qualname__.__len__()==13 (tied with get_name==set_name==13 in the three-way tie group); Task.get_context.__qualname__.__len__()==16 (3 more than get_coro); Task.remove_done_callback.__qualname__.__len__()==25 (longest Task method); Task.__bases__[0].__name__=='Future' (Task inherits from Future); Task.__mro__.__len__()==3; Task.__module__=='_asyncio' (len=8); first standalone Task.get_coro qualname equality invariant in taskacc117 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: Task.get_coro.__qualname__.__eq__
  args: ["Task.get_coro"]
  expected: true

invariant asyncio_extra117.task_get_context_qualname_eq:
  description: "asyncio.Task.get_context.__qualname__.__eq__('Task.get_context') returns True — 'Task.get_context' has len=16: 'Task.'=5+'get_context'=11=16; Task.get_context is a method_descriptor that returns the contextvars.Context object the task is running in (added in Python 3.7 when contextvars was introduced; each task has its own copy of the context); asyncio.Task.get_context.__qualname__.__len__()==16 (unique length — no other Task method has qualname len=16); compare: Task.get_coro.__qualname__.__len__()==13 (3 shorter), Task.add_done_callback.__qualname__.__len__()==22 (6 longer); 'get_context'=11 chars ('get_'=4+'context'=7=11) vs 'get_coro'=8 chars ('get_'=4+'coro'=4=8) — context name is 3 chars longer; Task.__qualname__=='Task' (len=4); Task.__module__=='_asyncio'; first standalone Task.get_context qualname equality invariant in taskacc117 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: Task.get_context.__qualname__.__eq__
  args: ["Task.get_context"]
  expected: true

invariant asyncio_extra117.task_remove_done_callback_qualname_eq:
  description: "asyncio.Task.remove_done_callback.__qualname__.__eq__('Task.remove_done_callback') returns True — 'Task.remove_done_callback' has len=25: 'Task.'=5+'remove_done_callback'=20=25; this is the longest __qualname__ of any Task method; compare: Task.add_done_callback.__qualname__.__len__()==22 (3 shorter); Task.done.__qualname__.__len__()==9 (shortest Task method, 16 shorter than remove_done_callback); 'remove_done_callback'=20 chars ('remove_'=7+'done_callback'=13=20; 'add_done_callback'=17 chars so remove is 3 chars longer than add); Task.remove_done_callback removes a previously registered callback and returns the number of callbacks removed (0 or 1); Task.__mro__.__len__()==3; Task.__bases__[0].__name__=='Future'; first standalone Task.remove_done_callback qualname equality invariant in taskacc117 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: method_names
  kind: python_call_eq
  function: Task.remove_done_callback.__qualname__.__eq__
  args: ["Task.remove_done_callback"]
  expected: true

invariant asyncio_extra117.task_mro_len_3:
  description: "asyncio.Task.__mro__.__len__() == 3 — the MRO (Method Resolution Order) is [asyncio.Task, asyncio.Future, object]: 3 entries; Task inherits directly from Future which inherits from object; Task.__bases__[0].__name__=='Future' (single base class); this 3-step hierarchy explains how Task inherits cancellation semantics from Future and adds coroutine-wrapping behavior; compare: asyncio.Future.__mro__.__len__()==2 ([Future, object]) — Task adds 1 level by inheriting Future; Task.__qualname__.__len__()==4 ('Task'=4); Task.__module__=='_asyncio' (len=8); Task.__mro__.__len__()==3 is a cross-check on the class hierarchy depth; first standalone Task __mro__ length invariant in taskacc117 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Task.__mro__.__len__
  args: []
  expected: 3

invariant asyncio_extra117.task_qualname_class_str:
  description: "asyncio.Task.__qualname__.__class__.__name__.__eq__('str') returns True — Task.__qualname__=='Task' is a plain Python str; all class __qualname__ attributes in CPython are str instances; Task.__qualname__.__class__.__name__=='str' (the metaclass of str is type, not str itself); Task.__qualname__.__len__()==4 ('Task'=4); Task.__module__=='_asyncio'; Task.cancel.__qualname__.__class__.__name__=='str' (method qualnames are also str); Task.__mro__.__len__()==3; Task.__bases__[0].__name__=='Future'; this invariant confirms the type of the __qualname__ attribute itself, which is fundamental to how Python represents class names; first standalone Task __qualname__ class name invariant in taskacc117 namespace; wave 257; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: Task.__qualname__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
