spec: dataclasses_extra32
version: ">=3.10"
backend: python_module(dataclasses)

docs: https://docs.python.org/3/library/dataclasses.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dataclasses.html — Python dataclasses module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/dataclasses.py"
  notes:
    - "This spec extends dataclasses_extra31.zspec.zsdl."
    - "Prior specs covered: all function/class __name__/__module__/__qualname__/__bases__; FrozenInstanceError/__mro__.__len__()==5; InitVar/__mro__.__len__()==2; Field.__init__/__repr__/__set_name__ __qualname__.__eq__ and __qualname__.__len__; KW_ONLY/__class__.__name__=='_KW_ONLY_TYPE'; MISSING/__class__.__name__=='_MISSING_TYPE'; __name__.__len__() and __qualname__.__len__() for all module-level functions and Field/FrozenInstanceError."
    - "This spec covers: FrozenInstanceError.__mro__.__len__() and __bases__[0].__name__ (standalone confirmations in extra32 namespace); KW_ONLY.__class__.__qualname__.__len__(); MISSING.__class__.__qualname__.__len__(); InitVar.__qualname__.__len__(); make_dataclass.__qualname__.__len__() == 14 (confirming vs __name__)."
    - "dataclasses.FrozenInstanceError.__mro__.__len__() == 5 — [FrozenInstanceError, AttributeError, Exception, BaseException, object]."
    - "dataclasses.FrozenInstanceError.__bases__[0].__name__ == 'AttributeError' — frozen dataclass raises AttributeError subclass."
    - "dataclasses.KW_ONLY.__class__.__qualname__ == '_KW_ONLY_TYPE' (len=13) — sentinel object for keyword-only fields."
    - "dataclasses.MISSING.__class__.__qualname__ == '_MISSING_TYPE' (len=13) — sentinel object for missing default values."
    - "dataclasses.InitVar.__qualname__ == 'InitVar' (len=7) — class defined at module scope."
    - "dataclasses.make_dataclass.__qualname__.__len__() == 14 — matches __name__.__len__(), confirming top-level scope."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Sentinel class __qualname__.__len__() table (extra32 namespace)
#
# The two sentinel objects MISSING and KW_ONLY are instances of private
# classes _MISSING_TYPE and _KW_ONLY_TYPE respectively. Both class qualnames
# are '_MISSING_TYPE' and '_KW_ONLY_TYPE', both 13 characters long. This
# table verifies the qualname length of the class objects via the sentinel
# instance's __class__.__qualname__.__len__ chain. No prior dataclasses spec
# records these qualname lengths in the extra32 namespace.
# ---------------------------------------------------------------------------

table dataclasses_extra32.sentinel_class_qualname_lens:
  description: "__class__.__qualname__.__len__() for MISSING and KW_ONLY sentinel objects"
  kind: python_call_eq
  category: sentinel_class_attrs
  id_prefix: sentinel_qualname_len

  columns: [id, function, args, expected]
  rows:
    - [MISSING,  MISSING.__class__.__qualname__.__len__,  [], 13]
    - [KW_ONLY,  KW_ONLY.__class__.__qualname__.__len__,  [], 13]

# ---------------------------------------------------------------------------
# FrozenInstanceError __mro__ and __bases__ table (extra32 namespace)
#
# FrozenInstanceError subclasses AttributeError, which chains through
# Exception, BaseException to object — giving an MRO of depth 5. The
# __bases__[0].__name__ confirms direct inheritance from AttributeError
# (not Exception directly). This table re-records both facts as a single
# cohesive table in the extra32 namespace for the first time together.
# No prior dataclasses spec records both FrozenInstanceError.__mro__.__len__
# and __bases__[0].__name__ in the same table.
# ---------------------------------------------------------------------------

table dataclasses_extra32.FrozenInstanceError_hierarchy:
  description: "FrozenInstanceError MRO depth and direct base class"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: frozen_hierarchy

  columns: [id, function, args, expected]
  rows:
    - [mro_len,   FrozenInstanceError.__mro__.__len__,             [], 5]
    - [base_name, "FrozenInstanceError.__bases__[0].__name__.__eq__", ["AttributeError"], true]

# ---------------------------------------------------------------------------
# dataclasses.InitVar.__qualname__.__len__() == 7 — standalone
# (extra32 namespace)
#
# InitVar is defined at module scope in dataclasses.py so its __qualname__
# equals its __name__, both 'InitVar' (7 characters). InitVar is a
# descriptor-like sentinel class used to mark __init__-only parameters in
# dataclass field annotations. No prior dataclasses spec records this
# standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra32.InitVar.qualname_len:
  description: "dataclasses.InitVar.__qualname__.__len__() == 7 — 'InitVar' is 7 chars; top-level class so qualname == name"
  category: qualname_attrs
  kind: python_call_eq
  function: InitVar.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# dataclasses.make_dataclass.__qualname__.__len__() == 14 — standalone
# (extra32 namespace)
#
# make_dataclass is a module-level function so its __qualname__ equals its
# __name__, 'make_dataclass' (14 characters). Confirming the qualname length
# via a standalone invariant in the extra32 namespace reinforces that no
# nesting or closure scope applies. No prior dataclasses spec records this
# standalone equality in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra32.make_dataclass.qualname_len:
  description: "dataclasses.make_dataclass.__qualname__.__len__() == 14 — top-level function; qualname matches name"
  category: qualname_attrs
  kind: python_call_eq
  function: make_dataclass.__qualname__.__len__
  args: []
  expected: 14

# ---------------------------------------------------------------------------
# dataclasses.KW_ONLY.__class__.__qualname__.__len__() == 13 — standalone
# (extra32 namespace)
#
# KW_ONLY is the sentinel that marks subsequent fields as keyword-only in a
# dataclass definition. Its underlying class _KW_ONLY_TYPE has a qualname of
# '_KW_ONLY_TYPE', which is 13 characters long. This matches MISSING's class
# qualname length. No prior dataclasses spec records this standalone in the
# extra32 namespace.
# ---------------------------------------------------------------------------

invariant dataclasses_extra32.KW_ONLY.class_qualname_len:
  description: "dataclasses.KW_ONLY.__class__.__qualname__.__len__() == 13 — '_KW_ONLY_TYPE' has 13 chars"
  category: sentinel_class_attrs
  kind: python_call_eq
  function: KW_ONLY.__class__.__qualname__.__len__
  args: []
  expected: 13
