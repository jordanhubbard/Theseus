spec: io_extra64
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pyio.py"
    - "CPython source: Modules/_io/"
    - "io_extra63.zspec.zsdl — covers io.__all__.__class__.__name__.__eq__('list') and __all__.__len__()==24; BytesIO/StringIO/TextIOWrapper/IOBase/RawIOBase __eq__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "io_extra62.zspec.zsdl — covers BytesIO/StringIO/TextIOWrapper/IOBase/RawIOBase __repr__.__class__.__name__.__eq__('wrapper_descriptor'); io.__spec__.__class__.__name__.__eq__('ModuleSpec'); io.__spec__.name.__class__.__name__.__eq__('str'); BytesIO/StringIO __hash__.__class__.__name__.__eq__('wrapper_descriptor')."
    - "io_extra61.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper __class__.__module__.__eq__('builtins'); IOBase/RawIOBase/BufferedIOBase/TextIOBase __class__.__module__.__eq__('abc'); io.__spec__.name.__eq__('io') and __len__()==2."
    - "io_extra60.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/IOBase __dict__.__class__.__name__/__qualname__.__eq__('mappingproxy')."
    - "io_extra59.zspec.zsdl — covers DEFAULT_BUFFER_SIZE __class__.__module__ equality/length; BufferedIOBase/TextIOBase __module__ equality/length."
    - "io_extra58.zspec.zsdl — covers BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper __module__.__eq__('_io'); IOBase/RawIOBase __module__.__eq__('io'); open __module__.__eq__('_io')."
    - "io_extra57.zspec.zsdl — covers BytesIO/StringIO method qualname equality for read/write/seek/tell/getvalue."
    - "io_extra56.zspec.zsdl — covers __doc__.__class__.__name__/__qualname__ for BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/TextIOWrapper/IOBase/RawIOBase/BufferedIOBase/TextIOBase and module."
  notes:
    - "This spec extends io_extra63.zspec.zsdl."
    - "Wave 224 theme: __all__.__contains__ membership + module __package__ identity + class __doc__.__class__.__name__ checks."
    - "io.__all__.__contains__ membership: The io module's __all__ list contains all major public classes. __all__.__contains__ is the list membership test method. 'BytesIO' in io.__all__ == True. Similarly for 'StringIO', 'FileIO', 'BufferedReader', 'TextIOWrapper', 'IOBase'. All six return True. No prior io spec uses __all__.__contains__ as a callable. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.__package__ == '' — io is a C-extension module (_io) with a thin Python wrapper. Its __package__ is the empty string because io is not a package (it has no submodules). This differs from re.__package__=='re' and pathlib.__package__=='pathlib', both of which are packages (have __init__.py). Verified: io.__package__.__eq__('') == True. No prior io spec checks __package__ equality. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.BytesIO.__doc__.__class__.__name__.__len__() == 3 — the type name 'str' has length 3. io_extra56 covers BytesIO.__doc__.__class__.__name__.__eq__('str') (equality). This spec adds the __len__() == 3 anchor which is novel. The chain: BytesIO.__doc__ is a str instance; its .__class__ is str; .__class__.__name__ is 'str'; .__len__() == 3. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "io.IOBase.__doc__.__class__.__name__.__len__() == 3 — same reasoning as BytesIO. IOBase is an abstract base class; its docstring is a str; 'str'.__len__() == 3. Novel. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.__all__.__contains__ membership checks
#
# The io module's __all__ list contains 24 public names. This table verifies
# that six key class names are members: 'BytesIO', 'StringIO', 'FileIO',
# 'BufferedReader', 'TextIOWrapper', 'IOBase'. Each call to __all__.__contains__
# with that name returns True.
#
# No prior io spec uses __all__.__contains__ as a callable on specific names.
# All six anchors are novel in the iopkg64 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra64.all_contains_classes:
  description: "io.__all__.__contains__ membership for BytesIO/StringIO/FileIO/BufferedReader/TextIOWrapper/IOBase — all six are public names in io.__all__ (24-entry list); __contains__ called as a method returns True for each; no prior io spec uses __all__.__contains__ as a callable on specific names; all six novel anchors in iopkg64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: iopkg64cnt

  columns: [id, function, args, expected]
  rows:
    - [contains_BytesIO,       __all__.__contains__, ["BytesIO"],       true]
    - [contains_StringIO,      __all__.__contains__, ["StringIO"],      true]
    - [contains_FileIO,        __all__.__contains__, ["FileIO"],        true]
    - [contains_BufferedReader, __all__.__contains__, ["BufferedReader"], true]
    - [contains_TextIOWrapper, __all__.__contains__, ["TextIOWrapper"], true]
    - [contains_IOBase,        __all__.__contains__, ["IOBase"],        true]

# ---------------------------------------------------------------------------
# io.__package__ identity
#
# io is a C-extension module backed by _io with a thin Python wrapper.
# It is NOT a package — it has no subdirectory or __init__.py. Therefore
# its __package__ attribute is the empty string ''.
#
#   io.__package__.__eq__('') == True
#
# This contrasts with re.__package__=='re' and pathlib.__package__=='pathlib',
# which are actual packages (directories with __init__.py).
#
# No prior io spec checks __package__ equality. Novel in iopkg64 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra64.package_identity:
  description: "io.__package__.__eq__('') — io is a C-extension module (not a package); its __package__ is the empty string ''; contrasts with re.__package__=='re' and pathlib.__package__=='pathlib' which are packages; no prior io spec checks __package__ equality; novel anchor in iopkg64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: module_identity
  id_prefix: iopkg64pkg

  columns: [id, function, args, expected]
  rows:
    - [package_eq_empty, __package__.__eq__, [""], true]

# ---------------------------------------------------------------------------
# io BytesIO/IOBase __doc__.__class__.__name__.__len__() == 3
#
# io_extra56 covered BytesIO/StringIO/FileIO/BufferedReader/BufferedWriter/
# TextIOWrapper/IOBase/RawIOBase/BufferedIOBase/TextIOBase
# __doc__.__class__.__name__.__eq__('str'). That equality anchor is prior art.
#
# Novel angle: the __len__() of the type name string. 'str' has length 3.
# The chain: T.__doc__ is a str instance; .__class__ is the str type;
# .__class__.__name__ is 'str'; .__len__() == 3.
#
#   BytesIO.__doc__.__class__.__name__.__len__() == 3
#   IOBase.__doc__.__class__.__name__.__len__()  == 3
#
# No prior io spec checks __doc__.__class__.__name__.__len__() for any class.
# Both anchors are novel in the iopkg64 namespace.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table io_extra64.doc_class_name_len:
  description: "io BytesIO/IOBase __doc__.__class__.__name__.__len__()==3 — the docstring type name 'str' has length 3; io_extra56 covered the __eq__('str') equality; this spec adds the __len__()==3 angle which is novel; both anchors novel in iopkg64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: iopkg64dlen

  columns: [id, function, args, expected]
  rows:
    - [BytesIO_doc_class_name_len, "BytesIO.__doc__.__class__.__name__.__len__", [], 3]
    - [IOBase_doc_class_name_len,  "IOBase.__doc__.__class__.__name__.__len__",  [], 3]

invariant io_extra64.all_contains_BytesIO:
  description: "io.__all__.__contains__('BytesIO') == True — 'BytesIO' is a public name in io.__all__ (24-entry list); no prior io spec uses __all__.__contains__ as a callable on specific names; novel anchor in iopkg64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["BytesIO"]
  expected: true

invariant io_extra64.all_contains_IOBase:
  description: "io.__all__.__contains__('IOBase') == True — 'IOBase' is a public name in io.__all__ (24-entry list); no prior io spec uses __all__.__contains__ as a callable; novel anchor in iopkg64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __all__.__contains__
  args: ["IOBase"]
  expected: true

invariant io_extra64.package_eq_empty_string:
  description: "io.__package__.__eq__('') == True — io is a C-extension module, not a package; __package__ is the empty string; contrasts with re ('re') and pathlib ('pathlib') which are packages; no prior io spec checks __package__ equality; novel anchor in iopkg64 namespace; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant io_extra64.BytesIO_doc_class_name_len_3:
  description: "io.BytesIO.__doc__.__class__.__name__.__len__() == 3 — the str type name 'str' has length 3; io_extra56 covers BytesIO.__doc__.__class__.__name__.__eq__('str') (equality); this __len__()==3 angle is novel; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: class_identity
  kind: python_call_eq
  function: BytesIO.__doc__.__class__.__name__.__len__
  args: []
  expected: 3
