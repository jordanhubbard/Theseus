spec: socket_extra1861
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python socket documentation — https://docs.python.org/3/library/socket.html"
    - "POSIX.1-2017 — AF_INET, SOCK_STREAM, SOL_SOCKET constants"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "Wave 571: bitwise and in-place operators for socket module classes"
    - "socket.socket and socket.error do not define bitwise or in-place operators in their own __dict__"
    - "AF_UNIX is available on POSIX platforms (macOS/Linux/FreeBSD); not available on Windows"
    - "SO_KEEPALIVE and SO_REUSEADDR are universally present on POSIX platforms"
  created_at: "2026-04-12"

table socket_extra1861.bitwise_operators:
  columns: [id, function, args, expected]
  rows:
    - ["sk1861-bit-001", "socket.socket.__dict__.__contains__", ["__or__"], false]
    - ["sk1861-bit-002", "socket.socket.__dict__.__contains__", ["__and__"], false]
    - ["sk1861-bit-003", "socket.socket.__dict__.__contains__", ["__xor__"], false]
    - ["sk1861-bit-004", "socket.socket.__dict__.__contains__", ["__invert__"], false]
    - ["sk1861-bit-005", "socket.error.__dict__.__contains__", ["__or__"], false]
    - ["sk1861-bit-006", "socket.__dict__.__contains__", ["__or__"], false]
    - ["sk1861-bit-007", "socket.__dict__.__contains__", ["__and__"], false]
    - ["sk1861-bit-008", "socket.__dict__.__contains__", ["__xor__"], false]

table socket_extra1861.inplace_operators:
  columns: [id, function, args, expected]
  rows:
    - ["sk1861-iop-001", "socket.socket.__dict__.__contains__", ["__iadd__"], false]
    - ["sk1861-iop-002", "socket.socket.__dict__.__contains__", ["__ior__"], false]
    - ["sk1861-iop-003", "socket.socket.__dict__.__contains__", ["__imul__"], false]
    - ["sk1861-iop-004", "socket.error.__dict__.__contains__", ["__iadd__"], false]
    - ["sk1861-iop-005", "socket.__dict__.__contains__", ["__iadd__"], false]
    - ["sk1861-iop-006", "socket.__dict__.__contains__", ["__ior__"], false]
    - ["sk1861-iop-007", "socket.__dict__.__contains__", ["__imul__"], false]
    - ["sk1861-iop-008", "socket.__dict__.__contains__", ["__isub__"], false]

table socket_extra1861.socket_address_family_constants:
  columns: [id, function, args, expected]
  rows:
    - ["sk1861-afc-001", "socket.__dict__.__contains__", ["AF_UNIX"], true]
    - ["sk1861-afc-002", "socket.__dict__.__contains__", ["AF_INET"], true]
    - ["sk1861-afc-003", "socket.__dict__.__contains__", ["AF_INET6"], true]
    - ["sk1861-afc-004", "socket.__dict__.__contains__", ["SOCK_STREAM"], true]
    - ["sk1861-afc-005", "socket.__dict__.__contains__", ["SOCK_DGRAM"], true]
    - ["sk1861-afc-006", "socket.__dict__.__contains__", ["SOCK_RAW"], true]
    - ["sk1861-afc-007", "socket.__dict__.__contains__", ["SOL_SOCKET"], true]
    - ["sk1861-afc-008", "socket.__dict__.__contains__", ["SO_REUSEADDR"], true]
    - ["sk1861-afc-009", "socket.__dict__.__contains__", ["SO_KEEPALIVE"], true]
    - ["sk1861-afc-010", "socket.__dict__.__contains__", ["IPPROTO_TCP"], true]
