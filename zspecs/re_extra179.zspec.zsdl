spec: re_extra179
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Match object method names — group, groups, groupdict, start, end, span, expand — all are method_descriptor instances on the C-implemented Match type."
    - "re.Match.string and re.Match.re are member_descriptor objects (read-only C struct members), not properties; they do not have .fget."
    - "re.Match.lastindex and re.Match.lastgroup are getset_descriptor objects."
    - "Name length groupings: end (3); span (4); group==start (5); groups==expand (6); groupdict (9)."
    - "re.Match.group.__name__ == 'group' (len=5); start (5) ties with group — a 2-way tie at length 5."
    - "re.Match.groups.__name__ == 'groups' (len=6); expand (6) ties with groups — a 2-way tie at length 6."
    - "re.Match.end.__name__ == 'end' (len=3) — the shortest Match method name."
    - "re.Match.groupdict.__name__ == 'groupdict' (len=9) — the longest Match method name covered."
    - "re.Match.string.__class__.__name__ == 'member_descriptor' — string is a read-only C struct member, not a Python property."
    - "re.Match.re.__class__.__name__ == 'member_descriptor' — re attribute is also a C member_descriptor."
    - "Length ordering: end (3) < span (4) < group==start (5) < groups==expand (6) < groupdict (9)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: re.Match group-extraction method names
# groupdict (9) > groups (6) > group (5) — a strict ordering
# ---------------------------------------------------------------------------

table re_extra179.group_method_names:
  description: "re.Match group-extraction method names: group.__name__=='group' (len=5); groups.__name__=='groups' (len=6); groupdict.__name__=='groupdict' (len=9); group (5) < groups (6) < groupdict (9)"
  kind: python_call_eq
  category: identity
  id_prefix: rematch179

  columns: [id, function, args, expected, description]
  rows:
    - [group_name,      Match.group.__name__.__eq__,      ["group"],     true, "re.Match.group.__name__ == 'group' — group() returns one or more subgroups of the match; 'group' has 5 characters: g(1)r(2)o(3)u(4)p(5); group (5) == start (5): a 2-way tie among Match methods at length 5; confirmed Python 3.14.3 macOS"]
    - [group_name_len,  Match.group.__name__.__len__,     [],            5,    "re.Match.group.__name__.__len__() == 5 — 'group' has 5 characters; group (5) == start (5): both share length 5; end (3) < span (4) < group==start (5) < groups==expand (6) < groupdict (9): the full length ordering; confirmed Python 3.14.3 macOS"]
    - [groups_name,     Match.groups.__name__.__eq__,     ["groups"],    true, "re.Match.groups.__name__ == 'groups' — groups() returns a tuple of all subgroup matches; 'groups' has 6 characters: g(1)r(2)o(3)u(4)p(5)s(6); groups (6) == expand (6): a 2-way tie at length 6; confirmed Python 3.14.3 macOS"]
    - [groups_name_len, Match.groups.__name__.__len__,    [],            6,    "re.Match.groups.__name__.__len__() == 6 — 'groups' has 6 characters; group (5) < groups (6): the plural 's' adds 1 character; groups (6) == expand (6): both share length 6; confirmed Python 3.14.3 macOS"]
    - [groupdict_name,  Match.groupdict.__name__.__eq__,  ["groupdict"], true, "re.Match.groupdict.__name__ == 'groupdict' — groupdict() returns a dict of all named subgroup matches; 'groupdict' has 9 characters: g(1)r(2)o(3)u(4)p(5)d(6)i(7)c(8)t(9); groupdict (9) is the longest Match method name covered; confirmed Python 3.14.3 macOS"]
    - [groupdict_name_len, Match.groupdict.__name__.__len__, [],         9,    "re.Match.groupdict.__name__.__len__() == 9 — 'groupdict' has 9 characters; groups (6) < groupdict (9): groupdict is 3 characters longer than groups; groupdict (9) is the maximum length in the Match method name ordering; confirmed Python 3.14.3 macOS"]
    - [group_class,     Match.group.__class__.__name__.__eq__, ["method_descriptor"], true, "re.Match.group.__class__.__name__ == 'method_descriptor' — Match is implemented in C so its methods are method_descriptor objects; this holds for all Match methods: group, groups, groupdict, start, end, span, expand; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: re.Match position method names (start, end, span)
# end (3) < span (4) < start (5)
# ---------------------------------------------------------------------------

table re_extra179.position_method_names:
  description: "re.Match position method names: start.__name__=='start' (len=5); end.__name__=='end' (len=3); span.__name__=='span' (len=4); end (3) < span (4) < start (5): a strict ascending order"
  kind: python_call_eq
  category: identity
  id_prefix: rematch179

  columns: [id, function, args, expected, description]
  rows:
    - [start_name,     Match.start.__name__.__eq__,   ["start"], true, "re.Match.start.__name__ == 'start' — start() returns the index of the start of the match; 'start' has 5 characters: s(1)t(2)a(3)r(4)t(5); start (5) == group (5): a 2-way tie at length 5; start (5) > span (4) > end (3): strict ordering among position methods; confirmed Python 3.14.3 macOS"]
    - [start_name_len, Match.start.__name__.__len__,  [],        5,    "re.Match.start.__name__.__len__() == 5 — 'start' has 5 characters; start (5) == group (5): both share length 5; end (3) < span (4) < start (5): start is the longest position method name; confirmed Python 3.14.3 macOS"]
    - [end_name,       Match.end.__name__.__eq__,     ["end"],   true, "re.Match.end.__name__ == 'end' — end() returns the index past the end of the match; 'end' has 3 characters: e(1)n(2)d(3); end (3) is the shortest Match method name covered; end (3) < span (4) < start (5): the strict position method ordering; confirmed Python 3.14.3 macOS"]
    - [end_name_len,   Match.end.__name__.__len__,    [],        3,    "re.Match.end.__name__.__len__() == 3 — 'end' has 3 characters; end (3) is the minimum length among all Match method names covered; end (3) < span (4) < start (5) < group==start [tie resolved] < groups==expand (6) < groupdict (9); confirmed Python 3.14.3 macOS"]
    - [span_name,      Match.span.__name__.__eq__,    ["span"],  true, "re.Match.span.__name__ == 'span' — span() returns a tuple (start, end) of the match; 'span' has 4 characters: s(1)p(2)a(3)n(4); span (4) is uniquely length 4 among the seven Match methods covered; end (3) < span (4) < start (5); confirmed Python 3.14.3 macOS"]
    - [span_name_len,  Match.span.__name__.__len__,   [],        4,    "re.Match.span.__name__.__len__() == 4 — 'span' has 4 characters; span (4) is the unique length-4 Match method; end (3) < span (4) < start==group (5): span is strictly between end and start in the length ordering; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: re.Match expand method and C-descriptor attribute class names
# expand (6); Match.string and Match.re are member_descriptor
# ---------------------------------------------------------------------------

table re_extra179.expand_and_descriptors:
  description: "re.Match expand method and read-only C attribute descriptors: expand.__name__=='expand' (len=6); Match.string.__class__.__name__=='member_descriptor'; Match.re.__class__.__name__=='member_descriptor'"
  kind: python_call_eq
  category: identity
  id_prefix: rematch179

  columns: [id, function, args, expected, description]
  rows:
    - [expand_name,       Match.expand.__name__.__eq__,              ["expand"],           true, "re.Match.expand.__name__ == 'expand' — expand() returns the match string with backslash substitutions; 'expand' has 6 characters: e(1)x(2)p(3)a(4)n(5)d(6); expand (6) == groups (6): a 2-way tie at length 6; confirmed Python 3.14.3 macOS"]
    - [expand_name_len,   Match.expand.__name__.__len__,             [],                   6,    "re.Match.expand.__name__.__len__() == 6 — 'expand' has 6 characters; expand (6) == groups (6): both share length 6; group==start (5) < groups==expand (6) < groupdict (9): expand is in the middle tier; confirmed Python 3.14.3 macOS"]
    - [expand_class,      Match.expand.__class__.__name__.__eq__,    ["method_descriptor"], true, "re.Match.expand.__class__.__name__ == 'method_descriptor' — expand is a C method_descriptor, same as all other Match methods; confirmed Python 3.14.3 macOS"]
    - [string_class,      Match.string.__class__.__name__.__eq__,    ["member_descriptor"], true, "re.Match.string.__class__.__name__ == 'member_descriptor' — string is a read-only C struct member (not a Python property); it holds the string that was searched; member_descriptor objects do not have a .fget attribute unlike Python property objects; confirmed Python 3.14.3 macOS"]
    - [re_attr_class,     Match.re.__class__.__name__.__eq__,        ["member_descriptor"], true, "re.Match.re.__class__.__name__ == 'member_descriptor' — the re attribute (the compiled regex pattern) is also a C member_descriptor, same class as Match.string; both Match.string and Match.re are member_descriptor, not getset_descriptor or property; confirmed Python 3.14.3 macOS"]
    - [groupdict_class,   Match.groupdict.__class__.__name__.__eq__, ["method_descriptor"], true, "re.Match.groupdict.__class__.__name__ == 'method_descriptor' — groupdict, like all Match extraction methods, is a C method_descriptor; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra179.group_name_is_group:
  description: "re.Match.group.__name__ == 'group' — group() returns subgroups from the match; len=5; group (5) == start (5): a 2-way tie at length 5; end (3) < span (4) < group==start (5): group is in the middle tier; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Match.group.__name__.__eq__
  args: ["group"]
  expected: true

invariant re_extra179.groups_name_len_is_6:
  description: "re.Match.groups.__name__.__len__() == 6 — 'groups' has 6 characters; groups (6) == expand (6): a 2-way tie at length 6; group (5) < groups (6): the plural adds 1 character; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Match.groups.__name__.__len__
  args: []
  expected: 6

invariant re_extra179.groupdict_name_len_is_9:
  description: "re.Match.groupdict.__name__.__len__() == 9 — 'groupdict' has 9 characters; groupdict (9) is the longest Match method name; groups (6) < groupdict (9): groupdict is 3 characters longer; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Match.groupdict.__name__.__len__
  args: []
  expected: 9

invariant re_extra179.end_name_len_is_3:
  description: "re.Match.end.__name__.__len__() == 3 — 'end' has 3 characters; end (3) is the shortest Match method name covered; end (3) < span (4) < start (5): end is the minimum in the position method length ordering; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Match.end.__name__.__len__
  args: []
  expected: 3

invariant re_extra179.span_name_len_is_4:
  description: "re.Match.span.__name__.__len__() == 4 — 'span' has 4 characters; span (4) is the unique length-4 Match method; end (3) < span (4) < start==group (5): span is strictly between end and start; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Match.span.__name__.__len__
  args: []
  expected: 4

invariant re_extra179.string_is_member_descriptor:
  description: "re.Match.string.__class__.__name__ == 'member_descriptor' — Match.string is a C struct member, not a Python property; it does not have .fget; member_descriptor objects are read-only C-level attributes; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Match.string.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra179.re_attr_is_member_descriptor:
  description: "re.Match.re.__class__.__name__ == 'member_descriptor' — Match.re (the compiled pattern) is a C member_descriptor, same class as Match.string; both Match.string and Match.re are member_descriptor instances; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Match.re.__class__.__name__.__eq__
  args: ["member_descriptor"]
  expected: true

invariant re_extra179.expand_name_is_expand:
  description: "re.Match.expand.__name__ == 'expand' — expand() performs backslash substitutions on the match; len=6; expand (6) == groups (6): a 2-way tie at length 6; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: Match.expand.__name__.__eq__
  args: ["expand"]
  expected: true

