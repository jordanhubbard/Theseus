spec: asyncio_extra631
version: ">=3.9"
backend: python_module(asyncio)
docs: https://docs.python.org/3/library/asyncio.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-stream.html — asyncio streams"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers Lock, Semaphore, Event qualnames and stream function qualnames/modules"
  created_at: "2026-04-12T00:00:00Z"

table asyncio_extra631.lock_qualnames:
  description: "asyncio.Lock method __qualname__ identity checks"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: as631lk
  columns: [id, function, args, expected]
  rows:
    - [as631lk001, asyncio.Lock.__init__.__qualname__.__eq__, ["Lock.__init__"], true]
    - [as631lk002, asyncio.Lock.acquire.__qualname__.__eq__, ["Lock.acquire"], true]
    - [as631lk003, asyncio.Lock.release.__qualname__.__eq__, ["Lock.release"], true]
    - [as631lk004, asyncio.Lock.__repr__.__qualname__.__eq__, ["Lock.__repr__"], true]

table asyncio_extra631.semaphore_qualnames:
  description: "asyncio.Semaphore method __qualname__ identity checks"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: as631sm
  columns: [id, function, args, expected]
  rows:
    - [as631sm001, asyncio.Semaphore.__init__.__qualname__.__eq__, ["Semaphore.__init__"], true]
    - [as631sm002, asyncio.Semaphore.acquire.__qualname__.__eq__, ["Semaphore.acquire"], true]
    - [as631sm003, asyncio.Semaphore.release.__qualname__.__eq__, ["Semaphore.release"], true]

table asyncio_extra631.event_qualnames:
  description: "asyncio.Event method __qualname__ identity checks"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: as631ev
  columns: [id, function, args, expected]
  rows:
    - [as631ev001, asyncio.Event.__init__.__qualname__.__eq__, ["Event.__init__"], true]
    - [as631ev002, asyncio.Event.set.__qualname__.__eq__, ["Event.set"], true]
    - [as631ev003, asyncio.Event.clear.__qualname__.__eq__, ["Event.clear"], true]
    - [as631ev004, asyncio.Event.wait.__qualname__.__eq__, ["Event.wait"], true]

table asyncio_extra631.streams_identity:
  description: "asyncio stream function qualname and module identity checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: as631st
  columns: [id, function, args, expected]
  rows:
    - [as631st001, asyncio.open_connection.__qualname__.__eq__, ["open_connection"], true]
    - [as631st002, asyncio.start_server.__qualname__.__eq__, ["start_server"], true]
    - [as631st003, asyncio.open_connection.__module__.__eq__, ["asyncio.streams"], true]
