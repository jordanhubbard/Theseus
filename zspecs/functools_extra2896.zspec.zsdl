spec: ft2896
version: ">=3.9"
backend: python_module(functools)
docs: https://docs.python.org/3/library/functools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 640 (ft2896): __itruediv__, __ifloordiv__, __imod__ dict-presence checks for functools types."
    - "functools classes are not numeric types — none define in-place true-divide, floor-divide, or modulo operators."
    - "Verified types: functools.partial, functools.partialmethod, functools.cached_property, functools._lru_cache_wrapper, functools._CacheInfo, functools.singledispatch."
    - "functools._lru_cache_wrapper is the C-level wrapper type produced by functools.lru_cache()."
    - "functools._CacheInfo is the namedtuple class for lru_cache statistics."
    - "functools.singledispatch is the dispatch decorator function; its __dict__ is empty."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ft2896.itruediv:
  description: "functools types __itruediv__ dict-presence checks; wave 640"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ft2896
  columns: [id, function, args, expected]
  rows:
    - ["ft2896001", operator.contains, [functools.partial.__dict__,              "__itruediv__"], false]
    - ["ft2896002", operator.contains, [functools.partialmethod.__dict__,        "__itruediv__"], false]
    - ["ft2896003", operator.contains, [functools.cached_property.__dict__,      "__itruediv__"], false]
    - ["ft2896004", operator.contains, [functools._lru_cache_wrapper.__dict__,   "__itruediv__"], false]
    - ["ft2896005", operator.contains, [functools._CacheInfo.__dict__,           "__itruediv__"], false]
    - ["ft2896006", operator.contains, [functools.singledispatch.__dict__,       "__itruediv__"], false]

