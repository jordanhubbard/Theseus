spec: sqlite3_extra24
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
  notes:
    - "This spec extends sqlite3_extra23.zspec.zsdl."
    - "Prior specs covered: Connection/Cursor/Row __name__/__module__/__qualname__, Error/DatabaseError/OperationalError/IntegrityError/InterfaceError/DataError/NotSupportedError/ProgrammingError/InternalError/Warning __name__/__module__ and bases, connect/__name__/__module__, sqlite3.sqlite_version type, Connection/__init__.__name__, Cursor/__init__.__name__."
    - "This spec covers: sqlite3.Connection.__module__.__len__(), sqlite3.Cursor.__module__.__len__(), sqlite3.Row.__module__.__len__(), sqlite3.Connection.__name__.__len__(), sqlite3.Cursor.__name__.__len__(), sqlite3.Row.__name__.__len__(), sqlite3.Error.__module__.__len__(), sqlite3.DatabaseError.__module__.__len__(), sqlite3.OperationalError.__module__.__len__(), sqlite3.Error.__name__.__len__(), sqlite3.DatabaseError.__name__.__len__(), sqlite3.connect.__module__.__len__()."
    - "sqlite3.Connection.__module__ == 'sqlite3' — length 7. Verified at runtime."
    - "sqlite3.Cursor.__module__ == 'sqlite3' — length 7. Verified at runtime."
    - "sqlite3.Row.__module__ == 'sqlite3' — length 7. Verified at runtime."
    - "sqlite3.Connection.__name__ == 'Connection' — length 10. Verified at runtime."
    - "sqlite3.Cursor.__name__ == 'Cursor' — length 6. Verified at runtime."
    - "sqlite3.Row.__name__ == 'Row' — length 3. Verified at runtime."
    - "sqlite3.Error.__module__ == 'sqlite3' — length 7. Verified at runtime."
    - "sqlite3.DatabaseError.__module__ == 'sqlite3' — length 7. Verified at runtime."
    - "sqlite3.OperationalError.__module__ == 'sqlite3' — length 7. Verified at runtime."
    - "sqlite3.Error.__name__ == 'Error' — length 5. Verified at runtime."
    - "sqlite3.DatabaseError.__name__ == 'DatabaseError' — length 13. Verified at runtime."
    - "sqlite3.connect.__module__ == '_sqlite3' — connect is implemented in the C extension _sqlite3, length 8. Verified at runtime."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sqlite3.Connection.__module__ — __len__()
#
# Prior specs verify Connection.__module__ == 'sqlite3'. No prior spec verifies
# the length of Connection.__module__ as a standalone invariant.
# len('sqlite3') == 7. Verified at runtime: 7.
# ---------------------------------------------------------------------------

invariant sqlite3_extra24.Connection.module_len:
  description: "len(sqlite3.Connection.__module__) == 7 — 'sqlite3' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Connection.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# sqlite3.Cursor.__module__ — __len__()
#
# Prior specs verify Cursor.__module__ == 'sqlite3'. No prior spec verifies
# the length of Cursor.__module__ as a standalone invariant.
# len('sqlite3') == 7. Verified at runtime: 7.
# ---------------------------------------------------------------------------

invariant sqlite3_extra24.Cursor.module_len:
  description: "len(sqlite3.Cursor.__module__) == 7 — 'sqlite3' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Cursor.__module__.__len__
  args: []
  expected: 7

