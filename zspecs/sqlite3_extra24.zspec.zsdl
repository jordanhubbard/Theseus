invariant sqlite3_extra24.Connection.name_len:
  description: "len(sqlite3.Connection.__name__) == 10 — 'Connection' has 10 characters"
  category: class_identity
  kind: python_call_eq
  function: Connection.__name__.__len__
  args: []
  expected: 10

