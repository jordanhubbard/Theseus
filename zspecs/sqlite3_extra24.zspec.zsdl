# ---------------------------------------------------------------------------
# sqlite3.connect.__module__ — __len__()
#
# Prior specs verify connect.__module__ == '_sqlite3' (the C extension module).
# No prior spec verifies the length of connect.__module__ as a standalone
# invariant. len('_sqlite3') == 8. Verified at runtime: 8.
# ---------------------------------------------------------------------------

invariant sqlite3_extra24.connect.module_len:
  description: "len(sqlite3.connect.__module__) == 8 — '_sqlite3' has 8 characters; connect is implemented in the C extension"
  category: function_identity
  kind: python_call_eq
  function: connect.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# Table: Connection, Cursor, Row __module__ and __name__ __len__() values
#
# No prior spec groups Connection, Cursor, and Row __module__.__len__ and
# __name__.__len__ checks into a single table. All values verified at runtime.
# ---------------------------------------------------------------------------

table sqlite3_extra24.class_identifier_lengths:
  description: "sqlite3 class __module__ and __name__ lengths — Connection, Cursor, Row"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [Connection_module_len,
       Connection.__module__.__len__,
       [],
       7,
       "len(Connection.__module__) == 7"]
    - [Cursor_module_len,
       Cursor.__module__.__len__,
       [],
       7,
       "len(Cursor.__module__) == 7"]
    - [Row_module_len,
       Row.__module__.__len__,
       [],
       7,
       "len(Row.__module__) == 7"]
    - [Connection_name_len,
       Connection.__name__.__len__,
       [],
       10,
       "len(Connection.__name__) == 10"]
    - [Cursor_name_len,
       Cursor.__name__.__len__,
       [],
       6,
       "len(Cursor.__name__) == 6"]
    - [Row_name_len,
       Row.__name__.__len__,
       [],
       3,
       "len(Row.__name__) == 3"]

# ---------------------------------------------------------------------------
# Table: exception class __module__ and __name__ __len__() values, plus connect
#
# No prior spec groups Error, DatabaseError, and OperationalError __module__.__len__
# and __name__.__len__ checks, together with connect.__module__.__len__, into a
# single table. All values verified at runtime.
# ---------------------------------------------------------------------------

table sqlite3_extra24.exception_and_connect_len_attrs:
  description: "sqlite3 exception class and connect __module__ and __name__ lengths — Error, DatabaseError, OperationalError, connect"
  kind: python_call_eq
  category: class_identity
  columns: [id, function, args, expected, description]
  rows:
    - [Error_module_len,
       Error.__module__.__len__,
       [],
       7,
       "len(Error.__module__) == 7"]
    - [DatabaseError_module_len,
       DatabaseError.__module__.__len__,
       [],
       7,
       "len(DatabaseError.__module__) == 7"]
    - [OperationalError_module_len,
       OperationalError.__module__.__len__,
       [],
       7,
       "len(OperationalError.__module__) == 7"]
    - [Error_name_len,
       Error.__name__.__len__,
       [],
       5,
       "len(Error.__name__) == 5"]
    - [DatabaseError_name_len,
       DatabaseError.__name__.__len__,
       [],
       13,
       "len(DatabaseError.__name__) == 13"]
    - [connect_module_len,
       connect.__module__.__len__,
       [],
       8,
       "len(connect.__module__) == 8"]
