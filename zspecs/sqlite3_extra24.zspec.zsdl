# ---------------------------------------------------------------------------

invariant sqlite3_extra24.DatabaseError.module_len:
  description: "len(sqlite3.DatabaseError.__module__) == 7 — 'sqlite3' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: DatabaseError.__module__.__len__
