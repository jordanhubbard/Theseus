# ---------------------------------------------------------------------------

invariant sqlite3_extra24.OperationalError.module_len:
  description: "len(sqlite3.OperationalError.__module__) == 7 — 'sqlite3' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: OperationalError.__module__.__len__
  args: []
