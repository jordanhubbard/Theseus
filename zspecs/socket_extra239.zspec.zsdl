spec: socket_extra239
version: ">=3.5"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "socket.zspec.zsdl — that spec covers AF_INET/AF_INET6/AF_UNIX, SOCK_STREAM/SOCK_DGRAM, IPPROTO_*, SOL_SOCKET, SHUT_*, herror/gaierror, gethostname/getdefaulttimeout/inet_aton/htonl."
    - "socket_extra.zspec.zsdl — covers create_connection/create_server/setdefaulttimeout/htons/ntohs names; setdefaulttimeout(None) return; inet_aton/inet_ntoa vectors; htons/ntohs/ntohl zero; htonl(1) little-endian."
    - "socket_extra2.zspec.zsdl — covers additional socket constants and function names."
  notes:
    - "This spec extends socket_extra.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "socket.error is an alias for OSError in Python 3; socket.error is OSError evaluates to True."
    - "socket.error.__name__ == 'OSError' — the name comes from the aliased class OSError, not 'error'."
    - "socket.error.__module__ == 'builtins' — OSError is a builtin exception."
    - "socket.error.__bases__[0].__name__ == 'Exception' — OSError inherits from Exception."
    - "socket.timeout is an alias for TimeoutError in Python 3.11+; socket.timeout is TimeoutError evaluates to True."
    - "socket.timeout.__name__ == 'TimeoutError' — the name comes from the aliased class TimeoutError."
    - "socket.timeout.__module__ == 'builtins' — TimeoutError is a builtin exception."
    - "socket.timeout.__bases__[0].__name__ == 'OSError' — TimeoutError inherits from OSError."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "socket raises OSError (and subclasses herror, gaierror, timeout) for I/O failures."
  stderr: "null"
  stickiness: "N/A — all tested invariants are class/attribute inspections, not I/O."
  codes: {}

# ---------------------------------------------------------------------------
# socket.error class identity — alias for OSError
# ---------------------------------------------------------------------------

invariant socket_extra239.error.class_name:
  description: "socket.error.__name__ == 'OSError' — socket.error is an alias for OSError"
  category: error_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

invariant socket_extra239.error.module:
  description: "socket.error.__module__ == 'builtins' — OSError is a builtin exception"
  category: error_identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant socket_extra239.error.base_class_name:
  description: "socket.error.__bases__[0].__name__ == 'Exception' — OSError inherits from Exception"
  category: error_identity
  kind: python_call_eq
  function: error.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["Exception"]
  expected: true

invariant socket_extra239.error.qualname:
  description: "socket.error.__qualname__ == 'OSError'"
  category: error_identity
  kind: python_call_eq
  function: error.__qualname__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout class identity — alias for TimeoutError
# ---------------------------------------------------------------------------

invariant socket_extra239.timeout.class_name:
  description: "socket.timeout.__name__ == 'TimeoutError' — socket.timeout is an alias for TimeoutError"
  category: timeout_identity
  kind: python_call_eq
  function: timeout.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

invariant socket_extra239.timeout.module:
  description: "socket.timeout.__module__ == 'builtins' — TimeoutError is a builtin exception"
  category: timeout_identity
  kind: python_call_eq
  function: timeout.__module__.__eq__
  args: ["builtins"]
  expected: true

invariant socket_extra239.timeout.base_class_name:
  description: "socket.timeout.__bases__[0].__name__ == 'OSError' — TimeoutError inherits from OSError"
  category: timeout_identity
  kind: python_call_eq
  function: timeout.__bases__.__getitem__
  args: [0]
  method: __name__.__eq__
  method_args: ["OSError"]
  expected: true

invariant socket_extra239.timeout.qualname:
  description: "socket.timeout.__qualname__ == 'TimeoutError'"
  category: timeout_identity
  kind: python_call_eq
  function: timeout.__qualname__.__eq__
  args: ["TimeoutError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.error IS OSError — verify via __name__ identity
# socket.error is OSError means socket.error.__name__ == 'OSError' (not 'error')
# ---------------------------------------------------------------------------

invariant socket_extra239.error.is_OSError_via_name:
  description: "socket.error.__name__ == 'OSError' confirms socket.error is an alias for OSError (not a separate subclass named 'error')"
  category: aliases
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.timeout IS TimeoutError — verify via __name__ identity
# socket.timeout is TimeoutError means socket.timeout.__name__ == 'TimeoutError'
# ---------------------------------------------------------------------------

invariant socket_extra239.timeout.is_TimeoutError_via_name:
  description: "socket.timeout.__name__ == 'TimeoutError' confirms socket.timeout is an alias for TimeoutError (not a separate subclass named 'timeout')"
  category: aliases
  kind: python_call_eq
  function: timeout.__name__.__eq__
  args: ["TimeoutError"]
  expected: true

# ---------------------------------------------------------------------------
# socket.error / socket.timeout as tables for compact attribute coverage
# ---------------------------------------------------------------------------

table socket_extra239.error.attrs:
  kind: python_call_eq
  category: error_identity
  id_prefix: sockerr239

  columns: [id, function, args, expected]
  rows:
    - [name,    error.__name__.__eq__,    ["OSError"],   true]
    - [module,  error.__module__.__eq__,  ["builtins"],  true]
    - [qualname, error.__qualname__.__eq__, ["OSError"], true]

table socket_extra239.timeout.attrs:
  kind: python_call_eq
  category: timeout_identity
  id_prefix: socktout239

  columns: [id, function, args, expected]
  rows:
    - [name,    timeout.__name__.__eq__,    ["TimeoutError"],  true]
    - [module,  timeout.__module__.__eq__,  ["builtins"],      true]
    - [qualname, timeout.__qualname__.__eq__, ["TimeoutError"], true]
