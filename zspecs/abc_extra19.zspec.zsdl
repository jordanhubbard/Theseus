spec: abc_extra19
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
    - "abc_extra18.zspec.zsdl — covers combined __qualname__ table for six abc members; __qualname__.__len__ for abstractclassmethod/abstractstaticmethod; abstractclassmethod.__mro__[1].__name__; abstractstaticmethod.__mro__[1].__name__."
    - "abc_extra11.zspec.zsdl — covers ABCMeta.__instancecheck__.__qualname__."
    - "abc_extra10.zspec.zsdl — covers ABCMeta.__subclasscheck__.__qualname__."
    - "abc_extra17.zspec.zsdl — covers combined __qualname__ table and __qualname__.__len__ table for ABCMeta/ABC/abstractmethod/get_cache_token."
  notes:
    - "This spec extends abc.zspec.zsdl through abc_extra18.zspec.zsdl."
    - "Focus: method-level __qualname__ values not yet combined into a single table in the extra19 namespace — ABCMeta.register, ABCMeta.__instancecheck__, ABCMeta.__subclasscheck__, and abstractmethod.__call__."
    - "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' — method qualname includes enclosing class; not previously collected as a standalone or combined invariant in any prior spec."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — covered as standalone in abc_extra11 but not in the extra19 combined table."
    - "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' — covered as standalone in abc_extra10 but not in the extra19 combined table."
    - "abc.abstractmethod.__call__.__qualname__ == 'function.__call__' — abstractmethod is a class whose __call__ is inherited from function; qualname is 'function.__call__'."
    - "abc.ABC.__qualname__ == 'ABC' — top-level class, qualname equals name."
    - "abc.ABCMeta.__qualname__ == 'ABCMeta' — top-level class, qualname equals name."
    - "abc.abstractmethod.__qualname__ == 'abstractmethod' — top-level class, qualname equals name."
    - "abc.get_cache_token.__qualname__ == 'get_cache_token' — top-level function, qualname equals name."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for abc method-level members — combined table in extra19 namespace
#
# ABCMeta.register.__qualname__ has never appeared in any prior abc spec.
# ABCMeta.__instancecheck__/__subclasscheck__ each covered as standalones in
# abc_extra11/abc_extra10, but not combined in the extra19 namespace.
# abstractmethod.__call__.__qualname__ == 'function.__call__' is novel.
# ---------------------------------------------------------------------------

table abc_extra19.method_qualnames:
  description: "__qualname__ for abc method-level members in the extra19 namespace"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [ABC,                        ABC.__qualname__.__eq__,                        ["ABC"],                        true]
    - [ABCMeta,                    ABCMeta.__qualname__.__eq__,                    ["ABCMeta"],                    true]
    - [abstractmethod,             abstractmethod.__qualname__.__eq__,             ["abstractmethod"],             true]
    - [get_cache_token,            get_cache_token.__qualname__.__eq__,            ["get_cache_token"],            true]
    - [ABCMeta_register,           "ABCMeta.register.__qualname__.__eq__",         ["ABCMeta.register"],          true]
    - [ABCMeta_instancecheck,      "ABCMeta.__instancecheck__.__qualname__.__eq__", ["ABCMeta.__instancecheck__"], true]
    - [ABCMeta_subclasscheck,      "ABCMeta.__subclasscheck__.__qualname__.__eq__", ["ABCMeta.__subclasscheck__"], true]
    - [abstractmethod_call,        "abstractmethod.__call__.__qualname__.__eq__",  ["function.__call__"],         true]

# ---------------------------------------------------------------------------
# abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' — standalone
#
# No prior abc spec records ABCMeta.register.__qualname__ as a standalone
# invariant. Method qualnames include the enclosing class name.
# ---------------------------------------------------------------------------

invariant abc_extra19.ABCMeta.register.qualname:
  description: "abc.ABCMeta.register.__qualname__ == 'ABCMeta.register' — method qualname includes enclosing class"
  category: method_qualnames
  kind: python_call_eq
  function: "ABCMeta.register.__qualname__.__eq__"
  args: ["ABCMeta.register"]
  expected: true

# ---------------------------------------------------------------------------
# abc.abstractmethod.__call__.__qualname__ == 'function.__call__' — standalone
#
# abstractmethod is a class that inherits __call__ from function (the C-level
# function type). Its __call__.__qualname__ is therefore 'function.__call__',
# not 'abstractmethod.__call__'. No prior spec records this value.
# ---------------------------------------------------------------------------

invariant abc_extra19.abstractmethod.call.qualname:
  description: "abc.abstractmethod.__call__.__qualname__ == 'function.__call__' — inherited from C-level function type"
  category: method_qualnames
  kind: python_call_eq
  function: "abstractmethod.__call__.__qualname__.__eq__"
  args: ["function.__call__"]
  expected: true
