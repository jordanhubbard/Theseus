spec: operator_extra21
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra20.zspec.zsdl."
    - "operator_extra20 covers: __name__.__eq__ for add/sub/mul/truediv/floordiv/mod/pow/neg; arithmetic call results table; truediv float invariant."
    - "operator_extra19 covers: getitem/contains/length_hint/index/concat call results."
    - "No prior operator spec records __bases__[0].__name__.__eq__ for attrgetter/itemgetter/methodcaller together in the extra21 namespace."
    - "attrgetter, itemgetter, and methodcaller are C-level callable classes inheriting directly from 'object'."
    - "operator.attrgetter.__module__ == 'operator' (public alias); the arithmetic functions (add/mul/sub) have __module__ == '_operator' (C extension)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __bases__[0].__name__.__eq__ table — attrgetter, itemgetter, methodcaller
#
# Verifies that each callable class's direct base class is 'object'.
# All three are C-level types with no intermediate Python base class.
# No prior operator spec records these three base names in one table in
# the extra21 namespace.
# ---------------------------------------------------------------------------

table operator_extra21.base_names:
  kind: python_call_eq
  category: class_attrs
  columns: [id, function, args, expected, description]
  rows:
    - [operator_extra21.base_names.attrgetter,
       "attrgetter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "operator.attrgetter.__bases__[0].__name__ == 'object'"]
    - [operator_extra21.base_names.itemgetter,
       "itemgetter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "operator.itemgetter.__bases__[0].__name__ == 'object'"]
    - [operator_extra21.base_names.methodcaller,
       "methodcaller.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "operator.methodcaller.__bases__[0].__name__ == 'object'"]

# ---------------------------------------------------------------------------
# __qualname__.__eq__ for attrgetter, itemgetter, methodcaller
#
# Each class has a simple (non-nested) qualname equal to its class name.
# No prior operator spec records these qualname checks in the extra21 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra21.attrgetter.qualname:
  description: "operator.attrgetter.__qualname__ == 'attrgetter' — simple qualname, no nesting"
  category: qualnames
  kind: python_call_eq
  function: attrgetter.__qualname__.__eq__
  args: ["attrgetter"]
  expected: true

invariant operator_extra21.itemgetter.qualname:
  description: "operator.itemgetter.__qualname__ == 'itemgetter' — simple qualname, no nesting"
  category: qualnames
  kind: python_call_eq
  function: itemgetter.__qualname__.__eq__
  args: ["itemgetter"]
  expected: true

invariant operator_extra21.methodcaller.qualname:
  description: "operator.methodcaller.__qualname__ == 'methodcaller' — simple qualname, no nesting"
  category: qualnames
  kind: python_call_eq
  function: methodcaller.__qualname__.__eq__
  args: ["methodcaller"]
  expected: true

# ---------------------------------------------------------------------------
# __module__.__eq__ for attrgetter, itemgetter, methodcaller
#
# These three callable classes are exposed under the public 'operator' module
# name (not '_operator'), so their __module__ == 'operator'.
# No prior operator spec records these three module checks in the extra21
# namespace.
# ---------------------------------------------------------------------------

invariant operator_extra21.attrgetter.module:
  description: "operator.attrgetter.__module__ == 'operator' — public module name"
  category: class_attrs
  kind: python_call_eq
  function: attrgetter.__module__.__eq__
  args: ["operator"]
  expected: true

invariant operator_extra21.itemgetter.module:
  description: "operator.itemgetter.__module__ == 'operator' — public module name"
  category: class_attrs
  kind: python_call_eq
  function: itemgetter.__module__.__eq__
  args: ["operator"]
  expected: true

invariant operator_extra21.methodcaller.module:
  description: "operator.methodcaller.__module__ == 'operator' — public module name"
  category: class_attrs
  kind: python_call_eq
  function: methodcaller.__module__.__eq__
  args: ["operator"]
  expected: true
