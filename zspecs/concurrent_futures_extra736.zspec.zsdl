spec: concurrent_futures_extra736
version: ">=3.9"
backend: python_module(concurrent.futures)
docs: "Behavioral spec for concurrent.futures ThreadPoolExecutor and ProcessPoolExecutor method qualnames"
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from: []
  notes: "Covers ThreadPoolExecutor and ProcessPoolExecutor method qualnames and class-level identity"
  created_at: "2026-04-12"

table concurrent_futures_extra736.executor_qualnames:
  description: "concurrent.futures ThreadPoolExecutor and ProcessPoolExecutor method qualname identity checks"
  kind: python_call_eq
  category: qualname_identity
  id_prefix: cf736xx
  columns: [id, function, args, expected]
  rows:
    - ["cf736xx001", "concurrent.futures.ThreadPoolExecutor.submit.__qualname__.__eq__", ["ThreadPoolExecutor.submit"], true]
    - ["cf736xx002", "concurrent.futures.ThreadPoolExecutor.map.__qualname__.__eq__", ["ThreadPoolExecutor.map"], true]
    - ["cf736xx003", "concurrent.futures.ThreadPoolExecutor.shutdown.__qualname__.__eq__", ["ThreadPoolExecutor.shutdown"], true]
    - ["cf736xx004", "concurrent.futures.ThreadPoolExecutor.__enter__.__qualname__.__eq__", ["ThreadPoolExecutor.__enter__"], true]
    - ["cf736xx005", "concurrent.futures.ThreadPoolExecutor.__exit__.__qualname__.__eq__", ["ThreadPoolExecutor.__exit__"], true]
    - ["cf736xx006", "concurrent.futures.ProcessPoolExecutor.submit.__qualname__.__eq__", ["ProcessPoolExecutor.submit"], true]
    - ["cf736xx007", "concurrent.futures.ProcessPoolExecutor.map.__qualname__.__eq__", ["ProcessPoolExecutor.map"], true]
    - ["cf736xx008", "concurrent.futures.ProcessPoolExecutor.shutdown.__qualname__.__eq__", ["ProcessPoolExecutor.shutdown"], true]
    - ["cf736xx009", "concurrent.futures.ThreadPoolExecutor.__qualname__.__eq__", ["ThreadPoolExecutor"], true]
    - ["cf736xx010", "concurrent.futures.ProcessPoolExecutor.__qualname__.__eq__", ["ProcessPoolExecutor"], true]
    - ["cf736xx011", "concurrent.futures.ThreadPoolExecutor.__doc__.__class__.__name__.__eq__", ["str"], true]
    - ["cf736xx012", "concurrent.futures.ProcessPoolExecutor.__doc__.__class__.__name__.__eq__", ["str"], true]
