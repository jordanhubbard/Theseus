spec: hashlib_extra1441
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "https://docs.python.org/3/library/_hashlib.html — CPython _hashlib extension documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_hashlib.c"
    - "hashlib_extra.zspec.zsdl — covers blake2b/blake2s name attrs; sha3_224/sha3_384 digest_size/block_size; algorithms_available/guaranteed; pbkdf2_hmac."
    - "hashlib_extra2.zspec.zsdl — covers md5/sha1/sha256 empty hexdigest; sha256/sha512 digest_size eq; algorithms_guaranteed type; new() api."
    - "hashlib_extra3.zspec.zsdl — covers sha512/sha384/sha224/sha3_256/sha3_512/blake2b/blake2s name attrs; sha512/md5 block_size; openssl constructor names; algorithms_guaranteed len."
    - "hashlib_extra4.zspec.zsdl — covers algorithms_guaranteed/available __contains__ for sha256/sha512/md5/sha1/sha3_256/blake2b; new.__name__/new.__module__."
  notes:
    - "This spec does NOT duplicate invariants present in any prior hashlib spec."
    - "Wave 543 theme: __subclasshook__ and __instancecheck__ checks for _hashlib.HASH and _hashlib.HASHXOF."
    - "_hashlib.HASH is the C-level type returned by hashlib.new('md5').__class__; accessible as _hashlib.HASH."
    - "_hashlib.HASHXOF is the C-level type for extendable-output functions (e.g. shake_128/shake_256)."
    - "_hashlib.HASH.__subclasshook__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_hashlib.HASH.__instancecheck__.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__subclasshook__ in _hashlib.HASH.__dict__ == False — inherited from type/object, not defined on HASH. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "__instancecheck__ in _hashlib.HASH.__dict__ == False — inherited from type/object, not defined on HASH. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "_hashlib.HASHXOF shares the same pattern: both __subclasshook__ and __instancecheck__ are 'builtin_function_or_method' and absent from HASHXOF.__dict__."
    - "The 'builtin_function_or_method' type name reflects that both methods are inherited from the type() metaclass at the C level — no Python-level override exists on HASH or HASHXOF."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# _hashlib.HASH — __subclasshook__ and __instancecheck__ type and dict checks
#
# Wave 543 theme: Both methods are inherited from the type metaclass at C level.
# Neither HASH nor HASHXOF defines them in their own __dict__.
# Access path uses the _hashlib module directly (hashlib re-exports the type
# implicitly via hashlib.new().__class__, but _hashlib.HASH is the canonical name).
# ---------------------------------------------------------------------------

table hashlib_extra1441.HASH_subclasshook:
  description: "_hashlib.HASH.__subclasshook__.__class__.__name__=='builtin_function_or_method' and not in HASH.__dict__ — HASH inherits __subclasshook__ from type metaclass at C level; no Python-level override; wave 543 first hl1441sh anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl1441sh

  columns: [id, function, args, expected, description]
  rows:
    - [hl1441sh001, "_hashlib.HASH.__subclasshook__.__class__.__name__.__eq__", ["builtin_function_or_method"], true,  "_hashlib.HASH.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — C-level inheritance from type metaclass"]
    - [hl1441sh002, "_hashlib.HASH.__dict__.__contains__",                      ["__subclasshook__"],           false, "_hashlib.HASH.__dict__ does not contain '__subclasshook__' — inherited from type, not defined on HASH"]
    - [hl1441sh003, "_hashlib.HASH.__subclasshook__.__class__.__name__.__eq__", ["classmethod_descriptor"],     false, "_hashlib.HASH.__subclasshook__.__class__.__name__ is NOT 'classmethod_descriptor' — it is 'builtin_function_or_method'"]
    - [hl1441sh004, "_hashlib.HASH.__subclasshook__.__class__.__name__.__eq__", ["method_descriptor"],          false, "_hashlib.HASH.__subclasshook__.__class__.__name__ is NOT 'method_descriptor' — it is 'builtin_function_or_method'"]
    - [hl1441sh005, "_hashlib.HASH.__instancecheck__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "_hashlib.HASH.__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — C-level inheritance from type metaclass"]
    - [hl1441sh006, "_hashlib.HASH.__dict__.__contains__",                       ["__instancecheck__"],          false, "_hashlib.HASH.__dict__ does not contain '__instancecheck__' — inherited from type, not defined on HASH"]

# ---------------------------------------------------------------------------
# _hashlib.HASHXOF — __subclasshook__ and __instancecheck__ type and dict checks
#
# HASHXOF is the C-level type for extendable-output functions (shake_128, shake_256).
# It follows the same pattern as HASH: both methods are inherited from type, absent
# from HASHXOF.__dict__, and have class name 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

table hashlib_extra1441.HASHXOF_subclasshook:
  description: "_hashlib.HASHXOF.__subclasshook__.__class__.__name__=='builtin_function_or_method' and not in HASHXOF.__dict__ — HASHXOF follows same pattern as HASH; both methods inherited from type at C level; no Python-level override; wave 543 first hl1441xf anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl1441xf

  columns: [id, function, args, expected, description]
  rows:
    - [hl1441xf001, "_hashlib.HASHXOF.__subclasshook__.__class__.__name__.__eq__", ["builtin_function_or_method"], true,  "_hashlib.HASHXOF.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — C-level inheritance from type metaclass"]
    - [hl1441xf002, "_hashlib.HASHXOF.__dict__.__contains__",                      ["__subclasshook__"],           false, "_hashlib.HASHXOF.__dict__ does not contain '__subclasshook__' — inherited from type, not defined on HASHXOF"]
    - [hl1441xf003, "_hashlib.HASHXOF.__instancecheck__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "_hashlib.HASHXOF.__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — C-level inheritance from type metaclass"]
    - [hl1441xf004, "_hashlib.HASHXOF.__dict__.__contains__",                       ["__instancecheck__"],          false, "_hashlib.HASHXOF.__dict__ does not contain '__instancecheck__' — inherited from type, not defined on HASHXOF"]
    - [hl1441xf005, "_hashlib.HASHXOF.__subclasshook__.__class__.__name__.__eq__", ["classmethod_descriptor"],     false, "_hashlib.HASHXOF.__subclasshook__.__class__.__name__ is NOT 'classmethod_descriptor'"]
    - [hl1441xf006, "_hashlib.HASHXOF.__instancecheck__.__class__.__name__.__eq__", ["wrapper_descriptor"],        false, "_hashlib.HASHXOF.__instancecheck__.__class__.__name__ is NOT 'wrapper_descriptor'"]

# ---------------------------------------------------------------------------
# Symmetry checks: HASH and HASHXOF share the same __subclasshook__ type name
#
# Both types are C-level extension types that inherit from type via the same
# mechanism. Their __subclasshook__ and __instancecheck__ type names are
# identical: 'builtin_function_or_method'. This table anchors the symmetry
# by verifying the string equality of the two class names against each other.
# ---------------------------------------------------------------------------

table hashlib_extra1441.HASH_HASHXOF_symmetry:
  description: "_hashlib.HASH and _hashlib.HASHXOF have identical __subclasshook__/__instancecheck__ class names — both C-level types inherit from type metaclass identically; 'builtin_function_or_method' for both; symmetry confirms consistent C-extension metaclass protocol; wave 543 hl1441sy anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: hl1441sy

  columns: [id, function, args, expected, description]
  rows:
    - [hl1441sy001, "_hashlib.HASH.__subclasshook__.__class__.__name__.__eq__",  ["builtin_function_or_method"], true, "_hashlib.HASH.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — symmetry with HASHXOF"]
    - [hl1441sy002, "_hashlib.HASHXOF.__subclasshook__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "_hashlib.HASHXOF.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' — symmetry with HASH"]
    - [hl1441sy003, "_hashlib.HASH.__instancecheck__.__class__.__name__.__eq__",  ["builtin_function_or_method"], true, "_hashlib.HASH.__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — symmetry with HASHXOF"]
    - [hl1441sy004, "_hashlib.HASHXOF.__instancecheck__.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "_hashlib.HASHXOF.__instancecheck__.__class__.__name__ == 'builtin_function_or_method' — symmetry with HASH"]
    - [hl1441sy005, "_hashlib.HASH.__dict__.__contains__",  ["__subclasshook__"],  false, "_hashlib.HASH.__dict__ missing '__subclasshook__' — confirms C-level inheritance pattern"]
    - [hl1441sy006, "_hashlib.HASHXOF.__dict__.__contains__", ["__subclasshook__"], false, "_hashlib.HASHXOF.__dict__ missing '__subclasshook__' — confirms C-level inheritance pattern"]
