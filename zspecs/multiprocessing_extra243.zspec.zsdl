    - [fc_name_len,  context.ForkContext.__name__.__len__,                   [],                         11,   "multiprocessing.context.ForkContext.__name__.__len__() == 11; verified with Python 3.14.3"]
    - [fc_mod_eq,    context.ForkContext.__module__.__eq__,                  ["multiprocessing.context"], true, "multiprocessing.context.ForkContext.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [fc_mod_len,   context.ForkContext.__module__.__len__,                 [],                         23,   "multiprocessing.context.ForkContext.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [fc_base_eq,   "context.ForkContext.__bases__[0].__name__.__eq__",     ["BaseContext"],            true, "multiprocessing.context.ForkContext.__bases__[0].__name__ == 'BaseContext'; verified with Python 3.14.3"]
    - [fc_base_len,  "context.ForkContext.__bases__[0].__name__.__len__",    [],                         11,   "multiprocessing.context.ForkContext.__bases__[0].__name__.__len__() == 11; verified with Python 3.14.3"]
    - [fsc_name_eq,  context.ForkServerContext.__name__.__eq__,              ["ForkServerContext"],      true, "multiprocessing.context.ForkServerContext.__name__ == 'ForkServerContext'; verified with Python 3.14.3"]
    - [fsc_name_len, context.ForkServerContext.__name__.__len__,             [],                         17,   "multiprocessing.context.ForkServerContext.__name__.__len__() == 17; verified with Python 3.14.3"]
