invariant multiprocessing_extra243.spawn_context_module:
  description: "multiprocessing.context.SpawnContext.__module__.__eq__('multiprocessing.context') returns True — SpawnContext is defined in multiprocessing.context(len=23); all three start-method context classes share this same module string; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: context.SpawnContext.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra243.fork_server_context_name:
  description: "multiprocessing.context.ForkServerContext.__name__.__eq__('ForkServerContext') returns True — ForkServerContext(len=17) is the longest-named context class, longer than SpawnContext(len=12) and ForkContext(len=11); all inherit from BaseContext(len=11); verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: context.ForkServerContext.__name__.__eq__
  args: ["ForkServerContext"]
  expected: true
