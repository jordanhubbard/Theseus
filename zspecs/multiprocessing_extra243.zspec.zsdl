spec: multiprocessing_extra243
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py (SpawnContext, ForkContext, ForkServerContext, BaseContext)"
  notes:
    - "multiprocessing.get_start_method() == 'spawn' on macOS/Darwin — macOS deprecated 'fork' as default due to safety issues; Python 3.8+ changed macOS default to 'spawn'."
    - "multiprocessing.context.SpawnContext.__name__ == 'SpawnContext' (len=12); __module__ == 'multiprocessing.context' (len=23); __bases__[0].__name__ == 'BaseContext' (len=11)."
    - "multiprocessing.context.ForkContext.__name__ == 'ForkContext' (len=11); __module__ == 'multiprocessing.context' (len=23); __bases__[0].__name__ == 'BaseContext' (len=11) — ForkContext name and BaseContext name share length 11."
    - "multiprocessing.context.ForkServerContext.__name__ == 'ForkServerContext' (len=17); __module__ == 'multiprocessing.context' (len=23); __bases__[0].__name__ == 'BaseContext' (len=11)."
    - "All three context classes inherit from BaseContext(len=11) in multiprocessing.context(len=23)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing context class identity — SpawnContext, ForkContext, ForkServerContext
#
# context.SpawnContext.__name__ == 'SpawnContext' (len=12)
# context.SpawnContext.__module__ == 'multiprocessing.context' (len=23)
# context.SpawnContext.__bases__[0].__name__ == 'BaseContext' (len=11)
#
# context.ForkContext.__name__ == 'ForkContext' (len=11)
# context.ForkContext.__module__ == 'multiprocessing.context' (len=23)
# context.ForkContext.__bases__[0].__name__ == 'BaseContext' (len=11)
#
# context.ForkServerContext.__name__ == 'ForkServerContext' (len=17)
# context.ForkServerContext.__module__ == 'multiprocessing.context' (len=23)
# context.ForkServerContext.__bases__[0].__name__ == 'BaseContext' (len=11)
# ---------------------------------------------------------------------------

table multiprocessing_extra243.spawn_context_class_identity:
  description: "multiprocessing SpawnContext class identity — SpawnContext(len=12) inherits from BaseContext(len=11); __module__=='multiprocessing.context'(len=23); on macOS 'spawn' is the default start method; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mp243sc

  columns: [id, function, args, expected, description]
  rows:
    - [sc_name_eq,   context.SpawnContext.__name__.__eq__,                   ["SpawnContext"],           true, "multiprocessing.context.SpawnContext.__name__ == 'SpawnContext'; verified with Python 3.14.3"]
    - [sc_name_len,  context.SpawnContext.__name__.__len__,                  [],                         12,   "multiprocessing.context.SpawnContext.__name__.__len__() == 12; verified with Python 3.14.3"]
    - [sc_mod_eq,    context.SpawnContext.__module__.__eq__,                 ["multiprocessing.context"], true, "multiprocessing.context.SpawnContext.__module__ == 'multiprocessing.context'; verified with Python 3.14.3"]
    - [sc_mod_len,   context.SpawnContext.__module__.__len__,                [],                         23,   "multiprocessing.context.SpawnContext.__module__.__len__() == 23; verified with Python 3.14.3"]
    - [sc_base_eq,   "context.SpawnContext.__bases__[0].__name__.__eq__",    ["BaseContext"],            true, "multiprocessing.context.SpawnContext.__bases__[0].__name__ == 'BaseContext'; verified with Python 3.14.3"]
    - [sc_base_len,  "context.SpawnContext.__bases__[0].__name__.__len__",   [],                         11,   "multiprocessing.context.SpawnContext.__bases__[0].__name__.__len__() == 11; verified with Python 3.14.3"]

