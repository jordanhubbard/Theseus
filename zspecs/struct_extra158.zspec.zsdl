    - [str_qualname_obj,      "Struct.__str__.__qualname__.__eq__",              ["object.__str__"],             true, "struct.Struct.__str__.__qualname__ == 'object.__str__' (14 chars = 'object.'=7 + '__str__'=7; inherited from object; 'object.' prefix not 'Struct.')"]
