# ---------------------------------------------------------------------------
# struct.Struct.__new__.__qualname__.__eq__('Struct.__new__') — standalone
#
# struct.Struct.__new__.__qualname__ is 'Struct.__new__' (14 chars = 'Struct.'=7 + '__new__'=7).
# Struct.__new__ is a builtin_function_or_method. The __new__ method is the object allocator;
# it creates a new instance of Struct before __init__ initializes it. In C extension types like
# Struct, __new__ is implemented as a C function (hence builtin_function_or_method). '__new__'
# (7 chars) = '__'=2 + 'new'=3 + '__'=2. Struct defines its own __new__ (not inherited from
# object), so the qualname is 'Struct.__new__' with the 'Struct.' prefix (not 'object.__new__').
# 'Struct.__new__' (14 chars) is 1 char shorter than 'Struct.__repr__' (15 chars; extra157).
# No prior struct spec anchors Struct.__new__.__qualname__ as a standalone under structnew158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra158.Struct_new_qualname_eq:
  description: "struct.Struct.__new__.__qualname__.__eq__('Struct.__new__') == True — 14 chars = 'Struct.'=7 + '__new__'=7; builtin_function_or_method (C-level allocator; not wrapper_descriptor like __init__); Struct defines its own __new__ so qualname has 'Struct.' prefix (not 'object.' prefix); '__new__'=7 chars; ties 'object.__str__'=14 chars; shorter than 'Struct.__repr__'=15 (extra157); length ordering: Struct.pack(11) < Struct.__new__(14) < Struct.__repr__(15; extra157) < Struct.__sizeof__(17; extra157); no prior struct spec anchors this as a standalone; first standalone under structnew158"
  category: identity
  kind: python_call_eq
  function: Struct.__new__.__qualname__.__eq__
  args: ["Struct.__new__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__str__.__qualname__.__eq__('object.__str__') — standalone
#
# struct.Struct.__str__.__qualname__ is 'object.__str__' (14 chars = 'object.'=7 + '__str__'=7).
# Unlike __repr__, which has qualname 'Struct.__repr__' (Struct defines its own repr), __str__
# is NOT defined on Struct. It is inherited from the built-in object class. When Python looks
# up __str__ on a Struct instance, it finds the 'object.__str__' slot via the MRO. The qualname
# 'object.__str__' reflects that the method's defining class is 'object', not 'Struct'. This
# also makes __str__ a wrapper_descriptor (the type used for C-level special methods inherited
# from object). 'object.__str__' (14 chars) ties 'Struct.__new__' (14 chars) because both
# 'object.'=7 and 'Struct.'=7 have the same length prefix. No prior struct spec anchors
# Struct.__str__.__qualname__ as a standalone under structnew158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra158.Struct_str_qualname_eq:
  description: "struct.Struct.__str__.__qualname__.__eq__('object.__str__') == True — 14 chars = 'object.'=7 + '__str__'=7; 'object.' prefix (not 'Struct.') because __str__ is NOT defined on Struct; inherited from built-in object class via MRO; wrapper_descriptor type (C-level special method); contrasts with __repr__ which has 'Struct.' prefix (Struct defines its own __repr__; extra157 anchors 'Struct.__repr__'=15 chars); 'object.__str__' ties 'Struct.__new__' at 14 chars (both prefixes are 7 chars); no prior struct spec anchors this as a standalone; first standalone under structnew158"
  category: identity
  kind: python_call_eq
  function: Struct.__str__.__qualname__.__eq__
  args: ["object.__str__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__class__.__name__.__eq__('type') — standalone
#
# struct.error.__class__.__name__ is 'type' (4 chars). struct.error is a Python exception
# class. Every class in Python has a metaclass; for standard classes the metaclass is 'type'.
# So struct.error.__class__ is the built-in 'type' metaclass, and struct.error.__class__.__name__
# == 'type'. This contrasts with struct.error.__name__ == 'error' (the class's own name; extra151
# anchors this) and struct.error.__class__.__name__ == 'type' (the metaclass name; novel here).
# struct.error inherits from Exception (struct.error.__bases__[0].__name__ == 'Exception').
# struct.error.__module__ == 'struct' (extra151 anchors this). struct.error.__doc__ is None
# (extra153 anchors this). 'type' (4 chars) is the shortest string anchored in this spec.
# No prior struct spec anchors error.__class__.__name__ as a standalone under structnew158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra158.struct_error_class_type:
  description: "struct.error.__class__.__name__.__eq__('type') == True — 'type' (4 chars); struct.error is a Python exception class; its metaclass is the built-in 'type'; __class__.__name__ gives the metaclass name ('type'), not the class name itself ('error'; extra151 anchors error.__name__=='error'); extra151 anchors error.__name__=='error' and error.__module__=='struct' but NOT __class__.__name__=='type'; extra153 anchors error.__doc__==None; 'type' (4 chars) is shortest string in this spec; struct.error inherits from Exception (__bases__[0].__name__=='Exception'); no prior struct spec anchors this as a standalone; first standalone under structnew158"
  category: identity
  kind: python_call_eq
  function: error.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception') — standalone
#
# struct.error.__bases__[0].__name__ is 'Exception' (9 chars). struct.error.__bases__ is a
# tuple containing exactly one element: the Exception class. struct.error is defined as:
# class error(Exception): pass (in Modules/_struct.c). Exception (9 chars) is the standard
# base class for most user-defined and module-specific exceptions in Python. It inherits from
# BaseException -> object. struct.error is therefore in the exception hierarchy:
# struct.error -> Exception -> BaseException -> object. 'Exception' (9 chars) =
# 'Exception'=9. struct.error.__bases__[0].__module__ == 'builtins' (the Exception class
# is defined in the built-in builtins module). No prior struct spec anchors
# struct.error.__bases__[0].__name__ as a standalone under structnew158.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra158.struct_error_base_exception:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — 'Exception' (9 chars); struct.error directly inherits from Exception; inheritance chain: struct.error -> Exception -> BaseException -> object; struct.error is defined as 'class error(Exception): pass' in Modules/_struct.c; Exception.__module__=='builtins' (error.__bases__[0].__module__=='builtins'); __bases__ is a 1-element tuple; __bases__[0] is the Exception class; 'Exception'=9 chars; struct.error is a module-level exception for struct format/value errors; no prior struct spec anchors this as a standalone; first standalone under structnew158"
  category: identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

