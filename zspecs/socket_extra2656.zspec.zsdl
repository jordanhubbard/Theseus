spec: socket_extra2656
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket classes documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from: ["CPython source code"]
  notes: ["Wave 624: checks socket.socket, socket.AddressFamily, socket.SocketKind __dict__ for __contains__, __add__, __mul__ presence. All three classes return False for all three dunders — none defines __contains__, __add__, or __mul__ in its own __dict__."]
  created_at: "2026-04-13"
error_model: python_exceptions

table socket_extra2656.socket_dict_presence:
  description: "socket.socket __dict__ does not contain __contains__, __add__, or __mul__"
  kind: python_call_eq
  category: dict_presence
  id_prefix: sk2656sc
  columns: [id, function, args, expected]
  rows:
    - ["sk2656sc001", socket.socket.__dict__.__contains__, ["__contains__"], false]
    - ["sk2656sc002", socket.socket.__dict__.__contains__, ["__add__"],      false]
    - ["sk2656sc003", socket.socket.__dict__.__contains__, ["__mul__"],      false]

