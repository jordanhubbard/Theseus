spec: functools_extra264
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "This spec covers: functools.reduce function identity — name, qualname, module, class; functools.cmp_to_key function identity; functools.total_ordering decorator identity."
    - "functools.reduce.__name__ == 'reduce' — C-level builtin function name. Verified with Python 3.14.3."
    - "functools.reduce.__qualname__ == 'reduce' — top-level; qualname equals name. Verified with Python 3.14.3."
    - "functools.reduce.__module__ == '_functools' — reduce is implemented in the _functools C extension, not in Lib/functools.py. Verified with Python 3.14.3."
    - "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — reduce is a C-level builtin, not a Python function. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__name__ == 'cmp_to_key' — C-level builtin function name. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__qualname__ == 'cmp_to_key' — top-level; qualname equals name. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__module__ == '_functools' — cmp_to_key is implemented in the _functools C extension. Verified with Python 3.14.3."
    - "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — cmp_to_key is a C-level builtin. Verified with Python 3.14.3."
    - "functools.total_ordering.__name__ == 'total_ordering' — Python function name. Verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering' — top-level decorator function; qualname equals name. Verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools' — total_ordering is defined in Lib/functools.py as a Python function. Verified with Python 3.14.3."
    - "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a plain Python function. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.reduce function identity contracts
#
# functools.reduce.__name__              == 'reduce'
# functools.reduce.__qualname__          == 'reduce'
# functools.reduce.__module__            == '_functools'
# functools.reduce.__class__.__name__    == 'builtin_function_or_method'
#
# reduce is a C-level builtin from _functools. New to extra264.
# ---------------------------------------------------------------------------

table functools_extra264.reduce_identity:
  description: "functools.reduce name, qualname, module, class contracts; C-level builtin from _functools; new to extra264"
  kind: python_call_eq
  category: identity
  id_prefix: ftre264

  columns: [id, function, args, expected, description]
  rows:
    - [reduce_name_eq,
       reduce.__name__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__name__.__eq__('reduce') == True — C-level builtin function name; new to extra264"]
    - [reduce_qualname_eq,
       reduce.__qualname__.__eq__,
       ["reduce"],
       true,
       "functools.reduce.__qualname__.__eq__('reduce') == True — top-level; qualname equals name; new to extra264"]
    - [reduce_module_eq,
       reduce.__module__.__eq__,
       ["_functools"],
       true,
       "functools.reduce.__module__.__eq__('_functools') == True — implemented in the _functools C extension; new to extra264"]
    - [reduce_class_name_eq,
       reduce.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.reduce.__class__.__name__.__eq__('builtin_function_or_method') == True — C-level builtin, not a Python function; new to extra264"]
    - [reduce_name_class_eq,
       reduce.__name__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.reduce.__name__.__class__.__name__.__eq__('str') == True — __name__ is a str; new to extra264"]

# ---------------------------------------------------------------------------
# Table 2: functools.cmp_to_key function identity contracts
#
# functools.cmp_to_key.__name__              == 'cmp_to_key'
# functools.cmp_to_key.__qualname__          == 'cmp_to_key'
# functools.cmp_to_key.__module__            == '_functools'
# functools.cmp_to_key.__class__.__name__    == 'builtin_function_or_method'
#
# cmp_to_key is a C-level builtin from _functools. New to extra264.
# ---------------------------------------------------------------------------

table functools_extra264.cmp_to_key_identity:
  description: "functools.cmp_to_key name, qualname, module, class contracts; C-level builtin from _functools; new to extra264"
  kind: python_call_eq
  category: identity
  id_prefix: ftck264

  columns: [id, function, args, expected, description]
  rows:
    - [cmp_to_key_name_eq,
       cmp_to_key.__name__.__eq__,
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__name__.__eq__('cmp_to_key') == True — C-level builtin function name; new to extra264"]
    - [cmp_to_key_qualname_eq,
       cmp_to_key.__qualname__.__eq__,
       ["cmp_to_key"],
       true,
       "functools.cmp_to_key.__qualname__.__eq__('cmp_to_key') == True — top-level; qualname equals name; new to extra264"]
    - [cmp_to_key_module_eq,
       cmp_to_key.__module__.__eq__,
       ["_functools"],
       true,
       "functools.cmp_to_key.__module__.__eq__('_functools') == True — implemented in the _functools C extension; new to extra264"]
    - [cmp_to_key_class_name_eq,
       cmp_to_key.__class__.__name__.__eq__,
       ["builtin_function_or_method"],
       true,
       "functools.cmp_to_key.__class__.__name__.__eq__('builtin_function_or_method') == True — C-level builtin, not a Python function; new to extra264"]
    - [cmp_to_key_qualname_class_eq,
       cmp_to_key.__qualname__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.cmp_to_key.__qualname__.__class__.__name__.__eq__('str') == True — __qualname__ is a str; new to extra264"]

# ---------------------------------------------------------------------------
# Table 3: functools.total_ordering decorator identity contracts
#
# functools.total_ordering.__name__              == 'total_ordering'
# functools.total_ordering.__qualname__          == 'total_ordering'
# functools.total_ordering.__module__            == 'functools'
# functools.total_ordering.__class__.__name__    == 'function'
#
# total_ordering is a plain Python function defined in Lib/functools.py.
# New to extra264.
# ---------------------------------------------------------------------------

table functools_extra264.total_ordering_identity:
  description: "functools.total_ordering name, qualname, module, class contracts; Python function decorator; new to extra264"
  kind: python_call_eq
  category: identity
  id_prefix: ftto264

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_name_eq,
       total_ordering.__name__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__name__.__eq__('total_ordering') == True — Python function name; new to extra264"]
    - [total_ordering_qualname_eq,
       total_ordering.__qualname__.__eq__,
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — top-level decorator function; qualname equals name; new to extra264"]
    - [total_ordering_module_eq,
       total_ordering.__module__.__eq__,
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — defined in Lib/functools.py as a Python function; new to extra264"]
    - [total_ordering_class_name_eq,
       total_ordering.__class__.__name__.__eq__,
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — plain Python function, not a C builtin; new to extra264"]
    - [total_ordering_module_class_eq,
       total_ordering.__module__.__class__.__name__.__eq__,
       ["str"],
       true,
       "functools.total_ordering.__module__.__class__.__name__.__eq__('str') == True — __module__ is a str; new to extra264"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra264
# ---------------------------------------------------------------------------

invariant functools_extra264.reduce.name_eq:
  description: "functools.reduce.__name__ == 'reduce' — C-level builtin function name; new to extra264"
  category: identity
  kind: python_call_eq
  function: reduce.__name__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra264.reduce.qualname_eq:
  description: "functools.reduce.__qualname__ == 'reduce' — top-level; qualname equals name; new to extra264"
  category: identity
  kind: python_call_eq
  function: reduce.__qualname__.__eq__
  args: ["reduce"]
  expected: true

invariant functools_extra264.reduce.module_eq:
  description: "functools.reduce.__module__ == '_functools' — implemented in the _functools C extension; new to extra264"
  category: identity
  kind: python_call_eq
  function: reduce.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra264.reduce.class_is_builtin:
  description: "functools.reduce.__class__.__name__ == 'builtin_function_or_method' — C-level builtin, not a Python function; new to extra264"
  category: identity
  kind: python_call_eq
  function: reduce.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra264.cmp_to_key.name_eq:
  description: "functools.cmp_to_key.__name__ == 'cmp_to_key' — C-level builtin function name; new to extra264"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__name__.__eq__
  args: ["cmp_to_key"]
  expected: true

invariant functools_extra264.cmp_to_key.module_eq:
  description: "functools.cmp_to_key.__module__ == '_functools' — implemented in the _functools C extension; new to extra264"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__module__.__eq__
  args: ["_functools"]
  expected: true

invariant functools_extra264.cmp_to_key.class_is_builtin:
  description: "functools.cmp_to_key.__class__.__name__ == 'builtin_function_or_method' — C-level builtin, not a Python function; new to extra264"
  category: identity
  kind: python_call_eq
  function: cmp_to_key.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant functools_extra264.total_ordering.name_eq:
  description: "functools.total_ordering.__name__ == 'total_ordering' — Python function name; new to extra264"
  category: identity
  kind: python_call_eq
  function: total_ordering.__name__.__eq__
  args: ["total_ordering"]
  expected: true

invariant functools_extra264.total_ordering.module_eq:
  description: "functools.total_ordering.__module__ == 'functools' — defined in Lib/functools.py; new to extra264"
  category: identity
  kind: python_call_eq
  function: total_ordering.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra264.total_ordering.class_is_function:
  description: "functools.total_ordering.__class__.__name__ == 'function' — plain Python function, not a C builtin; new to extra264"
  category: identity
  kind: python_call_eq
  function: total_ordering.__class__.__name__.__eq__
  args: ["function"]
  expected: true
