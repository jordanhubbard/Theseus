spec: decimal_extra219
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification, Version 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec covers: decimal class __class__.__name__ type and MRO contracts for Decimal, Context, DecimalException, InvalidOperation, DivisionByZero."
    - "decimal.Decimal.__class__.__name__ == 'type'; verified with Python 3.14.3."
    - "decimal.Context.__class__.__name__ == 'type'; verified with Python 3.14.3."
    - "decimal.DecimalException.__class__.__name__ == 'type'; verified with Python 3.14.3."
    - "decimal.Decimal.__mro__.__len__() == 2: [Decimal, object]; verified with Python 3.14.3."
    - "decimal.DecimalException.__mro__.__len__() == 5: [DecimalException, ArithmeticError, Exception, BaseException, object]; verified with Python 3.14.3."
    - "decimal.InvalidOperation.__mro__.__len__() == 6: [InvalidOperation, DecimalException, ArithmeticError, Exception, BaseException, object]; verified with Python 3.14.3."
    - "decimal.DivisionByZero.__mro__.__len__() == 7: [DivisionByZero, DecimalException, ZeroDivisionError, ArithmeticError, Exception, BaseException, object]; verified with Python 3.14.3."
    - "decimal.Decimal.__mro__[0].__name__ == 'Decimal'; verified with Python 3.14.3."
    - "decimal.Decimal.__mro__[1].__name__ == 'object'; verified with Python 3.14.3."
    - "decimal.DecimalException.__mro__[1].__name__ == 'ArithmeticError'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal class __class__.__name__ values
# Decimal, Context, DecimalException are all plain classes (metaclass == type).
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table decimal_extra219.class_type_names:
  description: "decimal class __class__.__name__ contracts for Decimal, Context, DecimalException; all plain classes with metaclass type; verified with Python 3.14.3"
  kind: python_call_eq
  category: class_metadata
  id_prefix: declstypename219

  columns: [id, function, args, expected]
  rows:
    - [decimal_classname,      Decimal.__class__.__name__.__eq__,          ["type"], true]
    - [context_classname,      Context.__class__.__name__.__eq__,          ["type"], true]
    - [decexc_classname,       DecimalException.__class__.__name__.__eq__, ["type"], true]

# ---------------------------------------------------------------------------
# decimal class __mro__ length contracts
# Decimal has depth-2 MRO; exception classes have deeper chains.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table decimal_extra219.mro_lengths:
  description: "decimal class __mro__ length contracts for Decimal (2), DecimalException (5), InvalidOperation (6), DivisionByZero (7); verified with Python 3.14.3"
  kind: python_call_eq
  category: class_metadata
  id_prefix: decmrolen219

  columns: [id, function, args, expected]
  rows:
    - [decimal_mro_len,      Decimal.__mro__.__len__,          [], 2]
    - [decexc_mro_len,       DecimalException.__mro__.__len__, [], 5]
    - [invalidop_mro_len,    InvalidOperation.__mro__.__len__, [], 6]
    - [divbyzero_mro_len,    DivisionByZero.__mro__.__len__,   [], 7]

# ---------------------------------------------------------------------------
# Standalone invariants for MRO element names
# Functions with [ in path must be double-quoted.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant decimal_extra219.Decimal.class_type:
  description: "decimal.Decimal.__class__.__name__ == 'type' — Decimal is a plain class with metaclass type; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: Decimal.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant decimal_extra219.Decimal.mro_len:
  description: "decimal.Decimal.__mro__.__len__() == 2: Decimal -> object; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: Decimal.__mro__.__len__
  args: []
  expected: 2

invariant decimal_extra219.DecimalException.mro_len:
  description: "decimal.DecimalException.__mro__.__len__() == 5: DecimalException -> ArithmeticError -> Exception -> BaseException -> object; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: DecimalException.__mro__.__len__
  args: []
  expected: 5

invariant decimal_extra219.Decimal.mro0_name:
  description: "decimal.Decimal.__mro__[0].__name__ == 'Decimal' — first MRO element is the class itself; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: "Decimal.__mro__[0].__name__.__eq__"
  args: ["Decimal"]
  expected: true

invariant decimal_extra219.Decimal.mro1_name:
  description: "decimal.Decimal.__mro__[1].__name__ == 'object' — Decimal directly extends object; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: "Decimal.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant decimal_extra219.DecimalException.mro1_name:
  description: "decimal.DecimalException.__mro__[1].__name__ == 'ArithmeticError' — DecimalException directly extends ArithmeticError; verified with Python 3.14.3"
  category: class_metadata
  kind: python_call_eq
  function: "DecimalException.__mro__[1].__name__.__eq__"
  args: ["ArithmeticError"]
  expected: true
