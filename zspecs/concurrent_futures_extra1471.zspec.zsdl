spec: concurrent_futures_extra1471
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "concurrent_futures_extra.zspec.zsdl — covers class name and module checks"
    - "concurrent_futures_extra1456.zspec.zsdl — covers __contains__ and __iter__ dict membership checks"
    - "CPython source: Lib/concurrent/futures/_base.py, Lib/concurrent/futures/thread.py, Lib/concurrent/futures/process.py"
  notes:
    - "Wave 545 (_extra1471): focuses on __len__ and __getitem__ method presence and type checks for concurrent.futures classes."
    - "concurrent.futures.Future does not define '__len__' in its own __dict__ — Future represents a single async computation result, not a collection. Verified Python 3.14.4."
    - "concurrent.futures.Future does not define '__getitem__' in its own __dict__ — result retrieved via .result(), not index access. Verified Python 3.14.4."
    - "concurrent.futures.Executor does not define '__len__' or '__getitem__' in its own __dict__ — Executor is an abstract base for thread/process pools, not a sequence. Verified Python 3.14.4."
    - "concurrent.futures.ThreadPoolExecutor does not define '__len__' or '__getitem__' in its own __dict__ — ThreadPoolExecutor manages worker threads, not a container. Verified Python 3.14.4."
    - "concurrent.futures.ProcessPoolExecutor does not define '__len__' or '__getitem__' in its own __dict__ — ProcessPoolExecutor manages worker processes, not a sequence. Verified Python 3.14.4."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: concurrent.futures class __len__ dict absence
#
# Wave 545 theme: '__len__' not in own __dict__ for concurrent.futures
# classes. Future, Executor, ThreadPoolExecutor, and ProcessPoolExecutor
# are all execution management abstractions — none define __len__ because
# they are not sized containers.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1471.len_dict_membership:
  description: "concurrent.futures classes: '__len__' not in own __dict__ for Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor; wave 545; new to extra1471"
  kind: python_call_eq
  category: len_dict_membership
  id_prefix: cf1471ld

  columns: [id, function, args, expected, description]
  rows:
    - [cf1471ld001,
       "Future.__dict__.__contains__",
       ["__len__"],
       false,
       "concurrent.futures.Future.__dict__.__contains__('__len__') == False — Future represents a single pending computation result; is not a sized collection; no __len__ in own class __dict__; new to extra1471"]
    - [cf1471ld002,
       "Executor.__dict__.__contains__",
       ["__len__"],
       false,
       "concurrent.futures.Executor.__dict__.__contains__('__len__') == False — Executor is an abstract pool manager; is not a container; no __len__ in own class __dict__; new to extra1471"]
    - [cf1471ld003,
       "ThreadPoolExecutor.__dict__.__contains__",
       ["__len__"],
       false,
       "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__len__') == False — ThreadPoolExecutor manages a thread pool; is not a sized collection; no __len__ in own class __dict__; new to extra1471"]
    - [cf1471ld004,
       "ProcessPoolExecutor.__dict__.__contains__",
       ["__len__"],
       false,
       "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__len__') == False — ProcessPoolExecutor manages a process pool; is not a sized collection; no __len__ in own class __dict__; new to extra1471"]
    - [cf1471ld005,
       "Future.__dict__.__contains__",
       ["__len__"],
       false,
       "concurrent.futures.Future.__dict__.__contains__('__len__') == False — cross-check: a Future yields exactly one result via .result(); sized-container protocol entirely absent; new to extra1471"]
    - [cf1471ld006,
       "ThreadPoolExecutor.__dict__.__contains__",
       ["__len__"],
       false,
       "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__len__') == False — cross-check: ThreadPoolExecutor submit/map API does not expose __len__; new to extra1471"]
    - [cf1471ld007,
       "Executor.__dict__.__contains__",
       ["__len__"],
       false,
       "concurrent.futures.Executor.__dict__.__contains__('__len__') == False — cross-check: abstract Executor base defines submit and map, not container methods; no __len__; new to extra1471"]
    - [cf1471ld008,
       "ProcessPoolExecutor.__dict__.__contains__",
       ["__len__"],
       false,
       "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__len__') == False — cross-check: ProcessPoolExecutor is a pool manager with a submit/shutdown lifecycle, not a sequence; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 2: concurrent.futures class __getitem__ dict absence
#
# Wave 545 theme: '__getitem__' not in own __dict__ for concurrent.futures
# classes. None of the executor or future classes support subscript access;
# results are retrieved via .result() for futures and .submit()/.map() for
# executors.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1471.getitem_dict_membership:
  description: "concurrent.futures classes: '__getitem__' not in own __dict__ for Future, Executor, ThreadPoolExecutor, ProcessPoolExecutor; wave 545; new to extra1471"
  kind: python_call_eq
  category: getitem_dict_membership
  id_prefix: cf1471gi

  columns: [id, function, args, expected, description]
  rows:
    - [cf1471gi001,
       "Future.__dict__.__contains__",
       ["__getitem__"],
       false,
       "concurrent.futures.Future.__dict__.__contains__('__getitem__') == False — Future result is obtained via .result() or .exception(); subscript access not defined; no __getitem__ in own class __dict__; new to extra1471"]
    - [cf1471gi002,
       "Executor.__dict__.__contains__",
       ["__getitem__"],
       false,
       "concurrent.futures.Executor.__dict__.__contains__('__getitem__') == False — Executor is an abstract pool manager; subscript access not applicable; no __getitem__ in own class __dict__; new to extra1471"]
    - [cf1471gi003,
       "ThreadPoolExecutor.__dict__.__contains__",
       ["__getitem__"],
       false,
       "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__getitem__') == False — ThreadPoolExecutor submits callables and returns Futures; subscript access not defined; no __getitem__ in own class __dict__; new to extra1471"]
    - [cf1471gi004,
       "ProcessPoolExecutor.__dict__.__contains__",
       ["__getitem__"],
       false,
       "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__getitem__') == False — ProcessPoolExecutor submits callables and returns Futures; subscript access not defined; no __getitem__ in own class __dict__; new to extra1471"]
    - [cf1471gi005,
       "Future.__dict__.__contains__",
       ["__getitem__"],
       false,
       "concurrent.futures.Future.__dict__.__contains__('__getitem__') == False — cross-check: Future state transitions (pending/running/done) do not include sequence indexing; new to extra1471"]
    - [cf1471gi006,
       "ThreadPoolExecutor.__dict__.__contains__",
       ["__getitem__"],
       false,
       "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__getitem__') == False — cross-check: ThreadPoolExecutor manages workers via context manager or explicit shutdown; no subscript protocol; new to extra1471"]
    - [cf1471gi007,
       "Executor.__dict__.__contains__",
       ["__getitem__"],
       false,
       "concurrent.futures.Executor.__dict__.__contains__('__getitem__') == False — cross-check: base Executor defines submit, map, shutdown — not __getitem__; new to extra1471"]
    - [cf1471gi008,
       "ProcessPoolExecutor.__dict__.__contains__",
       ["__getitem__"],
       false,
       "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__getitem__') == False — cross-check: ProcessPoolExecutor spawns/forks worker processes; no subscript protocol; new to extra1471"]

# ---------------------------------------------------------------------------
# Table 3: concurrent.futures cross-protocol absence — __len__ and __getitem__
#
# Wave 545 theme: confirm both halves of the sequence protocol (__len__ and
# __getitem__) are absent from these concurrent.futures classes in a single
# cross-validation table.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1471.sequence_protocol_absence:
  description: "concurrent.futures classes: both '__len__' and '__getitem__' absent from own __dict__; cross-check; wave 545; new to extra1471"
  kind: python_call_eq
  category: sequence_protocol_absence
  id_prefix: cf1471sp

  columns: [id, function, args, expected, description]
  rows:
    - [cf1471sp001,
       "Future.__dict__.__contains__",
       ["__len__"],
       false,
       "concurrent.futures.Future.__dict__.__contains__('__len__') == False — sequence protocol cross-check: sized half absent from Future; new to extra1471"]
    - [cf1471sp002,
       "Future.__dict__.__contains__",
       ["__getitem__"],
       false,
       "concurrent.futures.Future.__dict__.__contains__('__getitem__') == False — sequence protocol cross-check: subscript half absent from Future; new to extra1471"]
    - [cf1471sp003,
       "ThreadPoolExecutor.__dict__.__contains__",
       ["__len__"],
       false,
       "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__len__') == False — sequence protocol cross-check: sized half absent from ThreadPoolExecutor; new to extra1471"]
    - [cf1471sp004,
       "ThreadPoolExecutor.__dict__.__contains__",
       ["__getitem__"],
       false,
       "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__('__getitem__') == False — sequence protocol cross-check: subscript half absent from ThreadPoolExecutor; new to extra1471"]
    - [cf1471sp005,
       "ProcessPoolExecutor.__dict__.__contains__",
       ["__len__"],
       false,
       "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__len__') == False — sequence protocol cross-check: sized half absent from ProcessPoolExecutor; new to extra1471"]
    - [cf1471sp006,
       "ProcessPoolExecutor.__dict__.__contains__",
       ["__getitem__"],
       false,
       "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__('__getitem__') == False — sequence protocol cross-check: subscript half absent from ProcessPoolExecutor; new to extra1471"]
    - [cf1471sp007,
       "Executor.__dict__.__contains__",
       ["__len__"],
       false,
       "concurrent.futures.Executor.__dict__.__contains__('__len__') == False — sequence protocol cross-check: sized half absent from Executor; new to extra1471"]
    - [cf1471sp008,
       "Executor.__dict__.__contains__",
       ["__getitem__"],
       false,
       "concurrent.futures.Executor.__dict__.__contains__('__getitem__') == False — sequence protocol cross-check: subscript half absent from Executor; new to extra1471"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra1471
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra1471.Future_len_not_in_dict:
  description: "'__len__' not in concurrent.futures.Future.__dict__ — Future does not define the sized protocol; wave 545; new to extra1471"
  kind: python_call_eq
  function: Future.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant concurrent_futures_extra1471.Future_getitem_not_in_dict:
  description: "'__getitem__' not in concurrent.futures.Future.__dict__ — Future does not define subscript access; wave 545; new to extra1471"
  kind: python_call_eq
  function: Future.__dict__.__contains__
  args: ["__getitem__"]
  expected: false

invariant concurrent_futures_extra1471.ThreadPoolExecutor_len_not_in_dict:
  description: "'__len__' not in concurrent.futures.ThreadPoolExecutor.__dict__ — ThreadPoolExecutor does not define the sized protocol; wave 545; new to extra1471"
  kind: python_call_eq
  function: ThreadPoolExecutor.__dict__.__contains__
  args: ["__len__"]
  expected: false

invariant concurrent_futures_extra1471.ProcessPoolExecutor_getitem_not_in_dict:
  description: "'__getitem__' not in concurrent.futures.ProcessPoolExecutor.__dict__ — ProcessPoolExecutor does not define subscript access; wave 545; new to extra1471"
  kind: python_call_eq
  function: ProcessPoolExecutor.__dict__.__contains__
  args: ["__getitem__"]
  expected: false
