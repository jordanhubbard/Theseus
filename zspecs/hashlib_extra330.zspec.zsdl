spec: hashlib_extra330
version: ">=3.11"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.file_digest — function identity (Python 3.11+)
# ---------------------------------------------------------------------------

invariant hashlib_extra330.file_digest.function_name:
  description: "hashlib.file_digest.__name__ == 'file_digest' (Python 3.11+ function for file hashing)"
  category: function_identity
  kind: python_call_eq
  function: file_digest.__name__.__eq__
  args: ["file_digest"]
  expected: true

invariant hashlib_extra330.file_digest.module:
  description: "hashlib.file_digest.__module__ == 'hashlib'"
  category: function_identity
  kind: python_call_eq
  function: file_digest.__module__.__eq__
  args: ["hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5 and hashlib.sha256 qualnames
# These are OpenSSL-backed constructors; their __qualname__ reflects the
# internal binding name (openssl_md5, openssl_sha256) not the alias name.
# ---------------------------------------------------------------------------

invariant hashlib_extra330.md5.qualname:
  description: "hashlib.md5.__qualname__ == 'openssl_md5' (OpenSSL-backed constructor qualname)"
  category: function_identity
  kind: python_call_eq
  function: md5.__qualname__.__eq__
  args: ["openssl_md5"]
  expected: true

invariant hashlib_extra330.sha256.qualname:
  description: "hashlib.sha256.__qualname__ == 'openssl_sha256' (OpenSSL-backed constructor qualname)"
  category: function_identity
  kind: python_call_eq
  function: sha256.__qualname__.__eq__
  args: ["openssl_sha256"]
  expected: true

# ---------------------------------------------------------------------------
# copy() — class name and name attribute (confirmed wave 460)
# ---------------------------------------------------------------------------

invariant hashlib_extra330.md5.copy_class_name:
  description: "hashlib.md5(b'hello').copy().__class__.__name__ == 'HASH'"
  category: copy_semantics
  kind: python_call_eq
  function: md5
  args: ["hello"]
  method: copy.__class__.__name__.__eq__
  method_args: ["HASH"]
  expected: true

invariant hashlib_extra330.md5.copy_name_attr:
  description: "hashlib.md5(b'hello').copy().name == 'md5'"
  category: copy_semantics
  kind: python_call_eq
  function: md5
  args: ["hello"]
  method: copy.name.__eq__
  method_args: ["md5"]
  expected: true

invariant hashlib_extra330.sha256.copy_name_attr:
  description: "hashlib.sha256(b'hello').copy().name == 'sha256'"
  category: copy_semantics
  kind: python_call_eq
  function: sha256
  args: ["hello"]
  method: copy.name.__eq__
  method_args: ["sha256"]
  expected: true

# ---------------------------------------------------------------------------
# algorithms_available — membership checks
# ---------------------------------------------------------------------------

table hashlib_extra330.algorithms_available.membership:
  kind: python_call_eq
  category: algorithms
  id_prefix: alg_available

  columns: [id, function, args, expected]
  rows:
    - [md5,    algorithms_available.__contains__, ["md5"],    true]
    - [sha256, algorithms_available.__contains__, ["sha256"], true]

# ---------------------------------------------------------------------------
# algorithms_guaranteed — sha256 membership
# ---------------------------------------------------------------------------

invariant hashlib_extra330.algorithms_guaranteed.sha256:
  description: "hashlib.algorithms_guaranteed.__contains__('sha256') == True"
  category: algorithms
  kind: python_call_eq
  function: algorithms_guaranteed.__contains__
  args: ["sha256"]
  expected: true
