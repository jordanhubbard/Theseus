spec: uuid_extra29
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html
rfcs:
  - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "RFC 4122 — A Universally Unique IDentifier (UUID) URN Namespace"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra28.zspec.zsdl — covers UUID.time_low/time_mid/clock_seq_low property descriptor class name lens (8); time_low/time_mid/clock_seq_low fget __qualname__.__len__()."
    - "uuid_extra27.zspec.zsdl — covers UUID.bytes_le.__class__.__name__.__len__()==8; uuid3/uuid5 result __class__.__name__.__len__()==4; NAMESPACE_URL.__class__.__qualname__.__len__()==4; uuid3/uuid5.__qualname__.__len__()==5 standalone."
    - "uuid_extra26.zspec.zsdl — covers UUID.int/is_safe member_descriptor class name len (17); UUID.hex/urn/variant/version property descriptor class name len (8)."
    - "uuid_extra25.zspec.zsdl — covers UUID.__init_subclass__/__subclasshook__ __qualname__.__len__(); uuid.__spec__.__name__/__loader__.__class__.__name__.__len__(); UUID.__new__.__qualname__.__len__()==14."
    - "uuid_extra23.zspec.zsdl — covers UUID.hex/bytes/bytes_le.fget.__qualname__.__len__(); UUID.__dict__.__class__.__name__.__len__()==12; uuid1/3/4/5 __qualname__.__len__()==5."
    - "uuid_extra22.zspec.zsdl — covers UUID.__slots__.__class__.__name__.__eq__('tuple') and UUID.__slots__.__len__()==3."
    - "uuid_extra21.zspec.zsdl — covers uuid1/3/4/5 __name__.__len__()==5; NAMESPACE_URL/OID/X500 __class__.__module__.__len__()==4."
    - "uuid_extra16.zspec.zsdl — covers UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__ __qualname__.__eq__ and __qualname__.__len__()."
  notes:
    - "This spec extends uuid through uuid_extra28; it does NOT duplicate invariants present in those files."
    - "Prior specs covered: uuid1/3/4/5 __name__.__len__()==5 (extra21); uuid1/3/4/5 __qualname__.__len__()==5 (extra23); UUID.__str__/__repr__/__eq__/__hash__/__init__/__int__ __qualname__.__len__() (extra16); UUID.__slots__.__len__()==3 (extra22); NAMESPACE_URL.__class__.__module__.__len__()==4 (extra21); UUID.hex/urn/variant/version/__class__.__name__.__len__()==8 (extra26)."
    - "This spec covers: UUID.__module__.__len__() (NOVEL — no prior spec checks UUID.__module__.__len__(); 'uuid' has 4 chars; extra21 covers NAMESPACE_URL.__class__.__module__.__len__()==4 which IS the same value but accessed via an instance's __class__.__module__, not the class object's own __module__ attribute); SafeUUID.__module__.__len__() (NOVEL — no prior spec checks SafeUUID.__module__.__len__(); 'uuid' has 4 chars; SafeUUID is an Enum defined in the uuid module); SafeUUID.__mro__.__len__() (NOVEL — no prior spec checks SafeUUID.__mro__.__len__()==3; SafeUUID MRO is (SafeUUID, Enum, object)); UUID.__mro__.__len__() (NOVEL — no prior spec checks UUID.__mro__.__len__()==2; UUID is a standalone class with MRO (UUID, object)); uuid.getnode.__qualname__.__len__() (NOVEL — extra21/extra23 cover uuid1/3/4/5 __qualname__.__len__()==5; no prior spec checks getnode.__qualname__.__len__()==7); uuid.uuid4.__doc__.__class__.__name__.__len__() (NOVEL — uuid4.__doc__ is a str; 'str' has 3 chars; no prior spec checks __doc__.__class__.__name__.__len__() for any uuid function)."
    - "UUID.__module__ == 'uuid' (len 4). No prior spec directly checks UUID.__module__.__len__(). extra21 checks NAMESPACE_URL.__class__.__module__.__len__()==4, which reads the same module string but via a UUID instance's class attribute, not the class itself. The UUID class's own __module__ attribute provides a distinct regression invariant. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "SafeUUID.__module__ == 'uuid' (len 4). No prior spec checks SafeUUID.__module__ in any capacity. SafeUUID is an Enum class defined at the top level of the uuid module. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "SafeUUID.__mro__ == (SafeUUID, Enum, object) — len 3. SafeUUID is a simple Enum subclass with MRO depth 3. No prior spec checks SafeUUID.__mro__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "UUID.__mro__ == (UUID, object) — len 2. UUID does not inherit from any intermediate class; MRO depth is 2. No prior spec checks UUID.__mro__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.getnode.__qualname__ == 'getnode' (len 7). extra21/extra23 cover uuid1/3/4/5 __qualname__.__len__()==5 but not getnode. getnode.__qualname__ is 'getnode' (7 chars). Novel: no prior spec checks getnode.__qualname__.__len__(). Verified Python 3.14 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__doc__.__class__.__name__ == 'str' (len 3). uuid4 is a Python function; its __doc__ attribute is a str object. 'str' has 3 chars. No prior spec checks __doc__.__class__.__name__.__len__() for any uuid function. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# UUID.__module__.__len__() and SafeUUID.__module__.__len__()
#
# Both UUID and SafeUUID are defined at the top level of the uuid module.
# UUID.__module__ == 'uuid' (len 4)
# SafeUUID.__module__ == 'uuid' (len 4)
#
# extra21 checks NAMESPACE_URL.__class__.__module__.__len__()==4 which reads the
# same string 'uuid' but via a UUID instance's __class__ chain. The class-level
# __module__ attributes are distinct regression invariants.
# No prior spec directly checks UUID.__module__.__len__() or
# SafeUUID.__module__.__len__().
# ---------------------------------------------------------------------------

table uuid_extra29.class_module_lens:
  description: "uuid.UUID/__module__.__len__()==4 and uuid.SafeUUID/__module__.__len__()==4 — novel direct class __module__ checks; extra21 covers NAMESPACE_URL.__class__.__module__.__len__ (via instance chain) but not the class objects themselves"
  kind: python_call_eq
  category: module_metadata
  id_prefix: ucml29

  columns: [id, function, args, expected]
  rows:
    - [UUID_module_len,     UUID.__module__.__len__,     [], 4]
    - [SafeUUID_module_len, SafeUUID.__module__.__len__, [], 4]

# ---------------------------------------------------------------------------
# SafeUUID.__mro__.__len__() and UUID.__mro__.__len__()
#
# SafeUUID is an Enum subclass: MRO = (SafeUUID, Enum, object) -> len 3.
# UUID is a standalone class: MRO = (UUID, object) -> len 2.
#
# No prior spec checks __mro__.__len__() for either UUID or SafeUUID.
# extra22 checks UUID.__slots__.__len__()==3 (tuple length, not MRO).
# extra25 covers UUID.__init_subclass__/__subclasshook__ but not MRO length.
# ---------------------------------------------------------------------------

table uuid_extra29.class_mro_lens:
  description: "uuid.SafeUUID.__mro__.__len__()==3 (Enum subclass) and uuid.UUID.__mro__.__len__()==2 (simple class) — novel; no prior spec checks __mro__.__len__() for either class"
  kind: python_call_eq
  category: class_introspection
  id_prefix: ucmrol29

  columns: [id, function, args, expected]
  rows:
    - [SafeUUID_mro_len, SafeUUID.__mro__.__len__, [], 3]
    - [UUID_mro_len,     UUID.__mro__.__len__,     [], 2]

# ---------------------------------------------------------------------------
# uuid.getnode.__qualname__.__len__()
#
# uuid.getnode is a Python function that returns the MAC address of the
# hardware interface as an integer.
# getnode.__qualname__ == 'getnode' (len 7).
#
# extra21/extra23 cover uuid1/3/4/5 __qualname__.__len__()==5 (table form).
# getnode is absent from all prior __qualname__.__len__() coverage.
# ---------------------------------------------------------------------------

invariant uuid_extra29.getnode.qualname_len:
  description: "uuid.getnode.__qualname__.__len__() == 7 — 'getnode' has 7 chars; novel: extra21/extra23 cover uuid1/3/4/5 __qualname__.__len__()==5 but not getnode"
  category: function_names
  kind: python_call_eq
  function: getnode.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# uuid.uuid4.__doc__.__class__.__name__.__len__()
#
# uuid4 is a Python function; its __doc__ is a str object.
# uuid4.__doc__.__class__.__name__ == 'str' (len 3).
# No prior uuid spec checks __doc__.__class__.__name__.__len__() for any uuid
# function. The docstring type class name check provides a cross-axis invariant
# confirming the docstring is a Python str.
# ---------------------------------------------------------------------------

invariant uuid_extra29.uuid4_doc.class_name_len:
  description: "uuid.uuid4.__doc__.__class__.__name__.__len__() == 3 — uuid4 docstring is a str; 'str' has 3 chars; novel: no prior uuid spec checks __doc__.__class__.__name__.__len__() for any function"
  category: module_metadata
  kind: python_call_eq
  function: uuid4.__doc__.__class__.__name__.__len__
  args: []
  expected: 3
