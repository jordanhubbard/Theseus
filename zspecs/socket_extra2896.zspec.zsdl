spec: sk2896
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket: Low-level networking interface"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 640 (sk2896): __itruediv__, __ifloordiv__, __imod__ dict-presence checks for socket types."
    - "Wave 638 showed socket.AddressInfo and socket.MsgFlag have reflected bitwise ops (__ror__, __rand__, __rxor__) True; wave 639 showed in-place bitwise (__ior__, __iand__, __ixor__) are also present."
    - "Despite the IntFlag inheritance of AddressInfo and MsgFlag, in-place arithmetic ops (itruediv/ifloordiv/imod) are NOT defined — these are not numeric divide/modulo types."
    - "Verified types: socket.socket, socket.AddressFamily, socket.SocketKind, socket.AddressInfo, socket.MsgFlag, socket.error, socket.herror, socket.gaierror, socket.timeout."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table sk2896.itruediv:
  description: "socket types __itruediv__ dict-presence checks; wave 640"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2896
  columns: [id, function, args, expected]
  rows:
    - ["sk2896001", operator.contains, [socket.socket.__dict__,        "__itruediv__"], false]
    - ["sk2896002", operator.contains, [socket.AddressFamily.__dict__, "__itruediv__"], false]
    - ["sk2896003", operator.contains, [socket.SocketKind.__dict__,    "__itruediv__"], false]
    - ["sk2896004", operator.contains, [socket.AddressInfo.__dict__,   "__itruediv__"], false]
    - ["sk2896005", operator.contains, [socket.MsgFlag.__dict__,       "__itruediv__"], false]
    - ["sk2896006", operator.contains, [socket.error.__dict__,         "__itruediv__"], false]
    - ["sk2896007", operator.contains, [socket.herror.__dict__,        "__itruediv__"], false]
    - ["sk2896008", operator.contains, [socket.gaierror.__dict__,      "__itruediv__"], false]

