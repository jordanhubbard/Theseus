spec: threading_extra1786
version: ">=3.9"
backend: python_module(threading)
docs: https://docs.python.org/3/library/threading.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — threading module reference"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "threading.zspec.zsdl — covers class __name__ checks (Barrier, BoundedSemaphore, Condition), function names, TIMEOUT_MAX, active_count, Lock, Event, Semaphore, current_thread.is_alive"
    - "threading_extra.zspec.zsdl — covers class_modules table, threading.local name/module, current_thread class name, get_ident, TIMEOUT_MAX, stack_size"
    - "threading_sync.zspec.zsdl — covers Barrier, BoundedSemaphore, RLock, Condition, Semaphore"
    - "threading_timer.zspec.zsdl — covers Timer, ThreadError, main_thread, current_thread, enumerate, active_count"
  notes:
    - "Wave 566 theme: __class_getitem__ and __init_subclass__ class creation hooks (PEP 487/585)."
    - "threading.Thread is a pure Python class defined in Lib/threading.py. It is not a generic container type and does not define __class_getitem__ in its own __dict__."
    - "threading.Event is a pure Python class. It does not define __class_getitem__ in its own __dict__."
    - "threading.local.__dict__.__contains__('__class_getitem__') == False — threading.local is a C extension type from _thread; it was not given __class_getitem__ under PEP 585 because thread-local storage objects are not parameterizable generic containers."
    - "threading.Lock is a factory function (not a class) returning a _thread.lock; the __class_getitem__ question does not apply to the returned type in the threading namespace."
    - "None of the threading classes (Thread, Event, Barrier, Semaphore, BoundedSemaphore, Condition, RLock, Timer, local) define __init_subclass__ in their own __dict__."
    - "Thread does define __init__ in its own __dict__ because it is designed to be subclassed and overrides initialization."
    - "threading.local is the C-level _thread.local type; its __module__ is '_thread'. It owns __init__ and __new__ via C slot wrappers."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: __class_getitem__ and __init_subclass__ absence in threading classes
#
# threading classes are not generic container types; none define
# __class_getitem__ in their own __dict__. None define __init_subclass__
# either — that dunder is inherited from object for all pure Python classes,
# and from the C type hierarchy for threading.local.
# ---------------------------------------------------------------------------

table threading_extra1786.class_creation_hooks:
  description: "threading classes do not define __class_getitem__ or __init_subclass__ in their own __dict__ (PEP 487/585)"
  kind: python_call_eq
  category: class_creation_hooks
  id_prefix: th1786

  columns: [id, function, args, expected]
  rows:
    - ["th1786001", threading.Thread.__dict__.__contains__,            ["__class_getitem__"],  false]
    - ["th1786002", threading.Event.__dict__.__contains__,             ["__class_getitem__"],  false]
    - ["th1786003", threading.local.__dict__.__contains__,             ["__class_getitem__"],  false]
    - ["th1786004", threading.Barrier.__dict__.__contains__,           ["__class_getitem__"],  false]
    - ["th1786005", threading.Semaphore.__dict__.__contains__,         ["__class_getitem__"],  false]
    - ["th1786006", threading.BoundedSemaphore.__dict__.__contains__,  ["__class_getitem__"],  false]
    - ["th1786007", threading.Thread.__dict__.__contains__,            ["__init_subclass__"],  false]
    - ["th1786008", threading.Event.__dict__.__contains__,             ["__init_subclass__"],  false]
    - ["th1786009", threading.local.__dict__.__contains__,             ["__init_subclass__"],  false]
    - ["th1786010", threading.Barrier.__dict__.__contains__,           ["__init_subclass__"],  false]
    - ["th1786011", threading.Semaphore.__dict__.__contains__,         ["__init_subclass__"],  false]
    - ["th1786012", threading.BoundedSemaphore.__dict__.__contains__,  ["__init_subclass__"],  false]

# ---------------------------------------------------------------------------
# Table 2: complementary __dict__ membership checks for threading classes
#
# Thread is designed for subclassing; it owns __init__, __repr__, run,
# start, join, is_alive, daemon (property), name (property).
# Event owns __init__, set, clear, is_set, wait.
# threading.local (C type) owns __init__ and __new__ as C slot wrappers;
# does not own __subclasshook__, __class_getitem__, or __init_subclass__.
# Barrier owns __init__, wait, reset, abort, parties, n_waiting, broken.
# ---------------------------------------------------------------------------

table threading_extra1786.dict_membership_complement:
  description: "Complementary __dict__ membership checks for threading classes"
  kind: python_call_eq
  category: dict_membership
  id_prefix: th1786

  columns: [id, function, args, expected]
  rows:
    - ["th1786013", threading.Thread.__dict__.__contains__,            ["__init__"],           true]
    - ["th1786014", threading.Thread.__dict__.__contains__,            ["run"],                true]
    - ["th1786015", threading.Thread.__dict__.__contains__,            ["start"],              true]
    - ["th1786016", threading.Thread.__dict__.__contains__,            ["join"],               true]
    - ["th1786017", threading.Event.__dict__.__contains__,             ["__init__"],           true]
    - ["th1786018", threading.Event.__dict__.__contains__,             ["set"],                true]
    - ["th1786019", threading.Event.__dict__.__contains__,             ["wait"],               true]
    - ["th1786020", threading.Barrier.__dict__.__contains__,           ["__init__"],           true]
    - ["th1786021", threading.Barrier.__dict__.__contains__,           ["wait"],               true]
    - ["th1786022", threading.Thread.__dict__.__contains__,            ["__subclasshook__"],   false]
    - ["th1786023", threading.Event.__dict__.__contains__,             ["__subclasshook__"],   false]
    - ["th1786024", threading.local.__dict__.__contains__,             ["__subclasshook__"],   false]
    - ["th1786025", threading.Semaphore.__dict__.__contains__,         ["__init__"],           true]
