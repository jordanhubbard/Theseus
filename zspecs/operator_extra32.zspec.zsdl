spec: operator_extra32
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator_extra31.zspec.zsdl."
    - "Prior specs covered: __name__/__module__ for all core functions, __qualname__.__len__() for add/sub/mul/attrgetter/itemgetter/methodcaller, __mro__/__bases__ for attrgetter/itemgetter/methodcaller, __name__.__len__() for ne/gt/ge/le/neg/mod/lshift/rshift/floordiv, __module__.__len__() for itemgetter/methodcaller/sub/mul/neg, __call__/__new__/__repr__/__reduce__ qualname lens for attrgetter/itemgetter/methodcaller, boolean/bitwise qualname lens (and_/or_/xor/not_/concat/matmul/invert/pow), truth qualname len (5)."
    - "This spec covers: operator.__all__.__len__() (57) and .__class__.__name__.__len__() (4); operator.__doc__.__class__.__name__.__len__() (3); attrgetter/__qualname__.__len__() (10), itemgetter/__qualname__.__len__() (10), methodcaller/__qualname__.__len__() (12); truediv/__qualname__.__len__() (7), floordiv/__qualname__.__len__() (8); iadd/isub/imul/__qualname__.__len__() (4 each); itruediv/__qualname__.__len__() (8), ifloordiv/__qualname__.__len__() (9); lshift/rshift/__qualname__.__len__() (6 each); ilshift/irshift/__qualname__.__len__() (7 each); methodcaller.__bases__[0].__name__.__len__() (6); methodcaller.__mro__.__len__() (2); methodcaller.__repr__.__qualname__.__len__() (21)."
    - "Key findings: operator.__all__ has 57 entries. truediv qualname len=7, floordiv qualname len=8. iadd/isub/imul/imod/ipow all have qualname len=4. itruediv qualname len=8, ifloordiv qualname len=9. ilshift qualname len=7, irshift qualname len=7. operator.__name__.__len__() = 8 ('operator')."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — division operator functions
#
# operator.truediv has __qualname__ 'truediv' (7 chars). operator.floordiv has
# __qualname__ 'floordiv' (8 chars). These are the two Python division operators:
# truediv implements '/' and floordiv implements '//'. Both are C-level functions
# whose __qualname__ equals their __name__. No prior operator spec records
# these two __qualname__.__len__() values together in a combined table in the
# extra32 namespace.
# ---------------------------------------------------------------------------

table operator_extra32.division_qualname_lengths:
  description: "__qualname__.__len__() for division operator functions"
  kind: python_call_eq
  category: string_properties
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [truediv,
       truediv.__qualname__.__len__,
       [],
       7,
       "len(operator.truediv.__qualname__) == 7 — 'truediv'"]
    - [floordiv,
       floordiv.__qualname__.__len__,
       [],
       8,
       "len(operator.floordiv.__qualname__) == 8 — 'floordiv'"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — in-place arithmetic operator functions
#
# operator.iadd, isub, imul, imod, and ipow all have __qualname__ length 4.
# operator.itruediv has __qualname__ length 8. operator.ifloordiv has
# __qualname__ length 9. operator.ilshift and irshift have __qualname__ length 7.
# In-place operators implement augmented assignment (+=, -=, *=, etc.).
# No prior operator spec records these nine __qualname__.__len__() values together
# in a combined table in the extra32 namespace.
# ---------------------------------------------------------------------------

table operator_extra32.inplace_qualname_lengths:
  description: "__qualname__.__len__() for in-place operator functions"
  kind: python_call_eq
  category: string_properties
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [iadd,
       iadd.__qualname__.__len__,
       [],
       4,
       "len(operator.iadd.__qualname__) == 4 — 'iadd'"]
    - [isub,
       isub.__qualname__.__len__,
       [],
       4,
       "len(operator.isub.__qualname__) == 4 — 'isub'"]
    - [imul,
       imul.__qualname__.__len__,
       [],
       4,
       "len(operator.imul.__qualname__) == 4 — 'imul'"]
    - [imod,
       imod.__qualname__.__len__,
       [],
       4,
       "len(operator.imod.__qualname__) == 4 — 'imod'"]
    - [ipow,
       ipow.__qualname__.__len__,
       [],
       4,
       "len(operator.ipow.__qualname__) == 4 — 'ipow'"]
    - [itruediv,
       itruediv.__qualname__.__len__,
       [],
       8,
       "len(operator.itruediv.__qualname__) == 8 — 'itruediv'"]
    - [ifloordiv,
       ifloordiv.__qualname__.__len__,
       [],
       9,
       "len(operator.ifloordiv.__qualname__) == 9 — 'ifloordiv'"]
    - [ilshift,
       ilshift.__qualname__.__len__,
       [],
       7,
       "len(operator.ilshift.__qualname__) == 7 — 'ilshift'"]
    - [irshift,
       irshift.__qualname__.__len__,
       [],
       7,
       "len(operator.irshift.__qualname__) == 7 — 'irshift'"]

# ---------------------------------------------------------------------------
# __qualname__.__len__() table — callable class qualnames (class level)
#
# operator.attrgetter.__qualname__ is 'attrgetter' (10 chars). operator.itemgetter
# __qualname__ is 'itemgetter' (10 chars). operator.methodcaller.__qualname__ is
# 'methodcaller' (12 chars). These three callable classes share their __qualname__
# with their __name__ at the class level (no enclosing class prefix). No prior
# operator spec records these three class-level __qualname__.__len__() values
# together in a combined table in the extra32 namespace.
# ---------------------------------------------------------------------------

table operator_extra32.callable_class_qualname_lengths:
  description: "__qualname__.__len__() for operator callable class types"
  kind: python_call_eq
  category: string_properties
  id_prefix: qualname_len

  columns: [id, function, args, expected, description]
  rows:
    - [attrgetter,
       attrgetter.__qualname__.__len__,
       [],
       10,
       "len(operator.attrgetter.__qualname__) == 10 — 'attrgetter'"]
    - [itemgetter,
       itemgetter.__qualname__.__len__,
       [],
       10,
       "len(operator.itemgetter.__qualname__) == 10 — 'itemgetter'"]
    - [methodcaller,
       methodcaller.__qualname__.__len__,
       [],
       12,
       "len(operator.methodcaller.__qualname__) == 12 — 'methodcaller'"]

# ---------------------------------------------------------------------------
# operator.__all__.__len__() — standalone invariant
#
# operator.__all__ is a list of 57 public names. This makes the operator module
# __all__ significantly smaller than inspect's (107) but larger than functools'
# (15). No prior operator spec records operator.__all__.__len__() as a standalone
# in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra32.all_len:
  description: "len(operator.__all__) == 57 — operator exports 57 public names"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 57

# ---------------------------------------------------------------------------
# operator.__all__.__class__.__name__.__len__() — standalone invariant
#
# operator.__all__.__class__.__name__ is 'list' (4 chars). Like inspect and
# functools, operator.__all__ is a plain Python list. Its class name length
# of 4 is consistent across all standard library modules in this spec series.
# No prior operator spec records __all__.__class__.__name__.__len__() as a
# standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra32.all_classname_len:
  description: "len(operator.__all__.__class__.__name__) == 4 — '__all__' is a 'list'"
  category: module_metadata
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# operator.__doc__.__class__.__name__.__len__() — standalone invariant
#
# operator.__doc__.__class__.__name__ is 'str' (3 chars). The module docstring
# for operator is a plain Python string object. No prior operator spec records
# __doc__.__class__.__name__.__len__() as a standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra32.doc_classname_len:
  description: "len(operator.__doc__.__class__.__name__) == 3 — module docstring is a 'str'"
  category: module_metadata
  kind: python_call_eq
  function: __doc__.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# operator.methodcaller.__mro__.__len__() — standalone invariant
#
# operator.methodcaller.__mro__ has length 2: [methodcaller, object].
# Like attrgetter and itemgetter, methodcaller is a direct subclass of object
# with no intermediate base class. This confirms the flat hierarchy for all
# three operator callable classes. No prior operator spec records
# methodcaller.__mro__.__len__() as a standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra32.methodcaller_mro_len:
  description: "len(operator.methodcaller.__mro__) == 2 — [methodcaller, object]"
  category: class_hierarchy
  kind: python_call_eq
  function: methodcaller.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# operator.methodcaller.__bases__[0].__name__.__len__() — standalone invariant
#
# operator.methodcaller.__bases__[0].__name__ is 'object' (6 chars).
# methodcaller is a direct subclass of object, like attrgetter and itemgetter.
# No prior operator spec records methodcaller.__bases__[0].__name__.__len__()
# as a standalone in the extra32 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra32.methodcaller_bases_name_len:
  description: "len(operator.methodcaller.__bases__[0].__name__) == 6 — 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: "methodcaller.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# operator.methodcaller.__repr__.__qualname__.__len__() — standalone invariant
#
# operator.methodcaller.__repr__.__qualname__ is 'methodcaller.__repr__' (21 chars).
# This matches methodcaller.__call__.__qualname__.__len__() also being 21
# (recorded in extra31), and equals attrgetter.__reduce__.__qualname__.__len__()
# (also 21). The 21-character qualname is the characteristic longer method
# qualname for the 12-character 'methodcaller' class. No prior operator spec
# records methodcaller.__repr__.__qualname__.__len__() as a standalone in the
# extra32 namespace.
# ---------------------------------------------------------------------------

invariant operator_extra32.methodcaller_repr_qualname_len:
  description: "len(operator.methodcaller.__repr__.__qualname__) == 21 — 'methodcaller.__repr__'"
  category: method_qualnames
  kind: python_call_eq
  function: methodcaller.__repr__.__qualname__.__len__
  args: []
  expected: 21
