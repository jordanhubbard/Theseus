    - [io1366uo003, io.UnsupportedOperation.__itemsize__.__class__.__name__.__eq__,   ["int"], true, "io.UnsupportedOperation.__itemsize__.__class__.__name__ == 'int' (C-type attribute, platform int); verified with Python 3.12"]
    - [io1366uo004, io.IOBase.__flags__.__class__.__name__.__eq__,                    ["int"], true, "io.IOBase.__flags__.__class__.__name__ == 'int' (cross-check: abstract base also uses int); verified with Python 3.12"]
    - [io1366uo005, io.BytesIO.__flags__.__class__.__name__.__eq__,                   ["int"], true, "io.BytesIO.__flags__.__class__.__name__ == 'int' (cross-check: concrete class also uses int); verified with Python 3.12"]
