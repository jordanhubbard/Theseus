table io_extra1366.unsupported_operation_flags_basicsize_itemsize:
  description: "io.UnsupportedOperation __flags__, __basicsize__, __itemsize__ type checks — wave 538 theme: UnsupportedOperation is a hybrid exception class (inherits from both OSError and ValueError); it is a Python-level class but still has integer-typed C-slot attributes __flags__, __basicsize__, and __itemsize__; only type name checked; verified with Python 3.12"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: io1366uo
  columns: [id, function, args, expected, description]
  rows:
    - [io1366uo001, io.UnsupportedOperation.__flags__.__class__.__name__.__eq__,      ["int"], true, "io.UnsupportedOperation.__flags__.__class__.__name__ == 'int' (C-type attribute, platform int); verified with Python 3.12"]
