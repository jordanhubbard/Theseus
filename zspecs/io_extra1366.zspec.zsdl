spec: io_extra1366
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO, UnsupportedOperation documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Wave 538 (_extra1366): focuses on __flags__, __basicsize__, and __itemsize__ C-type attribute checks for io module classes."
    - "All io classes are C extension types exposed through the _io module; each has integer-valued __flags__, __basicsize__, and __itemsize__ attributes."
    - "Only the type (int) is checked — exact values are platform-specific and intentionally not tested."
    - "io.IOBase.__flags__.__class__.__name__ == 'int'; io.IOBase.__basicsize__.__class__.__name__ == 'int'; io.IOBase.__itemsize__.__class__.__name__ == 'int'; verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
    - "All eight io classes (IOBase, RawIOBase, BufferedIOBase, TextIOBase, BytesIO, StringIO, FileIO, UnsupportedOperation) return 'int' for __flags__, __basicsize__, and __itemsize__ class name checks."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table io_extra1366.iobase_flags_basicsize_itemsize:
  description: "io.IOBase, io.RawIOBase, io.BufferedIOBase, io.TextIOBase __flags__, __basicsize__, __itemsize__ type checks — wave 538 theme: all four abstract io base classes are C extension types; __flags__, __basicsize__, and __itemsize__ are always int-typed; only type name is checked, not exact value; verified with Python 3.12"
  kind: python_call_eq
  category: ctype_attr_checks
  id_prefix: io1366ib
  columns: [id, function, args, expected, description]
  rows:
    - [io1366ib001, io.IOBase.__flags__.__class__.__name__.__eq__,          ["int"], true, "io.IOBase.__flags__.__class__.__name__ == 'int' (C-type attribute, platform int); verified with Python 3.12"]
    - [io1366ib002, io.IOBase.__basicsize__.__class__.__name__.__eq__,      ["int"], true, "io.IOBase.__basicsize__.__class__.__name__ == 'int' (C-type attribute, platform int); verified with Python 3.12"]
    - [io1366ib003, io.IOBase.__itemsize__.__class__.__name__.__eq__,       ["int"], true, "io.IOBase.__itemsize__.__class__.__name__ == 'int' (C-type attribute, platform int); verified with Python 3.12"]
    - [io1366ib004, io.RawIOBase.__flags__.__class__.__name__.__eq__,       ["int"], true, "io.RawIOBase.__flags__.__class__.__name__ == 'int' (C-type attribute, platform int); verified with Python 3.12"]
    - [io1366ib005, io.RawIOBase.__basicsize__.__class__.__name__.__eq__,   ["int"], true, "io.RawIOBase.__basicsize__.__class__.__name__ == 'int' (C-type attribute, platform int); verified with Python 3.12"]
    - [io1366ib006, io.RawIOBase.__itemsize__.__class__.__name__.__eq__,    ["int"], true, "io.RawIOBase.__itemsize__.__class__.__name__ == 'int' (C-type attribute, platform int); verified with Python 3.12"]
    - [io1366ib007, io.BufferedIOBase.__flags__.__class__.__name__.__eq__,  ["int"], true, "io.BufferedIOBase.__flags__.__class__.__name__ == 'int' (C-type attribute, platform int); verified with Python 3.12"]
    - [io1366ib008, io.BufferedIOBase.__basicsize__.__class__.__name__.__eq__, ["int"], true, "io.BufferedIOBase.__basicsize__.__class__.__name__ == 'int' (C-type attribute, platform int); verified with Python 3.12"]
    - [io1366ib009, io.BufferedIOBase.__itemsize__.__class__.__name__.__eq__,  ["int"], true, "io.BufferedIOBase.__itemsize__.__class__.__name__ == 'int' (C-type attribute, platform int); verified with Python 3.12"]
    - [io1366ib010, io.TextIOBase.__flags__.__class__.__name__.__eq__,      ["int"], true, "io.TextIOBase.__flags__.__class__.__name__ == 'int' (C-type attribute, platform int); verified with Python 3.12"]
