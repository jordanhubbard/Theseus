spec: io_extra41
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "io_extra40.zspec.zsdl — covers IOBase/RawIOBase/BufferedIOBase/TextIOBase ABC method __qualname__.__len__() for readable/writable/seekable/tell/flush/close/read/readall/readinto/write/readline."
    - "io_extra38.zspec.zsdl — covers StringIO method __qualname__.__len__() for read(13)/write(14)/getvalue(17)/seek(13); BytesIO method __qualname__.__len__() for read(12)/write(13)/getvalue(16)/seek(12); TextIOWrapper method __qualname__.__len__() for read(18)/write(19)/readline(22)/seek(18)."
    - "io_extra36.zspec.zsdl — covers BufferedReader.read(19)/readline(23)/read1(20); BufferedWriter.write(20)/flush(20); FileIO.readinto(15) __qualname__.__len__()."
  notes:
    - "This spec extends io_extra40.zspec.zsdl."
    - "Prior specs collectively covered: __name__/__module__/__qualname__/__dict__.__class__.__name__/__reduce__.__name__/__init_subclass__.__qualname__ for all ten io classes; __mro__.__len__() for all ten classes; __bases__[0].__name__/__len__() for all ten classes; SEEK_*/DEFAULT_BUFFER_SIZE constants; StringIO/BytesIO/TextIOWrapper method __qualname__.__len__() for read/write/getvalue/seek/readline; BufferedReader/BufferedWriter/FileIO method __qualname__.__len__(); IOBase/RawIOBase/BufferedIOBase/TextIOBase ABC method __qualname__.__len__()."
    - "This spec covers: StringIO.readline/__qualname__.__len__()==17 (NOVEL — io_extra38 covers StringIO read/write/getvalue/seek but NOT readline); BytesIO.tell/__qualname__.__len__()==12 (NOVEL — io_extra38 covers BytesIO read/write/getvalue/seek but NOT tell); TextIOWrapper.tell(18)/flush(19)/close(19)/readable(22)/writable(22)/seekable(22) __qualname__.__len__() (NOVEL — io_extra38 covers TextIOWrapper read/write/readline/seek but NOT tell/flush/close/readable/writable/seekable); BufferedWriter.tell(19)/seek(19)/writable(23) __qualname__.__len__() (NOVEL — io_extra36 covers BufferedWriter write/flush but NOT tell/seek/writable)."
    - "io.StringIO.readline.__qualname__ == 'StringIO.readline' — len 17. io_extra38 covers StringIO read/write/getvalue/seek but not readline. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BytesIO.tell.__qualname__ == 'BytesIO.tell' — len 12. io_extra38 covers BytesIO read/write/getvalue/seek but not tell. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.TextIOWrapper.tell.__qualname__ == 'TextIOWrapper.tell' — len 18. Equals TextIOWrapper.seek (18). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.TextIOWrapper.flush.__qualname__ == 'TextIOWrapper.flush' — len 19. Equals TextIOWrapper.write (19). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.TextIOWrapper.close.__qualname__ == 'TextIOWrapper.close' — len 19. Equals TextIOWrapper.flush (19). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.TextIOWrapper.readable/__qualname__ == 'TextIOWrapper.readable' — len 22. Equals TextIOWrapper.writable/seekable (22 each). All three delegation methods share the same qualname length. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.TextIOWrapper.writable/__qualname__ == 'TextIOWrapper.writable' — len 22. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.TextIOWrapper.seekable/__qualname__ == 'TextIOWrapper.seekable' — len 22. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.tell.__qualname__ == 'BufferedWriter.tell' — len 19. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.seek.__qualname__ == 'BufferedWriter.seek' — len 19. Equals BufferedWriter.tell (19). Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "io.BufferedWriter.writable.__qualname__ == 'BufferedWriter.writable' — len 23. Longest BufferedWriter method qualname. Novel. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# StringIO.readline and BytesIO.tell __qualname__.__len__()
#
# io_extra38 covered StringIO read(13)/write(14)/getvalue(17)/seek(13) and
# BytesIO read(12)/write(13)/getvalue(16)/seek(12) but did NOT cover readline
# or tell for either class. Both are novel.
#
#   StringIO.readline -> 'StringIO.readline' -> 17
#   BytesIO.tell      -> 'BytesIO.tell'      -> 12
# ---------------------------------------------------------------------------

table io_extra41.StringIO_BytesIO_gap_method_qualname_lens:
  description: "io.StringIO.readline(17) and BytesIO.tell(12) __qualname__.__len__() — methods missed in io_extra38 which covered read/write/getvalue/seek but not readline/tell"
  kind: python_call_eq
  category: method_identity
  id_prefix: sbgmq41

  columns: [id, function, args, expected]
  rows:
    - [StringIO_readline, StringIO.readline.__qualname__.__len__, [], 17]
    - [BytesIO_tell,      BytesIO.tell.__qualname__.__len__,     [], 12]

# ---------------------------------------------------------------------------
# TextIOWrapper navigation and status method __qualname__.__len__()
#
# io_extra38 covered TextIOWrapper.read(18)/write(19)/readline(22)/seek(18)
# but did NOT cover tell, flush, close, readable, writable, or seekable.
# These are all novel. Notable clustering: tell==seek==18; flush==close==19;
# readable==writable==seekable==22.
#
#   TextIOWrapper.tell     -> 'TextIOWrapper.tell'     -> 18
#   TextIOWrapper.flush    -> 'TextIOWrapper.flush'    -> 19
#   TextIOWrapper.close    -> 'TextIOWrapper.close'    -> 19
#   TextIOWrapper.readable -> 'TextIOWrapper.readable' -> 22
#   TextIOWrapper.writable -> 'TextIOWrapper.writable' -> 22
#   TextIOWrapper.seekable -> 'TextIOWrapper.seekable' -> 22
# ---------------------------------------------------------------------------

table io_extra41.TextIOWrapper_nav_method_qualname_lens:
  description: "io.TextIOWrapper tell(18)/flush(19)/close(19)/readable(22)/writable(22)/seekable(22) __qualname__.__len__() — six methods not covered in io_extra38"
  kind: python_call_eq
  category: method_identity
  id_prefix: twnmq41

  columns: [id, function, args, expected]
  rows:
    - [tell,     TextIOWrapper.tell.__qualname__.__len__,     [], 18]
    - [flush,    TextIOWrapper.flush.__qualname__.__len__,    [], 19]
    - [close,    TextIOWrapper.close.__qualname__.__len__,    [], 19]
    - [readable, TextIOWrapper.readable.__qualname__.__len__, [], 22]
    - [writable, TextIOWrapper.writable.__qualname__.__len__, [], 22]
    - [seekable, TextIOWrapper.seekable.__qualname__.__len__, [], 22]

# ---------------------------------------------------------------------------
# BufferedWriter navigation method __qualname__.__len__()
#
# io_extra36 covered BufferedWriter.write(20)/flush(20) but did NOT cover
# tell, seek, or writable. All three are novel.
#
#   BufferedWriter.tell     -> 'BufferedWriter.tell'     -> 19
#   BufferedWriter.seek     -> 'BufferedWriter.seek'     -> 19
#   BufferedWriter.writable -> 'BufferedWriter.writable' -> 23 (longest)
#
# Note: BufferedWriter.readable.__qualname__ is '_IOBase.readable' (len 16)
# because readable is inherited from the C-level _IOBase and carries the
# internal prefix; that is covered by io_extra40. Only writable, tell, and
# seek are defined at the BufferedWriter level with the 'BufferedWriter.' prefix.
# ---------------------------------------------------------------------------

invariant io_extra41.BufferedWriter.tell_qualname_len:
  description: "io.BufferedWriter.tell.__qualname__.__len__() == 19 — 'BufferedWriter.tell' has 19 characters; novel (io_extra36 covers write/flush but not tell)"
  category: method_identity
  kind: python_call_eq
  function: BufferedWriter.tell.__qualname__.__len__
  args: []
  expected: 19

invariant io_extra41.BufferedWriter.seek_qualname_len:
  description: "io.BufferedWriter.seek.__qualname__.__len__() == 19 — 'BufferedWriter.seek' has 19 characters; equals tell (19); novel"
  category: method_identity
  kind: python_call_eq
  function: BufferedWriter.seek.__qualname__.__len__
  args: []
  expected: 19

invariant io_extra41.BufferedWriter.writable_qualname_len:
  description: "io.BufferedWriter.writable.__qualname__.__len__() == 23 — 'BufferedWriter.writable' has 23 characters; longest BufferedWriter method qualname; novel"
  category: method_identity
  kind: python_call_eq
  function: BufferedWriter.writable.__qualname__.__len__
  args: []
  expected: 23
