spec: decimal_extra2011
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2011 (_extra2011): __add__/__radd__/__iadd__, __mul__/__rmul__/__imul__, __sub__/__rsub__/__isub__ dict-presence checks."
    - "decimal.Decimal is a full numeric type: defines __add__, __radd__, __mul__, __rmul__, __sub__, __rsub__ in its own __dict__ (all True)."
    - "decimal.Decimal is immutable: does NOT define __iadd__, __imul__, __isub__ (in-place operators) — all False."
    - "decimal.Context is an arithmetic context object, not a numeric type — no arithmetic operators in its __dict__."
    - "decimal.DecimalException is an Exception subclass — no arithmetic operators in its __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table decimal_extra2011.add_protocol:
  description: "decimal types __add__/__radd__/__iadd__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2011

  columns: [id, function, args, expected]
  rows:
    - ["dc2011001", "decimal.Decimal.__dict__.__contains__",          ["__add__"],  true]
    - ["dc2011002", "decimal.Decimal.__dict__.__contains__",          ["__radd__"], true]
    - ["dc2011003", "decimal.Decimal.__dict__.__contains__",          ["__iadd__"], false]
    - ["dc2011004", "decimal.Context.__dict__.__contains__",          ["__add__"],  false]
    - ["dc2011005", "decimal.Context.__dict__.__contains__",          ["__radd__"], false]
    - ["dc2011006", "decimal.Context.__dict__.__contains__",          ["__iadd__"], false]
    - ["dc2011007", "decimal.DecimalException.__dict__.__contains__", ["__add__"],  false]
    - ["dc2011008", "decimal.DecimalException.__dict__.__contains__", ["__radd__"], false]
    - ["dc2011009", "decimal.DecimalException.__dict__.__contains__", ["__iadd__"], false]

table decimal_extra2011.mul_protocol:
  description: "decimal types __mul__/__rmul__/__imul__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2011m

  columns: [id, function, args, expected]
  rows:
    - ["dc2011m001", "decimal.Decimal.__dict__.__contains__",          ["__mul__"],  true]
    - ["dc2011m002", "decimal.Decimal.__dict__.__contains__",          ["__rmul__"], true]
    - ["dc2011m003", "decimal.Decimal.__dict__.__contains__",          ["__imul__"], false]
    - ["dc2011m004", "decimal.Context.__dict__.__contains__",          ["__mul__"],  false]
    - ["dc2011m005", "decimal.Context.__dict__.__contains__",          ["__rmul__"], false]
    - ["dc2011m006", "decimal.Context.__dict__.__contains__",          ["__imul__"], false]
    - ["dc2011m007", "decimal.DecimalException.__dict__.__contains__", ["__mul__"],  false]
    - ["dc2011m008", "decimal.DecimalException.__dict__.__contains__", ["__rmul__"], false]
    - ["dc2011m009", "decimal.DecimalException.__dict__.__contains__", ["__imul__"], false]

table decimal_extra2011.sub_protocol:
  description: "decimal types __sub__/__rsub__/__isub__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2011s

  columns: [id, function, args, expected]
  rows:
    - ["dc2011s001", "decimal.Decimal.__dict__.__contains__",          ["__sub__"],  true]
    - ["dc2011s002", "decimal.Decimal.__dict__.__contains__",          ["__rsub__"], true]
    - ["dc2011s003", "decimal.Decimal.__dict__.__contains__",          ["__isub__"], false]
    - ["dc2011s004", "decimal.Context.__dict__.__contains__",          ["__sub__"],  false]
    - ["dc2011s005", "decimal.Context.__dict__.__contains__",          ["__rsub__"], false]
    - ["dc2011s006", "decimal.Context.__dict__.__contains__",          ["__isub__"], false]
    - ["dc2011s007", "decimal.DecimalException.__dict__.__contains__", ["__sub__"],  false]
    - ["dc2011s008", "decimal.DecimalException.__dict__.__contains__", ["__rsub__"], false]
    - ["dc2011s009", "decimal.DecimalException.__dict__.__contains__", ["__isub__"], false]
