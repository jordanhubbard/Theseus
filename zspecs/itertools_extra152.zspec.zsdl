  id_prefix: itertoolsislice152

  columns: [id, function, args, expected, description]
  rows:
    - [islice_doc_class_eq_str,
       "islice.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.islice.__doc__.__class__.__name__.__eq__('str') == True — islice is a C extension type; its __doc__ is a non-None str describing iteration slicing behavior; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra152"]
    - [islice_qualname_eq_name,
       "islice.__qualname__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__qualname__.__eq__('islice') == True — islice is defined at top-level module scope; __qualname__ equals __name__ == 'islice' for this C type; str.__eq__('islice') returns True; new to extra152"]
    - [islice_name_eq,
       "islice.__name__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__name__.__eq__('islice') == True — islice is the C extension type for slicing an iterator; its __name__ is 'islice'; str.__eq__('islice') returns True; new to extra152"]
    - [islice_mro_len_eq_2,
       "islice.__mro__.__len__",
       [],
       2,
       "itertools.islice.__mro__.__len__() == 2 — islice inherits directly from object; MRO is [islice, object]; len(__mro__) == 2; new to extra152"]

