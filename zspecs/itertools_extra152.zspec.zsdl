       ["combinations"],
       true,
       "itertools.combinations.__qualname__.__eq__('combinations') == True — combinations __qualname__ equals __name__ for this top-level C type; both are 'combinations'; str.__eq__('combinations') returns True; new to extra152"]
    - [combinations_mro_len_eq_2,
       "combinations.__mro__.__len__",
       [],
       2,
       "itertools.combinations.__mro__.__len__() == 2 — combinations inherits directly from object; MRO is [combinations, object]; len(__mro__) == 2; new to extra152"]
    - [permutations_doc_class_eq_str,
       "permutations.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.permutations.__doc__.__class__.__name__.__eq__('str') == True — permutations is a C extension type; its __doc__ is a non-None str describing r-length permutations; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra152"]
    - [permutations_qualname_eq_name,
       "permutations.__qualname__.__eq__",
       ["permutations"],
       true,
       "itertools.permutations.__qualname__.__eq__('permutations') == True — permutations __qualname__ equals __name__ for this top-level C type; both are 'permutations'; str.__eq__('permutations') returns True; new to extra152"]
    - [permutations_mro_len_eq_2,
