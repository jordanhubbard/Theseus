# ---------------------------------------------------------------------------
# Table 3: itertools.islice — __doc__ is a string, qualname, and MRO
#
# Wave 281 theme: islice C type doc and hierarchy checks.
#
# itertools.islice.__doc__.__class__.__name__ == 'str'
# itertools.islice.__qualname__ == 'islice' (qualname == name)
# itertools.islice.__mro__.__len__() == 2
# itertools.islice.__name__.__eq__('islice') == True
#
# islice is one of the core itertools types for slicing iterables.
# New to extra152.
# ---------------------------------------------------------------------------

table itertools_extra152.islice_doc_and_mro:
  description: "itertools.islice: __doc__ class 'str', __qualname__ == __name__ 'islice', MRO len 2; wave 281; new to extra152"
  kind: python_call_eq
