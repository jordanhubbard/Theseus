spec: itertools_extra152
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools C-type __doc__.__class__.__name__ == 'str' (doc is a string, not None) for chain, product, combinations, permutations, islice; __qualname__ == __name__ (True for all top-level C types); chain.__mro__.__len__() == 2, product.__mro__.__len__() == 2 (Wave 281)."
    - "itertools.chain.__doc__.__class__.__name__ == 'str' — chain.__doc__ is a str (not None); all C extension types in itertools have non-None __doc__ attributes. Verified with Python 3.14.3."
    - "itertools.chain.__qualname__.__eq__(itertools.chain.__name__) — True for all top-level C types because they are not nested in any other class. Verified with Python 3.14.3."
    - "itertools.chain.__mro__.__len__() == 2 — chain inherits directly from object; MRO is [chain, object]. Verified with Python 3.14.3."
    - "itertools.product.__mro__.__len__() == 2 — product inherits directly from object; MRO is [product, object]. Verified with Python 3.14.3."
    - "itertools.combinations.__doc__.__class__.__name__ == 'str'; combinations.__qualname__ == combinations.__name__; MRO len 2. Verified with Python 3.14.3."
    - "itertools.permutations.__doc__.__class__.__name__ == 'str'; permutations.__qualname__ == permutations.__name__; MRO len 2. Verified with Python 3.14.3."
    - "itertools.islice.__doc__.__class__.__name__ == 'str'; islice.__qualname__ == islice.__name__; MRO len 2. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools C-type __doc__ is a string — chain and product
#
# Wave 281 theme: C extension types in itertools always have string __doc__.
#
# itertools.chain.__doc__.__class__.__name__ == 'str'
# itertools.product.__doc__.__class__.__name__ == 'str'
# itertools.chain.__mro__.__len__() == 2
# itertools.product.__mro__.__len__() == 2
#
# C extension types defined in Modules/itertoolsmodule.c have non-None __doc__
# attributes. All are plain str objects. MRO is always 2 (type, object).
# New to extra152.
# ---------------------------------------------------------------------------

table itertools_extra152.chain_product_doc_and_mro:
  description: "itertools chain/product: __doc__ class 'str' (not None), __qualname__ == __name__, MRO len 2; C type doc and hierarchy; wave 281; new to extra152"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolscpdoc152

  columns: [id, function, args, expected, description]
  rows:
    - [chain_doc_class_eq_str,
       "chain.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.chain.__doc__.__class__.__name__.__eq__('str') == True — chain is a C extension type; its __doc__ attribute is a non-None str object describing its behavior; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra152"]
    - [chain_qualname_eq_name,
       "chain.__qualname__.__eq__",
       ["chain"],
       true,
       "itertools.chain.__qualname__.__eq__('chain') == True — chain is defined at top-level module scope; __qualname__ equals __name__ for all top-level C types; str.__eq__('chain') returns True; new to extra152"]
    - [chain_mro_len_eq_2,
       "chain.__mro__.__len__",
       [],
       2,
       "itertools.chain.__mro__.__len__() == 2 — chain inherits directly from object; MRO is [chain, object]; len(__mro__) == 2; new to extra152"]
    - [product_doc_class_eq_str,
       "product.__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.product.__doc__.__class__.__name__.__eq__('str') == True — product is a C extension type; its __doc__ is a non-None str describing the Cartesian product behavior; __doc__.__class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra152"]
    - [product_qualname_eq_name,
       "product.__qualname__.__eq__",
       ["product"],
       true,
       "itertools.product.__qualname__.__eq__('product') == True — product is defined at top-level module scope; __qualname__ == __name__ == 'product' for this top-level C type; str.__eq__('product') returns True; new to extra152"]
    - [product_mro_len_eq_2,
       "product.__mro__.__len__",
       [],
       2,
       "itertools.product.__mro__.__len__() == 2 — product inherits directly from object; MRO is [product, object]; len(__mro__) == 2; new to extra152"]

# ---------------------------------------------------------------------------
# Table 2: itertools C-type __doc__ is a string — combinations and permutations
#
# Wave 281 theme: C extension types in itertools always have string __doc__.
#
# itertools.combinations.__doc__.__class__.__name__ == 'str'
# itertools.permutations.__doc__.__class__.__name__ == 'str'
# combinations.__qualname__ == 'combinations' (qualname == name)
# permutations.__qualname__ == 'permutations' (qualname == name)
#
