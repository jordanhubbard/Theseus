spec: dbm_extra2
version: ">=3.9"
backend: python_module(dbm)

docs: https://docs.python.org/3/library/dbm.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dbm.html — Python dbm module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dbm/__init__.py"
  notes:
    - "This spec extends dbm.zspec.zsdl and dbm_extra.zspec.zsdl."
    - "dbm.zspec.zsdl covers: open/__name__, whichdb/__name__, whichdb nonexistent returns None, error is tuple."
    - "dbm_extra.zspec.zsdl covers: open/__name__; whichdb/__name__/__module__/is_function; error/__name__/__module__/is_type/base_is_OSError/bases_len; dumb/__name__/open_name/error_name."
    - "This spec adds: dbm.__name__ == 'dbm' and dbm.__package__ == 'dbm' (module identity); dumb.open.__module__; dumb._Database.__name__; open.__class__.__name__ checks."
    - "dbm.__name__ and dbm.__package__ are attributes on the module object itself, accessible via the dotted function chain."
    - "dbm.dumb._Database is the internal pure-Python implementation class; __name__ == '_Database'."
    - "dbm.dumb.open.__module__ == 'dbm.dumb' — the open function in the dumb submodule is defined there."
    - "dbm.open may be a builtin_function_or_method or a Python function depending on platform build."
    - "dbm.ndbm is available on macOS/Darwin; dbm.ndbm.__name__ == 'dbm.ndbm'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# dbm module identity — __name__ and __package__
# These check attributes on the module object itself; not covered in any prior spec.
# ---------------------------------------------------------------------------

invariant dbm_extra2.module.name:
  description: "dbm.__name__ == 'dbm' — the module's own __name__ attribute"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["dbm"]
  expected: true

invariant dbm_extra2.module.package:
  description: "dbm.__package__ == 'dbm' — dbm is a package (its __package__ matches its __name__)"
  category: module_identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["dbm"]
  expected: true

# ---------------------------------------------------------------------------
# dbm.open — class name check (not __name__)
# dbm_extra checks open.__name__; here we check open.__class__.__name__ to
# confirm it is a callable (either 'function' or 'builtin_function_or_method').
# We verify it is not 'NoneType' — i.e., open is a non-null callable.
# ---------------------------------------------------------------------------

invariant dbm_extra2.open.class_is_not_none:
  description: "dbm.open.__class__.__name__ != 'NoneType' — open is a callable, not None"
  category: functions
  kind: python_call_eq
  function: open.__class__.__name__.__ne__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# dbm.dumb submodule — additional vectors not in dbm_extra
# dbm_extra covers: dumb.__name__, dumb.open.__name__, dumb.error.__name__.
# New: dumb.open.__module__, dumb._Database.__name__.
# ---------------------------------------------------------------------------

invariant dbm_extra2.dumb.open_module:
  description: "dbm.dumb.open.__module__ == 'dbm.dumb' — open is defined in the dumb submodule"
  category: submodules
  kind: python_call_eq
  function: dumb.open.__module__.__eq__
  args: ["dbm.dumb"]
  expected: true

invariant dbm_extra2.dumb._Database_name:
  description: "dbm.dumb._Database.__name__ == '_Database' — internal pure-Python implementation class"
  category: submodules
  kind: python_call_eq
  function: dumb._Database.__name__.__eq__
  args: ["_Database"]
  expected: true

invariant dbm_extra2.dumb._Database_module:
  description: "dbm.dumb._Database.__module__ == 'dbm.dumb' — _Database is defined in dbm.dumb"
  category: submodules
  kind: python_call_eq
  function: dumb._Database.__module__.__eq__
  args: ["dbm.dumb"]
  expected: true

# ---------------------------------------------------------------------------
# dbm.ndbm submodule — available on macOS/Darwin
# dbm_extra does not cover dbm.ndbm at all.
# ndbm.__name__ == 'dbm.ndbm' on macOS.
# ---------------------------------------------------------------------------

invariant dbm_extra2.ndbm.name:
  description: "dbm.ndbm.__name__ == 'dbm.ndbm' — ndbm submodule name (macOS/Darwin)"
  category: submodules
  kind: python_call_eq
  function: ndbm.__name__.__eq__
  args: ["dbm.ndbm"]
  expected: true

# ---------------------------------------------------------------------------
# Table of function/attribute identifiers
# Each row verifies __name__ or identity in the dbm_extra2 namespace.
# (open and whichdb __name__ are covered in dbm.zspec and dbm_extra;
#  here we check error.__name__ and dumb.__name__ as new table rows.)
# ---------------------------------------------------------------------------

table dbm_extra2.attr_names:
  kind: python_call_eq
  category: attrs
  id_prefix: attr

  columns: [id, function, args, expected]
  rows:
    - [error_name, error.__name__.__eq__,   ["error"],   true]
    - [dumb_name,  dumb.__name__.__eq__,    ["dbm.dumb"], true]
    - [ndbm_name,  ndbm.__name__.__eq__,    ["dbm.ndbm"], true]
