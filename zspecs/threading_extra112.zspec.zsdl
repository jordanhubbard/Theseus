spec: threading_extra112
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading_extra111.zspec.zsdl."
    - "This spec covers: threading.RLock factory function and threading._RLock pure-Python class — method types and code attributes for acquire, release, __enter__, __exit__, __repr__, __init__; wave 263."
    - "threading.RLock is a function (factory), type(threading.RLock).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading.RLock() returns an instance of type _thread.RLock (C-level); type(threading.RLock()).__name__ == 'RLock'; type(threading.RLock()).__module__ == '_thread'. Verified with Python 3.14.3."
    - "threading._RLock is a pure-Python class, type(threading._RLock).__name__ == 'type'. Verified with Python 3.14.3."
    - "threading._RLock.__bases__ == (object,); threading._RLock.__mro__ has length 2. Verified with Python 3.14.3."
    - "type(threading._RLock.acquire).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading._RLock.acquire.__qualname__ == '_RLock.acquire'. Verified with Python 3.14.3."
    - "threading._RLock.acquire.__code__.co_argcount == 3. Verified with Python 3.14.3."
    - "threading._RLock.acquire.__code__.co_name == 'acquire'. Verified with Python 3.14.3."
    - "type(threading._RLock.release).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading._RLock.release.__qualname__ == '_RLock.release'. Verified with Python 3.14.3."
    - "threading._RLock.release.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "threading._RLock.release.__code__.co_name == 'release'. Verified with Python 3.14.3."
    - "threading._RLock.__enter__ is threading._RLock.acquire (same function object). Verified with Python 3.14.3."
    - "threading._RLock.__enter__.__qualname__ == '_RLock.acquire'. Verified with Python 3.14.3."
    - "threading._RLock.__enter__.__code__.co_argcount == 3. Verified with Python 3.14.3."
    - "type(threading._RLock.__exit__).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading._RLock.__exit__.__qualname__ == '_RLock.__exit__'. Verified with Python 3.14.3."
    - "threading._RLock.__exit__.__code__.co_argcount == 4. Verified with Python 3.14.3."
    - "threading._RLock.__exit__.__code__.co_name == '__exit__'. Verified with Python 3.14.3."
    - "type(threading._RLock.__repr__).__name__ == 'function'. Verified with Python 3.14.3."
    - "threading._RLock.__repr__.__qualname__ == '_RLock.__repr__'. Verified with Python 3.14.3."
    - "threading._RLock.__repr__.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "threading._RLock.__init__.__qualname__ == '_RLock.__init__'. Verified with Python 3.14.3."
    - "threading._RLock.__init__.__code__.co_argcount == 1. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading._RLock acquire and release method attributes
#
# Wave 263 theme: threading._RLock is a pure-Python implementation of
# reentrant lock in Lib/threading.py. It is used as a fallback when the C
# extension (_thread.RLock) is unavailable. Its acquire(self, blocking=True,
# timeout=-1) method has co_argcount 3 (self, blocking, timeout).
# Its release(self) method has co_argcount 1. Both are type 'function' with
# dotted qualnames following the '_RLock.method_name' pattern.
#
# type(threading._RLock.acquire).__name__ == 'function'
# threading._RLock.acquire.__qualname__ == '_RLock.acquire'
# threading._RLock.acquire.__code__.co_argcount == 3
# threading._RLock.acquire.__code__.co_name == 'acquire'
# type(threading._RLock.release).__name__ == 'function'
# threading._RLock.release.__qualname__ == '_RLock.release'
# threading._RLock.release.__code__.co_argcount == 1
# threading._RLock.release.__code__.co_name == 'release'
#
# New to extra112.
# ---------------------------------------------------------------------------

table threading_extra112.rlock_acquire_release:
  description: "threading._RLock acquire/release: type 'function'; qualnames '_RLock.acquire'/'_RLock.release'; co_argcount 3/1; co_name 'acquire'/'release'; wave 263; new to extra112"
  kind: python_call_eq
  category: code_identity
  id_prefix: threadingrar112

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_acquire_type_function,
       "_RLock.acquire.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.acquire.__class__.__name__.__eq__('function') == True — threading._RLock is a pure-Python class in Lib/threading.py; its acquire method is a plain Python function accessed unbound from the class; type(threading._RLock.acquire).__name__ is 'function'; str.__eq__('function') returns True; new to extra112"]
    - [rlock_acquire_qualname,
       "_RLock.acquire.__qualname__.__eq__",
       ["_RLock.acquire"],
       true,
       "threading._RLock.acquire.__qualname__.__eq__('_RLock.acquire') == True — threading._RLock.acquire is defined inside the _RLock class body; its __qualname__ follows the dotted '_RLock.acquire' pattern; str.__eq__('_RLock.acquire') returns True; new to extra112"]
    - [rlock_acquire_co_argcount_3,
       "_RLock.acquire.__code__.co_argcount.__eq__",
       [3],
       true,
       "threading._RLock.acquire.__code__.co_argcount.__eq__(3) == True — threading._RLock.acquire(self, blocking=True, timeout=-1) has 3 positional-or-keyword parameters: self (the lock instance), blocking (whether to block, default True), and timeout (maximum wait time, default -1 meaning no timeout); co_argcount counts all 3; int.__eq__(3) returns True; new to extra112"]
    - [rlock_acquire_co_name,
       "_RLock.acquire.__code__.co_name.__eq__",
       ["acquire"],
       true,
       "threading._RLock.acquire.__code__.co_name.__eq__('acquire') == True — __code__.co_name is the simple function name as written in the def statement; _RLock.acquire is defined as 'def acquire(self, blocking=True, timeout=-1)' inside the _RLock class body; co_name is 'acquire'; str.__eq__('acquire') returns True; new to extra112"]
    - [rlock_release_type_function,
       "_RLock.release.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.release.__class__.__name__.__eq__('function') == True — threading._RLock.release is a plain Python function; release decrements the recursion count and releases the underlying primitive lock when the count reaches zero; str.__eq__('function') returns True; new to extra112"]
    - [rlock_release_qualname,
       "_RLock.release.__qualname__.__eq__",
       ["_RLock.release"],
       true,
       "threading._RLock.release.__qualname__.__eq__('_RLock.release') == True — threading._RLock.release is defined inside the _RLock class body; its __qualname__ is '_RLock.release'; str.__eq__('_RLock.release') returns True; new to extra112"]
    - [rlock_release_co_argcount_1,
       "_RLock.release.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading._RLock.release.__code__.co_argcount.__eq__(1) == True — threading._RLock.release(self) has 1 positional-or-keyword parameter: self only; release takes no additional arguments; co_argcount is 1; int.__eq__(1) returns True; new to extra112"]
    - [rlock_release_co_name,
       "_RLock.release.__code__.co_name.__eq__",
       ["release"],
       true,
       "threading._RLock.release.__code__.co_name.__eq__('release') == True — _RLock.release is defined as 'def release(self)' inside the _RLock class body; co_name is 'release'; str.__eq__('release') returns True; new to extra112"]

# ---------------------------------------------------------------------------
# Table 2: threading._RLock __enter__ and __exit__ context manager methods
#
# Wave 263 theme: threading._RLock.__enter__ is aliased to acquire — the same
# function object. Therefore __enter__.__qualname__ is '_RLock.acquire' (not
# '_RLock.__enter__') and co_argcount is 3. This is a notable Python pattern
# where the context manager entry method is literally the same object as
# acquire. __exit__ is a separate function with co_argcount 4 (self, t, v, tb).
#
# threading._RLock.__enter__ is threading._RLock.acquire (True)
# threading._RLock.__enter__.__qualname__ == '_RLock.acquire'
# threading._RLock.__enter__.__code__.co_argcount == 3
# type(threading._RLock.__exit__).__name__ == 'function'
# threading._RLock.__exit__.__qualname__ == '_RLock.__exit__'
# threading._RLock.__exit__.__code__.co_argcount == 4
# threading._RLock.__exit__.__code__.co_name == '__exit__'
#
# New to extra112.
# ---------------------------------------------------------------------------

table threading_extra112.rlock_context_manager:
  description: "threading._RLock context manager: __enter__ is _RLock.acquire (same object, qualname '_RLock.acquire', co_argcount 3); __exit__ is separate function (co_argcount 4, co_name '__exit__'); wave 263; new to extra112"
  kind: python_call_eq
  category: code_identity
  id_prefix: threadingrcm112

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_enter_qualname_is_acquire,
       "_RLock.__enter__.__qualname__.__eq__",
       ["_RLock.acquire"],
       true,
       "threading._RLock.__enter__.__qualname__.__eq__('_RLock.acquire') == True — threading._RLock.__enter__ is an alias for threading._RLock.acquire (the same function object); therefore its __qualname__ is '_RLock.acquire' not '_RLock.__enter__'; this demonstrates the Python pattern of setting __enter__ = acquire in the class body; str.__eq__('_RLock.acquire') returns True; new to extra112"]
    - [rlock_enter_co_argcount_3,
       "_RLock.__enter__.__code__.co_argcount.__eq__",
       [3],
       true,
       "threading._RLock.__enter__.__code__.co_argcount.__eq__(3) == True — since __enter__ is the same object as acquire, its co_argcount is 3 (self, blocking, timeout); this confirms __enter__ is acquire; int.__eq__(3) returns True; new to extra112"]
    - [rlock_enter_co_name_acquire,
       "_RLock.__enter__.__code__.co_name.__eq__",
       ["acquire"],
       true,
       "threading._RLock.__enter__.__code__.co_name.__eq__('acquire') == True — threading._RLock.__enter__ is the same function object as acquire; its co_name is 'acquire' (the def-statement name); str.__eq__('acquire') returns True; new to extra112"]
    - [rlock_exit_type_function,
       "_RLock.__exit__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.__exit__.__class__.__name__.__eq__('function') == True — threading._RLock.__exit__ is a separate pure-Python function (unlike __enter__ which is an alias); it releases the lock when leaving the with block; str.__eq__('function') returns True; new to extra112"]
    - [rlock_exit_qualname,
       "_RLock.__exit__.__qualname__.__eq__",
       ["_RLock.__exit__"],
       true,
       "threading._RLock.__exit__.__qualname__.__eq__('_RLock.__exit__') == True — threading._RLock.__exit__ is defined as a separate function inside the _RLock class body (unlike __enter__ which aliases acquire); its __qualname__ is '_RLock.__exit__'; str.__eq__('_RLock.__exit__') returns True; new to extra112"]
    - [rlock_exit_co_argcount_4,
       "_RLock.__exit__.__code__.co_argcount.__eq__",
       [4],
       true,
       "threading._RLock.__exit__.__code__.co_argcount.__eq__(4) == True — threading._RLock.__exit__(self, t, v, tb) has 4 positional-or-keyword parameters: self, t (exception type), v (exception value), and tb (traceback); co_argcount is 4; int.__eq__(4) returns True; new to extra112"]
    - [rlock_exit_co_name,
       "_RLock.__exit__.__code__.co_name.__eq__",
       ["__exit__"],
       true,
       "threading._RLock.__exit__.__code__.co_name.__eq__('__exit__') == True — threading._RLock.__exit__ is defined as 'def __exit__(self, t, v, tb)' in the _RLock class body; co_name is '__exit__'; str.__eq__('__exit__') returns True; new to extra112"]

# ---------------------------------------------------------------------------
# Table 3: threading._RLock class metadata and __repr__ / __init__ attributes
#
# Wave 263 theme: threading._RLock inherits from object only (single base).
# Its __mro__ has length 2 (_RLock, object). threading.RLock is a factory
# function (type 'function') that returns a C-level _thread.RLock by default
# (or a threading._RLock if the C extension is unavailable). The instance
# returned by threading.RLock() has type name 'RLock' and module '_thread'.
# _RLock.__repr__ and _RLock.__init__ are type 'function' with dotted qualnames.
#
# threading._RLock.__bases__[0].__name__ == 'object'
# len(threading._RLock.__mro__) == 2
# type(threading.RLock).__name__ == 'function'
# type(threading._RLock).__name__ == 'type'
# type(threading._RLock.__repr__).__name__ == 'function'
# threading._RLock.__repr__.__qualname__ == '_RLock.__repr__'
# threading._RLock.__repr__.__code__.co_argcount == 1
# threading._RLock.__init__.__qualname__ == '_RLock.__init__'
# threading._RLock.__init__.__code__.co_argcount == 1
#
# New to extra112.
# ---------------------------------------------------------------------------

table threading_extra112.rlock_class_meta:
  description: "threading._RLock class metadata: bases object/mro len 2; RLock is 'function' (factory); _RLock is 'type'; _RLock.__repr__ co_argcount 1; _RLock.__init__ co_argcount 1; wave 263; new to extra112"
  kind: python_call_eq
  category: type_identity
  id_prefix: threadingrcm2_112

  columns: [id, function, args, expected, description]
  rows:
    - [rlock_base_is_object,
       "_RLock.__bases__.__getitem__(0).__name__.__eq__",
       ["object"],
       true,
       "threading._RLock.__bases__.__getitem__(0).__name__.__eq__('object') == True — threading._RLock inherits from object only (no mixin bases); it is a standalone pure-Python implementation of the reentrant lock protocol; __bases__[0] is the object type; str.__eq__('object') returns True; new to extra112"]
    - [rlock_mro_len_2,
       "_RLock.__mro__.__len__",
       [],
       2,
       "threading._RLock.__mro__.__len__() == 2 — threading._RLock has MRO [_RLock, object] of length 2; it is a direct subclass of object with no intermediate base classes; list.__len__() returns 2; int.__eq__(2) returns True; new to extra112"]
    - [rlock_factory_type_function,
       "RLock.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading.RLock.__class__.__name__.__eq__('function') == True — threading.RLock is a factory function (not a class); it is defined as a function in Lib/threading.py that returns _allocate_lock() or _RLock(); type(threading.RLock).__name__ is 'function'; str.__eq__('function') returns True; new to extra112"]
    - [rlock_class_type_type,
       "_RLock.__class__.__name__.__eq__",
       ["type"],
       true,
       "threading._RLock.__class__.__name__.__eq__('type') == True — threading._RLock is a pure-Python class (a 'type' instance); it is the Python fallback implementation of reentrant locking; type(threading._RLock).__name__ is 'type'; str.__eq__('type') returns True; new to extra112"]
    - [rlock_repr_type_function,
       "_RLock.__repr__.__class__.__name__.__eq__",
       ["function"],
       true,
       "threading._RLock.__repr__.__class__.__name__.__eq__('function') == True — threading._RLock.__repr__ is a pure-Python function defined in the _RLock class body; it returns a human-readable string showing the lock state; str.__eq__('function') returns True; new to extra112"]
    - [rlock_repr_qualname,
       "_RLock.__repr__.__qualname__.__eq__",
       ["_RLock.__repr__"],
       true,
       "threading._RLock.__repr__.__qualname__.__eq__('_RLock.__repr__') == True — threading._RLock.__repr__ is defined inside the _RLock class body; its __qualname__ is '_RLock.__repr__' following the dotted class.method pattern; str.__eq__('_RLock.__repr__') returns True; new to extra112"]
    - [rlock_repr_co_argcount_1,
       "_RLock.__repr__.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading._RLock.__repr__.__code__.co_argcount.__eq__(1) == True — threading._RLock.__repr__(self) takes only self; co_argcount is 1; int.__eq__(1) returns True; new to extra112"]
    - [rlock_init_qualname,
       "_RLock.__init__.__qualname__.__eq__",
       ["_RLock.__init__"],
       true,
       "threading._RLock.__init__.__qualname__.__eq__('_RLock.__init__') == True — threading._RLock.__init__ is defined inside the _RLock class body; its __qualname__ is '_RLock.__init__'; str.__eq__('_RLock.__init__') returns True; new to extra112"]
    - [rlock_init_co_argcount_1,
       "_RLock.__init__.__code__.co_argcount.__eq__",
       [1],
       true,
       "threading._RLock.__init__.__code__.co_argcount.__eq__(1) == True — threading._RLock.__init__(self) takes only self; the primitive lock is created internally; co_argcount is 1; int.__eq__(1) returns True; new to extra112"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra112
# ---------------------------------------------------------------------------

invariant threading_extra112.rlock_acquire_co_argcount:
  description: "threading._RLock.acquire.__code__.co_argcount == 3 — acquire(self, blocking, timeout); 3 parameters; wave 263; new to extra112"
  kind: python_call_eq
  function: _RLock.acquire.__code__.co_argcount.__eq__
  args: [3]
  expected: true

invariant threading_extra112.rlock_release_co_argcount:
  description: "threading._RLock.release.__code__.co_argcount == 1 — release(self); self only; wave 263; new to extra112"
  kind: python_call_eq
  function: _RLock.release.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant threading_extra112.rlock_exit_co_argcount:
  description: "threading._RLock.__exit__.__code__.co_argcount == 4 — __exit__(self, t, v, tb); 4 parameters for exception protocol; wave 263; new to extra112"
  kind: python_call_eq
  function: _RLock.__exit__.__code__.co_argcount.__eq__
  args: [4]
  expected: true

invariant threading_extra112.rlock_enter_qualname_is_acquire:
  description: "threading._RLock.__enter__.__qualname__ == '_RLock.acquire' — __enter__ is literally the acquire function; qualname confirms identity; wave 263; new to extra112"
  kind: python_call_eq
  function: _RLock.__enter__.__qualname__.__eq__
  args: ["_RLock.acquire"]
  expected: true

invariant threading_extra112.rlock_mro_len:
  description: "len(threading._RLock.__mro__) == 2 — direct object subclass; MRO is [_RLock, object]; wave 263; new to extra112"
  kind: python_call_eq
  function: _RLock.__mro__.__len__
  args: []
  expected: 2
