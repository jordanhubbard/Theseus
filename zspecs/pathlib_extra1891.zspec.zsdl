spec: pathlib_extra1891
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "Tests unary arithmetic protocol, __fspath__, async iteration protocol, and construction attrs for pathlib types"
    - "None of the pathlib types implement unary arithmetic dunder methods"
    - "PurePath defines __fspath__ directly; Path and PurePosixPath inherit it and do not define it in their own __dict__"
    - "None of the pathlib types implement async iteration protocol methods"
    - "PurePath and Path define __new__ for construction; PurePosixPath and PureWindowsPath inherit __new__"
    - "PurePath uses __new__ rather than __init__ for construction; __init__ is not in PurePath.__dict__"
  created_at: "2026-04-12"

table pathlib_extra1891.unary_arithmetic:
  columns: [id, function, args, expected]
  rows:
    - ["pl1891-ua-001", "pathlib.PurePath.__dict__.__contains__", ["__abs__"], false]
    - ["pl1891-ua-002", "pathlib.PurePath.__dict__.__contains__", ["__neg__"], false]
    - ["pl1891-ua-003", "pathlib.Path.__dict__.__contains__", ["__abs__"], false]
    - ["pl1891-ua-004", "pathlib.PurePosixPath.__dict__.__contains__", ["__abs__"], false]
    - ["pl1891-ua-005", "pathlib.PureWindowsPath.__dict__.__contains__", ["__abs__"], false]
    - ["pl1891-ua-006", "pathlib.PurePath.__dict__.__contains__", ["__round__"], false]
    - ["pl1891-ua-007", "pathlib.PurePath.__dict__.__contains__", ["__floor__"], false]
    - ["pl1891-ua-008", "pathlib.PurePath.__dict__.__contains__", ["__ceil__"], false]

table pathlib_extra1891.fspath_aiter_protocol:
  columns: [id, function, args, expected]
  rows:
    - ["pl1891-fa-001", "pathlib.PurePath.__dict__.__contains__", ["__fspath__"], true]
    - ["pl1891-fa-002", "pathlib.Path.__dict__.__contains__", ["__fspath__"], false]
    - ["pl1891-fa-003", "pathlib.PurePosixPath.__dict__.__contains__", ["__fspath__"], false]
    - ["pl1891-fa-004", "pathlib.PurePath.__dict__.__contains__", ["__aiter__"], false]
    - ["pl1891-fa-005", "pathlib.PurePath.__dict__.__contains__", ["__anext__"], false]
    - ["pl1891-fa-006", "pathlib.Path.__dict__.__contains__", ["__aiter__"], false]
    - ["pl1891-fa-007", "pathlib.PurePath.__dict__.__contains__", ["__length_hint__"], false]
    - ["pl1891-fa-008", "pathlib.Path.__dict__.__contains__", ["__fspath__"], false]

table pathlib_extra1891.purepath_construction_attrs:
  columns: [id, function, args, expected]
  rows:
    - ["pl1891-ca-001", "pathlib.PurePath.__dict__.__contains__", ["__new__"], true]
    - ["pl1891-ca-002", "pathlib.PurePath.__dict__.__contains__", ["__init__"], false]
    - ["pl1891-ca-003", "pathlib.PurePath.__dict__.__contains__", ["__init_subclass__"], false]
    - ["pl1891-ca-004", "pathlib.Path.__dict__.__contains__", ["__new__"], true]
    - ["pl1891-ca-005", "pathlib.Path.__dict__.__contains__", ["__init__"], false]
    - ["pl1891-ca-006", "pathlib.PurePosixPath.__dict__.__contains__", ["__new__"], false]
