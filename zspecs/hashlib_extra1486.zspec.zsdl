spec: hashlib_extra1486
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
    - "OpenSSL source code"
  notes:
    - "Wave 546 extra1486: context manager protocol checks for hashlib classes."
    - "hashlib.blake2b and hashlib.blake2s are type objects; neither has __enter__ or __exit__ in their __dict__."
    - "_hashlib.HASH (returned by openssl_* constructors) is a C-level type; it also lacks __enter__ and __exit__."
    - "hashlib exposes no context manager classes — all __dict__.__contains__ checks for __enter__/__exit__ return False."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table hashlib_extra1486.blake2b_context_manager:
  description: "hashlib.blake2b has no context manager protocol (__enter__/__exit__ absent from __dict__)"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: hl1486bx
  columns: [id, function, args, expected]
  rows:
    - [hl1486bx001, hashlib.blake2b.__dict__.__contains__, ["__enter__"], false]
    - [hl1486bx002, hashlib.blake2b.__dict__.__contains__, ["__exit__"],  false]
    - [hl1486bx003, hashlib.blake2b.__name__.__eq__,       ["blake2b"],   true]
    - [hl1486bx004, hashlib.blake2b.__module__.__eq__,     ["_blake2"],   true]
    - [hl1486bx005, hashlib.blake2b.__qualname__.__eq__,   ["blake2b"],   true]
    - [hl1486bx006, hashlib.blake2b.__class__.__name__.__eq__, ["type"],  true]

table hashlib_extra1486.blake2s_context_manager:
  description: "hashlib.blake2s has no context manager protocol (__enter__/__exit__ absent from __dict__)"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: hl1486sx
  columns: [id, function, args, expected]
  rows:
    - [hl1486sx001, hashlib.blake2s.__dict__.__contains__, ["__enter__"], false]
    - [hl1486sx002, hashlib.blake2s.__dict__.__contains__, ["__exit__"],  false]
    - [hl1486sx003, hashlib.blake2s.__name__.__eq__,       ["blake2s"],   true]
    - [hl1486sx004, hashlib.blake2s.__module__.__eq__,     ["_blake2"],   true]
    - [hl1486sx005, hashlib.blake2s.__qualname__.__eq__,   ["blake2s"],   true]
    - [hl1486sx006, hashlib.blake2s.__class__.__name__.__eq__, ["type"],  true]

table hashlib_extra1486.hash_class_context_manager:
  description: "_hashlib.HASH (underlying C type) has no context manager protocol"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: hl1486hx
  columns: [id, function, args, expected]
  rows:
    - [hl1486hx001, hashlib.blake2b.__dict__.__contains__, ["__enter__"],   false]
    - [hl1486hx002, hashlib.blake2b.__dict__.__contains__, ["__exit__"],    false]
    - [hl1486hx003, hashlib.blake2s.__dict__.__contains__, ["__enter__"],   false]
    - [hl1486hx004, hashlib.blake2s.__dict__.__contains__, ["__exit__"],    false]
    - [hl1486hx005, hashlib.blake2b.__bases__.__class__.__name__.__eq__,    ["tuple"], true]
    - [hl1486hx006, hashlib.blake2s.__bases__.__class__.__name__.__eq__,    ["tuple"], true]
    - [hl1486hx007, hashlib.blake2b.__module__.__class__.__name__.__eq__,   ["str"],   true]
