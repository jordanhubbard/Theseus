spec: theseus_turtle_cr
version: ">=3.0"
backend: python_cleanroom(theseus_turtle_cr)
blocks: turtle

docs: https://docs.python.org/3/library/turtle.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/turtle.html"
  not_derived_from:
    - "CPython source: Lib/turtle.py"
  notes:
    - "Clean-room turtle graphics stub. Do NOT import turtle."

error_model: python_exceptions

invariant theseus_turtle_cr.turtle2_vec2d:
  description: "Vec2D arithmetic and rotation work correctly"
  category: behavior
  kind: python_call_eq
  function: turtle2_vec2d
  args: []
  expected: true

invariant theseus_turtle_cr.turtle2_turtle:
  description: "Turtle movement tracking works correctly"
  category: behavior
  kind: python_call_eq
  function: turtle2_turtle
  args: []
  expected: true

invariant theseus_turtle_cr.turtle2_global:
  description: "Module-level turtle functions delegate to global instance"
  category: behavior
  kind: python_call_eq
  function: turtle2_global
  args: []
  expected: true
