spec: operator_extra6
version: ">=3.9"
backend: python_module(operator)

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html — Python operator module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_operator.c"
  notes:
    - "This spec extends operator.zspec.zsdl through operator_extra5.zspec.zsdl."
    - "operator_extra3 covers __module__ == '_operator' for add/sub/mul/truediv/floordiv/mod/pow/neg/abs/eq/ne/lt/le/gt/ge/not_/and_/or_/xor/lshift/rshift/getitem/setitem/delitem/contains."
    - "operator_extra4 covers __qualname__ for arithmetic and comparison operators."
    - "operator_extra5 covers __qualname__ for logical/bitwise/item-access/inplace/misc and attrgetter/itemgetter/methodcaller."
    - "This spec adds: (1) __module__ for iadd/isub/imul/itruediv/iand/ior/ixor/ifloordiv/imod/ipow/ilshift/irshift/imatmul — all '_operator'; (2) __module__ for truth/is_/is_not/concat/length_hint/index/pos — all '_operator'; (3) __module__ for attrgetter/itemgetter/methodcaller — all 'operator' (pure-Python classes); (4) lshift/rshift call results for additional argument pairs; (5) is_not call results; (6) matmul __name__/__qualname__/__module__."
    - "operator.iadd.__module__ == '_operator' — in-place operators are C builtins."
    - "operator.truth.__module__ == '_operator'."
    - "operator.is_not.__module__ == '_operator'."
    - "operator.attrgetter.__module__ == 'operator' — factory classes are defined in the pure-Python operator module wrapper."
    - "operator.itemgetter.__module__ == 'operator'."
    - "operator.methodcaller.__module__ == 'operator'."
    - "operator.lshift(3, 2) == 12 — left shift by 2 positions."
    - "operator.rshift(32, 3) == 4 — right shift by 3 positions."
    - "operator.is_not(None, 1) == True — None is not 1."
    - "operator.is_not(1, 1) == False — 1 is 1 (small int identity)."
    - "operator.matmul.__name__ == 'matmul' — matrix multiplication operator (Python 3.5+)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ — in-place operators not covered by operator_extra3
#
# operator_extra3 covers __module__ for iadd only implicitly via the
# arithmetic table (note: actually extra3 does NOT include iadd/isub/imul —
# those appear only in operator.zspec.zsdl as __name__ checks). No prior spec
# records __module__ for any in-place operator. All are '_operator'.
# ---------------------------------------------------------------------------

table operator_extra6.module_checks.inplace:
  kind: python_call_eq
  category: module_checks
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [iadd,     iadd.__module__.__eq__,     ["_operator"], true]
    - [isub,     isub.__module__.__eq__,     ["_operator"], true]
    - [imul,     imul.__module__.__eq__,     ["_operator"], true]
    - [itruediv, itruediv.__module__.__eq__, ["_operator"], true]
    - [iand,     iand.__module__.__eq__,     ["_operator"], true]
    - [ior,      ior.__module__.__eq__,      ["_operator"], true]
    - [ixor,     ixor.__module__.__eq__,     ["_operator"], true]
    - [ifloordiv, ifloordiv.__module__.__eq__, ["_operator"], true]
    - [imod,     imod.__module__.__eq__,     ["_operator"], true]
    - [ilshift,  ilshift.__module__.__eq__,  ["_operator"], true]
    - [irshift,  irshift.__module__.__eq__,  ["_operator"], true]

# ---------------------------------------------------------------------------
# __module__ — miscellaneous operators not covered by operator_extra3
#
# truth, is_, is_not, concat, length_hint, index, pos: __module__ not in any
# prior spec. All are C builtins from the _operator extension.
# ---------------------------------------------------------------------------

table operator_extra6.module_checks.misc:
  kind: python_call_eq
  category: module_checks
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [truth,       truth.__module__.__eq__,       ["_operator"], true]
    - [is_,         is_.__module__.__eq__,          ["_operator"], true]
    - [is_not,      is_not.__module__.__eq__,       ["_operator"], true]
    - [concat,      concat.__module__.__eq__,       ["_operator"], true]
    - [length_hint, length_hint.__module__.__eq__,  ["_operator"], true]
    - [index,       index.__module__.__eq__,         ["_operator"], true]
    - [pos,         pos.__module__.__eq__,           ["_operator"], true]

# ---------------------------------------------------------------------------
# __module__ — attrgetter, itemgetter, methodcaller
#
# These factory classes are defined in the pure-Python operator module wrapper
# (operator.py), not in the C extension _operator. Their __module__ is
# 'operator', not '_operator'. No prior spec records this.
# ---------------------------------------------------------------------------

table operator_extra6.module_checks.factory_classes:
  kind: python_call_eq
  category: module_checks
  id_prefix: module

  columns: [id, function, args, expected]
  rows:
    - [attrgetter,   attrgetter.__module__.__eq__,   ["operator"], true]
    - [itemgetter,   itemgetter.__module__.__eq__,   ["operator"], true]
    - [methodcaller, methodcaller.__module__.__eq__, ["operator"], true]

# ---------------------------------------------------------------------------
# lshift / rshift — additional call result vectors
#
# operator.zspec.zsdl does NOT include lshift or rshift call results
# (they appear only in the bitwise section without lshift/rshift examples).
# operator_extra3 covers lshift/rshift __module__. No prior spec tests
# actual call results for these two operators.
# ---------------------------------------------------------------------------

invariant operator_extra6.lshift.three_by_two:
  description: "operator.lshift(3, 2) == 12 — 3 << 2 == 12"
  category: bitwise
  kind: python_call_eq
  function: lshift
  args: [3, 2]
  expected: 12

invariant operator_extra6.rshift.thirtytwo_by_three:
  description: "operator.rshift(32, 3) == 4 — 32 >> 3 == 4"
  category: bitwise
  kind: python_call_eq
  function: rshift
  args: [32, 3]
  expected: 4

# ---------------------------------------------------------------------------
# is_not — identity non-equality operator
#
# operator_extra2 covers is_(None, None) == True. No prior spec tests is_not.
# operator.is_not(a, b) returns True iff a is not b.
# ---------------------------------------------------------------------------

invariant operator_extra6.is_not.none_vs_one:
  description: "operator.is_not(None, 1) == True — None is not 1"
  category: logical
  kind: python_call_eq
  function: is_not
  args: [null, 1]
  expected: true

invariant operator_extra6.is_not.one_vs_one:
  description: "operator.is_not(1, 1) == False — small int 1 is identical to itself"
  category: logical
  kind: python_call_eq
  function: is_not
  args: [1, 1]
  expected: false

# ---------------------------------------------------------------------------
# matmul — matrix multiplication operator (Python 3.5+, __matmul__)
#
# operator_extra4 and extra5 cover __qualname__ for arithmetic operators but
# not matmul. No prior spec checks matmul __name__, __qualname__, or __module__.
# ---------------------------------------------------------------------------

invariant operator_extra6.matmul.name:
  description: "operator.matmul.__name__ == 'matmul'"
  category: function_names
  kind: python_call_eq
  function: matmul.__name__.__eq__
  args: ["matmul"]
  expected: true

invariant operator_extra6.matmul.qualname:
  description: "operator.matmul.__qualname__ == 'matmul'"
  category: qualnames
  kind: python_call_eq
  function: matmul.__qualname__.__eq__
  args: ["matmul"]
  expected: true

invariant operator_extra6.matmul.module:
  description: "operator.matmul.__module__ == '_operator' — matmul is implemented in the C extension"
  category: module_checks
  kind: python_call_eq
  function: matmul.__module__.__eq__
  args: ["_operator"]
  expected: true
