spec: itertools_extra155
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers: itertools.__spec__.__class__.__name__ 'ModuleSpec'; itertools.__spec__.name 'itertools'; itertools.__doc__.__class__.__name__ 'str'; itertools.__doc__.__len__() 1386; itertools.__name__ 'itertools'; itertools.__package__ '' (empty string); itertools.__loader__.__class__.__name__ 'type' (Wave 284)."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — itertools is a C extension module; its __spec__ is still an importlib.machinery.ModuleSpec; __class__.__name__ is 'ModuleSpec'. Verified with Python 3.14.3."
    - "itertools.__spec__.name == 'itertools' — the ModuleSpec records the module name 'itertools'. Verified with Python 3.14.3."
    - "itertools.__doc__.__class__.__name__ == 'str' — the module docstring is a Python str object. Verified with Python 3.14.3."
    - "itertools.__doc__.__len__() == 1386 — the itertools module docstring is 1386 characters long. Verified with Python 3.14.3."
    - "itertools.__name__ == 'itertools' — the module's __name__ attribute is 'itertools'. Verified with Python 3.14.3."
    - "itertools.__package__ == '' — itertools is a top-level C extension module; its __package__ is an empty string (not None). Verified with Python 3.14.3."
    - "itertools.__loader__.__class__.__name__ == 'type' — the loader for itertools is a C-level built-in type (BuiltinImporter); its __class__.__name__ is 'type'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.__spec__ attributes and __doc__ class
#
# Wave 284 theme: itertools module __spec__ ModuleSpec attributes and __doc__
# string class identity.
#
# itertools.__spec__.__class__.__name__ == 'ModuleSpec'
# itertools.__spec__.name.__eq__('itertools') == True
# itertools.__doc__.__class__.__name__ == 'str'
# itertools.__name__.__eq__('itertools') == True
#
# itertools is a C extension module but still has a full ModuleSpec just like
# Python source modules. Its __doc__ is a str describing the module purpose and
# listing iterator-building functions complementary to Python's built-ins.
# New to extra155.
# ---------------------------------------------------------------------------

table itertools_extra155.spec_and_doc_class:
  description: "itertools.__spec__: class 'ModuleSpec', name 'itertools'; __doc__: class 'str'; __name__: 'itertools'; wave 284; new to extra155"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsspecdc155

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_eq_ModuleSpec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — itertools is a C extension module; its __spec__ is an importlib.machinery.ModuleSpec instance; __class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra155"]
    - [spec_name_eq_itertools,
       "__spec__.name.__eq__",
       ["itertools"],
       true,
       "itertools.__spec__.name.__eq__('itertools') == True — the ModuleSpec for itertools records the fully-qualified module name 'itertools'; str.__eq__('itertools') returns True; new to extra155"]
    - [doc_class_eq_str,
       "__doc__.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__doc__.__class__.__name__.__eq__('str') == True — the itertools module docstring is a Python str object describing the module and its iterator-building functions; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra155"]
    - [name_eq_itertools,
       "__name__.__eq__",
       ["itertools"],
       true,
       "itertools.__name__.__eq__('itertools') == True — the module's __name__ attribute is 'itertools'; this is the module's fully-qualified name as recorded in its namespace; str.__eq__('itertools') returns True; new to extra155"]

# ---------------------------------------------------------------------------
# Table 2: itertools.__doc__ length, __package__, and __loader__ class
#
# Wave 284 theme: itertools module-level dunder attributes — docstring length,
# package membership, and loader class.
#
# itertools.__doc__.__len__() == 1386
# itertools.__package__.__eq__('') == True
# itertools.__loader__.__class__.__name__.__eq__('type') == True
#
# itertools.__package__ is an empty string (not None) because itertools is a
# top-level module with no package parent. The loader is BuiltinImporter, a
# C-level class whose own __class__ is 'type'. New to extra155.
# ---------------------------------------------------------------------------

table itertools_extra155.doc_len_package_loader:
  description: "itertools.__doc__.__len__() 1386; __package__ empty string; __loader__.__class__.__name__ 'type'; wave 284; new to extra155"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsdpl155

  columns: [id, function, args, expected, description]
  rows:
    - [doc_len_eq_1386,
       "__doc__.__len__",
       [],
       1386,
       "itertools.__doc__.__len__() == 1386 — the itertools module docstring is 1386 characters long; it describes the module purpose as implementing a number of iterator building blocks complementary to Python's built-in iterators; str.__len__() returns 1386; new to extra155"]
    - [package_eq_empty_string,
       "__package__.__eq__",
       [""],
       true,
       "itertools.__package__.__eq__('') == True — itertools is a top-level C extension module with no package parent; __package__ is an empty string (not None); str.__eq__('') returns True; new to extra155"]
    - [loader_class_eq_type,
       "__loader__.__class__.__name__.__eq__",
       ["type"],
       true,
       "itertools.__loader__.__class__.__name__.__eq__('type') == True — itertools uses BuiltinImporter as its loader; BuiltinImporter is a C-level class whose metaclass is type; __loader__.__class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra155"]
    - [spec_name_str_class_eq,
       "__spec__.name.__class__.__name__.__eq__",
       ["str"],
       true,
       "itertools.__spec__.name.__class__.__name__.__eq__('str') == True — the ModuleSpec name attribute is a Python str; __class__.__name__ is 'str'; str.__eq__('str') returns True; new to extra155"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra155
# ---------------------------------------------------------------------------

invariant itertools_extra155.spec_class_ModuleSpec:
  description: "itertools.__spec__.__class__.__name__ == 'ModuleSpec' — C extension module still has a full ModuleSpec; wave 284; new to extra155"
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant itertools_extra155.spec_name_itertools:
  description: "itertools.__spec__.name == 'itertools' — ModuleSpec records the module's fully-qualified name; wave 284; new to extra155"
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra155.doc_class_str:
  description: "itertools.__doc__.__class__.__name__ == 'str' — module docstring is a Python str; wave 284; new to extra155"
  kind: python_call_eq
  function: __doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant itertools_extra155.doc_len_1386:
  description: "itertools.__doc__.__len__() == 1386 — itertools module docstring is 1386 characters; wave 284; new to extra155"
  kind: python_call_eq
  function: __doc__.__len__
  args: []
  expected: 1386

invariant itertools_extra155.name_itertools:
  description: "itertools.__name__ == 'itertools' — module __name__ attribute is 'itertools'; wave 284; new to extra155"
  kind: python_call_eq
  function: __name__.__eq__
  args: ["itertools"]
  expected: true

invariant itertools_extra155.package_empty_string:
  description: "itertools.__package__ == '' — top-level module has empty string __package__ (not None); wave 284; new to extra155"
  kind: python_call_eq
  function: __package__.__eq__
  args: [""]
  expected: true

invariant itertools_extra155.loader_class_type:
  description: "itertools.__loader__.__class__.__name__ == 'type' — BuiltinImporter loader class has metaclass type; wave 284; new to extra155"
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["type"]
  expected: true
