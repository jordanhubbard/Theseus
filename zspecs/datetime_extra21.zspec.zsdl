spec: datetime_extra21
version: ">=3.9"
backend: python_module(datetime)

docs: https://docs.python.org/3/library/datetime.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/datetime.html — Python datetime module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_datetimemodule.c"
    - "CPython source: Lib/datetime.py"
  notes:
    - "This spec extends datetime.zspec.zsdl and prior extras through datetime_extra20.zspec.zsdl."
    - "Prior specs covered: date/time/datetime/timedelta/timezone/tzinfo __name__/__module__/__qualname__/__bases__, various __init__.__name__ and __init__.__qualname__=='object.__init__' for C classes, MINYEAR/MAXYEAR values, date.today.__name__/__qualname__, datetime.now/__name__/__qualname__, datetime.utcnow/__name__, datetime.fromisoformat/__name__."
    - "This spec covers: __len__() of __module__ strings for date, time, datetime, timedelta, timezone; __len__() of __name__ strings for date, time, datetime, timedelta, timezone; __len__() of __qualname__ for date.today and datetime.now."
    - "No prior datetime spec checks datetime.date.__module__.__len__()."
    - "No prior datetime spec checks datetime.time.__module__.__len__()."
    - "No prior datetime spec checks datetime.datetime.__module__.__len__()."
    - "No prior datetime spec checks datetime.timedelta.__module__.__len__()."
    - "No prior datetime spec checks datetime.timezone.__module__.__len__()."
    - "No prior datetime spec checks datetime.date.__name__.__len__()."
    - "No prior datetime spec checks datetime.time.__name__.__len__()."
    - "No prior datetime spec checks datetime.datetime.__name__.__len__()."
    - "No prior datetime spec checks datetime.timedelta.__name__.__len__()."
    - "No prior datetime spec checks datetime.timezone.__name__.__len__()."
    - "No prior datetime spec checks datetime.date.today.__qualname__.__len__()."
    - "No prior datetime spec checks datetime.datetime.now.__qualname__.__len__()."
    - "datetime.date.__module__ == 'datetime' — len 8."
    - "datetime.time.__module__ == 'datetime' — len 8."
    - "datetime.datetime.__module__ == 'datetime' — len 8."
    - "datetime.timedelta.__module__ == 'datetime' — len 8."
    - "datetime.timezone.__module__ == 'datetime' — len 8."
    - "datetime.date.__name__ == 'date' — len 4."
    - "datetime.time.__name__ == 'time' — len 4."
    - "datetime.datetime.__name__ == 'datetime' — len 8."
    - "datetime.timedelta.__name__ == 'timedelta' — len 9."
    - "datetime.timezone.__name__ == 'timezone' — len 8."
    - "datetime.date.today.__qualname__ == 'date.today' — len 10."
    - "datetime.datetime.now.__qualname__ == 'datetime.now' — len 12."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__.__len__() for date, time, datetime, timedelta, timezone
#
# All five C extension classes have __module__ == 'datetime' which has length 8.
# No prior datetime spec checks the length of any class's __module__ string.
# ---------------------------------------------------------------------------

invariant datetime_extra21.date.module.len:
  description: "datetime.date.__module__.__len__() == 8 — 'datetime' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: date.__module__.__len__
  args: []
  expected: 8

invariant datetime_extra21.time.module.len:
  description: "datetime.time.__module__.__len__() == 8 — 'datetime' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: time.__module__.__len__
  args: []
  expected: 8

invariant datetime_extra21.datetime.module.len:
  description: "datetime.datetime.__module__.__len__() == 8 — 'datetime' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: datetime.__module__.__len__
  args: []
  expected: 8

invariant datetime_extra21.timedelta.module.len:
  description: "datetime.timedelta.__module__.__len__() == 8 — 'datetime' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: timedelta.__module__.__len__
  args: []
  expected: 8

invariant datetime_extra21.timezone.module.len:
  description: "datetime.timezone.__module__.__len__() == 8 — 'datetime' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: timezone.__module__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# __name__.__len__() for date, time, datetime, timedelta, timezone
#
# 'date' and 'time' each have length 4; 'datetime' and 'timezone' each have
# length 8; 'timedelta' has length 9.  No prior datetime spec checks the length
# of any class's __name__ string.
# ---------------------------------------------------------------------------

invariant datetime_extra21.date.name.len:
  description: "datetime.date.__name__.__len__() == 4 — 'date' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: date.__name__.__len__
  args: []
  expected: 4

invariant datetime_extra21.time.name.len:
  description: "datetime.time.__name__.__len__() == 4 — 'time' has 4 characters"
  category: string_lengths
  kind: python_call_eq
  function: time.__name__.__len__
  args: []
  expected: 4

invariant datetime_extra21.datetime.name.len:
  description: "datetime.datetime.__name__.__len__() == 8 — 'datetime' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: datetime.__name__.__len__
  args: []
  expected: 8

invariant datetime_extra21.timedelta.name.len:
  description: "datetime.timedelta.__name__.__len__() == 9 — 'timedelta' has 9 characters"
  category: string_lengths
  kind: python_call_eq
  function: timedelta.__name__.__len__
  args: []
  expected: 9

invariant datetime_extra21.timezone.name.len:
  description: "datetime.timezone.__name__.__len__() == 8 — 'timezone' has 8 characters"
  category: string_lengths
  kind: python_call_eq
  function: timezone.__name__.__len__
  args: []
  expected: 8

# ---------------------------------------------------------------------------
# __qualname__.__len__() for date.today and datetime.now
#
# datetime_extra20 checks the value of date.today.__qualname__ == 'date.today'
# and datetime.now.__qualname__ == 'datetime.now'.  No prior datetime spec checks
# the length of those __qualname__ strings.  'date.today' has length 10 and
# 'datetime.now' has length 12.
# ---------------------------------------------------------------------------

invariant datetime_extra21.date.today.qualname.len:
  description: "datetime.date.today.__qualname__.__len__() == 10 — 'date.today' has 10 characters"
  category: string_lengths
  kind: python_call_eq
  function: date.today.__qualname__.__len__
  args: []
  expected: 10

invariant datetime_extra21.datetime.now.qualname.len:
  description: "datetime.datetime.now.__qualname__.__len__() == 12 — 'datetime.now' has 12 characters"
  category: string_lengths
  kind: python_call_eq
  function: datetime.now.__qualname__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# Consolidated table — all twelve new invariants
#
# All twelve are first covered in this spec (datetime_extra21).
# ---------------------------------------------------------------------------

table datetime_extra21.module_name_and_qualname_lengths:
  description: "datetime class __module__/__name__ string lengths and date.today/datetime.now __qualname__ lengths"
  kind: python_call_eq
  category: string_lengths
  id_prefix: dte21

  columns: [id, function, args, expected]
  rows:
    - [date_module_len,           date.__module__.__len__,           [], 8]
    - [time_module_len,           time.__module__.__len__,           [], 8]
    - [datetime_module_len,       datetime.__module__.__len__,       [], 8]
    - [timedelta_module_len,      timedelta.__module__.__len__,      [], 8]
    - [timezone_module_len,       timezone.__module__.__len__,       [], 8]
    - [date_name_len,             date.__name__.__len__,             [], 4]
    - [time_name_len,             time.__name__.__len__,             [], 4]
    - [datetime_name_len,         datetime.__name__.__len__,         [], 8]
    - [timedelta_name_len,        timedelta.__name__.__len__,        [], 9]
    - [timezone_name_len,         timezone.__name__.__len__,         [], 8]
    - [date_today_qualname_len,   date.today.__qualname__.__len__,   [], 10]
    - [datetime_now_qualname_len, datetime.now.__qualname__.__len__, [], 12]
