spec: itertools_extra1816
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 568 (_extra1816): __format__ string formatting protocol; __reduce__ pickle protocol; __copy__/__deepcopy__ copy protocol; __setstate__/__getnewargs__ dict-presence checks for itertools C types."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table itertools_extra1816.format_protocol:
  description: "itertools C types __format__ and __reduce__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1816

  columns: [id, function, args, expected]
  rows:
    - ["it1816001", "itertools.count.__dict__.__contains__", ["__format__"], false]
    - ["it1816002", "itertools.count.__dict__.__contains__", ["__reduce__"], true]
    - ["it1816003", "itertools.chain.__dict__.__contains__", ["__format__"], false]
    - ["it1816004", "itertools.chain.__dict__.__contains__", ["__reduce__"], true]
    - ["it1816005", "itertools.cycle.__dict__.__contains__", ["__reduce__"], true]
    - ["it1816006", "itertools.repeat.__dict__.__contains__", ["__reduce__"], true]
    - ["it1816007", "itertools.product.__dict__.__contains__", ["__reduce__"], true]
    - ["it1816008", "itertools.combinations.__dict__.__contains__", ["__reduce__"], true]

table itertools_extra1816.copy_protocol:
  description: "itertools C types __copy__/__deepcopy__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1816

  columns: [id, function, args, expected]
  rows:
    - ["it1816101", "itertools.count.__dict__.__contains__", ["__copy__"], false]
    - ["it1816102", "itertools.count.__dict__.__contains__", ["__deepcopy__"], false]
    - ["it1816103", "itertools.chain.__dict__.__contains__", ["__copy__"], false]
    - ["it1816104", "itertools.chain.__dict__.__contains__", ["__deepcopy__"], false]
    - ["it1816105", "itertools.cycle.__dict__.__contains__", ["__copy__"], false]
    - ["it1816106", "itertools.repeat.__dict__.__contains__", ["__copy__"], false]
    - ["it1816107", "itertools.product.__dict__.__contains__", ["__copy__"], false]
    - ["it1816108", "itertools.combinations.__dict__.__contains__", ["__copy__"], false]

table itertools_extra1816.setstate_protocol:
  description: "itertools C types __setstate__ and __new__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1816

  columns: [id, function, args, expected]
  rows:
    - ["it1816201", "itertools.count.__dict__.__contains__", ["__setstate__"], true]
    - ["it1816202", "itertools.chain.__dict__.__contains__", ["__setstate__"], false]
    - ["it1816203", "itertools.chain.__dict__.__contains__", ["__new__"], true]
    - ["it1816204", "itertools.cycle.__dict__.__contains__", ["__setstate__"], true]
    - ["it1816205", "itertools.repeat.__dict__.__contains__", ["__setstate__"], false]
    - ["it1816206", "itertools.product.__dict__.__contains__", ["__setstate__"], true]
    - ["it1816207", "itertools.combinations.__dict__.__contains__", ["__setstate__"], true]
    - ["it1816208", "itertools.permutations.__dict__.__contains__", ["__setstate__"], true]
    - ["it1816209", "itertools.combinations_with_replacement.__dict__.__contains__", ["__setstate__"], true]
    - ["it1816210", "itertools.islice.__dict__.__contains__", ["__reduce__"], true]
