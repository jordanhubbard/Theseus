spec: heapq_extra5
version: ">=3.9"
backend: python_module(heapq)

docs: https://docs.python.org/3/library/heapq.html

provenance:
  derived_from:
    - "Python heapq documentation — https://docs.python.org/3/library/heapq.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/heapq.py"
    - "CPython source: Modules/_heapqmodule.c"
  notes:
    - "Extends heapq.zspec.zsdl, heapq_extra.zspec.zsdl, heapq_extra2.zspec.zsdl, heapq_extra3.zspec.zsdl, and heapq_extra4.zspec.zsdl."
    - "No prior spec covers __qualname__ for any heapq function; this spec adds all of them."
    - "heapq.heappush.__module__ == '_heapq' (already in heapq_extra3); the requested __qualname__ vectors are entirely new."
    - "heappush/heappop/heapify/heappushpop/heapreplace are C builtins; their __qualname__ equals __name__."
    - "nlargest/nsmallest/merge are pure-Python; their __qualname__ also equals __name__."
    - "Behavioral: nlargest(3, [1,4,2,9,3]) == [9,4,3] — input [1,4,2,9,3] not used in any prior spec."
    - "Behavioral: nsmallest(3, [1,4,2,9,3]) == [1,2,3] — same input, complementary check."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ checks — heap mutation functions (C builtins)
# No __qualname__ for any heapq function has appeared in any prior spec.
# ---------------------------------------------------------------------------

table heapq_extra5.qualnames_heap_ops:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [heappush,    heappush.__qualname__.__eq__,    ["heappush"],    true]
    - [heappop,     heappop.__qualname__.__eq__,     ["heappop"],     true]
    - [heapify,     heapify.__qualname__.__eq__,     ["heapify"],     true]
    - [heappushpop, heappushpop.__qualname__.__eq__, ["heappushpop"], true]
    - [heapreplace, heapreplace.__qualname__.__eq__, ["heapreplace"], true]

# ---------------------------------------------------------------------------
# __qualname__ checks — selection / merge functions (pure-Python)
# ---------------------------------------------------------------------------

table heapq_extra5.qualnames_selection:
  kind: python_call_eq
  category: function_qualnames
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [nlargest,  nlargest.__qualname__.__eq__,  ["nlargest"],  true]
    - [nsmallest, nsmallest.__qualname__.__eq__, ["nsmallest"], true]
    - [merge,     merge.__qualname__.__eq__,     ["merge"],     true]

# ---------------------------------------------------------------------------
# Behavioral invariants — input [1, 4, 2, 9, 3]
# This input is distinct from all prior spec inputs:
#   heapq        uses [1,8,2,6,3]
#   heapq_extra  uses [1,5,3,2,4]
#   heapq_extra2 uses [5,1,3,2,4]
#   heapq_extra3 uses [1,5,2,4,3]
#   heapq_extra4 uses [10,3,7,1,9,5,8,2,6,4] and [-5,-1,-3,-2,-4]
# ---------------------------------------------------------------------------

invariant heapq_extra5.nlargest.top3_14293:
  description: "heapq.nlargest(3, [1,4,2,9,3]) == [9, 4, 3] — three largest in descending order"
  category: behavior
  kind: python_call_eq
  function: nlargest
  args: [3, [1, 4, 2, 9, 3]]
  expected: [9, 4, 3]

invariant heapq_extra5.nsmallest.top3_14293:
  description: "heapq.nsmallest(3, [1,4,2,9,3]) == [1, 2, 3] — three smallest in ascending order"
  category: behavior
  kind: python_call_eq
  function: nsmallest
  args: [3, [1, 4, 2, 9, 3]]
  expected: [1, 2, 3]
