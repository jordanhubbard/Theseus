spec: asyncio_extra328
version: ">=3.8"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-subprocess.html — asyncio subprocess documentation"
    - "https://docs.python.org/3/library/asyncio-stream.html — asyncio Streams documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "Covers asyncio subprocess and streams class/function identity: __name__, __module__, and __bases__[0].__name__."
    - "asyncio.subprocess.Process.__module__ == 'asyncio.subprocess' — defined in the asyncio.subprocess submodule."
    - "asyncio.subprocess.Process.__bases__[0].__name__ == 'object' — Process inherits directly from object."
    - "asyncio.streams.StreamReader.__module__ == 'asyncio.streams' — defined in asyncio.streams."
    - "asyncio.streams.StreamReader.__bases__[0].__name__ == 'object' — StreamReader inherits from object."
    - "asyncio.streams.StreamWriter.__module__ == 'asyncio.streams'."
    - "asyncio.streams.StreamWriter.__bases__[0].__name__ == 'object'."
    - "asyncio.streams.StreamReaderProtocol.__module__ == 'asyncio.streams'."
    - "asyncio.create_subprocess_exec.__module__ == 'asyncio.subprocess' — coroutine defined there."
    - "asyncio.create_subprocess_shell.__module__ == 'asyncio.subprocess'."
    - "asyncio.open_connection.__module__ == 'asyncio.streams'."
    - "asyncio.start_server.__module__ == 'asyncio.streams'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.subprocess.Process — name, module, and base class
#
# asyncio.subprocess.Process is the class wrapping a subprocess spawned via
# create_subprocess_exec or create_subprocess_shell. It inherits from object.
# ---------------------------------------------------------------------------

invariant asyncio_extra328.subprocess_Process.name:
  description: "asyncio.subprocess.Process.__name__ == 'Process'"
  category: subprocess_classes
  kind: python_call_eq
  function: subprocess.Process.__name__.__eq__
  args: ["Process"]
  expected: true

invariant asyncio_extra328.subprocess_Process.module:
  description: "asyncio.subprocess.Process.__module__ == 'asyncio.subprocess'"
  category: subprocess_classes
  kind: python_call_eq
  function: subprocess.Process.__module__.__eq__
  args: ["asyncio.subprocess"]
  expected: true

invariant asyncio_extra328.subprocess_Process.base:
  description: "asyncio.subprocess.Process.__bases__[0].__name__ == 'object'"
  category: subprocess_classes
  kind: python_call_eq
  function: subprocess.Process.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# asyncio.streams.StreamReader — name, module, and base class
#
# StreamReader is the readable side of an asyncio stream pair. It is a plain
# Python class defined in asyncio.streams and inherits from object.
# ---------------------------------------------------------------------------

invariant asyncio_extra328.StreamReader.name:
  description: "asyncio.streams.StreamReader.__name__ == 'StreamReader'"
  category: stream_classes
  kind: python_call_eq
  function: streams.StreamReader.__name__.__eq__
  args: ["StreamReader"]
  expected: true

invariant asyncio_extra328.StreamReader.module:
  description: "asyncio.streams.StreamReader.__module__ == 'asyncio.streams'"
  category: stream_classes
  kind: python_call_eq
  function: streams.StreamReader.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true

invariant asyncio_extra328.StreamReader.base:
  description: "asyncio.streams.StreamReader.__bases__[0].__name__ == 'object'"
  category: stream_classes
  kind: python_call_eq
  function: streams.StreamReader.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# asyncio.streams.StreamWriter — name, module, and base class
#
# StreamWriter wraps the write side of a stream, providing async write
# methods. It inherits from object and is defined in asyncio.streams.
# ---------------------------------------------------------------------------

invariant asyncio_extra328.StreamWriter.name:
  description: "asyncio.streams.StreamWriter.__name__ == 'StreamWriter'"
  category: stream_classes
  kind: python_call_eq
  function: streams.StreamWriter.__name__.__eq__
  args: ["StreamWriter"]
  expected: true

invariant asyncio_extra328.StreamWriter.module:
  description: "asyncio.streams.StreamWriter.__module__ == 'asyncio.streams'"
  category: stream_classes
  kind: python_call_eq
  function: streams.StreamWriter.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true

invariant asyncio_extra328.StreamWriter.base:
  description: "asyncio.streams.StreamWriter.__bases__[0].__name__ == 'object'"
  category: stream_classes
  kind: python_call_eq
  function: streams.StreamWriter.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "object"

# ---------------------------------------------------------------------------
# asyncio.streams.StreamReaderProtocol — name and module
#
# StreamReaderProtocol is the FlowControlMixin-based protocol adapter that
# bridges the transport layer to a StreamReader. It is defined in asyncio.streams.
# ---------------------------------------------------------------------------

invariant asyncio_extra328.StreamReaderProtocol.name:
  description: "asyncio.streams.StreamReaderProtocol.__name__ == 'StreamReaderProtocol'"
  category: stream_classes
  kind: python_call_eq
  function: streams.StreamReaderProtocol.__name__.__eq__
  args: ["StreamReaderProtocol"]
  expected: true

invariant asyncio_extra328.StreamReaderProtocol.module:
  description: "asyncio.streams.StreamReaderProtocol.__module__ == 'asyncio.streams'"
  category: stream_classes
  kind: python_call_eq
  function: streams.StreamReaderProtocol.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.create_subprocess_exec — name and module
#
# create_subprocess_exec is a coroutine function that creates a subprocess
# and returns an asyncio.subprocess.Process instance. It is defined in
# asyncio.subprocess and re-exported at the asyncio package level.
# ---------------------------------------------------------------------------

invariant asyncio_extra328.create_subprocess_exec.name:
  description: "asyncio.create_subprocess_exec.__name__ == 'create_subprocess_exec'"
  category: subprocess_functions
  kind: python_call_eq
  function: create_subprocess_exec.__name__.__eq__
  args: ["create_subprocess_exec"]
  expected: true

invariant asyncio_extra328.create_subprocess_exec.module:
  description: "asyncio.create_subprocess_exec.__module__ == 'asyncio.subprocess'"
  category: subprocess_functions
  kind: python_call_eq
  function: create_subprocess_exec.__module__.__eq__
  args: ["asyncio.subprocess"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.create_subprocess_shell — name and module
#
# create_subprocess_shell is the shell-variant counterpart to
# create_subprocess_exec. It runs the command through the system shell
# and is defined alongside create_subprocess_exec in asyncio.subprocess.
# ---------------------------------------------------------------------------

invariant asyncio_extra328.create_subprocess_shell.name:
  description: "asyncio.create_subprocess_shell.__name__ == 'create_subprocess_shell'"
  category: subprocess_functions
  kind: python_call_eq
  function: create_subprocess_shell.__name__.__eq__
  args: ["create_subprocess_shell"]
  expected: true

invariant asyncio_extra328.create_subprocess_shell.module:
  description: "asyncio.create_subprocess_shell.__module__ == 'asyncio.subprocess'"
  category: subprocess_functions
  kind: python_call_eq
  function: create_subprocess_shell.__module__.__eq__
  args: ["asyncio.subprocess"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.open_connection — name and module
#
# open_connection is a high-level coroutine that establishes a network
# connection and returns a (StreamReader, StreamWriter) pair. It is defined
# in asyncio.streams.
# ---------------------------------------------------------------------------

invariant asyncio_extra328.open_connection.name:
  description: "asyncio.open_connection.__name__ == 'open_connection'"
  category: stream_functions
  kind: python_call_eq
  function: open_connection.__name__.__eq__
  args: ["open_connection"]
  expected: true

invariant asyncio_extra328.open_connection.module:
  description: "asyncio.open_connection.__module__ == 'asyncio.streams'"
  category: stream_functions
  kind: python_call_eq
  function: open_connection.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true

# ---------------------------------------------------------------------------
# asyncio.start_server — name and module
#
# start_server is a high-level coroutine that creates a TCP server. It is
# defined in asyncio.streams and re-exported at the asyncio package level.
# ---------------------------------------------------------------------------

invariant asyncio_extra328.start_server.name:
  description: "asyncio.start_server.__name__ == 'start_server'"
  category: stream_functions
  kind: python_call_eq
  function: start_server.__name__.__eq__
  args: ["start_server"]
  expected: true

invariant asyncio_extra328.start_server.module:
  description: "asyncio.start_server.__module__ == 'asyncio.streams'"
  category: stream_functions
  kind: python_call_eq
  function: start_server.__module__.__eq__
  args: ["asyncio.streams"]
  expected: true
