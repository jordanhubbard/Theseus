error_model: python_exceptions

table pathlib_extra676.class_name_identity:
  description: "pathlib class __class__.__name__ identity checks"
  kind: python_call_eq
  category: class_identity
  id_prefix: pl676cn
  columns: [id, function, args, expected]
  rows:
    - [pl676cn001, pathlib.Path.__class__.__name__.__eq__, ["type"], true]
    - [pl676cn002, pathlib.PurePath.__class__.__name__.__eq__, ["type"], true]
    - [pl676cn003, pathlib.PosixPath.__class__.__name__.__eq__, ["type"], true]
    - [pl676cn004, pathlib.WindowsPath.__class__.__name__.__eq__, ["type"], true]
    - [pl676cn005, pathlib.PurePosixPath.__class__.__name__.__eq__, ["type"], true]
    - [pl676cn006, pathlib.PureWindowsPath.__class__.__name__.__eq__, ["type"], true]

table pathlib_extra676.purepath_module_identity:
  description: "pathlib PurePath __module__ identity checks"
  kind: python_call_eq
  category: module_identity
  id_prefix: pl676mi
  columns: [id, function, args, expected]
  rows:
    - [pl676mi001, pathlib.PurePosixPath.__module__.__eq__, ["pathlib"], true]
    - [pl676mi002, pathlib.PureWindowsPath.__module__.__eq__, ["pathlib"], true]

table pathlib_extra676.qualname_identity:
