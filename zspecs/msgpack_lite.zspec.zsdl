spec: msgpack_lite
version: ">=0.1.0"
backend: node(msgpack-lite)

docs: https://github.com/kawanet/msgpack-lite#readme

provenance:
  derived_from:
    - "msgpack-lite README — https://github.com/kawanet/msgpack-lite#readme"
    - "MessagePack specification — https://github.com/msgpack/msgpack/blob/master/spec.md"
    - "Test vectors verified with msgpack-lite via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "msgpack-lite source"
  notes:
    - "msgpack-lite is a pure-JS MessagePack encoder/decoder."
    - "Install: npm install msgpack-lite"
    - "encode(value) returns a Node Buffer; decode(buf_or_array) returns the JS value."
    - "Test vectors compare encode output via .toString('base64') and verify decode round-trips of known wire bytes."
  rfcs:
    - "MessagePack specification — https://github.com/msgpack/msgpack/blob/master/spec.md"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Pure functions; never throws on JSON-shaped input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

# encode(value) — Buffer -> base64 for equality comparison
table msgpack_lite.encode:
  kind: node_chain_eq
  category: encode
  entry: named
  function: encode
  id_prefix: enc

  columns: [id, entry_args, chain, expected]
  rows:
    - [single_pair_object,
       [{a: 1}],
       [{method: toString, args: ["base64"]}],
       "gaFhAQ=="]

    - [array_three,
       [[1, 2, 3]],
       [{method: toString, args: ["base64"]}],
       "kwECAw=="]

    - [boolean_true,
       [true],
       [{method: toString, args: ["base64"]}],
       "ww=="]

    - [null_value,
       [~],
       [{method: toString, args: ["base64"]}],
       "wA=="]

    - [int_42,
       [42],
       [{method: toString, args: ["base64"]}],
       "Kg=="]

# decode(bytes_array) — pass byte array as plain JSON array
table msgpack_lite.decode:
  kind: node_chain_eq
  category: decode
  entry: named
  function: decode
  id_prefix: dec

  columns: [id, entry_args, chain, expected]
  rows:
    - [single_pair_object,
       [[0x81, 0xa1, 0x61, 0x01]],
       [],
       {a: 1}]

    - [array_three,
       [[0x93, 0x01, 0x02, 0x03]],
       [],
       [1, 2, 3]]

    - [boolean_true,
       [[0xc3]],
       [],
       true]

    - [null_value,
       [[0xc0]],
       [],
       ~]

    - [int_42,
       [[0x2a]],
       [],
       42]
