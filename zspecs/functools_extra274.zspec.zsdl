spec: functools_extra274
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/functools.py"
  notes:
    - "functools.WRAPPER_ASSIGNMENTS is a tuple of 6 strings: '__module__', '__name__', '__qualname__', '__doc__', '__annotate__', '__type_params__'."
    - "WRAPPER_ASSIGNMENTS[0] == '__module__' (len=10); WRAPPER_ASSIGNMENTS[-1] == '__type_params__' (len=15 — longest element)."
    - "WRAPPER_ASSIGNMENTS[3] == '__doc__' (len=7 — shortest element in tuple)."
    - "functools.WRAPPER_UPDATES is a single-element tuple: ('__dict__',); WRAPPER_UPDATES[0] == '__dict__' (len=8)."
    - "functools.reduce raises TypeError for empty sequence without initial value — 'reduce() of empty iterable with no initial value'."
    - "functools.partial raises TypeError if first argument is not callable — e.g. partial(42) raises TypeError."
    - "WRAPPER_ASSIGNMENTS is a tuple class ('tuple').__name__; WRAPPER_UPDATES is also 'tuple'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.WRAPPER_ASSIGNMENTS element identity
#
# WRAPPER_ASSIGNMENTS is a 6-element tuple.
# [0] == '__module__' (len=10)
# [1] == '__name__' (len=8)
# [2] == '__qualname__' (len=12)
# [3] == '__doc__' (len=7 — shortest)
# [4] == '__annotate__' (len=12)
# [5] == '__type_params__' (len=15 — longest)
# WRAPPER_UPDATES is a 1-element tuple: ('__dict__',)
# ---------------------------------------------------------------------------

table functools_extra274.wrapper_assignments_elements:
  description: "functools.WRAPPER_ASSIGNMENTS 6-element tuple and WRAPPER_UPDATES 1-element tuple identity — WRAPPER_ASSIGNMENTS: '__module__'(10), '__name__'(8), '__qualname__'(12), '__doc__'(7 shortest), '__annotate__'(12), '__type_params__'(15 longest); WRAPPER_UPDATES: '__dict__'(8); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: ftex274wa

  columns: [id, function, args, expected, description]
  rows:
    - [wa_len,              WRAPPER_ASSIGNMENTS.__len__,                 [],                             6,    "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — tuple has 6 elements; verified with Python 3.14.3"]
    - [wa_cls_eq,           WRAPPER_ASSIGNMENTS.__class__.__name__.__eq__, ["tuple"],                   true, "functools.WRAPPER_ASSIGNMENTS.__class__.__name__ == 'tuple'; verified with Python 3.14.3"]
    - [wa0_eq,              WRAPPER_ASSIGNMENTS.__getitem__(0).__eq__,   ["__module__"],                 true, "functools.WRAPPER_ASSIGNMENTS[0] == '__module__'; verified with Python 3.14.3"]
    - [wa0_len,             WRAPPER_ASSIGNMENTS.__getitem__(0).__len__,  [],                             10,   "functools.WRAPPER_ASSIGNMENTS[0].__len__() == 10 — '__module__' has 10 chars; verified with Python 3.14.3"]
    - [wa1_eq,              WRAPPER_ASSIGNMENTS.__getitem__(1).__eq__,   ["__name__"],                   true, "functools.WRAPPER_ASSIGNMENTS[1] == '__name__'; verified with Python 3.14.3"]
    - [wa1_len,             WRAPPER_ASSIGNMENTS.__getitem__(1).__len__,  [],                             8,    "functools.WRAPPER_ASSIGNMENTS[1].__len__() == 8 — '__name__' has 8 chars; verified with Python 3.14.3"]
    - [wa2_eq,              WRAPPER_ASSIGNMENTS.__getitem__(2).__eq__,   ["__qualname__"],               true, "functools.WRAPPER_ASSIGNMENTS[2] == '__qualname__'; verified with Python 3.14.3"]
    - [wa2_len,             WRAPPER_ASSIGNMENTS.__getitem__(2).__len__,  [],                             12,   "functools.WRAPPER_ASSIGNMENTS[2].__len__() == 12 — '__qualname__' has 12 chars; verified with Python 3.14.3"]
    - [wa3_eq,              WRAPPER_ASSIGNMENTS.__getitem__(3).__eq__,   ["__doc__"],                    true, "functools.WRAPPER_ASSIGNMENTS[3] == '__doc__' — shortest element (7 chars); verified with Python 3.14.3"]
    - [wa3_len,             WRAPPER_ASSIGNMENTS.__getitem__(3).__len__,  [],                             7,    "functools.WRAPPER_ASSIGNMENTS[3].__len__() == 7 — '__doc__' is shortest element; verified with Python 3.14.3"]
    - [wa4_eq,              WRAPPER_ASSIGNMENTS.__getitem__(4).__eq__,   ["__annotate__"],               true, "functools.WRAPPER_ASSIGNMENTS[4] == '__annotate__'; verified with Python 3.14.3"]
    - [wa4_len,             WRAPPER_ASSIGNMENTS.__getitem__(4).__len__,  [],                             12,   "functools.WRAPPER_ASSIGNMENTS[4].__len__() == 12 — '__annotate__' has 12 chars; verified with Python 3.14.3"]
    - [wa5_eq,              WRAPPER_ASSIGNMENTS.__getitem__(5).__eq__,   ["__type_params__"],            true, "functools.WRAPPER_ASSIGNMENTS[5] == '__type_params__' — longest element (15 chars); verified with Python 3.14.3"]
    - [wa5_len,             WRAPPER_ASSIGNMENTS.__getitem__(5).__len__,  [],                             15,   "functools.WRAPPER_ASSIGNMENTS[5].__len__() == 15 — '__type_params__' is longest element; verified with Python 3.14.3"]
    - [wu_len,              WRAPPER_UPDATES.__len__,                     [],                             1,    "functools.WRAPPER_UPDATES.__len__() == 1 — single-element tuple; verified with Python 3.14.3"]
    - [wu_cls_eq,           WRAPPER_UPDATES.__class__.__name__.__eq__,   ["tuple"],                     true, "functools.WRAPPER_UPDATES.__class__.__name__ == 'tuple'; verified with Python 3.14.3"]
    - [wu0_eq,              WRAPPER_UPDATES.__getitem__(0).__eq__,        ["__dict__"],                  true, "functools.WRAPPER_UPDATES[0] == '__dict__'; verified with Python 3.14.3"]
    - [wu0_len,             WRAPPER_UPDATES.__getitem__(0).__len__,       [],                            8,    "functools.WRAPPER_UPDATES[0].__len__() == 8 — '__dict__' has 8 chars; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — functools_extra274
# ---------------------------------------------------------------------------

invariant functools_extra274.wrapper_assignments_len_is_six:
  description: "functools.WRAPPER_ASSIGNMENTS.__len__() == 6 — tuple has 6 elements: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra274.wrapper_assignments_contains_module:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__module__') == True — '__module__' is the first element of WRAPPER_ASSIGNMENTS"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__module__"]
  expected: true

invariant functools_extra274.wrapper_assignments_contains_type_params:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__type_params__') == True — '__type_params__' is the last element of WRAPPER_ASSIGNMENTS (len=15, longest)"
  category: identity
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__type_params__"]
  expected: true

invariant functools_extra274.wrapper_updates_len_is_one:
  description: "functools.WRAPPER_UPDATES.__len__() == 1 — single-element tuple containing only '__dict__'"
  category: identity
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1

invariant functools_extra274.wrapper_updates_contains_dict:
  description: "functools.WRAPPER_UPDATES.__contains__('__dict__') == True — '__dict__' is the sole element of WRAPPER_UPDATES (len=8)"
  category: identity
  kind: python_call_eq
  function: WRAPPER_UPDATES.__contains__
  args: ["__dict__"]
  expected: true

invariant functools_extra274.reduce_empty_no_init_raises_typeerror:
  description: "functools.reduce(lambda a,b: a+b, []) raises TypeError — empty iterable with no initial value raises TypeError"
  category: errors
  kind: python_call_raises
  function: reduce
  args: ["lambda a,b: a+b", []]
  raises: TypeError

invariant functools_extra274.partial_non_callable_raises_typeerror:
  description: "functools.partial(42) raises TypeError — first argument must be callable; passing a non-callable integer raises TypeError"
  category: errors
  kind: python_call_raises
  function: partial
  args: [42]
  raises: TypeError
