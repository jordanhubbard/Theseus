provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module class documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks decimal module class __qualname__ identity for Decimal, Context, and exception hierarchy"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table decimal_extra916.core_class_qualnames:
  description: "decimal.Decimal and decimal.Context __qualname__ identity"
  kind: python_call_eq
  category: core_class_qualnames
  id_prefix: dc916cc
  columns: [id, function, args, expected]
  rows:
    - [dc916cc001, decimal.Decimal.__qualname__.__eq__,  ["Decimal"],  true]
    - [dc916cc002, decimal.Context.__qualname__.__eq__,  ["Context"],  true]
    - [dc916cc003, decimal.Decimal.__module__.__eq__,    ["decimal"],  true]
    - [dc916cc004, decimal.Context.__module__.__eq__,    ["decimal"],  true]
    - [dc916cc005, decimal.Decimal.__name__.__eq__,      ["Decimal"],  true]
    - [dc916cc006, decimal.Context.__name__.__eq__,      ["Context"],  true]
    - [dc916cc007, decimal.Decimal.__class__.__name__.__eq__, ["type"], true]
    - [dc916cc008, decimal.Context.__class__.__name__.__eq__, ["type"], true]

table decimal_extra916.exception_qualnames:
