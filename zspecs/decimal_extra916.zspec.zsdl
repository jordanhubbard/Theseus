    - [dc916ex006, decimal.Inexact.__qualname__.__eq__,           ["Inexact"],           true]
    - [dc916ex007, decimal.DecimalException.__module__.__eq__,    ["decimal"],           true]
    - [dc916ex008, decimal.InvalidOperation.__module__.__eq__,    ["decimal"],           true]

table decimal_extra916.exception_name_identity:
