table abc_extra253.hashable_sized_callable_identity:
  description: "collections.abc.Hashable(len=8), Sized(len=5), and Callable(len=8) class identity — all three inherit from object(len=6); all defined in collections.abc(len=15); each has exactly 1 abstract method: __hash__, __len__, __call__ respectively; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc253hsc

  columns: [id, function, args, expected, description]
  rows:
    - [h_name_eq,          Hashable.__name__.__eq__,                              ["Hashable"],         true, "collections.abc.Hashable.__name__ == 'Hashable'; verified with Python 3.14.3"]
    - [h_name_len,         Hashable.__name__.__len__,                             [],                   8,    "collections.abc.Hashable.__name__.__len__() == 8 — same length as Callable; verified with Python 3.14.3"]
    - [h_mod_eq,           Hashable.__module__.__eq__,                            ["collections.abc"],  true, "collections.abc.Hashable.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [h_base_eq,          "Hashable.__bases__[0].__name__.__eq__",               ["object"],           true, "collections.abc.Hashable.__bases__[0].__name__ == 'object' — Hashable inherits directly from object; verified with Python 3.14.3"]
    - [h_am_len,           Hashable.__abstractmethods__.__len__,                  [],                   1,    "collections.abc.Hashable.__abstractmethods__.__len__() == 1; verified with Python 3.14.3"]
    - [h_am_hash,          "Hashable.__abstractmethods__.__contains__",           ["__hash__"],         true, "collections.abc.Hashable.__abstractmethods__.__contains__('__hash__') == True; verified with Python 3.14.3"]
    - [sz_name_eq,         Sized.__name__.__eq__,                                 ["Sized"],            true, "collections.abc.Sized.__name__ == 'Sized'; verified with Python 3.14.3"]
    - [sz_name_len,        Sized.__name__.__len__,                                [],                   5,    "collections.abc.Sized.__name__.__len__() == 5; verified with Python 3.14.3"]
    - [sz_mod_eq,          Sized.__module__.__eq__,                               ["collections.abc"],  true, "collections.abc.Sized.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [sz_base_eq,         "Sized.__bases__[0].__name__.__eq__",                  ["object"],           true, "collections.abc.Sized.__bases__[0].__name__ == 'object' — Sized inherits directly from object; verified with Python 3.14.3"]
    - [sz_am_len,          Sized.__abstractmethods__.__len__,                     [],                   1,    "collections.abc.Sized.__abstractmethods__.__len__() == 1; verified with Python 3.14.3"]
    - [sz_am_len_member,   Sized.__abstractmethods__.__contains__,                ["__len__"],          true, "collections.abc.Sized.__abstractmethods__.__contains__('__len__') == True; verified with Python 3.14.3"]
    - [cl_name_eq,         Callable.__name__.__eq__,                              ["Callable"],         true, "collections.abc.Callable.__name__ == 'Callable'; verified with Python 3.14.3"]
    - [cl_name_len,        Callable.__name__.__len__,                             [],                   8,    "collections.abc.Callable.__name__.__len__() == 8 — same length as Hashable; verified with Python 3.14.3"]
    - [cl_mod_eq,          Callable.__module__.__eq__,                            ["collections.abc"],  true, "collections.abc.Callable.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [cl_base_eq,         "Callable.__bases__[0].__name__.__eq__",               ["object"],           true, "collections.abc.Callable.__bases__[0].__name__ == 'object' — Callable inherits directly from object; verified with Python 3.14.3"]
    - [cl_am_len,          Callable.__abstractmethods__.__len__,                  [],                   1,    "collections.abc.Callable.__abstractmethods__.__len__() == 1; verified with Python 3.14.3"]
    - [cl_am_call,         "Callable.__abstractmethods__.__contains__",           ["__call__"],         true, "collections.abc.Callable.__abstractmethods__.__contains__('__call__') == True; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra253
# ---------------------------------------------------------------------------

invariant abc_extra253.mutable_set_has_most_abstract_methods:
  description: "collections.abc.MutableSet.__abstractmethods__.__len__() == 5 — MutableSet has the most abstract methods (5) among all five ABCs in this spec; Set has 3, Hashable/Sized/Callable each have 1; MutableSet extends Set by adding non-dunder 'add' and 'discard'; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: MutableSet.__abstractmethods__.__len__
  args: []
  expected: 5

invariant abc_extra253.mutable_set_add_is_non_dunder:
  description: "collections.abc.MutableSet.__abstractmethods__.__contains__('add') returns True — 'add' and 'discard' are the two non-dunder abstract methods in MutableSet; all other abstract methods across Set, Hashable, Sized, and Callable are dunder methods; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: MutableSet.__abstractmethods__.__contains__
  args: ["add"]
  expected: true
