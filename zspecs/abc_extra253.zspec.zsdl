# collections.abc.Set.__bases__[0].__name__ == 'Collection' (len=10)
# collections.abc.Set.__abstractmethods__ has 3 members: __contains__, __iter__, __len__
# ---------------------------------------------------------------------------

table abc_extra253.set_class_identity:
  description: "collections.abc.Set(len=3) class identity — inherits from Collection(len=10); defined in collections.abc(len=15); __abstractmethods__ frozenset has 3 members: __contains__, __iter__, __len__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc253s

  columns: [id, function, args, expected, description]
  rows:
    - [s_name_eq,          Set.__name__.__eq__,                                   ["Set"],              true, "collections.abc.Set.__name__ == 'Set'; verified with Python 3.14.3"]
    - [s_name_len,         Set.__name__.__len__,                                  [],                   3,    "collections.abc.Set.__name__.__len__() == 3 — shortest class name in spec; verified with Python 3.14.3"]
    - [s_mod_eq,           Set.__module__.__eq__,                                 ["collections.abc"],  true, "collections.abc.Set.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [s_mod_len,          Set.__module__.__len__,                                [],                   15,   "collections.abc.Set.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [s_base_eq,          "Set.__bases__[0].__name__.__eq__",                    ["Collection"],       true, "collections.abc.Set.__bases__[0].__name__ == 'Collection' — Set inherits from Collection; verified with Python 3.14.3"]
    - [s_base_len,         "Set.__bases__[0].__name__.__len__",                   [],                   10,   "collections.abc.Set.__bases__[0].__name__.__len__() == 10; verified with Python 3.14.3"]
    - [s_am_len,           Set.__abstractmethods__.__len__,                       [],                   3,    "collections.abc.Set.__abstractmethods__.__len__() == 3; verified with Python 3.14.3"]
    - [s_am_contains,      "Set.__abstractmethods__.__contains__",                ["__contains__"],     true, "collections.abc.Set.__abstractmethods__.__contains__('__contains__') == True; verified with Python 3.14.3"]
    - [s_am_iter,          Set.__abstractmethods__.__contains__,                  ["__iter__"],         true, "collections.abc.Set.__abstractmethods__.__contains__('__iter__') == True; verified with Python 3.14.3"]
    - [s_am_len_member,    Set.__abstractmethods__.__contains__,                  ["__len__"],          true, "collections.abc.Set.__abstractmethods__.__contains__('__len__') == True; verified with Python 3.14.3"]

