spec: abc_extra253
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.Set.__name__ == 'Set' (len=3); __module__ == 'collections.abc' (len=15); __bases__[0].__name__ == 'Collection' (len=10); __abstractmethods__ has 3 members: __contains__, __iter__, __len__."
    - "collections.abc.MutableSet.__name__ == 'MutableSet' (len=10); __bases__[0].__name__ == 'Set' (len=3); __abstractmethods__ has 5 members: __contains__, __iter__, __len__, add, discard."
    - "collections.abc.Hashable.__name__ == 'Hashable' (len=8); __bases__[0].__name__ == 'object' (len=6); __abstractmethods__ has 1 member: __hash__."
    - "collections.abc.Sized.__name__ == 'Sized' (len=5); __bases__[0].__name__ == 'object' (len=6); __abstractmethods__ has 1 member: __len__."
    - "collections.abc.Callable.__name__ == 'Callable' (len=8); __bases__[0].__name__ == 'object' (len=6); __abstractmethods__ has 1 member: __call__."
    - "Hashable, Sized, and Callable all inherit directly from object and each has exactly 1 abstract method."
    - "Set has the shortest name (len=3); MutableSet.__abstractmethods__ has the most members (5); Set has 3 abstract methods — one more than Sequence's 2 (from abc_extra252)."
    - "MutableSet adds 'add' and 'discard' beyond Set's 3 abstract methods; both are non-dunder methods."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

