table abc_extra253.mutable_set_class_identity:
  description: "collections.abc.MutableSet(len=10) class identity — inherits from Set(len=3); defined in collections.abc(len=15); __abstractmethods__ frozenset has 5 members: __contains__, __iter__, __len__, add, discard — adds non-dunder 'add' and 'discard' beyond Set's 3 abstract methods; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abc253ms

  columns: [id, function, args, expected, description]
  rows:
    - [ms_name_eq,         MutableSet.__name__.__eq__,                            ["MutableSet"],       true, "collections.abc.MutableSet.__name__ == 'MutableSet'; verified with Python 3.14.3"]
    - [ms_name_len,        MutableSet.__name__.__len__,                           [],                   10,   "collections.abc.MutableSet.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [ms_mod_eq,          MutableSet.__module__.__eq__,                          ["collections.abc"],  true, "collections.abc.MutableSet.__module__ == 'collections.abc'; verified with Python 3.14.3"]
    - [ms_mod_len,         MutableSet.__module__.__len__,                         [],                   15,   "collections.abc.MutableSet.__module__.__len__() == 15; verified with Python 3.14.3"]
    - [ms_base_eq,         "MutableSet.__bases__[0].__name__.__eq__",             ["Set"],              true, "collections.abc.MutableSet.__bases__[0].__name__ == 'Set' — MutableSet inherits from Set; verified with Python 3.14.3"]
    - [ms_base_len,        "MutableSet.__bases__[0].__name__.__len__",            [],                   3,    "collections.abc.MutableSet.__bases__[0].__name__.__len__() == 3 — inherits from Set(len=3); verified with Python 3.14.3"]
    - [ms_am_len,          MutableSet.__abstractmethods__.__len__,                [],                   5,    "collections.abc.MutableSet.__abstractmethods__.__len__() == 5 — most abstract methods in spec; verified with Python 3.14.3"]
    - [ms_am_contains,     "MutableSet.__abstractmethods__.__contains__",         ["__contains__"],     true, "collections.abc.MutableSet.__abstractmethods__.__contains__('__contains__') == True; verified with Python 3.14.3"]
    - [ms_am_iter,         MutableSet.__abstractmethods__.__contains__,           ["__iter__"],         true, "collections.abc.MutableSet.__abstractmethods__.__contains__('__iter__') == True; verified with Python 3.14.3"]
    - [ms_am_len_member,   MutableSet.__abstractmethods__.__contains__,           ["__len__"],          true, "collections.abc.MutableSet.__abstractmethods__.__contains__('__len__') == True; verified with Python 3.14.3"]
    - [ms_am_add,          MutableSet.__abstractmethods__.__contains__,           ["add"],              true, "collections.abc.MutableSet.__abstractmethods__.__contains__('add') == True — non-dunder abstract method; verified with Python 3.14.3"]
    - [ms_am_discard,      MutableSet.__abstractmethods__.__contains__,           ["discard"],          true, "collections.abc.MutableSet.__abstractmethods__.__contains__('discard') == True — non-dunder abstract method; verified with Python 3.14.3"]

