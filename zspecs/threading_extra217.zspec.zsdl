invariant threading_extra217.join_varnames_contains_timeout:
  description: "threading.Thread.join.__code__.co_varnames.__contains__('timeout') == True — timeout is a parameter of Thread.join; wave 382; new to extra217"
  kind: python_call_eq
  function: Thread.join.__code__.co_varnames.__contains__
  args: ["timeout"]
