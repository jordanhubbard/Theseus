spec: threading_extra217
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers threading.Thread method __code__ attribute checks (wave 382)."
    - "threading.Thread.__init__.__code__.co_varnames contains 'target', 'name', 'daemon'; co_argcount == 6; co_kwonlyargcount == 2. Verified with Python 3.14.3."
    - "threading.Thread.start.__code__.co_argcount == 1 (only self). Verified with Python 3.14.3."
    - "threading.Thread.join.__code__.co_varnames contains 'timeout'; co_argcount == 2. Verified with Python 3.14.3."
    - "threading.Thread.run.__code__.co_argcount == 1 (only self). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread.__init__ — co_varnames.__contains__ checks
#
# threading.Thread.__init__ is a pure-Python method with the signature:
#   __init__(self, group=None, target=None, name=None, args=(), kwargs={},
#            *, daemon=None)
# co_varnames == ('self', 'group', 'target', 'name', 'args', 'kwargs',
#                 'daemon', 'context', 'target_name')
# co_argcount == 6 (self, group, target, name, args, kwargs)
# co_kwonlyargcount == 2 (daemon is keyword-only; context is also kw-only)
#
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table threading_extra217.thread_init_co_varnames:
  description: "threading.Thread.__init__.__code__.co_varnames contains 'target', 'name', 'daemon'; wave 382; new to extra217"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra217init

  columns: [id, function, args, expected, description]
  rows:
    - [init_varnames_contains_target,
       Thread.__init__.__code__.co_varnames.__contains__,
       ["target"],
       true,
       "threading.Thread.__init__.__code__.co_varnames.__contains__('target') == True — Thread.__init__ accepts 'target' as a parameter specifying the callable to invoke in the thread; co_varnames contains 'target' so __contains__ returns True; new to extra217"]
    - [init_varnames_contains_name,
       Thread.__init__.__code__.co_varnames.__contains__,
       ["name"],
       true,
       "threading.Thread.__init__.__code__.co_varnames.__contains__('name') == True — Thread.__init__ accepts 'name' as a parameter specifying the thread name (used in repr and logging); co_varnames contains 'name' so __contains__ returns True; new to extra217"]
    - [init_varnames_contains_daemon,
       Thread.__init__.__code__.co_varnames.__contains__,
       ["daemon"],
       true,
       "threading.Thread.__init__.__code__.co_varnames.__contains__('daemon') == True — Thread.__init__ accepts 'daemon' as a keyword-only parameter controlling whether the thread is a daemon thread; co_varnames contains 'daemon' so __contains__ returns True; new to extra217"]
    - [init_varnames_contains_self,
       Thread.__init__.__code__.co_varnames.__contains__,
       ["self"],
       true,
       "threading.Thread.__init__.__code__.co_varnames.__contains__('self') == True — Thread.__init__ is a method; its first parameter is 'self' referring to the Thread instance being initialized; co_varnames contains 'self' so __contains__ returns True; new to extra217"]
    - [init_varnames_not_contains_timeout,
       Thread.__init__.__code__.co_varnames.__contains__,
       ["timeout"],
       false,
       "threading.Thread.__init__.__code__.co_varnames.__contains__('timeout') == False — Thread.__init__ has no 'timeout' parameter; timeout belongs to Thread.join(); co_varnames does not contain 'timeout' so __contains__ returns False; new to extra217"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread.__init__ — co_argcount and co_kwonlyargcount
#
# Thread.__init__ has 6 positional-or-keyword parameters:
#   self, group, target, name, args, kwargs
# It has 2 keyword-only parameters: daemon, context (in Python 3.14.3).
#
# Verified with Python 3.14.3:
#   co_argcount == 6
#   co_kwonlyargcount == 2
# ---------------------------------------------------------------------------

table threading_extra217.thread_init_co_argcount:
  description: "threading.Thread.__init__.__code__.co_argcount == 6, co_kwonlyargcount == 2; wave 382; new to extra217"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra217initcount

  columns: [id, function, args, expected, description]
  rows:
    - [init_co_argcount_eq_6,
       Thread.__init__.__code__.co_argcount.__eq__,
       [6],
       true,
       "threading.Thread.__init__.__code__.co_argcount.__eq__(6) == True — co_argcount counts the positional-or-keyword parameters: self, group, target, name, args, kwargs; that is 6 parameters; int.__eq__(6) returns True; new to extra217"]
    - [init_co_kwonlyargcount_eq_2,
       Thread.__init__.__code__.co_kwonlyargcount.__eq__,
       [2],
       true,
       "threading.Thread.__init__.__code__.co_kwonlyargcount.__eq__(2) == True — co_kwonlyargcount counts keyword-only parameters (those after *); Thread.__init__ has 'daemon' and 'context' as keyword-only in Python 3.14.3; that is 2; int.__eq__(2) returns True; new to extra217"]

# ---------------------------------------------------------------------------
# Table 3: threading.Thread.start — co_varnames and co_argcount
#
# threading.Thread.start() takes only self. It has no other parameters.
# co_varnames == ('self',) and co_argcount == 1.
#
# Verified with Python 3.14.3:
#   Thread.start.__code__.co_varnames == ('self',)
#   Thread.start.__code__.co_argcount == 1
# ---------------------------------------------------------------------------

table threading_extra217.thread_start_co_attrs:
  description: "threading.Thread.start.__code__: co_varnames contains 'self', co_argcount == 1; wave 382; new to extra217"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra217start

  columns: [id, function, args, expected, description]
  rows:
    - [start_varnames_contains_self,
       Thread.start.__code__.co_varnames.__contains__,
       ["self"],
       true,
       "threading.Thread.start.__code__.co_varnames.__contains__('self') == True — Thread.start() is a method that takes only self; co_varnames contains 'self' so __contains__ returns True; new to extra217"]
    - [start_varnames_not_contains_target,
       Thread.start.__code__.co_varnames.__contains__,
       ["target"],
       false,
       "threading.Thread.start.__code__.co_varnames.__contains__('target') == False — Thread.start() takes no arguments besides self; it starts the thread activity; 'target' is a parameter of __init__, not start; co_varnames does not contain 'target' so __contains__ returns False; new to extra217"]
    - [start_co_argcount_eq_1,
       Thread.start.__code__.co_argcount.__eq__,
       [1],
       true,
       "threading.Thread.start.__code__.co_argcount.__eq__(1) == True — Thread.start() has exactly one positional-or-keyword parameter: self; co_argcount is 1; int.__eq__(1) returns True; new to extra217"]

# ---------------------------------------------------------------------------
# Table 4: threading.Thread.join — co_varnames.__contains__ and co_argcount
#
# threading.Thread.join(timeout=None) takes self and an optional timeout.
# co_varnames == ('self', 'timeout') and co_argcount == 2.
#
# Verified with Python 3.14.3:
#   Thread.join.__code__.co_varnames.__contains__('timeout') == True
#   Thread.join.__code__.co_argcount == 2
# ---------------------------------------------------------------------------

table threading_extra217.thread_join_co_attrs:
  description: "threading.Thread.join.__code__: co_varnames contains 'timeout', co_argcount == 2; wave 382; new to extra217"
  kind: python_call_eq
  category: identity
  id_prefix: threadingextra217join

  columns: [id, function, args, expected, description]
  rows:
    - [join_varnames_contains_timeout,
       Thread.join.__code__.co_varnames.__contains__,
       ["timeout"],
       true,
       "threading.Thread.join.__code__.co_varnames.__contains__('timeout') == True — Thread.join() accepts an optional timeout parameter specifying how long to wait in seconds; co_varnames contains 'timeout' so __contains__ returns True; new to extra217"]
    - [join_varnames_contains_self,
       Thread.join.__code__.co_varnames.__contains__,
       ["self"],
       true,
       "threading.Thread.join.__code__.co_varnames.__contains__('self') == True — Thread.join() is a method; its first parameter is 'self'; co_varnames contains 'self' so __contains__ returns True; new to extra217"]
    - [join_varnames_not_contains_daemon,
       Thread.join.__code__.co_varnames.__contains__,
       ["daemon"],
       false,
       "threading.Thread.join.__code__.co_varnames.__contains__('daemon') == False — Thread.join() has no 'daemon' parameter; daemon is a parameter of Thread.__init__(); co_varnames does not contain 'daemon' so __contains__ returns False; new to extra217"]
    - [join_co_argcount_eq_2,
       Thread.join.__code__.co_argcount.__eq__,
       [2],
       true,
       "threading.Thread.join.__code__.co_argcount.__eq__(2) == True — Thread.join() has two positional-or-keyword parameters: self and timeout; co_argcount is 2; int.__eq__(2) returns True; new to extra217"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra217
# ---------------------------------------------------------------------------

invariant threading_extra217.init_varnames_contains_target:
  description: "threading.Thread.__init__.__code__.co_varnames.__contains__('target') == True — 'target' is a parameter of Thread.__init__; wave 382; new to extra217"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_varnames.__contains__
  args: ["target"]
  expected: true

invariant threading_extra217.init_varnames_contains_name:
  description: "threading.Thread.__init__.__code__.co_varnames.__contains__('name') == True — 'name' is a parameter of Thread.__init__; wave 382; new to extra217"
  kind: python_call_eq
  function: Thread.__init__.__code__.co_varnames.__contains__
  args: ["name"]
  expected: true

invariant threading_extra217.init_varnames_contains_daemon:
  description: "threading.Thread.__init__.__code__.co_varnames.__contains__('daemon') == True — 'daemon' is a keyword-only parameter of Thread.__init__; wave 382; new to extra217"
  kind: python_call_eq
