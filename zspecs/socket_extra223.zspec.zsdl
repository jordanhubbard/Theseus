spec: socket_extra223
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html
rfcs:
  - "RFC 793 — Transmission Control Protocol (TCP)"
  - "RFC 791 — Internet Protocol (IP)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
  notes:
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "socket.socket.close.__class__.__name__ == 'function' — close is defined in Lib/socket.py (Python-level wrapper)."
    - "socket.socket.bind.__class__.__name__ == 'method_descriptor' — bind is a C-level method on _socket.socket."
    - "socket.socket.connect.__class__.__name__ == 'method_descriptor' — connect is a C-level method on _socket.socket."
    - "socket.socket.listen.__class__.__name__ == 'method_descriptor' — listen is a C-level method on _socket.socket."
    - "socket.socket.accept.__class__.__name__ == 'function' — accept is overridden in Lib/socket.py."
    - "socket.socket.send.__class__.__name__ == 'method_descriptor' — send is a C-level method on _socket.socket."
    - "socket.socket.recv.__class__.__name__ == 'method_descriptor' — recv is a C-level method on _socket.socket."
    - "socket.socket.fileno.__class__.__name__ == 'method_descriptor' — fileno is a C-level method on _socket.socket."
    - "socket.socket.setsockopt.__class__.__name__ == 'method_descriptor' — setsockopt is a C-level method on _socket.socket."
    - "socket.socket.getsockopt.__class__.__name__ == 'method_descriptor' — getsockopt is a C-level method on _socket.socket."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket method __class__ type contracts
#
# socket.socket.close.__class__.__name__      == 'function'          (Python override in Lib/socket.py)
# socket.socket.bind.__class__.__name__       == 'method_descriptor' (C-level on _socket.socket)
# socket.socket.connect.__class__.__name__    == 'method_descriptor'
# socket.socket.listen.__class__.__name__     == 'method_descriptor'
# socket.socket.accept.__class__.__name__     == 'function'          (Python override in Lib/socket.py)
# socket.socket.send.__class__.__name__       == 'method_descriptor'
# socket.socket.recv.__class__.__name__       == 'method_descriptor'
# socket.socket.fileno.__class__.__name__     == 'method_descriptor'
# socket.socket.setsockopt.__class__.__name__ == 'method_descriptor'
# socket.socket.getsockopt.__class__.__name__ == 'method_descriptor'
# ---------------------------------------------------------------------------

table socket_extra223.socket_method_type_contracts:
  description: "socket.socket method __class__ type contracts in socket223 namespace — wave 223 theme: most socket.socket methods are C-level method_descriptor objects inherited from _socket.socket; close and accept are overridden as pure Python functions in Lib/socket.py; bind/connect/listen/send/recv/fileno/setsockopt/getsockopt are all method_descriptor; verified with Python 3.14.3 on macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: socket223

  columns: [id, function, args, expected, description]
  rows:
    - [socket_close_class,      socket.socket.close.__class__.__name__.__eq__,      ["function"],         true, "socket.socket.close.__class__.__name__ == 'function' — close is overridden as a pure Python function in Lib/socket.py"]
    - [socket_bind_class,       socket.socket.bind.__class__.__name__.__eq__,       ["method_descriptor"], true, "socket.socket.bind.__class__.__name__ == 'method_descriptor' — bind is a C-level method descriptor inherited from _socket.socket"]
    - [socket_connect_class,    socket.socket.connect.__class__.__name__.__eq__,    ["method_descriptor"], true, "socket.socket.connect.__class__.__name__ == 'method_descriptor' — connect is a C-level method descriptor inherited from _socket.socket"]
    - [socket_listen_class,     socket.socket.listen.__class__.__name__.__eq__,     ["method_descriptor"], true, "socket.socket.listen.__class__.__name__ == 'method_descriptor' — listen is a C-level method descriptor inherited from _socket.socket"]
    - [socket_accept_class,     socket.socket.accept.__class__.__name__.__eq__,     ["function"],         true, "socket.socket.accept.__class__.__name__ == 'function' — accept is overridden as a pure Python function in Lib/socket.py"]
    - [socket_send_class,       socket.socket.send.__class__.__name__.__eq__,       ["method_descriptor"], true, "socket.socket.send.__class__.__name__ == 'method_descriptor' — send is a C-level method descriptor inherited from _socket.socket"]
    - [socket_recv_class,       socket.socket.recv.__class__.__name__.__eq__,       ["method_descriptor"], true, "socket.socket.recv.__class__.__name__ == 'method_descriptor' — recv is a C-level method descriptor inherited from _socket.socket"]
    - [socket_fileno_class,     socket.socket.fileno.__class__.__name__.__eq__,     ["method_descriptor"], true, "socket.socket.fileno.__class__.__name__ == 'method_descriptor' — fileno is a C-level method descriptor inherited from _socket.socket"]
    - [socket_setsockopt_class, socket.socket.setsockopt.__class__.__name__.__eq__, ["method_descriptor"], true, "socket.socket.setsockopt.__class__.__name__ == 'method_descriptor' — setsockopt is a C-level method descriptor inherited from _socket.socket"]
    - [socket_getsockopt_class, socket.socket.getsockopt.__class__.__name__.__eq__, ["method_descriptor"], true, "socket.socket.getsockopt.__class__.__name__ == 'method_descriptor' — getsockopt is a C-level method descriptor inherited from _socket.socket"]

# ---------------------------------------------------------------------------
# Standalone invariants for socket method type contracts
# ---------------------------------------------------------------------------

invariant socket_extra223.socket_close_function_eq:
  description: "socket.socket.close.__class__.__name__.__eq__('function') == True — close is overridden in Lib/socket.py as a pure Python function that also calls _real_close; this distinguishes it from pure C-level methods on _socket.socket; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: socket.socket.close.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant socket_extra223.socket_bind_method_descriptor_eq:
  description: "socket.socket.bind.__class__.__name__.__eq__('method_descriptor') == True — bind is a C-level method_descriptor inherited from _socket.socket; not overridden in Lib/socket.py; verified with Python 3.14.3"
  category: class_identity
  kind: python_call_eq
  function: socket.socket.bind.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true
