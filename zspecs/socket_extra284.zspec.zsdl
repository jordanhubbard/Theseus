spec: socket_extra284
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket constants for address families and protocol types"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "AF_INET=2 and SOCK_STREAM=1 are universally stable across all Unix-like platforms"
    - "IPPROTO_TCP=6 and IPPROTO_UDP=17 match IANA-assigned protocol numbers"
    - "AF_INET and AF_UNIX are AddressFamily IntEnum; SOCK_STREAM and SOCK_DGRAM are SocketKind IntEnum"
    - "IPPROTO_TCP, IPPROTO_UDP, IPPROTO_IP are plain int on CPython 3.14 macOS"
    - "AF_INET6 is platform-specific (30 on macOS, 10 on Linux) and intentionally excluded"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table socket_extra284.constant_values:
  description: "Standard socket constants have their IANA/POSIX-specified integer values"
  kind: python_call_eq
  category: identity
  id_prefix: sck

  columns: [id, function, args, expected, description]
  rows:
    - [sck001, socket.AF_INET.__eq__,     [2],  true, "AF_INET equals 2 (IPv4 address family)"]
    - [sck002, socket.AF_UNIX.__eq__,     [1],  true, "AF_UNIX equals 1 (Unix domain socket)"]
    - [sck003, socket.SOCK_STREAM.__eq__, [1],  true, "SOCK_STREAM equals 1 (TCP-style stream socket)"]
    - [sck004, socket.SOCK_DGRAM.__eq__,  [2],  true, "SOCK_DGRAM equals 2 (UDP-style datagram socket)"]
    - [sck005, socket.SOCK_RAW.__eq__,    [3],  true, "SOCK_RAW equals 3 (raw socket)"]
    - [sck006, socket.IPPROTO_TCP.__eq__, [6],  true, "IPPROTO_TCP equals 6 (IANA TCP protocol number)"]
    - [sck007, socket.IPPROTO_UDP.__eq__, [17], true, "IPPROTO_UDP equals 17 (IANA UDP protocol number)"]
    - [sck008, socket.IPPROTO_IP.__eq__,  [0],  true, "IPPROTO_IP equals 0 (dummy protocol for IP)"]

table socket_extra284.constant_class_names:
  description: "Socket constants have the expected enum or int class names"
  kind: python_call_eq
  category: identity
  id_prefix: scc

  columns: [id, function, args, expected, description]
  rows:
    - [scc001, socket.AF_INET.__class__.__name__.__eq__,     ["AddressFamily"], true, "AF_INET is AddressFamily IntEnum"]
    - [scc002, socket.AF_UNIX.__class__.__name__.__eq__,     ["AddressFamily"], true, "AF_UNIX is AddressFamily IntEnum"]
    - [scc003, socket.SOCK_STREAM.__class__.__name__.__eq__, ["SocketKind"],    true, "SOCK_STREAM is SocketKind IntEnum"]
    - [scc004, socket.SOCK_DGRAM.__class__.__name__.__eq__,  ["SocketKind"],    true, "SOCK_DGRAM is SocketKind IntEnum"]
    - [scc005, socket.IPPROTO_TCP.__class__.__name__.__eq__, ["int"],           true, "IPPROTO_TCP is plain int"]
    - [scc006, socket.IPPROTO_UDP.__class__.__name__.__eq__, ["int"],           true, "IPPROTO_UDP is plain int"]
    - [scc007, socket.IPPROTO_IP.__class__.__name__.__eq__,  ["int"],           true, "IPPROTO_IP is plain int"]

invariant socket_extra284.af_inet_eq_2:
  description: "AF_INET equals 2"
  category: identity
  kind: python_call_eq
  function: socket.AF_INET.__eq__
  args: [2]
  expected: true

invariant socket_extra284.sock_stream_eq_1:
  description: "SOCK_STREAM equals 1"
  category: identity
  kind: python_call_eq
  function: socket.SOCK_STREAM.__eq__
  args: [1]
  expected: true

invariant socket_extra284.ipproto_tcp_eq_6:
  description: "IPPROTO_TCP equals 6 (IANA-assigned)"
  category: identity
  kind: python_call_eq
  function: socket.IPPROTO_TCP.__eq__
  args: [6]
  expected: true

invariant socket_extra284.ipproto_udp_eq_17:
  description: "IPPROTO_UDP equals 17 (IANA-assigned)"
  category: identity
  kind: python_call_eq
  function: socket.IPPROTO_UDP.__eq__
  args: [17]
  expected: true
