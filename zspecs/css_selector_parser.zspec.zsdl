spec: css_selector_parser
version: ">=3.0.0"
backend: node(css-selector-parser)

docs: https://github.com/mdevils/css-selector-parser#readme

provenance:
  derived_from:
    - "css-selector-parser README — https://github.com/mdevils/css-selector-parser#readme"
    - "Selectors Level 4 — https://drafts.csswg.org/selectors/"
    - "Test vectors verified with css-selector-parser via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "css-selector-parser source"
  notes:
    - "Parse and serialise CSS selectors — used by html-to-text, juice."
    - "Install: npm install css-selector-parser"
    - "v3 CJS; named exports createParser / render / ast / traverse."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Parser throws SyntaxError on malformed selectors."
  stderr: "null"
  stickiness: "N/A — each parse independent."
  codes: {}

invariant css_selector_parser.parse_simple_class:
  description: "parse('.foo') returns a Selector with one Rule"
  category: parse
  kind: node_chain_eq
  entry: factory
  factory: createParser
  entry_args: []
  chain:
    - {call: [".foo"]}
    - {get: type}
  expected: "Selector"

invariant css_selector_parser.parse_tag_class_combination:
  description: "parse('div.foo') yields type 'Selector'"
  category: parse
  kind: node_chain_eq
  entry: factory
  factory: createParser
  entry_args: []
  chain:
    - {call: ["div.foo"]}
    - {get: type}
  expected: "Selector"

invariant css_selector_parser.parse_one_rule:
  description: "Selector for 'div.foo' has rules array of length 1"
  category: parse
  kind: node_chain_eq
  entry: factory
  factory: createParser
  entry_args: []
  chain:
    - {call: ["div.foo"]}
    - {get: rules}
    - {get: length}
  expected: 1

invariant css_selector_parser.parse_first_item_TagName:
  description: "First item in 'div.foo' rule is a TagName"
  category: parse
  kind: node_chain_eq
  entry: factory
  factory: createParser
  entry_args: []
  chain:
    - {call: ["div.foo"]}
    - {get: "rules.0.items.0.type"}
  expected: "TagName"

invariant css_selector_parser.parse_first_item_name:
  description: "First item's name is 'div'"
  category: parse
  kind: node_chain_eq
  entry: factory
  factory: createParser
  entry_args: []
  chain:
    - {call: ["div.foo"]}
    - {get: "rules.0.items.0.name"}
  expected: "div"

invariant css_selector_parser.parse_second_item_ClassName:
  description: "Second item is a ClassName"
  category: parse
  kind: node_chain_eq
  entry: factory
  factory: createParser
  entry_args: []
  chain:
    - {call: ["div.foo"]}
    - {get: "rules.0.items.1.type"}
  expected: "ClassName"

invariant css_selector_parser.has_createParser:
  description: "createParser is exported"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "createParser.constructor.name"}
  expected: "Function"

invariant css_selector_parser.has_render:
  description: "render is exported (serialize back to selector text)"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "render.constructor.name"}
  expected: "Function"
