spec: selectors
version: ">=3.4"
backend: python_module(selectors)

docs: https://docs.python.org/3/library/selectors.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/selectors.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/selectors.py"
  notes:
    - "selectors provides a high-level I/O multiplexing interface built on top of select/poll/epoll/kqueue."
    - "On macOS, DefaultSelector is an alias for KqueueSelector (kqueue is the most efficient mechanism)."
    - "DefaultSelector.__name__ == 'KqueueSelector' on macOS; the name is platform-specific."
    - "EpollSelector is Linux-only and is not present on macOS; it is omitted from this spec."
    - "KqueueSelector is macOS-only and is included here since tests target Darwin 25.4.0."
    - "BaseSelector is an abstract base class (ABCMeta); its abstract methods are register, unregister, select, get_map."
    - "SelectSelector and KqueueSelector both inherit from _BaseSelectorImpl, which inherits from BaseSelector."
    - "SelectorKey is a namedtuple with fields: fileobj, fd, events, data."
    - "EVENT_READ == 1 and EVENT_WRITE == 2 are portable integer constants."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Selector methods raise ValueError for invalid file objects or event masks; KeyError if a file object is not registered."
  stderr: "null"
  stickiness: "N/A — each call is stateless."
  codes: {}

# ---------------------------------------------------------------------------
# EVENT_READ and EVENT_WRITE constants
# ---------------------------------------------------------------------------

table selectors.event_constants:
  kind: python_call_eq
  category: constants
  id_prefix: const

  columns: [id, function, args, expected]
  rows:
    - [EVENT_READ,  "EVENT_READ.__eq__",  [1], true]
    - [EVENT_WRITE, "EVENT_WRITE.__eq__", [2], true]

# ---------------------------------------------------------------------------
# Constants are plain ints
# ---------------------------------------------------------------------------

table selectors.event_constant_types:
  kind: python_call_eq
  category: types
  id_prefix: const_type

  columns: [id, function, args, expected]
  rows:
    - [EVENT_READ,  "EVENT_READ.__class__.__name__.__eq__",  ["int"], true]
    - [EVENT_WRITE, "EVENT_WRITE.__class__.__name__.__eq__", ["int"], true]

# ---------------------------------------------------------------------------
# BaseSelector class name and module
# ---------------------------------------------------------------------------

invariant selectors.BaseSelector.class_name:
  description: "selectors.BaseSelector.__name__ == 'BaseSelector'"
  category: classnames
  kind: python_call_eq
  function: "BaseSelector.__name__.__eq__"
  args: ["BaseSelector"]
  expected: true

invariant selectors.BaseSelector.module:
  description: "selectors.BaseSelector.__module__ == 'selectors'"
  category: classnames
  kind: python_call_eq
  function: "BaseSelector.__module__.__eq__"
  args: ["selectors"]
  expected: true

# ---------------------------------------------------------------------------
# SelectSelector class name and module
# ---------------------------------------------------------------------------

invariant selectors.SelectSelector.class_name:
  description: "selectors.SelectSelector.__name__ == 'SelectSelector'"
  category: classnames
  kind: python_call_eq
  function: "SelectSelector.__name__.__eq__"
  args: ["SelectSelector"]
  expected: true

invariant selectors.SelectSelector.module:
  description: "selectors.SelectSelector.__module__ == 'selectors'"
  category: classnames
  kind: python_call_eq
  function: "SelectSelector.__module__.__eq__"
  args: ["selectors"]
  expected: true

# ---------------------------------------------------------------------------
# KqueueSelector class name (macOS only)
# ---------------------------------------------------------------------------

invariant selectors.KqueueSelector.class_name:
  description: "selectors.KqueueSelector.__name__ == 'KqueueSelector' — macOS only"
  category: classnames
  kind: python_call_eq
  function: "KqueueSelector.__name__.__eq__"
  args: ["KqueueSelector"]
  expected: true

invariant selectors.KqueueSelector.module:
  description: "selectors.KqueueSelector.__module__ == 'selectors'"
  category: classnames
  kind: python_call_eq
  function: "KqueueSelector.__module__.__eq__"
  args: ["selectors"]
  expected: true

# ---------------------------------------------------------------------------
# DefaultSelector is KqueueSelector on macOS
# ---------------------------------------------------------------------------

invariant selectors.DefaultSelector.name_on_macos:
  description: "selectors.DefaultSelector.__name__ == 'KqueueSelector' on macOS/Darwin"
  category: classnames
  kind: python_call_eq
  function: "DefaultSelector.__name__.__eq__"
  args: ["KqueueSelector"]
  expected: true

# ---------------------------------------------------------------------------
# SelectorKey namedtuple
# ---------------------------------------------------------------------------

invariant selectors.SelectorKey.class_name:
  description: "selectors.SelectorKey.__name__ == 'SelectorKey'"
  category: classnames
  kind: python_call_eq
  function: "SelectorKey.__name__.__eq__"
  args: ["SelectorKey"]
  expected: true

invariant selectors.SelectorKey.base_class:
  description: "selectors.SelectorKey.__bases__[0].__name__ == 'tuple' — SelectorKey is a namedtuple"
  category: hierarchy
  kind: python_call_eq
  function: "SelectorKey.__bases__.__getitem__"
  args: [0]
  method: __name__
  method_args: []
  expected: "tuple"

# ---------------------------------------------------------------------------
# SelectorKey _fields — named fields of the namedtuple
# ---------------------------------------------------------------------------

table selectors.SelectorKey.fields:
  kind: python_call_eq
  category: namedtuple_fields
  id_prefix: field

  columns: [id, function, args, expected]
  rows:
    - [fileobj, "SelectorKey._fields.__contains__", ["fileobj"], true]
    - [fd,      "SelectorKey._fields.__contains__", ["fd"],      true]
    - [events,  "SelectorKey._fields.__contains__", ["events"],  true]
    - [data,    "SelectorKey._fields.__contains__", ["data"],    true]
