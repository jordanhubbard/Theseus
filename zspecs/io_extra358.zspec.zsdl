spec: io_extra358
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "io stream classes are implemented in the _io C extension; __module__ returns '_io' not 'io'"
    - "BytesIO and BufferedReader share the same base class _BufferedIOBase"
    - "StringIO and TextIOWrapper share the same base class _TextIOBase"
    - "FileIO inherits from _RawIOBase"
    - "All class __name__ and __module__ values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io stream class identity — class names
# ---------------------------------------------------------------------------

table io_extra358.stream_class_names:
  description: "io stream class __name__ identity checks — BytesIO, StringIO, BufferedReader, FileIO, TextIOWrapper; all implemented in the _io C extension; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iostreamname358

  columns: [id, function, args, expected]
  rows:
    - [bytesio_name,        io.BytesIO.__name__.__eq__,        ["BytesIO"],        true]
    - [stringio_name,       io.StringIO.__name__.__eq__,       ["StringIO"],       true]
    - [bufferedreader_name, io.BufferedReader.__name__.__eq__, ["BufferedReader"], true]
    - [fileio_name,         io.FileIO.__name__.__eq__,         ["FileIO"],         true]
    - [textiowrapper_name,  io.TextIOWrapper.__name__.__eq__,  ["TextIOWrapper"],  true]

# ---------------------------------------------------------------------------
# io stream class identity — module attributes
# ---------------------------------------------------------------------------

table io_extra358.stream_class_modules:
  description: "io stream class __module__ identity checks — all five stream classes report __module__ as '_io' (the underlying C extension), not 'io'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iostreammod358

  columns: [id, function, args, expected]
  rows:
    - [bytesio_module,        io.BytesIO.__module__.__eq__,        ["_io"], true]
    - [stringio_module,       io.StringIO.__module__.__eq__,       ["_io"], true]
    - [bufferedreader_module, io.BufferedReader.__module__.__eq__, ["_io"], true]
    - [fileio_module,         io.FileIO.__module__.__eq__,         ["_io"], true]
    - [textiowrapper_module,  io.TextIOWrapper.__module__.__eq__,  ["_io"], true]

# ---------------------------------------------------------------------------
# io stream class identity — base class names
# ---------------------------------------------------------------------------

table io_extra358.stream_class_bases:
  description: "io stream class __bases__[0].__name__ identity checks — BytesIO and BufferedReader extend _BufferedIOBase; StringIO and TextIOWrapper extend _TextIOBase; FileIO extends _RawIOBase; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: iostreambase358

  columns: [id, function, args, expected]
  rows:
    - [bytesio_base,        "io.BytesIO.__bases__[0].__name__.__eq__",        ["_BufferedIOBase"], true]
    - [stringio_base,       "io.StringIO.__bases__[0].__name__.__eq__",       ["_TextIOBase"],     true]
    - [bufferedreader_base, "io.BufferedReader.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true]
    - [fileio_base,         "io.FileIO.__bases__[0].__name__.__eq__",         ["_RawIOBase"],      true]
    - [textiowrapper_base,  "io.TextIOWrapper.__bases__[0].__name__.__eq__",  ["_TextIOBase"],     true]
