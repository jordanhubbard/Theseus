spec: multiprocessing_extra31
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "https://docs.python.org/3/library/multiprocessing.html#synchronization-between-processes — multiprocessing synchronization primitives"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/synchronize.py"
    - "CPython source: Lib/multiprocessing/queues.py"
  notes:
    - "This spec extends multiprocessing_extra30.zspec.zsdl."
    - "Prior specs covered: Process/Queue/Pool/Lock/Event/Semaphore/Value/Array __name__/__module__, Process.__bases__[0].__name__=='BaseProcess', Process.__qualname__, ProcessError/AuthenticationError/BufferTooShort/TimeoutError identity and bases, cpu_count/get_start_method/set_start_method/get_context/active_children __qualname__, exception __module__ and __len__(), context-bound class __qualname__.__len__() for Pool/Queue/Lock/Event/Semaphore/Barrier, Process method __qualname__.__len__() for start/run/join/terminate/is_alive/kill, Pool method __qualname__.__len__() tables, AuthenticationError/ProcessError/BufferTooShort __bases__[0].__name__, Process/Pool/AuthenticationError/ProcessError __mro__.__len__(), __all__ metadata, class __dict__.__class__.__name__.__len__() for Process/AuthenticationError/ProcessError, Pool class metadata (dict/bases/qualname/name/module), Process name/qualname/module/mro/bases metadata, DefaultContext method qualname lengths, BufferTooShort/TimeoutError qualname lengths."
    - "This spec covers: multiprocessing.synchronize.Lock/__name__.__len__()==4, __qualname__.__len__()==4, __module__.__len__()==27, __mro__.__len__()==3, __bases__[0].__name__.__len__()==7 ('SemLock'); multiprocessing.synchronize.Event/__name__.__len__()==5, __module__.__len__()==27, __mro__.__len__()==2, __bases__[0].__name__.__len__()==6 ('object'); multiprocessing.synchronize.Semaphore/__name__.__len__()==9, __module__.__len__()==27, __mro__.__len__()==3, __bases__[0].__name__.__len__()==7 ('SemLock'); multiprocessing.queues.Queue/__name__.__len__()==5, __module__.__len__()==22, __mro__.__len__()==2, __bases__[0].__name__.__len__()==6 ('object')."
    - "The synchronize submodule 'multiprocessing.synchronize' is 27 characters long — the same length for Lock, Event, and Semaphore."
    - "multiprocessing.synchronize.Lock and multiprocessing.synchronize.Semaphore both subclass SemLock (7 chars), a C-extension wrapper around a POSIX semaphore."
    - "multiprocessing.synchronize.Event.__mro__.__len__() == 2 — Event is a direct subclass of object (no SemLock intermediate), different from Lock and Semaphore."
    - "multiprocessing.queues.Queue.__module__ == 'multiprocessing.queues' (22 chars), shorter than 'multiprocessing.synchronize' (27 chars)."
    - "multiprocessing.queues.Queue.__mro__.__len__() == 2 — Queue is a direct subclass of object, unlike asyncio.Queue which extends _LoopBoundMixin."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.synchronize.Lock class identity — extra31 namespace
#
# The concrete Lock class lives in the multiprocessing.synchronize submodule.
# When mp.Lock() is called, a multiprocessing.synchronize.Lock instance is
# returned. The class attributes:
#   Lock.__name__.__len__()             == 4  ('Lock')
#   Lock.__qualname__.__len__()         == 4  ('Lock')
#   Lock.__module__.__len__()           == 27 ('multiprocessing.synchronize')
#   Lock.__mro__.__len__()              == 3  — (Lock, SemLock, object)
#   Lock.__bases__[0].__name__.__len__() == 7  ('SemLock' — C-extension)
# No prior multiprocessing spec has examined the synchronize submodule classes
# directly.
# ---------------------------------------------------------------------------

table multiprocessing_extra31.synchronize_lock_identity:
  description: "multiprocessing.synchronize.Lock class identity lengths in extra31 namespace"
  kind: python_call_eq
  category: class_names
  id_prefix: synclockident31

  columns: [id, function, args, expected]
  rows:
    - [name_len,     multiprocessing.synchronize.Lock.__name__.__len__,     [], 4]
    - [qualname_len, multiprocessing.synchronize.Lock.__qualname__.__len__,  [], 4]
    - [module_len,   multiprocessing.synchronize.Lock.__module__.__len__,    [], 27]

table multiprocessing_extra31.synchronize_lock_hierarchy:
  description: "multiprocessing.synchronize.Lock __mro__.__len__() and __bases__[0].__name__.__len__() in extra31 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: synclockhier31

  columns: [id, function, args, expected, method, method_args, description]
  rows:
    - [mro_len,
       multiprocessing.synchronize.Lock.__mro__,
       [],
       !ascii "",
       __len__,
       [],
       "synchronize.Lock MRO depth == 3 — (Lock, SemLock, object)"]

invariant multiprocessing_extra31.synchronize_Lock_base_name_len:
  description: "multiprocessing.synchronize.Lock.__bases__[0].__name__.__len__() == 7 — base is SemLock (C-extension, 7 chars)"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.synchronize.Lock.__bases__[0].__name__.__len__"
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# multiprocessing.synchronize.Event class identity — extra31 namespace
#
# The synchronize.Event class has a different MRO than Lock and Semaphore
# because it does not subclass SemLock. Instead it is a pure Python class
# that wraps a Condition and a value:
#   Event.__name__.__len__()              == 5  ('Event')
#   Event.__module__.__len__()            == 27 ('multiprocessing.synchronize')
#   Event.__mro__.__len__()               == 2  — (Event, object) — direct object subclass
#   Event.__bases__[0].__name__.__len__() == 6  ('object')
# The MRO depth of 2 contrasts with Lock (3) and Semaphore (3).
# ---------------------------------------------------------------------------

table multiprocessing_extra31.synchronize_event_identity:
  description: "multiprocessing.synchronize.Event class identity and hierarchy lengths in extra31 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: synceventident31

  columns: [id, function, args, expected]
  rows:
    - [name_len,   multiprocessing.synchronize.Event.__name__.__len__,   [], 5]
    - [module_len, multiprocessing.synchronize.Event.__module__.__len__,  [], 27]

invariant multiprocessing_extra31.synchronize_Event_mro_len:
  description: "multiprocessing.synchronize.Event.__mro__.__len__() == 2 — Event is a direct subclass of object, unlike Lock/Semaphore which subclass SemLock"
  category: class_hierarchy
  kind: python_call_eq
  function: multiprocessing.synchronize.Event.__mro__.__len__
  args: []
  expected: 2

invariant multiprocessing_extra31.synchronize_Event_base_name_len:
  description: "multiprocessing.synchronize.Event.__bases__[0].__name__.__len__() == 6 — base is object (6 chars), not SemLock"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.synchronize.Event.__bases__[0].__name__.__len__"
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# multiprocessing.synchronize.Semaphore class identity — extra31 namespace
#
# Like Lock, Semaphore subclasses SemLock. Its key attributes:
#   Semaphore.__name__.__len__()              == 9  ('Semaphore')
#   Semaphore.__module__.__len__()            == 27 ('multiprocessing.synchronize')
#   Semaphore.__mro__.__len__()               == 3  — (Semaphore, SemLock, object)
#   Semaphore.__bases__[0].__name__.__len__() == 7  ('SemLock')
# Semaphore and Lock share the same MRO depth (3) and the same base class
# name length (7), unlike Event which is a direct object subclass.
# ---------------------------------------------------------------------------

table multiprocessing_extra31.synchronize_semaphore_identity:
  description: "multiprocessing.synchronize.Semaphore class identity and hierarchy lengths in extra31 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: syncsemident31

  columns: [id, function, args, expected]
  rows:
    - [name_len,   multiprocessing.synchronize.Semaphore.__name__.__len__,   [], 9]
    - [module_len, multiprocessing.synchronize.Semaphore.__module__.__len__,  [], 27]

invariant multiprocessing_extra31.synchronize_Semaphore_mro_len:
  description: "multiprocessing.synchronize.Semaphore.__mro__.__len__() == 3 — (Semaphore, SemLock, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: multiprocessing.synchronize.Semaphore.__mro__.__len__
  args: []
  expected: 3

invariant multiprocessing_extra31.synchronize_Semaphore_base_name_len:
  description: "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__len__() == 7 — base is SemLock, same as Lock"
  category: class_hierarchy
  kind: python_call_eq
  function: "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__len__"
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# multiprocessing.queues.Queue class identity — extra31 namespace
#
# The concrete Queue class lives in multiprocessing.queues. Unlike asyncio.Queue
# which extends _LoopBoundMixin (MRO depth 3), this Queue is a flat class:
#   queues.Queue.__name__.__len__()              == 5  ('Queue')
#   queues.Queue.__module__.__len__()            == 22 ('multiprocessing.queues')
#   queues.Queue.__mro__.__len__()               == 2  — (Queue, object)
#   queues.Queue.__bases__[0].__name__.__len__() == 6  ('object')
# The submodule 'multiprocessing.queues' (22 chars) is shorter than
# 'multiprocessing.synchronize' (27 chars).
# ---------------------------------------------------------------------------

table multiprocessing_extra31.queues_queue_identity:
  description: "multiprocessing.queues.Queue class identity and hierarchy lengths in extra31 namespace"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: queuesqueueident31

  columns: [id, function, args, expected]
  rows:
    - [name_len,   multiprocessing.queues.Queue.__name__.__len__,   [], 5]
    - [module_len, multiprocessing.queues.Queue.__module__.__len__,  [], 22]

invariant multiprocessing_extra31.queues_Queue_mro_len:
  description: "multiprocessing.queues.Queue.__mro__.__len__() == 2 — direct object subclass, unlike asyncio.Queue which has MRO depth 3"
  category: class_hierarchy
  kind: python_call_eq
  function: multiprocessing.queues.Queue.__mro__.__len__
  args: []
  expected: 2

invariant multiprocessing_extra31.synchronize_module_name_len:
  description: "multiprocessing.synchronize.Lock/__module__.__len__() == 27 — 'multiprocessing.synchronize' is the longest submodule path in this spec"
  category: class_names
  kind: python_call_eq
  function: multiprocessing.synchronize.Lock.__module__.__len__
  args: []
  expected: 27
