spec: mp2956
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.html"
    - "CPython docs — https://docs.python.org/3/library/multiprocessing.shared_ctypes.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
  notes:
    - "Wave 644 — theme: __invert__, __round__, __trunc__ dict-presence (bitwise invert, round, truncate)."
    - "Tests operator.contains(SomeClass.__dict__, '__invert__') etc. for multiprocessing classes."
    - "Classes covered: Process, pool.Pool, pool.AsyncResult, pool.MapResult, managers.SyncManager, managers.ListProxy, managers.SetProxy, managers.DictProxy."
    - "None of these classes define __invert__, __round__, or __trunc__ in their own __dict__."
    - "pool.Pool.__module__ == 'multiprocessing.pool'; managers.*.__module__ == 'multiprocessing.managers'."
    - "Process.__module__ == 'multiprocessing.context' on Python 3.12+."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __invert__ dict-presence — operator.contains(Cls.__dict__, '__invert__')
#
# None of the multiprocessing classes define __invert__; all results are false.
# ---------------------------------------------------------------------------

table mp2956.invert:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_invert
  id_prefix: inv

  columns: [id, function, args, expected]
  rows:
    - ["inv_Process",     operator.contains, [Process.__dict__,                              "__invert__"], false]
    - ["inv_Pool",        operator.contains, [multiprocessing.pool.Pool.__dict__,            "__invert__"], false]
    - ["inv_AsyncResult", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,     "__invert__"], false]
    - ["inv_MapResult",   operator.contains, [multiprocessing.pool.MapResult.__dict__,       "__invert__"], false]
    - ["inv_SyncManager", operator.contains, [multiprocessing.managers.SyncManager.__dict__, "__invert__"], false]
    - ["inv_ListProxy",   operator.contains, [multiprocessing.managers.ListProxy.__dict__,   "__invert__"], false]
    - ["inv_SetProxy",    operator.contains, [multiprocessing.managers.SetProxy.__dict__,    "__invert__"], false]
    - ["inv_DictProxy",   operator.contains, [multiprocessing.managers.DictProxy.__dict__,   "__invert__"], false]

