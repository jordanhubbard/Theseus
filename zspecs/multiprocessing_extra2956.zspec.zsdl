# ---------------------------------------------------------------------------
# combined — all three operators for a cross-class sample
#
# Spot-checks __invert__, __round__, __trunc__ absence across a representative
# selection of multiprocessing classes in a single table for concise coverage.
# ---------------------------------------------------------------------------

table mp2956.combined:
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: unary_combined
  id_prefix: comb

  columns: [id, function, args, expected]
  rows:
    - ["comb_Process_inv",       operator.contains, [Process.__dict__,                              "__invert__"], false]
    - ["comb_Process_rnd",       operator.contains, [Process.__dict__,                              "__round__"],  false]
    - ["comb_Process_trunc",     operator.contains, [Process.__dict__,                              "__trunc__"],  false]
    - ["comb_Pool_inv",          operator.contains, [multiprocessing.pool.Pool.__dict__,            "__invert__"], false]
    - ["comb_Pool_rnd",          operator.contains, [multiprocessing.pool.Pool.__dict__,            "__round__"],  false]
    - ["comb_Pool_trunc",        operator.contains, [multiprocessing.pool.Pool.__dict__,            "__trunc__"],  false]
    - ["comb_AsyncResult_inv",   operator.contains, [multiprocessing.pool.AsyncResult.__dict__,     "__invert__"], false]
    - ["comb_AsyncResult_rnd",   operator.contains, [multiprocessing.pool.AsyncResult.__dict__,     "__round__"],  false]
    - ["comb_AsyncResult_trunc", operator.contains, [multiprocessing.pool.AsyncResult.__dict__,     "__trunc__"],  false]
    - ["comb_SyncManager_inv",   operator.contains, [multiprocessing.managers.SyncManager.__dict__, "__invert__"], false]
    - ["comb_SyncManager_rnd",   operator.contains, [multiprocessing.managers.SyncManager.__dict__, "__round__"],  false]
    - ["comb_SyncManager_trunc", operator.contains, [multiprocessing.managers.SyncManager.__dict__, "__trunc__"],  false]
    - ["comb_ListProxy_inv",     operator.contains, [multiprocessing.managers.ListProxy.__dict__,   "__invert__"], false]
    - ["comb_ListProxy_rnd",     operator.contains, [multiprocessing.managers.ListProxy.__dict__,   "__round__"],  false]
    - ["comb_ListProxy_trunc",   operator.contains, [multiprocessing.managers.ListProxy.__dict__,   "__trunc__"],  false]
    - ["comb_DictProxy_inv",     operator.contains, [multiprocessing.managers.DictProxy.__dict__,   "__invert__"], false]
    - ["comb_DictProxy_rnd",     operator.contains, [multiprocessing.managers.DictProxy.__dict__,   "__round__"],  false]
    - ["comb_DictProxy_trunc",   operator.contains, [multiprocessing.managers.DictProxy.__dict__,   "__trunc__"],  false]
    - ["comb_SetProxy_inv",      operator.contains, [multiprocessing.managers.SetProxy.__dict__,    "__invert__"], false]
    - ["comb_SetProxy_rnd",      operator.contains, [multiprocessing.managers.SetProxy.__dict__,    "__round__"],  false]
    - ["comb_SetProxy_trunc",    operator.contains, [multiprocessing.managers.SetProxy.__dict__,    "__trunc__"],  false]
