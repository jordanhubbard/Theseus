spec: uuid_extra410
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.UUID.__int__.__name__ == '__int__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__int__.__qualname__ == 'UUID.__int__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__name__ == '__lt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__lt__.__qualname__ == 'UUID.__lt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__le__.__name__ == '__le__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__gt__.__name__ == '__gt__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__ge__.__name__ == '__ge__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__eq__.__name__ == '__eq__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__hash__.__name__ == '__hash__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: uuid.UUID is a pure-Python class. Its comparison and conversion methods (__int__, __lt__, __le__, __gt__, __ge__, __eq__, __hash__) are regular Python functions defined in the class body. Each method's __name__ is the bare dunder name, and its __qualname__ is prefixed with 'UUID.' following the standard Python qualname convention for methods. Note: uuid.UUID does NOT define __bytes__ — bytes conversion is handled via the .bytes property instead."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID comparison and conversion method names
#
# Wave 410 theme: uuid.UUID comparison/conversion dunder method identity.
#
# uuid.UUID is a pure-Python class. Its ordering and conversion methods
# (__int__, __lt__, __le__, __gt__, __ge__, __eq__, __hash__) are regular
# Python function objects. Accessing them on the class returns the function
# directly. Each function's __name__ is the bare dunder name (e.g. '__lt__')
# and its __qualname__ is 'UUID.__lt__' per standard Python qualname rules.
#
# Note: uuid.UUID does not define __bytes__. UUID-to-bytes conversion is
# provided by the .bytes and .bytes_le properties rather than __bytes__.
#
# Covered methods: __int__, __lt__, __le__, __gt__, __ge__, __eq__, __hash__
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra410.comparison_method_names:
  description: "uuid.UUID comparison and hash method __name__ values — each dunder method's __name__ is the bare dunder string; uuid.UUID is pure Python so these are regular function objects; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidcm410

  columns: [id, function, args, expected]
  rows:
    - [int_name,   UUID.__int__.__name__.__eq__,   ["__int__"],   true]
    - [lt_name,    UUID.__lt__.__name__.__eq__,    ["__lt__"],    true]
    - [le_name,    UUID.__le__.__name__.__eq__,    ["__le__"],    true]
    - [gt_name,    UUID.__gt__.__name__.__eq__,    ["__gt__"],    true]
    - [ge_name,    UUID.__ge__.__name__.__eq__,    ["__ge__"],    true]
    - [eq_name,    UUID.__eq__.__name__.__eq__,    ["__eq__"],    true]
    - [hash_name,  UUID.__hash__.__name__.__eq__,  ["__hash__"],  true]

# ---------------------------------------------------------------------------
# uuid.UUID comparison method qualnames
#
# Each method's __qualname__ is 'UUID.<method_name>' following the standard
# CPython qualname convention for methods defined in a class body. The
# qualname encodes both the class context and the method name, allowing
# introspection tools to reconstruct the definition scope.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra410.comparison_method_qualnames:
  description: "uuid.UUID comparison and hash method __qualname__ values — qualname is 'UUID.<method>' for each; standard Python convention for class-body method definitions; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidcq410

  columns: [id, function, args, expected]
  rows:
    - [int_qualname,   UUID.__int__.__qualname__.__eq__,   ["UUID.__int__"],   true]
    - [lt_qualname,    UUID.__lt__.__qualname__.__eq__,    ["UUID.__lt__"],    true]
    - [le_qualname,    UUID.__le__.__qualname__.__eq__,    ["UUID.__le__"],    true]
    - [gt_qualname,    UUID.__gt__.__qualname__.__eq__,    ["UUID.__gt__"],    true]
    - [ge_qualname,    UUID.__ge__.__qualname__.__eq__,    ["UUID.__ge__"],    true]
    - [eq_qualname,    UUID.__eq__.__qualname__.__eq__,    ["UUID.__eq__"],    true]
    - [hash_qualname,  UUID.__hash__.__qualname__.__eq__,  ["UUID.__hash__"],  true]
