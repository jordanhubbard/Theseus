# ---------------------------------------------------------------------------
# Standalone invariants — pure-Python function __qualname__
# ---------------------------------------------------------------------------

invariant os_extra34.makedirs.qualname:
  description: "os.makedirs.__qualname__ == 'makedirs' — pure-Python function qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: makedirs.__qualname__.__eq__
  args: ["makedirs"]
  expected: true

invariant os_extra34.getenv.qualname:
  description: "os.getenv.__qualname__ == 'getenv' — pure-Python function qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: getenv.__qualname__.__eq__
  args: ["getenv"]
  expected: true
