invariant os_extra34.rmdir.qualname:
  description: "os.rmdir.__qualname__ == 'rmdir' — C-level builtin qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: rmdir.__qualname__.__eq__
  args: ["rmdir"]
  expected: true

invariant os_extra34.rename.qualname:
  description: "os.rename.__qualname__ == 'rename' — C-level builtin qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: rename.__qualname__.__eq__
  args: ["rename"]
  expected: true

invariant os_extra34.stat.qualname:
  description: "os.stat.__qualname__ == 'stat' — C-level builtin qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: stat.__qualname__.__eq__
  args: ["stat"]
  expected: true

invariant os_extra34.getpid.qualname:
  description: "os.getpid.__qualname__ == 'getpid' — C-level builtin qualname equals bare function name"
  category: function_attrs
  kind: python_call_eq
  function: getpid.__qualname__.__eq__
