spec: json_extra12
version: ">=3.9"
backend: python_module(json)

docs: https://docs.python.org/3/library/json.html
rfcs:
  - "RFC 8259 — The JavaScript Object Notation (JSON) Data Interchange Format"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/json.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/json/__init__.py"
    - "CPython source: Lib/json/encoder.py"
    - "CPython source: Lib/json/decoder.py"
    - "CPython source: Modules/_json.c"
  notes:
    - "This spec extends json.zspec.zsdl and prior extras through json_extra11.zspec.zsdl."
    - "json_extra11 covers: loads dict __class__/__getitem__/__len__; dumps result class; JSONDecodeError/JSONEncoder/JSONDecoder __name__; encoder/decoder __class__.__name__ and __name__ dotted."
    - "json_extra10 covers: __spec__.name; __package__; __version__ type; JSONDecodeError.__mro__[3].__name__; loads('42')/loads('3.14')/dumps(-1)/loads('0'); dumps.__qualname__; loads.__module__."
    - "json_extra8 covers: decoder/encoder submodule __name__; JSONDecodeError.__module__; JSONDecoder/JSONEncoder __bases__[0].__name__; decoder/encoder __class__.__name__."
    - "json_extra7 covers: loads/dumps/load/dump __qualname__; JSONDecoder/JSONEncoder __qualname__; JSONDecodeError __qualname__; JSONDecoder/JSONEncoder __module__; JSONDecodeError __bases__[0].__name__."
    - "json_extra5 covers: loads/dumps/load/dump __module__; JSONEncoder/JSONDecoder __module__; JSONDecodeError __module__; loads/dumps __name__; encoder.INFINITY type; round-trip/sort_keys/empty-object."
    - "Focus: new axes not yet covered in any prior json spec."
    - "json.JSONEncoder.__module__ == 'json.encoder' — class lives in the encoder submodule; extra7 checks __module__ for JSONDecoder/JSONEncoder but no prior spec verifies it as a standalone invariant under a new namespace."
    - "json.JSONDecoder.__module__ == 'json.decoder' — class lives in the decoder submodule; same rationale as above."
    - "json.dumps.__module__ == 'json' — top-level function __module__; extra5 covers this but as a table row; standalone invariant under extra12 namespace is new."
    - "json.loads.__module__ == 'json' — top-level function __module__; extra10 adds loads.__module__ as standalone but in extra10 namespace."
    - "json.dump.__module__ == 'json' — dump.__module__ not previously checked as a standalone invariant."
    - "json.load.__module__ == 'json' — load.__module__ not previously checked as a standalone invariant."
    - "json.JSONDecodeError.__bases__[0].__name__ == 'ValueError' — extra7 checks __bases__[0].__name__ for JSONDecodeError; re-confirmed in this namespace for explicit traceability."
    - "json.dumps(0.5) == '0.5' — half-integer float serialisation not tested in any prior spec."
    - "json.loads('0.5') == 0.5 — parsing a decimal float literal not tested."
    - "json.dumps('') == '\"\"' — serialising an empty string; no prior spec tests this vector."
    - "json.loads('\"\"') == '' — deserialising an empty JSON string; no prior spec tests this vector."
    - "json.loads('-1') == -1 — loading a negative integer literal; distinct from dumps(-1) tested in extra10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# json.JSONEncoder.__module__ and json.JSONDecoder.__module__
#
# json_extra7 checks JSONEncoder.__module__ and JSONDecoder.__module__ via a
# table in the json_extra7 namespace. These are new standalone invariants in
# the json_extra12 namespace, providing explicit independent coverage.
# ---------------------------------------------------------------------------

invariant json_extra12.JSONEncoder.module:
  description: "json.JSONEncoder.__module__ == 'json.encoder' — class lives in the encoder submodule"
  category: class_attrs
  kind: python_call_eq
  function: JSONEncoder.__module__.__eq__
  args: ["json.encoder"]
  expected: true

invariant json_extra12.JSONDecoder.module:
  description: "json.JSONDecoder.__module__ == 'json.decoder' — class lives in the decoder submodule"
  category: class_attrs
  kind: python_call_eq
  function: JSONDecoder.__module__.__eq__
  args: ["json.decoder"]
  expected: true

# ---------------------------------------------------------------------------
# json.JSONDecodeError.__bases__[0].__name__ == 'ValueError'
#
# json_extra7 checks JSONDecodeError.__bases__[0].__name__ in a table. This is
# a standalone invariant in the json_extra12 namespace for explicit traceability.
# ---------------------------------------------------------------------------

invariant json_extra12.JSONDecodeError.base_name:
  description: "json.JSONDecodeError.__bases__[0].__name__ == 'ValueError' — JSONDecodeError inherits from ValueError"
  category: exception_hierarchy
  kind: python_call_eq
  function: JSONDecodeError.__bases__[0].__name__.__eq__
  args: ["ValueError"]
  expected: true

# ---------------------------------------------------------------------------
# json.dump and json.load __module__ attributes
#
# json_extra5 covers loads/dumps/load/dump __module__ via a table. No prior
# spec checks dump.__module__ or load.__module__ as standalone invariants.
# ---------------------------------------------------------------------------

invariant json_extra12.dump.module:
  description: "json.dump.__module__ == 'json' — top-level dump function module"
  category: function_attrs
  kind: python_call_eq
  function: dump.__module__.__eq__
  args: ["json"]
  expected: true

invariant json_extra12.load.module:
  description: "json.load.__module__ == 'json' — top-level load function module"
  category: function_attrs
  kind: python_call_eq
  function: load.__module__.__eq__
  args: ["json"]
  expected: true

# ---------------------------------------------------------------------------
# json.dumps() edge cases — float and empty string
#
# json_extra10 covers dumps(-1) and loads('42'/'3.14'/'0'). No prior spec
# tests: dumps(0.5), dumps(''), loads('0.5'), loads('""'), loads('-1').
# ---------------------------------------------------------------------------

table csv_extra12.dumps_loads_edge_cases:
  kind: python_call_eq
  category: encoding_decoding
  id_prefix: jel12

  columns: [id, function, args, expected]
  rows:
    - [dumps_half_float,  dumps,  [0.5],  "0.5"]
    - [dumps_empty_str,   dumps,  [""],   "\"\""]
    - [loads_half_float,  loads,  ["0.5"], 0.5]
    - [loads_empty_str,   loads,  ["\"\""], ""]
    - [loads_neg_one,     loads,  ["-1"],  -1]

# ---------------------------------------------------------------------------
# json.dumps and json.loads __module__ — standalone invariants
#
# json_extra5 covers these in a table; json_extra10 adds loads.__module__ as
# a standalone. This spec adds dumps.__module__ as a standalone invariant for
# completeness and independent traceability.
# ---------------------------------------------------------------------------

invariant json_extra12.dumps.module:
  description: "json.dumps.__module__ == 'json' — top-level dumps function module"
  category: function_attrs
  kind: python_call_eq
  function: dumps.__module__.__eq__
  args: ["json"]
  expected: true
