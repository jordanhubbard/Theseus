spec: struct_extra293
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "struct.pack('>B', 256) raises struct.error: 'B' format requires 0 <= number <= 255."
    - "struct.pack('>b', 128) raises struct.error: 'b' format requires -128 <= number <= 127."
    - "struct.pack('>H', 65536) raises struct.error: 'H' format requires 0 <= number <= 65535."
    - "struct.unpack('>I', b'\\x00\\x01') raises struct.error: unpack requires a buffer of 4 bytes."
    - "struct.pack('z', 1) raises struct.error: bad char in struct format."
    - "struct.error.__name__ == 'error', __module__ == 'struct', __bases__[0].__name__ == 'Exception'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model:
  semantics: "struct.error is raised for out-of-range values, buffer size mismatches, and invalid format characters."
  stderr: "null"
  stickiness: "N/A — struct functions are pure; results are deterministic."
  codes: {}

# ---------------------------------------------------------------------------
# pack — out-of-range value errors
# ---------------------------------------------------------------------------

table struct_extra293.pack_out_of_range_raises:
  description: "struct.pack raises struct.error for out-of-range integer values — 'B' (unsigned byte) max is 255, 'b' (signed byte) max is 127, 'H' (unsigned short) max is 65535; verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-12"
  kind: python_call_raises
  category: errors
  id_prefix: structerr293

  columns: [id, function, args, expected]
  rows:
    - [pack_B_256,    struct.pack,  [">B", 256],    struct.error]
    - [pack_b_128,    struct.pack,  [">b", 128],    struct.error]
    - [pack_H_65536,  struct.pack,  [">H", 65536],  struct.error]

# ---------------------------------------------------------------------------
# unpack — buffer size mismatch error
# ---------------------------------------------------------------------------

invariant struct_extra293.unpack.buffer_too_small:
  description: "struct.unpack('>I', b'\\x00\\x01') raises struct.error — '>I' requires 4 bytes but only 2 provided"
  category: errors
  kind: python_call_raises
  function: struct.unpack
  args: [">I", {type: bytes_hex, value: "0001"}]
  expected_exception: struct.error

# ---------------------------------------------------------------------------
# pack — invalid format character error
# ---------------------------------------------------------------------------

invariant struct_extra293.pack.invalid_format_char:
  description: "struct.pack('z', 1) raises struct.error — 'z' is not a valid struct format character"
  category: errors
  kind: python_call_raises
  function: struct.pack
  args: ["z", 1]
  expected_exception: struct.error

# ---------------------------------------------------------------------------
# struct.error class identity
# ---------------------------------------------------------------------------

invariant struct_extra293.error.name:
  description: "struct.error.__name__ == 'error' — the struct exception class is named 'error'"
  category: class_identity
  kind: python_call_eq
  function: error.__name__.__eq__
  args: ["error"]
  expected: true

invariant struct_extra293.error.module:
  description: "struct.error.__module__ == 'struct' — struct.error belongs to the struct module"
  category: class_identity
  kind: python_call_eq
  function: error.__module__.__eq__
  args: ["struct"]
  expected: true

invariant struct_extra293.error.base_name:
  description: "struct.error.__bases__[0].__name__ == 'Exception' — struct.error directly inherits from Exception"
  category: class_identity
  kind: python_call_eq
  function: error.__bases__[0].__name__.__eq__
  args: ["Exception"]
  expected: true
