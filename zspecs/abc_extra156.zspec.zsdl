spec: abc_extra156
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec covers: abc.ABC.__subclasshook__ and abc.ABC.__init_subclass__ method qualnames, abc.ABCMeta.__prepare__ qualname, and qualname length comparisons. abc.ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (len=20: 'ABC'=3+'.'=1+'__subclasshook__'=16=20; '__subclasshook__'='_'+'_'+'subclasshook'=12+'_'+'_'=2+12+2=16; 'subclasshook'=12: 'subclass'=8+'hook'=4=12); abc.ABC.__init_subclass__.__qualname__=='ABC.__init_subclass__' (len=21: 'ABC'=3+'.'=1+'__init_subclass__'=17=21; '__init_subclass__'='_'+'_'+'init_subclass'=13+'_'+'_'=2+13+2=17; 'init_subclass'=13: 'init'=4+'_'=1+'subclass'=8=13); abc.ABCMeta.__prepare__.__qualname__=='ABCMeta.__prepare__' (len=19: 'ABCMeta'=7+'.'=1+'__prepare__'=11=19; '__prepare__'='_'+'_'+'prepare'=7+'_'+'_'=2+7+2=11). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABC.__subclasshook__.__class__.__name__=='builtin_function_or_method' — __subclasshook__ is implemented in the C extension _abc module (not as a pure Python function in abc.py); the class name 'builtin_function_or_method' (len=26) reveals it is a C builtin; this is different from abc.ABCMeta.__subclasscheck__ (len=25 qualname) and abc.ABCMeta.__instancecheck__ (len=25 qualname) which are pure Python functions (__class__.__name__=='function', established in extra155); __subclasshook__ and __init_subclass__ on abc.ABC are both C builtins (builtin_function_or_method). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.ABCMeta.__prepare__.__qualname__=='ABCMeta.__prepare__' (len=19: 'ABCMeta'=7+'.'=1+'__prepare__'=11=19) — __prepare__ is a class method on ABCMeta; __prepare__ is called by the metaclass protocol to create the class namespace before class body execution; ABCMeta.__prepare__.__class__.__name__=='builtin_function_or_method' (C builtin, not pure Python); qualname length ordering for abc methods: __prepare__(19) < __subclasshook__(20) < __init_subclass__(21); compare with ABCMeta methods from prior specs: register(16) < _dump_registry(22) < __subclasscheck__(25) == __instancecheck__(25) — these are on ABCMeta not on ABC. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "Qualname length ordering for methods in this spec: ABCMeta.__prepare__(19) < ABC.__subclasshook__(20) < ABC.__init_subclass__(21); '__subclasshook__'=16 < '__init_subclass__'=17 < (compare: '__subclasscheck__'=17 == '__instancecheck__'=17 from extra155); 'ABC.'=4 prefix (3+1=4) vs 'ABCMeta.'=8 prefix (7+1=8); the shorter 'ABC.' prefix explains why ABC.method qualnames (4+method_len) are shorter than ABCMeta.method qualnames (8+method_len) for comparable method name lengths. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABC.__subclasshook__ qualname — extra156
#
# abc.ABC.__subclasshook__.__qualname__.__eq__('ABC.__subclasshook__') == True
# abc.ABC.__subclasshook__.__qualname__.__len__()                       == 20
# ---------------------------------------------------------------------------

table abc_extra156.abc_ABC_subclasshook_qualname:
  description: "abc.ABC.__subclasshook__ qualname checks in abcabcsh156 namespace — abc.ABC.__subclasshook__.__qualname__=='ABC.__subclasshook__' (len=20: 'ABC'=3+'.'=1+'__subclasshook__'=16=20; '__subclasshook__'='_'+'_'+'subclasshook'=12+'_'+'_'=2+12+2=16; 'subclasshook'=12: 'subclass'=8+'hook'=4=12); abc.ABC.__subclasshook__ is a C builtin method (__class__.__name__=='builtin_function_or_method') — it provides a class method hook for custom issubclass() behavior; subclasses of ABC can override __subclasshook__ to customize virtual subclass detection without calling register(); the default implementation on ABC returns NotImplemented; qualname 'ABC.__subclasshook__' (len=20) vs 'ABCMeta.__subclasscheck__' (len=25; established in extra155) — the ABCMeta method qualname is 5 chars longer because 'ABCMeta'=7 > 'ABC'=3 (4 chars) and '__subclasscheck__'=17 > '__subclasshook__'=16 (1 char); total difference: 4+1=5; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcsh156

  columns: [id, function, args, expected, description]
  rows:
    - [sh_qn_eq,    abc.ABC.__subclasshook__.__qualname__.__eq__,              ["ABC.__subclasshook__"],   true,  "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (len=20); verified with Python 3.14.3"]
    - [sh_qn_len,   abc.ABC.__subclasshook__.__qualname__.__len__,             [],                          20,    "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 ('ABC.__subclasshook__'); verified with Python 3.14.3"]
    - [sh_cls_eq,   abc.ABC.__subclasshook__.__class__.__name__.__eq__,        ["builtin_function_or_method"], true, "abc.ABC.__subclasshook__.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]
    - [sh_name_eq,  abc.ABC.__subclasshook__.__name__.__eq__,                  ["__subclasshook__"],        true,  "abc.ABC.__subclasshook__.__name__ == '__subclasshook__' (len=16); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABC.__init_subclass__ qualname — extra156
#
# abc.ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__') == True
# abc.ABC.__init_subclass__.__qualname__.__len__()                        == 21
# ---------------------------------------------------------------------------

table abc_extra156.abc_ABC_init_subclass_qualname:
  description: "abc.ABC.__init_subclass__ qualname checks in abcabcis156 namespace — abc.ABC.__init_subclass__.__qualname__=='ABC.__init_subclass__' (len=21: 'ABC'=3+'.'=1+'__init_subclass__'=17=21; '__init_subclass__'='_'+'_'+'init_subclass'=13+'_'+'_'=2+13+2=17; 'init_subclass'=13: 'init'=4+'_'=1+'subclass'=8=13); abc.ABC.__init_subclass__ is a C builtin method (__class__.__name__=='builtin_function_or_method') called whenever ABC is subclassed; it is the class creation hook for ABC subclasses; qualname 'ABC.__init_subclass__' (len=21) is 1 char longer than 'ABC.__subclasshook__' (len=20) because '__init_subclass__'=17 > '__subclasshook__'=16; qualname length ordering in this spec: __prepare__(19) < __subclasshook__(20) < __init_subclass__(21); all three are C builtins with qualnames starting with 'ABC.' or 'ABCMeta.'; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcis156

  columns: [id, function, args, expected, description]
  rows:
    - [is_qn_eq,    abc.ABC.__init_subclass__.__qualname__.__eq__,              ["ABC.__init_subclass__"],   true,  "abc.ABC.__init_subclass__.__qualname__ == 'ABC.__init_subclass__' (len=21); verified with Python 3.14.3"]
    - [is_qn_len,   abc.ABC.__init_subclass__.__qualname__.__len__,             [],                           21,    "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 ('ABC.__init_subclass__'); verified with Python 3.14.3"]
    - [is_cls_eq,   abc.ABC.__init_subclass__.__class__.__name__.__eq__,        ["builtin_function_or_method"], true, "abc.ABC.__init_subclass__.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]
    - [is_name_eq,  abc.ABC.__init_subclass__.__name__.__eq__,                  ["__init_subclass__"],        true,  "abc.ABC.__init_subclass__.__name__ == '__init_subclass__' (len=17); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# abc.ABCMeta.__prepare__ qualname and cross-comparison — extra156
#
# abc.ABCMeta.__prepare__.__qualname__.__eq__('ABCMeta.__prepare__') == True
# abc.ABCMeta.__prepare__.__qualname__.__len__()                      == 19
# ---------------------------------------------------------------------------

table abc_extra156.abc_ABCMeta_prepare_qualname:
  description: "abc.ABCMeta.__prepare__ qualname checks and cross-comparison in abcprep156 namespace — abc.ABCMeta.__prepare__.__qualname__=='ABCMeta.__prepare__' (len=19: 'ABCMeta'=7+'.'=1+'__prepare__'=11=19; '__prepare__'='_'+'_'+'prepare'=7+'_'+'_'=2+7+2=11; 'prepare'=7); __prepare__ is a metaclass classmethod called by Python's class creation machinery to create the namespace dict for the class being defined; ABCMeta.__prepare__.__class__.__name__=='builtin_function_or_method' (C builtin — same class as ABC.__subclasshook__ and ABC.__init_subclass__); qualname length ordering in this spec: __prepare__(19) < __subclasshook__(20) < __init_subclass__(21); 'ABCMeta.__prepare__' (len=19) is the shortest qualname in this spec because 'ABCMeta'=7 but '__prepare__'=11 is shorter than '__subclasshook__'=16 or '__init_subclass__'=17; 7+1+11=19 vs 3+1+16=20 (subclasshook) and 3+1+17=21 (init_subclass); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcprep156

  columns: [id, function, args, expected, description]
  rows:
    - [prep_qn_eq,    abc.ABCMeta.__prepare__.__qualname__.__eq__,         ["ABCMeta.__prepare__"],  true,  "abc.ABCMeta.__prepare__.__qualname__ == 'ABCMeta.__prepare__' (len=19); verified with Python 3.14.3"]
    - [prep_qn_len,   abc.ABCMeta.__prepare__.__qualname__.__len__,        [],                        19,    "abc.ABCMeta.__prepare__.__qualname__.__len__() == 19 (shortest qualname in this spec); verified with Python 3.14.3"]
    - [prep_cls_eq,   abc.ABCMeta.__prepare__.__class__.__name__.__eq__,   ["builtin_function_or_method"], true, "abc.ABCMeta.__prepare__.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]
    - [prep_name_eq,  abc.ABCMeta.__prepare__.__name__.__eq__,             ["__prepare__"],           true,  "abc.ABCMeta.__prepare__.__name__ == '__prepare__' (len=11); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra156
# ---------------------------------------------------------------------------

invariant abc_extra156.abc_ABC_subclasshook_qualname_eq:
  description: "abc.ABC.__subclasshook__.__qualname__.__eq__('ABC.__subclasshook__') returns True — abc.ABC.__subclasshook__ is the class method hook for customizing virtual subclass detection; __subclasshook__.__qualname__=='ABC.__subclasshook__' (len=20: 'ABC'=3+'.'=1+'__subclasshook__'=16=20; '__subclasshook__'='_'+'_'+'subclasshook'=12+'_'+'_'=2+12+2=16; 'subclasshook'='subclass'=8+'hook'=4=12); ABC.__subclasshook__ is a C builtin (__class__.__name__=='builtin_function_or_method'); subclasses of ABC override __subclasshook__ to return True (is a virtual subclass) or False (is not) or NotImplemented (defer to default logic); compare: ABCMeta.__subclasscheck__.__qualname__=='ABCMeta.__subclasscheck__' (len=25; established in extra155 — the actual issubclass override on the metaclass, 5 chars longer); the 'ABC.' (len=4) prefix is shorter than 'ABCMeta.' (len=8) prefix; NEW in extra156: first standalone abc.ABC.__subclasshook__.__qualname__ identity invariant in abcabcsh156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__subclasshook__.__qualname__.__eq__
  args: ["ABC.__subclasshook__"]
  expected: true

invariant abc_extra156.abc_ABC_subclasshook_qualname_len:
  description: "abc.ABC.__subclasshook__.__qualname__.__len__() == 20 — 'ABC.__subclasshook__' has 20 characters: 'ABC'=3+'.'=1+'__subclasshook__'=16=20; '__subclasshook__'=16: 2+'subclasshook'=12+2=16; 'subclasshook'='subclass'=8+'hook'=4=12; compare qualname lengths in this spec: ABCMeta.__prepare__(19) < ABC.__subclasshook__(20) < ABC.__init_subclass__(21); qualname length difference between __subclasshook__(20) and __init_subclass__(21): 1 char because '__init_subclass__'=17 > '__subclasshook__'=16 while both share the 'ABC.'=4 prefix (3+1=4); compare with ABCMeta methods from extra155: __subclasshook__(20) < _dump_registry(22) < __subclasscheck__(25) == __instancecheck__(25); NEW in extra156: first standalone __subclasshook__.__qualname__.__len__ invariant in abcabcsh156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__subclasshook__.__qualname__.__len__
  args: []
  expected: 20

invariant abc_extra156.abc_ABC_init_subclass_qualname_eq:
  description: "abc.ABC.__init_subclass__.__qualname__.__eq__('ABC.__init_subclass__') returns True — abc.ABC.__init_subclass__ is the class creation hook called whenever a class is subclassed from ABC; __init_subclass__.__qualname__=='ABC.__init_subclass__' (len=21: 'ABC'=3+'.'=1+'__init_subclass__'=17=21; '__init_subclass__'='_'+'_'+'init_subclass'=13+'_'+'_'=2+13+2=17; 'init_subclass'='init'=4+'_'=1+'subclass'=8=13); ABC.__init_subclass__ is a C builtin (__class__.__name__=='builtin_function_or_method'); it is called with keyword arguments from the class statement when a direct subclass of ABC is created; qualname 'ABC.__init_subclass__' (len=21) is 1 char longer than 'ABC.__subclasshook__' (len=20) because '__init_subclass__'=17 > '__subclasshook__'=16; NEW in extra156: first standalone abc.ABC.__init_subclass__.__qualname__ identity invariant in abcabcis156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__init_subclass__.__qualname__.__eq__
  args: ["ABC.__init_subclass__"]
  expected: true

invariant abc_extra156.abc_ABC_init_subclass_qualname_len:
  description: "abc.ABC.__init_subclass__.__qualname__.__len__() == 21 — 'ABC.__init_subclass__' has 21 characters: 'ABC'=3+'.'=1+'__init_subclass__'=17=21; '__init_subclass__'=17: 2+'init_subclass'=13+2=17; 'init_subclass'='init'=4+'_'=1+'subclass'=8=13; qualname len=21 is 1 longer than __subclasshook__(20) and 2 longer than __prepare__(19); compare: ABC.__init_subclass__ qualname (len=21) vs ABCMeta.__subclasscheck__ qualname (len=25; established in extra155) — 4 chars shorter because 'ABC'=3 vs 'ABCMeta'=7 (4 char difference) and '__init_subclass__'=17 == '__subclasscheck__'=17 (same length); when the method name lengths are equal, the prefix length determines the total qualname length; NEW in extra156: first standalone abc.ABC.__init_subclass__.__qualname__.__len__ invariant in abcabcis156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABC.__init_subclass__.__qualname__.__len__
  args: []
  expected: 21

invariant abc_extra156.abc_ABCMeta_prepare_qualname_eq:
  description: "abc.ABCMeta.__prepare__.__qualname__.__eq__('ABCMeta.__prepare__') returns True — abc.ABCMeta.__prepare__ is the classmethod called during class creation to prepare the class namespace; __prepare__.__qualname__=='ABCMeta.__prepare__' (len=19: 'ABCMeta'=7+'.'=1+'__prepare__'=11=19; '__prepare__'='_'+'_'+'prepare'=7+'_'+'_'=2+7+2=11); ABCMeta.__prepare__ is a C builtin (__class__.__name__=='builtin_function_or_method'); __prepare__(name, bases, **kwargs) returns the dict (or dict-like object) that will be used as the class namespace during class body execution; it allows metaclasses to provide ordered or special-purpose namespaces; 'ABCMeta.__prepare__' (len=19) is the shortest qualname in this spec: __prepare__(19) < __subclasshook__(20) < __init_subclass__(21); compare: ABCMeta.register.__qualname__=='ABCMeta.register' (len=16; established in prior specs — shorter than __prepare__(19) because 'register'=8 < '__prepare__'=11); NEW in extra156: first standalone abc.ABCMeta.__prepare__.__qualname__ identity invariant in abcprep156 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__prepare__.__qualname__.__eq__
  args: ["ABCMeta.__prepare__"]
  expected: true
