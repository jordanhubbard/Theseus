spec: object_assign
version: ">=4.1.1"
backend: node(object-assign)

docs: https://www.npmjs.com/package/object-assign

provenance:
  derived_from:
    - "object-assign README — https://www.npmjs.com/package/object-assign"
    - "Test vectors verified with object-assign via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "object-assign source"
  notes:
    - "object-assign is an npm package. Install: npm install object-assign"
    - "Polyfill for Object.assign — copies enumerable own properties from sources into target."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the target object."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table object_assign.assign:
  kind: node_module_call_eq
  function: ~
  category: object
  id_prefix: oassign

  columns: [id, args, expected]
  rows:
    - [two_objs,    [{"a": 1}, {"b": 2}],           {"a": 1, "b": 2}]
    - [override,    [{"a": 1}, {"a": 2, "b": 3}],   {"a": 2, "b": 3}]
    - [three_objs,  [{"x": 1}, {"y": 2}, {"z": 3}], {"x": 1, "y": 2, "z": 3}]
