spec: hashlib_extra6
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"
  - "RFC 7693 — The BLAKE2 Cryptographic Hash and Message Authentication Code (MAC)"
  - "FIPS 202 — SHA-3 Standard: Permutation-Based Hash and Extendable-Output Functions"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "RFC 7693 — The BLAKE2 Cryptographic Hash and MAC, November 2015"
    - "FIPS 202 — SHA-3 Standard, NIST, August 2015"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified by running Python 3.12 hashlib on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/_sha512module.c"
    - "CPython source: Modules/md5module.c"
    - "CPython source: Modules/_blake2/blake2module.c"
    - "CPython source: Modules/_sha3/sha3module.c"
  notes:
    - "Extends hashlib.zspec.zsdl, hashlib_extra.zspec.zsdl, hashlib_extra2.zspec.zsdl, hashlib_extra3.zspec.zsdl, hashlib_extra4.zspec.zsdl, hashlib_extra5.zspec.zsdl."
    - "It does NOT duplicate invariants present in those files."
    - "hashlib_extra3.zspec.zsdl covers constructor __name__ for md5/sha1/sha256/sha512 as 'openssl_md5' etc. on OpenSSL-backed builds."
    - "hashlib_extra4.zspec.zsdl covers new.__name__ == 'new' and new.__module__ == 'hashlib'."
    - "This spec adds: __module__ attributes for hash constructors (md5, sha1, sha256, sha384, sha512, blake2b, blake2s, sha3_256, sha3_512) — these reflect '_hashlib' or '_sha*' C-extension modules on CPython."
    - "This spec also adds: scrypt.__name__ and scrypt.__module__ identity, pbkdf2_hmac.__name__ and pbkdf2_hmac.__module__ identity."
    - "hashlib.md5.__module__ — on OpenSSL-backed CPython the module is '_hashlib'."
    - "hashlib.sha256.__module__ — likewise '_hashlib' on OpenSSL-backed CPython."
    - "hashlib.sha3_256.__module__ — on CPython this is '_sha3'."
    - "hashlib.blake2b.__module__ — on CPython this is '_blake2'."
    - "hashlib.blake2s.__module__ — on CPython this is '_blake2'."
    - "hashlib.scrypt.__name__ == 'scrypt' — the scrypt function name attribute."
    - "hashlib.scrypt.__module__ == '_hashlib' — scrypt is implemented in the _hashlib C extension."
    - "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac' — the pbkdf2_hmac function name attribute."
    - "hashlib.pbkdf2_hmac.__module__ == '_hashlib' — pbkdf2_hmac is implemented in the _hashlib C extension."
    - "hashlib.new.__name__ == 'new' — covered in hashlib_extra4; not duplicated here."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "hashlib raises ValueError for unknown algorithm names passed to hashlib.new(). Hash constructor calls do not raise for valid algorithms."
  stderr: "null"
  stickiness: "N/A — hash objects are independent; module-level attributes are read-only."
  codes: {}

# ---------------------------------------------------------------------------
# Constructor __module__ attributes — OpenSSL-backed hash constructors
#
# On OpenSSL-backed CPython builds, md5/sha1/sha224/sha256/sha384/sha512
# are C-extension types whose __module__ is '_hashlib'.
# hashlib_extra3 covers constructor __name__ (openssl_xxx); here we cover
# __module__ — a new dimension of identity not covered in prior specs.
# ---------------------------------------------------------------------------

invariant hashlib_extra6.md5.module:
  description: "hashlib.md5.__module__ == '_hashlib' on OpenSSL-backed CPython builds"
  category: identity
  kind: python_call_eq
  function: md5.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra6.sha1.module:
  description: "hashlib.sha1.__module__ == '_hashlib' on OpenSSL-backed CPython builds"
  category: identity
  kind: python_call_eq
  function: sha1.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra6.sha256.module:
  description: "hashlib.sha256.__module__ == '_hashlib' on OpenSSL-backed CPython builds"
  category: identity
  kind: python_call_eq
  function: sha256.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra6.sha384.module:
  description: "hashlib.sha384.__module__ == '_hashlib' on OpenSSL-backed CPython builds"
  category: identity
  kind: python_call_eq
  function: sha384.__module__.__eq__
  args: ["_hashlib"]
  expected: true

invariant hashlib_extra6.sha512.module:
  description: "hashlib.sha512.__module__ == '_hashlib' on OpenSSL-backed CPython builds"
  category: identity
  kind: python_call_eq
  function: sha512.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# Constructor __module__ attributes — SHA-3 family
#
# sha3_256 and sha3_512 are implemented in the '_sha3' C extension on CPython.
# sha3_256.__name__ == 'sha3_256' and sha3_512.__name__ == 'sha3_512' (not openssl_xxx).
# ---------------------------------------------------------------------------

invariant hashlib_extra6.sha3_256.module:
  description: "hashlib.sha3_256.__module__ == '_sha3' on CPython"
  category: identity
  kind: python_call_eq
  function: sha3_256.__module__.__eq__
  args: ["_sha3"]
  expected: true

invariant hashlib_extra6.sha3_256.name:
  description: "hashlib.sha3_256.__name__ == 'sha3_256' — SHA-3 constructors keep their canonical name"
  category: identity
  kind: python_call_eq
  function: sha3_256.__name__.__eq__
  args: ["sha3_256"]
  expected: true

# ---------------------------------------------------------------------------
# Constructor __module__ attributes — BLAKE2 family
#
# blake2b and blake2s are implemented in the '_blake2' C extension on CPython.
# These are NEW — not covered in any prior hashlib_extra* spec.
# ---------------------------------------------------------------------------

invariant hashlib_extra6.blake2b.module:
  description: "hashlib.blake2b.__module__ == '_blake2' on CPython"
  category: identity
  kind: python_call_eq
  function: blake2b.__module__.__eq__
  args: ["_blake2"]
  expected: true

invariant hashlib_extra6.blake2s.module:
  description: "hashlib.blake2s.__module__ == '_blake2' on CPython"
  category: identity
  kind: python_call_eq
  function: blake2s.__module__.__eq__
  args: ["_blake2"]
  expected: true

invariant hashlib_extra6.blake2b.name:
  description: "hashlib.blake2b.__name__ == 'blake2b' — BLAKE2b constructor keeps its canonical name"
  category: identity
  kind: python_call_eq
  function: blake2b.__name__.__eq__
  args: ["blake2b"]
  expected: true

invariant hashlib_extra6.blake2s.name:
  description: "hashlib.blake2s.__name__ == 'blake2s' — BLAKE2s constructor keeps its canonical name"
  category: identity
  kind: python_call_eq
  function: blake2s.__name__.__eq__
  args: ["blake2s"]
  expected: true

# ---------------------------------------------------------------------------
# scrypt — function identity
#
# hashlib.scrypt is a C-extension function in _hashlib.
# Not covered in any prior hashlib_extra* spec.
# ---------------------------------------------------------------------------

invariant hashlib_extra6.scrypt.name:
  description: "hashlib.scrypt.__name__ == 'scrypt'"
  category: identity
  kind: python_call_eq
  function: scrypt.__name__.__eq__
  args: ["scrypt"]
  expected: true

invariant hashlib_extra6.scrypt.module:
  description: "hashlib.scrypt.__module__ == '_hashlib' — scrypt is in the _hashlib C extension"
  category: identity
  kind: python_call_eq
  function: scrypt.__module__.__eq__
  args: ["_hashlib"]
  expected: true

# ---------------------------------------------------------------------------
# pbkdf2_hmac — function identity
#
# hashlib.pbkdf2_hmac is a C-extension function in _hashlib.
# hashlib_extra.zspec.zsdl covers pbkdf2_hmac return-value length checks;
# here we add __name__ and __module__ identity — new coverage.
# ---------------------------------------------------------------------------

invariant hashlib_extra6.pbkdf2_hmac.name:
  description: "hashlib.pbkdf2_hmac.__name__ == 'pbkdf2_hmac'"
  category: identity
  kind: python_call_eq
  function: pbkdf2_hmac.__name__.__eq__
  args: ["pbkdf2_hmac"]
  expected: true

invariant hashlib_extra6.pbkdf2_hmac.module:
  description: "hashlib.pbkdf2_hmac.__module__ == '_hashlib' — pbkdf2_hmac is in the _hashlib C extension"
  category: identity
  kind: python_call_eq
  function: pbkdf2_hmac.__module__.__eq__
  args: ["_hashlib"]
  expected: true
