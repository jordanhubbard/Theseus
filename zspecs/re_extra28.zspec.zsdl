spec: re_extra28
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra27.zspec.zsdl."
    - "re_extra25 covers: __qualname__ for compile/match/search/findall/finditer/sub/subn/split/fullmatch/escape as standalone invariants."
    - "re_extra27 covers: Pattern/Match/RegexFlag __module__, RegexFlag base, error qualname/base, IGNORECASE/MULTILINE class qualname/module, compile __module__."
    - "re_extra6 covers: purge/__module__ and escape/__module__."
    - "re_extra19 covers: sub/__module__."
    - "Focus: __module__ for search/match/fullmatch/findall/finditer/subn/split — none of these appear as standalone __module__ invariants in any prior re spec."
    - "re.search.__module__ == 're' — module-level function defined in the re module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.match.__module__ == 're' — module-level function defined in the re module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.fullmatch.__module__ == 're' — module-level function defined in the re module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.findall.__module__ == 're' — module-level function defined in the re module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.finditer.__module__ == 're' — module-level function defined in the re module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.subn.__module__ == 're' — module-level function defined in the re module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "re.split.__module__ == 're' — module-level function defined in the re module. Verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.search.__module__
#
# re_extra25 records re.search.__qualname__ == 'search'. re_extra27 records
# re.compile.__module__ == 're'. No prior re spec records re.search.__module__
# as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant re_extra28.search.module:
  description: "re.search.__module__ == 're' — module-level function defined in the re module"
  category: function_module
  kind: python_call_eq
  function: search.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.match.__module__
#
# re_extra25 records re.match.__qualname__ == 'match'. No prior re spec
# records re.match.__module__ as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant re_extra28.match.module:
  description: "re.match.__module__ == 're' — module-level function defined in the re module"
  category: function_module
  kind: python_call_eq
  function: match.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.fullmatch.__module__
#
# re_extra25 records re.fullmatch.__qualname__ == 'fullmatch'. No prior re
# spec records re.fullmatch.__module__ as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant re_extra28.fullmatch.module:
  description: "re.fullmatch.__module__ == 're' — module-level function defined in the re module"
  category: function_module
  kind: python_call_eq
  function: fullmatch.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.findall.__module__
#
# re_extra25 records re.findall.__qualname__ == 'findall'. No prior re spec
# records re.findall.__module__ as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant re_extra28.findall.module:
  description: "re.findall.__module__ == 're' — module-level function defined in the re module"
  category: function_module
  kind: python_call_eq
  function: findall.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.finditer.__module__
#
# re_extra25 records re.finditer.__qualname__ == 'finditer'. No prior re spec
# records re.finditer.__module__ as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant re_extra28.finditer.module:
  description: "re.finditer.__module__ == 're' — module-level function defined in the re module"
  category: function_module
  kind: python_call_eq
  function: finditer.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.subn.__module__
#
# re_extra25 records re.subn.__qualname__ == 'subn'. re_extra19 records
# re.sub.__module__. No prior re spec records re.subn.__module__ as a
# standalone named invariant.
# ---------------------------------------------------------------------------

invariant re_extra28.subn.module:
  description: "re.subn.__module__ == 're' — module-level function defined in the re module"
  category: function_module
  kind: python_call_eq
  function: subn.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# re.split.__module__
#
# re_extra25 records re.split.__qualname__ == 'split'. No prior re spec
# records re.split.__module__ as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant re_extra28.split.module:
  description: "re.split.__module__ == 're' — module-level function defined in the re module"
  category: function_module
  kind: python_call_eq
  function: split.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# Consolidated table — all seven function __module__ checks
#
# Covers search/match/fullmatch/findall/finditer/subn/split __module__, each
# equalling 're'. These are the remaining public re module-level functions
# whose __module__ has not appeared as a standalone named invariant in any
# prior re spec.
# ---------------------------------------------------------------------------

table re_extra28.function_modules:
  description: "__module__ values for re module-level functions not previously covered as standalone invariants"
  kind: python_call_eq
  category: function_module

  columns: [id, function, args, expected]
  rows:
    - [search_module,   search.__module__.__eq__,   ["re"], true]
    - [match_module,    match.__module__.__eq__,    ["re"], true]
    - [fullmatch_module, fullmatch.__module__.__eq__, ["re"], true]
    - [findall_module,  findall.__module__.__eq__,  ["re"], true]
    - [finditer_module, finditer.__module__.__eq__,  ["re"], true]
    - [subn_module,     subn.__module__.__eq__,     ["re"], true]
    - [split_module,    split.__module__.__eq__,    ["re"], true]
