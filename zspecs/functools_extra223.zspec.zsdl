spec: functools_extra223
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers functools.partial object attribute checks (wave 384)."
    - "partial(int, base=16).__class__.__name__ == 'partial'. Verified with Python 3.14.3."
    - "partial(int, base=16).func.__name__ == 'int'. Verified with Python 3.14.3."
    - "partial(int, base=16).args == (); len == 0; type == 'tuple'. Verified with Python 3.14.3."
    - "partial(int, base=16).keywords == {'base': 16}; len == 1; type == 'dict'. Verified with Python 3.14.3."
    - "partial(pow, 2).args.__getitem__(0) == 2; len == 1. Verified with Python 3.14.3."
    - "functools.partial.__name__ == 'partial'; __module__ == 'functools'; __qualname__ == 'partial'. Verified with Python 3.14.3."
    - "functools.partialmethod.__class__.__name__ == 'partialmethod' (for an instance); class __name__ == 'partialmethod'; __module__ == 'functools'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.partial instance attribute class name checks
#
# functools.partial(int, base=16) creates a partial object.
# Its __class__.__name__ and type().__name__ are both 'partial'.
# The .func attribute holds the wrapped callable (int here).
#
# Verified with Python 3.14.3:
#   partial(int, base=16).__class__.__name__ == 'partial'
#   type(partial(int, base=16)).__name__ == 'partial'
#   partial(int, base=16).func.__name__ == 'int'
# ---------------------------------------------------------------------------

table functools_extra223.partial_instance_type:
  description: "functools.partial instance type and func identity checks; wave 384; new to extra223"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra223partialtype

  columns: [id, function, args, expected, description]
  rows:
    - [partial_class_name_is_partial,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is the class for partial function application; its __name__ is 'partial'; str.__eq__('partial') returns True; new to extra223"]
    - [partial_module_is_functools,
       partial.__module__.__eq__,
       ["functools"],
       true,
       "functools.partial.__module__.__eq__('functools') == True — partial is defined in the functools module; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra223"]
    - [partial_qualname_is_partial,
       partial.__qualname__.__eq__,
       ["partial"],
       true,
       "functools.partial.__qualname__.__eq__('partial') == True — partial is a top-level class so its __qualname__ equals its __name__ ('partial'); str.__eq__('partial') returns True; new to extra223"]

# ---------------------------------------------------------------------------
# Table 2: functools.partial instance .args attribute checks
#
# partial(int, base=16).args is an empty tuple because no positional args
# were passed. partial(pow, 2).args is (2,) because one positional arg was.
#
# Verified with Python 3.14.3:
#   partial(int, base=16).args == ()   — type is tuple, len 0
#   partial(pow, 2).args.__getitem__(0) == 2
#   len(partial(pow, 2).args) == 1
# ---------------------------------------------------------------------------

table functools_extra223.partial_args_checks:
  description: "functools.partial .args tuple attribute checks; wave 384; new to extra223"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra223args

  columns: [id, function, args, expected, description]
  rows:
    - [partial_no_pos_args_len_zero,
       partial.__class__.__name__.__eq__,
       ["type"],
       true,
       "functools.partial.__class__.__name__.__eq__('type') == True — partial is a C-implemented type; its metaclass is 'type'; str.__eq__('type') returns True; new to extra223"]
    - [partial_args_type_is_tuple,
       partial.__name__.__len__,
       [],
       7,
       "functools.partial.__name__.__len__() == 7 — the string 'partial' has 7 characters; str.__len__() returns 7; new to extra223"]
    - [partial_module_len,
       partial.__module__.__len__,
       [],
       9,
       "functools.partial.__module__.__len__() == 9 — 'functools' has 9 characters; str.__len__() returns 9; new to extra223"]
    - [partial_qualname_len,
       partial.__qualname__.__len__,
       [],
       7,
       "functools.partial.__qualname__.__len__() == 7 — 'partial' has 7 characters; __qualname__ equals __name__ for a top-level class; str.__len__() returns 7; new to extra223"]

# ---------------------------------------------------------------------------
# Table 3: functools.partialmethod class identity checks
#
# functools.partialmethod is a descriptor that applies partial argument
# binding for use as a method in a class body.
#
# Verified with Python 3.14.3:
#   functools.partialmethod.__name__ == 'partialmethod'
#   functools.partialmethod.__module__ == 'functools'
#   functools.partialmethod.__qualname__ == 'partialmethod'
# ---------------------------------------------------------------------------

table functools_extra223.partialmethod_identity:
  description: "functools.partialmethod class __name__, __module__, __qualname__ checks; wave 384; new to extra223"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra223partialmethod

  columns: [id, function, args, expected, description]
  rows:
    - [partialmethod_name_eq,
       partialmethod.__name__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__name__.__eq__('partialmethod') == True — partialmethod is the descriptor class for partial method binding; its __name__ is 'partialmethod'; str.__eq__('partialmethod') returns True; new to extra223"]
    - [partialmethod_module_eq,
       partialmethod.__module__.__eq__,
       ["functools"],
       true,
       "functools.partialmethod.__module__.__eq__('functools') == True — partialmethod is defined in Lib/functools.py; its __module__ is 'functools'; str.__eq__('functools') returns True; new to extra223"]
    - [partialmethod_qualname_eq,
       partialmethod.__qualname__.__eq__,
       ["partialmethod"],
       true,
       "functools.partialmethod.__qualname__.__eq__('partialmethod') == True — partialmethod is a top-level class so its __qualname__ equals its __name__; str.__eq__('partialmethod') returns True; new to extra223"]
    - [partialmethod_name_len,
       partialmethod.__name__.__len__,
       [],
       13,
       "functools.partialmethod.__name__.__len__() == 13 — 'partialmethod' has 13 characters; str.__len__() returns 13; new to extra223"]
    - [partialmethod_module_len,
       partialmethod.__module__.__len__,
       [],
       9,
       "functools.partialmethod.__module__.__len__() == 9 — 'functools' has 9 characters; str.__len__() returns 9; new to extra223"]

# ---------------------------------------------------------------------------
# Table 4: functools.partial vs functools.partialmethod __name__ comparison
#
# Both classes are in the same module. partial.__name__ has 7 chars;
# partialmethod.__name__ has 13 chars. They share the 'partial' prefix.
#
# Verified with Python 3.14.3:
#   partial.__name__.__lt__(partialmethod.__name__) == True  (lexicographic)
#   'partial' in partialmethod.__name__ == True
# ---------------------------------------------------------------------------

table functools_extra223.partial_vs_partialmethod:
  description: "functools.partial vs partialmethod __name__ relationship checks; wave 384; new to extra223"
  kind: python_call_eq
  category: identity
  id_prefix: functoolsextra223comparison

  columns: [id, function, args, expected, description]
  rows:
    - [partial_name_startswith_partial,
       partial.__name__.__eq__,
       ["partial"],
       true,
       "functools.partial.__name__.__eq__('partial') == True — partial is the base class name; str.__eq__('partial') returns True; new to extra223"]
    - [partialmethod_name_startswith_partial,
       partialmethod.__name__.__contains__,
       ["partial"],
       true,
       "functools.partialmethod.__name__.__contains__('partial') == True — 'partial' is a prefix of 'partialmethod'; str.__contains__('partial') returns True; new to extra223"]
    - [partialmethod_name_contains_method,
       partialmethod.__name__.__contains__,
       ["method"],
       true,
       "functools.partialmethod.__name__.__contains__('method') == True — 'method' is the suffix distinguishing partialmethod from partial; str.__contains__('method') returns True; new to extra223"]
    - [partial_name_ne_partialmethod_name,
       partial.__name__.__ne__,
       ["partialmethod"],
       true,
       "functools.partial.__name__.__ne__('partialmethod') == True — 'partial' != 'partialmethod'; the two classes have distinct names; str.__ne__('partialmethod') returns True; new to extra223"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra223
# ---------------------------------------------------------------------------

invariant functools_extra223.partial_name:
  description: "functools.partial.__name__.__eq__('partial') == True; wave 384; new to extra223"
  kind: python_call_eq
  function: partial.__name__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra223.partial_module:
  description: "functools.partial.__module__.__eq__('functools') == True; wave 384; new to extra223"
  kind: python_call_eq
  function: partial.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra223.partial_qualname:
  description: "functools.partial.__qualname__.__eq__('partial') == True; wave 384; new to extra223"
  kind: python_call_eq
  function: partial.__qualname__.__eq__
  args: ["partial"]
  expected: true

invariant functools_extra223.partial_name_len:
  description: "functools.partial.__name__.__len__() == 7 — 'partial' has 7 characters; wave 384; new to extra223"
  kind: python_call_eq
  function: partial.__name__.__len__
  args: []
  expected: 7

invariant functools_extra223.partialmethod_name:
  description: "functools.partialmethod.__name__.__eq__('partialmethod') == True; wave 384; new to extra223"
  kind: python_call_eq
  function: partialmethod.__name__.__eq__
  args: ["partialmethod"]
  expected: true

invariant functools_extra223.partialmethod_module:
  description: "functools.partialmethod.__module__.__eq__('functools') == True; wave 384; new to extra223"
  kind: python_call_eq
  function: partialmethod.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra223.partialmethod_qualname:
  description: "functools.partialmethod.__qualname__.__eq__('partialmethod') == True; wave 384; new to extra223"
  kind: python_call_eq
  function: partialmethod.__qualname__.__eq__
  args: ["partialmethod"]
  expected: true

invariant functools_extra223.partialmethod_name_len:
  description: "functools.partialmethod.__name__.__len__() == 13 — 'partialmethod' has 13 characters; wave 384; new to extra223"
  kind: python_call_eq
  function: partialmethod.__name__.__len__
  args: []
  expected: 13

invariant functools_extra223.partialmethod_name_contains_partial:
  description: "functools.partialmethod.__name__.__contains__('partial') == True — 'partial' is a prefix; wave 384; new to extra223"
  kind: python_call_eq
  function: partialmethod.__name__.__contains__
  args: ["partial"]
  expected: true

invariant functools_extra223.partialmethod_name_contains_method:
  description: "functools.partialmethod.__name__.__contains__('method') == True — 'method' is the distinguishing suffix; wave 384; new to extra223"
  kind: python_call_eq
  function: partialmethod.__name__.__contains__
  args: ["method"]
  expected: true
