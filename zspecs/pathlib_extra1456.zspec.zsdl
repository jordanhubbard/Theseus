spec: pathlib_extra1456
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/__init__.py"
    - "CPython source: Lib/pathlib/_local.py"
  notes:
    - "This spec covers __contains__ and __iter__ method presence and type checks for pathlib module classes (wave 544, _extra1456)."
    - "pathlib.PurePath does NOT define __iter__ or __contains__ in its own __dict__; paths are not containers or iterables."
    - "pathlib.Path does NOT define __iter__ or __contains__ in its own __dict__ either; iterdir() is the method for iteration."
    - "PurePath defines __truediv__ (function) in its own __dict__ to support the / operator for path joining."
    - "PurePath defines __eq__, __hash__, __lt__, __le__, __gt__, __ge__ (functions) in its own __dict__."
    - "Path defines exists, is_file, is_dir, iterdir, glob (functions) in its own __dict__."
    - "PurePath.name, .parent, .suffix, .stem, .root, .drive, .anchor, .parts, .parents are all property objects in PurePath.__dict__."
    - "Neither PurePath nor Path defines __contains__ — 'x in path' is a TypeError at runtime."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__ — __iter__ and __contains__ absence
# Paths are not iterables or containers; they expose no iteration protocol.
# ---------------------------------------------------------------------------

table pathlib_extra1456.PurePath_dict_no_iter_contains:
  description: "pathlib.PurePath.__dict__.__contains__: __iter__=False, __contains__=False — PurePath defines no iteration or membership-test protocol; paths are not sequences or containers"
  kind: python_call_eq
  category: identity
  id_prefix: pl1456pp

  columns: [id, function, args, expected, description]
  rows:
    - [pl1456pp001, PurePath.__dict__.__contains__, ["__iter__"],      false, "pathlib.PurePath.__dict__.__contains__('__iter__') == False — PurePath does not define __iter__ in its own __dict__; path objects are not iterable; to iterate over directory contents use Path.iterdir() on a concrete Path"]
    - [pl1456pp002, PurePath.__dict__.__contains__, ["__contains__"],  false, "pathlib.PurePath.__dict__.__contains__('__contains__') == False — PurePath does not define __contains__ in its own __dict__; 'x in purepath' raises TypeError at runtime since paths have no container protocol"]
    - [pl1456pp003, PurePath.__dict__.__contains__, ["__truediv__"],   true,  "pathlib.PurePath.__dict__.__contains__('__truediv__') == True — PurePath defines __truediv__ as a function in its own __dict__; this enables the / operator for path joining: PurePath('/a') / 'b' == PurePath('/a/b')"]
    - [pl1456pp004, PurePath.__dict__.__contains__, ["__eq__"],        true,  "pathlib.PurePath.__dict__.__contains__('__eq__') == True — PurePath defines __eq__ as a function in its own __dict__; path equality is case-insensitive on Windows (WindowsPath) and case-sensitive on POSIX (PosixPath)"]
    - [pl1456pp005, PurePath.__dict__.__contains__, ["__hash__"],      true,  "pathlib.PurePath.__dict__.__contains__('__hash__') == True — PurePath defines __hash__ as a function in its own __dict__; paths are hashable and can be used as dict keys or in sets; hash respects the same case-sensitivity rules as __eq__"]
    - [pl1456pp006, PurePath.__dict__.__contains__, ["joinpath"],      true,  "pathlib.PurePath.__dict__.__contains__('joinpath') == True — PurePath defines joinpath() as a function in its own __dict__; joinpath() concatenates path segments and is equivalent to using the / operator repeatedly"]

# ---------------------------------------------------------------------------
# pathlib.PurePath.__dict__ — property members present
# name, parent, suffix, stem, root, drive, anchor, parts, parents are all
# property objects defined directly in PurePath.__dict__.
# ---------------------------------------------------------------------------

table pathlib_extra1456.PurePath_dict_properties:
  description: "pathlib.PurePath.__dict__.__contains__: name/parent/suffix/stem/root/drive/anchor/parts/parents all True — these are property objects defined directly in PurePath.__dict__"
  kind: python_call_eq
  category: identity
  id_prefix: pl1456pr

  columns: [id, function, args, expected, description]
  rows:
    - [pl1456pr001, PurePath.__dict__.__contains__, ["name"],    true, "pathlib.PurePath.__dict__.__contains__('name') == True — PurePath.name is a property in PurePath.__dict__; it returns the final path component (e.g. PurePath('/foo/bar.txt').name == 'bar.txt')"]
    - [pl1456pr002, PurePath.__dict__.__contains__, ["parent"],  true, "pathlib.PurePath.__dict__.__contains__('parent') == True — PurePath.parent is a property in PurePath.__dict__; it returns the logical parent of the path (e.g. PurePath('/foo/bar').parent == PurePath('/foo'))"]
    - [pl1456pr003, PurePath.__dict__.__contains__, ["suffix"],  true, "pathlib.PurePath.__dict__.__contains__('suffix') == True — PurePath.suffix is a property in PurePath.__dict__; it returns the last file extension (e.g. PurePath('foo.tar.gz').suffix == '.gz')"]
    - [pl1456pr004, PurePath.__dict__.__contains__, ["stem"],    true, "pathlib.PurePath.__dict__.__contains__('stem') == True — PurePath.stem is a property in PurePath.__dict__; it returns the final component without its last suffix (e.g. PurePath('foo.tar.gz').stem == 'foo.tar')"]
    - [pl1456pr005, PurePath.__dict__.__contains__, ["root"],    true, "pathlib.PurePath.__dict__.__contains__('root') == True — PurePath.root is a property in PurePath.__dict__; it returns the root of the path ('/' on POSIX, empty string for relative paths)"]
    - [pl1456pr006, PurePath.__dict__.__contains__, ["drive"],   true, "pathlib.PurePath.__dict__.__contains__('drive') == True — PurePath.drive is a property in PurePath.__dict__; it returns the drive letter on Windows (e.g. 'C:') or empty string on POSIX"]
    - [pl1456pr007, PurePath.__dict__.__contains__, ["anchor"],  true, "pathlib.PurePath.__dict__.__contains__('anchor') == True — PurePath.anchor is a property in PurePath.__dict__; it is the concatenation of drive and root (e.g. 'C:\\\\' on Windows or '/' on POSIX)"]
    - [pl1456pr008, PurePath.__dict__.__contains__, ["parts"],   true, "pathlib.PurePath.__dict__.__contains__('parts') == True — PurePath.parts is a property in PurePath.__dict__; it returns a tuple of path components (e.g. PurePath('/usr/bin/python').parts == ('/', 'usr', 'bin', 'python'))"]
    - [pl1456pr009, PurePath.__dict__.__contains__, ["parents"], true, "pathlib.PurePath.__dict__.__contains__('parents') == True — PurePath.parents is a property in PurePath.__dict__; it returns an immutable sequence of the path's logical ancestors"]

# ---------------------------------------------------------------------------
# pathlib.Path.__dict__ — __iter__ and __contains__ absence + concrete methods
# Path inherits all PurePath behavior; adds filesystem-access methods.
# ---------------------------------------------------------------------------

table pathlib_extra1456.Path_dict_no_iter_contains:
  description: "pathlib.Path.__dict__.__contains__: __iter__=False, __contains__=False; exists/is_file/is_dir/iterdir all True — Path defines filesystem methods but no iteration or contains protocol"
  kind: python_call_eq
  category: identity
  id_prefix: pl1456pa

  columns: [id, function, args, expected, description]
  rows:
    - [pl1456pa001, Path.__dict__.__contains__, ["__iter__"],      false,  "pathlib.Path.__dict__.__contains__('__iter__') == False — Path does not define __iter__ in its own __dict__; Path objects are not directly iterable; use Path.iterdir() to iterate over directory contents"]
    - [pl1456pa002, Path.__dict__.__contains__, ["__contains__"],  false,  "pathlib.Path.__dict__.__contains__('__contains__') == False — Path does not define __contains__ in its own __dict__; path objects have no membership-test protocol; 'x in Path(...)' raises TypeError"]
    - [pl1456pa003, Path.__dict__.__contains__, ["exists"],        true,   "pathlib.Path.__dict__.__contains__('exists') == True — Path.exists() is a function defined directly in Path.__dict__; returns True if the path exists on the filesystem (follows symlinks by default)"]
    - [pl1456pa004, Path.__dict__.__contains__, ["is_file"],       true,   "pathlib.Path.__dict__.__contains__('is_file') == True — Path.is_file() is a function in Path.__dict__; returns True if the path points to a regular file (follows symlinks)"]
    - [pl1456pa005, Path.__dict__.__contains__, ["is_dir"],        true,   "pathlib.Path.__dict__.__contains__('is_dir') == True — Path.is_dir() is a function in Path.__dict__; returns True if the path points to a directory (follows symlinks)"]
    - [pl1456pa006, Path.__dict__.__contains__, ["iterdir"],       true,   "pathlib.Path.__dict__.__contains__('iterdir') == True — Path.iterdir() is a function in Path.__dict__; it yields Path objects for each item in the directory; it is the explicit iteration API for directory contents, distinct from __iter__"]
    - [pl1456pa007, Path.__dict__.__contains__, ["glob"],          true,   "pathlib.Path.__dict__.__contains__('glob') == True — Path.glob() is a function in Path.__dict__; it yields all matching paths under the directory using Unix shell-style wildcard patterns"]
    - [pl1456pa008, PurePath.__class__.__name__.__eq__,            ["type"], true, "pathlib.PurePath.__class__.__name__ == 'type' — PurePath is a class object with metaclass 'type'; confirmed with Python 3.14.3 on macOS/Darwin 25.4.0"]
    - [pl1456pa009, Path.__class__.__name__.__eq__,                ["type"], true, "pathlib.Path.__class__.__name__ == 'type' — Path is a class object with metaclass 'type'; confirmed with Python 3.14.3 on macOS/Darwin 25.4.0"]
