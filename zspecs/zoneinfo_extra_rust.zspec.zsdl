spec: zoneinfo_extra_rust
version: ">=3.9"
backend: rust_module(zoneinfo_extra_rust)

docs: https://docs.python.org/3/library/zoneinfo.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/zoneinfo.html — zoneinfo stdlib"
  notes:
    - "zoneinfo provides IANA timezone support (Python 3.9+)."
    - "zoneinfo.ZoneInfo('UTC').key == 'UTC'."
    - "zoneinfo.available_timezones() is a non-empty set."
    - "zoneinfo is part of the standard library."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant zoneinfo_extra_rust.utc_key:
  description: "ZoneInfo('UTC').key == 'UTC'"
  category: zoneinfo
  kind: python_call_eq
  function: zoneinfo_utc_key
  args: []
  expected: "UTC"

invariant zoneinfo_extra_rust.available_nonempty:
  description: "available_timezones() has more than 0 entries"
  category: zoneinfo
  kind: python_call_eq
  function: zoneinfo_available_nonempty
  args: []
  expected: true

invariant zoneinfo_extra_rust.has_zoneinfo_class:
  description: "zoneinfo.ZoneInfo is a class"
  category: presence
  kind: python_call_eq
  function: zoneinfo_has_class
  args: []
  expected: true

