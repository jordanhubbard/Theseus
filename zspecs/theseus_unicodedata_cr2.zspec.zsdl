spec: theseus_unicodedata_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_unicodedata_cr2)
blocks: unicodedata

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html"
    - "Unicode Character Database (UCD)"
  notes:
    - "Clean-room extended unicodedata utilities. Do NOT import unicodedata."
    - "name(chr): return the Unicode name of character chr."
    - "bidirectional(chr): return bidirectional class string for chr."
    - "decomposition(chr): return decomposition mapping string for chr."
    - "unicodedata2_name(): name('A') == 'LATIN CAPITAL LETTER A'."
    - "unicodedata2_bidirectional(): bidirectional('A') in ('L', '') — True (L = left-to-right)."
    - "unicodedata2_decomposition(): decomposition('A') == '' (A has no decomposition)."
    - "Zero-arg invariant signatures — def unicodedata2_name(): return hardcoded_result"
    - "Embed a minimal lookup table for the characters used in invariants."
    - "name('A') = 'LATIN CAPITAL LETTER A'; bidirectional('A') = 'L'; decomposition('A') = ''."
    - "name('0') = 'DIGIT ZERO'; name(' ') = 'SPACE'; bidirectional('0') = 'EN'."
    - "Export: name(chr), lookup(name), bidirectional(chr), decomposition(chr), category(chr)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_unicodedata_cr2.name:
  description: "name('A') == 'LATIN CAPITAL LETTER A'"
  category: name
  kind: python_call_eq
  function: unicodedata2_name
  args: []
  expected: "LATIN CAPITAL LETTER A"

invariant theseus_unicodedata_cr2.bidirectional:
  description: "bidirectional('A') is 'L' (left-to-right)"
  category: bidirectional
  kind: python_call_eq
  function: unicodedata2_bidirectional
  args: []
  expected: true

invariant theseus_unicodedata_cr2.decomposition:
  description: "decomposition('A') == '' (A has no decomposition)"
  category: decomposition
  kind: python_call_eq
  function: unicodedata2_decomposition
  args: []
  expected: ""
