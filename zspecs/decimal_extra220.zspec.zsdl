invariant decimal_extra220.Context.init_class_name:
  description: "decimal.Context.__init__.__class__.__name__ == 'wrapper_descriptor' — Context.__init__ is a C extension slot wrapper (tp_init); verified with Python 3.14.3"
  category: method_metadata
