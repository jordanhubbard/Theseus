spec: decimal_extra220
version: ">=3.7"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "IBM General Decimal Arithmetic Specification, Version 1.72 — http://speleotrove.com/decimal/decarith.html"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "This spec covers: decimal Context and Decimal method __class__.__name__ type contracts."
    - "decimal.getcontext.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3."
    - "decimal.setcontext.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3."
    - "decimal.Decimal.__init__.__class__.__name__ == 'wrapper_descriptor'; C extension slot wrapper; verified with Python 3.14.3."
    - "decimal.Decimal.__new__.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3."
    - "decimal.Decimal.quantize.__class__.__name__ == 'method_descriptor'; C extension method; verified with Python 3.14.3."
    - "decimal.Decimal.sqrt.__class__.__name__ == 'method_descriptor'; C extension method; verified with Python 3.14.3."
    - "decimal.Decimal.log10.__class__.__name__ == 'method_descriptor'; C extension method; verified with Python 3.14.3."
    - "decimal.Decimal.is_finite.__class__.__name__ == 'method_descriptor'; C extension method; verified with Python 3.14.3."
    - "decimal.Decimal.is_nan.__class__.__name__ == 'method_descriptor'; C extension method; verified with Python 3.14.3."
    - "decimal.Context.__init__.__class__.__name__ == 'wrapper_descriptor'; C extension slot wrapper; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal module-level function __class__.__name__ values
# getcontext and setcontext are C-level builtins.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table decimal_extra220.module_function_class_names:
  description: "decimal module-level function __class__.__name__ contracts for getcontext and setcontext; both are builtin_function_or_method; verified with Python 3.14.3"
  kind: python_call_eq
  category: function_metadata
  id_prefix: decmthdclsname220

  columns: [id, function, args, expected]
  rows:
    - [getcontext_classname, getcontext.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [setcontext_classname, setcontext.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# decimal.Decimal method __class__.__name__ values
# Decimal is a C extension type; its methods are method_descriptor.
# __init__ and __new__ have special types (wrapper_descriptor/builtin_function_or_method).
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table decimal_extra220.decimal_method_class_names:
  description: "decimal.Decimal method __class__.__name__ contracts; C extension methods are method_descriptor; __init__ is wrapper_descriptor; __new__ is builtin_function_or_method; verified with Python 3.14.3"
  kind: python_call_eq
  category: method_metadata
  id_prefix: decmthdclsname220b

  columns: [id, function, args, expected]
  rows:
    - [decimal_init_classname,     Decimal.__init__.__class__.__name__.__eq__,     ["wrapper_descriptor"],          true]
    - [decimal_new_classname,      Decimal.__new__.__class__.__name__.__eq__,      ["builtin_function_or_method"],  true]
    - [decimal_quantize_classname, Decimal.quantize.__class__.__name__.__eq__,     ["method_descriptor"],           true]
    - [decimal_sqrt_classname,     Decimal.sqrt.__class__.__name__.__eq__,         ["method_descriptor"],           true]
    - [decimal_log10_classname,    Decimal.log10.__class__.__name__.__eq__,        ["method_descriptor"],           true]
    - [decimal_isfinite_classname, Decimal.is_finite.__class__.__name__.__eq__,    ["method_descriptor"],           true]
    - [decimal_isnan_classname,    Decimal.is_nan.__class__.__name__.__eq__,       ["method_descriptor"],           true]

# ---------------------------------------------------------------------------
# decimal.Context method __class__.__name__ values
# Context is a C extension type; __init__ is a wrapper_descriptor.
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

table decimal_extra220.context_method_class_names:
  description: "decimal.Context method __class__.__name__ contracts; Context.__init__ is wrapper_descriptor (C extension slot); verified with Python 3.14.3"
  kind: python_call_eq
  category: method_metadata
  id_prefix: decctxclsname220

  columns: [id, function, args, expected]
  rows:
    - [context_init_classname, Context.__init__.__class__.__name__.__eq__, ["wrapper_descriptor"], true]

# ---------------------------------------------------------------------------
# Standalone invariants
# Verified with Python 3.14.3.
# ---------------------------------------------------------------------------

invariant decimal_extra220.getcontext.class_name:
  description: "decimal.getcontext.__class__.__name__ == 'builtin_function_or_method' — getcontext is a C-level builtin; verified with Python 3.14.3"
  category: function_metadata
  kind: python_call_eq
  function: getcontext.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant decimal_extra220.setcontext.class_name:
  description: "decimal.setcontext.__class__.__name__ == 'builtin_function_or_method' — setcontext is a C-level builtin; verified with Python 3.14.3"
  category: function_metadata
  kind: python_call_eq
  function: setcontext.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant decimal_extra220.Decimal.init_class_name:
  description: "decimal.Decimal.__init__.__class__.__name__ == 'wrapper_descriptor' — Decimal.__init__ is a C extension slot wrapper (tp_init); verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: Decimal.__init__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

invariant decimal_extra220.Decimal.new_class_name:
  description: "decimal.Decimal.__new__.__class__.__name__ == 'builtin_function_or_method' — Decimal.__new__ is a C-level builtin (tp_new); verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: Decimal.__new__.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant decimal_extra220.Decimal.quantize_class_name:
  description: "decimal.Decimal.quantize.__class__.__name__ == 'method_descriptor' — Decimal.quantize is a C extension method_descriptor; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: Decimal.quantize.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra220.Decimal.sqrt_class_name:
  description: "decimal.Decimal.sqrt.__class__.__name__ == 'method_descriptor' — Decimal.sqrt is a C extension method_descriptor; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: Decimal.sqrt.__class__.__name__.__eq__
  args: ["method_descriptor"]
  expected: true

invariant decimal_extra220.Decimal.is_finite_class_name:
  description: "decimal.Decimal.is_finite.__class__.__name__ == 'method_descriptor' — Decimal.is_finite is a C extension method_descriptor; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: Decimal.is_finite.__class__.__name__.__eq__
