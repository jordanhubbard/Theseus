  description: "decimal.Decimal.is_nan.__class__.__name__ == 'method_descriptor' — Decimal.is_nan is a C extension method_descriptor; verified with Python 3.14.3"
  category: method_metadata
  kind: python_call_eq
  function: Decimal.is_nan.__class__.__name__.__eq__
