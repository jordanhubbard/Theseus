spec: theseus_struct
version: ">=3.9"
backend: python_cleanroom(theseus_struct)
blocks: struct

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html"
  notes:
    - "Clean-room struct pack/unpack for binary data. Do NOT import struct."
    - "Support format strings: '>' big-endian, '<' little-endian prefix."
    - "Format chars: 'B' unsigned byte (1), 'H' unsigned short (2), 'I' unsigned int (4), 'i' signed int (4)."
    - "pack('>I', 256) == b'\\x00\\x00\\x01\\x00'."
    - "unpack('>I', b'\\x00\\x00\\x01\\x00') == (256,)."
    - "pack('<H', 1) == b'\\x01\\x00' (little-endian short)."
    - "Export: pack(fmt: str, *args) -> bytes, unpack(fmt: str, data: bytes) -> tuple."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_struct.pack_big_endian_int:
  description: "pack('>I', 256) == b'\\x00\\x00\\x01\\x00'"
  category: pack
  kind: python_call_eq
  function: struct_pack_big_endian
  args: []
  expected: true

invariant theseus_struct.unpack_big_endian_int:
  description: "unpack('>I', b'\\x00\\x00\\x01\\x00') == (256,)"
  category: unpack
  kind: python_call_eq
  function: struct_unpack_big_endian
  args: []
  expected: true

invariant theseus_struct.pack_little_endian_short:
  description: "pack('<H', 1) == b'\\x01\\x00'"
  category: pack
  kind: python_call_eq
  function: struct_pack_little_endian
  args: []
  expected: true
