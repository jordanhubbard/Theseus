spec: node_vm
version: ">=12.0.0"
backend: node(vm)

docs: https://nodejs.org/api/vm.html

provenance:
  derived_from:
    - "Node.js vm module documentation — https://nodejs.org/api/vm.html"
    - "Test vectors verified with Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "Node.js source"
  notes:
    - "vm is a Node.js built-in module. No npm install required."
    - "vm.runInNewContext(code) evaluates code in a sandboxed V8 context."
    - "The sandbox has no access to Node.js globals by default."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns the evaluated expression value."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table node_vm.runInNewContext:
  kind: node_module_call_eq
  function: runInNewContext
  category: runInNewContext
  id_prefix: vmrun

  columns: [id, args, expected]
  rows:
    - [add,      ["1 + 2"],              3]
    - [string,   ['"hello" + " world"'], "hello world"]
    - [ternary,  ["true ? 42 : 0"],      42]
    - [array,    ["[1,2,3].length"],     3]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T22:03:13Z
  iterations: 1
  pass_count: 4
  fail_count: 0
  total_invariants: 4
  notes: Synthesis succeeded in 1 iteration(s). 4 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
