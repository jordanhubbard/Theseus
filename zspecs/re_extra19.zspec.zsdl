spec: re_extra19
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec extends re.zspec.zsdl and prior extras through re_extra18.zspec.zsdl."
    - "re_extra18 covers: compile(r'\\d+').pattern; compile(r'\\w+').pattern; compile .groups for 0/1/2 groups; compile groupindex one named group; IGNORECASE/MULTILINE/DOTALL __int__() values."
    - "re_extra14 covers: compile(r'[a-z]+').pattern; compile groupindex one named group; RegexFlag name/qualname/module/base."
    - "re_extra12 covers: sub(r'\\s+', ' ', 'a  b  c') == 'a b c' — whitespace collapsing with double spaces."
    - "re_extra11 covers: sub(r'a', 'b', 'aaa', 1) == 'baa' — count argument limiting replacements."
    - "re_extra4 covers: sub.__name__ == 'sub'; subn.__name__ == 'subn'; sub.__module__ == 're' as standalone invariants."
    - "re_extra10 covers: subn(r'a', 'b', 'aaa')[1] == 3 — subn count three; subn.__qualname__."
    - "re_extra14 covers: subn(r'\\d', 'X', 'a1b2c3')[0] == 'aXbXcX'; subn(r'\\d', 'X', 'a1b2c3')[1] == 3."
    - "NOT yet covered (now covered here): re.sub(r'\\s+', ' ', 'hello   world') == 'hello world' — triple-space input."
    - "NOT yet covered (now covered here): re.sub(r'\\d', 'X', 'abc123') == 'abcXXX' — trailing digit block."
    - "NOT yet covered (now covered here): re.sub(r'^', '> ', 'hello') == '> hello' — anchor at line start."
    - "NOT yet covered (now covered here): re.sub(r'$', '!', 'hello') == 'hello!' — anchor at line end."
    - "NOT yet covered (now covered here): re.sub(r'[aeiou]', '*', 'hello world') == 'h*ll* w*rld' — vowel class."
    - "NOT yet covered (now covered here): re.subn(r'\\d', 'X', 'a1b2c3').__getitem__(0) == 'aXbXcX' via __getitem__."
    - "NOT yet covered (now covered here): re.subn(r'\\d', 'X', 'a1b2c3').__getitem__(1) == 3 via __getitem__."
    - "NOT yet covered (now covered here): re.subn(r'\\s+', '-', 'a b c').__getitem__(1) == 2 — two spaces replaced."
    - "re.sub(r'\\s+', ' ', 'hello   world') == 'hello world' — triple-space collapsed to single space."
    - "re.sub(r'\\d', 'X', 'abc123') == 'abcXXX' — consecutive trailing digits all replaced."
    - "re.sub(r'^', '> ', 'hello') == '> hello' — caret anchor inserts prefix at string start."
    - "re.sub(r'$', '!', 'hello') == 'hello!' — dollar anchor appends at string end."
    - "re.sub(r'[aeiou]', '*', 'hello world') == 'h*ll* w*rld' — vowel character class replaced."
    - "re.subn(r'\\d', 'X', 'a1b2c3').__getitem__(0) == 'aXbXcX' — tuple index 0 via __getitem__."
    - "re.subn(r'\\d', 'X', 'a1b2c3').__getitem__(1) == 3 — tuple index 1 (count) via __getitem__."
    - "re.subn(r'\\s+', '-', 'a b c').__getitem__(1) == 2 — two whitespace runs replaced."
    - "re.sub.__name__ == 'sub' — namespace anchor (covered in re_extra4/re_extra5 namespaces)."
    - "re.subn.__name__ == 'subn' — namespace anchor (covered in re_extra4/re_extra5 namespaces)."
    - "re.sub.__module__ == 're' — namespace anchor (covered in re_extra4/re_extra6 namespaces)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table: re.sub — new input vectors not covered in prior specs
#
# re_extra12 covers sub(r'\s+', ' ', 'a  b  c') with double spaces.
# re_extra11 covers sub with count argument.
# re_extra.zspec covers sub(r'\d', 'X', 'a1b2') with four-char input.
# No prior spec tests:
#   - sub(r'\s+', ' ', 'hello   world') — triple-space collapse with longer input
#   - sub(r'\d', 'X', 'abc123') — trailing digit block (consecutive digits)
#   - sub(r'^', '> ', 'hello') — caret anchor inserting a prefix
#   - sub(r'$', '!', 'hello') — dollar anchor appending a suffix
#   - sub(r'[aeiou]', '*', 'hello world') — vowel character class
# ---------------------------------------------------------------------------

table re_extra19.sub_new_vectors:
  description: "re.sub new input vectors — triple-space, trailing digits, anchors, vowel class"
  kind: python_call_eq
  category: sub
  id_prefix: snv

  columns: [id, function, args, expected]
  rows:
    - [triple_space,    sub, ["\\s+",    " ",   "hello   world"],  "hello world"]
    - [trailing_digits, sub, ["\\d",     "X",   "abc123"],         "abcXXX"]
    - [caret_anchor,    sub, ["^",       "> ",  "hello"],          "> hello"]
    - [dollar_anchor,   sub, ["$",       "!",   "hello"],          "hello!"]
    - [vowel_class,     sub, ["[aeiou]", "*",   "hello world"],    "h*ll* w*rld"]

# ---------------------------------------------------------------------------
# re.subn — result string and count via __getitem__
#
# re_extra14 covers subn(r'\d', 'X', 'a1b2c3')[0] and [1] using the method
# field (presumably __getitem__ or indexing). This spec uses the function-call
# form with __getitem__ as the method to explicitly test tuple index access.
# re_extra10 covers subn(r'a', 'b', 'aaa')[1] == 3 via __getitem__.
# No prior spec tests subn(r'\s+', '-', 'a b c')[1] == 2 (two space replacements).
# ---------------------------------------------------------------------------

invariant re_extra19.subn.getitem_result_string:
  description: "re.subn(r'\\d', 'X', 'a1b2c3').__getitem__(0) == 'aXbXcX' — tuple index 0 via __getitem__"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["\\d", "X", "a1b2c3"]
  method: __getitem__
  method_args: [0]
  expected: "aXbXcX"

invariant re_extra19.subn.getitem_count:
  description: "re.subn(r'\\d', 'X', 'a1b2c3').__getitem__(1) == 3 — tuple index 1 (count) via __getitem__"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["\\d", "X", "a1b2c3"]
  method: __getitem__
  method_args: [1]
  expected: 3

invariant re_extra19.subn.whitespace_count:
  description: "re.subn(r'\\s+', '-', 'a b c').__getitem__(1) == 2 — two whitespace runs replaced"
  category: subn
  kind: python_call_eq
  function: subn
  args: ["\\s+", "-", "a b c"]
  method: __getitem__
  method_args: [1]
  expected: 2

# ---------------------------------------------------------------------------
# re.sub and re.subn — function identity anchors in re_extra19 namespace
#
# re_extra4 covers sub.__name__ and subn.__name__ as standalone invariants.
# re_extra5 covers both in a table. re_extra4/re_extra6 cover sub.__module__.
# These are namespace anchors for re_extra19.
# ---------------------------------------------------------------------------

invariant re_extra19.sub.name:
  description: "re.sub.__name__ == 'sub' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: sub.__name__.__eq__
  args: ["sub"]
  expected: true

invariant re_extra19.subn.name:
  description: "re.subn.__name__ == 'subn' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: subn.__name__.__eq__
  args: ["subn"]
  expected: true

invariant re_extra19.sub.module:
  description: "re.sub.__module__ == 're' — namespace anchor"
  category: function_identity
  kind: python_call_eq
  function: sub.__module__.__eq__
  args: ["re"]
  expected: true

# ---------------------------------------------------------------------------
# Table: re.subn — __getitem__ access on result tuple
#
# Groups the three subn __getitem__ vectors in one indexed table.
# No prior spec groups subn __getitem__ calls for different patterns together.
# ---------------------------------------------------------------------------

table re_extra19.subn_getitem:
  description: "re.subn tuple element access via __getitem__ — string and count extraction"
  kind: python_call_eq
  category: subn
  id_prefix: sgi

  columns: [id, function, args, method, method_args, expected]
  rows:
    - [digit_string, subn, ["\\d",  "X", "a1b2c3"], __getitem__, [0], "aXbXcX"]
    - [digit_count,  subn, ["\\d",  "X", "a1b2c3"], __getitem__, [1], 3]
    - [space_count,  subn, ["\\s+", "-", "a b c"],  __getitem__, [1], 2]
