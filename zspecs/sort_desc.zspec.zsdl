spec: sort_desc
version: ">=0.2.0"
backend: node(sort-desc)

docs: https://www.npmjs.com/package/sort-desc

provenance:
  derived_from:
    - "sort-desc README — https://www.npmjs.com/package/sort-desc"
    - "Test vectors verified with sort-desc via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "sort-desc source"
  notes:
    - "sort-desc is an npm package. Install: npm install sort-desc"
    - "String comparator function for descending sort. Returns -1, 0, or 1."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns -1, 0, or 1."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table sort_desc.compare:
  kind: node_module_call_eq
  function: ~
  category: array
  id_prefix: sortdsc

  columns: [id, args, expected]
  rows:
    - [greater_first,  ["banana", "apple"],  -1]
    - [lesser_second,  ["apple", "banana"],  1]
    - [equal,          ["a", "a"],           0]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-05T00:07:46Z
  iterations: 1
  pass_count: 3
  fail_count: 0
  total_invariants: 3
  notes: Synthesis succeeded in 1 iteration(s). 3 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
