spec: ipaddress_extra2
version: ">=3.3"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "RFC 791 — Internet Protocol (IPv4), September 1981"
    - "RFC 2460 — Internet Protocol, Version 6 (IPv6), December 1998"
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
    - "ipaddress.zspec.zsdl — covers IPv4/IPv6 address attributes and error cases"
    - "ipaddress_extra.zspec.zsdl — covers class names, module checks, packed bytes, is_private, factory return types"
  notes:
    - "This spec extends ipaddress.zspec.zsdl and ipaddress_extra.zspec.zsdl."
    - "ipaddress.IPv4Address.__name__ == 'IPv4Address' — class name attribute."
    - "ipaddress.IPv6Address.__name__ == 'IPv6Address' — class name attribute."
    - "ipaddress.IPv4Network.__name__ == 'IPv4Network' — class name attribute."
    - "ipaddress.IPv6Network.__name__ == 'IPv6Network' — class name attribute."
    - "ipaddress.ip_address.__name__ == 'ip_address' — factory function name."
    - "ipaddress.ip_network.__name__ == 'ip_network' — factory function name."
    - "ipaddress.ip_interface.__name__ == 'ip_interface' — factory function name."
    - "IPv4Address('127.0.0.1').__class__.__name__ == 'IPv4Address' — loopback address type."
    - "IPv4Address('127.0.0.1').packed.__class__.__name__ == 'bytes' — packed is a bytes object."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __name__ attributes — IPv4Address, IPv6Address, IPv4Network, IPv6Network
# ---------------------------------------------------------------------------

table ipaddress_extra2.class_names:
  kind: python_call_eq
  category: class_names
  id_prefix: cname

  columns: [id, description, function, args, expected]
  rows:
    - [IPv4Address,  "IPv4Address.__name__ == 'IPv4Address'",  IPv4Address.__name__.__eq__,  ["IPv4Address"],  true]
    - [IPv6Address,  "IPv6Address.__name__ == 'IPv6Address'",  IPv6Address.__name__.__eq__,  ["IPv6Address"],  true]
    - [IPv4Network,  "IPv4Network.__name__ == 'IPv4Network'",  IPv4Network.__name__.__eq__,  ["IPv4Network"],  true]
    - [IPv6Network,  "IPv6Network.__name__ == 'IPv6Network'",  IPv6Network.__name__.__eq__,  ["IPv6Network"],  true]

# ---------------------------------------------------------------------------
# Factory function __name__ attributes
# ---------------------------------------------------------------------------

table ipaddress_extra2.factory_names:
  kind: python_call_eq
  category: factory_names
  id_prefix: fname

  columns: [id, description, function, args, expected]
  rows:
    - [ip_address,    "ip_address.__name__ == 'ip_address'",     ip_address.__name__.__eq__,    ["ip_address"],    true]
    - [ip_network,    "ip_network.__name__ == 'ip_network'",     ip_network.__name__.__eq__,    ["ip_network"],    true]
    - [ip_interface,  "ip_interface.__name__ == 'ip_interface'", ip_interface.__name__.__eq__,  ["ip_interface"],  true]

# ---------------------------------------------------------------------------
# IPv4Address('127.0.0.1') — instance type and packed attribute type
# ---------------------------------------------------------------------------

invariant ipaddress_extra2.IPv4Address.loopback_class:
  description: "IPv4Address('127.0.0.1').__class__.__name__ == 'IPv4Address'"
  category: IPv4Address
  kind: python_call_eq
  function: IPv4Address
  args: ["127.0.0.1"]
  method: __class__.__name__.__eq__
  method_args: ["IPv4Address"]
  expected: true

invariant ipaddress_extra2.IPv4Address.packed_is_bytes:
  description: "IPv4Address('127.0.0.1').packed.__class__.__name__ == 'bytes'"
  category: IPv4Address
  kind: python_call_eq
  function: IPv4Address
  args: ["127.0.0.1"]
  method: packed
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["bytes"]
  expected: true
