spec: socket_extra706
version: ">=3.9"
backend: python_module(socket)
docs: https://docs.python.org/3/library/socket.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Covers socket module-level function qualnames and socket class attributes"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table socket_extra706.qualnames:
  description: "socket module-level function and socket class qualname and module attribute checks"
  kind: python_call_eq
  category: qualnames
  id_prefix: sk706qn
  columns: [id, function, args, expected]
  rows:
    - [sk706qn001, socket.socket.__qualname__.__eq__, ["socket"], true]
    - [sk706qn002, socket.socket.__module__.__eq__, ["socket"], true]
    - [sk706qn003, socket.socket.__doc__.__class__.__name__.__eq__, ["str"], true]
    - [sk706qn004, socket.getaddrinfo.__qualname__.__eq__, ["getaddrinfo"], true]
    - [sk706qn005, socket.getaddrinfo.__module__.__eq__, ["socket"], true]
    - [sk706qn006, socket.gethostname.__qualname__.__eq__, ["gethostname"], true]
    - [sk706qn007, socket.gethostbyname.__qualname__.__eq__, ["gethostbyname"], true]
    - [sk706qn008, socket.getnameinfo.__qualname__.__eq__, ["getnameinfo"], true]
    - [sk706qn009, socket.setdefaulttimeout.__qualname__.__eq__, ["setdefaulttimeout"], true]
    - [sk706qn010, socket.getdefaulttimeout.__qualname__.__eq__, ["getdefaulttimeout"], true]
    - [sk706qn011, socket.create_connection.__qualname__.__eq__, ["create_connection"], true]
    - [sk706qn012, socket.create_server.__qualname__.__eq__, ["create_server"], true]
