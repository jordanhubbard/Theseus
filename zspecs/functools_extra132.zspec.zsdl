spec: functools_extra132
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — Python functools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/functools.py"
    - "CPython source: Modules/_functoolsmodule.c"
  notes:
    - "This spec covers: functools.cached_property class identity and MRO; functools.total_ordering code object attributes (Wave 259)."
    - "functools.cached_property.__name__ == 'cached_property' — cached_property is a pure-Python class. Verified with Python 3.14.3."
    - "functools.cached_property.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits directly from object. Verified with Python 3.14.3."
    - "len(functools.cached_property.__mro__) == 2 — MRO is [cached_property, object]. Verified with Python 3.14.3."
    - "functools.cached_property.__class__.__name__ == 'type' — cached_property is a class whose metaclass is type. Verified with Python 3.14.3."
    - "functools.cached_property.__qualname__ == 'cached_property' (len 15). Verified with Python 3.14.3."
    - "functools.total_ordering.__class__.__name__ == 'function' — total_ordering is a plain Python function (decorator factory). Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_name == 'total_ordering'. Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_argcount == 1 — takes a single argument cls. Verified with Python 3.14.3."
    - "functools.total_ordering.__code__.co_varnames[0] == 'cls' — first parameter is cls. Verified with Python 3.14.3."
    - "len(functools.total_ordering.__code__.co_varnames) == 6 — co_varnames: cls, op, roots, root, opname, opfunc. Verified with Python 3.14.3."
    - "functools.total_ordering.__module__ == 'functools'. Verified with Python 3.14.3."
    - "functools.total_ordering.__qualname__ == 'total_ordering' (len 14). Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: functools.cached_property class identity
#
# Wave 259 theme: functools.cached_property class identity attributes.
#
# functools.cached_property.__name__.__eq__('cached_property') == True
# functools.cached_property.__module__.__eq__('functools') == True
# functools.cached_property.__bases__[0].__name__.__eq__('object') == True
# functools.cached_property.__mro__.__len__() == 2
# functools.cached_property.__class__.__name__.__eq__('type') == True
# functools.cached_property.__qualname__.__len__() == 15
#
# cached_property is a pure-Python class defined in Lib/functools.py that
# implements a cached property descriptor. It inherits directly from object;
# MRO is [cached_property, object] (length 2). New to extra132.
# ---------------------------------------------------------------------------

table functools_extra132.cached_property_identity:
  description: "functools.cached_property class identity: __name__, __module__, __bases__[0], MRO len, __class__.__name__, __qualname__ len; wave 259; new to extra132"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolscachedprop132

  columns: [id, function, args, expected, description]
  rows:
    - [cached_property_name_eq,
       "cached_property.__name__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__name__.__eq__('cached_property') == True — cached_property is a pure-Python class defined with 'class cached_property:' in Lib/functools.py; its __name__ is 'cached_property'; str.__eq__('cached_property') returns True; new to extra132"]
    - [cached_property_module_eq_functools,
       "cached_property.__module__.__eq__",
       ["functools"],
       true,
       "functools.cached_property.__module__.__eq__('functools') == True — cached_property is defined in Lib/functools.py; __module__ is 'functools'; str.__eq__('functools') returns True; new to extra132"]
    - [cached_property_bases_first_eq_object,
       "cached_property.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "functools.cached_property.__bases__[0].__name__.__eq__('object') == True — cached_property inherits directly from object with no intermediate base; __bases__[0].__name__ is 'object'; str.__eq__('object') returns True; new to extra132"]
    - [cached_property_mro_len_eq_2,
       "cached_property.__mro__.__len__",
       [],
       2,
       "functools.cached_property.__mro__.__len__() == 2 — the MRO of cached_property is [cached_property, object]; it has exactly two entries; len(__mro__) is 2; new to extra132"]
    - [cached_property_class_name_eq_type,
       "cached_property.__class__.__name__.__eq__",
       ["type"],
       true,
       "functools.cached_property.__class__.__name__.__eq__('type') == True — cached_property is a Python class; its metaclass is the built-in type; __class__.__name__ is 'type'; str.__eq__('type') returns True; new to extra132"]
    - [cached_property_qualname_len_eq_15,
       "cached_property.__qualname__.__len__",
       [],
       15,
       "functools.cached_property.__qualname__.__len__() == 15 — __qualname__ is 'cached_property' which has 15 characters; cached_property is defined at module scope so qualname equals the class name; len('cached_property') == 15; new to extra132"]

# ---------------------------------------------------------------------------
# Table 2: functools.total_ordering code object attributes
#
# Wave 259 theme: functools.total_ordering code object identity.
#
# functools.total_ordering.__class__.__name__.__eq__('function') == True
# functools.total_ordering.__code__.co_name.__eq__('total_ordering') == True
# functools.total_ordering.__code__.co_argcount.__eq__(1) == True
# functools.total_ordering.__code__.co_varnames[0].__eq__('cls') == True
# functools.total_ordering.__code__.co_varnames.__len__() == 6
#
# total_ordering is a pure-Python decorator that fills in missing comparison
# methods given __eq__ and one of __lt__/__le__/__gt__/__ge__. It takes a
# single argument cls. co_varnames includes cls, op, roots, root, opname, opfunc.
# New to extra132.
# ---------------------------------------------------------------------------

table functools_extra132.total_ordering_code_attrs:
  description: "functools.total_ordering code object: __class__.__name__=='function', co_name, co_argcount==1, co_varnames[0]=='cls', co_varnames len==6; wave 259; new to extra132"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolstotalorder132

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_class_name_eq_function,
       "total_ordering.__class__.__name__.__eq__",
       ["function"],
       true,
       "functools.total_ordering.__class__.__name__.__eq__('function') == True — total_ordering is a plain Python decorator factory function defined with 'def total_ordering(cls):' in Lib/functools.py; __class__.__name__ is 'function'; str.__eq__('function') returns True; new to extra132"]
    - [total_ordering_co_name_eq,
       "total_ordering.__code__.co_name.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__code__.co_name.__eq__('total_ordering') == True — co_name reflects the name from the def statement; the function is named 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra132"]
    - [total_ordering_co_argcount_eq_1,
       "total_ordering.__code__.co_argcount.__eq__",
       [1],
       true,
       "functools.total_ordering.__code__.co_argcount.__eq__(1) == True — total_ordering takes a single positional argument cls (the class to decorate); co_argcount is 1; int.__eq__(1) returns True; new to extra132"]
    - [total_ordering_co_varnames_0_eq_cls,
       "total_ordering.__code__.co_varnames[0].__eq__",
       ["cls"],
       true,
       "functools.total_ordering.__code__.co_varnames[0].__eq__('cls') == True — the first entry in co_varnames is the parameter name 'cls'; co_varnames lists parameters followed by local variables; str.__eq__('cls') returns True; new to extra132"]
    - [total_ordering_co_varnames_len_eq_6,
       "total_ordering.__code__.co_varnames.__len__",
       [],
       6,
       "functools.total_ordering.__code__.co_varnames.__len__() == 6 — co_varnames contains cls, op, roots, root, opname, opfunc (the parameter plus five local variables); len(co_varnames) is 6; new to extra132"]

# ---------------------------------------------------------------------------
# Table 3: functools.total_ordering module and qualname
#
# Wave 259 theme: functools.total_ordering module and qualname identity.
#
# functools.total_ordering.__module__.__eq__('functools') == True
# functools.total_ordering.__qualname__.__eq__('total_ordering') == True
# functools.total_ordering.__qualname__.__len__() == 14
#
# total_ordering is defined at module scope in Lib/functools.py;
# __module__ is 'functools'; __qualname__ is the simple function name (len 14).
# New to extra132.
# ---------------------------------------------------------------------------

table functools_extra132.total_ordering_module_qualname:
  description: "functools.total_ordering __module__=='functools', __qualname__=='total_ordering' (len 14); module-scope decorator factory; wave 259; new to extra132"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolstotalorder132

  columns: [id, function, args, expected, description]
  rows:
    - [total_ordering_module_eq_functools,
       "total_ordering.__module__.__eq__",
       ["functools"],
       true,
       "functools.total_ordering.__module__.__eq__('functools') == True — total_ordering is defined in Lib/functools.py; its __module__ attribute is 'functools'; str.__eq__('functools') returns True; new to extra132"]
    - [total_ordering_qualname_eq,
       "total_ordering.__qualname__.__eq__",
       ["total_ordering"],
       true,
       "functools.total_ordering.__qualname__.__eq__('total_ordering') == True — total_ordering is defined at module scope; __qualname__ equals the simple function name 'total_ordering'; str.__eq__('total_ordering') returns True; new to extra132"]
    - [total_ordering_qualname_len_eq_14,
       "total_ordering.__qualname__.__len__",
       [],
       14,
       "functools.total_ordering.__qualname__.__len__() == 14 — __qualname__ is 'total_ordering' which has 14 characters; len('total_ordering') == 14; new to extra132"]
    - [cached_property_name_len_eq_15,
       "cached_property.__name__.__len__",
       [],
       15,
       "functools.cached_property.__name__.__len__() == 15 — __name__ is 'cached_property' which has 15 characters; len('cached_property') == 15; new to extra132"]
    - [cached_property_qualname_eq,
       "cached_property.__qualname__.__eq__",
       ["cached_property"],
       true,
       "functools.cached_property.__qualname__.__eq__('cached_property') == True — cached_property is defined at module scope; __qualname__ equals the class name 'cached_property'; str.__eq__('cached_property') returns True; new to extra132"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra132
# ---------------------------------------------------------------------------

invariant functools_extra132.cached_property_name:
  description: "functools.cached_property.__name__ == 'cached_property' — pure-Python descriptor class in Lib/functools.py; wave 259; new to extra132"
  kind: python_call_eq
  function: cached_property.__name__.__eq__
  args: ["cached_property"]
  expected: true

invariant functools_extra132.cached_property_mro_len:
  description: "len(functools.cached_property.__mro__) == 2 — MRO is [cached_property, object]; wave 259; new to extra132"
  kind: python_call_eq
  function: cached_property.__mro__.__len__
  args: []
  expected: 2

invariant functools_extra132.total_ordering_co_argcount:
  description: "functools.total_ordering.__code__.co_argcount == 1 — takes single argument cls; wave 259; new to extra132"
  kind: python_call_eq
  function: total_ordering.__code__.co_argcount.__eq__
  args: [1]
  expected: true

invariant functools_extra132.total_ordering_co_varnames_0:
  description: "functools.total_ordering.__code__.co_varnames[0] == 'cls' — first parameter is cls; wave 259; new to extra132"
  kind: python_call_eq
  function: total_ordering.__code__.co_varnames[0].__eq__
  args: ["cls"]
  expected: true

invariant functools_extra132.cached_property_bases_object:
  description: "functools.cached_property.__bases__[0].__name__ == 'object' — cached_property inherits directly from object; wave 259; new to extra132"
  kind: python_call_eq
  function: cached_property.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true
