spec: abc_extra264
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.Container, Sized, Hashable each inherit directly from object."
    - "collections.abc.Awaitable inherits from object; its sole abstract method is __await__."
    - "collections.abc.Coroutine inherits from Awaitable; abstract methods: __await__, send, throw."
    - "collections.abc.AsyncIterable inherits from object; abstract method: __aiter__."
    - "collections.abc.AsyncIterator inherits from AsyncIterable; abstract method: __anext__."
    - "collections.abc.AsyncGenerator inherits from AsyncIterator; abstract methods: asend, athrow."
    - "All __module__ values == 'collections.abc' (exposed under the public alias, not '_collections_abc')."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Container, Sized, Hashable __name__ and __module__ — table
#
# Three basic container ABCs that each inherit directly from object.
# ---------------------------------------------------------------------------

table abc_extra264.basic_container_identity:
  description: "collections.abc Container, Sized, Hashable report expected __name__ and __module__"
  kind: python_call_eq
  category: identity
  id_prefix: basicabc

  columns: [id, function, args, expected, description]
  rows:
    - [container_name,   collections.abc.Container.__name__.__eq__,   ["Container"],      true, "collections.abc.Container.__name__ == 'Container'"]
    - [container_mod,    collections.abc.Container.__module__.__eq__,  ["collections.abc"], true, "collections.abc.Container.__module__ == 'collections.abc'"]
    - [sized_name,       collections.abc.Sized.__name__.__eq__,        ["Sized"],           true, "collections.abc.Sized.__name__ == 'Sized'"]
    - [sized_mod,        collections.abc.Sized.__module__.__eq__,      ["collections.abc"], true, "collections.abc.Sized.__module__ == 'collections.abc'"]
    - [hashable_name,    collections.abc.Hashable.__name__.__eq__,     ["Hashable"],        true, "collections.abc.Hashable.__name__ == 'Hashable'"]

# ---------------------------------------------------------------------------
# Async ABC __name__ and __module__ — table
#
# Five async ABCs: Awaitable, Coroutine, AsyncIterable, AsyncIterator,
# AsyncGenerator. All report __module__ == 'collections.abc'.
# ---------------------------------------------------------------------------

table abc_extra264.async_abc_identity:
  description: "collections.abc async ABCs report expected __name__ and __module__"
  kind: python_call_eq
  category: identity
  id_prefix: asyncabc

  columns: [id, function, args, expected, description]
  rows:
    - [awaitable_name,      collections.abc.Awaitable.__name__.__eq__,      ["Awaitable"],      true, "collections.abc.Awaitable.__name__ == 'Awaitable'"]
    - [awaitable_mod,       collections.abc.Awaitable.__module__.__eq__,    ["collections.abc"], true, "collections.abc.Awaitable.__module__ == 'collections.abc'"]
    - [coroutine_name,      collections.abc.Coroutine.__name__.__eq__,      ["Coroutine"],       true, "collections.abc.Coroutine.__name__ == 'Coroutine'"]
    - [asynciterable_name,  collections.abc.AsyncIterable.__name__.__eq__,  ["AsyncIterable"],   true, "collections.abc.AsyncIterable.__name__ == 'AsyncIterable'"]
    - [asynciterator_name,  collections.abc.AsyncIterator.__name__.__eq__,  ["AsyncIterator"],   true, "collections.abc.AsyncIterator.__name__ == 'AsyncIterator'"]

# ---------------------------------------------------------------------------
# Base class chain for async ABCs — standalone invariants
# ---------------------------------------------------------------------------

invariant abc_extra264.Container.bases0_name:
  description: "collections.abc.Container.__bases__[0].__name__ == 'object'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Container.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant abc_extra264.Coroutine.bases0_name:
  description: "collections.abc.Coroutine.__bases__[0].__name__ == 'Awaitable'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.Coroutine.__bases__[0].__name__.__eq__"
  args: ["Awaitable"]
  expected: true

invariant abc_extra264.AsyncIterator.bases0_name:
  description: "collections.abc.AsyncIterator.__bases__[0].__name__ == 'AsyncIterable'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.AsyncIterator.__bases__[0].__name__.__eq__"
  args: ["AsyncIterable"]
  expected: true

invariant abc_extra264.AsyncGenerator.name:
  description: "collections.abc.AsyncGenerator.__name__ == 'AsyncGenerator'"
  category: identity
  kind: python_call_eq
  function: collections.abc.AsyncGenerator.__name__.__eq__
  args: ["AsyncGenerator"]
  expected: true

invariant abc_extra264.AsyncGenerator.bases0_name:
  description: "collections.abc.AsyncGenerator.__bases__[0].__name__ == 'AsyncIterator'"
  category: identity
  kind: python_call_eq
  function: "collections.abc.AsyncGenerator.__bases__[0].__name__.__eq__"
  args: ["AsyncIterator"]
  expected: true
