    - ["mp3271021",  operator.contains, [multiprocessing.managers.SyncManager.__dict__,    "__rxor__"], false]
    - ["mp3271022",  operator.contains, [multiprocessing.managers.BaseListProxy.__dict__,  "__rxor__"], false]
    - ["mp3271023",  operator.contains, [multiprocessing.managers._BaseDictProxy.__dict__, "__rxor__"], false]
    - ["mp3271024",  operator.contains, [multiprocessing.managers._BaseSetProxy.__dict__,  "__rxor__"], false]

# ---------------------------------------------------------------------------
# combined — __rand__, __ror__, __rxor__ across all 8 mp subjects
#
# Covers the full matrix: 8 classes x 3 methods = 24 rows.
# __rand__: false for all 8 — not in any type's own __dict__.
# __ror__: false for all 8 — not in any type's own __dict__.
# __rxor__: false for all 8 — not in any type's own __dict__.
# All 24 values are false.
# _BaseSetProxy asymmetry — the central finding of this wave:
#   Wave 661: _BaseSetProxy.__and__ = false (proxy does not forward __and__).
#   Wave 661: _BaseSetProxy.__or__ = false (proxy does not forward __or__).
#   Wave 661: _BaseSetProxy.__xor__ = false (proxy does not forward __xor__).
#   Wave 665: _BaseSetProxy.__rand__ = false (set does not define __rand__).
#   Wave 665: _BaseSetProxy.__ror__ = false (set does not define __ror__).
#   Wave 665: _BaseSetProxy.__rxor__ = false (set does not define __rxor__).
#   set defines __and__/__or__/__xor__ as symmetric intersection/union/
#   symmetric-difference operators, but Python's set type has never defined
#   the reflected variants __rand__/__ror__/__rxor__. Set operations are
#   symmetric in practice (s & t == t & s for sets) but this symmetry is
#   implemented by both operands defining the forward operator, not through
#   Python's reflected operator dispatch mechanism.
# _BaseDictProxy and __ror__: Python 3.9+ dict defines __ror__ for PEP 584
#   merge (d2 | d1 where d2 is not a dict). _BaseDictProxy does NOT forward
#   __ror__ because multiprocessing proxies only forward methods explicitly
#   registered through the proxy's method list — operator dunders are not
#   automatically proxied through the IPC callthrough mechanism.
# BaseListProxy across waves:
#   Wave 658: BaseListProxy.__add__ = true, BaseListProxy.__mul__ = true.
#   Waves 662–665: all reflected operators false (list has no __radd__,
#   __rmul__, __rand__, __ror__, __rxor__, etc.).
# multiprocessing is a process-based concurrency library; its types interact
#   exclusively through explicit method calls, subprocess lifecycle management,
#   and IPC — never through Python's reflected bitwise logical operators.
# ---------------------------------------------------------------------------

