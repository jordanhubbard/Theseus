spec: pathlib_extra15
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — Python pathlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
  notes:
    - "This spec extends pathlib.zspec.zsdl through pathlib_extra14.zspec.zsdl."
    - "pathlib_extra14 covers PurePosixPath stem (plain/single/multi ext), suffix_txt, suffix_gz, suffixes_multi/none, name_with_ext, parent_str, parts_tuple, root_absolute/relative, drive_absolute."
    - "pathlib_extra13 covers PurePosixPath stem_no_suffix, drive_empty, anchor_relative, parts_relative_len, joinpath_absolute_reset, relative_to_two_levels, name_bare_file, truediv_simple, suffix_access table."
    - "pathlib_extra12 covers parts.__len__, parts[0], parents.__len__, with_suffix strip/add, joinpath single/multi, match wildcard true/false, suffixes.__len__, suffixes[0]."
    - "NOT yet covered: pathlib.PurePath.__module__ == 'pathlib' as a standalone invariant."
    - "NOT yet covered: pathlib.PurePosixPath.__module__ == 'pathlib' as a standalone invariant."
    - "NOT yet covered: pathlib.PureWindowsPath.__module__ == 'pathlib' as a standalone invariant."
    - "NOT yet covered: pathlib.Path.__module__ == 'pathlib' as a standalone invariant."
    - "NOT yet covered: pathlib.PosixPath.__module__ == 'pathlib' as a standalone invariant."
    - "NOT yet covered: pathlib.WindowsPath.__module__ == 'pathlib' as a standalone invariant."
    - "NOT yet covered: pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath'."
    - "NOT yet covered: pathlib.PosixPath.__bases__[0].__name__ == 'Path'."
    - "NOT yet covered: pathlib.PurePath.__name__ == 'PurePath' as a standalone invariant."
    - "NOT yet covered: pathlib.Path.__name__ == 'Path' as a standalone invariant."
    - "NOT yet covered: pathlib.PurePosixPath('/a/b').__str__() == '/a/b' as a standalone invariant."
    - "NOT yet covered: pathlib.PurePosixPath('/a/b').__repr__().__class__.__name__ == 'str'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class __module__ attributes — all six public pathlib classes
#
# All pathlib classes are defined in the pathlib module. No prior spec records
# __module__ for any pathlib class as a standalone invariant.
# ---------------------------------------------------------------------------

invariant pathlib_extra15.PurePath.module:
  description: "pathlib.PurePath.__module__ == 'pathlib'"
  category: class_modules
  kind: python_call_eq
  function: PurePath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra15.PurePosixPath.module:
  description: "pathlib.PurePosixPath.__module__ == 'pathlib'"
  category: class_modules
  kind: python_call_eq
  function: PurePosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra15.PureWindowsPath.module:
  description: "pathlib.PureWindowsPath.__module__ == 'pathlib'"
  category: class_modules
  kind: python_call_eq
  function: PureWindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra15.Path.module:
  description: "pathlib.Path.__module__ == 'pathlib'"
  category: class_modules
  kind: python_call_eq
  function: Path.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra15.PosixPath.module:
  description: "pathlib.PosixPath.__module__ == 'pathlib'"
  category: class_modules
  kind: python_call_eq
  function: PosixPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

invariant pathlib_extra15.WindowsPath.module:
  description: "pathlib.WindowsPath.__module__ == 'pathlib'"
  category: class_modules
  kind: python_call_eq
  function: WindowsPath.__module__.__eq__
  args: ["pathlib"]
  expected: true

# ---------------------------------------------------------------------------
# Class __name__ attributes — PurePath and Path
#
# No prior spec checks PurePath.__name__ or Path.__name__ as standalone
# invariants. (Prior specs check instance-level attributes only.)
# ---------------------------------------------------------------------------

invariant pathlib_extra15.PurePath.name_attr:
  description: "pathlib.PurePath.__name__ == 'PurePath'"
  category: class_names
  kind: python_call_eq
  function: PurePath.__name__.__eq__
  args: ["PurePath"]
  expected: true

invariant pathlib_extra15.Path.name_attr:
  description: "pathlib.Path.__name__ == 'Path'"
  category: class_names
  kind: python_call_eq
  function: Path.__name__.__eq__
  args: ["Path"]
  expected: true

# ---------------------------------------------------------------------------
# Class inheritance — __bases__[0].__name__
#
# PurePosixPath extends PurePath; PosixPath extends Path. No prior spec
# verifies the immediate base class name for either of these classes.
# ---------------------------------------------------------------------------

invariant pathlib_extra15.PurePosixPath.base_is_PurePath:
  description: "pathlib.PurePosixPath.__bases__[0].__name__ == 'PurePath'"
  category: hierarchy
  kind: python_call_eq
  function: PurePosixPath.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "PurePath"

invariant pathlib_extra15.PosixPath.base_is_Path:
  description: "pathlib.PosixPath.__bases__[0].__name__ == 'Path'"
  category: hierarchy
  kind: python_call_eq
  function: PosixPath.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Path"

# ---------------------------------------------------------------------------
# PurePosixPath instance string representation
#
# No prior spec checks that str(PurePosixPath('/a/b')) returns the path string
# as a standalone invariant using __str__ called directly via method chain.
# ---------------------------------------------------------------------------

invariant pathlib_extra15.PurePosixPath.str_repr:
  description: "str(pathlib.PurePosixPath('/a/b')) == '/a/b'"
  category: string_repr
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b"]
  method: __str__
  expected: "/a/b"

# ---------------------------------------------------------------------------
# PurePosixPath instance repr — class name of result
#
# No prior spec checks that repr() of a PurePosixPath instance returns a str.
# We verify __repr__().__class__.__name__ == 'str' via method chain.
# ---------------------------------------------------------------------------

invariant pathlib_extra15.PurePosixPath.repr_class_name:
  description: "pathlib.PurePosixPath('/a/b').__repr__().__class__.__name__ == 'str'"
  category: string_repr
  kind: python_call_eq
  function: PurePosixPath
  args: ["/a/b"]
  method: __repr__
  method_chain: __class__.__name__.__eq__
  method_chain_args: ["str"]
  expected: true
