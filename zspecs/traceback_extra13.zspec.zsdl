spec: traceback_extra13
version: ">=3.9"
backend: python_module(traceback)

docs: https://docs.python.org/3/library/traceback.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/traceback.html — Python traceback module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/traceback.py"
  notes:
    - "This spec extends traceback.zspec.zsdl through traceback_extra12.zspec.zsdl."
    - "Prior specs cover: __name__/__qualname__/__module__ for print_exc/print_tb/format_exc/format_tb/extract_tb/extract_stack/walk_tb/walk_stack/clear_frames/format_exception/print_exception/format_list/print_list/format_exception_only/format_stack/print_stack; TracebackException/__name__/__qualname__/__module__/__bases__/__mro__; StackSummary/__name__/__qualname__/__module__/__bases__/__mro__; FrameSummary/__name__/__qualname__/__module__/__bases__/__mro__."
    - "This spec covers: __class__.__name__ == 'function' for the 8 primary traceback module-level functions (print_exc, print_tb, format_exc, format_tb, extract_tb, extract_stack, walk_tb, walk_stack) plus 8 additional functions (clear_frames, format_exception, print_exception, format_list, print_list, format_exception_only, format_stack, print_stack)."
    - "No prior traceback spec records __class__.__name__ for any module-level function."
    - "All traceback module-level functions are regular Python functions, so __class__.__name__ == 'function'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Primary traceback functions — __class__.__name__
#
# No prior traceback spec records __class__.__name__ for any module-level
# function. All are ordinary Python functions, so the value is 'function'.
# ---------------------------------------------------------------------------

table traceback_extra13.primary_function_class_names:
  description: "__class__.__name__ == 'function' for primary traceback module-level functions"
  kind: python_call_eq
  category: function_class_names

  columns: [id, function, args, expected]
  rows:
    - [print_exc,    print_exc.__class__.__name__.__eq__,    ["function"], true]
    - [print_tb,     print_tb.__class__.__name__.__eq__,     ["function"], true]
    - [format_exc,   format_exc.__class__.__name__.__eq__,   ["function"], true]
    - [format_tb,    format_tb.__class__.__name__.__eq__,    ["function"], true]
    - [extract_tb,   extract_tb.__class__.__name__.__eq__,   ["function"], true]
    - [extract_stack, extract_stack.__class__.__name__.__eq__, ["function"], true]
    - [walk_tb,      walk_tb.__class__.__name__.__eq__,      ["function"], true]
    - [walk_stack,   walk_stack.__class__.__name__.__eq__,   ["function"], true]

# ---------------------------------------------------------------------------
# Additional traceback functions — __class__.__name__
#
# Same pattern applied to the remaining public module-level functions not
# covered by the primary table above.
# ---------------------------------------------------------------------------

table traceback_extra13.additional_function_class_names:
  description: "__class__.__name__ == 'function' for additional traceback module-level functions"
  kind: python_call_eq
  category: function_class_names

  columns: [id, function, args, expected]
  rows:
    - [clear_frames,         clear_frames.__class__.__name__.__eq__,         ["function"], true]
    - [format_exception,     format_exception.__class__.__name__.__eq__,     ["function"], true]
    - [print_exception,      print_exception.__class__.__name__.__eq__,      ["function"], true]
    - [format_list,          format_list.__class__.__name__.__eq__,          ["function"], true]
    - [print_list,           print_list.__class__.__name__.__eq__,           ["function"], true]
    - [format_exception_only, format_exception_only.__class__.__name__.__eq__, ["function"], true]
    - [format_stack,         format_stack.__class__.__name__.__eq__,         ["function"], true]
    - [print_stack,          print_stack.__class__.__name__.__eq__,          ["function"], true]
