spec: theseus_resource_cr
version: ">=3.8"
backend: python_cleanroom(theseus_resource_cr)
blocks: resource

docs: https://docs.python.org/3/library/resource.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/resource.html"
  not_derived_from:
    - "CPython source: Modules/resource.c"
  notes:
    - "Clean-room resource module. Do NOT import resource."

error_model: python_exceptions

invariant theseus_resource_cr.resource2_getrlimit:
  description: "getrlimit(RLIMIT_NOFILE) returns a 2-tuple"
  category: behavior
  kind: python_call_eq
  function: resource2_getrlimit
  args: []
  expected: true

invariant theseus_resource_cr.resource2_constants:
  description: "RLIMIT_NOFILE and RLIM_INFINITY constants are ints"
  category: behavior
  kind: python_call_eq
  function: resource2_constants
  args: []
  expected: true

invariant theseus_resource_cr.resource2_getrusage:
  description: "getrusage(RUSAGE_SELF) returns a struct_rusage"
  category: behavior
  kind: python_call_eq
  function: resource2_getrusage
  args: []
  expected: true
