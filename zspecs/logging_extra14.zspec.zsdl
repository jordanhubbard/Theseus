spec: logging_extra14
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
  notes:
    - "This spec extends logging.zspec.zsdl through logging_extra13.zspec.zsdl."
    - "logging_extra13 covers: CRITICAL/ERROR/WARNING/INFO/DEBUG/NOTSET level constants; getLevelName(10)=='DEBUG'; getLogger/basicConfig/disable/captureWarnings __name__."
    - "logging_extra12 covers: MRO lengths for NullHandler/Filter/LogRecord/Filterer/FileHandler; NullHandler base class; getLevelName str->int for INFO/WARNING/ERROR/CRITICAL/NOTSET."
    - "NOT yet covered: logging.Logger.__qualname__ == 'Logger' as a standalone invariant."
    - "NOT yet covered: logging.Handler.__qualname__; logging.Formatter.__qualname__; logging.Filter.__qualname__."
    - "NOT yet covered: logging.LogRecord.__qualname__; logging.StreamHandler.__qualname__; logging.FileHandler.__qualname__; logging.NullHandler.__qualname__."
    - "NOT yet covered: logging.Logger.__module__; logging.Handler.__module__; logging.Formatter.__module__."
    - "logging.Logger.__qualname__ == 'Logger' — class defined at module level in logging/__init__.py."
    - "logging.StreamHandler.__qualname__ == 'StreamHandler' — subclass of Handler at module level."
    - "logging.FileHandler.__qualname__ == 'FileHandler' — subclass of StreamHandler at module level."
    - "logging.NullHandler.__qualname__ == 'NullHandler' — subclass of Handler at module level."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __qualname__ for Logger, Handler, Formatter, Filter, LogRecord
#
# No prior logging spec records __qualname__ for these core classes as
# standalone boolean __eq__ invariants. All are defined at module scope in
# logging/__init__.py so __qualname__ matches the class name.
# ---------------------------------------------------------------------------

invariant logging_extra14.Logger.qualname:
  description: "logging.Logger.__qualname__ == 'Logger'"
  category: class_qualnames
  kind: python_call_eq
  function: Logger.__qualname__.__eq__
  args: ["Logger"]
  expected: true

invariant logging_extra14.Handler.qualname:
  description: "logging.Handler.__qualname__ == 'Handler'"
  category: class_qualnames
  kind: python_call_eq
  function: Handler.__qualname__.__eq__
  args: ["Handler"]
  expected: true

invariant logging_extra14.Formatter.qualname:
  description: "logging.Formatter.__qualname__ == 'Formatter'"
  category: class_qualnames
  kind: python_call_eq
  function: Formatter.__qualname__.__eq__
  args: ["Formatter"]
  expected: true

invariant logging_extra14.Filter.qualname:
  description: "logging.Filter.__qualname__ == 'Filter'"
  category: class_qualnames
  kind: python_call_eq
  function: Filter.__qualname__.__eq__
  args: ["Filter"]
  expected: true

invariant logging_extra14.LogRecord.qualname:
  description: "logging.LogRecord.__qualname__ == 'LogRecord'"
  category: class_qualnames
  kind: python_call_eq
  function: LogRecord.__qualname__.__eq__
  args: ["LogRecord"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ for StreamHandler, FileHandler, NullHandler
#
# No prior logging spec records __qualname__ for these Handler subclasses.
# ---------------------------------------------------------------------------

invariant logging_extra14.StreamHandler.qualname:
  description: "logging.StreamHandler.__qualname__ == 'StreamHandler'"
  category: class_qualnames
  kind: python_call_eq
  function: StreamHandler.__qualname__.__eq__
  args: ["StreamHandler"]
  expected: true

invariant logging_extra14.FileHandler.qualname:
  description: "logging.FileHandler.__qualname__ == 'FileHandler'"
  category: class_qualnames
  kind: python_call_eq
  function: FileHandler.__qualname__.__eq__
  args: ["FileHandler"]
  expected: true

invariant logging_extra14.NullHandler.qualname:
  description: "logging.NullHandler.__qualname__ == 'NullHandler'"
  category: class_qualnames
  kind: python_call_eq
  function: NullHandler.__qualname__.__eq__
  args: ["NullHandler"]
  expected: true

# ---------------------------------------------------------------------------
# __module__ for Logger, Handler, Formatter
#
# No prior logging spec records __module__ for Logger, Handler, or Formatter
# as standalone boolean __eq__ invariants. All three are defined in
# logging/__init__.py and thus have __module__ == 'logging'.
# ---------------------------------------------------------------------------

invariant logging_extra14.Logger.module:
  description: "logging.Logger.__module__ == 'logging'"
  category: class_modules
  kind: python_call_eq
  function: Logger.__module__.__eq__
  args: ["logging"]
  expected: true

invariant logging_extra14.Handler.module:
  description: "logging.Handler.__module__ == 'logging'"
  category: class_modules
  kind: python_call_eq
  function: Handler.__module__.__eq__
  args: ["logging"]
  expected: true

invariant logging_extra14.Formatter.module:
  description: "logging.Formatter.__module__ == 'logging'"
  category: class_modules
  kind: python_call_eq
  function: Formatter.__module__.__eq__
  args: ["logging"]
  expected: true
