spec: io_extra125
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/bytesio.c"
  notes:
    - "This spec extends io_extra124.zspec.zsdl."
    - "This spec covers: io.BytesIO method qualnames and MRO slot names not yet covered by equality assertions."
    - "io.BytesIO.read1.__qualname__ == 'BytesIO.read1' (len 13); no prior spec asserts equality."
    - "io.BytesIO.readline.__qualname__ == 'BytesIO.readline' (len 16); prior specs covered __len__ only."
    - "io.BytesIO.readinto.__qualname__ == 'BytesIO.readinto' (len 16); no prior spec asserts equality."
    - "io.BytesIO.writelines.__qualname__ == 'BytesIO.writelines' (len 18); prior specs covered __len__ only."
    - "io.BytesIO.truncate.__qualname__ == 'BytesIO.truncate' (len 16); prior specs covered __len__ only."
    - "io.BytesIO.__mro__[1].__name__ == '_BufferedIOBase' (len 15); prior specs covered __len__ but not equality."
    - "io.BytesIO.__mro__[2].__name__ == '_IOBase' (len 7); prior specs covered __len__ but not equality."
    - "Length ordering: writelines(18) > readline(16)==readinto(16)==truncate(16) > read1(13)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BytesIO.read1 and readline qualnames (equality assertions)
# BytesIO.read1.__qualname__ == 'BytesIO.read1' (13 chars).
# BytesIO.readline.__qualname__ == 'BytesIO.readline' (16 chars).
# No prior io spec asserts BytesIO.read1.__qualname__.__eq__ == 'BytesIO.read1'.
# Prior specs covered BytesIO.readline.__qualname__.__len__()==16 but NOT equality.
# read1(13) is shorter than readline(16) because 'read1' is 5 chars vs 'readline' is 8 chars.
# Both are method_descriptor objects from the _io C extension (Modules/_io/bytesio.c).
# 'BytesIO.' prefix (8 chars) + 'read1'(5) == 13; + 'readline'(8) == 16.
# ---------------------------------------------------------------------------

table io_extra125.BytesIO_read1_readline_qualnames:
  description: "io.BytesIO.read1.__qualname__='BytesIO.read1'(13); readline.__qualname__='BytesIO.readline'(16); equality assertions novel; prior specs covered readline len but not eq; read1 entirely novel equality"
  kind: python_call_eq
  category: method_identity
  id_prefix: iobyrd1rl125a

  columns: [id, function, args, expected, description]
  rows:
    - [bio_read1_qn_eq,     "BytesIO.read1.__qualname__.__eq__",          ["BytesIO.read1"],    true,  "io.BytesIO.read1.__qualname__ == 'BytesIO.read1' (13 chars; read1 reads up to size bytes, using at most one raw read; no prior spec asserts this equality)"]
    - [bio_read1_qn_len,    "BytesIO.read1.__qualname__.__len__",         [],                   13,    "io.BytesIO.read1.__qualname__.__len__() == 13 ('BytesIO.read1': 'BytesIO.'(8)+'read1'(5)==13)"]
    - [bio_rl_qn_eq,        "BytesIO.readline.__qualname__.__eq__",       ["BytesIO.readline"], true,  "io.BytesIO.readline.__qualname__ == 'BytesIO.readline' (16 chars; readline reads one line from the stream; prior specs covered __len__ but not equality)"]
    - [bio_rl_qn_len,       "BytesIO.readline.__qualname__.__len__",      [],                   16,    "io.BytesIO.readline.__qualname__.__len__() == 16 ('BytesIO.readline': 'BytesIO.'(8)+'readline'(8)==16)"]
    - [bio_rl_gt_r1,        "BytesIO.readline.__qualname__.__len__.__gt__", [13],               true,  "len('BytesIO.readline') > len('BytesIO.read1') (16 > 13; 'readline'(8) is 3 chars longer than 'read1'(5))"]
    - [bio_read1_type,      "BytesIO.read1.__class__.__name__.__eq__",    ["method_descriptor"], true, "type(io.BytesIO.read1).__name__ == 'method_descriptor' (C extension method from Modules/_io/bytesio.c)"]
    - [bio_rl_type,         "BytesIO.readline.__class__.__name__.__eq__", ["method_descriptor"], true, "type(io.BytesIO.readline).__name__ == 'method_descriptor' (C extension method; same type as read1, read, write, getvalue)"]
    - [bio_r1_ne_rl,        "BytesIO.read1.__qualname__.__eq__",          ["BytesIO.readline"], false, "io.BytesIO.read1.__qualname__ != 'BytesIO.readline' (distinct methods: read1 does at most one raw read; readline reads until newline)"]

# ---------------------------------------------------------------------------
# io.BytesIO.readinto and writelines qualnames (equality assertions)
# BytesIO.readinto.__qualname__ == 'BytesIO.readinto' (16 chars).
# BytesIO.writelines.__qualname__ == 'BytesIO.writelines' (18 chars).
# No prior io spec asserts BytesIO.readinto.__qualname__.__eq__ == 'BytesIO.readinto'.
# Prior specs covered BytesIO.writelines.__qualname__.__len__()==18 but NOT equality.
# readinto reads up to len(b) bytes into a pre-allocated, writable bytes-like object b.
# writelines writes a list of lines to the stream (each item is written using write()).
# writelines(18) > readinto(16): 'writelines'(10) is 2 chars longer than 'readinto'(8).
# ---------------------------------------------------------------------------

table io_extra125.BytesIO_readinto_writelines_qualnames:
  description: "io.BytesIO.readinto.__qualname__='BytesIO.readinto'(16); writelines.__qualname__='BytesIO.writelines'(18); equality assertions novel; prior specs covered writelines len but not eq; readinto entirely novel equality"
  kind: python_call_eq
  category: method_identity
  id_prefix: iobyrdwr125b

  columns: [id, function, args, expected, description]
  rows:
    - [bio_rdinto_qn_eq,    "BytesIO.readinto.__qualname__.__eq__",         ["BytesIO.readinto"],    true,  "io.BytesIO.readinto.__qualname__ == 'BytesIO.readinto' (16 chars; readinto reads up to len(b) bytes into pre-allocated buffer b; no prior spec asserts this equality)"]
    - [bio_rdinto_qn_len,   "BytesIO.readinto.__qualname__.__len__",        [],                      16,    "io.BytesIO.readinto.__qualname__.__len__() == 16 ('BytesIO.readinto': 'BytesIO.'(8)+'readinto'(8)==16)"]
    - [bio_wl_qn_eq,        "BytesIO.writelines.__qualname__.__eq__",       ["BytesIO.writelines"],  true,  "io.BytesIO.writelines.__qualname__ == 'BytesIO.writelines' (18 chars; writelines writes a list of lines; prior specs covered __len__ but not equality)"]
    - [bio_wl_qn_len,       "BytesIO.writelines.__qualname__.__len__",      [],                      18,    "io.BytesIO.writelines.__qualname__.__len__() == 18 ('BytesIO.writelines': 'BytesIO.'(8)+'writelines'(10)==18; longest BytesIO method qualname)"]
    - [bio_wl_gt_rdinto,    "BytesIO.writelines.__qualname__.__len__.__gt__", [16],                  true,  "len('BytesIO.writelines') > len('BytesIO.readinto') (18 > 16; 'writelines'(10) is 2 chars longer than 'readinto'(8))"]
    - [bio_rdinto_type,     "BytesIO.readinto.__class__.__name__.__eq__",   ["method_descriptor"],   true,  "type(io.BytesIO.readinto).__name__ == 'method_descriptor' (C extension method from Modules/_io/bytesio.c)"]
    - [bio_wl_type,         "BytesIO.writelines.__class__.__name__.__eq__", ["method_descriptor"],   true,  "type(io.BytesIO.writelines).__name__ == 'method_descriptor' (C extension method; same type as readinto and all BytesIO data methods)"]

# ---------------------------------------------------------------------------
# io.BytesIO.truncate qualname and BytesIO MRO slot names (equality assertions)
# BytesIO.truncate.__qualname__ == 'BytesIO.truncate' (16 chars).
# BytesIO.__mro__[1].__name__ == '_BufferedIOBase' (15 chars).
# BytesIO.__mro__[2].__name__ == '_IOBase' (7 chars).
# Prior specs covered BytesIO.truncate.__qualname__.__len__()==16 but NOT equality.
# No prior spec asserts BytesIO.__mro__[1].__name__.__eq__('_BufferedIOBase') or
# BytesIO.__mro__[2].__name__.__eq__('_IOBase') via the bracket-access double-quote form.
# BytesIO MRO is [BytesIO, _BufferedIOBase, _IOBase, object] (length 4).
# _BufferedIOBase(15) > _IOBase(7): the base class name is more than twice as long.
# ---------------------------------------------------------------------------

table io_extra125.BytesIO_truncate_mro_qualnames:
  description: "io.BytesIO.truncate.__qualname__='BytesIO.truncate'(16); mro[1]='_BufferedIOBase'(15); mro[2]='_IOBase'(7); truncate eq and MRO slot name eq are novel; prior specs covered truncate len and mro len"
  kind: python_call_eq
  category: method_identity
  id_prefix: iobytrmro125c

  columns: [id, function, args, expected, description]
  rows:
    - [bio_tr_qn_eq,        "BytesIO.truncate.__qualname__.__eq__",           ["BytesIO.truncate"],    true,  "io.BytesIO.truncate.__qualname__ == 'BytesIO.truncate' (16 chars; truncate truncates the stream; prior specs covered __len__ but not equality)"]
    - [bio_tr_qn_len,       "BytesIO.truncate.__qualname__.__len__",          [],                      16,    "io.BytesIO.truncate.__qualname__.__len__() == 16 ('BytesIO.truncate': 'BytesIO.'(8)+'truncate'(8)==16; same length as readline(16) and readinto(16))"]
    - [bio_mro1_eq,         "BytesIO.__mro__[1].__name__.__eq__",             ["_BufferedIOBase"],     true,  "io.BytesIO.__mro__[1].__name__ == '_BufferedIOBase' (15 chars; the C-level buffered IO base at MRO slot 1; BytesIO directly subclasses _BufferedIOBase)"]
    - [bio_mro1_len,        "BytesIO.__mro__[1].__name__.__len__",            [],                      15,    "io.BytesIO.__mro__[1].__name__.__len__() == 15 ('_BufferedIOBase' has 15 characters: '_Buffered'(9)+'IO'(2)+'Base'(4)==15)"]
    - [bio_mro2_eq,         "BytesIO.__mro__[2].__name__.__eq__",             ["_IOBase"],             true,  "io.BytesIO.__mro__[2].__name__ == '_IOBase' (7 chars; the root C IO base at MRO slot 2; same name as StringIO.__mro__[2].__name__)"]
    - [bio_mro2_len,        "BytesIO.__mro__[2].__name__.__len__",            [],                      7,     "io.BytesIO.__mro__[2].__name__.__len__() == 7 ('_IOBase' has 7 characters: '_'(1)+'IO'(2)+'Base'(4)==7)"]
    - [bio_mro1_gt_mro2,    "BytesIO.__mro__[1].__name__.__len__.__gt__",     [7],                     true,  "len('_BufferedIOBase') > len('_IOBase') (15 > 7; the intermediate base is more than twice as long as the root base name)"]
    - [bio_tr_eq_rdinto,    "BytesIO.truncate.__qualname__.__len__.__eq__",   [16],                    true,  "len('BytesIO.truncate') == len('BytesIO.readinto') == 16 (truncate and readinto share the same qualname length: both use 8-char method names after the 8-char 'BytesIO.' prefix)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra125.BytesIO.read1_qualname_eq:
  description: "io.BytesIO.read1.__qualname__ == 'BytesIO.read1' (length 13; read1(size=-1) reads up to size bytes using at most one raw system call; it is intended for buffered I/O implementations that wish to expose the underlying raw stream; BytesIO.read1 is a C method_descriptor defined in Modules/_io/bytesio.c; its qualname uses the 'BytesIO.' prefix (8 chars) followed by 'read1' (5 chars) totalling 13; read1(13) is shorter than readline(16), readinto(16), and truncate(16) — it has the shortest qualname among the BytesIO buffered-read methods; no prior io_extra spec has asserted BytesIO.read1.__qualname__.__eq__('BytesIO.read1') in any form)"
  category: method_identity
  kind: python_call_eq
  function: "BytesIO.read1.__qualname__.__eq__"
  args: ["BytesIO.read1"]
  expected: true

invariant io_extra125.BytesIO.readline_qualname_eq:
  description: "io.BytesIO.readline.__qualname__ == 'BytesIO.readline' (length 16; readline(size=-1) reads one line from the byte stream; if size is given, at most that many bytes are read; BytesIO.readline is a C method_descriptor in Modules/_io/bytesio.c; its qualname uses the 'BytesIO.' prefix (8 chars) followed by 'readline' (8 chars) totalling 16; readline(16) shares its length with readinto(16) and truncate(16); prior io_extra specs verified BytesIO.readline.__qualname__.__len__()==16 but never asserted the full string equality 'BytesIO.readline')"
  category: method_identity
  kind: python_call_eq
  function: "BytesIO.readline.__qualname__.__eq__"
  args: ["BytesIO.readline"]
  expected: true

invariant io_extra125.BytesIO.readinto_qualname_eq:
  description: "io.BytesIO.readinto.__qualname__ == 'BytesIO.readinto' (length 16; readinto(b) reads up to len(b) bytes into a pre-allocated, writable bytes-like object b and returns the number of bytes read; BytesIO.readinto is a C method_descriptor in Modules/_io/bytesio.c; its qualname uses the 'BytesIO.' prefix (8 chars) followed by 'readinto' (8 chars) totalling 16; readinto(16) shares its length with readline(16) and truncate(16); no prior io_extra spec has asserted BytesIO.readinto.__qualname__.__eq__('BytesIO.readinto') in any form)"
  category: method_identity
  kind: python_call_eq
  function: "BytesIO.readinto.__qualname__.__eq__"
  args: ["BytesIO.readinto"]
  expected: true

invariant io_extra125.BytesIO.writelines_qualname_eq:
  description: "io.BytesIO.writelines.__qualname__ == 'BytesIO.writelines' (length 18; writelines(lines) writes a list of lines to the stream; line separators are not added so it is usual to provide them in each line; BytesIO.writelines is a C method_descriptor defined in Modules/_io/bytesio.c; its qualname uses the 'BytesIO.' prefix (8 chars) followed by 'writelines' (10 chars) totalling 18; 'BytesIO.writelines' (18) is the longest qualname among all BytesIO data methods; prior io_extra specs verified BytesIO.writelines.__qualname__.__len__()==18 but never asserted the full string equality 'BytesIO.writelines')"
  category: method_identity
  kind: python_call_eq
  function: "BytesIO.writelines.__qualname__.__eq__"
  args: ["BytesIO.writelines"]
  expected: true

invariant io_extra125.BytesIO.mro1_name_eq:
  description: "io.BytesIO.__mro__[1].__name__ == '_BufferedIOBase' (length 15; BytesIO's MRO is [BytesIO, _BufferedIOBase, _IOBase, object]; the class at slot 1 is the C-level _BufferedIOBase which provides the buffered I/O base protocol; _BufferedIOBase is the private C implementation of the public BufferedIOBase abstract base; its name '_BufferedIOBase' uses the '_Buffered' prefix (9 chars) + 'IO' (2 chars) + 'Base' (4 chars) = 15 chars; prior io_extra specs verified BytesIO.__mro__[1].__name__.__len__()==15 in length tables but no prior spec asserted the full string equality '_BufferedIOBase' via the double-quoted bracket notation for the __mro__[1] slot)"
  category: type_identity
  kind: python_call_eq
  function: "BytesIO.__mro__[1].__name__.__eq__"
  args: ["_BufferedIOBase"]
  expected: true
