spec: typing_protocol
version: ">=3.8"
backend: python_module(typing)

docs: https://docs.python.org/3/library/typing.html#typing.Protocol

provenance:
  derived_from:
    - "Python typing documentation — https://docs.python.org/3/library/typing.html"
    - "PEP 544 — Protocols: Structural subtyping (static duck typing)"
    - "Test vectors verified by running Python 3.14.3 typing module on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/typing.py"
  notes:
    - "typing.Protocol is the base class for structural subtyping (PEP 544, Python 3.8+)."
    - "typing.runtime_checkable is a decorator that allows isinstance() checks on Protocol subclasses."
    - "typing.SupportsInt, SupportsFloat, SupportsAbs, SupportsRound, SupportsBytes, SupportsComplex are built-in protocols."
    - "All built-in Supports* protocols are decorated with @runtime_checkable."
    - "Protocol.__module__ is 'typing'; Supports* classes have __module__ == 'typing'."
    - "SupportsInt is a Protocol subclass; its __bases__ include Protocol."
    - "SupportsFloat, SupportsAbs, SupportsRound, SupportsBytes, SupportsComplex similarly extend Protocol."
    - "isinstance(42, SupportsInt) is True because int defines __int__."
    - "isinstance(3.14, SupportsFloat) is True because float defines __float__."
    - "isinstance(42, SupportsAbs) is True because int defines __abs__."
    - "isinstance(42, SupportsRound) is True because int defines __round__."
    - "isinstance(b'', SupportsBytes) is True because bytes defines __bytes__."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Protocol class — name and module checks
#
# typing.Protocol is the base class for structural subtyping introduced in
# PEP 544 (Python 3.8+). Verifies the exported symbol has the right identity.
# ---------------------------------------------------------------------------

invariant typing_protocol.names.Protocol:
  description: "typing.Protocol.__name__ == 'Protocol'"
  category: names
  kind: python_call_eq
  function: Protocol.__name__.__eq__
  args: ["Protocol"]
  expected: true

invariant typing_protocol.names.Protocol_module:
  description: "typing.Protocol.__module__ == 'typing'"
  category: names
  kind: python_call_eq
  function: Protocol.__module__.__eq__
  args: ["typing"]
  expected: true

invariant typing_protocol.names.runtime_checkable:
  description: "typing.runtime_checkable.__name__ == 'runtime_checkable'"
  category: names
  kind: python_call_eq
  function: runtime_checkable.__name__.__eq__
  args: ["runtime_checkable"]
  expected: true

# ---------------------------------------------------------------------------
# Supports* protocol class names
#
# Each built-in Supports* class is a Protocol with a single abstract method.
# We verify __name__ for each to confirm the symbols are correctly exported.
# ---------------------------------------------------------------------------

table typing_protocol.supports.names:
  description: "Supports* protocols have the correct __name__"
  kind: python_call_eq
  category: supports_names
  id_prefix: supports_name

  columns: [id, function, args, expected]
  rows:
    - [SupportsInt,     SupportsInt.__name__.__eq__,     ["SupportsInt"],     true]
    - [SupportsFloat,   SupportsFloat.__name__.__eq__,   ["SupportsFloat"],   true]
    - [SupportsAbs,     SupportsAbs.__name__.__eq__,     ["SupportsAbs"],     true]
    - [SupportsRound,   SupportsRound.__name__.__eq__,   ["SupportsRound"],   true]
    - [SupportsBytes,   SupportsBytes.__name__.__eq__,   ["SupportsBytes"],   true]
    - [SupportsComplex, SupportsComplex.__name__.__eq__, ["SupportsComplex"], true]

# ---------------------------------------------------------------------------
# Supports* protocol module checks
#
# All Supports* protocols are defined in the typing module; their __module__
# attribute must be 'typing'.
# ---------------------------------------------------------------------------

table typing_protocol.supports.modules:
  description: "Supports* protocols have __module__ == 'typing'"
  kind: python_call_eq
  category: supports_modules
  id_prefix: supports_module

  columns: [id, function, args, expected]
  rows:
    - [SupportsInt,     SupportsInt.__module__.__eq__,     ["typing"], true]
    - [SupportsFloat,   SupportsFloat.__module__.__eq__,   ["typing"], true]
    - [SupportsAbs,     SupportsAbs.__module__.__eq__,     ["typing"], true]
    - [SupportsRound,   SupportsRound.__module__.__eq__,   ["typing"], true]
    - [SupportsBytes,   SupportsBytes.__module__.__eq__,   ["typing"], true]
    - [SupportsComplex, SupportsComplex.__module__.__eq__, ["typing"], true]
