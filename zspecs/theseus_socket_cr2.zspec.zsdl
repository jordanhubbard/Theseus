spec: theseus_socket_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_socket_cr2)
blocks: socket

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html"
  notes:
    - "Clean-room socket constants and address utilities. Do NOT import socket."
    - "AF_INET, AF_INET6, SOCK_STREAM, SOCK_DGRAM: numeric constants matching POSIX."
    - "inet_aton(ip): pack IPv4 dotted-decimal string into 4-byte bytes."
    - "inet_ntoa(b): unpack 4-byte bytes into dotted-decimal string."
    - "socket_cr2_af_inet(): AF_INET == 2."
    - "socket_cr2_inet_aton(): inet_aton('127.0.0.1') == b'\\x7f\\x00\\x00\\x01'."
    - "socket_cr2_inet_ntoa(): inet_ntoa(b'\\xc0\\xa8\\x01\\x01') == '192.168.1.1'."
    - "Export: AF_INET, AF_INET6, SOCK_STREAM, SOCK_DGRAM, inet_aton, inet_ntoa."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_socket_cr2.af_inet:
  description: "AF_INET == 2"
  category: constants
  kind: python_call_eq
  function: socket_cr2_af_inet
  args: []
  expected: true

invariant theseus_socket_cr2.inet_aton:
  description: "inet_aton('127.0.0.1') == b'\\x7f\\x00\\x00\\x01'"
  category: address
  kind: python_call_eq
  function: socket_cr2_inet_aton
  args: []
  expected: true

invariant theseus_socket_cr2.inet_ntoa:
  description: "inet_ntoa(b'\\xc0\\xa8\\x01\\x01') == '192.168.1.1'"
  category: address
  kind: python_call_eq
  function: socket_cr2_inet_ntoa
  args: []
  expected: "192.168.1.1"
