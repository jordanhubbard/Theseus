    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 684 (ab3556): __reduce__, __reduce_ex__, __getstate__ dict-presence checks for abc types."
    - "All values false — abc.ABC, abc.ABCMeta, and abc.abstractmethod do not define __reduce__, __reduce_ex__, or __getstate__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table ab3556.reduce:
  description: "abc types __reduce__ dict-presence checks; wave 684"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: ab3556
  columns: [id, function, args, expected]
  rows:
    - ["ab3556001", operator.contains, [abc.ABC.__dict__,                                 "__reduce__"], false]
    - ["ab3556002", operator.contains, [abc.ABCMeta.__dict__,                             "__reduce__"], false]
    - ["ab3556003", operator.contains, [type(abc.abstractmethod(lambda: None)).__dict__,  "__reduce__"], false]

