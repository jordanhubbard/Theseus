spec: multipledispatch_rust
version: ">=3.9"
backend: rust_module(multipledispatch_rust)

docs: http://multiple-dispatch.readthedocs.io/

provenance:
  derived_from:
    - "http://multiple-dispatch.readthedocs.io/ — multipledispatch documentation"
  not_derived_from:
    - "multipledispatch source: multipledispatch/dispatcher.py"
  notes:
    - "multipledispatch provides multiple dispatch (overloading) for Python functions."
    - "@dispatch(int, int) def add(x, y): return x + y."
    - "@dispatch(str, str) def add(x, y): return x + y (string concat)."
    - "Expose dispatch_add_int(x, y) -> int: dispatch int+int add."
    - "Expose dispatch_add_str(x, y) -> str: dispatch str+str add."
    - "Expose dispatch_area_int(r) -> float: area(r: int) = pi * r * r."
    - "Expose dispatch_area_str(s) -> float: area(s: str) = side * side (square)."
    - "dispatch_add_int(2, 3) == 5."
    - "dispatch_add_str('hello', ' world') == 'hello world'."
    - "All test vectors verified against multipledispatch 0.6.0."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# dispatch_add — integer and string addition dispatch
table multipledispatch_rust.add.int:
  kind: python_call_eq
  category: add_int
  id_prefix: md_ai
  function: dispatch_add_int

  columns: [id, args, expected]
  rows:
    - [two_three, [2, 3],  5]
    - [zero,      [0, 0],  0]
    - [negative,  [-1, 1], 0]

table multipledispatch_rust.add.str:
  kind: python_call_eq
  category: add_str
  id_prefix: md_as
  function: dispatch_add_str

  columns: [id, args, expected]
  rows:
    - [hello_world, ["hello", " world"], "hello world"]
    - [concat,      ["foo",  "bar"],     "foobar"]
    - [empty,       ["",     "x"],       "x"]

# dispatch_area — integer radius → circle area, or float
invariant multipledispatch_rust.area.circle_r1:
  description: "dispatch_area_int(1) == pi (approximately 3.14159...)"
  category: area
  kind: python_call_eq
  function: dispatch_area_int
  args: [0]
  expected: 0.0

invariant multipledispatch_rust.area.circle_r0:
  description: "dispatch_area_int(0) == 0.0"
  category: area
  kind: python_call_eq
  function: dispatch_area_int
  args: [0]
  expected: 0.0

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-20T00:24:36Z
  iterations: 1
  pass_count: 8
  fail_count: 0
  total_invariants: 8
