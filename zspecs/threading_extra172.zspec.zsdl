spec: threading_extra172
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: threading.Thread.__dict__.__contains__('daemon') True; threading.Thread.__dict__.__contains__('name') True; threading.Thread.__dict__.__contains__('ident') True; threading.Thread.__dict__.__contains__('native_id') True; threading.Thread.__dict__.__len__() 28; threading.TIMEOUT_MAX.__class__.__name__ 'float'; threading.TIMEOUT_MAX.__gt__(0) True (Wave 300)."
    - "threading.Thread.__dict__.__contains__('daemon') == True — Thread defines a 'daemon' property descriptor in its class dict; daemon threads are abruptly terminated when the main program exits without calling join(); '__dict__.__contains__('daemon')' returns True. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('name') == True — Thread defines a 'name' property descriptor in its class dict; the name is a string used for identification in thread listings and log messages. Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('ident') == True — Thread defines an 'ident' property descriptor in its class dict; ident is a nonzero integer thread identifier (or None before the thread starts or after it terminates). Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__contains__('native_id') == True — Thread defines a 'native_id' property descriptor in its class dict; native_id is the OS-level native thread ID (added in Python 3.8). Verified with Python 3.14.3."
    - "threading.Thread.__dict__.__len__() == 28 — Thread.__dict__ has exactly 28 keys on Python 3.14.3. Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — threading.TIMEOUT_MAX is the maximum value allowed for the timeout parameter of blocking functions in the threading module; it is a float (platform-dependent, typically a very large value). Verified with Python 3.14.3."
    - "threading.TIMEOUT_MAX.__gt__(0) == True — threading.TIMEOUT_MAX is a positive float value greater than zero; on macOS/Darwin 25.4.0 its value is 9223372036.0. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread.__dict__ contains property descriptors 'daemon',
# 'name', 'ident', 'native_id'
#
# Wave 300 theme: threading.Thread defines 'daemon', 'name', 'ident', and
# 'native_id' as property descriptors in its class __dict__.
#
# threading.Thread.__dict__.__contains__('daemon') == True
# threading.Thread.__dict__.__contains__('name') == True
# threading.Thread.__dict__.__contains__('ident') == True
# threading.Thread.__dict__.__contains__('native_id') == True
#
# All four are property descriptors defined directly in the Thread class body
# in Lib/threading.py. 'daemon' controls whether the thread is daemonic.
# 'name' is a string identifier. 'ident' is the OS thread ID (nonzero int or
# None). 'native_id' is the OS native thread ID (added in Python 3.8). New to
# extra172.
# ---------------------------------------------------------------------------

table threading_extra172.thread_dict_property_descriptors:
  description: "threading.Thread.__dict__: contains 'daemon', 'name', 'ident', 'native_id'; wave 300; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtdpd172

  columns: [id, function, args, expected, description]
  rows:
    - [thread_dict_has_daemon,
       "Thread.__dict__.__contains__",
       ["daemon"],
       true,
       "threading.Thread.__dict__.__contains__('daemon') == True — Thread defines a 'daemon' property descriptor in Lib/threading.py; daemon threads are abruptly terminated when the main program exits without joining; 'daemon' is a key in Thread.__dict__; __contains__('daemon') returns True; new to extra172"]
    - [thread_dict_has_name,
       "Thread.__dict__.__contains__",
       ["name"],
       true,
       "threading.Thread.__dict__.__contains__('name') == True — Thread defines a 'name' property descriptor in Lib/threading.py; the name is a string used for identification in thread listings and log messages; 'name' is a key in Thread.__dict__; __contains__('name') returns True; new to extra172"]
    - [thread_dict_has_ident,
       "Thread.__dict__.__contains__",
       ["ident"],
       true,
       "threading.Thread.__dict__.__contains__('ident') == True — Thread defines an 'ident' property descriptor in Lib/threading.py; ident is the thread identifier (a nonzero integer) that the OS assigns when the thread starts, or None before the thread has started or after it terminates; 'ident' is a key in Thread.__dict__; __contains__('ident') returns True; new to extra172"]
    - [thread_dict_has_native_id,
       "Thread.__dict__.__contains__",
       ["native_id"],
       true,
       "threading.Thread.__dict__.__contains__('native_id') == True — Thread defines a 'native_id' property descriptor in Lib/threading.py (added in Python 3.8); native_id is the OS-level native thread ID assigned by the host OS; 'native_id' is a key in Thread.__dict__; __contains__('native_id') returns True; new to extra172"]

# ---------------------------------------------------------------------------
# Table 2: threading.Thread.__dict__.__len__() == 28
#
# Wave 300 theme: threading.Thread.__dict__ has exactly 28 keys on Python 3.14.3.
#
# threading.Thread.__dict__.__len__() == 28
# threading.Thread.__dict__.__len__() != 4
# threading.Thread.__dict__.__contains__('ident') == True  (cross-check)
# threading.Thread.__dict__.__contains__('nonexistent') == False
#
# Thread.__dict__ is the mappingproxy of Thread's own namespace. On Python 3.14.3
# it contains exactly 28 keys: the Thread lifecycle methods (start, run, join,
# is_alive), the property descriptors (daemon, name, ident, native_id), the
# initialization/repr/dunder methods, and other infrastructure entries. New to
# extra172.
# ---------------------------------------------------------------------------

table threading_extra172.thread_dict_len:
  description: "threading.Thread.__dict__.__len__() == 28; negative cross-checks; wave 300; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtdl172

  columns: [id, function, args, expected, description]
  rows:
    - [thread_dict_len_28,
       "Thread.__dict__.__len__",
       [],
       28,
       "threading.Thread.__dict__.__len__() == 28 — Thread.__dict__ is the mappingproxy of Thread's own class namespace; on Python 3.14.3 it contains exactly 28 keys including lifecycle methods (start, run, join, is_alive), property descriptors (daemon, name, ident, native_id), init/repr/dunder methods, and other infrastructure; mappingproxy.__len__() returns 28; new to extra172"]
    - [thread_dict_len_not_4,
       "Thread.__dict__.__len__",
       [],
       28,
       "threading.Thread.__dict__.__len__() == 28 (not 4) — although daemon, name, ident, and native_id are four notable property descriptors, Thread.__dict__ contains 28 entries in total including many lifecycle methods and dunder infrastructure; mappingproxy.__len__() returns 28; new to extra172"]
    - [thread_dict_has_ident_xcheck,
       "Thread.__dict__.__contains__",
       ["ident"],
       true,
       "threading.Thread.__dict__.__contains__('ident') == True — cross-check confirming 'ident' is present in Thread.__dict__; ident is the property descriptor exposing the OS thread identifier; __contains__('ident') returns True; new to extra172"]
    - [thread_dict_no_nonexistent,
       "Thread.__dict__.__contains__",
       ["nonexistent"],
       false,
       "threading.Thread.__dict__.__contains__('nonexistent') == False — 'nonexistent' is not defined anywhere on threading.Thread; Thread.__dict__ does not contain 'nonexistent'; __contains__('nonexistent') returns False; new to extra172"]

# ---------------------------------------------------------------------------
# Table 3: threading.TIMEOUT_MAX is a positive float
#
# Wave 300 theme: threading.TIMEOUT_MAX — __class__.__name__ 'float',
# __gt__(0) True.
#
# threading.TIMEOUT_MAX.__class__.__name__ == 'float'
# threading.TIMEOUT_MAX.__gt__(0) == True
# threading.TIMEOUT_MAX.__class__.__name__ != 'int'
# threading.TIMEOUT_MAX.__gt__(0) != False
#
# threading.TIMEOUT_MAX is the maximum value allowed for the timeout parameter
# of blocking functions (such as threading.Lock.acquire). It is a float
# (platform-dependent), constrained by the operating system's maximum sleep
# duration. On macOS/Darwin 25.4.0 with Python 3.14.3 its value is 9223372036.0.
# New to extra172.
# ---------------------------------------------------------------------------

table threading_extra172.timeout_max_type_and_sign:
  description: "threading.TIMEOUT_MAX: __class__.__name__ 'float', __gt__(0) True; wave 300; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtmts172

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_max_class_float,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["float"],
       true,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('float') == True — threading.TIMEOUT_MAX is a float value representing the maximum allowed timeout for blocking threading functions; its __class__.__name__ is 'float'; str.__eq__('float') returns True; new to extra172"]
    - [timeout_max_gt_0,
       "TIMEOUT_MAX.__gt__",
       [0],
       true,
       "threading.TIMEOUT_MAX.__gt__(0) == True — threading.TIMEOUT_MAX is a large positive float value (9223372036.0 on macOS/Darwin 25.4.0 with Python 3.14.3); it is strictly greater than 0; float.__gt__(0) returns True; new to extra172"]
    - [timeout_max_not_int,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["int"],
       false,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('int') == False — threading.TIMEOUT_MAX is a float, NOT an integer; its __class__.__name__ is 'float', not 'int'; str.__eq__('int') returns False; new to extra172"]
    - [timeout_max_gt_0_not_false,
       "TIMEOUT_MAX.__gt__",
       [0],
       true,
       "threading.TIMEOUT_MAX.__gt__(0) == True (not False) — TIMEOUT_MAX is a positive float; cross-check confirming __gt__(0) returns True, not False; float.__gt__(0) returns True; new to extra172"]

# ---------------------------------------------------------------------------
# Table 4: threading.TIMEOUT_MAX additional class checks and cross-checks with
# Thread.__dict__
#
# Wave 300 theme: threading.TIMEOUT_MAX additional type identity checks and
# cross-checks contrasting it with Thread.__dict__ properties.
#
# threading.TIMEOUT_MAX.__class__.__name__ != 'str'
# threading.TIMEOUT_MAX.__class__.__name__ != 'type'
# threading.Thread.__dict__.__contains__('native_id') == True  (cross-check)
# threading.Thread.__dict__.__contains__('daemon') == True  (cross-check)
#
# TIMEOUT_MAX is neither a string nor a class; it is a plain float module-level
# constant. This table confirms its class is exclusively 'float' and provides
# cross-checks for Thread.__dict__ property descriptors. New to extra172.
# ---------------------------------------------------------------------------

table threading_extra172.timeout_max_negative_and_xcheck:
  description: "threading.TIMEOUT_MAX: not str, not type; Thread.__dict__ native_id and daemon cross-checks; wave 300; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtmnx172

  columns: [id, function, args, expected, description]
  rows:
    - [timeout_max_not_str,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["str"],
       false,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('str') == False — threading.TIMEOUT_MAX is a float constant, NOT a string; its __class__.__name__ is 'float', not 'str'; str.__eq__('str') returns False; new to extra172"]
    - [timeout_max_not_type,
       "TIMEOUT_MAX.__class__.__name__.__eq__",
       ["type"],
       false,
       "threading.TIMEOUT_MAX.__class__.__name__.__eq__('type') == False — threading.TIMEOUT_MAX is a float constant (a scalar value), NOT a class; its __class__.__name__ is 'float', not 'type'; str.__eq__('type') returns False; new to extra172"]
    - [thread_dict_native_id_xcheck,
       "Thread.__dict__.__contains__",
       ["native_id"],
       true,
       "threading.Thread.__dict__.__contains__('native_id') == True — cross-check confirming 'native_id' is present in Thread.__dict__; native_id is the property descriptor (added in Python 3.8) exposing the OS-level native thread ID; __contains__('native_id') returns True; new to extra172"]
    - [thread_dict_daemon_xcheck,
       "Thread.__dict__.__contains__",
       ["daemon"],
       true,
       "threading.Thread.__dict__.__contains__('daemon') == True — cross-check confirming 'daemon' is present in Thread.__dict__; daemon is the property descriptor controlling whether the thread is a daemon thread; __contains__('daemon') returns True; new to extra172"]

# ---------------------------------------------------------------------------
# Table 5: threading.Thread.__dict__ negative checks for names absent from
# the class dict
#
# Wave 300 theme: negative contains checks confirming that Thread.__dict__ does
# not contain names irrelevant to Thread.
#
# threading.Thread.__dict__.__contains__('keys') == False
# threading.Thread.__dict__.__contains__('sleep') == False
# threading.Thread.__dict__.__contains__('acquire') == False
# threading.Thread.__dict__.__contains__('daemon') == True  (cross-check)
#
# 'keys' is a dict method. 'sleep' is a threading module-level function (not a
# Thread method). 'acquire' is a Lock method. None of these are defined on the
# Thread class itself. These negative checks confirm that Thread.__dict__ correctly
# excludes such unrelated names. New to extra172.
# ---------------------------------------------------------------------------

table threading_extra172.thread_dict_absent_names:
  description: "threading.Thread.__dict__: does not contain 'keys', 'sleep', 'acquire'; daemon cross-check; wave 300; new to extra172"
  kind: python_call_eq
  category: identity
  id_prefix: threadingtan172

  columns: [id, function, args, expected, description]
  rows:
    - [thread_dict_no_keys,
       "Thread.__dict__.__contains__",
       ["keys"],
       false,
       "threading.Thread.__dict__.__contains__('keys') == False — 'keys' is a dict method and has no relation to threading.Thread; Thread.__dict__ does not contain 'keys'; __contains__('keys') returns False; new to extra172"]
    - [thread_dict_no_sleep,
       "Thread.__dict__.__contains__",
       ["sleep"],
       false,
       "threading.Thread.__dict__.__contains__('sleep') == False — 'sleep' is a threading module-level function (threading.sleep), not a method on the Thread class; Thread.__dict__ does not contain 'sleep'; __contains__('sleep') returns False; new to extra172"]
    - [thread_dict_no_acquire,
       "Thread.__dict__.__contains__",
       ["acquire"],
       false,
       "threading.Thread.__dict__.__contains__('acquire') == False — 'acquire' is a method on threading.Lock (and other synchronization primitives), not on threading.Thread; Thread.__dict__ does not contain 'acquire'; __contains__('acquire') returns False; new to extra172"]
    - [thread_dict_daemon_xcheck2,
       "Thread.__dict__.__contains__",
       ["daemon"],
       true,
       "threading.Thread.__dict__.__contains__('daemon') == True — cross-check confirming 'daemon' is present as a property descriptor in Thread.__dict__; __contains__('daemon') returns True; new to extra172"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra172
# ---------------------------------------------------------------------------

invariant threading_extra172.thread_dict_has_daemon:
  description: "threading.Thread.__dict__.__contains__('daemon') == True — Thread defines 'daemon' as a property descriptor controlling daemon thread behavior; wave 300; new to extra172"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["daemon"]
  expected: true

invariant threading_extra172.thread_dict_has_name:
  description: "threading.Thread.__dict__.__contains__('name') == True — Thread defines 'name' as a property descriptor for the thread's string identifier; wave 300; new to extra172"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["name"]
  expected: true

invariant threading_extra172.thread_dict_has_ident:
  description: "threading.Thread.__dict__.__contains__('ident') == True — Thread defines 'ident' as a property descriptor for the OS thread identifier (nonzero int or None); wave 300; new to extra172"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["ident"]
  expected: true

invariant threading_extra172.thread_dict_has_native_id:
  description: "threading.Thread.__dict__.__contains__('native_id') == True — Thread defines 'native_id' as a property descriptor for the OS-level native thread ID (added in Python 3.8); wave 300; new to extra172"
  kind: python_call_eq
  function: Thread.__dict__.__contains__
  args: ["native_id"]
  expected: true

invariant threading_extra172.thread_dict_len_28:
  description: "threading.Thread.__dict__.__len__() == 28 — Thread's class namespace (mappingproxy) has exactly 28 keys on Python 3.14.3; wave 300; new to extra172"
  kind: python_call_eq
  function: Thread.__dict__.__len__
  args: []
  expected: 28

invariant threading_extra172.timeout_max_class_float:
  description: "threading.TIMEOUT_MAX.__class__.__name__ == 'float' — TIMEOUT_MAX is the maximum allowed timeout for blocking threading functions; it is a float; wave 300; new to extra172"
  kind: python_call_eq
  function: TIMEOUT_MAX.__class__.__name__.__eq__
  args: ["float"]
  expected: true

invariant threading_extra172.timeout_max_gt_0:
  description: "threading.TIMEOUT_MAX.__gt__(0) == True — TIMEOUT_MAX is a large positive float (9223372036.0 on macOS/Darwin 25.4.0); it is strictly greater than 0; wave 300; new to extra172"
  kind: python_call_eq
  function: TIMEOUT_MAX.__gt__
  args: [0]
  expected: true

