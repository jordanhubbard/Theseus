spec: itertools_extra201
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers __class__.__name__ identity for public itertools iterator types: count, cycle, repeat, chain, islice, product, pairwise, batched."
    - "itertools.count.__class__.__name__ == 'type' — count is a C-level iterator type; its metaclass is 'type'. Verified with Python 3.14.3."
    - "itertools.cycle.__class__.__name__ == 'type' — cycle is a C-level iterator type; its metaclass is 'type'. Verified with Python 3.14.3."
    - "itertools.repeat.__class__.__name__ == 'type' — repeat is a C-level iterator type; its metaclass is 'type'. Verified with Python 3.14.3."
    - "itertools.chain.__class__.__name__ == 'type' — chain is a C-level iterator type; its metaclass is 'type'. Verified with Python 3.14.3."
    - "itertools.islice.__class__.__name__ == 'type' — islice is a C-level iterator type; its metaclass is 'type'. Verified with Python 3.14.3."
    - "itertools.product.__class__.__name__ == 'type' — product is a C-level iterator type; its metaclass is 'type'. Verified with Python 3.14.3."
    - "itertools.pairwise.__class__.__name__ == 'type' — pairwise is a C-level iterator type (Python 3.10+); its metaclass is 'type'. Verified with Python 3.14.3."
    - "itertools.batched.__class__.__name__ == 'type' — batched is a C-level iterator type (Python 3.12+); its metaclass is 'type'. Verified with Python 3.14.3."
    - "All itertools public callables are C-level types; type(X).__name__ == 'type' for all of them. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __class__.__name__ for infinite itertools iterator types
#
# count, cycle, repeat: infinite (or unbounded) itertools C-level types.
# All have metaclass 'type'; __class__.__name__ == 'type'.
# ---------------------------------------------------------------------------

table itertools_extra201.class_identity_infinite:
  description: "itertools infinite iterator types: count, cycle, repeat __class__.__name__=='type'; new to extra201"
  kind: python_call_eq
  category: class_identity
  id_prefix: iterclasses201

  columns: [id, function, args, expected, description]
  rows:
    - [count_class_type,
       count.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.count.__class__.__name__.__eq__('type') == True — count is a C-level infinite counter type; type(count).__name__ == 'type'; new to extra201"]
    - [cycle_class_type,
       cycle.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.cycle.__class__.__name__.__eq__('type') == True — cycle is a C-level infinite cycling type; type(cycle).__name__ == 'type'; new to extra201"]
    - [repeat_class_type,
       repeat.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.repeat.__class__.__name__.__eq__('type') == True — repeat is a C-level type yielding a value repeatedly; type(repeat).__name__ == 'type'; new to extra201"]

# ---------------------------------------------------------------------------
# Table 2: __class__.__name__ for chaining and slicing itertools types
#
# chain, islice: C-level itertools types for combining and slicing iterables.
# product: C-level type for Cartesian product iteration.
# All have metaclass 'type'.
# ---------------------------------------------------------------------------

table itertools_extra201.class_identity_chain_slice_product:
  description: "itertools chain, islice, product __class__.__name__=='type'; new to extra201"
  kind: python_call_eq
  category: class_identity
  id_prefix: iterclasses201

  columns: [id, function, args, expected, description]
  rows:
    - [chain_class_type,
       chain.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.chain.__class__.__name__.__eq__('type') == True — chain is a C-level type for chaining iterables; type(chain).__name__ == 'type'; new to extra201"]
    - [islice_class_type,
       islice.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.islice.__class__.__name__.__eq__('type') == True — islice is a C-level type for slicing iterables; type(islice).__name__ == 'type'; new to extra201"]
    - [product_class_type,
       product.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.product.__class__.__name__.__eq__('type') == True — product is a C-level type for Cartesian products; type(product).__name__ == 'type'; new to extra201"]

# ---------------------------------------------------------------------------
# Table 3: __class__.__name__ for newer itertools iterator types
#
# pairwise: C-level type added in Python 3.10 for overlapping consecutive pairs.
# batched: C-level type added in Python 3.12 for fixed-size batches.
# Both have metaclass 'type'.
# ---------------------------------------------------------------------------

table itertools_extra201.class_identity_pairwise_batched:
  description: "itertools pairwise and batched __class__.__name__=='type'; new to extra201"
  kind: python_call_eq
  category: class_identity
  id_prefix: iterclasses201

  columns: [id, function, args, expected, description]
  rows:
    - [pairwise_class_type,
       pairwise.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.pairwise.__class__.__name__.__eq__('type') == True — pairwise is a C-level type for overlapping consecutive pairs (Python 3.10+); type(pairwise).__name__ == 'type'; new to extra201"]
    - [batched_class_type,
       batched.__class__.__name__.__eq__,
       ["type"],
       true,
       "itertools.batched.__class__.__name__.__eq__('type') == True — batched is a C-level type for fixed-size batches (Python 3.12+); type(batched).__name__ == 'type'; new to extra201"]

# ---------------------------------------------------------------------------
# Standalone invariants — itertools_extra201
# ---------------------------------------------------------------------------

invariant itertools_extra201.count_class_type:
  description: "itertools.count.__class__.__name__ == 'type' — C-level infinite counter; metaclass is 'type'; new to extra201"
  kind: python_call_eq
  function: count.__class__.__name__.__eq__
  args: ["type"]
  expected: true

