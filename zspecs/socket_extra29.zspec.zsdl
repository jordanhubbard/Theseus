spec: socket_extra29
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra28.zspec.zsdl — covers socket.socket method __qualname__ and __name__ for bind/connect/listen/accept/send/recv; socket.getaddrinfo.__qualname__.__len__(); socket.setdefaulttimeout.__qualname__.__len__() and __module__.__len__()."
    - "socket_extra27.zspec.zsdl — covers __module__.__len__() for socket.socket/error/timeout/herror/gaierror; __name__.__len__() for socket.socket/error; __qualname__ for gethostname/getfqdn/inet_aton/inet_ntoa; gethostname.__module__.__len__()."
    - "socket_extra26.zspec.zsdl — covers socket.timeout/__bases__[0].__name__, socket.herror/__bases__[0].__name__, socket.gaierror/__bases__[0].__name__, socket.socket.__init__.__name__, socket.inet_aton/__name__/__module__, socket.inet_ntoa/__name__."
    - "socket_extra25.zspec.zsdl — covers socket.error/__module__, socket.timeout/__module__, socket.gaierror/__module__, socket.herror/__module__, socket.gethostname/__qualname__/__module__, socket.getfqdn/__qualname__/__module__, socket.getaddrinfo/__qualname__/__module__, socket.create_connection/__qualname__/__module__."
  notes:
    - "This spec extends socket_extra28.zspec.zsdl."
    - "Prior specs covered: socket.__name__/__package__, socket.socket/__name__/__module__/__qualname__/__bases__[0].__name__/__init__.__name__, error/timeout/herror/gaierror __name__/__module__/__bases__[0].__name__, AF_INET/AF_INET6/AF_UNIX values, SOCK_STREAM/SOCK_DGRAM values, IPPROTO_TCP/IPPROTO_UDP, gethostname/getfqdn/__name__/__module__/__qualname__, inet_aton/inet_ntoa/__name__/__module__/__qualname__, getaddrinfo/__name__/__module__/__qualname__, setdefaulttimeout/__name__/__module__, __module__.__len__() and __name__.__len__() for socket/error/timeout/herror/gaierror, method __qualname__/__name__ for bind/connect/listen/accept/send/recv, getaddrinfo/__qualname__/__len__(), setdefaulttimeout/__qualname__/__len__()/__module__/__len__()."
    - "This spec covers: socket.socket.__mro__.__len__(); socket.error.__mro__.__len__(); socket.timeout.__mro__.__len__(); socket.herror.__mro__.__len__(); socket.gaierror.__mro__.__len__(); socket.socket.setsockopt/__qualname__/__qualname__.__len__()/__name__/__name__.__len__(); socket.socket.getsockopt/__qualname__/__qualname__.__len__()/__name__/__name__.__len__(); socket.socket.settimeout/__qualname__.__len__()/__name__.__len__(); socket.socket.getpeername/__qualname__.__len__()/__name__.__len__()."
    - "socket.socket.__mro__.__len__() == 3 — (<class 'socket.socket'>, <class '_socket.socket'>, <class 'object'>). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.error.__mro__.__len__() == 4 — (OSError, Exception, BaseException, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.timeout.__mro__.__len__() == 5 — (timeout, OSError, Exception, BaseException, object). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.herror.__mro__.__len__() == 5. socket.gaierror.__mro__.__len__() == 5. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__qualname__ == 'socket.setsockopt' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__qualname__ == 'socket.getsockopt' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__qualname__ == 'socket.settimeout' — len 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.getpeername.__qualname__ == 'socket.getpeername' — len 18. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.setsockopt.__name__ == 'setsockopt' — len 10. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.getsockopt.__name__ == 'getsockopt' — len 10. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.settimeout.__name__ == 'settimeout' — len 10. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "socket.socket.getpeername.__name__ == 'getpeername' — len 11. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket and exception class __mro__.__len__()
#
# No prior spec checks __mro__.__len__() for any socket class.
# socket.socket.__mro__ == (socket.socket, _socket.socket, object) — len 3.
# socket.error.__mro__ == (OSError, Exception, BaseException, object) — len 4.
# socket.timeout.__mro__ == (timeout, OSError, Exception, BaseException, object) — len 5.
# socket.herror and socket.gaierror also have len 5 MROs.
# ---------------------------------------------------------------------------

invariant socket_extra29.socket_class.mro_len:
  description: "len(socket.socket.__mro__) == 3 — (socket.socket, _socket.socket, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: "socket.__mro__.__len__"
  args: []
  expected: 3

invariant socket_extra29.socket_error.mro_len:
  description: "len(socket.error.__mro__) == 4 — (OSError, Exception, BaseException, object)"
  category: class_hierarchy
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

table socket_extra29.exception_mro_lengths:
  description: "socket exception class __mro__.__len__() — timeout/herror/gaierror each have 5-deep MRO"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: seml29

  columns: [id, function, args, expected, description]
  rows:
    - [timeout,
       timeout.__mro__.__len__,
       [],
       5,
       "len(socket.timeout.__mro__) == 5"]
    - [herror,
       herror.__mro__.__len__,
       [],
       5,
       "len(socket.herror.__mro__) == 5"]
    - [gaierror,
       gaierror.__mro__.__len__,
       [],
       5,
       "len(socket.gaierror.__mro__) == 5"]

# ---------------------------------------------------------------------------
# socket.socket.setsockopt and getsockopt __qualname__ and __qualname__.__len__()
#
# No prior spec checks __qualname__ or __qualname__.__len__() for setsockopt or
# getsockopt. Both are method_descriptor objects whose __qualname__ follows the
# pattern 'socket.<methodname>' (class is also named 'socket').
# setsockopt.__qualname__ == 'socket.setsockopt' (len 17).
# getsockopt.__qualname__ == 'socket.getsockopt' (len 17).
# ---------------------------------------------------------------------------

table socket_extra29.sockopt_qualnames:
  description: "socket.socket.setsockopt/getsockopt __qualname__.__eq__ and __qualname__.__len__()"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: soq29

  columns: [id, function, args, expected, description]
  rows:
    - [setsockopt_qualname,
       "socket.setsockopt.__qualname__.__eq__",
       ["socket.setsockopt"],
       true,
       "socket.socket.setsockopt.__qualname__ == 'socket.setsockopt'"]
    - [getsockopt_qualname,
       "socket.getsockopt.__qualname__.__eq__",
       ["socket.getsockopt"],
       true,
       "socket.socket.getsockopt.__qualname__ == 'socket.getsockopt'"]
    - [setsockopt_qualname_len,
       "socket.setsockopt.__qualname__.__len__",
       [],
       17,
       "len('socket.setsockopt') == 17"]
    - [getsockopt_qualname_len,
       "socket.getsockopt.__qualname__.__len__",
       [],
       17,
       "len('socket.getsockopt') == 17"]

# ---------------------------------------------------------------------------
# socket.socket.settimeout and getpeername __qualname__.__len__() and __name__.__len__()
#
# No prior spec checks __qualname__.__len__() or __name__.__len__() for settimeout
# or getpeername. settimeout.__qualname__ == 'socket.settimeout' (len 17);
# getpeername.__qualname__ == 'socket.getpeername' (len 18).
# settimeout.__name__ == 'settimeout' (len 10);
# getpeername.__name__ == 'getpeername' (len 11).
# ---------------------------------------------------------------------------

invariant socket_extra29.settimeout.qualname_len:
  description: "len(socket.socket.settimeout.__qualname__) == 17 — len('socket.settimeout') == 17"
  category: function_qualnames
  kind: python_call_eq
  function: "socket.settimeout.__qualname__.__len__"
  args: []
  expected: 17

invariant socket_extra29.getpeername.qualname_len:
  description: "len(socket.socket.getpeername.__qualname__) == 18 — len('socket.getpeername') == 18"
  category: function_qualnames
  kind: python_call_eq
  function: "socket.getpeername.__qualname__.__len__"
  args: []
  expected: 18

table socket_extra29.timeout_peername_name_lengths:
  description: "socket.socket.settimeout/__name__.__len__()==10; getpeername/__name__.__len__()==11; setsockopt/__name__.__len__()==10; getsockopt/__name__.__len__()==10"
  kind: python_call_eq
  category: function_names
  id_prefix: tpnl29

  columns: [id, function, args, expected, description]
  rows:
    - [settimeout,
       "socket.settimeout.__name__.__len__",
       [],
       10,
       "len('settimeout') == 10"]
    - [getpeername,
       "socket.getpeername.__name__.__len__",
       [],
       11,
       "len('getpeername') == 11"]
    - [setsockopt,
       "socket.setsockopt.__name__.__len__",
       [],
       10,
       "len('setsockopt') == 10"]
    - [getsockopt,
       "socket.getsockopt.__name__.__len__",
       [],
       10,
       "len('getsockopt') == 10"]
