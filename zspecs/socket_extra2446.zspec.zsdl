spec: socket_extra2446
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — socket module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "CPython source: Lib/socket.py"
    - "socket_extra227.zspec.zsdl and other pre-existing socket_extra files"
  notes:
    - "Theme: __enter__/__exit__ context manager protocol dict-presence for socket types."
    - "socket.socket DOES define __enter__ and __exit__ in its own __dict__; socket instances ARE valid context managers (the with-statement calls __enter__ on open and __exit__ to auto-close)."
    - "socket.AddressFamily is an IntEnum subclass; it does NOT define __enter__ or __exit__ in its own __dict__."
    - "socket.SocketKind is an IntEnum subclass; it does NOT define __enter__ or __exit__ in its own __dict__."
    - "socket.socket.__dict__ also contains __init__, __repr__, dup, accept, makefile, close, detach, sendfile, family, type — all are own Python-level methods or descriptors defined in Lib/socket.py."
    - "socket.AddressFamily and socket.SocketKind carry their enum members (AF_INET, AF_UNIX, AF_INET6; SOCK_STREAM, SOCK_DGRAM, SOCK_RAW) as own class-dict entries."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: socket.socket — context manager protocol PRESENT
#
# socket.socket is a Python class defined in Lib/socket.py. It explicitly
# implements __enter__ and __exit__ to support the with-statement: __enter__
# returns self and __exit__ calls self.close(). Both methods appear in the
# class __dict__ as own attributes. This is the primary positive case for the
# theme: socket.socket IS a context manager, directly confirmed via __dict__.
# ---------------------------------------------------------------------------

table socket_extra2446.socket_ctx_protocol_present:
  description: "socket.socket.__dict__: __enter__ and __exit__ present — socket IS a context manager; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2446

  columns: [id, function, args, expected]
  rows:
    - ["sk2446-001", "socket.socket.__dict__.__contains__", ["__enter__"], true]
    - ["sk2446-002", "socket.socket.__dict__.__contains__", ["__exit__"], true]

# ---------------------------------------------------------------------------
# Table 2: socket.socket — Python-level socket API present in __dict__
#
# socket.socket is defined in Lib/socket.py, which adds Python-level wrappers
# and helpers on top of the C-level _socket.socket base type. The following
# methods are all defined directly in the Python class body and appear in
# socket.socket.__dict__: __init__, __repr__, dup, accept, makefile, close,
# detach, sendfile. The descriptors family and type are also own class entries.
# ---------------------------------------------------------------------------

table socket_extra2446.socket_python_api_present:
  description: "socket.socket.__dict__: __init__, __repr__, dup, accept, makefile, close, detach, sendfile, family, type present; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2446

  columns: [id, function, args, expected]
  rows:
    - ["sk2446-003", "socket.socket.__dict__.__contains__", ["__init__"], true]
    - ["sk2446-004", "socket.socket.__dict__.__contains__", ["__repr__"], true]
    - ["sk2446-005", "socket.socket.__dict__.__contains__", ["dup"], true]
    - ["sk2446-006", "socket.socket.__dict__.__contains__", ["accept"], true]
    - ["sk2446-007", "socket.socket.__dict__.__contains__", ["makefile"], true]
    - ["sk2446-008", "socket.socket.__dict__.__contains__", ["close"], true]
    - ["sk2446-009", "socket.socket.__dict__.__contains__", ["detach"], true]
    - ["sk2446-010", "socket.socket.__dict__.__contains__", ["sendfile"], true]
    - ["sk2446-011", "socket.socket.__dict__.__contains__", ["family"], true]
    - ["sk2446-012", "socket.socket.__dict__.__contains__", ["type"], true]

# ---------------------------------------------------------------------------
# Table 3: socket.AddressFamily — context manager protocol absent
#
# socket.AddressFamily is an IntEnum subclass generated by the socket module.
# It holds named constants for socket address families (AF_INET, AF_UNIX,
# AF_INET6, etc.). It does NOT define __enter__ or __exit__ in its own
# __dict__. The enum members AF_INET, AF_UNIX, AF_INET6 are present as own
# class-dict entries, as is the standard enum infrastructure _member_names_.
# ---------------------------------------------------------------------------

table socket_extra2446.addressfamily_ctx_and_members:
  description: "socket.AddressFamily.__dict__: __enter__/__exit__ absent; AF_INET/AF_UNIX/AF_INET6 members present; new to extra2446"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2446

  columns: [id, function, args, expected]
  rows:
    - ["sk2446-013", "socket.AddressFamily.__dict__.__contains__", ["__enter__"], false]
    - ["sk2446-014", "socket.AddressFamily.__dict__.__contains__", ["__exit__"], false]
    - ["sk2446-015", "socket.AddressFamily.__dict__.__contains__", ["AF_INET"], true]
    - ["sk2446-016", "socket.AddressFamily.__dict__.__contains__", ["AF_UNIX"], true]
    - ["sk2446-017", "socket.AddressFamily.__dict__.__contains__", ["AF_INET6"], true]
    - ["sk2446-018", "socket.AddressFamily.__dict__.__contains__", ["_member_names_"], true]
    - ["sk2446-019", "socket.AddressFamily.__dict__.__contains__", ["__format__"], true]

# ---------------------------------------------------------------------------
# Table 4: socket.SocketKind — context manager protocol absent; members present
#
# socket.SocketKind is an IntEnum subclass for socket type constants
# (SOCK_STREAM, SOCK_DGRAM, SOCK_RAW, etc.). Like AddressFamily it does NOT
# define __enter__ or __exit__ in its own __dict__. The enum members are
# present as own class-dict entries. New to extra2446.
# ---------------------------------------------------------------------------

table socket_extra2446.socketkind_ctx_and_members:
  description: "socket.SocketKind.__dict__: __enter__/__exit__ absent; SOCK_STREAM/SOCK_DGRAM/SOCK_RAW members present; new to extra2446"
  kind: python_call_eq
