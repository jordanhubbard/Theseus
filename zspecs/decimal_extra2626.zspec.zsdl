spec: decimal_extra2626
version: ">=3.9"
backend: python_module(decimal)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python 3 decimal documentation — https://docs.python.org/3/library/decimal.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra.zspec.zsdl — covers existing decimal invariants"
    - "decimal_extra2611.zspec.zsdl — covers __init_subclass__/__subclasshook__/__class_getitem__ dict-presence"
  notes:
    - "Wave 622 (decimal_extra2626) theme: __length_hint__, __missing__, and __reversed__ dict-presence checks."
    - "None of the decimal classes define __length_hint__, __missing__, or __reversed__ in their own __dict__."
    - "__length_hint__ is a sized-iterator protocol method; decimal types are numeric types, not iterators."
    - "__missing__ is a dict subclass hook; decimal.Decimal, decimal.Context, and decimal.DecimalException are not dict subclasses."
    - "__reversed__ is a reverse-iteration protocol method; decimal types do not support iteration or reversal."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2626.no_length_hint_in_decimal_classes:
  description: "__length_hint__ is absent from decimal.Decimal, decimal.Context, and decimal exception class __dict__s — decimal types are not sized iterators"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2626

  columns: [id, function, args, expected]
  rows:
    - ["dc2626001", "decimal.Decimal.__dict__.__contains__",          ["__length_hint__"], false]
    - ["dc2626002", "decimal.Context.__dict__.__contains__",          ["__length_hint__"], false]
    - ["dc2626003", "decimal.DecimalException.__dict__.__contains__", ["__length_hint__"], false]

# ---------------------------------------------------------------------------
# __missing__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2626.no_missing_in_decimal_classes:
  description: "__missing__ is absent from decimal class __dict__s — decimal types are not dict subclasses"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2626

  columns: [id, function, args, expected]
  rows:
    - ["dc2626004", "decimal.Decimal.__dict__.__contains__",          ["__missing__"], false]
    - ["dc2626005", "decimal.Context.__dict__.__contains__",          ["__missing__"], false]
    - ["dc2626006", "decimal.DecimalException.__dict__.__contains__", ["__missing__"], false]

# ---------------------------------------------------------------------------
# __reversed__ dict-presence — decimal.Decimal, decimal.Context, exception classes
# ---------------------------------------------------------------------------

table decimal_extra2626.no_reversed_in_decimal_classes:
  description: "__reversed__ is absent from decimal class __dict__s — decimal types do not support reverse iteration"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2626

  columns: [id, function, args, expected]
  rows:
    - ["dc2626007", "decimal.Decimal.__dict__.__contains__",          ["__reversed__"], false]
    - ["dc2626008", "decimal.Context.__dict__.__contains__",          ["__reversed__"], false]
    - ["dc2626009", "decimal.DecimalException.__dict__.__contains__", ["__reversed__"], false]

# ---------------------------------------------------------------------------
# Complementary: decimal.Decimal and decimal.Context HAVE domain methods but NOT container/iterator protocol methods
# Confirms Decimal is a rich numeric type and Context is a configuration object, neither is a container or iterator
# ---------------------------------------------------------------------------

table decimal_extra2626.decimal_arithmetic_not_container_hooks:
  description: "decimal.Decimal defines __new__/__add__/real/sqrt but NOT __length_hint__/__missing__/__reversed__; decimal.Context defines prec/rounding/create_decimal similarly"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc2626

  columns: [id, function, args, expected]
  rows:
    - ["dc2626010", "decimal.Decimal.__dict__.__contains__", ["__new__"],         true]
    - ["dc2626011", "decimal.Decimal.__dict__.__contains__", ["__add__"],         true]
    - ["dc2626012", "decimal.Decimal.__dict__.__contains__", ["real"],            true]
    - ["dc2626013", "decimal.Decimal.__dict__.__contains__", ["sqrt"],            true]
    - ["dc2626014", "decimal.Decimal.__dict__.__contains__", ["__length_hint__"], false]
    - ["dc2626015", "decimal.Decimal.__dict__.__contains__", ["__missing__"],     false]
    - ["dc2626016", "decimal.Decimal.__dict__.__contains__", ["__reversed__"],    false]
    - ["dc2626017", "decimal.Context.__dict__.__contains__", ["prec"],            true]
    - ["dc2626018", "decimal.Context.__dict__.__contains__", ["rounding"],        true]
    - ["dc2626019", "decimal.Context.__dict__.__contains__", ["create_decimal"],  true]
    - ["dc2626020", "decimal.Context.__dict__.__contains__", ["__length_hint__"], false]
    - ["dc2626021", "decimal.Context.__dict__.__contains__", ["__missing__"],     false]
    - ["dc2626022", "decimal.Context.__dict__.__contains__", ["__reversed__"],    false]
