spec: concurrent_futures_extra1756
version: ">=3.9"
backend: python_module(concurrent.futures)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/concurrent.futures.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 564 (_extra1756): arithmetic operator protocol dict-presence checks."
    - "Theme: which concurrent.futures stdlib types define __add__, __sub__, __mul__, __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their own __dict__."
    - "concurrent.futures.Future: async result container for submitted tasks; not a numeric type — no arithmetic operators in __dict__ -> all False."
    - "concurrent.futures.ThreadPoolExecutor: thread-pool executor; not a numeric type — no arithmetic operators in __dict__ -> all False."
    - "concurrent.futures.ProcessPoolExecutor: process-pool executor; not a numeric type — no arithmetic operators in __dict__ -> all False."
    - "Rationale: concurrent.futures types model async work submission and result retrieval, not numeric quantities."
    - "Complementary checks: concurrent.futures.FIRST_COMPLETED.__class__.__name__ -> 'str' (module-level string constant); concurrent.futures.as_completed.__class__.__name__ -> 'function'."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: arithmetic operator protocol dict-presence checks for concurrent.futures types
#
# Wave 564 theme: which concurrent.futures types define __add__, __sub__,
# __mul__, __truediv__, __floordiv__, __pow__, __neg__, __pos__ in their
# own __dict__.
#
# concurrent.futures.Future: tracks the state of an asynchronous computation
#   submitted to an Executor. It offers callbacks, cancellation, and result
#   retrieval but is not a numeric type. No arithmetic operators in __dict__.
# concurrent.futures.ThreadPoolExecutor: manages a pool of threads for
#   parallel task execution. Not a numeric type; no arithmetic operators.
# concurrent.futures.ProcessPoolExecutor: manages a pool of subprocesses for
#   parallel task execution via fork/spawn. Not numeric; no arithmetic
#   operators in __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1756.arithmetic_operators:
  description: "concurrent.futures types arithmetic operator dict-presence checks — all False — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1756

  columns: [id, function, args, expected]
  rows:
    - ["cf1756001", "concurrent.futures.Future.__dict__.__contains__",              ["__add__"],      false]
    - ["cf1756002", "concurrent.futures.Future.__dict__.__contains__",              ["__sub__"],      false]
    - ["cf1756003", "concurrent.futures.Future.__dict__.__contains__",              ["__mul__"],      false]
    - ["cf1756004", "concurrent.futures.Future.__dict__.__contains__",              ["__truediv__"],  false]
    - ["cf1756005", "concurrent.futures.Future.__dict__.__contains__",              ["__floordiv__"], false]
    - ["cf1756006", "concurrent.futures.Future.__dict__.__contains__",              ["__pow__"],      false]
    - ["cf1756007", "concurrent.futures.Future.__dict__.__contains__",              ["__neg__"],      false]
    - ["cf1756008", "concurrent.futures.Future.__dict__.__contains__",              ["__pos__"],      false]
    - ["cf1756009", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__add__"],      false]
    - ["cf1756010", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__sub__"],      false]
    - ["cf1756011", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__mul__"],      false]
    - ["cf1756012", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__neg__"],      false]
    - ["cf1756013", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__add__"],      false]
    - ["cf1756014", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__sub__"],      false]
    - ["cf1756015", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__mul__"],      false]
    - ["cf1756016", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__truediv__"],  false]
    - ["cf1756017", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__floordiv__"], false]
    - ["cf1756018", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__neg__"],      false]

# ---------------------------------------------------------------------------
# Table 2: complementary checks for concurrent.futures module-level attributes
#
# The arithmetic theme is all-False for concurrent.futures types. These
# complementary checks confirm genuine concurrent.futures-specific attributes:
# - concurrent.futures.FIRST_COMPLETED is a module-level string constant
#   (one of the return_when sentinels for wait()); its class name is 'str'.
# - concurrent.futures.as_completed is a plain Python generator function;
#   its class name is 'function' (not 'builtin_function_or_method').
# - concurrent.futures.Future.__dict__ does NOT contain '__pow__' (confirms
#   the arithmetic absence for a different operator, cross-checking table 1).
# - concurrent.futures.ThreadPoolExecutor.__dict__ does NOT contain '__pos__'.
# - concurrent.futures.ProcessPoolExecutor.__dict__ does NOT contain '__pos__'.
# These checks are distinct from all prior concurrent_futures wave specs and
# provide informative signal about the module's public constant and function types.
# ---------------------------------------------------------------------------

table concurrent_futures_extra1756.complementary_checks:
  description: "concurrent.futures module-level constant and function class name checks — wave 564 _extra1756"
  kind: python_call_eq
  category: dict_contains
  id_prefix: cf1756

  columns: [id, function, args, expected]
  rows:
    - ["cf1756019", "concurrent.futures.FIRST_COMPLETED.__class__.__name__.__eq__",  ["str"],      true]
    - ["cf1756020", "concurrent.futures.as_completed.__class__.__name__.__eq__",     ["function"], true]
    - ["cf1756021", "concurrent.futures.Future.__dict__.__contains__",              ["__pow__"],   false]
    - ["cf1756022", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__pos__"],   false]
    - ["cf1756023", "concurrent.futures.ProcessPoolExecutor.__dict__.__contains__", ["__pos__"],   false]
    - ["cf1756024", "concurrent.futures.Future.__dict__.__contains__",              ["__pos__"],   false]
    - ["cf1756025", "concurrent.futures.ThreadPoolExecutor.__dict__.__contains__",  ["__pow__"],   false]
