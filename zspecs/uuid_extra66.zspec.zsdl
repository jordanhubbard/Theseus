spec: uuid_extra66
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra65.zspec.zsdl — covers UUID/__dict__/__contains__ bytes/bytes_le/fields/urn/variant/time_low / uuid1/__qualname__=='uuid1' / uuid4/__qualname__=='uuid4' / UUID/__qualname__=='UUID' (table + invariants)."
    - "uuid_extra64.zspec.zsdl — covers UUID/__dict__/__contains__ __eq__/__lt__/__hash__/hex/int/version / RESERVED_NCS/RFC_4122/RESERVED_MICROSOFT/RESERVED_FUTURE/__class__/__name__=='str' (table + invariants)."
    - "uuid_extra63.zspec.zsdl — covers UUID.__eq__/__lt__ __code__.co_name/co_argcount / uuid3/uuid5 __code__.co_name/co_argcount / NAMESPACE_DNS/URL/OID/X500/__class__/__name__=='UUID' (table + invariants)."
    - "uuid_extra62.zspec.zsdl — covers UUID.__init__/__str__/__hash__ __code__.co_name/co_argcount / uuid4/uuid1 __code__.co_name/co_argcount (table + invariants)."
    - "uuid.zspec / early extras — cover uuid.__name__/__package__ (base spec)."
  notes:
    - "This spec extends uuid through uuid_extra65; it does NOT duplicate invariants present in those files."
    - "Wave 241 theme: UUID __init__ co_varnames + SafeUUID identity."
    - "uuid.UUID.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__init__.__code__.co_varnames.__len__() == 15 — UUID.__init__ has 15 local variable slots. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__name__ == 'SafeUUID' — SafeUUID enum class name. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__module__ == 'uuid' — SafeUUID is defined in the uuid module. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__class__.__name__ == 'EnumType' — SafeUUID is an enum class whose metaclass is EnumType. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.SafeUUID.__qualname__ == 'SafeUUID' — SafeUUID has a simple qualname. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.UUID.__str__.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is a tuple. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_varnames class and length
#
# Wave 241 theme: UUID __init__ co_varnames identity.
#
# uuid.UUID.__init__.__code__.co_varnames is a tuple with 15 entries (all
# local variable names including parameters). No prior uuid spec checks
# co_varnames.__class__.__name__ or co_varnames.__len__() for UUID.__init__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra66.UUID_init_co_varnames:
  description: "uuid.UUID/__init__/__code__/co_varnames/__class__/__name__.__eq__('tuple')==True / UUID/__init__/__code__/co_varnames/__len__()==15 — UUID.__init__ co_varnames is a tuple with 15 local variable slots; no prior uuid spec checks co_varnames class or length for UUID.__init__; first co_varnames class and length anchor for UUID.__init__"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidmore66

  columns: [id, function, args, expected]
  rows:
    - [UUID_init_co_varnames_class_tuple, UUID.__init__.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]
    - [UUID_init_co_varnames_len_15,      UUID.__init__.__code__.co_varnames.__len__,                   [],        15]

# ---------------------------------------------------------------------------
# uuid.SafeUUID __name__ and __module__
#
# Wave 241 theme: SafeUUID identity.
#
# uuid.SafeUUID is an enum class defined in the uuid module. Its __name__
# is 'SafeUUID' and __module__ is 'uuid'. No prior uuid spec checks
# SafeUUID.__name__ or SafeUUID.__module__.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra66.SafeUUID_name_module:
  description: "uuid.SafeUUID/__name__.__eq__('SafeUUID')==True / SafeUUID/__module__.__eq__('uuid')==True — SafeUUID is an enum class defined in the uuid module; no prior uuid spec checks SafeUUID.__name__ or SafeUUID.__module__; first name and module anchor for SafeUUID"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuidmore66

  columns: [id, function, args, expected]
  rows:
    - [SafeUUID_name_SafeUUID, SafeUUID.__name__.__eq__,   ["SafeUUID"], true]
    - [SafeUUID_module_uuid,   SafeUUID.__module__.__eq__, ["uuid"],     true]

# ---------------------------------------------------------------------------
# uuid.SafeUUID __class__.__name__ and __qualname__
#
# Wave 241 theme: SafeUUID metaclass and qualname.
#
# uuid.SafeUUID is an enum class whose metaclass is EnumType. Its __qualname__
# is the simple string 'SafeUUID'. No prior uuid spec checks SafeUUID.__class__.__name__
# or SafeUUID.__qualname__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra66.SafeUUID_class_qualname:
  description: "uuid.SafeUUID/__class__/__name__.__eq__('EnumType')==True / SafeUUID/__qualname__.__eq__('SafeUUID')==True — SafeUUID is an enum class; its metaclass is EnumType; its qualname is 'SafeUUID'; no prior uuid spec checks SafeUUID.__class__.__name__ or SafeUUID.__qualname__; first metaclass and qualname anchor for SafeUUID"
  kind: python_call_eq
  category: class_identity
  id_prefix: uuidmore66

  columns: [id, function, args, expected]
  rows:
    - [SafeUUID_class_EnumType,    SafeUUID.__class__.__name__.__eq__, ["EnumType"], true]
    - [SafeUUID_qualname_SafeUUID, SafeUUID.__qualname__.__eq__,       ["SafeUUID"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__str__ / uuid4 / uuid1 co_varnames class
#
# Wave 241 theme: co_varnames is tuple for UUID methods and module functions.
#
# uuid.UUID.__str__.__code__.co_varnames is a tuple.
# uuid.uuid4.__code__.co_varnames is a tuple.
# uuid.uuid1.__code__.co_varnames is a tuple.
# No prior uuid spec checks co_varnames.__class__.__name__ for UUID.__str__,
# uuid4, or uuid1. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra66.str_uuid4_uuid1_co_varnames_class:
  description: "uuid.UUID/__str__/__code__/co_varnames/__class__/__name__.__eq__('tuple')==True / uuid4/__code__/co_varnames/__class__/__name__.__eq__('tuple')==True / uuid1/__code__/co_varnames/__class__/__name__.__eq__('tuple')==True — co_varnames is always a tuple for Python code objects; no prior uuid spec checks co_varnames class for UUID.__str__, uuid4, or uuid1; first co_varnames class anchor for UUID.__str__/uuid4/uuid1"
  kind: python_call_eq
  category: code_attrs
  id_prefix: uuidmore66

  columns: [id, function, args, expected]
  rows:
    - [UUID_str_co_varnames_class_tuple,  UUID.__str__.__code__.co_varnames.__class__.__name__.__eq__, ["tuple"], true]
    - [uuid4_co_varnames_class_tuple,     uuid4.__code__.co_varnames.__class__.__name__.__eq__,        ["tuple"], true]
    - [uuid1_co_varnames_class_tuple,     uuid1.__code__.co_varnames.__class__.__name__.__eq__,        ["tuple"], true]

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_varnames.__class__.__name__ == 'tuple' — standalone
#
# uuid.UUID.__init__.__code__.co_varnames is a tuple. No prior uuid spec checks
# co_varnames.__class__.__name__ for UUID.__init__. First co_varnames class
# standalone for UUID.__init__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra66.UUID_init_co_varnames_class_tuple:
  description: "uuid.UUID.__init__.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is always a tuple; no prior uuid spec checks co_varnames class for UUID.__init__; first co_varnames class standalone for UUID.__init__"
  category: code_attrs
  kind: python_call_eq
  function: UUID.__init__.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.UUID.__init__.__code__.co_varnames.__len__() == 15 — standalone
#
# uuid.UUID.__init__.__code__.co_varnames has 15 entries. No prior uuid spec
# checks co_varnames.__len__() for UUID.__init__. First co_varnames length
# standalone for UUID.__init__. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra66.UUID_init_co_varnames_len_15:
  description: "uuid.UUID.__init__.__code__.co_varnames.__len__() == 15 — UUID.__init__ has 15 local variable slots; no prior uuid spec checks co_varnames length for UUID.__init__; first co_varnames length standalone for UUID.__init__"
  category: code_attrs
  kind: python_call_eq
  function: UUID.__init__.__code__.co_varnames.__len__
  args: []
  expected: 15

# ---------------------------------------------------------------------------
