invariant uuid_extra66.uuid4_co_varnames_class_tuple:
  description: "uuid.uuid4.__code__.co_varnames.__class__.__name__.__eq__('tuple') == True — co_varnames is a tuple for all Python code objects; no prior uuid spec checks co_varnames class for uuid4; first co_varnames class standalone for uuid4"
  category: code_attrs
  kind: python_call_eq
  function: uuid4.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
