# ---------------------------------------------------------------------------
# uuid.uuid4.__code__.co_varnames.__class__.__name__.__eq__('tuple') — standalone
#
# uuid.uuid4.__code__.co_varnames is a tuple. No prior uuid spec checks
# co_varnames.__class__.__name__ for uuid4. First co_varnames class standalone
