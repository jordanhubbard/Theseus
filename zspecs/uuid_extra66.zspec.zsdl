invariant uuid_extra66.SafeUUID_name_SafeUUID:
  description: "uuid.SafeUUID.__name__.__eq__('SafeUUID') == True — SafeUUID enum class has __name__ 'SafeUUID'; no prior uuid spec checks SafeUUID.__name__; first __name__ standalone for SafeUUID"
  category: class_identity
  kind: python_call_eq
  function: SafeUUID.__name__.__eq__
  args: ["SafeUUID"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__class__.__name__.__eq__('EnumType') — standalone
#
# uuid.SafeUUID is an enum class whose metaclass is EnumType. No prior uuid
