invariant uuid_extra66.SafeUUID_class_EnumType:
  description: "uuid.SafeUUID.__class__.__name__.__eq__('EnumType') == True — SafeUUID is an enum class with metaclass EnumType; no prior uuid spec checks SafeUUID.__class__.__name__; first metaclass standalone for SafeUUID"
  category: class_identity
  kind: python_call_eq
  function: SafeUUID.__class__.__name__.__eq__
  args: ["EnumType"]
