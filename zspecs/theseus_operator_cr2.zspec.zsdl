spec: theseus_operator_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_operator_cr2)
blocks: operator

docs: https://docs.python.org/3/library/operator.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/operator.html"
  notes:
    - "Clean-room extended operator utilities. Do NOT import operator."
    - "attrgetter(*attrs): return callable that fetches attr(s) from its operand."
    - "itemgetter(*items): return callable that fetches item(s) from its operand."
    - "methodcaller(name, *args, **kwargs): return callable that calls method on its operand."
    - "operator2_attrgetter(): attrgetter('x')(SimpleNamespace(x=42)) == 42."
    - "operator2_itemgetter(): itemgetter(1)([10,20,30]) == 20."
    - "operator2_methodcaller(): methodcaller('upper')('hello') == 'HELLO'."
    - "attrgetter: return lambda obj: getattr(obj, attr)."
    - "itemgetter: return lambda obj: obj[item]."
    - "methodcaller: return lambda obj: getattr(obj, name)(*args, **kwargs)."
    - "Export: attrgetter, itemgetter, methodcaller."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_operator_cr2.attrgetter:
  description: "attrgetter('x')(obj) == obj.x"
  category: attrgetter
  kind: python_call_eq
  function: operator2_attrgetter
  args: []
  expected: 42

invariant theseus_operator_cr2.itemgetter:
  description: "itemgetter(1)([10,20,30]) == 20"
  category: itemgetter
  kind: python_call_eq
  function: operator2_itemgetter
  args: []
  expected: 20

invariant theseus_operator_cr2.methodcaller:
  description: "methodcaller('upper')('hello') == 'HELLO'"
  category: methodcaller
  kind: python_call_eq
  function: operator2_methodcaller
  args: []
  expected: "HELLO"
