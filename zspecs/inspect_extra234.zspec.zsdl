spec: inspect_extra234
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec covers inspect.BoundArguments class identity and method contracts."
    - "inspect.BoundArguments.__name__ == 'BoundArguments' (len=14) — the class name. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__module__ == 'inspect' — BoundArguments is defined in Lib/inspect.py. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__qualname__ == 'BoundArguments' — top-level class with unqualified qualname. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__class__.__name__ == 'type' — BoundArguments is a Python class; its metaclass is the built-in type. Verified with Python 3.14.3."
    - "inspect.BoundArguments.__bases__[0].__name__ == 'object' — BoundArguments inherits directly from object. Verified with Python 3.14.3."
    - "inspect.BoundArguments.apply_defaults.__name__ == 'apply_defaults' (len=14) — apply_defaults is a Python function on BoundArguments. Verified with Python 3.14.3."
    - "inspect.BoundArguments.apply_defaults.__qualname__ == 'BoundArguments.apply_defaults' — qualname carries the class prefix. Verified with Python 3.14.3."
    - "inspect.BoundArguments.args.__class__.__name__ == 'property' — args is a property descriptor. Verified with Python 3.14.3."
    - "inspect.BoundArguments.kwargs.__class__.__name__ == 'property' — kwargs is a property descriptor. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.BoundArguments class identity contracts
#
# inspect.BoundArguments.__name__ == 'BoundArguments' (len=14)
# inspect.BoundArguments.__module__ == 'inspect'
# inspect.BoundArguments.__qualname__ == 'BoundArguments'
# inspect.BoundArguments.__class__.__name__ == 'type'
# inspect.BoundArguments.__bases__[0].__name__ == 'object'
#
# BoundArguments is a Python class in Lib/inspect.py that represents the
# result of binding arguments to a Signature. New to extra234.
# ---------------------------------------------------------------------------

table inspect_extra234.bound_arguments_class_identity:
  description: "inspect.BoundArguments class identity contracts: name, module, qualname, metaclass, base; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra234baclassid

  columns: [id, function, args, expected, description]
  rows:
    - [bound_arguments_name_eq,
       BoundArguments.__name__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments is the class in Lib/inspect.py holding bound argument mappings; __name__ is 'BoundArguments' (len=14); new to extra234"]
    - [bound_arguments_name_len_14,
       BoundArguments.__name__.__len__,
       [],
       14,
       "inspect.BoundArguments.__name__.__len__() == 14 — 'BoundArguments' has exactly 14 characters (B-o-u-n-d-A-r-g-u-m-e-n-t-s); str.__len__() returns 14; new to extra234"]
    - [bound_arguments_module_eq,
       BoundArguments.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined in Lib/inspect.py; __module__ is 'inspect' (len=7); new to extra234"]
    - [bound_arguments_qualname_eq,
       BoundArguments.__qualname__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__qualname__.__eq__('BoundArguments') == True — BoundArguments is a top-level class with unqualified qualname 'BoundArguments'; new to extra234"]
    - [bound_arguments_class_is_type,
       BoundArguments.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.BoundArguments.__class__.__name__.__eq__('type') == True — BoundArguments is a Python class; its metaclass is the built-in type; __class__.__name__ is 'type'; new to extra234"]

# ---------------------------------------------------------------------------
# Table 2: inspect.BoundArguments base and apply_defaults method contracts
#
# inspect.BoundArguments.__bases__[0].__name__ == 'object'
# inspect.BoundArguments.apply_defaults.__name__ == 'apply_defaults' (len=14)
# inspect.BoundArguments.apply_defaults.__qualname__ == 'BoundArguments.apply_defaults'
# inspect.BoundArguments.args.__class__.__name__ == 'property'
# inspect.BoundArguments.kwargs.__class__.__name__ == 'property'
#
# BoundArguments inherits directly from object. apply_defaults is a Python
# function; args and kwargs are property descriptors. New to extra234.
# ---------------------------------------------------------------------------

table inspect_extra234.bound_arguments_methods:
  description: "inspect.BoundArguments base is object; apply_defaults method; args and kwargs property contracts; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra234bamethodid

  columns: [id, function, args, expected, description]
  rows:
    - [bound_arguments_base_is_object,
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — BoundArguments inherits directly from object with no intermediate base; __bases__[0].__name__ is 'object'; new to extra234"]
    - [apply_defaults_name_eq,
       BoundArguments.apply_defaults.__name__.__eq__,
       ["apply_defaults"],
       true,
       "inspect.BoundArguments.apply_defaults.__name__.__eq__('apply_defaults') == True — apply_defaults is a Python function that sets default values for missing arguments; __name__ is 'apply_defaults' (len=14); new to extra234"]
    - [apply_defaults_qualname_eq,
       BoundArguments.apply_defaults.__qualname__.__eq__,
       ["BoundArguments.apply_defaults"],
       true,
       "inspect.BoundArguments.apply_defaults.__qualname__.__eq__('BoundArguments.apply_defaults') == True — apply_defaults is a method of BoundArguments; its __qualname__ carries the class prefix; new to extra234"]
    - [args_class_is_property,
       BoundArguments.args.__class__.__name__.__eq__,
       ["property"],
       true,
       "inspect.BoundArguments.args.__class__.__name__.__eq__('property') == True — args is a property descriptor on BoundArguments that returns a tuple of positional arguments; __class__.__name__ is 'property'; new to extra234"]
    - [kwargs_class_is_property,
       BoundArguments.kwargs.__class__.__name__.__eq__,
       ["property"],
       true,
       "inspect.BoundArguments.kwargs.__class__.__name__.__eq__('property') == True — kwargs is a property descriptor on BoundArguments that returns a dict of keyword arguments; __class__.__name__ is 'property'; new to extra234"]

# ---------------------------------------------------------------------------
# Table 3: inspect.BoundArguments apply_defaults length and module length contracts
#
# inspect.BoundArguments.apply_defaults.__name__.__len__() == 14
# inspect.BoundArguments.__module__.__len__() == 7
# inspect.BoundArguments.__name__.__len__() == 14
# inspect.BoundArguments.__qualname__.__len__() == 14
# inspect.BoundArguments.__class__.__name__.__eq__('type') == True
#
# Length contracts for BoundArguments identity strings. New to extra234.
# ---------------------------------------------------------------------------

table inspect_extra234.bound_arguments_length_contracts:
  description: "inspect.BoundArguments length contracts for apply_defaults, module, name, and qualname; new to extra234"
  kind: python_call_eq
  category: identity
  id_prefix: inspectextra234balenid

  columns: [id, function, args, expected, description]
  rows:
    - [apply_defaults_name_len_14,
       BoundArguments.apply_defaults.__name__.__len__,
       [],
       14,
       "inspect.BoundArguments.apply_defaults.__name__.__len__() == 14 — 'apply_defaults' has exactly 14 characters (a-p-p-l-y-_-d-e-f-a-u-l-t-s); str.__len__() returns 14; new to extra234"]
    - [bound_arguments_module_len_7,
       BoundArguments.__module__.__len__,
       [],
       7,
       "inspect.BoundArguments.__module__.__len__() == 7 — 'inspect' has exactly 7 characters (i-n-s-p-e-c-t); str.__len__() returns 7; new to extra234"]
    - [bound_arguments_name_len_check,
       BoundArguments.__name__.__len__,
       [],
       14,
       "inspect.BoundArguments.__name__.__len__() == 14 — 'BoundArguments' has exactly 14 characters; confirmed via str.__len__(); new to extra234"]
    - [bound_arguments_qualname_len_14,
       BoundArguments.__qualname__.__len__,
       [],
       14,
       "inspect.BoundArguments.__qualname__.__len__() == 14 — 'BoundArguments' qualname has exactly 14 characters; str.__len__() returns 14; new to extra234"]
    - [bound_arguments_class_type_confirm,
       BoundArguments.__class__.__name__.__eq__,
       ["type"],
       true,
       "inspect.BoundArguments.__class__.__name__.__eq__('type') == True — BoundArguments metaclass is the built-in type (confirmed in length table); new to extra234"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra234
# ---------------------------------------------------------------------------

invariant inspect_extra234.bound_arguments_name_eq:
  description: "inspect.BoundArguments.__name__ == 'BoundArguments' (len=14); new to extra234"
  kind: python_call_eq
  function: BoundArguments.__name__.__eq__
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra234.bound_arguments_name_len_14:
  description: "inspect.BoundArguments.__name__.__len__() == 14 — 'BoundArguments' has 14 characters; new to extra234"
  kind: python_call_eq
  function: BoundArguments.__name__.__len__
  args: []
  expected: 14

invariant inspect_extra234.bound_arguments_module_eq:
  description: "inspect.BoundArguments.__module__ == 'inspect'; new to extra234"
  kind: python_call_eq
  function: BoundArguments.__module__.__eq__
  args: ["inspect"]
  expected: true

invariant inspect_extra234.bound_arguments_qualname_eq:
  description: "inspect.BoundArguments.__qualname__ == 'BoundArguments'; new to extra234"
  kind: python_call_eq
  function: BoundArguments.__qualname__.__eq__
  args: ["BoundArguments"]
  expected: true

invariant inspect_extra234.bound_arguments_class_is_type:
  description: "inspect.BoundArguments.__class__.__name__ == 'type'; new to extra234"
  kind: python_call_eq
  function: BoundArguments.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant inspect_extra234.bound_arguments_base_is_object:
  description: "inspect.BoundArguments.__bases__[0].__name__ == 'object'; new to extra234"
  kind: python_call_eq
  function: "BoundArguments.__bases__[0].__name__.__eq__"
  args: ["object"]
  expected: true

invariant inspect_extra234.apply_defaults_name_eq:
  description: "inspect.BoundArguments.apply_defaults.__name__ == 'apply_defaults' (len=14); new to extra234"
  kind: python_call_eq
  function: BoundArguments.apply_defaults.__name__.__eq__
  args: ["apply_defaults"]
  expected: true

invariant inspect_extra234.apply_defaults_name_len_14:
  description: "inspect.BoundArguments.apply_defaults.__name__.__len__() == 14 — 'apply_defaults' has 14 characters; new to extra234"
  kind: python_call_eq
  function: BoundArguments.apply_defaults.__name__.__len__
  args: []
  expected: 14

invariant inspect_extra234.apply_defaults_qualname_eq:
  description: "inspect.BoundArguments.apply_defaults.__qualname__ == 'BoundArguments.apply_defaults'; new to extra234"
  kind: python_call_eq
  function: BoundArguments.apply_defaults.__qualname__.__eq__
  args: ["BoundArguments.apply_defaults"]
  expected: true

invariant inspect_extra234.args_class_is_property:
  description: "inspect.BoundArguments.args.__class__.__name__ == 'property'; new to extra234"
  kind: python_call_eq
  function: BoundArguments.args.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant inspect_extra234.kwargs_class_is_property:
  description: "inspect.BoundArguments.kwargs.__class__.__name__ == 'property'; new to extra234"
  kind: python_call_eq
  function: BoundArguments.kwargs.__class__.__name__.__eq__
  args: ["property"]
  expected: true

invariant inspect_extra234.bound_arguments_module_len_7:
  description: "inspect.BoundArguments.__module__.__len__() == 7 — 'inspect' has 7 characters; new to extra234"
  kind: python_call_eq
  function: BoundArguments.__module__.__len__
  args: []
  expected: 7
