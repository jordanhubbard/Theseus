  notes:
    - "TensorFlow is a deep learning framework."
    - "tf.constant([1.0, 2.0, 3.0]).numpy().tolist() == [1.0, 2.0, 3.0]."
    - "tf.reduce_sum([1.0, 2.0, 3.0]).numpy() == 6.0."
    - "tf.reduce_mean([1.0, 2.0, 3.0]).numpy() == 2.0."
    - "tf.shape(tf.constant([[1,2],[3,4]]))[0].numpy() == 2."
    - "Expose tf_sum(lst) -> float: float(tf.reduce_sum(lst).numpy())."
    - "Expose tf_mean(lst) -> float: float(tf.reduce_mean(lst).numpy())."
    - "Expose tf_len(lst) -> int: len(tf.constant(lst).numpy())."
    - "All test vectors verified against tensorflow 2.19.0."
  created_at: "2026-04-19T00:00:00Z"

