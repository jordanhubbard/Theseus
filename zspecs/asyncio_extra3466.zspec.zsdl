    - ["as3466009", operator.contains, [asyncio.PriorityQueue.__dict__,    "__iter__"], false]
    - ["as3466010", operator.contains, [asyncio.LifoQueue.__dict__,        "__iter__"], false]

# ---------------------------------------------------------------------------
# __next__ dict-presence — operator.contains(Cls.__dict__, '__next__')
#
# All 10 asyncio classes return false for __next__.
# next(x) delegates to __next__ when defined in the class's own __dict__.
# asyncio types do not define __next__ in their own __dict__; iterator
#   advancement is not supported as part of the asyncio public API.
# asyncio.Task/Future: results are retrieved via result()/exception();
#   no __next__ defined in their own __dict__.
# asyncio.Event/Lock/Condition: synchronization state managed via
#   set()/clear()/acquire()/release(); no __next__ in their own __dict__.
# asyncio.Semaphore/BoundedSemaphore: permit-count guards with no __next__
#   defined at the class level in their own __dict__.
# asyncio.Queue/PriorityQueue/LifoQueue: item stores with no __next__
#   in their own __dict__; items are dequeued via get() coroutines.
# ---------------------------------------------------------------------------

