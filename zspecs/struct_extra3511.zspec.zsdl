spec: st3511
version: ">=3.9"
backend: python_module(struct)
docs: https://docs.python.org/3/library/struct.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — struct module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 681 (st3511): __get__, __set__, __delete__ dict-presence checks for struct types."
    - "All values false — struct.Struct does not implement the descriptor protocol."
    - "struct.Struct is a C-level type (_struct.Struct); it does not define __get__, __set__, or __delete__ in its own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __get__ dict-presence — operator.contains(Cls.__dict__, '__get__')
# ---------------------------------------------------------------------------

table st3511.get:
  description: "struct.Struct __get__ dict-presence checks; wave 681"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: st3511
  columns: [id, function, args, expected]
  rows:
    - ["st3511001", operator.contains, [struct.Struct.__dict__, "__get__"], false]

