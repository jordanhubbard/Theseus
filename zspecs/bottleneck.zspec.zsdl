spec: bottleneck
version: ">=2.0.0"
backend: node(bottleneck)

docs: https://github.com/SGrondin/bottleneck#readme

provenance:
  derived_from:
    - "bottleneck README — https://github.com/SGrondin/bottleneck#readme"
    - "Test vectors verified with bottleneck via Node.js 22 on macOS Darwin 25.4.0, 2026-04-25"
  not_derived_from:
    - "bottleneck source"
  notes:
    - "Task scheduler & rate limiter for Node and the browser."
    - "Install: npm install bottleneck"
    - "v2 CJS; require('bottleneck') returns the Bottleneck class directly."
    - "Constructor: new Bottleneck({maxConcurrent, minTime, ...})"
  created_at: "2026-04-25T00:00:00Z"

error_model:
  semantics: "Constructor accepts options; never throws on valid options."
  stderr: "null"
  stickiness: "N/A — each limiter independent."
  codes: {}

invariant bottleneck.empty_initially:
  description: "New limiter is empty()"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{maxConcurrent: 2, minTime: 100}]
  chain:
    - {method: empty, args: []}
  expected: true

invariant bottleneck.queued_zero_initially:
  description: "New limiter has queued() == 0"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{maxConcurrent: 2}]
  chain:
    - {method: queued, args: []}
  expected: 0

invariant bottleneck.counts_received:
  description: "counts().RECEIVED is 0 for fresh limiter"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{maxConcurrent: 2}]
  chain:
    - {method: counts, args: []}
    - {get: RECEIVED}
  expected: 0

invariant bottleneck.counts_queued:
  description: "counts().QUEUED is 0 for fresh limiter"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{maxConcurrent: 2}]
  chain:
    - {method: counts, args: []}
    - {get: QUEUED}
  expected: 0

invariant bottleneck.counts_running:
  description: "counts().RUNNING is 0 for fresh limiter"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{maxConcurrent: 2}]
  chain:
    - {method: counts, args: []}
    - {get: RUNNING}
  expected: 0

invariant bottleneck.counts_executing:
  description: "counts().EXECUTING is 0 for fresh limiter"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{maxConcurrent: 2}]
  chain:
    - {method: counts, args: []}
    - {get: EXECUTING}
  expected: 0

invariant bottleneck.jobs_empty:
  description: "jobs() returns an empty array for fresh limiter (length 0)"
  category: state
  kind: node_chain_eq
  entry: constructor
  class: ""
  entry_args: [{maxConcurrent: 2}]
  chain:
    - {method: jobs, args: []}
    - {get: length}
  expected: 0
