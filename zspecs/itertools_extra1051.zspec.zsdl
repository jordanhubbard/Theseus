spec: itertools_extra1051
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks itertools error conditions and type introspection for chain, combinations, count"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table itertools_extra1051.error_conditions:
  description: "itertools error conditions that must raise"
  kind: python_call_raises
  category: error_conditions
  id_prefix: it1051x
  columns: [id, function, args, expected]
  rows:
    - [it1051x001, itertools.combinations,                        [[1, 2, 3], -1],                  ValueError]
    - [it1051x002, itertools.combinations,                        [[1, 2], -5],                     ValueError]
    - [it1051x003, itertools.permutations,                        [[1, 2, 3], -1],                  ValueError]
    - [it1051x004, itertools.permutations,                        [[1, 2], -3],                     ValueError]
    - [it1051x005, itertools.combinations_with_replacement,       [[1, 2, 3], -1],                  ValueError]
    - [it1051x006, itertools.combinations_with_replacement,       [["a", "b"], -2],                 ValueError]
    - [it1051x007, itertools.islice,                              [[1, 2, 3], 0, 10, 0],            ValueError]

table itertools_extra1051.class_introspection:
  description: "itertools class and qualname identity checks"
  kind: python_call_eq
  category: class_introspection
  id_prefix: it1051c
  columns: [id, function, args, expected]
  rows:
    - [it1051c001, itertools.chain.__qualname__.__eq__,                     ["chain"],                    true]
    - [it1051c002, itertools.chain.__module__.__eq__,                       ["itertools"],                true]
    - [it1051c003, itertools.chain.from_iterable.__qualname__.__eq__,       ["chain.from_iterable"],      true]
    - [it1051c004, itertools.combinations.__qualname__.__eq__,              ["combinations"],             true]
    - [it1051c005, itertools.combinations.__module__.__eq__,                ["itertools"],                true]
    - [it1051c006, itertools.combinations.__new__.__qualname__.__eq__,      ["combinations.__new__"],     true]
    - [it1051c007, itertools.count.__qualname__.__eq__,                     ["count"],                    true]
    - [it1051c008, itertools.count.__module__.__eq__,                       ["itertools"],                true]

table itertools_extra1051.instance_introspection:
  description: "itertools instance class name checks"
  kind: python_call_eq
  category: instance_introspection
  id_prefix: it1051i
  columns: [id, function, args, expected]
  rows:
    - [it1051i001, itertools.count.__class__.__name__.__eq__,               ["type"],                    true]
    - [it1051i002, itertools.chain.__class__.__name__.__eq__,               ["type"],                    true]
    - [it1051i003, itertools.combinations.__class__.__name__.__eq__,        ["type"],                    true]
    - [it1051i004, itertools.permutations.__class__.__name__.__eq__,        ["type"],                    true]
    - [it1051i005, itertools.permutations.__module__.__eq__,                ["itertools"],               true]
    - [it1051i006, itertools.islice.__class__.__name__.__eq__,              ["type"],                    true]
    - [it1051i007, itertools.islice.__module__.__eq__,                      ["itertools"],               true]
    - [it1051i008, itertools.combinations_with_replacement.__module__.__eq__, ["itertools"],             true]
