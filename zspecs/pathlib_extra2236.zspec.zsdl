spec: pathlib_extra2236
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "CPython source: Lib/pathlib.py"
    - "pathlib.zspec.zsdl"
  notes:
    - "Wave _extra2236: __slots__ and slot descriptor protocol checks for pathlib classes."
    - "Covers __slots__, __weakref__, __dict__, __abstractmethods__, __init__, __new__, __subclasshook__ presence in pathlib class dicts."
    - "pathlib.PurePath defines __slots__, __init__, and __new__ in its own __dict__; no __weakref__, __dict__, __abstractmethods__, or __subclasshook__."
    - "pathlib.PurePosixPath and pathlib.PureWindowsPath define __slots__ but neither __init__ nor __new__ in their own __dict__."
    - "pathlib.Path defines __slots__ and __new__ but not __init__ in its own __dict__."
    - "None of these pure-Python classes expose __weakref__ or __dict__ descriptors in their own __dict__ because __slots__ suppresses the instance __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table pathlib_extra2236.PurePath_slot_protocol:
  description: "pathlib.PurePath __slots__/__weakref__/__dict__/__abstractmethods__/__init__/__new__/__subclasshook__ dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2236

  columns: [id, function, args, expected]
  rows:
    - ["pl2236001", "pathlib.PurePath.__dict__.__contains__", ["__slots__"], true]
    - ["pl2236002", "pathlib.PurePath.__dict__.__contains__", ["__weakref__"], false]
    - ["pl2236003", "pathlib.PurePath.__dict__.__contains__", ["__dict__"], false]
    - ["pl2236004", "pathlib.PurePath.__dict__.__contains__", ["__abstractmethods__"], false]
    - ["pl2236005", "pathlib.PurePath.__dict__.__contains__", ["__init__"], true]
    - ["pl2236006", "pathlib.PurePath.__dict__.__contains__", ["__new__"], true]
    - ["pl2236007", "pathlib.PurePath.__dict__.__contains__", ["__subclasshook__"], false]

