spec: decimal_extra128
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec covers: decimal exception class __bases__[0].__name__ equality for the full exception hierarchy."
    - "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' — DecimalException is the root of the decimal exception hierarchy and directly extends ArithmeticError."
    - "decimal.InvalidOperation.__bases__[0].__name__ == 'DecimalException' — InvalidOperation extends DecimalException directly."
    - "decimal.Clamped.__bases__[0].__name__ == 'DecimalException' — Clamped extends DecimalException directly."
    - "decimal.Rounded.__bases__[0].__name__ == 'DecimalException' — Rounded extends DecimalException directly."
    - "decimal.Subnormal.__bases__[0].__name__ == 'DecimalException' — Subnormal extends DecimalException directly."
    - "decimal.Inexact.__bases__[0].__name__ == 'DecimalException' — Inexact extends DecimalException directly."
    - "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' — DivisionByZero has two bases: [DecimalException, ZeroDivisionError]; __bases__[0] is DecimalException."
    - "decimal.Overflow.__bases__[0].__name__ == 'Inexact' — Overflow has two bases: [Inexact, Rounded]; __bases__[0] is Inexact."
    - "decimal.Underflow.__bases__[0].__name__ == 'Inexact' — Underflow has three bases: [Inexact, Rounded, Subnormal]; __bases__[0] is Inexact."
    - "decimal.DecimalException.__mro__.__len__() == 5 — MRO is [DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "decimal.Overflow.__mro__.__len__() == 8 — MRO is [Overflow, Inexact, Rounded, DecimalException, ArithmeticError, Exception, BaseException, object]."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal exception root: DecimalException and direct subclasses that extend
# DecimalException as their sole base.
# DecimalException.__bases__[0].__name__ == 'ArithmeticError'.
# InvalidOperation, Clamped, Rounded, Subnormal, Inexact all have
# __bases__[0].__name__ == 'DecimalException'.
# ---------------------------------------------------------------------------

table decimal_extra128.exception_bases_single_parent:
  description: "decimal exception classes with DecimalException as first base: InvalidOperation, Clamped, Rounded, Subnormal, Inexact; and DecimalException.__bases__[0].__name__ == 'ArithmeticError'"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: decexcbase128

  columns: [id, function, args, expected]
  rows:
    - [de_base_eq,   "DecimalException.__bases__[0].__name__.__eq__",  ["ArithmeticError"],    true]
    - [de_base_not,  "DecimalException.__bases__[0].__name__.__eq__",  ["Exception"],          false]
    - [io_base_eq,   "InvalidOperation.__bases__[0].__name__.__eq__",  ["DecimalException"],   true]
    - [cl_base_eq,   "Clamped.__bases__[0].__name__.__eq__",           ["DecimalException"],   true]
    - [rnd_base_eq,  "Rounded.__bases__[0].__name__.__eq__",           ["DecimalException"],   true]
    - [sub_base_eq,  "Subnormal.__bases__[0].__name__.__eq__",         ["DecimalException"],   true]
    - [inx_base_eq,  "Inexact.__bases__[0].__name__.__eq__",           ["DecimalException"],   true]
    - [io_base_not,  "InvalidOperation.__bases__[0].__name__.__eq__",  ["ArithmeticError"],    false]

# ---------------------------------------------------------------------------
# decimal exception classes with multiple bases (DivisionByZero, Overflow,
# Underflow). These have __bases__[0].__name__ as the primary decimal base.
# DivisionByZero.__bases__[0] == DecimalException (second base: ZeroDivisionError).
# Overflow.__bases__[0] == Inexact (second base: Rounded).
# Underflow.__bases__[0] == Inexact (second base: Rounded, third: Subnormal).
# ---------------------------------------------------------------------------

table decimal_extra128.exception_bases_multiple_parents:
  description: "decimal exceptions with multiple bases: DivisionByZero.__bases__[0].__name__='DecimalException', Overflow.__bases__[0].__name__='Inexact', Underflow.__bases__[0].__name__='Inexact'"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: decexcbase128

  columns: [id, function, args, expected]
  rows:
    - [dbz_base0_eq,  "DivisionByZero.__bases__[0].__name__.__eq__",  ["DecimalException"], true]
    - [dbz_base0_not, "DivisionByZero.__bases__[0].__name__.__eq__",  ["Inexact"],          false]
    - [ov_base0_eq,   "Overflow.__bases__[0].__name__.__eq__",        ["Inexact"],          true]
    - [ov_base0_not,  "Overflow.__bases__[0].__name__.__eq__",        ["DecimalException"], false]
    - [uf_base0_eq,   "Underflow.__bases__[0].__name__.__eq__",       ["Inexact"],          true]
    - [uf_base0_not,  "Underflow.__bases__[0].__name__.__eq__",       ["Rounded"],          false]

# ---------------------------------------------------------------------------
# decimal exception class MRO lengths
# DecimalException.__mro__.__len__() == 5 (5 entries: DecimalException through object).
# InvalidOperation.__mro__.__len__() == 6 (6 entries: InvalidOperation through object).
# Overflow.__mro__.__len__() == 8 (complex MRO due to multiple bases).
# ---------------------------------------------------------------------------

table decimal_extra128.exception_mro_lengths:
  description: "decimal exception class MRO lengths: DecimalException=5, InvalidOperation=6, Clamped=6, Rounded=6, Inexact=6, DivisionByZero=7, Overflow=8"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: decexcbase128

  columns: [id, function, args, expected]
  rows:
    - [de_mro_len,   DecimalException.__mro__.__len__,   [], 5]
    - [io_mro_len,   InvalidOperation.__mro__.__len__,   [], 6]
    - [cl_mro_len,   Clamped.__mro__.__len__,            [], 6]
    - [rnd_mro_len,  Rounded.__mro__.__len__,            [], 6]
    - [inx_mro_len,  Inexact.__mro__.__len__,            [], 6]
    - [dbz_mro_len,  DivisionByZero.__mro__.__len__,     [], 7]
    - [ov_mro_len,   Overflow.__mro__.__len__,           [], 8]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra128.DecimalException.base_is_ArithmeticError:
  description: "decimal.DecimalException.__bases__[0].__name__ == 'ArithmeticError' (DecimalException is the root of the decimal exception hierarchy and directly extends Python's built-in ArithmeticError)"
  category: class_hierarchy
  kind: python_call_eq
  function: DecimalException.__bases__[0].__name__.__eq__
  args: ["ArithmeticError"]
  expected: true

invariant decimal_extra128.Overflow.base_is_Inexact:
  description: "decimal.Overflow.__bases__[0].__name__ == 'Inexact' (Overflow has two bases: [Inexact, Rounded]; Inexact is first because Overflow is an inexact result that is also rounded and out of range)"
  category: class_hierarchy
  kind: python_call_eq
  function: Overflow.__bases__[0].__name__.__eq__
  args: ["Inexact"]
  expected: true

invariant decimal_extra128.DecimalException.mro_len_5:
  description: "decimal.DecimalException.__mro__.__len__() == 5 (MRO is [DecimalException, ArithmeticError, Exception, BaseException, object])"
  category: class_hierarchy
  kind: python_call_eq
  function: DecimalException.__mro__.__len__
  args: []
  expected: 5

invariant decimal_extra128.DivisionByZero.base_is_DecimalException:
  description: "decimal.DivisionByZero.__bases__[0].__name__ == 'DecimalException' (DivisionByZero inherits from both DecimalException and ZeroDivisionError; DecimalException is the primary decimal base)"
  category: class_hierarchy
  kind: python_call_eq
  function: DivisionByZero.__bases__[0].__name__.__eq__
  args: ["DecimalException"]
  expected: true

invariant decimal_extra128.Overflow.mro_len_8:
  description: "decimal.Overflow.__mro__.__len__() == 8 (MRO is [Overflow, Inexact, Rounded, DecimalException, ArithmeticError, Exception, BaseException, object] — longest of all decimal exceptions)"
  category: class_hierarchy
  kind: python_call_eq
  function: Overflow.__mro__.__len__
  args: []
  expected: 8

