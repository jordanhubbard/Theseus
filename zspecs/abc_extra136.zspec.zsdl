table abc_extra136.spec_metadata:
  description: "abc module spec metadata checks — __spec__.__class__.__name__.__eq__('ModuleSpec')==True (len=10: 'Module'=6+'Spec'=4=10); __spec__.name.__eq__('abc')==True (len=3: the canonical module name); abc.__package__ is '' (empty string, len=0) because abc is a top-level single-file module, not a package — distinct from asyncio and multiprocessing which have non-empty __package__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcspec136

  columns: [id, function, args, expected, description]
  rows:
    - [spec_cls_eq,   abc.__spec__.__class__.__name__.__eq__,  ["ModuleSpec"],  true,  "abc.__spec__.__class__.__name__ == 'ModuleSpec' (len=10); verified with Python 3.14.3"]
    - [spec_cls_len,  abc.__spec__.__class__.__name__.__len__,  [],             10,    "abc.__spec__.__class__.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [spec_name_eq,  abc.__spec__.name.__eq__,                ["abc"],         true,  "abc.__spec__.name == 'abc' (len=3); verified with Python 3.14.3"]
    - [spec_name_len, abc.__spec__.name.__len__,                [],             3,     "abc.__spec__.name.__len__() == 3; verified with Python 3.14.3"]
    - [pkg_len,       abc.__package__.__len__,                  [],             0,     "abc.__package__.__len__() == 0 (empty string; abc is a top-level module, not a package); verified with Python 3.14.3"]

