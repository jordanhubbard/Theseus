  description: "abc.ABCMeta identity and __new__ method code checks — ABCMeta.__name__.__eq__('ABCMeta')==True (len=7: 'ABC'=3+'Meta'=4=7); ABCMeta.__module__.__eq__('abc')==True (len=3); ABCMeta.__bases__[0].__name__.__eq__('type')==True (ABCMeta is a subclass of type — it is a metaclass); ABCMeta.__new__.__qualname__.__eq__('ABCMeta.__new__')==True (len=15: 'ABCMeta'=7+'.'=1+'__new__'=7=15); ABCMeta.__new__.__code__.co_argcount==4 ('mcls','name','bases','namespace'); ABCMeta.__new__.__code__.co_varnames.__len__()==6 (adds 'kwargs','cls' as locals); 'cls' in co_varnames; 'mcls' in co_varnames; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcmetanew136

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,      abc.ABCMeta.__name__.__eq__,                                 ["ABCMeta"],         true, "ABCMeta.__name__ == 'ABCMeta' (len=7); verified with Python 3.14.3"]
    - [name_len,     abc.ABCMeta.__name__.__len__,                                 [],                 7,    "ABCMeta.__name__.__len__() == 7; verified with Python 3.14.3"]
    - [mod_eq,       abc.ABCMeta.__module__.__eq__,                               ["abc"],              true, "ABCMeta.__module__ == 'abc' (len=3); verified with Python 3.14.3"]
    - ["base_name",  "abc.ABCMeta.__bases__[0].__name__.__eq__",                   ["type"],            true, "ABCMeta.__bases__[0].__name__ == 'type' (ABCMeta is a metaclass, subclass of type); verified with Python 3.14.3"]
    - [new_qn_len,   abc.ABCMeta.__new__.__qualname__.__len__,                     [],                 15,   "ABCMeta.__new__.__qualname__.__len__() == 15 ('ABCMeta.__new__' is 15 chars); verified with Python 3.14.3"]
    - [new_argc,     abc.ABCMeta.__new__.__code__.co_argcount.__eq__,             [4],                  true, "ABCMeta.__new__.__code__.co_argcount == 4 ('mcls','name','bases','namespace'); verified with Python 3.14.3"]
    - [new_vlen,     abc.ABCMeta.__new__.__code__.co_varnames.__len__,             [],                 6,    "ABCMeta.__new__.__code__.co_varnames.__len__() == 6 (adds 'kwargs','cls'); verified with Python 3.14.3"]
    - [cls_in,       abc.ABCMeta.__new__.__code__.co_varnames.__contains__,       ["cls"],              true, "ABCMeta.__new__.__code__.co_varnames contains 'cls'; verified with Python 3.14.3"]
    - [mcls_in,      abc.ABCMeta.__new__.__code__.co_varnames.__contains__,       ["mcls"],             true, "ABCMeta.__new__.__code__.co_varnames contains 'mcls' (metaclass parameter); verified with Python 3.14.3"]

