spec: abc_extra136
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "This spec covers: abc.__spec__.__class__.__name__=='ModuleSpec' (len=10); abc.__spec__.name=='abc' (len=3). abc.ABC — __doc__.__len__()==78; __doc__ is 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n'. abc.ABCMeta — __name__=='ABCMeta' (len=7), __module__=='abc' (len=3), __bases__[0].__name__=='type'; ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15), co_argcount==4, co_varnames.__len__()==6. abc.update_abstractmethods — __qualname__=='update_abstractmethods' (len=22), co_argcount==1, co_varnames.__len__()==5. abc.abstractmethod — __doc__.__len__()==537, __qualname__=='abstractmethod' (len=14), co_argcount==1, co_varnames.__len__()==1. abc.abstractproperty — __doc__.__len__()==221, __qualname__=='abstractproperty' (len=16). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "abc.__package__ is '' (empty string) because abc is a top-level module, not a package. abc.__spec__.name=='abc' (len=3). abc.ABC.__doc__ is 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' (len=78). abc.ABCMeta.__new__.__qualname__=='ABCMeta.__new__' (len=15: 'ABCMeta'=7+'.'=1+'__new__'=7=15); co_argcount==4 ('mcls','name','bases','namespace'); co_varnames==('mcls','name','bases','namespace','kwargs','cls') (len=6). abc.update_abstractmethods.__qualname__=='update_abstractmethods' (len=22); co_varnames==('cls','abstracts','scls','name','value') (len=5); co_argcount==1 ('cls' only). abc.abstractmethod.__code__.co_varnames==('funcobj',) (len=1); co_argcount==1. abc.abstractproperty.__doc__.__len__()==221; __qualname__=='abstractproperty' (len=16). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

