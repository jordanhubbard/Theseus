table abc_extra136.abc_doc:
  description: "abc.ABC __doc__ length and identity checks — ABC.__doc__.__len__()==78 (ABC has a short docstring: 'Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' which is 78 chars); ABC.__name__.__eq__('ABC')==True (len=3: same as __module__ len); ABC.__module__.__eq__('abc')==True (len=3); doc len (78) is much shorter than ABCMeta.__doc__ len (576) and abstractmethod.__doc__ len (537); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: abcabcdoc136

  columns: [id, function, args, expected, description]
  rows:
    - [doc_len,    abc.ABC.__doc__.__len__,       [],       78,   "abc.ABC.__doc__.__len__() == 78 ('Helper class that provides a standard way to create an ABC using\\ninheritance.\\n' is 78 chars); verified with Python 3.14.3"]
    - [name_eq,    abc.ABC.__name__.__eq__,       ["ABC"],  true, "abc.ABC.__name__ == 'ABC' (len=3); verified with Python 3.14.3"]
    - [name_len,   abc.ABC.__name__.__len__,       [],      3,    "abc.ABC.__name__.__len__() == 3; verified with Python 3.14.3"]
    - [mod_eq,     abc.ABC.__module__.__eq__,     ["abc"],  true, "abc.ABC.__module__ == 'abc' (len=3, same as __name__ len); verified with Python 3.14.3"]

