invariant abc_extra136.abcmeta_new_qualname_len_15:
  description: "abc.ABCMeta.__new__.__qualname__.__len__() == 15 — ABCMeta.__new__.__qualname__ is 'ABCMeta.__new__' (15 chars: 'ABCMeta'=7+'.'=1+'__new__'=7=15); ABCMeta.__new__ co_argcount==4 ('mcls','name','bases','namespace'); co_varnames.__len__()==6 (adds 'kwargs','cls'); ABCMeta.__bases__[0].__name__=='type'; qualname len (15) equals ABCMeta.register qualname len (16) minus 1; NEW in extra136: first standalone ABCMeta.__new__ qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.ABCMeta.__new__.__qualname__.__len__
  args: []
  expected: 15

invariant abc_extra136.update_abstractmethods_qualname_len_22:
  description: "abc.update_abstractmethods.__qualname__.__len__() == 22 — update_abstractmethods.__qualname__ is 'update_abstractmethods' (22 chars: 'update'=6+'_'=1+'abstractmethods'=15=22); added in Python 3.10 as a public API for updating abstract method sets on a class; co_argcount==1; co_varnames.__len__()==5; qualname len (22) is the longest of any function/method qualname covered in this spec (compare: ABCMeta.__new__=15, ABCMeta.register=16, abstractmethod=14); NEW in extra136: first standalone update_abstractmethods qualname length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.update_abstractmethods.__qualname__.__len__
  args: []
  expected: 22

invariant abc_extra136.abstractmethod_doc_len_537:
  description: "abc.abstractmethod.__doc__.__len__() == 537 — abc.abstractmethod.__doc__ is a 537-char docstring explaining the decorator: it describes the ABCMeta requirement, instantiation rules, super-call usage, and property/descriptor usage; doc len (537) is shorter than ABCMeta.__doc__ len (576) by 39 chars but longer than abstractproperty.__doc__ len (221) by 316 chars; abstractmethod co_argcount==1 ('funcobj'); co_varnames.__len__()==1; NEW in extra136: first standalone abstractmethod __doc__ length invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: abc.abstractmethod.__doc__.__len__
  args: []
  expected: 537

