    - [ap_doc_len,   abc.abstractproperty.__doc__.__len__,     [],                    221,  "abc.abstractproperty.__doc__.__len__() == 221; verified with Python 3.14.3"]
    - [meta_doc_len, abc.ABCMeta.__doc__.__len__,              [],                    576,  "abc.ABCMeta.__doc__.__len__() == 576 (longest in this spec); verified with Python 3.14.3"]
    - [am_qn_eq,     abc.abstractmethod.__qualname__.__eq__,   ["abstractmethod"],    true, "abc.abstractmethod.__qualname__ == 'abstractmethod' (len=14); verified with Python 3.14.3"]
    - [am_qn_len,    abc.abstractmethod.__qualname__.__len__,   [],                   14,   "abc.abstractmethod.__qualname__.__len__() == 14; verified with Python 3.14.3"]
    - [am_argc,      abc.abstractmethod.__code__.co_argcount.__eq__, [1],             true, "abc.abstractmethod.__code__.co_argcount == 1 ('funcobj' only); verified with Python 3.14.3"]
    - [am_vlen,      abc.abstractmethod.__code__.co_varnames.__len__, [],             1,    "abc.abstractmethod.__code__.co_varnames.__len__() == 1 ('funcobj' only); verified with Python 3.14.3"]
    - [funcobj_in,   abc.abstractmethod.__code__.co_varnames.__contains__, ["funcobj"], true, "abc.abstractmethod.__code__.co_varnames contains 'funcobj'; verified with Python 3.14.3"]

