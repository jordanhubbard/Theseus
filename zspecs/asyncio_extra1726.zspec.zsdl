spec: asyncio_extra1726
version: ">=3.9"
backend: python_module(asyncio)
error_model: python_exceptions

provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/asyncio.html"
    - "https://docs.python.org/3/library/asyncio-sync.html"
    - "https://docs.python.org/3/library/asyncio-task.html"
    - "https://docs.python.org/3/library/asyncio-queue.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 562 (_extra1726): comparison/ordering protocol dict-presence checks."
    - "Theme: which asyncio stdlib types define __lt__, __le__, __gt__, __ge__, __ne__ in their own __dict__."
    - "All asyncio synchronization and task types are pure Python classes with no ordering semantics."
    - "asyncio.Future: no comparison operators in own __dict__ — Future objects are not orderable -> all False."
    - "asyncio.Task: subclass of Future; inherits no comparison operators and defines none in its own __dict__ -> all False."
    - "asyncio.Lock: synchronization primitive; no comparison operators defined in own __dict__ -> all False."
    - "asyncio.Event: synchronization primitive; no comparison operators defined in own __dict__ -> all False."
    - "asyncio.Queue: container with ordering by priority (PriorityQueue) but base Queue has no comparison operators -> all False."
    - "asyncio.Condition: synchronization primitive; no comparison operators in own __dict__ -> all False."
    - "Cross-check: __eq__ and __hash__ are also absent from the own __dict__ of all listed asyncio types (inherited from object) -> all False."
    - "asyncio.Semaphore: no comparison operators defined in own __dict__ -> all False."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: comparison operator dict-presence checks (__lt__, __le__, __gt__, __ge__, __ne__)
#
# Wave 562 theme: do asyncio types define ordering/comparison dunders in their
# own __dict__? All asyncio synchronization primitives and task types are pure
# Python classes that carry no ordering semantics. None of them define __lt__,
# __le__, __gt__, __ge__, or __ne__ in their own __dict__. These operators are
# not inherited from object either (object defines __eq__ but not the rich
# ordering operators), so all checks return False.
# ---------------------------------------------------------------------------

table asyncio_extra1726.comparison_protocol:
  description: "asyncio types: __lt__, __le__, __gt__, __ge__, __ne__ dict-presence checks (all False — no ordering semantics)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1726

  columns: [id, function, args, expected]
  rows:
    - ["as1726001", "asyncio.Future.__dict__.__contains__",    ["__lt__"], false]
    - ["as1726002", "asyncio.Future.__dict__.__contains__",    ["__le__"], false]
    - ["as1726003", "asyncio.Future.__dict__.__contains__",    ["__gt__"], false]
    - ["as1726004", "asyncio.Future.__dict__.__contains__",    ["__ge__"], false]
    - ["as1726005", "asyncio.Future.__dict__.__contains__",    ["__ne__"], false]
    - ["as1726006", "asyncio.Task.__dict__.__contains__",      ["__lt__"], false]
    - ["as1726007", "asyncio.Task.__dict__.__contains__",      ["__le__"], false]
    - ["as1726008", "asyncio.Task.__dict__.__contains__",      ["__gt__"], false]
    - ["as1726009", "asyncio.Task.__dict__.__contains__",      ["__ge__"], false]
    - ["as1726010", "asyncio.Task.__dict__.__contains__",      ["__ne__"], false]

# ---------------------------------------------------------------------------
# Table 2: __eq__ and __hash__ dict-presence cross-checks
#
# Wave 562 cross-check: __eq__ and __hash__ are defined on object and inherited
# by all classes. None of the asyncio types override __eq__ or __hash__ in
# their own __dict__. This confirms that asyncio types rely entirely on
# object's identity-based equality and hashing. Future and Task objects are
# compared by identity, not by value or state, so defining __eq__ would be
# incorrect for these types.
# ---------------------------------------------------------------------------

table asyncio_extra1726.eq_hash_protocol:
  description: "asyncio types: __eq__ and __hash__ dict-presence cross-check (all inherited from object — not in own __dict__)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1726

  columns: [id, function, args, expected]
  rows:
    - ["as1726011", "asyncio.Future.__dict__.__contains__",    ["__eq__"],   false]
    - ["as1726012", "asyncio.Future.__dict__.__contains__",    ["__hash__"], false]
    - ["as1726013", "asyncio.Task.__dict__.__contains__",      ["__eq__"],   false]
    - ["as1726014", "asyncio.Task.__dict__.__contains__",      ["__hash__"], false]
    - ["as1726015", "asyncio.Lock.__dict__.__contains__",      ["__eq__"],   false]
    - ["as1726016", "asyncio.Lock.__dict__.__contains__",      ["__hash__"], false]
    - ["as1726017", "asyncio.Event.__dict__.__contains__",     ["__eq__"],   false]
    - ["as1726018", "asyncio.Event.__dict__.__contains__",     ["__hash__"], false]

# ---------------------------------------------------------------------------
# Table 3: ordering operator dict-presence for remaining asyncio sync primitives
#
# Wave 562 extension: extend the comparison/ordering protocol checks to the
# remaining synchronization primitives: Lock, Event, Semaphore, Queue, and
# Condition. None of these classes define __lt__, __le__, __gt__, __ge__, or
# __ne__ in their own __dict__. asyncio.Queue is a FIFO queue with no ordering
# between queue instances; asyncio.PriorityQueue orders items internally but
# does not define ordering operators on the queue class itself.
# ---------------------------------------------------------------------------

table asyncio_extra1726.sync_comparison_protocol:
  description: "asyncio sync primitives: __lt__, __le__, __gt__, __ge__, __ne__ dict-presence (all False — no ordering semantics)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: as1726

  columns: [id, function, args, expected]
  rows:
    - ["as1726019", "asyncio.Lock.__dict__.__contains__",      ["__lt__"], false]
    - ["as1726020", "asyncio.Lock.__dict__.__contains__",      ["__gt__"], false]
    - ["as1726021", "asyncio.Event.__dict__.__contains__",     ["__lt__"], false]
    - ["as1726022", "asyncio.Event.__dict__.__contains__",     ["__gt__"], false]
    - ["as1726023", "asyncio.Semaphore.__dict__.__contains__", ["__lt__"], false]
    - ["as1726024", "asyncio.Semaphore.__dict__.__contains__", ["__gt__"], false]
    - ["as1726025", "asyncio.Queue.__dict__.__contains__",     ["__lt__"], false]
    - ["as1726026", "asyncio.Queue.__dict__.__contains__",     ["__gt__"], false]
    - ["as1726027", "asyncio.Condition.__dict__.__contains__", ["__lt__"], false]
    - ["as1726028", "asyncio.Condition.__dict__.__contains__", ["__ne__"], false]
