spec: itertools_extra1741
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 563 (_extra1741): descriptor protocol dict-presence checks."
    - "All itertools types are C extension types (itertoolsmodule.c) — none implement the descriptor protocol."
    - "itertools.chain, islice, count, cycle, repeat, accumulate, compress, starmap, product, combinations, permutations, dropwhile, takewhile, zip_longest: all False for __get__, __set__, __delete__, __set_name__."
    - "Absence of descriptor methods reflects that itertools types are pure iterator objects, not descriptors."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: descriptor protocol dict-presence checks for itertools types
#
# Wave 563 theme: which itertools types define __get__, __set__, __delete__,
# __set_name__ in their own __dict__.
#
# All itertools types: C extension iterator types — none implement the
# descriptor protocol. All four descriptor dunders are absent from __dict__.
#
# chain, islice, count, cycle, repeat: all False for all 4 descriptor dunders.
# ---------------------------------------------------------------------------

table itertools_extra1741.descriptor_protocol:
  description: "itertools types descriptor protocol dict-presence checks — all False — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1741

  columns: [id, function, args, expected]
  rows:
    - ["it1741001", "itertools.chain.__dict__.__contains__", ["__get__"], false]
    - ["it1741002", "itertools.chain.__dict__.__contains__", ["__set__"], false]
    - ["it1741003", "itertools.chain.__dict__.__contains__", ["__delete__"], false]
    - ["it1741004", "itertools.chain.__dict__.__contains__", ["__set_name__"], false]
    - ["it1741005", "itertools.islice.__dict__.__contains__", ["__get__"], false]
    - ["it1741006", "itertools.islice.__dict__.__contains__", ["__set__"], false]
    - ["it1741007", "itertools.islice.__dict__.__contains__", ["__delete__"], false]
    - ["it1741008", "itertools.islice.__dict__.__contains__", ["__set_name__"], false]
    - ["it1741009", "itertools.count.__dict__.__contains__", ["__get__"], false]
    - ["it1741010", "itertools.count.__dict__.__contains__", ["__set__"], false]
    - ["it1741011", "itertools.count.__dict__.__contains__", ["__delete__"], false]
    - ["it1741012", "itertools.count.__dict__.__contains__", ["__set_name__"], false]

# ---------------------------------------------------------------------------
# Table 2: extended descriptor checks — more itertools types + contrast checks
#
# cycle, repeat, product, combinations: all False for all 4 descriptor dunders.
# Contrast: chain.__dict__ DOES contain __iter__, __next__, __new__ (iterator
# protocol methods), confirming the __dict__ is accessible and populated but
# lacks descriptor methods.
# ---------------------------------------------------------------------------

table itertools_extra1741.descriptor_extended_and_contrast:
  description: "itertools: cycle/repeat/product/combinations all non-descriptor; chain __dict__ has __iter__/__next__ — wave 563 _extra1741"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it1741

  columns: [id, function, args, expected]
  rows:
    - ["it1741013", "itertools.cycle.__dict__.__contains__", ["__get__"], false]
    - ["it1741014", "itertools.cycle.__dict__.__contains__", ["__set__"], false]
    - ["it1741015", "itertools.repeat.__dict__.__contains__", ["__get__"], false]
    - ["it1741016", "itertools.repeat.__dict__.__contains__", ["__set__"], false]
    - ["it1741017", "itertools.product.__dict__.__contains__", ["__get__"], false]
    - ["it1741018", "itertools.product.__dict__.__contains__", ["__set__"], false]
    - ["it1741019", "itertools.combinations.__dict__.__contains__", ["__get__"], false]
    - ["it1741020", "itertools.combinations.__dict__.__contains__", ["__set__"], false]
    - ["it1741021", "itertools.chain.__dict__.__contains__", ["__iter__"], true]
    - ["it1741022", "itertools.chain.__dict__.__contains__", ["__next__"], true]
    - ["it1741023", "itertools.chain.__dict__.__contains__", ["__new__"], true]
    - ["it1741024", "itertools.chain.__dict__.__contains__", ["__doc__"], true]
    - ["it1741025", "itertools.islice.__dict__.__contains__", ["__iter__"], true]
