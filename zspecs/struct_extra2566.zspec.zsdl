spec: struct_extra2566
version: ">=3.9"
backend: python_module(struct)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs — https://docs.python.org/3/library/struct.html"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
  notes:
    - "Wave 2566 theme: __getattr__, __setattr__, __delattr__ dict-presence — custom attribute access protocol."
    - "struct.Struct defines all three: __getattribute__, __setattr__, and __delattr__ in its own __dict__."
    - "This makes struct.Struct the most complete attribute-protocol implementor among the four wave-2566 classes."
    - "struct.Struct.__setattr__ and __delattr__ guard the compiled struct format — format and size are read-only after construction."
    - "struct.Struct.__getattribute__ is a C-level override that provides efficient access to the format and size descriptors."
    - "struct.Struct does NOT define __getattr__ — there is no fallback lazy lookup for missing attributes."
    - "struct.Struct defines __new__ and __init__ (both present) as it is a C type with a custom tp_new."
    - "struct.Struct defines pack, unpack, pack_into, unpack_from, iter_unpack as instance methods, plus format and size descriptors."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Core attribute access protocol — all three write/delete guards present
# ---------------------------------------------------------------------------

table struct_extra2566.attr_access_protocol:
  description: "struct.Struct defines __getattribute__, __setattr__, __delattr__ — the most complete attribute protocol among wave-2566 classes"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2566

  columns: [id, function, args, expected]
  rows:
    - ["st2566001", "struct.Struct.__dict__.__contains__", ["__getattribute__"], true]
    - ["st2566002", "struct.Struct.__dict__.__contains__", ["__setattr__"],      true]
    - ["st2566003", "struct.Struct.__dict__.__contains__", ["__delattr__"],      true]
    - ["st2566004", "struct.Struct.__dict__.__contains__", ["__getattr__"],      false]

# ---------------------------------------------------------------------------
# Lifecycle protocol — __new__, __init__, __repr__, __sizeof__
# ---------------------------------------------------------------------------

table struct_extra2566.lifecycle_protocol:
  description: "struct.Struct defines __new__, __init__, __repr__, and __sizeof__ in its __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2566

  columns: [id, function, args, expected]
  rows:
    - ["st2566005", "struct.Struct.__dict__.__contains__", ["__new__"],    true]
    - ["st2566006", "struct.Struct.__dict__.__contains__", ["__init__"],   true]
    - ["st2566007", "struct.Struct.__dict__.__contains__", ["__repr__"],   true]
    - ["st2566008", "struct.Struct.__dict__.__contains__", ["__sizeof__"], true]

# ---------------------------------------------------------------------------
# Packing API — struct-specific methods and descriptors
# ---------------------------------------------------------------------------

table struct_extra2566.packing_api:
  description: "struct.Struct defines its full packing/unpacking API directly in its __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2566

  columns: [id, function, args, expected]
  rows:
    - ["st2566009",  "struct.Struct.__dict__.__contains__", ["pack"],          true]
    - ["st2566010",  "struct.Struct.__dict__.__contains__", ["unpack"],        true]
    - ["st2566011",  "struct.Struct.__dict__.__contains__", ["pack_into"],     true]
    - ["st2566012",  "struct.Struct.__dict__.__contains__", ["unpack_from"],   true]
    - ["st2566013",  "struct.Struct.__dict__.__contains__", ["iter_unpack"],   true]
    - ["st2566014",  "struct.Struct.__dict__.__contains__", ["format"],        true]
    - ["st2566015",  "struct.Struct.__dict__.__contains__", ["size"],          true]

# ---------------------------------------------------------------------------
# Absent standard dunders — comparison and hashing not overridden
# ---------------------------------------------------------------------------

table struct_extra2566.absent_dunders:
  description: "Comparison and hashing dunders are absent from struct.Struct.__dict__ — inherited from object"
  kind: python_call_eq
  category: dict_contains
  id_prefix: st2566

  columns: [id, function, args, expected]
  rows:
    - ["st2566016", "struct.Struct.__dict__.__contains__", ["__eq__"],    false]
    - ["st2566017", "struct.Struct.__dict__.__contains__", ["__hash__"],  false]
    - ["st2566018", "struct.Struct.__dict__.__contains__", ["__slots__"], false]
    - ["st2566019", "struct.Struct.__dict__.__contains__", ["__del__"],   false]
