spec: diff
version: ">=5.0.0"
backend: node(diff)

docs: https://www.npmjs.com/package/diff

provenance:
  derived_from:
    - "diff README — https://www.npmjs.com/package/diff"
    - "Test vectors verified with diff via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "diff source"
  notes:
    - "diff is an npm package. Install: npm install diff"
    - "diffWords(a, b) returns an array of change objects with added/removed/value fields."
    - "diffChars(a, b) does the same at character level."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of change objects."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table diff.diffWords:
  kind: node_module_call_eq
  function: diffWords
  category: diff
  id_prefix: dfw

  columns: [id, args, expected]
  rows:
    - [replace, ["Hello World", "Hello Earth"],
       [{"count": 1, "added": false, "removed": false, "value": "Hello "},
        {"count": 1, "added": false, "removed": true,  "value": "World"},
        {"count": 1, "added": true,  "removed": false, "value": "Earth"}]]

table diff.diffChars:
  kind: node_module_call_eq
  function: diffChars
  category: diff
  id_prefix: dfc

  columns: [id, args, expected]
  rows:
    - [cat_cut, ["cat", "cut"],
       [{"count": 1, "added": false, "removed": false, "value": "c"},
        {"count": 1, "added": false, "removed": true,  "value": "a"},
        {"count": 1, "added": true,  "removed": false, "value": "u"},
        {"count": 1, "added": false, "removed": false, "value": "t"}]]

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T17:21:35Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
