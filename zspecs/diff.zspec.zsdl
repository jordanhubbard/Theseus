spec: diff
version: ">=5.0.0"
backend: node(diff)

docs: https://www.npmjs.com/package/diff

provenance:
  derived_from:
    - "diff README — https://www.npmjs.com/package/diff"
    - "Test vectors verified with diff via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "diff source"
  notes:
    - "diff is an npm package. Install: npm install diff"
    - "diffWords(a, b) returns an array of change objects representing word-level differences."
    - "diffChars(a, b) returns character-level differences."
    - "Each object has: count, added (boolean), removed (boolean), value (string)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns array of change objects."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table diff.diffWords:
  kind: node_module_call_eq
  function: diffWords
  category: diffWords
  id_prefix: dw

  columns: [id, args, expected]
  rows:
    - [change, ["Hello World", "Hello Earth"],
       [{"count": 1, "added": false, "removed": false, "value": "Hello "},
        {"count": 1, "added": false, "removed": true,  "value": "World"},
        {"count": 1, "added": true,  "removed": false, "value": "Earth"}]]
    - [same,   ["hello", "hello"],
       [{"count": 1, "added": false, "removed": false, "value": "hello"}]]

table diff.diffChars:
  kind: node_module_call_eq
  function: diffChars
  category: diffChars
  id_prefix: dc

  columns: [id, args, expected]
  rows:
    - [append, ["abc", "abcd"],
       [{"count": 3, "added": false, "removed": false, "value": "abc"},
        {"count": 1, "added": true,  "removed": false, "value": "d"}]]
    - [same,   ["abc", "abc"],
       [{"count": 3, "added": false, "removed": false, "value": "abc"}]]
