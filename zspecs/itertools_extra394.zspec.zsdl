spec: itertools_extra394
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "itertools.islice.__qualname__ == 'islice' — C extension type; __qualname__ equals __name__ for top-level C types. Verified with Python 3.14.4."
    - "itertools.takewhile.__qualname__ == 'takewhile' — C extension type; __qualname__ equals __name__. Verified with Python 3.14.4."
    - "itertools.dropwhile.__qualname__ == 'dropwhile' — C extension type; __qualname__ equals __name__. Verified with Python 3.14.4."
    - "itertools.compress.__qualname__ == 'compress' — C extension type; __qualname__ equals __name__. Verified with Python 3.14.4."
    - "itertools.filterfalse.__qualname__ == 'filterfalse' — C extension type; __qualname__ equals __name__. Verified with Python 3.14.4."
    - "itertools.starmap.__qualname__ == 'starmap' — C extension type; __qualname__ equals __name__. Verified with Python 3.14.4."
    - "itertools.zip_longest.__qualname__ == 'zip_longest' — C extension type; __qualname__ equals __name__. Verified with Python 3.14.4."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools iterator type __qualname__ values
#
# All itertools iterator types are implemented as C extension types.
# For top-level C types, __qualname__ equals __name__ (no enclosing scope).
# This table covers islice, takewhile, dropwhile, compress, filterfalse,
# starmap, and zip_longest.
# ---------------------------------------------------------------------------

table itertools_extra394.iterator_qualname:
  description: "itertools iterator type __qualname__ — equals __name__ for top-level C extension types; new to extra394"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsiq394

  columns: [id, function, args, expected, description]
  rows:
    - [islice_qualname_eq,
       "islice.__qualname__.__eq__",
       ["islice"],
       true,
       "itertools.islice.__qualname__.__eq__('islice') == True — islice is a C extension type; for top-level C types __qualname__ equals __name__, which is 'islice'; str.__eq__('islice') returns True; new to extra394"]
    - [takewhile_qualname_eq,
       "takewhile.__qualname__.__eq__",
       ["takewhile"],
       true,
       "itertools.takewhile.__qualname__.__eq__('takewhile') == True — takewhile is a C extension type; __qualname__ equals __name__ 'takewhile'; str.__eq__('takewhile') returns True; new to extra394"]
    - [dropwhile_qualname_eq,
       "dropwhile.__qualname__.__eq__",
       ["dropwhile"],
       true,
       "itertools.dropwhile.__qualname__.__eq__('dropwhile') == True — dropwhile is a C extension type; __qualname__ equals __name__ 'dropwhile'; str.__eq__('dropwhile') returns True; new to extra394"]
    - [compress_qualname_eq,
       "compress.__qualname__.__eq__",
       ["compress"],
       true,
       "itertools.compress.__qualname__.__eq__('compress') == True — compress is a C extension type; __qualname__ equals __name__ 'compress'; str.__eq__('compress') returns True; new to extra394"]
    - [filterfalse_qualname_eq,
       "filterfalse.__qualname__.__eq__",
       ["filterfalse"],
       true,
       "itertools.filterfalse.__qualname__.__eq__('filterfalse') == True — filterfalse is a C extension type; __qualname__ equals __name__ 'filterfalse'; str.__eq__('filterfalse') returns True; new to extra394"]
    - [starmap_qualname_eq,
       "starmap.__qualname__.__eq__",
       ["starmap"],
       true,
       "itertools.starmap.__qualname__.__eq__('starmap') == True — starmap is a C extension type; __qualname__ equals __name__ 'starmap'; str.__eq__('starmap') returns True; new to extra394"]
    - [zip_longest_qualname_eq,
       "zip_longest.__qualname__.__eq__",
       ["zip_longest"],
       true,
       "itertools.zip_longest.__qualname__.__eq__('zip_longest') == True — zip_longest is a C extension type; __qualname__ equals __name__ 'zip_longest'; str.__eq__('zip_longest') returns True; new to extra394"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra394
# ---------------------------------------------------------------------------

invariant itertools_extra394.islice_qualname:
  description: "itertools.islice.__qualname__ == 'islice' — C extension type; __qualname__ equals __name__; new to extra394"
  kind: python_call_eq
  function: islice.__qualname__.__eq__
  args: ["islice"]
  expected: true

