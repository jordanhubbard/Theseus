spec: theseus_asyncio_cr
version: ">=3.9"
backend: python_cleanroom(theseus_asyncio_cr)
blocks: asyncio

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html"
  notes:
    - "Clean-room async event loop primitives. Do NOT import asyncio, concurrent, or threading."
    - "Implement a minimal synchronous coroutine runner using generator-based coroutines."
    - "run(coro): runs a coroutine to completion, returning the result."
    - "gather(*coros): runs multiple coroutines, returns list of results."
    - "sleep(delay): suspend coroutine for delay steps (in simulation, just yields)."
    - "asyncio_run_simple(): run(simple_coro()) returns 42."
    - "asyncio_gather_two(): gather returns results from both coros."
    - "asyncio_future_result(): Future.set_result(99); result() == 99."
    - "Export: run(coro), gather(*coros), Future class with set_result/result."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

invariant theseus_asyncio_cr.run_simple:
  description: "run(coro_that_returns_42) == 42"
  category: run
  kind: python_call_eq
  function: asyncio_run_simple
  args: []
  expected: 42

invariant theseus_asyncio_cr.future_result:
  description: "Future.set_result(99); result() == 99"
  category: future
  kind: python_call_eq
  function: asyncio_future_result
  args: []
  expected: 99

invariant theseus_asyncio_cr.gather_two:
  description: "gather returns list of results from two coros"
  category: gather
  kind: python_call_eq
  function: asyncio_gather_two
  args: []
  expected: [1, 2]
