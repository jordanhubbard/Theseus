spec: functools_extra1876
version: ">=3.9"
backend: python_module(functools)
error_model: python_exceptions
provenance:
  derived_from:
    - "functools module documentation"
    - "CPython source inspection"
  not_derived_from:
    - "any third-party functools extensions"
  notes:
    - "Tests attribute access protocol membership in functools types"
    - "partial.__setattr__ exists to enforce read-only args/func/keywords"
    - "cached_property and partialmethod use __slots__, no custom attr protocol"
  created_at: "2026-04-12"

table functools_extra1876.attr_access_protocol:
