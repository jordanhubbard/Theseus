    - ["fu1876-aa-002", "functools.partial.__dict__.__contains__", ["__setattr__"], true]
    - ["fu1876-aa-003", "functools.partial.__dict__.__contains__", ["__delattr__"], false]
    - ["fu1876-aa-004", "functools.partial.__dict__.__contains__", ["__getattribute__"], false]
    - ["fu1876-aa-005", "functools.cached_property.__dict__.__contains__", ["__getattr__"], false]
    - ["fu1876-aa-006", "functools.cached_property.__dict__.__contains__", ["__setattr__"], false]
    - ["fu1876-aa-007", "functools.partialmethod.__dict__.__contains__", ["__getattr__"], false]
    - ["fu1876-aa-008", "functools.partialmethod.__dict__.__contains__", ["__setattr__"], false]

