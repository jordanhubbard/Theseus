spec: itertools_extra2551
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2551 (_extra2551): __reduce__, __reduce_ex__, __getnewargs__ dict-presence checks."
    - "All itertools types are C extension types implemented in Modules/itertoolsmodule.c."
    - "As of Python 3.14 on macOS, NO itertools type defines __reduce__, __reduce_ex__, or __getnewargs__ in its own __dict__."
    - "Itertools objects are not picklable in the general case; the C layer provides no pickle hooks."
    - "Checked: chain, count, cycle, repeat, islice, product, combinations, permutations, combinations_with_replacement, compress, dropwhile, filterfalse, groupby, pairwise, batched, accumulate, zip_longest."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __reduce__ dict-presence for itertools types
#
# All itertools C extension types lack __reduce__ in their __dict__.
# This means none implement a custom pickling protocol via __reduce__.
# ---------------------------------------------------------------------------

table itertools_extra2551.reduce_protocol:
  description: "itertools types __reduce__ dict-presence checks — all False — wave 2551 _extra2551"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2551

  columns: [id, function, args, expected]
  rows:
    - ["it2551001", "itertools.chain.__dict__.__contains__", ["__reduce__"], false]
    - ["it2551002", "itertools.count.__dict__.__contains__", ["__reduce__"], false]
    - ["it2551003", "itertools.cycle.__dict__.__contains__", ["__reduce__"], false]
    - ["it2551004", "itertools.repeat.__dict__.__contains__", ["__reduce__"], false]
    - ["it2551005", "itertools.islice.__dict__.__contains__", ["__reduce__"], false]
    - ["it2551006", "itertools.product.__dict__.__contains__", ["__reduce__"], false]
    - ["it2551007", "itertools.combinations.__dict__.__contains__", ["__reduce__"], false]
    - ["it2551008", "itertools.permutations.__dict__.__contains__", ["__reduce__"], false]
    - ["it2551009", "itertools.combinations_with_replacement.__dict__.__contains__", ["__reduce__"], false]

