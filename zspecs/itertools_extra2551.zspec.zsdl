# ---------------------------------------------------------------------------
# Table 3: __reduce_ex__ dict-presence for itertools types
#
# None of the itertools C types define __reduce_ex__ either.
# __reduce_ex__ is inherited from object.
# ---------------------------------------------------------------------------

table itertools_extra2551.reduce_ex_protocol:
  description: "itertools types __reduce_ex__ dict-presence checks — all False — wave 2551 _extra2551"
  kind: python_call_eq
