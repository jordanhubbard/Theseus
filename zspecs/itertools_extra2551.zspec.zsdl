# ---------------------------------------------------------------------------
# Table 4: __getnewargs__ dict-presence for itertools types
#
# None of the itertools C types define __getnewargs__.
# Namedtuple-style reconstruction is not used here.
# ---------------------------------------------------------------------------

table itertools_extra2551.getnewargs_protocol:
  description: "itertools types __getnewargs__ dict-presence checks — all False — wave 2551 _extra2551"
