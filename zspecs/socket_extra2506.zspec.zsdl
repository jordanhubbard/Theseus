spec: socket_extra2506
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/socket.html"
    - "CPython source: Lib/socket.py, Modules/_socket.c"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 583 (_extra2506): __add__, __sub__, __mul__ dict-presence checks."
    - "socket.socket is not an arithmetic type; it defines none of these additive, subtractive, or multiplicative protocols in its own __dict__."
    - "socket.error, socket.timeout, and socket.gaierror are Exception subclasses; they define no arithmetic protocols in their own __dict__."
    - "socket.AddressFamily and socket.SocketKind are IntFlag subclasses; despite inheriting from int, they define none of __add__/__sub__/__mul__ in their own __dict__."
    - "All __add__/__sub__/__mul__ dunder methods (including r/i variants) are absent from all checked socket type dicts."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

table socket_extra2506.socket_add_protocol:
  description: "socket.socket __add__/__radd__/__iadd__ dict-presence checks (socket is not arithmetic)"
  kind: python_call_eq
  category: dict_contains
  id_prefix: sk2506

  columns: [id, function, args, expected]
  rows:
    - ["sk2506001", "socket.socket.__dict__.__contains__", ["__add__"], false]
    - ["sk2506002", "socket.socket.__dict__.__contains__", ["__radd__"], false]
    - ["sk2506003", "socket.socket.__dict__.__contains__", ["__iadd__"], false]

