spec: struct_extra149
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra148.zspec.zsdl — covers struct.Struct.__name__/__module__/__bases__[0].__name__ / Struct.pack.__qualname__.__eq__('Struct.pack') / Struct.unpack.__qualname__.__eq__('Struct.unpack') / struct.error.__name__/__module__/__bases__[0].__name__ (table + invariants)."
    - "struct_extra147.zspec.zsdl — covers struct.calcsize for 'B'/'H'/'I'/'Q'/'f'/'d'/'?'/'BB'/'HH'/'II'/'QQ' (table + invariants)."
    - "struct_extra146.zspec.zsdl — covers _struct.__dict__.__len__()==15 / _struct.__dict__.__contains__('Struct'/'pack'/'error'/'calcsize'/'unpack'/'pack_into'/'iter_unpack'/'_clearcache') (table + invariants)."
    - "struct_extra143.zspec.zsdl — covers struct.Struct.__dict__.__contains__('pack'/'unpack'/'pack_into'/'format'/'size'/'iter_unpack'/'unpack_from') (table + invariants)."
    - "struct_extra141.zspec.zsdl — covers struct.Struct.__module__/__qualname__/__bases__[0].__name__/__mro__.__len__ (table + invariants)."
    - "struct.zspec / early extras — cover struct.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in struct_extra93 through struct_extra148."
    - "Wave 335 theme: struct.Struct instance method qualnames (pack_into/unpack_from/iter_unpack) and descriptor types for size/format — Struct.pack_into.__qualname__.__eq__('Struct.pack_into') / Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from') / Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') / Struct.size.__class__.__name__.__eq__('getset_descriptor') / Struct.format.__class__.__name__.__eq__('getset_descriptor')."
    - "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.size.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.format.__class__.__name__ == 'getset_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.Struct.pack_into.__qualname__ == 'Struct.pack_into' (16 chars). pack_into writes packed bytes into a writable buffer at a given offset, instead of returning a new bytes object like pack(). struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from' (18 chars). unpack_from reads from a buffer at a given offset without requiring the buffer to be exactly the right size. struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack' (18 chars). iter_unpack returns an iterator that reads successive fixed-size chunks from a buffer."
    - "Note: struct.Struct.size and struct.Struct.format are getset_descriptor objects (15 chars), NOT properties. C extension types use getset_descriptor for computed read-only attributes implemented via C-level PyGetSetDef. This contrasts with Python @property (8 chars, as seen on uuid.UUID attributes) and member_descriptor (17 chars, as seen on uuid.UUID.int). Struct.size is the number of bytes in the packed struct; Struct.format is the format string passed to Struct()."
    - "Note: qualname lengths for Struct methods: Struct.pack(11) < Struct.unpack(13) < Struct.pack_into(16) < Struct.unpack_from(18) == Struct.iter_unpack(18). All follow the 'Struct.' prefix (7 chars) pattern. pack_into: 7+'pack_into'=9=16; unpack_from: 7+'unpack_from'=11=18; iter_unpack: 7+'iter_unpack'=11=18."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into')
# struct.Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from')
# struct.Struct.pack_into.__qualname__.__len__()==16
# struct.Struct.unpack_from.__qualname__.__len__()==18
#
# Wave 335 theme: Struct.pack_into and Struct.unpack_from qualnames.
#
# Struct.pack_into.__qualname__ == 'Struct.pack_into' (16 chars; 7+'pack_into'=9).
# Struct.unpack_from.__qualname__ == 'Struct.unpack_from' (18 chars; 7+'unpack_from'=11).
# extra148 anchors Struct.pack and Struct.unpack qualnames; no prior struct spec anchors
# pack_into or unpack_from qualnames as a table under structmq149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra149.Struct_pack_into_unpack_from_qualnames:
  description: "struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into')==True / Struct.unpack_from.__qualname__.__eq__('Struct.unpack_from')==True / Struct.pack_into.__qualname__.__len__()==16 / Struct.unpack_from.__qualname__.__len__()==18 — 'Struct.' prefix (7 chars) + method name; pack_into (9 chars) = 7+9=16; unpack_from (11 chars) = 7+11=18; pack_into writes to buffer at offset (no new bytes returned); unpack_from reads from buffer at offset (no exact-size requirement); length ordering: pack(11) < unpack(13) < pack_into(16) < unpack_from(18); first structmq149 anchor for these qualnames"
  kind: python_call_eq
  category: identity
  id_prefix: structmq149

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_pack_into_qualname,      "Struct.pack_into.__qualname__.__eq__",    ["Struct.pack_into"],  true, "struct.Struct.pack_into.__qualname__ == 'Struct.pack_into' (16 chars; 'Struct.'=7 + 'pack_into'=9)"]
    - [Struct_unpack_from_qualname,    "Struct.unpack_from.__qualname__.__eq__",  ["Struct.unpack_from"], true, "struct.Struct.unpack_from.__qualname__ == 'Struct.unpack_from' (18 chars; 'Struct.'=7 + 'unpack_from'=11)"]
    - [Struct_pack_into_qualname_len,  "Struct.pack_into.__qualname__.__len__",   [],                    16,   "struct.Struct.pack_into.__qualname__.__len__() is 16 ('Struct.pack_into' = 7+9 = 16 chars)"]
    - [Struct_unpack_from_qualname_len,"Struct.unpack_from.__qualname__.__len__", [],                    18,   "struct.Struct.unpack_from.__qualname__.__len__() is 18 ('Struct.unpack_from' = 7+11 = 18 chars)"]

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack')
# struct.Struct.iter_unpack.__qualname__.__len__()==18
# struct.Struct.size.__class__.__name__.__eq__('getset_descriptor')
# struct.Struct.format.__class__.__name__.__eq__('getset_descriptor')
#
# Wave 335 theme: iter_unpack qualname and size/format descriptor types.
#
# Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack' (18 chars; same length as
# Struct.unpack_from). Struct.size and Struct.format are both getset_descriptor (15 chars)
# — C extension computed read-only attributes, NOT Python @property (8 chars).
# No prior struct spec anchors iter_unpack qualname or size/format class names as a table
# under structmq149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra149.Struct_iter_unpack_size_format:
  description: "struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack')==True / Struct.iter_unpack.__qualname__.__len__()==18 / Struct.size.__class__.__name__.__eq__('getset_descriptor')==True / Struct.format.__class__.__name__.__eq__('getset_descriptor')==True — iter_unpack qualname is 18 chars (tied with Struct.unpack_from); iter_unpack returns iterator over successive fixed-size chunks; size and format are C-level getset_descriptor (15 chars), NOT Python @property (8 chars); first structmq149 anchor for iter_unpack qualname and size/format class names"
  kind: python_call_eq
  category: identity
  id_prefix: structmq149

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_iter_unpack_qualname,     "Struct.iter_unpack.__qualname__.__eq__",    ["Struct.iter_unpack"], true, "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack' (18 chars; 'Struct.'=7 + 'iter_unpack'=11)"]
    - [Struct_iter_unpack_qualname_len, "Struct.iter_unpack.__qualname__.__len__",   [],                    18,   "struct.Struct.iter_unpack.__qualname__.__len__() is 18 ('Struct.iter_unpack' = 7+11 = 18 chars; tied with unpack_from)"]
    - [Struct_size_getset,              "Struct.size.__class__.__name__.__eq__",     ["getset_descriptor"], true, "struct.Struct.size.__class__.__name__ == 'getset_descriptor' (15 chars; C-level PyGetSetDef; read-only; not @property)"]
    - [Struct_format_getset,            "Struct.format.__class__.__name__.__eq__",   ["getset_descriptor"], true, "struct.Struct.format.__class__.__name__ == 'getset_descriptor' (15 chars; C-level PyGetSetDef; returns format string)"]

# ---------------------------------------------------------------------------
# struct.Struct.size.__class__.__name__.__len__()==15
# struct.Struct.format.__class__.__name__.__len__()==15
# struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into')
#
# Wave 335 theme: getset_descriptor class name length checks and qualname comparisons.
#
# Both Struct.size and Struct.format have __class__.__name__.__len__() == 15
# ('getset_descriptor' = 15 chars). This is 7 chars longer than 'property' (8 chars)
# and 2 chars shorter than 'member_descriptor' (17 chars). No prior struct spec anchors
# getset_descriptor length or these combined checks as a table under structmq149.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra149.getset_descriptor_lengths_and_method_comparison:
  description: "struct.Struct.size.__class__.__name__.__len__()==15 / Struct.format.__class__.__name__.__len__()==15 / Struct.pack_into.__qualname__.__len__()==16 / Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack')==True — 'getset_descriptor' is 15 chars (7 longer than 'property'=8, 2 shorter than 'member_descriptor'=17); Struct.size is number of packed bytes; Struct.format is the format string; pack_into qualname length (16) > getset_descriptor length (15) by 1; first structmq149 anchor for getset_descriptor name lengths"
  kind: python_call_eq
  category: identity
  id_prefix: structmq149

  columns: [id, function, args, expected, description]
  rows:
    - [Struct_size_class_name_len_15,    "Struct.size.__class__.__name__.__len__",     [], 15,   "struct.Struct.size.__class__.__name__.__len__() is 15 ('getset_descriptor' = 15 chars; byte count of packed struct)"]
    - [Struct_format_class_name_len_15,  "Struct.format.__class__.__name__.__len__",   [], 15,   "struct.Struct.format.__class__.__name__.__len__() is 15 ('getset_descriptor' = 15 chars; format string passed to Struct())"]
    - [Struct_pack_into_qualname_len2,   "Struct.pack_into.__qualname__.__len__",      [], 16,   "struct.Struct.pack_into.__qualname__.__len__() is 16 (1 more than 'getset_descriptor' length of 15)"]
    - [Struct_iter_unpack_qualname2,     "Struct.iter_unpack.__qualname__.__eq__",     ["Struct.iter_unpack"], true, "struct.Struct.iter_unpack.__qualname__ == 'Struct.iter_unpack' (18 chars; confirms C extension method_descriptor qualname)"]

# ---------------------------------------------------------------------------
# struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into') — standalone
#
# struct.Struct.pack_into.__qualname__ is 'Struct.pack_into' (16 chars). pack_into is
# a method on Struct instances that packs data into an existing writable buffer (like a
# bytearray or memoryview) at a specified byte offset, rather than creating and returning
# a new bytes object like pack() does. Its qualname follows the 'Struct.' prefix (7 chars)
# pattern for all Struct method descriptors. extra148 anchors Struct.pack.__qualname__
# (11 chars) and Struct.unpack.__qualname__ (13 chars) as table rows; no prior struct spec
# anchors Struct.pack_into.__qualname__ as a standalone under structmq149.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra149.Struct_pack_into_qualname_eq:
  description: "struct.Struct.pack_into.__qualname__.__eq__('Struct.pack_into') == True — 16 chars; 'Struct.'=7 + 'pack_into'=9; packs into existing buffer at byte offset (no new bytes object); method_descriptor from _struct C extension; extra148 anchors Struct.pack(11) and Struct.unpack(13) qualnames; qualname length ordering: pack(11)<unpack(13)<pack_into(16)<unpack_from(18)==iter_unpack(18); no prior struct spec anchors this as a standalone; first standalone under structmq149"
  category: identity
  kind: python_call_eq
  function: Struct.pack_into.__qualname__.__eq__
  args: ["Struct.pack_into"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.size.__class__.__name__.__eq__('getset_descriptor') — standalone
#
# struct.Struct.size.__class__.__name__ is 'getset_descriptor' (15 chars). Struct.size
# is the number of bytes in a struct packed according to the format string (e.g., for
# Struct('II'), size == 8). It is implemented as a C-level PyGetSetDef attribute on the
# _struct.Struct C extension type. getset_descriptor objects are created by C extension
# types for computed read-only (or read-write) attributes. They differ from Python @property
# (8 chars, pure Python descriptor protocol) and from member_descriptor (17 chars, __slots__
# based storage). No prior struct spec anchors Struct.size.__class__.__name__ as a
# standalone under structmq149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra149.Struct_size_class_getset_descriptor:
  description: "struct.Struct.size.__class__.__name__.__eq__('getset_descriptor') == True — 15 chars; C-level PyGetSetDef attribute; returns byte count of packed struct; differs from @property (8 chars, pure Python) and member_descriptor (17 chars, __slots__); Struct('II').size == 8 (two unsigned ints); no prior struct spec anchors Struct.size class name as a standalone; first standalone under structmq149"
  category: identity
  kind: python_call_eq
  function: Struct.size.__class__.__name__.__eq__
  args: ["getset_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') — standalone
#
# struct.Struct.iter_unpack.__qualname__ is 'Struct.iter_unpack' (18 chars). iter_unpack
# returns an iterator that repeatedly applies the struct's format to a buffer, yielding
# one tuple per iteration. It requires the buffer to be an integer multiple of the struct
# size. Unlike unpack_from (which reads at a single offset), iter_unpack traverses the
# entire buffer in fixed-size steps. The qualname 'Struct.iter_unpack' (18 chars) is tied
# with 'Struct.unpack_from' (18 chars) — both are the longest Struct method qualnames.
# No prior struct spec anchors Struct.iter_unpack.__qualname__ as a standalone under
# structmq149. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra149.Struct_iter_unpack_qualname_eq:
  description: "struct.Struct.iter_unpack.__qualname__.__eq__('Struct.iter_unpack') == True — 18 chars (tied longest Struct method qualname with Struct.unpack_from); 'Struct.'=7 + 'iter_unpack'=11; returns iterator yielding one tuple per fixed-size step; buffer must be multiple of struct size; differs from unpack_from (single offset read); no prior struct spec anchors this as a standalone; first standalone under structmq149"
  category: identity
  kind: python_call_eq
  function: Struct.iter_unpack.__qualname__.__eq__
  args: ["Struct.iter_unpack"]
  expected: true

