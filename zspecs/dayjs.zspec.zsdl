spec: dayjs
version: ">=1.0.0"
backend: node(dayjs)

docs: https://day.js.org/

provenance:
  derived_from:
    - "dayjs README — https://github.com/iamkun/dayjs#readme"
    - "Test vectors verified with dayjs@1.11.13 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "dayjs source: dayjs.min.js"
  notes:
    - "dayjs exports the factory function as the module default (CJS)."
    - "dayjs(dateStr) parses a date string and returns a Day.js object."
    - "Months are 0-indexed: January is 0, December is 11."
    - "format() produces formatted date strings."
    - "year(), month(), date() extract components (month is 0-indexed)."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns Day.js object with method results. No errors for valid date strings."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table dayjs.format:
  kind: node_factory_call_eq
  function: ~
  method: format
  category: format
  id_prefix: dj_fmt

  columns: [id, args, method_args, expected]
  rows:
    - [iso_date,   ["2019-01-25"],  ["YYYY-MM-DD"],  "2019-01-25"]
    - [year_only,  ["2019-01-25"],  ["YYYY"],        "2019"]

table dayjs.components:
  kind: node_factory_call_eq
  function: ~
  category: components
  id_prefix: dj_comp

  columns: [id, args, method, method_args, expected]
  rows:
    - [year,   ["2019-01-25"],  year,   [],  2019]
    - [month,  ["2019-01-25"],  month,  [],  0]
    - [date,   ["2019-01-25"],  date,   [],  25]
