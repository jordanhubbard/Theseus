spec: re_extra209
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c — C extension SRE engine"
  notes:
    - "This spec covers: __code__ attributes of re module Python-level functions."
    - "re.compile.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108867 on Python 3.14.3."
    - "re.match.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108867."
    - "re.sub.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108871."
    - "re.compile.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 4."
    - "re.match.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 4."
    - "re.sub.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 7."
    - "re.compile.__code__.co_filename.__class__.__name__ == 'str' — source file path string."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.compile.__code__ co_flags and co_stacksize — class names
#
# re.compile is a Python function.
# __code__.co_flags.__class__.__name__ == 'int'  (value 67108867)
# __code__.co_stacksize.__class__.__name__ == 'int'  (value 4)
# __code__.co_filename.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table re_extra209.compile_code_attrs:
  description: "re.compile.__code__ attribute types — co_flags and co_stacksize are int; co_filename is str; co_flags==67108867; co_stacksize==4; verified Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: recoflags209

  columns: [id, function, args, expected, description]
  rows:
    - [compile_coflags_cls,      re.compile.__code__.co_flags.__class__.__name__.__eq__,      ["int"], true,  "re.compile.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108867; verified Python 3.14.3"]
    - [compile_costacksize_cls,  re.compile.__code__.co_stacksize.__class__.__name__.__eq__,  ["int"], true,  "re.compile.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 4; verified Python 3.14.3"]
    - [compile_cofilename_cls,   re.compile.__code__.co_filename.__class__.__name__.__eq__,   ["str"], true,  "re.compile.__code__.co_filename.__class__.__name__ == 'str' — co_filename is source file path; verified Python 3.14.3"]
    - [compile_coflags_not_str,  re.compile.__code__.co_flags.__class__.__name__.__eq__,      ["str"], false, "re.compile.__code__.co_flags.__class__.__name__ != 'str' — co_flags is int bitmask; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# re.match.__code__ co_flags and co_stacksize — class names
#
# re.match is a Python function.
# __code__.co_flags.__class__.__name__ == 'int'  (value 67108867)
# __code__.co_stacksize.__class__.__name__ == 'int'  (value 4)
# __code__.co_filename.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table re_extra209.match_code_attrs:
  description: "re.match.__code__ attribute types — co_flags and co_stacksize are int; co_filename is str; co_flags==67108867; co_stacksize==4; verified Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: recoflags209

  columns: [id, function, args, expected, description]
  rows:
    - [match_coflags_cls,      re.match.__code__.co_flags.__class__.__name__.__eq__,      ["int"], true,  "re.match.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108867; same as re.compile; verified Python 3.14.3"]
    - [match_costacksize_cls,  re.match.__code__.co_stacksize.__class__.__name__.__eq__,  ["int"], true,  "re.match.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 4; same as re.compile; verified Python 3.14.3"]
    - [match_cofilename_cls,   re.match.__code__.co_filename.__class__.__name__.__eq__,   ["str"], true,  "re.match.__code__.co_filename.__class__.__name__ == 'str' — source file path; verified Python 3.14.3"]
    - [match_coflags_not_float, re.match.__code__.co_flags.__class__.__name__.__eq__,     ["float"], false, "re.match.__code__.co_flags.__class__.__name__ != 'float' — co_flags is int; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# re.sub.__code__ co_flags and co_stacksize — class names
#
# re.sub is a Python function.
# __code__.co_flags.__class__.__name__ == 'int'  (value 67108871)
# __code__.co_stacksize.__class__.__name__ == 'int'  (value 7)
# __code__.co_filename.__class__.__name__ == 'str'
# ---------------------------------------------------------------------------

table re_extra209.sub_code_attrs:
  description: "re.sub.__code__ attribute types — co_flags and co_stacksize are int; co_filename is str; co_flags==67108871; co_stacksize==7; verified Python 3.14.3"
  kind: python_call_eq
  category: code_attrs
  id_prefix: recoflags209

  columns: [id, function, args, expected, description]
  rows:
    - [sub_coflags_cls,      re.sub.__code__.co_flags.__class__.__name__.__eq__,      ["int"], true,  "re.sub.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108871; differs from compile/match; verified Python 3.14.3"]
    - [sub_costacksize_cls,  re.sub.__code__.co_stacksize.__class__.__name__.__eq__,  ["int"], true,  "re.sub.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 7; larger than compile/match (4); verified Python 3.14.3"]
    - [sub_cofilename_cls,   re.sub.__code__.co_filename.__class__.__name__.__eq__,   ["str"], true,  "re.sub.__code__.co_filename.__class__.__name__ == 'str' — co_filename source file path; verified Python 3.14.3"]
    - [sub_coflags_not_none, re.sub.__code__.co_flags.__class__.__name__.__eq__,      ["NoneType"], false, "re.sub.__code__.co_flags.__class__.__name__ != 'NoneType' — co_flags is int; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — re_extra209
# ---------------------------------------------------------------------------

invariant re_extra209.compile_co_flags_class_name:
  description: "re.compile.__code__.co_flags.__class__.__name__ == 'int' — co_flags is a CPython integer bitmask encoding function compilation flags; value 67108867 on Python 3.14.3; re.compile is a pure-Python wrapper around the SRE C engine; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: re.compile.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant re_extra209.match_co_flags_class_name:
  description: "re.match.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108867 on Python 3.14.3; same bitmask as re.compile; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: re.match.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant re_extra209.sub_co_flags_class_name:
  description: "re.sub.__code__.co_flags.__class__.__name__ == 'int' — co_flags value 67108871 on Python 3.14.3; differs from re.compile and re.match (67108867) due to different compilation characteristics; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: re.sub.__code__.co_flags.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant re_extra209.compile_co_stacksize_class_name:
  description: "re.compile.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize is the maximum frame stack depth required; value 4 on Python 3.14.3; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: re.compile.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant re_extra209.compile_co_filename_class_name:
  description: "re.compile.__code__.co_filename.__class__.__name__ == 'str' — co_filename records the source file path where re.compile was defined; always a string in CPython; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: re.compile.__code__.co_filename.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant re_extra209.match_co_stacksize_class_name:
  description: "re.match.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 4 on Python 3.14.3; same stack depth as re.compile; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: re.match.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant re_extra209.sub_co_stacksize_class_name:
  description: "re.sub.__code__.co_stacksize.__class__.__name__ == 'int' — co_stacksize value 7 on Python 3.14.3; larger than re.compile and re.match (4) reflecting re.sub's more complex logic with replacement handling; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: re.sub.__code__.co_stacksize.__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant re_extra209.compile_co_flags_not_str:
  description: "re.compile.__code__.co_flags.__class__.__name__ != 'str' — co_flags is always an integer in CPython; it encodes flags like CO_OPTIMIZED (0x1), CO_NEWLOCALS (0x2), CO_VARARGS (0x4) etc. as bit positions; never a string; verified Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: code_attrs
  kind: python_call_eq
  function: re.compile.__code__.co_flags.__class__.__name__.__eq__
  args: ["str"]
  expected: false
