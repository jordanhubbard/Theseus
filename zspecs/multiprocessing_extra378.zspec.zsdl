spec: multiprocessing_extra378
version: ">=3.9"
backend: python_module(multiprocessing)
docs: https://docs.python.org/3/library/multiprocessing.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "multiprocessing.Process lives in module multiprocessing.context and derives from BaseProcess"
    - "multiprocessing.process.BaseProcess lives in module multiprocessing.process and derives from object"
    - "multiprocessing.current_process lives in module multiprocessing.process"
    - "multiprocessing.active_children lives in module multiprocessing.process"
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table multiprocessing_extra378.class_names:
  description: "Verify __name__ attribute of multiprocessing Process classes"
  kind: python_call_eq
  category: identity
  id_prefix: mp378n

  columns: [id, function, args, expected]
  rows:
    - [mp378n001, multiprocessing.Process.__name__.__eq__, ["Process"], true]
    - [mp378n002, multiprocessing.process.BaseProcess.__name__.__eq__, ["BaseProcess"], true]

table multiprocessing_extra378.class_modules:
  description: "Verify __module__ attribute of multiprocessing Process classes"
  kind: python_call_eq
  category: identity
  id_prefix: mp378m

  columns: [id, function, args, expected]
  rows:
    - [mp378m001, multiprocessing.Process.__module__.__eq__, ["multiprocessing.context"], true]
    - [mp378m002, multiprocessing.process.BaseProcess.__module__.__eq__, ["multiprocessing.process"], true]

table multiprocessing_extra378.class_bases:
  description: "Verify __bases__[0].__name__ (first immediate base class name) of multiprocessing Process classes"
  kind: python_call_eq
  category: identity
  id_prefix: mp378b

  columns: [id, function, args, expected]
  rows:
    - ["mp378b001", "multiprocessing.Process.__bases__[0].__name__.__eq__", ["BaseProcess"], true]
    - ["mp378b002", "multiprocessing.process.BaseProcess.__bases__[0].__name__.__eq__", ["object"], true]

table multiprocessing_extra378.function_names:
  description: "Verify __name__ attribute of multiprocessing top-level functions"
  kind: python_call_eq
  category: identity
  id_prefix: mp378fn

  columns: [id, function, args, expected]
  rows:
    - [mp378fn001, multiprocessing.current_process.__name__.__eq__, ["current_process"], true]
    - [mp378fn002, multiprocessing.active_children.__name__.__eq__, ["active_children"], true]

table multiprocessing_extra378.function_modules:
  description: "Verify __module__ attribute of multiprocessing top-level functions"
  kind: python_call_eq
  category: identity
  id_prefix: mp378fm

  columns: [id, function, args, expected]
  rows:
    - [mp378fm001, multiprocessing.current_process.__module__.__eq__, ["multiprocessing.process"], true]
    - [mp378fm002, multiprocessing.active_children.__module__.__eq__, ["multiprocessing.process"], true]
