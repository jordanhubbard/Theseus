spec: async_retry
version: ">=1.0.0"
backend: node(async-retry)

docs: https://github.com/vercel/async-retry#readme

provenance:
  derived_from:
    - "async-retry README — https://github.com/vercel/async-retry#readme"
    - "Test vectors verified with async-retry via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "async-retry source"
  notes:
    - "Promise-based retry — wraps an async function and returns a new function."
    - "Install: npm install async-retry"
    - "v1 CJS; module export IS the asyncRetry function."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Throws the last error if all retries fail."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant async_retry.module_is_function:
  description: "Module export is a function"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "constructor.name"}
  expected: "Function"

invariant async_retry.factory_arity:
  description: "asyncRetry takes (fn, options) — function.length 2"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: length}
  expected: 2

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: claude-cli
  attempted_at: 2026-05-04T05:39:30Z
  iterations: 1
  pass_count: 2
  fail_count: 0
  total_invariants: 2
  notes: Synthesis succeeded in 1 iteration(s). 2 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
