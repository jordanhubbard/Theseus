spec: itertools_extra2476
version: ">=3.9"
backend: python_module(itertools)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/itertools.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 2476 (_extra2476): __contains__ and __getitem__ dict-presence checks across itertools types."
    - "Theme: membership-test and item-access protocol presence in class __dict__."
    - "All itertools types are lazy iterators — none define __contains__ or __getitem__ in their __dict__."
    - "itertools.chain: defines __iter__, __next__, __new__, from_iterable — no __contains__ or __getitem__."
    - "itertools.cycle: defines __iter__, __next__, __new__ — no __contains__ or __getitem__."
    - "itertools.count: defines __iter__, __next__, __new__, __repr__ — no __contains__ or __getitem__."
    - "itertools.repeat: defines __iter__, __next__, __new__, __repr__, __length_hint__ — no __contains__ or __getitem__."
    - "itertools.groupby, islice, compress, dropwhile, takewhile, zip_longest: none define __contains__ or __getitem__."
    - "itertools.product, permutations, combinations, accumulate, filterfalse, starmap: same — no membership or item protocols."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# Table 1: __contains__ dict-presence across core itertools iterator types
#
# Lazy iterator classes (chain, cycle, count, islice, repeat, groupby)
# produce values on demand — they are not containers and do not support the
# `in` membership operator via __contains__ defined in their class __dict__.
# All checks return False.
# ---------------------------------------------------------------------------

table itertools_extra2476.contains_core_iterators:
  description: "itertools core lazy iterator types __contains__ dict-presence — all False — wave 2476"
  kind: python_call_eq
  category: dict_contains
  id_prefix: it2476

  columns: [id, function, args, expected]
  rows:
    - ["it2476001", "itertools.chain.__dict__.__contains__", ["__contains__"], false]
    - ["it2476002", "itertools.cycle.__dict__.__contains__", ["__contains__"], false]
    - ["it2476003", "itertools.count.__dict__.__contains__", ["__contains__"], false]
    - ["it2476004", "itertools.islice.__dict__.__contains__", ["__contains__"], false]
    - ["it2476005", "itertools.repeat.__dict__.__contains__", ["__contains__"], false]
    - ["it2476006", "itertools.groupby.__dict__.__contains__", ["__contains__"], false]

# ---------------------------------------------------------------------------
# Table 2: __getitem__ dict-presence across core itertools iterator types
#
# None of the core lazy iterator types define __getitem__. Index-based
# access is not supported on lazy sequences — all return False.
# ---------------------------------------------------------------------------

