    - ["it2476009", "itertools.count.__dict__.__contains__", ["__getitem__"], false]
    - ["it2476010", "itertools.islice.__dict__.__contains__", ["__getitem__"], false]
    - ["it2476011", "itertools.repeat.__dict__.__contains__", ["__getitem__"], false]
    - ["it2476012", "itertools.groupby.__dict__.__contains__", ["__getitem__"], false]

