spec: uuid_extra370
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — uuid documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "uuid.uuid1.__name__ == 'uuid1'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid1.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__name__ == 'uuid3'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid3.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__name__ == 'uuid4'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid4.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__name__ == 'uuid5'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.uuid5.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__name__ == 'getnode'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "uuid.getnode.__module__ == 'uuid'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: All uuid generator functions (uuid1, uuid3, uuid4, uuid5) and getnode are pure-Python functions defined in Lib/uuid.py; their __module__ is 'uuid' and __name__ matches the function name."
    - "Note: uuid1 generates a time-based UUID (RFC 4122 version 1). uuid3 uses MD5 hashing (version 3). uuid4 uses random bytes (version 4). uuid5 uses SHA-1 hashing (version 5)."
    - "Note: getnode returns the hardware address of the machine as a 48-bit integer (MAC address). It is defined in Lib/uuid.py."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.uuid1.__name__ / uuid.uuid1.__module__
# uuid.uuid3.__name__ / uuid.uuid3.__module__
# uuid.uuid4.__name__ / uuid.uuid4.__module__
# uuid.uuid5.__name__ / uuid.uuid5.__module__
# uuid.getnode.__name__ / uuid.getnode.__module__
#
# Wave 370 theme: uuid module function identity.
#
# All five functions (uuid1, uuid3, uuid4, uuid5, getnode) are pure-Python
# functions defined in Lib/uuid.py. Their __name__ attributes match the
# function names exactly, and their __module__ is 'uuid' for all of them.
#
# uuid1: RFC 4122 version 1 UUID — generated from the current time and the
#        machine's MAC address (hardware node ID).
# uuid3: RFC 4122 version 3 UUID — generated from an MD5 hash of a namespace
#        UUID and a name string.
# uuid4: RFC 4122 version 4 UUID — generated from random bytes (cryptographically
#        random via os.urandom).
# uuid5: RFC 4122 version 5 UUID — generated from a SHA-1 hash of a namespace
#        UUID and a name string.
# getnode: Returns the hardware address as a 48-bit integer (MAC address);
#          falls back to a random 48-bit integer with multicast bit set if no
#          MAC address is available.
#
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table uuid_extra370.generator_dunder_name:
  description: "uuid generator function __name__ identity — uuid1/uuid3/uuid4/uuid5/getnode are all pure-Python functions in Lib/uuid.py; __name__ matches the public function name exactly; verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfnid370

  columns: [id, function, args, expected]
  rows:
    - [uuid1_name,   uuid1.__name__.__eq__,   ["uuid1"],   true]
    - [uuid3_name,   uuid3.__name__.__eq__,   ["uuid3"],   true]
    - [uuid4_name,   uuid4.__name__.__eq__,   ["uuid4"],   true]
    - [uuid5_name,   uuid5.__name__.__eq__,   ["uuid5"],   true]
    - [getnode_name, getnode.__name__.__eq__, ["getnode"], true]

table uuid_extra370.generator_dunder_module:
  description: "uuid generator function __module__ identity — uuid1/uuid3/uuid4/uuid5/getnode all report __module__=='uuid' since they are defined in Lib/uuid.py (pure Python, not a C extension); verified Python 3.14.3 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: function_identity
  id_prefix: uuidfnid370

  columns: [id, function, args, expected]
  rows:
    - [uuid1_module,   uuid1.__module__.__eq__,   ["uuid"], true]
    - [uuid3_module,   uuid3.__module__.__eq__,   ["uuid"], true]
    - [uuid4_module,   uuid4.__module__.__eq__,   ["uuid"], true]
    - [uuid5_module,   uuid5.__module__.__eq__,   ["uuid"], true]
    - [getnode_module, getnode.__module__.__eq__, ["uuid"], true]

# ---------------------------------------------------------------------------
# uuid.uuid4.__name__ == 'uuid4' — standalone
#
# uuid.uuid4 is the most commonly used UUID generator. It produces a
# version-4 UUID from 122 bits of cryptographically random data (generated
# via os.urandom). It is defined in Lib/uuid.py as a plain Python function.
# Its __name__ is 'uuid4' and its __module__ is 'uuid'. RFC 4122 version 4
# UUIDs are suitable for generating unique identifiers without needing
# coordination between nodes. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra370.uuid4_name:
  description: "uuid.uuid4.__name__.__eq__('uuid4') == True — uuid4 is a pure-Python function in Lib/uuid.py; generates RFC 4122 version-4 UUIDs from 122 bits of os.urandom randomness; __name__ is 'uuid4'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: uuid4.__name__.__eq__
  args: ["uuid4"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.getnode.__module__ == 'uuid' — standalone
#
# uuid.getnode returns the hardware address of the machine as a 48-bit
# positive integer. It tries several platform-specific methods to read
# the MAC address and falls back to a random 48-bit integer (with the
# multicast bit set) if no MAC can be determined. It is a pure-Python
# function defined in Lib/uuid.py. Its __module__ is 'uuid'. Verified
# Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra370.getnode_module:
  description: "uuid.getnode.__module__.__eq__('uuid') == True — getnode is a pure-Python function in Lib/uuid.py; returns machine's 48-bit hardware address (MAC) or random fallback; __module__ is 'uuid'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: getnode.__module__.__eq__
  args: ["uuid"]
  expected: true

# ---------------------------------------------------------------------------
# uuid.uuid1.__module__ == 'uuid' — standalone
#
# uuid.uuid1 generates a time-based UUID per RFC 4122 version 1. It
# combines the current timestamp (100-nanosecond intervals since 15 Oct
# 1582) with the machine's MAC address (via getnode). It is a pure-Python
# function defined in Lib/uuid.py. Its __module__ is 'uuid'. The time-based
# nature means uuid1 values can reveal information about when and where they
# were generated. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant uuid_extra370.uuid1_module:
  description: "uuid.uuid1.__module__.__eq__('uuid') == True — uuid1 is a pure-Python function in Lib/uuid.py; generates RFC 4122 version-1 time-based UUIDs using current timestamp and MAC address; __module__ is 'uuid'; verified Python 3.14.3 macOS/Darwin 25.4.0"
  category: function_identity
  kind: python_call_eq
  function: uuid1.__module__.__eq__
  args: ["uuid"]
  expected: true
