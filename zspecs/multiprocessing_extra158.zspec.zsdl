#
# multiprocessing.Process.__dict__.__contains__('_bootstrap') == False
# multiprocessing.Process.__dict__.__contains__('__repr__')   == False
# multiprocessing.Process.__dict__.__contains__('pid')        == False
# multiprocessing.Process.__dict__.__contains__('exitcode')   == False
# ---------------------------------------------------------------------------

table multiprocessing_extra158.process_dict_absent:
  description: "multiprocessing.Process.__dict__ absent membership checks in mpannotations158 namespace — Process inherits from BaseProcess; most methods are NOT in Process.__dict__ because they are defined on BaseProcess; Process.__dict__.__contains__('_bootstrap')==False (_bootstrap is a method on BaseProcess); __contains__('__repr__')==False (__repr__ is on BaseProcess); __contains__('pid')==False (pid is a property on BaseProcess); __contains__('exitcode')==False (exitcode is a property on BaseProcess); Process.__dict__ on 3.14.3 contains only: _start_method, _Popen, _after_fork, __module__, __firstlineno__, __static_attributes__, __doc__; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: mpannotations158a

  columns: [id, function, args, expected, description]
  rows:
    - [process_dict_no_bootstrap,  "multiprocessing.Process.__dict__.__contains__",   ["_bootstrap"],  false, "multiprocessing.Process.__dict__.__contains__('_bootstrap') == False (on BaseProcess); verified Python 3.14.3"]
    - [process_dict_no_repr,       "multiprocessing.Process.__dict__.__contains__",   ["__repr__"],    false, "multiprocessing.Process.__dict__.__contains__('__repr__') == False (on BaseProcess); verified Python 3.14.3"]
    - [process_dict_no_pid,        "multiprocessing.Process.__dict__.__contains__",   ["pid"],         false, "multiprocessing.Process.__dict__.__contains__('pid') == False (property on BaseProcess); verified Python 3.14.3"]
    - [process_dict_no_exitcode,   "multiprocessing.Process.__dict__.__contains__",   ["exitcode"],    false, "multiprocessing.Process.__dict__.__contains__('exitcode') == False (property on BaseProcess); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: multiprocessing.Process.__dict__ — items PRESENT (defined on Process)
#
# multiprocessing.Process.__dict__.__contains__('_start_method') == True
# multiprocessing.Process.__dict__.__contains__('_Popen')        == True
# multiprocessing.Process.__dict__.__contains__('_after_fork')   == True
# multiprocessing.Process.__dict__.__contains__('authkey')       == False  (on BaseProcess)
# ---------------------------------------------------------------------------

table multiprocessing_extra158.process_dict_present:
  description: "multiprocessing.Process.__dict__ present membership checks in mpannotations158 namespace — Process defines only a small number of items directly: __contains__('_start_method')==True (_start_method is set to None on Process, overriding the BaseProcess class variable; subclasses like SpawnProcess set it to 'spawn'); __contains__('_Popen')==True (_Popen is a static method on Process, None by default; subclasses override it to point to the platform-specific Popen class); __contains__('_after_fork')==True (_after_fork is a method defined on Process for post-fork cleanup); __contains__('authkey')==False (authkey is a property on BaseProcess, not Process); verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: mpannotations158b

  columns: [id, function, args, expected, description]
  rows:
    - [process_dict_has_start_method,  "multiprocessing.Process.__dict__.__contains__",   ["_start_method"],  true,  "multiprocessing.Process.__dict__.__contains__('_start_method') == True; verified Python 3.14.3"]
    - [process_dict_has_popen,         "multiprocessing.Process.__dict__.__contains__",   ["_Popen"],         true,  "multiprocessing.Process.__dict__.__contains__('_Popen') == True; verified Python 3.14.3"]
    - [process_dict_has_after_fork,    "multiprocessing.Process.__dict__.__contains__",   ["_after_fork"],    true,  "multiprocessing.Process.__dict__.__contains__('_after_fork') == True; verified Python 3.14.3"]
    - [process_dict_no_authkey,        "multiprocessing.Process.__dict__.__contains__",   ["authkey"],        false, "multiprocessing.Process.__dict__.__contains__('authkey') == False (property on BaseProcess); verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — multiprocessing_extra158
# ---------------------------------------------------------------------------

invariant multiprocessing_extra158.process_init_annotations_class_name_dict:
  description: "multiprocessing.Process.__init__.__annotations__.__class__.__name__.__eq__('dict') returns True — Process.__init__.__annotations__ is a plain dict; on Python 3.14.3 Process.__init__ carries no PEP-3107 type annotations so the dict is empty ({}), but __annotations__.__class__.__name__ is 'dict' (len=4: d-i-c-t); __annotations__ is always a dict even when empty; NEW in extra158: first standalone mp.Process.__init__ annotations class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: annotations
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__annotations__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant multiprocessing_extra158.process_init_annotations_len_zero:
  description: "multiprocessing.Process.__init__.__annotations__.__len__() returns 0 — Process.__init__ has no type annotations on Python 3.14.3; __annotations__ is an empty dict with length 0; Process.__init__(self, group=None, target=None, name=None, args=(), kwargs={}, daemon=None) takes six keyword parameters but none are annotated; compare: __code__.co_varnames includes parameter names while __annotations__ remains empty; NEW in extra158; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: annotations
  kind: python_call_eq
  function: multiprocessing.Process.__init__.__annotations__.__len__
  args: []
  expected: 0

invariant multiprocessing_extra158.process_dict_no_bootstrap:
  description: "multiprocessing.Process.__dict__.__contains__('_bootstrap') returns False — _bootstrap() is a critical internal method but it is defined on BaseProcess, NOT on Process; Process inherits _bootstrap from BaseProcess; Process.__dict__ on Python 3.14.3 contains only 7 entries: _start_method, _Popen, _after_fork, __module__, __firstlineno__, __static_attributes__, __doc__; '_bootstrap' is NOT in Process.__dict__; NEW in extra158; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["_bootstrap"]
  expected: false

invariant multiprocessing_extra158.process_dict_no_repr:
  description: "multiprocessing.Process.__dict__.__contains__('__repr__') returns False — __repr__() is defined on BaseProcess, not on Process itself; Process inherits __repr__ from BaseProcess; '__repr__' is NOT in Process.__dict__; this is consistent with most Process methods (start, run, join, terminate, kill, is_alive, pid, exitcode, authkey, sentinel, name, daemon) all being inherited from BaseProcess rather than redefined on Process; NEW in extra158; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["__repr__"]
  expected: false

invariant multiprocessing_extra158.process_dict_no_pid:
  description: "multiprocessing.Process.__dict__.__contains__('pid') returns False — pid is a property defined on BaseProcess (via @property decorator); Process inherits pid from BaseProcess; 'pid' is NOT in Process.__dict__; similarly, exitcode and authkey are also properties on BaseProcess absent from Process.__dict__; this reflects the design where Process is a thin subclass that overrides only _start_method, _Popen, and _after_fork; NEW in extra158; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["pid"]
  expected: false

invariant multiprocessing_extra158.process_dict_no_exitcode:
  description: "multiprocessing.Process.__dict__.__contains__('exitcode') returns False — exitcode is a property defined on BaseProcess, not on Process; 'exitcode' is NOT in Process.__dict__; Process.exitcode returns the exit status of the child process (None if it hasn't terminated, negative if killed by a signal); the property implementation lives in BaseProcess; NEW in extra158; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["exitcode"]
  expected: false

invariant multiprocessing_extra158.process_dict_has_start_method:
  description: "multiprocessing.Process.__dict__.__contains__('_start_method') returns True — _start_method is set to None directly on the Process class body (overriding or shadowing the BaseProcess class variable); subclasses such as SpawnProcess set _start_method = 'spawn' and ForkProcess sets _start_method = 'fork'; '_start_method' IS in Process.__dict__; this is one of the few items defined directly on Process rather than inherited from BaseProcess; NEW in extra158; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["_start_method"]
  expected: true

invariant multiprocessing_extra158.process_dict_has_popen:
  description: "multiprocessing.Process.__dict__.__contains__('_Popen') returns True — _Popen is a static method set to None on the Process class body; platform-specific subclasses override _Popen to point to the appropriate process-creation class (e.g. SpawnProcess._Popen = popen_spawn_posix.Popen on POSIX); '_Popen' IS in Process.__dict__ alongside '_start_method' and '_after_fork'; these three are the only Process-specific overrides on Python 3.14.3; NEW in extra158; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: multiprocessing.Process.__dict__.__contains__
  args: ["_Popen"]
  expected: true

