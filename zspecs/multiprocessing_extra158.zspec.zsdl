spec: multiprocessing_extra158
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
  notes:
    - "multiprocessing.Process.__init__.__annotations__.__class__.__name__ == 'dict' — annotations is always a plain dict; Process.__init__ has no type annotations on Python 3.14.3."
    - "multiprocessing.Process inherits from BaseProcess; most methods (start, run, join, pid, exitcode, authkey, _bootstrap, __repr__) are defined on BaseProcess, NOT on Process itself."
    - "multiprocessing.Process.__dict__ on Python 3.14.3 contains only: __module__, __firstlineno__, _start_method, _Popen, _after_fork, __static_attributes__, __doc__."
    - "multiprocessing.Process.__dict__.__contains__('_bootstrap') returns False — _bootstrap is defined on BaseProcess, not Process."
    - "multiprocessing.Process.__dict__.__contains__('__repr__') returns False — __repr__ is defined on BaseProcess, not Process."
    - "multiprocessing.Process.__dict__.__contains__('pid') returns False — pid is a property defined on BaseProcess, not Process."
    - "multiprocessing.Process.__dict__.__contains__('exitcode') returns False — exitcode is a property defined on BaseProcess, not Process."
    - "multiprocessing.Process.__dict__.__contains__('authkey') returns False — authkey is a property defined on BaseProcess, not Process."
    - "multiprocessing.Process.__dict__.__contains__('_start_method') returns True — _start_method is set to None on Process (overriding BaseProcess's class variable)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Process.__init__.__annotations__ checks
#
# multiprocessing.Process.__init__.__annotations__.__class__.__name__ == 'dict'
# multiprocessing.Process.__init__.__annotations__.__len__()          == 0
# multiprocessing.Process.__init__.__annotations__.__contains__('return') == False
# multiprocessing.Process.__init__.__annotations__.__contains__('target') == False
# ---------------------------------------------------------------------------

table multiprocessing_extra158.process_init_annotations:
  description: "multiprocessing.Process.__init__.__annotations__ class name and membership checks in mpannotations158 namespace — Process.__init__.__annotations__.__class__.__name__=='dict' (annotations is always a plain dict; Process.__init__ has no type annotations on Python 3.14.3 so the dict is empty); __len__()==0 (no annotated parameters or return type); __contains__('return')==False (no return annotation); __contains__('target')==False ('target' is a parameter of Process.__init__ but carries no annotation); Process.__init__(group=None, target=None, name=None, args=(), kwargs={}, daemon=None) takes six parameters; verified with Python 3.14.3"
  kind: python_call_eq
  category: annotations
  id_prefix: mpannotations158

  columns: [id, function, args, expected, description]
  rows:
    - [process_init_annotations_class_name,    "multiprocessing.Process.__init__.__annotations__.__class__.__name__.__eq__",   ["dict"],     true,  "multiprocessing.Process.__init__.__annotations__.__class__.__name__ == 'dict'; verified Python 3.14.3"]
    - [process_init_annotations_len,           "multiprocessing.Process.__init__.__annotations__.__len__",                     [],           0,     "multiprocessing.Process.__init__.__annotations__.__len__() == 0 (no annotations); verified Python 3.14.3"]
    - [process_init_annotations_no_return,     "multiprocessing.Process.__init__.__annotations__.__contains__",                ["return"],   false, "multiprocessing.Process.__init__.__annotations__.__contains__('return') == False; verified Python 3.14.3"]
    - [process_init_annotations_no_target,     "multiprocessing.Process.__init__.__annotations__.__contains__",                ["target"],   false, "multiprocessing.Process.__init__.__annotations__.__contains__('target') == False; verified Python 3.14.3"]

