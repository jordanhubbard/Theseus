spec: multiprocessing_extra158
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "This spec covers: multiprocessing.Manager, multiprocessing.Value, and multiprocessing.Array function identity. All three are bound methods of BaseContext (like multiprocessing.Pipe and multiprocessing.Queue established in prior specs). multiprocessing.Manager.__qualname__=='BaseContext.Manager' (len=19: 'BaseContext'=11+'.'=1+'Manager'=7=19); multiprocessing.Manager.__class__.__name__=='method' (len=6; bound method of a BaseContext instance — NOT a function or class); multiprocessing.Manager.__module__=='multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23; all three bound methods are defined in Lib/multiprocessing/context.py); multiprocessing.Value.__qualname__=='BaseContext.Value' (len=17); multiprocessing.Array.__qualname__=='BaseContext.Array' (len=17; same length as Value because 'Value'=5 == 'Array'=5). All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Manager.__class__.__name__=='method' — Manager is a bound method of the default BaseContext instance (not a class or standalone function); this follows the same pattern as multiprocessing.Pipe and multiprocessing.Queue (both are also bound methods of BaseContext with __class__.__name__=='method'); Manager() returns a SyncManager instance that provides managed objects shared across processes (Manager().dict(), Manager().list(), Manager().Queue(), etc.); __qualname__=='BaseContext.Manager' confirms Manager is defined on the BaseContext class. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.Value.__qualname__=='BaseContext.Value' (len=17: 'BaseContext'=11+'.'=1+'Value'=5=17) and multiprocessing.Array.__qualname__=='BaseContext.Array' (len=17: 'BaseContext'=11+'.'=1+'Array'=5=17) — both Value and Array qualnames are the same length (17) because 'Value' and 'Array' are both 5-character names; compare: Manager qualname length==19 ('Manager'=7 > 'Value'=5 > 'Array'=5... wait: 'Manager'=7, 'Value'=5, 'Array'=5 — Manager(19) > Value(17) == Array(17)); all three are bound methods of BaseContext with __module__=='multiprocessing.context'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.Manager function identity — extra158
#
# multiprocessing.Manager.__qualname__.__eq__('BaseContext.Manager')     == True
# multiprocessing.Manager.__class__.__name__.__eq__('method')            == True
# multiprocessing.Manager.__module__.__eq__('multiprocessing.context')   == True
# ---------------------------------------------------------------------------

table multiprocessing_extra158.mp_manager_identity:
  description: "multiprocessing.Manager function identity checks in mpmgr158 namespace — multiprocessing.Manager.__qualname__=='BaseContext.Manager' (len=19: 'BaseContext'=11+'.'=1+'Manager'=7=19; Manager is a bound method on the BaseContext class; the qualname 'BaseContext.Manager' reveals it is defined on BaseContext in Lib/multiprocessing/context.py, not as a standalone function); multiprocessing.Manager.__class__.__name__=='method' (len=6; Manager is a bound method of the default BaseContext instance — NOT a function or class; this is the same pattern as multiprocessing.Pipe and multiprocessing.Queue established in prior specs); multiprocessing.Manager.__module__=='multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23; all context-accessed multiprocessing functions live in Lib/multiprocessing/context.py); Manager() returns a SyncManager instance for creating managed shared objects (dicts, lists, queues, etc.); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpmgr158

  columns: [id, function, args, expected, description]
  rows:
    - [mgr_qn_eq,   multiprocessing.Manager.__qualname__.__eq__,          ["BaseContext.Manager"],        true,  "mp.Manager.__qualname__ == 'BaseContext.Manager' (len=19; bound method on BaseContext); verified with Python 3.14.3"]
    - [mgr_cls_eq,  multiprocessing.Manager.__class__.__name__.__eq__,    ["method"],                     true,  "mp.Manager.__class__.__name__ == 'method' (len=6; bound method, not function or class); verified with Python 3.14.3"]
    - [mgr_mod_eq,  multiprocessing.Manager.__module__.__eq__,            ["multiprocessing.context"],    true,  "mp.Manager.__module__ == 'multiprocessing.context' (len=23; defined in context.py); verified with Python 3.14.3"]
    - [mgr_qn_len,  multiprocessing.Manager.__qualname__.__len__,         [],                             19,    "mp.Manager.__qualname__.__len__() == 19 ('BaseContext.Manager'; longest among Manager/Value/Array); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Value function identity — extra158
#
# multiprocessing.Value.__qualname__.__eq__('BaseContext.Value')    == True
# multiprocessing.Value.__class__.__name__.__eq__('method')         == True
# ---------------------------------------------------------------------------

table multiprocessing_extra158.mp_value_identity:
  description: "multiprocessing.Value function identity checks in mpval158 namespace — multiprocessing.Value.__qualname__=='BaseContext.Value' (len=17: 'BaseContext'=11+'.'=1+'Value'=5=17; Value is a bound method of the default BaseContext instance; qualname 'BaseContext.Value' confirms it is defined on BaseContext); multiprocessing.Value.__class__.__name__=='method' (len=6; same class as Manager and Array — all are bound methods of BaseContext); multiprocessing.Value.__module__=='multiprocessing.context' (len=23; same module as Manager and Array); multiprocessing.Value.__name__=='Value' (len=5: 'V'+'a'+'l'+'u'+'e'=5; the __name__ of the bound method); Value() creates a shared ctypes value in shared memory, allowing multiple processes to access and modify the same scalar value atomically; Value.__qualname__.__len__()==17 (same as Array.__qualname__.__len__()==17 since 'Value'=5=='Array'=5); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpval158

  columns: [id, function, args, expected, description]
  rows:
    - [val_qn_eq,   multiprocessing.Value.__qualname__.__eq__,          ["BaseContext.Value"],          true,  "mp.Value.__qualname__ == 'BaseContext.Value' (len=17; bound method on BaseContext); verified with Python 3.14.3"]
    - [val_cls_eq,  multiprocessing.Value.__class__.__name__.__eq__,    ["method"],                     true,  "mp.Value.__class__.__name__ == 'method' (len=6; bound method, same as Manager and Array); verified with Python 3.14.3"]
    - [val_mod_eq,  multiprocessing.Value.__module__.__eq__,            ["multiprocessing.context"],    true,  "mp.Value.__module__ == 'multiprocessing.context' (len=23; same module as Manager and Array); verified with Python 3.14.3"]
    - [val_name_eq, multiprocessing.Value.__name__.__eq__,              ["Value"],                      true,  "mp.Value.__name__ == 'Value' (len=5; the bound method name); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# multiprocessing.Array function identity — extra158
#
# multiprocessing.Array.__qualname__.__eq__('BaseContext.Array')    == True
# multiprocessing.Array.__class__.__name__.__eq__('method')         == True
# multiprocessing.Array.__qualname__.__len__()                      == 17
# ---------------------------------------------------------------------------

table multiprocessing_extra158.mp_array_identity:
  description: "multiprocessing.Array function identity checks in mparray158 namespace — multiprocessing.Array.__qualname__=='BaseContext.Array' (len=17: 'BaseContext'=11+'.'=1+'Array'=5=17; same length as Value.__qualname__='BaseContext.Value'=17 because 'Array'=5=='Value'=5); multiprocessing.Array.__class__.__name__=='method' (len=6; bound method of BaseContext instance — same class as Manager and Value); multiprocessing.Array.__module__=='multiprocessing.context' (len=23; same module as Manager and Value); multiprocessing.Array.__name__=='Array' (len=5: 'A'+'r'+'r'+'a'+'y'=5; same length as 'Value'=5); Array() creates a shared ctypes array in shared memory, allowing multiple processes to read and write array elements; qualname length ordering: Value(17)==Array(17) < Manager(19); both Value and Array have the same qualname length; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mparray158

  columns: [id, function, args, expected, description]
  rows:
    - [arr_qn_eq,    multiprocessing.Array.__qualname__.__eq__,          ["BaseContext.Array"],          true,  "mp.Array.__qualname__ == 'BaseContext.Array' (len=17; bound method on BaseContext); verified with Python 3.14.3"]
    - [arr_cls_eq,   multiprocessing.Array.__class__.__name__.__eq__,    ["method"],                     true,  "mp.Array.__class__.__name__ == 'method' (len=6; bound method, same as Manager and Value); verified with Python 3.14.3"]
    - [arr_qn_len,   multiprocessing.Array.__qualname__.__len__,         [],                             17,    "mp.Array.__qualname__.__len__() == 17 ('BaseContext.Array'; same length as Value=17); verified with Python 3.14.3"]
    - [arr_name_eq,  multiprocessing.Array.__name__.__eq__,              ["Array"],                      true,  "mp.Array.__name__ == 'Array' (len=5; same length as Value=5); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra158
# ---------------------------------------------------------------------------

invariant multiprocessing_extra158.mp_Manager_qualname_eq:
  description: "multiprocessing.Manager.__qualname__.__eq__('BaseContext.Manager') returns True — multiprocessing.Manager is a bound method of the default BaseContext instance (the process-start-method-specific context object); Manager.__qualname__=='BaseContext.Manager' (len=19: 'BaseContext'=11+'.'=1+'Manager'=7=19); the qualname starting with 'BaseContext.' reveals that Manager is defined on the BaseContext class in Lib/multiprocessing/context.py; Manager() starts a manager subprocess and returns a SyncManager instance that can create managed shared objects (proxied dicts, lists, queues, etc.) accessible from multiple processes; this is the same bound method pattern as multiprocessing.Pipe.__qualname__=='BaseContext.Pipe' (len=16; established in prior specs) and multiprocessing.Queue.__qualname__=='BaseContext.Queue'; Manager.__qualname__ (19) > Pipe.__qualname__ (16) because 'Manager'=7 > 'Pipe'=4; NEW in extra158: first standalone mp.Manager.__qualname__ identity invariant in mpmgr158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Manager.__qualname__.__eq__
  args: ["BaseContext.Manager"]
  expected: true

invariant multiprocessing_extra158.mp_Manager_class_is_method:
  description: "multiprocessing.Manager.__class__.__name__.__eq__('method') returns True — multiprocessing.Manager is a bound method of the default BaseContext instance; __class__.__name__=='method' (len=6: 'm'+'e'+'t'+'h'+'o'+'d'=6); 'method' is the class name for bound method objects in Python; this is the same class as multiprocessing.Pipe.__class__.__name__=='method' — all top-level multiprocessing factory functions that are accessed through the context system are bound methods of the default BaseContext instance; contrast: multiprocessing.pool.Pool.__class__.__name__=='type' (Pool is a class, not a bound method); Manager.__class__.__name__=='method' (len=6) is much shorter than the C builtin class name 'builtin_function_or_method' (len=26; established in extra154); NEW in extra158: first standalone mp.Manager.__class__.__name__ identity invariant in mpmgr158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Manager.__class__.__name__.__eq__
  args: ["method"]
  expected: true

invariant multiprocessing_extra158.mp_Manager_module_eq:
  description: "multiprocessing.Manager.__module__.__eq__('multiprocessing.context') returns True — multiprocessing.Manager is defined in Lib/multiprocessing/context.py; its __module__ is 'multiprocessing.context' (len=23: 'multiprocessing'=15+'.'=1+'context'=7=23); all three top-level multiprocessing bound methods covered in this spec (Manager, Value, Array) share __module__=='multiprocessing.context'; compare module name lengths in the multiprocessing family: pool (len=20) < queues (len=22) < context (len=23) < managers (len=24) < shared_memory (len=29); 'multiprocessing.context' (len=23) sits between queues (22) and managers (24); NEW in extra158: first standalone mp.Manager.__module__ identity invariant in mpmgr158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Manager.__module__.__eq__
  args: ["multiprocessing.context"]
  expected: true

invariant multiprocessing_extra158.mp_Value_qualname_eq:
  description: "multiprocessing.Value.__qualname__.__eq__('BaseContext.Value') returns True — multiprocessing.Value is a bound method of the default BaseContext instance; Value.__qualname__=='BaseContext.Value' (len=17: 'BaseContext'=11+'.'=1+'Value'=5=17); Value() creates a shared ctypes value in shared memory (e.g. Value('i', 0) creates a shared integer); the shared value can be accessed and modified atomically from multiple processes using Value.value and the optional lock; Value.__qualname__.__len__()==17 is the same as Array.__qualname__.__len__()==17 — both 'Value' and 'Array' are 5-character names giving the same qualname length; compare: Manager.__qualname__.__len__()==19 (2 longer than Value/Array because 'Manager'=7 > 'Value'=5); NEW in extra158: first standalone mp.Value.__qualname__ identity invariant in mpval158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Value.__qualname__.__eq__
  args: ["BaseContext.Value"]
  expected: true

invariant multiprocessing_extra158.mp_Array_qualname_eq:
  description: "multiprocessing.Array.__qualname__.__eq__('BaseContext.Array') returns True — multiprocessing.Array is a bound method of the default BaseContext instance; Array.__qualname__=='BaseContext.Array' (len=17: 'BaseContext'=11+'.'=1+'Array'=5=17); Array() creates a shared ctypes array in shared memory (e.g. Array('i', 10) creates a shared integer array of size 10); the shared array elements can be read and written from multiple processes; Array.__qualname__.__len__()==17 equals Value.__qualname__.__len__()==17 — 'Array'=5 and 'Value'=5 are the same length; compare: Manager.__qualname__.__len__()==19 > Array.__qualname__.__len__()==17 > Pipe.__qualname__.__len__()==16 (from prior specs); NEW in extra158: first standalone mp.Array.__qualname__ identity invariant in mparray158 namespace; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: identity
  kind: python_call_eq
  function: multiprocessing.Array.__qualname__.__eq__
  args: ["BaseContext.Array"]
  expected: true
