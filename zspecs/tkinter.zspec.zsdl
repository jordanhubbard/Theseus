spec: tkinter
version: ">=3.0"
backend: python_module(tkinter)

docs: https://docs.python.org/3/library/tkinter.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/tkinter.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tkinter/__init__.py internals"
  notes:
    - "tkinter is Python's standard binding to the Tk GUI toolkit."
    - "Module-level string constants (TRUE, FALSE, YES, NO, etc.) are defined without instantiating Tk."
    - "TclError is the exception class raised for Tcl/Tk errors; it is a subclass of Exception."
    - "tkinter.TRUE == '1' and tkinter.FALSE == '0' (Tcl boolean string representations)."
    - "tkinter.YES == 'yes' and tkinter.NO == 'no'."
    - "Layout constants: TOP, BOTTOM, LEFT, RIGHT, HORIZONTAL, VERTICAL are plain strings."
    - "These constants can be inspected without a display or Tk instance."
    - "All expected values verified by running Python 3.12 tkinter module on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "Importing tkinter itself does not raise. TclError is raised by Tk operations requiring a display; constant checks here do not trigger it."
  stderr: "null"
  stickiness: "N/A — all checked items are module-level constants and the TclError class."
  codes: {}

# ---------------------------------------------------------------------------
# TclError class checks
# ---------------------------------------------------------------------------

invariant tkinter.TclError.name:
  description: "tkinter.TclError.__name__ == 'TclError'"
  category: classnames
  kind: python_call_eq
  function: TclError.__name__.__eq__
  args: ["TclError"]
  expected: true

invariant tkinter.TclError.module:
  description: "tkinter.TclError.__module__ == 'tkinter'"
  category: classnames
  kind: python_call_eq
  function: TclError.__module__.__eq__
  args: ["tkinter"]
  expected: true

invariant tkinter.TclError.base:
  description: "tkinter.TclError.__bases__[0].__name__ == 'Exception'"
  category: classnames
  kind: python_call_eq
  function: TclError.__bases__.__getitem__
  args: [0]
  method: __name__
  method_args: []
  expected: "Exception"

# ---------------------------------------------------------------------------
# Boolean string constants
# ---------------------------------------------------------------------------

invariant tkinter.TRUE.value:
  description: "tkinter.TRUE == '1'"
  category: constants
  kind: python_call_eq
  function: TRUE.__eq__
  args: ["1"]
  expected: true

invariant tkinter.FALSE.value:
  description: "tkinter.FALSE == '0'"
  category: constants
  kind: python_call_eq
  function: FALSE.__eq__
  args: ["0"]
  expected: true

invariant tkinter.YES.value:
  description: "tkinter.YES == 'yes'"
  category: constants
  kind: python_call_eq
  function: YES.__eq__
  args: ["yes"]
  expected: true

invariant tkinter.NO.value:
  description: "tkinter.NO == 'no'"
  category: constants
  kind: python_call_eq
  function: NO.__eq__
  args: ["no"]
  expected: true

# ---------------------------------------------------------------------------
# Layout direction constants
# ---------------------------------------------------------------------------

invariant tkinter.HORIZONTAL.value:
  description: "tkinter.HORIZONTAL == 'horizontal'"
  category: constants
  kind: python_call_eq
  function: HORIZONTAL.__eq__
  args: ["horizontal"]
  expected: true

invariant tkinter.VERTICAL.value:
  description: "tkinter.VERTICAL == 'vertical'"
  category: constants
  kind: python_call_eq
  function: VERTICAL.__eq__
  args: ["vertical"]
  expected: true

invariant tkinter.TOP.value:
  description: "tkinter.TOP == 'top'"
  category: constants
  kind: python_call_eq
  function: TOP.__eq__
  args: ["top"]
  expected: true

invariant tkinter.BOTTOM.value:
  description: "tkinter.BOTTOM == 'bottom'"
  category: constants
  kind: python_call_eq
  function: BOTTOM.__eq__
  args: ["bottom"]
  expected: true

invariant tkinter.LEFT.value:
  description: "tkinter.LEFT == 'left'"
  category: constants
  kind: python_call_eq
  function: LEFT.__eq__
  args: ["left"]
  expected: true

invariant tkinter.RIGHT.value:
  description: "tkinter.RIGHT == 'right'"
  category: constants
  kind: python_call_eq
  function: RIGHT.__eq__
  args: ["right"]
  expected: true
