spec: pathlib_extra2221
version: ">=3.9"
backend: python_module(pathlib)
error_model: python_exceptions
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/pathlib.html"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave extra2221 (pathlib_extra2221): identity/display protocol dict-presence checks — __hash__, __repr__, __str__, __doc__, __module__, __qualname__, __name__."
    - "pathlib.PurePath is pure Python and defines __hash__, __repr__, __str__, __doc__, and __module__ in its own __dict__; __qualname__ and __name__ are absent — these are not stored in Python class __dict__ entries the same way."
    - "pathlib.PurePosixPath inherits all identity/display behaviour from PurePath; __doc__ and __module__ are present in its own __dict__ but __hash__, __repr__, and __str__ are not redefined."
    - "pathlib.PureWindowsPath follows the same pattern as PurePosixPath — only __doc__ and __module__ present in its own __dict__."
    - "pathlib.Path similarly inherits display protocol from PurePath; __doc__ and __module__ present in its own __dict__, others absent."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table pathlib_extra2221.purepath_identity_display:
  description: "pathlib.PurePath identity/display protocol dict-presence — pure Python base defines __hash__, __repr__, __str__, __doc__, __module__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: pl2221

  columns: [id, function, args, expected]
  rows:
    - ["pl2221001", "pathlib.PurePath.__dict__.__contains__", ["__hash__"], true]
    - ["pl2221002", "pathlib.PurePath.__dict__.__contains__", ["__repr__"], true]
    - ["pl2221003", "pathlib.PurePath.__dict__.__contains__", ["__str__"], true]
    - ["pl2221004", "pathlib.PurePath.__dict__.__contains__", ["__doc__"], true]
    - ["pl2221005", "pathlib.PurePath.__dict__.__contains__", ["__module__"], true]
    - ["pl2221006", "pathlib.PurePath.__dict__.__contains__", ["__qualname__"], false]
    - ["pl2221007", "pathlib.PurePath.__dict__.__contains__", ["__name__"], false]

