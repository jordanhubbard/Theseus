spec: itertools_extra1861
version: ">=3.9"
backend: python_module(itertools)
docs: https://docs.python.org/3/library/itertools.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools module reference"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
    - "itertools.zspec.zsdl — covers class_names, function_names, and core iterator behavior"
    - "itertools_extra.zspec.zsdl — covers module checks and iterator protocol dunders"
  notes:
    - "Wave 571 theme: bitwise operators (__or__/__and__/__xor__) and in-place operators (__iadd__/__imul__) and reflected operators (__radd__/__rmul__) for itertools C types."
    - "All itertools types (count, chain, cycle, repeat, product, combinations, permutations, islice) are C-level extension types."
    - "C-level iterator types do not define bitwise, in-place, or reflected operator dunders in their own __dict__."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

# ---------------------------------------------------------------------------
# Table 1: bitwise operators for itertools C types
#
# All itertools types are implemented in C. None define bitwise dunder
# methods (__or__, __and__, __xor__) in their own __dict__.
# ---------------------------------------------------------------------------

table itertools_extra1861.bitwise_operators:
  description: "Bitwise operator dunder methods absent from itertools C type own __dict__"
  kind: python_call_eq
  category: bitwise_operators
  id_prefix: it1861

  columns: [id, function, args, expected]
  rows:
    - ["it1861001", itertools.count.__dict__.__contains__,        ["__or__"],  false]
    - ["it1861002", itertools.count.__dict__.__contains__,        ["__and__"], false]
    - ["it1861003", itertools.count.__dict__.__contains__,        ["__xor__"], false]
    - ["it1861004", itertools.chain.__dict__.__contains__,        ["__or__"],  false]
    - ["it1861005", itertools.cycle.__dict__.__contains__,        ["__or__"],  false]
    - ["it1861006", itertools.repeat.__dict__.__contains__,       ["__or__"],  false]
    - ["it1861007", itertools.product.__dict__.__contains__,      ["__or__"],  false]
    - ["it1861008", itertools.combinations.__dict__.__contains__,  ["__or__"],  false]

# ---------------------------------------------------------------------------
# Table 2: in-place operators for itertools C types
#
# None of the itertools C types define in-place operator dunder methods in
# their own __dict__.
# ---------------------------------------------------------------------------

table itertools_extra1861.inplace_operators:
  description: "In-place operator dunder methods absent from itertools C type own __dict__"
  kind: python_call_eq
  category: inplace_operators
  id_prefix: it1861

  columns: [id, function, args, expected]
  rows:
    - ["it1861009", itertools.count.__dict__.__contains__,         ["__iadd__"], false]
    - ["it1861010", itertools.count.__dict__.__contains__,         ["__imul__"], false]
    - ["it1861011", itertools.chain.__dict__.__contains__,         ["__iadd__"], false]
    - ["it1861012", itertools.cycle.__dict__.__contains__,         ["__iadd__"], false]
    - ["it1861013", itertools.repeat.__dict__.__contains__,        ["__iadd__"], false]
    - ["it1861014", itertools.product.__dict__.__contains__,       ["__iadd__"], false]
    - ["it1861015", itertools.combinations.__dict__.__contains__,  ["__iadd__"], false]
    - ["it1861016", itertools.permutations.__dict__.__contains__,  ["__iadd__"], false]

# ---------------------------------------------------------------------------
# Table 3: reflected operators for itertools types
#
# None of the itertools C types define reflected operator dunder methods in
# their own __dict__.
# ---------------------------------------------------------------------------

table itertools_extra1861.reflected_operators:
  description: "Reflected operator dunder methods absent from itertools C type own __dict__"
  kind: python_call_eq
  category: reflected_operators
  id_prefix: it1861

  columns: [id, function, args, expected]
  rows:
    - ["it1861017", itertools.count.__dict__.__contains__,        ["__radd__"], false]
    - ["it1861018", itertools.count.__dict__.__contains__,        ["__rmul__"], false]
    - ["it1861019", itertools.chain.__dict__.__contains__,        ["__radd__"], false]
    - ["it1861020", itertools.cycle.__dict__.__contains__,        ["__radd__"], false]
    - ["it1861021", itertools.repeat.__dict__.__contains__,       ["__radd__"], false]
    - ["it1861022", itertools.product.__dict__.__contains__,      ["__radd__"], false]
    - ["it1861023", itertools.combinations.__dict__.__contains__,  ["__radd__"], false]
    - ["it1861024", itertools.islice.__dict__.__contains__,        ["__radd__"], false]
