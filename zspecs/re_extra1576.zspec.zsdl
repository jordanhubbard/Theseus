spec: re_extra1576
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
error_model: python_exceptions

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "any proprietary source"
  notes:
    - "Wave 552 (_extra1576): __str__/__repr__/__bytes__ protocol dict-presence checks for re classes."
    - "re.Pattern.__dict__ contains __repr__ (True) but NOT __str__ (False)."
    - "re.Match.__dict__ contains __repr__ (True) but NOT __str__ (False)."
    - "re.error.__dict__ does NOT contain __repr__ or __str__ in its own dict."
    - "re.Pattern and re.Match are C-level types; their __repr__ is defined in C, exposed via __dict__."
    - "re.UNICODE==32, re.IGNORECASE==2, re.MULTILINE==8, re.DOTALL==16, re.VERBOSE==64, re.ASCII==256."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table re_extra1576.pattern_str_repr_protocol:
  description: "re.Pattern.__dict__ str/repr protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1576pa

  columns: [id, function, args, expected]
  rows:
    - ["re1576pa001", "re.Pattern.__dict__.__contains__", ["__repr__"],  true]
    - ["re1576pa002", "re.Pattern.__dict__.__contains__", ["__str__"],   false]
    - ["re1576pa003", "re.Pattern.__dict__.__contains__", ["__bytes__"], false]
    - ["re1576pa004", "re.Pattern.__dict__.__contains__", ["__format__"], false]

table re_extra1576.match_str_repr_protocol:
  description: "re.Match.__dict__ str/repr protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1576ma

  columns: [id, function, args, expected]
  rows:
    - ["re1576ma001", "re.Match.__dict__.__contains__", ["__repr__"],  true]
    - ["re1576ma002", "re.Match.__dict__.__contains__", ["__str__"],   false]
    - ["re1576ma003", "re.Match.__dict__.__contains__", ["__bytes__"], false]
    - ["re1576ma004", "re.Match.__dict__.__contains__", ["__format__"], false]

table re_extra1576.error_str_repr_protocol:
  description: "re.error.__dict__ str/repr protocol dict-presence checks"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1576er

  columns: [id, function, args, expected]
  rows:
    - ["re1576er001", "re.error.__dict__.__contains__", ["__repr__"],  false]
    - ["re1576er002", "re.error.__dict__.__contains__", ["__str__"],   false]
    - ["re1576er003", "re.error.__dict__.__contains__", ["__bytes__"], false]

table re_extra1576.flag_constants:
  description: "re module flag constant integer values"
  kind: python_call_eq
  category: constants
  id_prefix: re1576fl

  columns: [id, function, args, expected]
  rows:
    - ["re1576fl001", "re.UNICODE",    [], 32]
    - ["re1576fl002", "re.IGNORECASE", [], 2]
    - ["re1576fl003", "re.MULTILINE",  [], 8]
    - ["re1576fl004", "re.DOTALL",     [], 16]
    - ["re1576fl005", "re.VERBOSE",    [], 64]
    - ["re1576fl006", "re.ASCII",      [], 256]
    - ["re1576fl007", "re.U",          [], 32]
    - ["re1576fl008", "re.I",          [], 2]
    - ["re1576fl009", "re.M",          [], 8]
    - ["re1576fl010", "re.S",          [], 16]
    - ["re1576fl011", "re.X",          [], 64]
    - ["re1576fl012", "re.A",          [], 256]

table re_extra1576.flag_name_attrs:
  description: "re flag __name__ string attributes"
  kind: python_call_eq
  category: str_repr
  id_prefix: re1576fn

  columns: [id, function, args, expected]
  rows:
    - ["re1576fn001", "re.RegexFlag.__name__",   [], "RegexFlag"]
    - ["re1576fn002", "re.Pattern.__name__",     [], "Pattern"]
    - ["re1576fn003", "re.Match.__name__",       [], "Match"]
    - ["re1576fn004", "re.error.__name__",       [], "error"]

table re_extra1576.pattern_repr_key_attrs:
  description: "re.Pattern __dict__ contains key protocol attributes"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re1576pr

  columns: [id, function, args, expected]
  rows:
    - ["re1576pr001", "re.Pattern.__dict__.__contains__", ["__doc__"],          true]
    - ["re1576pr002", "re.Pattern.__dict__.__contains__", ["__module__"],       true]
    - ["re1576pr003", "re.Pattern.__dict__.__contains__", ["__hash__"],         true]
    - ["re1576pr004", "re.Pattern.__dict__.__contains__", ["__eq__"],           true]
    - ["re1576pr005", "re.Pattern.__dict__.__contains__", ["__copy__"],         true]
    - ["re1576pr006", "re.Pattern.__dict__.__contains__", ["__deepcopy__"],     true]
    - ["re1576pr007", "re.Pattern.__dict__.__contains__", ["__class_getitem__"], true]
    - ["re1576pr008", "re.Match.__dict__.__contains__",   ["__doc__"],          true]
    - ["re1576pr009", "re.Match.__dict__.__contains__",   ["__module__"],       true]
    - ["re1576pr010", "re.Match.__dict__.__contains__",   ["__repr__"],         true]
