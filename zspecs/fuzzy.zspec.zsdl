spec: fuzzy
version: ">=0.1.0"
backend: node(fuzzy)

docs: https://www.npmjs.com/package/fuzzy

provenance:
  derived_from:
    - "fuzzy README — https://www.npmjs.com/package/fuzzy"
    - "Test vectors verified with fuzzy via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "fuzzy source"
  notes:
    - "fuzzy is an npm package. Install: npm install fuzzy"
    - "fuzzy.test(pattern, str) returns true if pattern fuzzy-matches str."
    - "fuzzy.filter(pattern, list) returns matching items with score/index metadata."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns boolean or array of match objects."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table fuzzy.test:
  kind: node_module_call_eq
  function: test
  category: match
  id_prefix: fuztest

  columns: [id, args, expected]
  rows:
    - [match,    ["tex", "text"],  true]
    - [no_match, ["xyz", "text"],  false]

table fuzzy.filter:
  kind: node_module_call_eq
  function: filter
  category: filter
  id_prefix: fuzfilter

  columns: [id, args, expected]
  rows:
    - [two_matches, ["tex", ["text", "context", "other"]],
       [{"string": "text",    "score": 11, "index": 0, "original": "text"},
        {"string": "context", "score": 11, "index": 1, "original": "context"}]]
