spec: tty_extra4
version: ">=3.12"
backend: python_module(tty)

docs: https://docs.python.org/3/library/tty.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/tty.html — Python tty module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/tty.py"
  notes:
    - "This spec extends tty.zspec.zsdl through tty_extra3.zspec.zsdl."
    - "tty covers: setraw/setcbreak __name__ and __module__, IFLAG/OFLAG/CFLAG/LFLAG/ISPEED/OSPEED/CC values."
    - "tty_extra covers: setraw/setcbreak __name__ and __module__ (invariants), IFLAG/OFLAG/CFLAG/LFLAG/CC class checks, all 7 index constant value checks."
    - "tty_extra2 covers: ISPEED/OSPEED class checks, setraw/setcbreak __qualname__, function class='function' table, compact class-check table, IFLAG<OFLAG and CC>OSPEED ordering."
    - "tty_extra3 covers: module __name__ and __package__, cfmakeraw/cfmakecbreak __name__/__module__/__qualname__/class, CFLAG+1==LFLAG, LFLAG<ISPEED."
    - "New here: tty module TCSANOW/TCSADRAIN/TCSAFLUSH value pins (tty re-exports these from termios); tty.ECHO/ICANON/ISIG/OPOST value pins; OFLAG+1==CFLAG arithmetic; ISPEED+1==OSPEED arithmetic; CC - OSPEED == 1 arithmetic."
    - "tty imports from termios: TCSANOW=0, TCSADRAIN=1, TCSAFLUSH=2 are re-exported unchanged."
    - "tty also re-exports ECHO=8, ICANON=256, ISIG=128, OPOST=1 from termios on macOS."
    - "OFLAG(1)+1 == CFLAG(2) — adjacent index arithmetic not checked in prior specs."
    - "ISPEED(4)+1 == OSPEED(5) — adjacent index arithmetic not checked in prior specs."
    - "CC(6) - OSPEED(5) == 1 — arithmetic relating the last two indices."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# tty.TCSANOW / TCSADRAIN / TCSAFLUSH — re-exported from termios
# tty imports these constants from termios; prior tty specs do not pin them.
# Values are the same as in termios: 0, 1, 2.
# ---------------------------------------------------------------------------

table tty_extra4.tcsa_constants.values:
  kind: python_call_eq
  category: constants
  id_prefix: tcsa_val

  columns: [id, function, args, expected]
  rows:
    - [TCSANOW,   TCSANOW.__eq__,   [0], true]
    - [TCSADRAIN, TCSADRAIN.__eq__, [1], true]
    - [TCSAFLUSH, TCSAFLUSH.__eq__, [2], true]

# ---------------------------------------------------------------------------
# tty.ECHO, tty.ICANON, tty.ISIG, tty.OPOST — re-exported lflag/oflag bits
# tty re-exports these from termios; they are NOT in any prior tty spec.
# Values on macOS: ECHO=8, ICANON=256, ISIG=128, OPOST=1.
# ---------------------------------------------------------------------------

invariant tty_extra4.ECHO.value:
  description: "tty.ECHO == 8 — echo lflag bitmask (macOS, re-exported from termios)"
  category: constants
  kind: python_call_eq
  function: ECHO.__eq__
  args: [8]
  expected: true

invariant tty_extra4.ICANON.value:
  description: "tty.ICANON == 256 — canonical mode lflag bitmask (macOS, re-exported from termios)"
  category: constants
  kind: python_call_eq
  function: ICANON.__eq__
  args: [256]
  expected: true

invariant tty_extra4.ISIG.value:
  description: "tty.ISIG == 128 — signal-generating characters lflag bitmask (macOS, re-exported from termios)"
  category: constants
  kind: python_call_eq
  function: ISIG.__eq__
  args: [128]
  expected: true

invariant tty_extra4.OPOST.value:
  description: "tty.OPOST == 1 — output post-processing oflag bitmask (macOS, re-exported from termios)"
  category: constants
  kind: python_call_eq
  function: OPOST.__eq__
  args: [1]
  expected: true

# ---------------------------------------------------------------------------
# Adjacent index arithmetic — new axes not in any prior tty spec
# tty_extra3 covers CFLAG+1==LFLAG and LFLAG<ISPEED.
# New: OFLAG+1==CFLAG (1+1=2), ISPEED+1==OSPEED (4+1=5), CC-OSPEED==1 (6-5=1).
# ---------------------------------------------------------------------------

invariant tty_extra4.OFLAG.plus_one_is_CFLAG:
  description: "tty.OFLAG + 1 == tty.CFLAG — OFLAG(1) and CFLAG(2) are adjacent indices"
  category: constants
  kind: python_call_eq
  function: OFLAG.__add__
  args: [1]
  method: __eq__
  method_args: [2]
  expected: true

invariant tty_extra4.ISPEED.plus_one_is_OSPEED:
  description: "tty.ISPEED + 1 == tty.OSPEED — ISPEED(4) and OSPEED(5) are adjacent indices"
  category: constants
  kind: python_call_eq
  function: ISPEED.__add__
  args: [1]
  method: __eq__
  method_args: [5]
  expected: true

invariant tty_extra4.CC.minus_OSPEED_is_one:
  description: "tty.CC - tty.OSPEED == 1 — CC(6) is one step above OSPEED(5)"
  category: constants
  kind: python_call_eq
  function: CC.__sub__
  args: [5]
  expected: 1
