spec: abc_extra691
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module ABCMeta documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from: ["CPython source code"]
  notes: ["Checks abc.ABCMeta method class and doc identity; avoids abstractclassmethod/abstractstaticmethod removed in 3.11"]
  created_at: "2026-04-12T00:00:00Z"
error_model: python_exceptions

table abc_extra691.abcmeta_method_identity:
  description: "abc.ABCMeta method __class__.__name__ and __doc__.__class__.__name__ identity"
  kind: python_call_eq
  category: abcmeta_identity
  id_prefix: ab691am
  columns: [id, function, args, expected]
  rows:
    - [ab691am001, abc.ABCMeta.__new__.__class__.__name__.__eq__,              ["staticmethod"],   true]
    - [ab691am002, abc.ABCMeta.__init__.__class__.__name__.__eq__,             ["function"],       true]
    - [ab691am003, abc.ABCMeta.register.__class__.__name__.__eq__,             ["function"],       true]
    - [ab691am004, abc.ABCMeta.__instancecheck__.__class__.__name__.__eq__,    ["function"],       true]
    - [ab691am005, abc.ABCMeta.__subclasscheck__.__class__.__name__.__eq__,    ["function"],       true]
    - [ab691am006, abc.ABCMeta.__init__.__doc__.__class__.__name__.__eq__,     ["str"],            true]
    - [ab691am007, abc.ABCMeta.register.__doc__.__class__.__name__.__eq__,     ["str"],            true]
    - [ab691am008, abc.abstractproperty.__qualname__.__eq__,                   ["abstractproperty"], true]
    - [ab691am009, abc.abstractproperty.__module__.__eq__,                     ["abc"],            true]
    - [ab691am010, abc.abstractproperty.__doc__.__class__.__name__.__eq__,     ["str"],            true]
    - [ab691am011, abc.ABC.__qualname__.__eq__,                                ["ABC"],            true]
    - [ab691am012, abc.ABC.__module__.__eq__,                                  ["abc"],            true]
