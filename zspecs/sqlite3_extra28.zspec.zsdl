spec: sqlite3_extra28
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
    - "sqlite3_extra27.zspec.zsdl — covers sqlite_version/__class__.__name__/__len__()==6; PARSE_DECLTYPES/PARSE_COLNAMES values/__class__.__name__; apilevel/'2.0'/__len__()==3; threadsafety==3; sqlite_version_info/__class__.__name__=='tuple'/__len__()==3; Connection/Cursor __dict__.__class__.__name__=='mappingproxy'/__len__()==12; Cursor.execute/fetchone/fetchall/fetchmany/close __qualname__/__len__()."
    - "sqlite3_extra26.zspec.zsdl — covers Connection/__mro__.__len__()==2; Error/__mro__.__len__()==4; Cursor/__mro__.__len__()==2; IntegrityError/__mro__.__len__()==6; IntegrityError/__bases__[0].__name__=='DatabaseError'; Connection.execute/cursor/commit/rollback/close __qualname__/__qualname__.__len__()/__name__.__len__()."
    - "sqlite3_extra25.zspec.zsdl — covers IntegrityError/OperationalError/InterfaceError/ProgrammingError/NotSupportedError/Warning __name__.__len__(); connect/__qualname__.__len__(); Connection/Cursor/Row __qualname__.__len__(); Warning.__module__.__len__()."
    - "sqlite3_extra24.zspec.zsdl — covers Connection/Cursor/Row __module__.__len__() and __name__.__len__(); Error/DatabaseError/OperationalError __module__.__len__() and __name__.__len__()."
  notes:
    - "This spec extends sqlite3_extra27.zspec.zsdl."
    - "Prior specs covered: Connection/Cursor/Row all __name__/__module__/__qualname__/__len__()/__mro__.__len__(); Connection/Cursor __dict__ as mappingproxy; Connection.__mro__.__len__()==2; Cursor.__mro__.__len__()==2; Error/__mro__.__len__()==4; IntegrityError/__mro__.__len__()==6; IntegrityError/__bases__[0].__name__=='DatabaseError'; Connection.execute/cursor/commit/rollback/close __qualname__/__len__(); Cursor.execute/fetchone/fetchall/fetchmany/close __qualname__/__len__(); sqlite_version/apilevel/threadsafety/sqlite_version_info/PARSE_DECLTYPES/PARSE_COLNAMES."
    - "This spec covers: sqlite3.Row/__dict__.__class__.__name__=='mappingproxy'/__len__()==12; sqlite3.Error/__dict__.__class__.__name__=='mappingproxy'/__len__()==12; sqlite3.Warning/__dict__.__class__.__name__=='mappingproxy'/__len__()==12; sqlite3.Warning/__mro__.__len__()==4; sqlite3.Row/__mro__.__len__()==2; sqlite3.Row/__bases__[0].__name__=='object'/__len__()==6; sqlite3.Connection/__bases__[0].__name__=='object'/__len__()==6; sqlite3.Error/__bases__[0].__name__=='Exception'/__len__()==9; sqlite3.Warning/__bases__[0].__name__=='Exception'/__len__()==9; sqlite3.Cursor.executemany/__qualname__=='Cursor.executemany'/__len__()==18; sqlite3.Cursor.rowcount/__qualname__.__len__()==15; sqlite3.Cursor.lastrowid/__qualname__.__len__()==16; sqlite3.Row.keys/__qualname__=='Row.keys'/__len__()==8; sqlite3.Connection.executescript/__qualname__/__len__()==24; sqlite3.Connection.create_function/__qualname__.__len__()==26."
    - "sqlite3.Row.__dict__.__class__.__name__ == 'mappingproxy' — len 12. Error and Warning also mappingproxy. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Warning.__mro__.__len__() == 4: Warning -> Exception -> BaseException -> object. Row.__mro__.__len__() == 2: Row -> object. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Connection.__bases__[0].__name__ == 'object' (len 6). Row.__bases__[0].__name__ == 'object' (len 6). Error.__bases__[0].__name__ == 'Exception' (len 9). Warning.__bases__[0].__name__ == 'Exception' (len 9). Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Cursor.executemany.__qualname__ == 'Cursor.executemany' — len 18. rowcount.__qualname__ len 15. lastrowid.__qualname__ len 16. Row.keys.__qualname__ == 'Row.keys' — len 8. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Connection.executescript.__qualname__ == 'Connection.executescript' — len 24. create_function.__qualname__ == 'Connection.create_function' — len 26. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sqlite3.Row, Error, Warning __dict__.__class__.__name__ and __len__()
#
# No prior spec checks __dict__.__class__.__name__ for Row, Error, or Warning.
# Connection and Cursor __dict__ were covered in sqlite3_extra27.
# Class __dict__ is always a mappingproxy; __class__.__name__ == 'mappingproxy' (len 12).
# ---------------------------------------------------------------------------

invariant sqlite3_extra28.Row_dict_class_name:
  description: "sqlite3.Row.__dict__.__class__.__name__ == 'mappingproxy' — Row class namespace is a mappingproxy"
  category: class_structure
  kind: python_call_eq
  function: "Row.__dict__.__class__.__name__.__eq__"
  args: ["mappingproxy"]
  expected: true

invariant sqlite3_extra28.Row_dict_class_name_len:
  description: "len(sqlite3.Row.__dict__.__class__.__name__) == 12 — len('mappingproxy') == 12"
  category: class_structure
  kind: python_call_eq
  function: "Row.__dict__.__class__.__name__.__len__"
  args: []
  expected: 12

table sqlite3_extra28.exception_dict_proxy_names:
  description: "sqlite3.Error/Warning __dict__.__class__.__name__=='mappingproxy' and __len__()==12"
  kind: python_call_eq
  category: class_structure
  id_prefix: sedpn28

  columns: [id, function, args, expected, description]
  rows:
    - [Error_dict_class,
       "Error.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "sqlite3.Error.__dict__.__class__.__name__ == 'mappingproxy'"]
    - [Error_dict_class_len,
       "Error.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len('mappingproxy') == 12"]
    - [Warning_dict_class,
       "Warning.__dict__.__class__.__name__.__eq__",
       ["mappingproxy"],
       true,
       "sqlite3.Warning.__dict__.__class__.__name__ == 'mappingproxy'"]
    - [Warning_dict_class_len,
       "Warning.__dict__.__class__.__name__.__len__",
       [],
       12,
       "len('mappingproxy') == 12"]

# ---------------------------------------------------------------------------
# sqlite3 class __mro__.__len__() — Warning and Row
#
# No prior spec checks Warning.__mro__.__len__() or Row.__mro__.__len__().
# Connection/__mro__.__len__()==2 and Error/__mro__.__len__()==4 and Cursor/__mro__.__len__()==2
# were all covered in sqlite3_extra26.
# Warning.__mro__ == [Warning, Exception, BaseException, object] — len 4.
# Row.__mro__ == [Row, object] — len 2.
# ---------------------------------------------------------------------------

invariant sqlite3_extra28.Warning_mro_len:
  description: "sqlite3.Warning.__mro__.__len__() == 4 — Warning -> Exception -> BaseException -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: Warning.__mro__.__len__
  args: []
  expected: 4

invariant sqlite3_extra28.Row_mro_len:
  description: "sqlite3.Row.__mro__.__len__() == 2 — Row -> object"
  category: class_hierarchy
  kind: python_call_eq
  function: Row.__mro__.__len__
  args: []
  expected: 2

# ---------------------------------------------------------------------------
# sqlite3 class __bases__[0].__name__ and __len__()
#
# No prior spec checks __bases__[0].__name__ for Connection, Row, Error, or Warning.
# IntegrityError/__bases__[0].__name__=='DatabaseError' was in extra26, not Connection/Row/Error/Warning.
# Connection.__bases__[0].__name__ == 'object' (len 6)
# Row.__bases__[0].__name__ == 'object' (len 6)
# Error.__bases__[0].__name__ == 'Exception' (len 9)
# Warning.__bases__[0].__name__ == 'Exception' (len 9)
# ---------------------------------------------------------------------------

table sqlite3_extra28.class_bases_names:
  description: "sqlite3.Connection/Row/__bases__[0].__name__=='object'; Error/Warning/__bases__[0].__name__=='Exception'"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: scbn28

  columns: [id, function, args, expected, description]
  rows:
    - [Connection_base_name,
       "Connection.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "sqlite3.Connection.__bases__[0].__name__ == 'object' (single-inheritance from object)"]
    - [Connection_base_name_len,
       "Connection.__bases__[0].__name__.__len__",
       [],
       6,
       "len('object') == 6"]
    - [Row_base_name,
       "Row.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "sqlite3.Row.__bases__[0].__name__ == 'object'"]
    - [Error_base_name,
       "Error.__bases__[0].__name__.__eq__",
       ["Exception"],
       true,
       "sqlite3.Error.__bases__[0].__name__ == 'Exception'"]
    - [Error_base_name_len,
       "Error.__bases__[0].__name__.__len__",
       [],
       9,
       "len('Exception') == 9"]
    - [Warning_base_name,
       "Warning.__bases__[0].__name__.__eq__",
       ["Exception"],
       true,
       "sqlite3.Warning.__bases__[0].__name__ == 'Exception'"]

# ---------------------------------------------------------------------------
# sqlite3.Cursor method __qualname__ — executemany, rowcount, lastrowid
#
# No prior spec checks __qualname__ for executemany, rowcount, or lastrowid.
# Cursor.execute/fetchone/fetchall/fetchmany/close were covered in sqlite3_extra27.
# executemany.__qualname__ == 'Cursor.executemany' (len 18)
# rowcount.__qualname__.__len__() == 15 ('Cursor.rowcount')
# lastrowid.__qualname__.__len__() == 16 ('Cursor.lastrowid')
# ---------------------------------------------------------------------------

invariant sqlite3_extra28.Cursor_executemany_qualname:
  description: "sqlite3.Cursor.executemany.__qualname__ == 'Cursor.executemany'"
  category: function_qualnames
  kind: python_call_eq
  function: Cursor.executemany.__qualname__.__eq__
  args: ["Cursor.executemany"]
  expected: true

invariant sqlite3_extra28.Cursor_executemany_qualname_len:
  description: "len(sqlite3.Cursor.executemany.__qualname__) == 18 — len('Cursor.executemany') == 18"
  category: function_qualnames
  kind: python_call_eq
  function: Cursor.executemany.__qualname__.__len__
  args: []
  expected: 18

table sqlite3_extra28.Cursor_method_qualname_lengths_new:
  description: "sqlite3.Cursor rowcount/lastrowid __qualname__.__len__() and Row.keys __qualname__"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: scmqln28

  columns: [id, function, args, expected, description]
  rows:
    - [rowcount_qualname_len,
       Cursor.rowcount.__qualname__.__len__,
       [],
       15,
       "len('Cursor.rowcount') == 15"]
    - [lastrowid_qualname_len,
       Cursor.lastrowid.__qualname__.__len__,
       [],
       16,
       "len('Cursor.lastrowid') == 16"]
    - [Row_keys_qualname,
       Row.keys.__qualname__.__eq__,
       ["Row.keys"],
       true,
       "sqlite3.Row.keys.__qualname__ == 'Row.keys'"]
    - [Row_keys_qualname_len,
       Row.keys.__qualname__.__len__,
       [],
       8,
       "len('Row.keys') == 8"]

# ---------------------------------------------------------------------------
# sqlite3.Connection.executescript and create_function __qualname__.__len__()
#
# No prior spec checks __qualname__ for executescript or create_function.
# Connection.execute/cursor/commit/rollback/close were covered in sqlite3_extra26.
# executescript.__qualname__ == 'Connection.executescript' (len 24)
# create_function.__qualname__ == 'Connection.create_function' (len 26)
# ---------------------------------------------------------------------------

table sqlite3_extra28.Connection_method_qualname_lengths_new:
  description: "sqlite3.Connection.executescript/__qualname__.__len__()==24; create_function/__qualname__.__len__()==26"
  kind: python_call_eq
  category: function_qualnames
  id_prefix: scmql28

  columns: [id, function, args, expected, description]
  rows:
    - [executescript_qualname_len,
       Connection.executescript.__qualname__.__len__,
       [],
       24,
       "len('Connection.executescript') == 24"]
    - [create_function_qualname_len,
       Connection.create_function.__qualname__.__len__,
       [],
       26,
       "len('Connection.create_function') == 26"]
