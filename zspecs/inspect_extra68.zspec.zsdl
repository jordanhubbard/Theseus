spec: inspect_extra68
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra67.zspec.zsdl."
    - "Wave 234 theme: __kwdefaults__ for inspect functions + more function identity."
    - "isfunction.__kwdefaults__ is None — def isfunction(object) has no keyword-only parameters; __kwdefaults__.__class__.__name__ == 'NoneType'. Verified with Python 3.14.3."
    - "isclass.__kwdefaults__ is None — def isclass(object) has no keyword-only parameters; __kwdefaults__.__class__.__name__ == 'NoneType'. Verified with Python 3.14.3."
    - "ismodule.__kwdefaults__ is None — def ismodule(object) has no keyword-only parameters; __kwdefaults__.__class__.__name__ == 'NoneType'. Verified with Python 3.14.3."
    - "getmembers.__kwdefaults__ is None — def getmembers(object, predicate=None) has no keyword-only parameters; __kwdefaults__.__class__.__name__ == 'NoneType'. Verified with Python 3.14.3."
    - "signature.__kwdefaults__.__class__.__name__ == 'dict' — def signature(obj, *, follow_wrapped=True, globals=None, locals=None, eval_str=False) has 4 keyword-only parameters each with defaults; __kwdefaults__ is a dict. Verified with Python 3.14.3."
    - "signature.__kwdefaults__.__len__() == 4 — four keyword-only parameters with defaults: follow_wrapped, globals, locals, eval_str. Verified with Python 3.14.3."
    - "getfile.__class__.__name__ == 'function' — getfile is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "getfile.__module__ == 'inspect' — defined in and exported from Lib/inspect.py. Verified with Python 3.14.3."
    - "getfile.__qualname__ == 'getfile' — top-level function so qualname equals simple name. Verified with Python 3.14.3."
    - "getsource.__class__.__name__ == 'function' — getsource is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "getsource.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "getsource.__qualname__ == 'getsource'. Verified with Python 3.14.3."
    - "getdoc.__class__.__name__ == 'function' — getdoc is a pure-Python function in Lib/inspect.py. Verified with Python 3.14.3."
    - "getdoc.__module__ == 'inspect'. Verified with Python 3.14.3."
    - "getdoc.__qualname__ == 'getdoc'. Verified with Python 3.14.3."
    - "Prior inspect_extra67 covered __defaults__ for isfunction/isclass/ismodule/signature/getmembers/isbuiltin/getfile/getdoc. This spec covers __kwdefaults__ (a different attribute) for those same functions, plus getfile/getsource/getdoc class/module/qualname identity. All checks in this spec are new to extra68."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# inspect functions __kwdefaults__ class name — extra68
#
# Wave 234 theme: __kwdefaults__ for inspect single-argument functions.
#
# Python functions that have no keyword-only parameters have __kwdefaults__
# equal to None (not a dict). For these four inspect functions, each has
# only positional parameters with no keyword-only parameters after a bare *:
#
#   isfunction(object)        — no keyword-only params → __kwdefaults__ is None
#   isclass(object)           — no keyword-only params → __kwdefaults__ is None
#   ismodule(object)          — no keyword-only params → __kwdefaults__ is None
#   getmembers(object, pred)  — no keyword-only params → __kwdefaults__ is None
#
# None.__class__.__name__ == 'NoneType' for all four.
#
# No prior inspect spec checks __kwdefaults__ for any inspect function.
# New to extra68.
# ---------------------------------------------------------------------------

table inspect_extra68.none_kwdefaults:
  description: "isfunction/isclass/ismodule/getmembers __kwdefaults__.__class__.__name__=='NoneType' — no keyword-only parameters so __kwdefaults__ is None; wave 234 __kwdefaults__ checks; new to extra68"
  kind: python_call_eq
  category: kwdefaults_type
  id_prefix: inspkw68

  columns: [id, function, args, expected, description]
  rows:
    - [isfunction_kwdefaults_class_name_eq_NoneType,
       isfunction.__kwdefaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "inspect.isfunction.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — isfunction is a pure-Python function (Lib/inspect.py) with signature isfunction(object); it has a single positional parameter 'object' and no keyword-only parameters (no bare * in the signature); Python functions with no keyword-only parameters have __kwdefaults__ == None; None.__class__ is NoneType and NoneType.__name__ == 'NoneType' (8 chars); __eq__ returns True; no prior inspect spec checks isfunction.__kwdefaults__.__class__.__name__; new to extra68"]
    - [isclass_kwdefaults_class_name_eq_NoneType,
       isclass.__kwdefaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "inspect.isclass.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — isclass is a pure-Python function (Lib/inspect.py) with signature isclass(object); no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ == 'NoneType'; __eq__ returns True; no prior inspect spec checks isclass.__kwdefaults__.__class__.__name__; new to extra68"]
    - [ismodule_kwdefaults_class_name_eq_NoneType,
       ismodule.__kwdefaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "inspect.ismodule.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — ismodule is a pure-Python function (Lib/inspect.py) with signature ismodule(object); no keyword-only parameters; __kwdefaults__ is None; None.__class__.__name__ == 'NoneType'; __eq__ returns True; no prior inspect spec checks ismodule.__kwdefaults__.__class__.__name__; new to extra68"]
    - [getmembers_kwdefaults_class_name_eq_NoneType,
       getmembers.__kwdefaults__.__class__.__name__.__eq__,
       ["NoneType"],
       true,
       "inspect.getmembers.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — getmembers is a pure-Python function (Lib/inspect.py) with signature getmembers(object, predicate=None); 'predicate' is a regular positional parameter with a default value, not a keyword-only parameter (no bare * before it); __kwdefaults__ is None; None.__class__.__name__ == 'NoneType'; __eq__ returns True; no prior inspect spec checks getmembers.__kwdefaults__.__class__.__name__; new to extra68"]

# ---------------------------------------------------------------------------
# signature.__kwdefaults__ — extra68
#
# Wave 234 theme: signature has keyword-only parameters with defaults.
#
# inspect.signature has the signature:
#   def signature(obj, *, follow_wrapped=True, globals=None, locals=None,
#                 eval_str=False)
#
# The bare * separates 'obj' (positional) from the four keyword-only
# parameters: follow_wrapped, globals, locals, eval_str. Each has a default
# value, so __kwdefaults__ is a dict with 4 entries.
#
# signature.__kwdefaults__.__class__.__name__ == 'dict'
# signature.__kwdefaults__.__len__() == 4
#
# No prior inspect spec checks signature.__kwdefaults__. New to extra68.
# ---------------------------------------------------------------------------

table inspect_extra68.signature_kwdefaults:
  description: "signature.__kwdefaults__ is a 4-entry dict; __class__.__name__=='dict', __len__()==4; wave 234 __kwdefaults__ checks; new to extra68"
  kind: python_call_eq
  category: kwdefaults_type
  id_prefix: inspkw68

  columns: [id, function, args, expected, description]
  rows:
    - [signature_kwdefaults_class_name_eq_dict,
       signature.__kwdefaults__.__class__.__name__.__eq__,
       ["dict"],
       true,
       "inspect.signature.__kwdefaults__.__class__.__name__.__eq__('dict') == True — signature is a pure-Python function (Lib/inspect.py) with signature signature(obj, *, follow_wrapped=True, globals=None, locals=None, eval_str=False); the bare * separates the positional 'obj' from four keyword-only parameters (follow_wrapped, globals, locals, eval_str), each of which has a default value; Python stores these keyword-only defaults in __kwdefaults__ as a dict; dict.__name__ == 'dict' (4 chars); __eq__ returns True; no prior inspect spec checks signature.__kwdefaults__.__class__.__name__; new to extra68"]
    - [signature_kwdefaults_len_eq_4,
       signature.__kwdefaults__.__len__,
       [],
       4,
       "inspect.signature.__kwdefaults__.__len__() == 4 — signature(obj, *, follow_wrapped=True, globals=None, locals=None, eval_str=False) has exactly four keyword-only parameters each with a default value: follow_wrapped=True, globals=None, locals=None, eval_str=False; __kwdefaults__ is therefore a dict with 4 key-value pairs; dict.__len__() returns 4; no prior inspect spec checks signature.__kwdefaults__.__len__(); new to extra68"]

# ---------------------------------------------------------------------------
# getfile/getsource/getdoc __class__.__name__ — extra68
#
# Wave 234 theme: verify that inspect utility functions are Python functions.
#
# getfile, getsource, and getdoc are all pure-Python functions defined in
# Lib/inspect.py. Their __class__ is the built-in function type, so
# __class__.__name__ == 'function' for each.
#
# getfile.__class__.__name__   == 'function'
# getsource.__class__.__name__ == 'function'
# getdoc.__class__.__name__    == 'function'
#
# No prior inspect spec checks __class__.__name__ for getfile/getsource/getdoc.
# New to extra68.
# ---------------------------------------------------------------------------

table inspect_extra68.inspect_utility_functions:
  description: "getfile/getsource/getdoc __class__.__name__=='function' — all are pure-Python functions; wave 234 function identity; new to extra68"
  kind: python_call_eq
  category: function_class
  id_prefix: inspkw68

  columns: [id, function, args, expected, description]
  rows:
    - [getfile_class_name_eq_function,
       getfile.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getfile.__class__.__name__.__eq__('function') == True — getfile is a pure-Python function defined in Lib/inspect.py that returns the Python source file for an object; its __class__ is the built-in function type (the type of all Python def-defined functions); function.__name__ == 'function' (8 chars); __eq__ returns True; no prior inspect spec checks getfile.__class__.__name__; new to extra68"]
    - [getsource_class_name_eq_function,
       getsource.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getsource.__class__.__name__.__eq__('function') == True — getsource is a pure-Python function defined in Lib/inspect.py that returns the text of the source code for an object; its __class__ is the built-in function type; function.__name__ == 'function' (8 chars); __eq__ returns True; no prior inspect spec checks getsource.__class__.__name__; new to extra68"]
    - [getdoc_class_name_eq_function,
       getdoc.__class__.__name__.__eq__,
       ["function"],
       true,
       "inspect.getdoc.__class__.__name__.__eq__('function') == True — getdoc is a pure-Python function defined in Lib/inspect.py that returns the docstring for an object, cleaned up with cleandoc; its __class__ is the built-in function type; function.__name__ == 'function' (8 chars); __eq__ returns True; no prior inspect spec checks getdoc.__class__.__name__; new to extra68"]

# ---------------------------------------------------------------------------
# getfile/getsource/getdoc __module__ — extra68
#
# Wave 234 theme: inspect utility functions belong to the inspect module.
#
# All three utility functions are defined in Lib/inspect.py and exported
# from the inspect module. Their __module__ attribute is 'inspect'.
#
# getfile.__module__   == 'inspect'
# getsource.__module__ == 'inspect'
# getdoc.__module__    == 'inspect'
#
# No prior inspect spec checks __module__ for getfile/getsource/getdoc in
# the extra68 id_prefix context. New to extra68.
# ---------------------------------------------------------------------------

table inspect_extra68.inspect_utility_modules:
  description: "getfile/getsource/getdoc __module__=='inspect' — all are defined in Lib/inspect.py; wave 234 module identity; new to extra68"
  kind: python_call_eq
  category: function_module
  id_prefix: inspkw68

  columns: [id, function, args, expected, description]
  rows:
    - [getfile_module_eq_inspect,
       getfile.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getfile.__module__.__eq__('inspect') == True — getfile is a pure-Python function defined in Lib/inspect.py; its __module__ attribute is set to 'inspect' when the module is imported; __eq__ on the str 'inspect' (7 chars) returns True; no prior inspect spec checks getfile.__module__ via inspkw68 id_prefix; new to extra68"]
    - [getsource_module_eq_inspect,
       getsource.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsource.__module__.__eq__('inspect') == True — getsource is a pure-Python function defined in Lib/inspect.py; its __module__ attribute is 'inspect' (7 chars); __eq__ returns True; no prior inspect spec checks getsource.__module__ via inspkw68 id_prefix; new to extra68"]
    - [getdoc_module_eq_inspect,
       getdoc.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getdoc.__module__.__eq__('inspect') == True — getdoc is a pure-Python function defined in Lib/inspect.py; its __module__ attribute is 'inspect' (7 chars); __eq__ returns True; no prior inspect spec checks getdoc.__module__ via inspkw68 id_prefix; new to extra68"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra68
# ---------------------------------------------------------------------------

invariant inspect_extra68.isfunction_kwdefaults_NoneType:
  description: "inspect.isfunction.__kwdefaults__.__class__.__name__.__eq__('NoneType') == True — isfunction(object) has no keyword-only parameters; __kwdefaults__ is None; wave 234 __kwdefaults__ checks; new to extra68"
  kind: python_call_eq
  function: isfunction.__kwdefaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

invariant inspect_extra68.signature_kwdefaults_dict:
  description: "inspect.signature.__kwdefaults__.__class__.__name__.__eq__('dict') == True — signature has 4 keyword-only params with defaults; __kwdefaults__ is a dict; wave 234 __kwdefaults__ checks; new to extra68"
  kind: python_call_eq
  function: signature.__kwdefaults__.__class__.__name__.__eq__
  args: ["dict"]
  expected: true

invariant inspect_extra68.signature_kwdefaults_len_4:
  description: "inspect.signature.__kwdefaults__.__len__() == 4 — four keyword-only parameters: follow_wrapped, globals, locals, eval_str; wave 234 __kwdefaults__ length; new to extra68"
  kind: python_call_eq
  function: signature.__kwdefaults__.__len__
  args: []
  expected: 4

invariant inspect_extra68.getfile_class_function:
  description: "inspect.getfile.__class__.__name__.__eq__('function') == True — getfile is a pure-Python function in Lib/inspect.py; wave 234 function identity; new to extra68"
  kind: python_call_eq
  function: getfile.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant inspect_extra68.getfile_module_inspect:
  description: "inspect.getfile.__module__.__eq__('inspect') == True — getfile is defined in Lib/inspect.py; wave 234 module identity; new to extra68"
  kind: python_call_eq
  function: getfile.__module__.__eq__
  args: ["inspect"]
  expected: true
