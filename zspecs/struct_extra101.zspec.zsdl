spec: struct_extra101
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra100.zspec.zsdl — covers Struct instance method qualname lengths / module-level function qualname lengths / Struct class-level method_descriptor type names (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers module-level function __doc__ lengths / Struct.size/__format__ __doc__ equality and lengths / struct module __doc__ length (table + invariants)."
    - "struct_extra98.zspec.zsdl — covers Struct.size/__format__ getset_descriptor class names and qualnames / descriptor qualname/name lengths and __objclass__.__name__ / Struct.__doc__ length (table + invariants)."
    - "struct_extra97.zspec.zsdl — covers struct module __spec__/__loader__ attribute lengths / Struct/__module__/__len__()==7 / error/__module__/__len__()==6 (table + invariants)."
    - "struct_extra96.zspec.zsdl — covers Struct method __name__.__len__() / module-level function __name__.__len__() / Struct.__name__/__len__() and error.__name__/__len__() (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers struct.pack_into/unpack_from/iter_unpack __qualname__.__len__() / Struct.__qualname__.__len__()==6 / error.__qualname__.__len__()==5 / module-level function __module__.__eq__('_struct') (table + invariants)."
    - "struct_extra94.zspec.zsdl — covers Struct method __qualname__.__len__() / struct.error MRO depth / module-level function __qualname__.__len__() (table + invariants)."
    - "struct_extra93.zspec.zsdl — covers Struct method __name__ equality / error __bases__/__module__ / Struct __module__/__qualname__/__bases__/__mro__.__len__()==2 (table + invariants)."
    - "struct_extra92.zspec.zsdl — covers struct module-level function __class__.__name__ / Struct method __class__.__name__ / struct.error inheritance and __module__/__qualname__ (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra100; it does NOT duplicate invariants present in those files."
    - "Wave 267 theme: struct.error class identity (__name__/__module__/__bases__[0].__name__/__mro__.__len__()) and struct.Struct class-level attribute types (__name__/__module__/__qualname__/__bases__[0].__name__)."
    - "struct.error.__name__ == 'error' (len 5). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct' (len 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__bases__[0].__name__ == 'Exception'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__mro__.__len__() == 4 (error, Exception, BaseException, object). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__name__ == 'Struct' (len 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__module__ == '_struct' (len 7). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__qualname__ == 'Struct' (len 6). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__bases__[0].__name__ == 'object'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__class__.__name__ == 'type'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(struct.Struct.__init__).__name__ == 'wrapper_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "type(struct.Struct.pack).__name__ == 'method_descriptor'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct.__init__.__qualname__ == 'Struct.__init__' (len 15). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('I').size == 4. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('I').format == 'I'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct.error has a 4-deep MRO (error, Exception, BaseException, object) compared to Struct's 2-deep MRO (Struct, object). struct.error inherits from Exception (not directly from BaseException)."
    - "Note: struct.Struct.__module__ is '_struct' (the C extension module), while struct.error.__module__ is 'struct' (the pure Python module). This is because error is defined in Lib/struct.py but Struct is a C type from Modules/_struct.c."
    - "Note: struct_extra93 anchors Struct.__bases__[0].__name__=='object' and Struct.__mro__.__len__()==2 at table level; this spec focuses on string equality for those same values and adds error class identity."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.error.__name__.__eq__('error')
# struct.error.__module__.__eq__('struct')
# struct.error.__bases__[0].__name__.__eq__('Exception')
# struct.error.__mro__.__len__()==4
# struct.error.__class__.__name__.__eq__('type')
#
# Wave 267 theme: struct.error class identity attributes.
#
# struct.error is a Python exception class defined in Lib/struct.py. It has
# __name__='error' (5 chars), __module__='struct' (6 chars), inherits from
# Exception (not BaseException directly), and has an MRO of depth 4:
# (error, Exception, BaseException, object). Its metaclass is 'type'.
# struct_extra93 anchors error __bases__/__module__ at table level; no prior
# struct spec anchors error.__name__/__mro__.__len__() as a grouped table
# with error.__class__.__name__ under structerr101.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra101.struct_error_class_identity:
  description: "error.__name__.__eq__('error')==True / error.__module__.__eq__('struct')==True / error.__bases__[0].__name__.__eq__('Exception')==True / error.__mro__.__len__()==4 / error.__class__.__name__.__eq__('type')==True — struct.error is defined in Lib/struct.py; MRO depth 4 (error, Exception, BaseException, object); inherits from Exception not BaseException directly; metaclass is 'type'; extra93 anchors __bases__/__module__; first structerr101 anchor grouping all five error identity attributes"
  kind: python_call_eq
  category: type_identity
  id_prefix: structerr101

  columns: [id, function, args, expected, description]
  rows:
    - [error_name_eq,      "error.__name__.__eq__",              ["error"],     true, "struct.error.__name__ is 'error' (5 chars; short uncapitalized name)"]
    - [error_module_eq,    "error.__module__.__eq__",            ["struct"],    true, "struct.error.__module__ is 'struct' (defined in Lib/struct.py, not _struct)"]
    - [error_base_eq,      "error.__bases__[0].__name__.__eq__", ["Exception"], true, "struct.error inherits from Exception (not BaseException directly)"]
    - [error_mro_len,      "error.__mro__.__len__",              [],            4,    "struct.error MRO depth is 4: (error, Exception, BaseException, object)"]
    - [error_class_type,   "error.__class__.__name__.__eq__",    ["type"],      true, "struct.error metaclass is 'type' (standard Python class metaclass)"]

# ---------------------------------------------------------------------------
# struct.Struct.__name__.__eq__('Struct')
# struct.Struct.__module__.__eq__('_struct')
# struct.Struct.__qualname__.__eq__('Struct')
# struct.Struct.__bases__[0].__name__.__eq__('object')
# struct.Struct.__class__.__name__.__eq__('type')
#
# Wave 267 theme: struct.Struct class-level attribute equality.
#
# struct.Struct is a C type from Modules/_struct.c. Its __name__ and
# __qualname__ are both 'Struct' (6 chars). Its __module__ is '_struct'
# (the C extension module, not 'struct'). It inherits directly from 'object'
# and its metaclass is 'type'. struct_extra93 anchors Struct.__module__,
# __qualname__, __bases__[0], __mro__.__len__()==2 at table level; no prior
# struct spec anchors these as string equality in a single grouped table
# under structerr101. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra101.Struct_class_attr_equality:
  description: "Struct.__name__.__eq__('Struct')==True / Struct.__module__.__eq__('_struct')==True / Struct.__qualname__.__eq__('Struct')==True / Struct.__bases__[0].__name__.__eq__('object')==True / Struct.__class__.__name__.__eq__('type')==True — Struct is a C type from _struct.c; __module__=='_struct' (C extension) while error.__module__=='struct' (Python module); __name__==__qualname__=='Struct'; inherits from object; metaclass is 'type'; extra93 anchors at table level; first structerr101 anchor for Struct identity equality"
  kind: python_call_eq
  category: type_identity
  id_prefix: structerr101

  columns: [id, function, args, expected, description]
  rows:
    - [struct_name_eq,    "Struct.__name__.__eq__",              ["Struct"],  true, "struct.Struct.__name__ is 'Struct' (6 chars; C type from _struct.c)"]
    - [struct_module_eq,  "Struct.__module__.__eq__",            ["_struct"], true, "struct.Struct.__module__ is '_struct' (C extension, not the 'struct' Python module)"]
    - [struct_qualname_eq, "Struct.__qualname__.__eq__",         ["Struct"],  true, "struct.Struct.__qualname__ is 'Struct' (same as __name__; no enclosing scope)"]
    - [struct_base_eq,    "Struct.__bases__[0].__name__.__eq__", ["object"],  true, "struct.Struct directly inherits from object (MRO depth 2: Struct, object)"]
    - [struct_class_type, "Struct.__class__.__name__.__eq__",    ["type"],    true, "struct.Struct metaclass is 'type' (standard metaclass for C-extension types)"]

# ---------------------------------------------------------------------------
# type(struct.Struct.__init__).__name__.__eq__('wrapper_descriptor')
# type(struct.Struct.pack).__name__.__eq__('method_descriptor')
# struct.Struct.__init__.__qualname__.__eq__('Struct.__init__')
# struct.Struct.__init__.__qualname__.__len__()==15
# struct.Struct('I').size.__eq__(4)
#
# Wave 267 theme: struct.Struct method types and Struct instance attributes.
#
# struct.Struct.__init__ is a wrapper_descriptor (the C slot wrapper for
# tp_init), while struct.Struct.pack is a method_descriptor (a C method).
# __init__.__qualname__ is 'Struct.__init__' (15 chars = 'Struct.' 7 + '__init__' 8).
# struct.Struct('I').size is 4 (unsigned int on 32/64-bit platform = 4 bytes).
# struct_extra100 anchors Struct.pack as method_descriptor; no prior struct spec
# anchors __init__ as wrapper_descriptor or __init__.__qualname__ string equality
# or size==4 as a group under structerr101.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra101.Struct_init_type_and_instance_attrs:
  description: "type(Struct.__init__).__name__=='wrapper_descriptor' / type(Struct.pack).__name__=='method_descriptor' / Struct.__init__.__qualname__.__eq__('Struct.__init__')==True / Struct.__init__.__qualname__.__len__()==15 / Struct.__new__(Struct, 'I').size.__eq__(4)==True — __init__ is wrapper_descriptor (C tp_init slot); pack is method_descriptor; __init__ qualname is 'Struct.__init__' (15 chars); Struct('I').size==4 (unsigned int 4 bytes); extra100 anchors pack as method_descriptor; first structerr101 anchor grouping __init__ type and qualname with size"
  kind: python_call_eq
  category: type_identity
  id_prefix: structerr101

  columns: [id, function, args, expected, description]
  rows:
    - [init_wrapper_desc,  "Struct.__init__.__class__.__name__.__eq__",          ["wrapper_descriptor"], true, "struct.Struct.__init__ is a wrapper_descriptor (C tp_init slot, distinct from method_descriptor)"]
    - [pack_method_desc,   "Struct.pack.__class__.__name__.__eq__",              ["method_descriptor"],  true, "struct.Struct.pack is a method_descriptor (C method slot)"]
    - [init_qualname_eq,   "Struct.__init__.__qualname__.__eq__",                ["Struct.__init__"],    true, "Struct.__init__.__qualname__ is 'Struct.__init__' (15 chars = 'Struct.' 7 + '__init__' 8)"]
    - [init_qualname_len,  "Struct.__init__.__qualname__.__len__",               [],                     15,   "'Struct.__init__' is 15 chars"]
    - [struct_i_size,      "Struct.__new__(Struct, 'I').size.__eq__",            [4],                    true, "Struct('I').size == 4 bytes (unsigned int on 32/64-bit platform)"]

# ---------------------------------------------------------------------------
# struct.error.__mro__.__len__()==4 — standalone
#
# struct.error.__mro__.__len__() is 4. The MRO is (error, Exception,
# BaseException, object). This 4-deep chain contrasts with struct.Struct's
# minimal 2-deep MRO (Struct, object). struct.error inherits from Exception
# which itself inherits from BaseException then object. struct_extra94 anchors
# struct.error MRO depth at table level; no prior struct spec anchors
# struct.error.__mro__.__len__()==4 as a standalone under structerr101.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra101.error_mro_len_4:
  description: "struct.error.__mro__.__len__() == 4 — MRO is (error, Exception, BaseException, object); 4-deep chain vs Struct's 2-deep (Struct, object); inherits from Exception not BaseException directly; extra94 anchors at table level; first standalone for error MRO depth under structerr101"
  category: type_identity
  kind: python_call_eq
  function: error.__mro__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# struct.error.__bases__[0].__name__.__eq__('Exception') — standalone
#
# struct.error.__bases__[0].__name__ is 'Exception'. struct.error directly
# inherits from Exception (not from BaseException or OSError). This makes
# it a catchable exception using 'except Exception' or 'except struct.error'.
# Unlike OSError (which inherits from Exception too), struct.error has no
# special OS integration — it is raised for format string errors in pack/
# unpack operations. struct_extra93 anchors error __bases__ at table level;
# no prior struct spec anchors error.__bases__[0].__name__ as a standalone
# under structerr101. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra101.error_base_exception:
  description: "struct.error.__bases__[0].__name__.__eq__('Exception') == True — struct.error inherits directly from Exception (not BaseException or OSError); raised for format string errors in pack/unpack; catchable with 'except Exception' or 'except struct.error'; extra93 anchors at table level; first standalone under structerr101"
  category: type_identity
  kind: python_call_eq
  function: "error.__bases__[0].__name__.__eq__"
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__module__.__eq__('_struct') — standalone
#
# struct.Struct.__module__ is '_struct'. Struct is a C type defined in
# Modules/_struct.c and compiled into the _struct extension module.
# The public struct Python module (Lib/struct.py) imports Struct from
# _struct and re-exports it. This contrasts with struct.error whose
# __module__ is 'struct' (the Python-level module). struct_extra93 anchors
# Struct.__module__ at table level; no prior struct spec anchors
# Struct.__module__.__eq__('_struct') as a standalone under structerr101.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra101.Struct_module_eq_struct:
  description: "struct.Struct.__module__.__eq__('_struct') == True — Struct is a C type from Modules/_struct.c compiled into the _struct extension; public struct module imports Struct from _struct; contrasts with error.__module__=='struct' (Python-level module); extra93 anchors at table level; first standalone under structerr101"
  category: type_identity
  kind: python_call_eq
  function: "Struct.__module__.__eq__"
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__init__.__qualname__.__eq__('Struct.__init__') — standalone
#
# struct.Struct.__init__.__qualname__ is 'Struct.__init__' (15 chars =
# 'Struct.' 7 + '__init__' 8). Struct.__init__ is a wrapper_descriptor —
# the C slot wrapper for tp_init — rather than a method_descriptor like
# pack/unpack. Its __qualname__ follows the same 'Struct.' prefix convention
# as pack/unpack but wraps a different C-level mechanism. No prior struct spec
# anchors Struct.__init__.__qualname__ string equality as a standalone under
# structerr101. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra101.Struct_init_qualname_eq:
  description: "struct.Struct.__init__.__qualname__.__eq__('Struct.__init__') == True — __init__ is a wrapper_descriptor (C tp_init slot) with qualname 'Struct.__init__' (15 chars = 'Struct.' 7 + '__init__' 8); different from method_descriptor (pack/unpack) but same 'Struct.' prefix convention; no prior struct spec anchors this as standalone; first standalone under structerr101"
  category: qualname_equality
  kind: python_call_eq
  function: "Struct.__init__.__qualname__.__eq__"
  args: ["Struct.__init__"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct.__qualname__.__eq__('Struct') — standalone
#
# struct.Struct.__qualname__ is 'Struct' (6 chars). For a top-level C type,
# __qualname__ equals __name__ because there is no enclosing scope. Both
# __name__ and __qualname__ are 'Struct'. struct_extra93 anchors
# Struct.__qualname__ at table level (alongside __module__ and __bases__);
# no prior struct spec anchors Struct.__qualname__.__eq__('Struct') as a
# standalone under structerr101. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra101.Struct_qualname_eq:
  description: "struct.Struct.__qualname__.__eq__('Struct') == True — Struct is a top-level C type so __qualname__==__name__=='Struct' (6 chars); no enclosing scope; extra93 anchors at table level; first standalone for Struct.__qualname__ equality under structerr101"
  category: qualname_equality
  kind: python_call_eq
  function: "Struct.__qualname__.__eq__"
  args: ["Struct"]
  expected: true
