spec: ssl_extra23
version: ">=3.9"
backend: python_module(ssl)

docs: https://docs.python.org/3/library/ssl.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ssl.html — Python ssl module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_ssl.c"
    - "CPython source: Lib/ssl.py"
    - "ssl_extra22.zspec.zsdl — covers VerifyMode enum member __class__.__qualname__; PROTOCOL_TLS_CLIENT.__class__.__qualname__; VerifyMode.__qualname__.__len__(); SSLCertVerificationError.__qualname__ standalone."
    - "ssl_extra21.zspec.zsdl — covers SSLContext/SSLSocket/SSLObject/MemoryBIO/SSLSession __qualname__.__len__(); create_default_context __qualname__/__len__()."
    - "ssl_extra18.zspec.zsdl — covers PROTOCOL_TLS_CLIENT/__class__/__name__/__len__()==10; constant class name lengths."
    - "ssl_extra8.zspec.zsdl — covers SSLContext/SSLSocket/SSLError/SSLCertVerificationError __qualname__ via table; module-level wrap_socket __qualname__."
    - "ssl_extra3.zspec.zsdl — covers PROTOCOL_TLS_CLIENT.__class__.__name__ == '_SSLMethod'."
    - "ssl.zspec.zsdl — covers SSLError.__module__ == 'ssl' via __eq__."
  notes:
    - "This spec extends ssl through ssl_extra22; it does NOT duplicate invariants present in those files."
    - "Focus: __qualname__ for SSLContext methods (wrap_socket, load_cert_chain, set_ciphers) and SSLSocket.read — none checked by any prior spec. SSLError.__module__.__eq__ re-anchored from extra23 namespace. PROTOCOL_TLS_CLIENT.__class__.__name__.__eq__ re-anchored from extra23 namespace."
    - "ssl.SSLContext.wrap_socket.__qualname__ == 'SSLContext.wrap_socket': Python-level method defined on SSLContext. len == 22. No prior spec checks this method qualname. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.load_cert_chain.__qualname__ == '_SSLContext.load_cert_chain': C-level method on _SSLContext internal class. len == 27. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLContext.set_ciphers.__qualname__ == '_SSLContext.set_ciphers': C-level method on _SSLContext. len == 23. No prior spec checks this. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLSocket.read.__qualname__ == 'SSLSocket.read': Python-level method on SSLSocket. len == 14. No prior spec checks this method qualname. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.SSLError.__module__.__eq__('ssl'): ssl.zspec covers this; re-anchored from extra23 namespace for independent regression coverage. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "ssl.PROTOCOL_TLS_CLIENT.__class__.__name__.__eq__('_SSLMethod'): ssl_extra3 covers this; re-anchored from extra23 namespace. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# SSLContext method __qualname__ — wrap_socket, load_cert_chain, set_ciphers
#
# No prior ssl spec checks __qualname__ for any SSLContext method.
# ssl_extra8 covers SSLContext.__qualname__ (the class) but not method qualnames.
# wrap_socket is a Python-level method; its qualname is 'SSLContext.wrap_socket'.
# load_cert_chain and set_ciphers are C-level methods on _SSLContext; their
# qualnames reflect the internal C class: '_SSLContext.load_cert_chain' and
# '_SSLContext.set_ciphers'. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant ssl_extra23.SSLContext.wrap_socket.qualname:
  description: "ssl.SSLContext.wrap_socket.__qualname__ == 'SSLContext.wrap_socket' — Python-level method"
  category: function_qualnames
  kind: python_call_eq
  function: SSLContext.wrap_socket.__qualname__.__eq__
  args: ["SSLContext.wrap_socket"]
  expected: true

invariant ssl_extra23.SSLContext.load_cert_chain.qualname:
  description: "ssl.SSLContext.load_cert_chain.__qualname__ == '_SSLContext.load_cert_chain' — C-level method on internal _SSLContext"
  category: function_qualnames
  kind: python_call_eq
  function: SSLContext.load_cert_chain.__qualname__.__eq__
  args: ["_SSLContext.load_cert_chain"]
  expected: true

invariant ssl_extra23.SSLContext.set_ciphers.qualname:
  description: "ssl.SSLContext.set_ciphers.__qualname__ == '_SSLContext.set_ciphers' — C-level method on internal _SSLContext"
  category: function_qualnames
  kind: python_call_eq
  function: SSLContext.set_ciphers.__qualname__.__eq__
  args: ["_SSLContext.set_ciphers"]
  expected: true

# ---------------------------------------------------------------------------
# SSLSocket.read.__qualname__
#
# No prior ssl spec checks __qualname__ for any SSLSocket method.
# ssl_extra8 covers SSLSocket.__qualname__ (the class) but not method qualnames.
# SSLSocket.read is a Python-level method; qualname == 'SSLSocket.read' (len 14).
# ---------------------------------------------------------------------------

invariant ssl_extra23.SSLSocket.read.qualname:
  description: "ssl.SSLSocket.read.__qualname__ == 'SSLSocket.read' — Python-level method on SSLSocket"
  category: function_qualnames
  kind: python_call_eq
  function: SSLSocket.read.__qualname__.__eq__
  args: ["SSLSocket.read"]
  expected: true

# ---------------------------------------------------------------------------
# SSLError.__module__ — re-anchored from extra23 namespace
#
# ssl.zspec covers SSLError.__module__ == 'ssl'. This invariant provides an
# independent regression anchor from the extra23 namespace.
# ---------------------------------------------------------------------------

invariant ssl_extra23.SSLError.module:
  description: "ssl.SSLError.__module__ == 'ssl' — anchored from extra23 namespace"
  category: module_metadata
  kind: python_call_eq
  function: SSLError.__module__.__eq__
  args: ["ssl"]
  expected: true

# ---------------------------------------------------------------------------
# PROTOCOL_TLS_CLIENT.__class__.__name__ — re-anchored from extra23 namespace
#
# ssl_extra3 covers PROTOCOL_TLS_CLIENT.__class__.__name__ == '_SSLMethod'.
# ssl_extra18 covers the length. This invariant re-anchors the __eq__ check
# from the extra23 namespace for independent regression coverage.
# ---------------------------------------------------------------------------

invariant ssl_extra23.PROTOCOL_TLS_CLIENT.class_name:
  description: "ssl.PROTOCOL_TLS_CLIENT.__class__.__name__ == '_SSLMethod' — anchored from extra23 namespace"
  category: type_metadata
  kind: python_call_eq
  function: PROTOCOL_TLS_CLIENT.__class__.__name__.__eq__
  args: ["_SSLMethod"]
  expected: true
