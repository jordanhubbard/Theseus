spec: decimal_extra105
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "CPython source: Modules/_decimal/_decimal.c"
  notes:
    - "This spec extends decimal_extra104.zspec.zsdl."
    - "This spec covers: decimal.Context method qualnames and types for quantize, normalize, sqrt, power, compare; and decimal.Decimal.quantize/normalize/sqrt/compare qualnames."
    - "type(decimal.Context.quantize).__name__ == 'method_descriptor' (C extension method); same for normalize, sqrt, power, compare."
    - "decimal.Context.quantize.__qualname__ == 'Context.quantize' (16 chars)."
    - "decimal.Context.normalize.__qualname__ == 'Context.normalize' (17 chars)."
    - "decimal.Context.sqrt.__qualname__ == 'Context.sqrt' (12 chars; shortest Context method qualname)."
    - "decimal.Context.power.__qualname__ == 'Context.power' (13 chars)."
    - "decimal.Context.compare.__qualname__ == 'Context.compare' (15 chars)."
    - "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize' (16 chars); type 'method_descriptor'."
    - "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize' (17 chars); type 'method_descriptor'."
    - "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt' (12 chars); type 'method_descriptor'."
    - "decimal.Decimal.compare.__qualname__ == 'Decimal.compare' (15 chars); type 'method_descriptor'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal.Context method types and qualnames: quantize, normalize, sqrt
# All are 'method_descriptor' (C extension tp_methods table entries).
# quantize: 'Context.quantize' (16 chars).
# normalize: 'Context.normalize' (17 chars).
# sqrt: 'Context.sqrt' (12 chars; shortest).
# ---------------------------------------------------------------------------

table decimal_extra105.Context_quantize_normalize_sqrt_qualnames:
  description: "decimal.Context quantize/normalize/sqrt: type='method_descriptor'; quantize='Context.quantize'(16), normalize='Context.normalize'(17), sqrt='Context.sqrt'(12)"
  kind: python_call_eq
  category: qualnames
  id_prefix: decctx105a

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_quantize_type,    "Context.quantize.__class__.__name__.__eq__",    ["method_descriptor"], true,  "type(decimal.Context.quantize).__name__ == 'method_descriptor' (C extension method in tp_methods)"]
    - [ctx_quantize_qn_eq,   "Context.quantize.__qualname__.__eq__",          ["Context.quantize"],  true,  "decimal.Context.quantize.__qualname__ == 'Context.quantize'"]
    - [ctx_quantize_qn_len,  "Context.quantize.__qualname__.__len__",         [],                    16,    "decimal.Context.quantize.__qualname__.__len__() == 16 ('Context.quantize' has 16 chars)"]
    - [ctx_normalize_type,   "Context.normalize.__class__.__name__.__eq__",   ["method_descriptor"], true,  "type(decimal.Context.normalize).__name__ == 'method_descriptor'"]
    - [ctx_normalize_qn_eq,  "Context.normalize.__qualname__.__eq__",         ["Context.normalize"], true,  "decimal.Context.normalize.__qualname__ == 'Context.normalize'"]
    - [ctx_normalize_qn_len, "Context.normalize.__qualname__.__len__",        [],                    17,    "decimal.Context.normalize.__qualname__.__len__() == 17 ('Context.normalize' has 17 chars; longest in this group)"]
    - [ctx_sqrt_type,        "Context.sqrt.__class__.__name__.__eq__",        ["method_descriptor"], true,  "type(decimal.Context.sqrt).__name__ == 'method_descriptor'"]
    - [ctx_sqrt_qn_eq,       "Context.sqrt.__qualname__.__eq__",              ["Context.sqrt"],      true,  "decimal.Context.sqrt.__qualname__ == 'Context.sqrt'"]
    - [ctx_sqrt_qn_len,      "Context.sqrt.__qualname__.__len__",             [],                    12,    "decimal.Context.sqrt.__qualname__.__len__() == 12 ('Context.sqrt' has 12 chars; shortest Context method qualname)"]
    - [ctx_normalize_gt_quantize, "Context.normalize.__qualname__.__len__.__gt__", [16],             true,  "len('Context.normalize') > len('Context.quantize') (17 > 16)"]

# ---------------------------------------------------------------------------
# decimal.Context method qualnames: power, compare
# power: 'Context.power' (13 chars).
# compare: 'Context.compare' (15 chars).
# Both are 'method_descriptor' (C extension tp_methods entries).
# ---------------------------------------------------------------------------

table decimal_extra105.Context_power_compare_qualnames:
  description: "decimal.Context power/compare: type='method_descriptor'; power='Context.power'(13), compare='Context.compare'(15)"
  kind: python_call_eq
  category: qualnames
  id_prefix: decctx105b

  columns: [id, function, args, expected, description]
  rows:
    - [ctx_power_type,      "Context.power.__class__.__name__.__eq__",    ["method_descriptor"], true,  "type(decimal.Context.power).__name__ == 'method_descriptor' (C extension method)"]
    - [ctx_power_qn_eq,     "Context.power.__qualname__.__eq__",          ["Context.power"],     true,  "decimal.Context.power.__qualname__ == 'Context.power'"]
    - [ctx_power_qn_len,    "Context.power.__qualname__.__len__",         [],                    13,    "decimal.Context.power.__qualname__.__len__() == 13 ('Context.power' has 13 chars)"]
    - [ctx_compare_type,    "Context.compare.__class__.__name__.__eq__",  ["method_descriptor"], true,  "type(decimal.Context.compare).__name__ == 'method_descriptor'"]
    - [ctx_compare_qn_eq,   "Context.compare.__qualname__.__eq__",        ["Context.compare"],   true,  "decimal.Context.compare.__qualname__ == 'Context.compare'"]
    - [ctx_compare_qn_len,  "Context.compare.__qualname__.__len__",       [],                    15,    "decimal.Context.compare.__qualname__.__len__() == 15 ('Context.compare' has 15 chars)"]
    - [ctx_compare_gt_power, "Context.compare.__qualname__.__len__.__gt__", [13],                true,  "len('Context.compare') > len('Context.power') (15 > 13)"]
    - [ctx_sqrt_lt_power,    "Context.sqrt.__qualname__.__len__.__lt__",   [13],                 true,  "len('Context.sqrt') < len('Context.power') (12 < 13; sqrt is the shortest Context method qualname)"]

# ---------------------------------------------------------------------------
# decimal.Decimal.quantize, normalize, sqrt, compare qualnames and types
# All are 'method_descriptor' (C extension methods on the Decimal type).
# quantize: 'Decimal.quantize' (16 chars).
# normalize: 'Decimal.normalize' (17 chars).
# sqrt: 'Decimal.sqrt' (12 chars).
# compare: 'Decimal.compare' (15 chars).
# ---------------------------------------------------------------------------

table decimal_extra105.Decimal_quantize_normalize_sqrt_compare_qualnames:
  description: "decimal.Decimal quantize/normalize/sqrt/compare: type='method_descriptor'; quantize='Decimal.quantize'(16), normalize='Decimal.normalize'(17), sqrt='Decimal.sqrt'(12), compare='Decimal.compare'(15)"
  kind: python_call_eq
  category: qualnames
  id_prefix: decctx105c

  columns: [id, function, args, expected, description]
  rows:
    - [dec_quantize_type,    "Decimal.quantize.__class__.__name__.__eq__",    ["method_descriptor"], true,  "type(decimal.Decimal.quantize).__name__ == 'method_descriptor' (C extension method on Decimal)"]
    - [dec_quantize_qn_eq,   "Decimal.quantize.__qualname__.__eq__",          ["Decimal.quantize"],  true,  "decimal.Decimal.quantize.__qualname__ == 'Decimal.quantize'"]
    - [dec_quantize_qn_len,  "Decimal.quantize.__qualname__.__len__",         [],                    16,    "decimal.Decimal.quantize.__qualname__.__len__() == 16 ('Decimal.quantize' has 16 chars)"]
    - [dec_normalize_type,   "Decimal.normalize.__class__.__name__.__eq__",   ["method_descriptor"], true,  "type(decimal.Decimal.normalize).__name__ == 'method_descriptor'"]
    - [dec_normalize_qn_eq,  "Decimal.normalize.__qualname__.__eq__",         ["Decimal.normalize"], true,  "decimal.Decimal.normalize.__qualname__ == 'Decimal.normalize'"]
    - [dec_normalize_qn_len, "Decimal.normalize.__qualname__.__len__",        [],                    17,    "decimal.Decimal.normalize.__qualname__.__len__() == 17 ('Decimal.normalize' has 17 chars; longest in this group)"]
    - [dec_sqrt_type,        "Decimal.sqrt.__class__.__name__.__eq__",        ["method_descriptor"], true,  "type(decimal.Decimal.sqrt).__name__ == 'method_descriptor'"]
    - [dec_sqrt_qn_eq,       "Decimal.sqrt.__qualname__.__eq__",              ["Decimal.sqrt"],      true,  "decimal.Decimal.sqrt.__qualname__ == 'Decimal.sqrt'"]
    - [dec_sqrt_qn_len,      "Decimal.sqrt.__qualname__.__len__",             [],                    12,    "decimal.Decimal.sqrt.__qualname__.__len__() == 12 ('Decimal.sqrt' has 12 chars; shortest Decimal arithmetic method qualname)"]
    - [dec_compare_type,     "Decimal.compare.__class__.__name__.__eq__",     ["method_descriptor"], true,  "type(decimal.Decimal.compare).__name__ == 'method_descriptor'"]
    - [dec_compare_qn_eq,    "Decimal.compare.__qualname__.__eq__",           ["Decimal.compare"],   true,  "decimal.Decimal.compare.__qualname__ == 'Decimal.compare'"]
    - [dec_compare_qn_len,   "Decimal.compare.__qualname__.__len__",          [],                    15,    "decimal.Decimal.compare.__qualname__.__len__() == 15 ('Decimal.compare' has 15 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant decimal_extra105.Context.quantize_qualname:
  description: "decimal.Context.quantize.__qualname__ == 'Context.quantize' (length 16; type is 'method_descriptor'; the 'Context.' prefix is 8 chars and 'quantize' adds 8 more; same length as Decimal.quantize at 16 chars — both classes expose identically-named methods)"
  category: qualnames
  kind: python_call_eq
  function: "Context.quantize.__qualname__.__eq__"
  args: ["Context.quantize"]
  expected: true

invariant decimal_extra105.Context.sqrt_qualname_len:
  description: "decimal.Context.sqrt.__qualname__.__len__() == 12 ('Context.sqrt' has 12 characters; it is the shortest Context method qualname among quantize(16)/normalize(17)/sqrt(12)/power(13)/compare(15); 'Context.' (8) + 'sqrt' (4) == 12)"
  category: qualnames
  kind: python_call_eq
  function: "Context.sqrt.__qualname__.__len__"
  args: []
  expected: 12

invariant decimal_extra105.Context.normalize_qualname_len:
  description: "decimal.Context.normalize.__qualname__.__len__() == 17 ('Context.normalize' has 17 characters; it is the longest Context method qualname among the five examined; 'Context.' (8) + 'normalize' (9) == 17)"
  category: qualnames
  kind: python_call_eq
  function: "Context.normalize.__qualname__.__len__"
  args: []
  expected: 17

invariant decimal_extra105.Decimal.quantize_qualname_len:
  description: "decimal.Decimal.quantize.__qualname__.__len__() == 16 ('Decimal.quantize' has 16 characters; type is 'method_descriptor'; the 'Decimal.' prefix (8 chars) plus 'quantize' (8 chars) gives 16; same numeric length as Context.quantize though with different class prefix)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.quantize.__qualname__.__len__"
  args: []
  expected: 16

invariant decimal_extra105.Decimal.sqrt_qualname_len:
  description: "decimal.Decimal.sqrt.__qualname__.__len__() == 12 ('Decimal.sqrt' has 12 characters; type is 'method_descriptor'; 'Decimal.' (8) + 'sqrt' (4) == 12; shortest Decimal arithmetic method qualname, matching Context.sqrt at 12 chars)"
  category: qualnames
  kind: python_call_eq
  function: "Decimal.sqrt.__qualname__.__len__"
  args: []
  expected: 12
