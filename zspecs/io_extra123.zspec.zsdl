spec: io_extra123
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/textio.c"
    - "CPython source: Modules/_io/_iomodule.c"
  notes:
    - "This spec extends io_extra122.zspec.zsdl."
    - "This spec covers: io.TextIOWrapper class identity not yet covered by prior specs."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' (len 13); __module__ == '_io' (len 3); metaclass 'type'."
    - "io.TextIOWrapper.__mro__ has 4 entries: (TextIOWrapper, _TextIOBase, _IOBase, object)."
    - "MRO slot names have NOT been indexed by bracket notation in any prior io_extra spec."
    - "io.TextIOWrapper.__mro__[1].__name__ == '_TextIOBase' (len 11); the private abstract text base."
    - "io.TextIOWrapper.__mro__[2].__name__ == '_IOBase' (len 7); the root C IO base class."
    - "io.TextIOWrapper.__mro__[3].__name__ == 'object' (len 6); universal Python base class."
    - "io.TextIOWrapper.seek.__qualname__ == 'TextIOWrapper.seek' (len 18); equality assertion is novel."
    - "io.TextIOWrapper.close.__qualname__ == 'TextIOWrapper.close' (len 19); equality assertion is novel."
    - "io_extra113 covered read/readline/write qualname equality; io_extra38 covered seek/close __len__() only."
    - "io_extra38 and io_extra41 covered seek/close qualname __len__() but NOT equality assertions."
    - "No prior io_extra spec has indexed TextIOWrapper.__mro__ slots by bracket notation."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.TextIOWrapper class identity: __name__, __module__, __class__.__name__
# TextIOWrapper is the concrete C extension class for text-mode I/O wrapping a
# buffered binary stream. It is defined in Modules/_io/textio.c and exported via
# the _io extension module. Its __name__ is 'TextIOWrapper' (13 chars) and its
# __module__ is '_io' (3 chars, with the underscore prefix marking it as a private
# C implementation detail). The public 'io' module in Lib/io.py re-exports it.
# Its metaclass is plain 'type' (not ABCMeta or EnumType).
# io_extra80-99 repeatedly verified __name__=='TextIOWrapper', __module__=='_io',
# and __bases__[0].__name__=='_TextIOBase', but no prior spec indexed __mro__ slots.
# ---------------------------------------------------------------------------

table io_extra123.TextIOWrapper_name_module_metaclass:
  description: "io.TextIOWrapper: __name__='TextIOWrapper'(13), __module__='_io'(3), metaclass='type'; C extension class from Modules/_io/textio.c; re-exported by public io module"
  kind: python_call_eq
  category: class_identity
  id_prefix: iotwnm123a

  columns: [id, function, args, expected, description]
  rows:
    - [tw_name_eq,       "TextIOWrapper.__name__.__eq__",              ["TextIOWrapper"], true,  "io.TextIOWrapper.__name__ == 'TextIOWrapper' (13 chars; name of the concrete text-mode IO wrapper class defined in Modules/_io/textio.c)"]
    - [tw_name_len,      "TextIOWrapper.__name__.__len__",             [],                13,    "io.TextIOWrapper.__name__.__len__() == 13 ('TextIOWrapper' has 13 characters: 'Text'(4)+'IO'(2)+'Wrapper'(7)==13)"]
    - [tw_mod_eq,        "TextIOWrapper.__module__.__eq__",            ["_io"],           true,  "io.TextIOWrapper.__module__ == '_io' (3 chars; C extension implementation module; the public io module re-exports it from _io)"]
    - [tw_mod_len,       "TextIOWrapper.__module__.__len__",           [],                3,     "io.TextIOWrapper.__module__.__len__() == 3 ('_io' has 3 characters; same as IncrementalNewlineDecoder.__module__.__len__())"]
    - [tw_cls_type,      "TextIOWrapper.__class__.__name__.__eq__",    ["type"],          true,  "type(io.TextIOWrapper).__name__ == 'type' (plain C extension type; no ABCMeta or EnumType metaclass)"]
    - [tw_mod_ne_io,     "TextIOWrapper.__module__.__eq__",            ["io"],            false, "io.TextIOWrapper.__module__ != 'io' (the module is '_io' with underscore prefix, not the public 'io' alias)"]
    - [tw_name_gt_mod,   "TextIOWrapper.__name__.__len__.__gt__",      [3],              true,  "len('TextIOWrapper') > len('_io') (13 > 3; the class name is much longer than its implementation module name)"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper MRO slot names (indexed bracket notation)
# TextIOWrapper.__mro__ == (TextIOWrapper, _TextIOBase, _IOBase, object) — 4 entries.
# This is the abstract C IO class hierarchy:
#   slot 0: TextIOWrapper — the concrete text-mode wrapper
#   slot 1: _TextIOBase — the abstract text IO base (provides text-mode ABC interface)
#   slot 2: _IOBase — the root C IO base class (provides close/readable/writable/seekable)
#   slot 3: object — universal Python base class
# No prior io_extra spec has indexed individual TextIOWrapper.__mro__ slots by bracket notation.
# io_extra80-99 covered __mro__.__len__()==4 as a table row but never slot-indexed the names.
# ---------------------------------------------------------------------------

table io_extra123.TextIOWrapper_mro_slot_names:
  description: "io.TextIOWrapper.__mro__ slot names: [0]='TextIOWrapper'(13),[1]='_TextIOBase'(11),[2]='_IOBase'(7),[3]='object'(6); 4-entry MRO; no prior io_extra spec has indexed TextIOWrapper MRO slots"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: iotwmro123b

  columns: [id, function, args, expected, description]
  rows:
    - [tw_mro0_name,   "TextIOWrapper.__mro__[0].__name__.__eq__",  ["TextIOWrapper"], true,  "io.TextIOWrapper.__mro__[0].__name__ == 'TextIOWrapper' (the class itself is always first in its own MRO)"]
    - [tw_mro1_name,   "TextIOWrapper.__mro__[1].__name__.__eq__",  ["_TextIOBase"],   true,  "io.TextIOWrapper.__mro__[1].__name__ == '_TextIOBase' (private abstract text IO base; defines the text-mode IO ABC interface for readlines/writelines)"]
    - [tw_mro2_name,   "TextIOWrapper.__mro__[2].__name__.__eq__",  ["_IOBase"],       true,  "io.TextIOWrapper.__mro__[2].__name__ == '_IOBase' (private root C IO base; defines close/readable/writable/seekable for all C io types)"]
    - [tw_mro3_name,   "TextIOWrapper.__mro__[3].__name__.__eq__",  ["object"],        true,  "io.TextIOWrapper.__mro__[3].__name__ == 'object' (universal Python base class; terminates the 4-entry MRO at slot 3)"]
    - [tw_mro1_len,    "TextIOWrapper.__mro__[1].__name__.__len__", [],                11,    "io.TextIOWrapper.__mro__[1].__name__.__len__() == 11 ('_TextIOBase' has 11 characters: '_Text'(5)+'IO'(2)+'Base'(4)==11)"]
    - [tw_mro2_len,    "TextIOWrapper.__mro__[2].__name__.__len__", [],                7,     "io.TextIOWrapper.__mro__[2].__name__.__len__() == 7 ('_IOBase' has 7 characters: '_IO'(3)+'Base'(4)==7)"]
    - [tw_mro1_gt_mro2, "TextIOWrapper.__mro__[1].__name__.__len__.__gt__", [7],       true,  "len('_TextIOBase') > len('_IOBase') (11 > 7; the abstract text IO base has a longer name than the root IO base)"]

# ---------------------------------------------------------------------------
# io.TextIOWrapper method qualnames: seek and close
# TextIOWrapper.seek.__qualname__ == 'TextIOWrapper.seek' (18 chars).
# TextIOWrapper.close.__qualname__ == 'TextIOWrapper.close' (19 chars).
# io_extra38 and io_extra41 covered __len__() == 18 and 19 respectively for these
# qualnames but did NOT assert equality against the string value 'TextIOWrapper.seek'
# or 'TextIOWrapper.close'. The equality assertions are novel for extra123.
# io_extra113 covered read/readline/write qualname equality; seek and close were omitted.
# Both seek and close are defined directly on TextIOWrapper (in its __dict__) as
# method_descriptor objects from the _io C extension.
# readline (22) > write (19) == close (19) > read (18) == seek (18).
# ---------------------------------------------------------------------------

table io_extra123.TextIOWrapper_seek_close_qualnames:
  description: "io.TextIOWrapper.seek.__qualname__='TextIOWrapper.seek'(18); close.__qualname__='TextIOWrapper.close'(19); equality assertions novel; io_extra113 covered read/readline/write eq; io_extra38/41 covered len only"
  kind: python_call_eq
  category: method_identity
  id_prefix: iotwskck123c

  columns: [id, function, args, expected, description]
  rows:
    - [tw_seek_qn_eq,    "TextIOWrapper.seek.__qualname__.__eq__",          ["TextIOWrapper.seek"],  true,  "io.TextIOWrapper.seek.__qualname__ == 'TextIOWrapper.seek' (18 chars; seek is defined on TextIOWrapper in _io C extension; qualname uses 'TextIOWrapper.' prefix)"]
    - [tw_seek_qn_len,   "TextIOWrapper.seek.__qualname__.__len__",         [],                      18,    "io.TextIOWrapper.seek.__qualname__.__len__() == 18 ('TextIOWrapper.seek' has 18 characters: 'TextIOWrapper.'(14)+'seek'(4)==18)"]
    - [tw_close_qn_eq,   "TextIOWrapper.close.__qualname__.__eq__",         ["TextIOWrapper.close"], true,  "io.TextIOWrapper.close.__qualname__ == 'TextIOWrapper.close' (19 chars; close is defined on TextIOWrapper in _io C extension; qualname uses 'TextIOWrapper.' prefix)"]
    - [tw_close_qn_len,  "TextIOWrapper.close.__qualname__.__len__",        [],                      19,    "io.TextIOWrapper.close.__qualname__.__len__() == 19 ('TextIOWrapper.close' has 19 characters: 'TextIOWrapper.'(14)+'close'(5)==19)"]
    - [tw_close_gt_seek, "TextIOWrapper.close.__qualname__.__len__.__gt__", [18],                    true,  "len('TextIOWrapper.close') > len('TextIOWrapper.seek') (19 > 18; 'close'(5) is 1 char longer than 'seek'(4))"]
    - [tw_seek_type,     "TextIOWrapper.seek.__class__.__name__.__eq__",    ["method_descriptor"],   true,  "type(io.TextIOWrapper.seek).__name__ == 'method_descriptor' (seek is a C method_descriptor, not a plain function; defined in Modules/_io/textio.c)"]
    - [tw_close_type,    "TextIOWrapper.close.__class__.__name__.__eq__",   ["method_descriptor"],   true,  "type(io.TextIOWrapper.close).__name__ == 'method_descriptor' (close is a C method_descriptor; same type as seek, read, write in TextIOWrapper)"]
    - [tw_seek_ne_rl,    "TextIOWrapper.seek.__qualname__.__eq__",          ["TextIOWrapper.readline"], false, "io.TextIOWrapper.seek.__qualname__ != 'TextIOWrapper.readline' (seek(18) and readline(22) are distinct methods with different qualnames and lengths)"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra123.TextIOWrapper.mro_slot1_is_TextIOBase:
  description: "io.TextIOWrapper.__mro__[1].__name__ == '_TextIOBase' (length 11; _TextIOBase is the private abstract C class for text-mode IO; it sits at MRO slot 1 immediately above TextIOWrapper in the inheritance chain; _TextIOBase defines the text-mode ABC interface — readlines, writelines — and inherits from _IOBase at slot 2; unlike the public ABCs (io.TextIOBase, io.RawIOBase, io.BufferedIOBase) which are Python-level abstract classes, _TextIOBase is a private C implementation class in Modules/_io/_iomodule.c; no prior io_extra spec has indexed TextIOWrapper.__mro__[1].__name__ via bracket notation)"
  category: class_hierarchy
  kind: python_call_eq
  function: "TextIOWrapper.__mro__[1].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra123.TextIOWrapper.mro_slot2_is_IOBase:
  description: "io.TextIOWrapper.__mro__[2].__name__ == '_IOBase' (length 7; _IOBase is the root C IO base class in the _io extension; it appears at slot 2 in TextIOWrapper's 4-entry MRO (TextIOWrapper, _TextIOBase, _IOBase, object); _IOBase defines the minimal IO interface: close(), readable(), writable(), seekable(), and __iter__/__next__; all concrete C io types (FileIO, BufferedReader, BufferedWriter, BufferedRandom, TextIOWrapper, BytesIO, StringIO) have _IOBase at slot 2 or later in their MRO; no prior io_extra spec has indexed TextIOWrapper.__mro__[2].__name__ via bracket notation)"
  category: class_hierarchy
  kind: python_call_eq
  function: "TextIOWrapper.__mro__[2].__name__.__eq__"
  args: ["_IOBase"]
  expected: true

invariant io_extra123.TextIOWrapper.seek_qualname_eq:
  description: "io.TextIOWrapper.seek.__qualname__ == 'TextIOWrapper.seek' (length 18; seek is a C method_descriptor defined directly on TextIOWrapper in Modules/_io/textio.c; its qualname uses the 'TextIOWrapper.' prefix (14 chars) followed by 'seek' (4 chars) for a total of 18; this is the same length as TextIOWrapper.read.__qualname__ ('TextIOWrapper.read' == 18); io_extra38 verified __len__()==18 but no prior spec asserted the equality 'TextIOWrapper.seek' as a full string; io_extra113 covered read/readline/write equality but not seek)"
  category: method_identity
  kind: python_call_eq
  function: "TextIOWrapper.seek.__qualname__.__eq__"
  args: ["TextIOWrapper.seek"]
  expected: true

invariant io_extra123.TextIOWrapper.close_qualname_eq:
  description: "io.TextIOWrapper.close.__qualname__ == 'TextIOWrapper.close' (length 19; close is a C method_descriptor defined directly on TextIOWrapper in Modules/_io/textio.c; its qualname uses the 'TextIOWrapper.' prefix (14 chars) followed by 'close' (5 chars) for a total of 19; this is the same length as TextIOWrapper.write.__qualname__ ('TextIOWrapper.write' == 19); io_extra41 verified __len__()==19 but no prior spec asserted the equality 'TextIOWrapper.close' as a full string; io_extra113 covered read/readline/write equality but not close)"
  category: method_identity
  kind: python_call_eq
  function: "TextIOWrapper.close.__qualname__.__eq__"
  args: ["TextIOWrapper.close"]
  expected: true

invariant io_extra123.TextIOWrapper.mro_slot1_len_11:
  description: "io.TextIOWrapper.__mro__[1].__name__.__len__() == 11 ('_TextIOBase' has 11 characters: the underscore prefix '_' (1) + 'Text' (4) + 'IO' (2) + 'Base' (4) == 11; this is longer than the root IO base '_IOBase'(7) at MRO slot 2 and longer than the concrete wrapper 'TextIOWrapper'(13) is a prefix of — but the abstract base name at slot 1 is notably longer than the root base name at slot 2; _TextIOBase's 11-char name is the longest private abstract base name in the io module's C hierarchy; no prior io_extra spec has tested TextIOWrapper.__mro__[1].__name__.__len__() with bracket notation)"
  category: class_hierarchy
  kind: python_call_eq
  function: "TextIOWrapper.__mro__[1].__name__.__len__"
  args: []
  expected: 11
