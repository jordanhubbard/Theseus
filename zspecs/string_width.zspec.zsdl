spec: string_width
version: ">=4.0.0"
backend: node(string-width)

docs: https://github.com/sindresorhus/string-width#readme

provenance:
  derived_from:
    - "string-width README — https://github.com/sindresorhus/string-width#readme"
    - "Test vectors verified with string-width@4.2.3 via Node.js 22.22.1 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "string-width source: index.js"
  notes:
    - "string-width exports the function as the module default (CJS in v4)."
    - "Returns the visual column width of a string in the terminal."
    - "ASCII characters have width 1. Empty string has width 0."
    - "CJK (fullwidth) characters have width 2 each."
    - "Emoji typically have width 2."
    - "ANSI escape codes require the ESC byte and cannot be expressed in YAML — not specced here."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a non-negative integer. No errors for string inputs."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table string_width.basic:
  kind: node_module_call_eq
  function: ~
  category: basic
  id_prefix: sw

  columns: [id, args, expected]
  rows:
    - [ascii,   ["hello"],  5]
    - [empty,   [""],       0]
    - [space,   [" "],      1]

table string_width.wide:
  kind: node_module_call_eq
  function: ~
  category: wide
  id_prefix: sw_wide

  columns: [id, args, expected]
  rows:
    - [cjk,    ["中文"],  4]
    - [emoji,  ["😀"],    2]
