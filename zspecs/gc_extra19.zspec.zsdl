spec: gc_extra19
version: ">=3.9"
backend: python_module(gc)

docs: https://docs.python.org/3/library/gc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/gc.html — Python gc module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/gcmodule.c"
    - "gc_extra18.zspec.zsdl — covers garbage/callbacks __class__.__name__; get_threshold/__class__/__len__; get_count/__class__/__len__; isenabled __class__.__name__; freeze/unfreeze/get_freeze_count __name__"
    - "gc_extra17.zspec.zsdl — covers collect return type; set_threshold/__name__/__module__; set_debug/__name__; get_debug return type; DEBUG_* __class__.__name__"
    - "gc_extra16.zspec.zsdl — covers get_threshold per-element values; get_count per-element type checks; freeze/unfreeze/get_freeze_count __name__ table"
    - "gc_extra15.zspec.zsdl — covers function_names table; garbage/callbacks class checks; threshold/count class and len checks; isenabled returns bool"
  notes:
    - "This spec extends gc.zspec.zsdl through gc_extra18.zspec.zsdl."
    - "NEW: isenabled.__name__; isenabled.__qualname__; get_threshold.__name__; get_count.__name__; per-element int type checks for threshold and count tuples; garbage.__len__()==0; callbacks.__len__()==0."
    - "gc.isenabled.__name__ == 'isenabled' — the C builtin name attribute."
    - "gc.isenabled.__qualname__ == 'isenabled' — the qualname is the same as __name__ for top-level C builtins."
    - "gc.get_threshold().__getitem__(0).__class__.__name__ == 'int' — each threshold element is an int."
    - "gc.get_count().__getitem__(0).__class__.__name__ == 'int' — each count element is an int."
    - "gc.garbage.__len__() == 0 — garbage list is empty in a clean interpreter."
    - "gc.callbacks.__len__() == 0 — callbacks list is empty when no GC callbacks are registered."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# isenabled — __name__ and __qualname__ (gc_extra19 namespace)
#
# No prior gc spec records isenabled.__name__ or isenabled.__qualname__ as
# standalone invariants. These anchor the function name attributes under
# the extra19 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra19.isenabled.name:
  description: "gc.isenabled.__name__ == 'isenabled' — C builtin function name attribute"
  category: function_attrs
  kind: python_call_eq
  function: isenabled.__name__.__eq__
  args: ["isenabled"]
  expected: true

invariant gc_extra19.isenabled.qualname:
  description: "gc.isenabled.__qualname__ == 'isenabled' — qualname equals __name__ for top-level C builtins"
  category: function_attrs
  kind: python_call_eq
  function: isenabled.__qualname__.__eq__
  args: ["isenabled"]
  expected: true

# ---------------------------------------------------------------------------
# get_threshold — __name__ (gc_extra19 namespace)
#
# No prior gc spec records get_threshold.__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant gc_extra19.get_threshold.name:
  description: "gc.get_threshold.__name__ == 'get_threshold' — C builtin function name attribute"
  category: function_attrs
  kind: python_call_eq
  function: get_threshold.__name__.__eq__
  args: ["get_threshold"]
  expected: true

# ---------------------------------------------------------------------------
# get_count — __name__ (gc_extra19 namespace)
#
# No prior gc spec records get_count.__name__ as a standalone invariant.
# ---------------------------------------------------------------------------

invariant gc_extra19.get_count.name:
  description: "gc.get_count.__name__ == 'get_count' — C builtin function name attribute"
  category: function_attrs
  kind: python_call_eq
  function: get_count.__name__.__eq__
  args: ["get_count"]
  expected: true

# ---------------------------------------------------------------------------
# get_threshold() element types — int (gc_extra19 namespace)
#
# gc_extra16 covers the numeric values of individual threshold elements.
# No prior spec records the __class__.__name__ == 'int' type check for each
# element as standalone invariants in the extra19 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra19.get_threshold.elem0_is_int:
  description: "gc.get_threshold()[0].__class__.__name__ == 'int' — gen-0 threshold is an int"
  category: element_types
  kind: python_call_eq
  function: get_threshold().__getitem__(0).__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra19.get_threshold.elem1_is_int:
  description: "gc.get_threshold()[1].__class__.__name__ == 'int' — gen-1 threshold is an int"
  category: element_types
  kind: python_call_eq
  function: get_threshold().__getitem__(1).__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra19.get_threshold.elem2_is_int:
  description: "gc.get_threshold()[2].__class__.__name__ == 'int' — gen-2 threshold is an int"
  category: element_types
  kind: python_call_eq
  function: get_threshold().__getitem__(2).__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# get_count() element types — int (gc_extra19 namespace)
#
# gc_extra16 covers per-element type checks in a table. These standalone
# invariants re-anchor the int type check under the extra19 namespace.
# ---------------------------------------------------------------------------

invariant gc_extra19.get_count.elem0_is_int:
  description: "gc.get_count()[0].__class__.__name__ == 'int' — gen-0 count is an int"
  category: element_types
  kind: python_call_eq
  function: get_count().__getitem__(0).__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra19.get_count.elem1_is_int:
  description: "gc.get_count()[1].__class__.__name__ == 'int' — gen-1 count is an int"
  category: element_types
  kind: python_call_eq
  function: get_count().__getitem__(1).__class__.__name__.__eq__
  args: ["int"]
  expected: true

invariant gc_extra19.get_count.elem2_is_int:
  description: "gc.get_count()[2].__class__.__name__ == 'int' — gen-2 count is an int"
  category: element_types
  kind: python_call_eq
  function: get_count().__getitem__(2).__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# garbage and callbacks — __len__ (gc_extra19 namespace)
#
# gc_extra18 covers garbage/callbacks __class__.__name__. No prior spec records
# garbage.__len__() == 0 or callbacks.__len__() == 0 as standalone invariants.
# These are valid in a clean interpreter with no GC callbacks registered.
# ---------------------------------------------------------------------------

invariant gc_extra19.garbage.len_is_zero:
  description: "gc.garbage.__len__() == 0 — garbage list is empty in a clean interpreter"
  category: collection_sizes
  kind: python_call_eq
  function: garbage.__len__
  args: []
  expected: 0

invariant gc_extra19.callbacks.len_is_zero:
  description: "gc.callbacks.__len__() == 0 — callbacks list is empty when no GC callbacks are registered"
  category: collection_sizes
  kind: python_call_eq
  function: callbacks.__len__
  args: []
  expected: 0
