spec: keyword_rust
version: ">=3.9"
backend: rust_module(keyword_rust)

docs: https://docs.python.org/3/library/keyword.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/keyword.html"
  not_derived_from:
    - "keyword source: internal implementation details"
  notes:
    - "Clean-room Rust reimplementation of Python keyword module, exposed via PyO3."
    - "iskeyword(s) returns True if s is a Python hard keyword, False otherwise."
    - "kwlist is a list of all Python hard keywords (35 as of Python 3.12)."
    - "Hard keywords include: for, while, if, def, class, return, import, lambda, True, False, None, and, or, not, in, is, etc."
    - "Non-keywords: 'hello', 'foo', 'print', 'len', 'match', 'case' (soft keywords)."
    - "All test vectors verified against Python 3.14.3 keyword module."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# iskeyword() — True for Python hard keywords
table keyword_rust.iskeyword.true_cases:
  kind: python_call_eq
  category: iskeyword
  id_prefix: iskeyword_true
  function: iskeyword

  columns: [id, args, expected]
  rows:
    - [for,    ["for"],    true]
    - [while,  ["while"],  true]
    - [if,     ["if"],     true]
    - [def,    ["def"],    true]
    - [class,  ["class"],  true]
    - [return, ["return"], true]
    - [import, ["import"], true]
    - [lambda, ["lambda"], true]
    - [True,   ["True"],   true]
    - [False,  ["False"],  true]
    - [None,   ["None"],   true]
    - [and,    ["and"],    true]
    - [or,     ["or"],     true]
    - [not,    ["not"],    true]
    - [in,     ["in"],     true]
    - [is,     ["is"],     true]

# iskeyword() — False for non-keywords
table keyword_rust.iskeyword.false_cases:
  kind: python_call_eq
  category: iskeyword
  id_prefix: iskeyword_false
  function: iskeyword

  columns: [id, args, expected]
  rows:
    - [hello, ["hello"], false]
    - [foo,   ["foo"],   false]
    - [print, ["print"], false]
    - [len,   ["len"],   false]
    - [match, ["match"], false]
    - [case,  ["case"],  false]

# kwlist — list of all keywords
invariant keyword_rust.kwlist.is_list:
  description: "kwlist is a non-empty list"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__len__
  args: []
  expected: 35

invariant keyword_rust.kwlist.contains_for:
  description: "kwlist contains 'for'"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__contains__
  args: ["for"]
  expected: true

invariant keyword_rust.kwlist.contains_def:
  description: "kwlist contains 'def'"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__contains__
  args: ["def"]
  expected: true

invariant keyword_rust.kwlist.not_contains_print:
  description: "kwlist does not contain 'print'"
  category: kwlist
  kind: python_call_eq
  function: kwlist.__contains__
  args: ["print"]
  expected: false

# ── Synthesis layer annotation ───────────────────────────────────────────────
synthesis:
  status: success
  model: azure/anthropic/claude-sonnet-4-6
  attempted_at: 2026-04-19T19:59:00Z
  iterations: 1
  pass_count: 26
  fail_count: 0
  total_invariants: 26
  notes: Synthesis succeeded in 1 iteration(s). 26 invariants passing.
  infeasible_reason: null
  invariant_annotations: {}
