spec: hashlib_extra62
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/hashlib.py"
    - "CPython source: Modules/_hashopenssl.c"
    - "hashlib_extra61.zspec.zsdl — covers hashlib.__loader__.__class__.__name__.__eq__('SourceFileLoader') / __spec__.__class__.__name__.__eq__('ModuleSpec') / __file__.__class__.__name__.__eq__('str') / __cached__.__class__.__name__.__eq__('str') (table + invariant)."
    - "hashlib_extra60.zspec.zsdl — covers hashlib.__all__.__contains__ for sha256/sha1/sha512/sha3_256 (table); blake2b/blake2s/md5/sha1 __doc__.__class__.__qualname__.__eq__('str'); __all__.__contains__('algorithms_guaranteed') (invariant)."
    - "hashlib_extra58.zspec.zsdl — covers hashlib.__spec__.name.__eq__('hashlib') and __spec__.name.__len__()==7."
    - "hashlib_extra36.zspec.zsdl — covers hashlib.__spec__.__name__.__len__()==7 and hashlib.__loader__.__class__.__name__.__len__()==16."
    - "hashlib_extra55.zspec.zsdl — covers hashlib.__name__.__eq__('hashlib') and __name__.__len__()==7."
    - "hashlib.zspec — covers hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra61; it does NOT duplicate invariants present in those files."
    - "Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations + __loader__.__name__ length checks."
    - "hashlib is a pure-Python module (hashlib.py). It is not a package: it has no subdirectory of sub-modules, so __spec__.submodule_search_locations is None (NoneType). For Python source files, __spec__.has_location is True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 1: No prior hashlib spec checks hashlib.__loader__.__class__.__name__.__len__()==16 in a table row context alongside the new __spec__.origin checks. hashlib_extra36 covers __loader__.__class__.__name__.__len__()==16 as a standalone invariant; hashlib_extra61 covers __loader__.__class__.__name__.__eq__('SourceFileLoader') as a table row and invariant. This spec adds __loader__.__class__.__name__.__len__()==16 as a table row, pairing it with the novel origin/submodule_search_locations/has_location rows as part of the wave 226 theme. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 2: No prior hashlib spec checks hashlib.__spec__.origin.__class__.__name__.__eq__('str'). hashlib.__spec__.origin is the absolute file path to hashlib.py as a Python str. Confirmed: type(hashlib.__spec__.origin).__name__ == 'str'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.origin.__class__.__name__ == 'str'. The ModuleSpec.origin attribute is the path to the source file (e.g., '.../lib/python3.14/hashlib.py') stored as a Python str. No prior hashlib spec checks __spec__.origin.__class__.__name__ in any form. Entirely novel origin type anchor for hashlib. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 3: No prior hashlib spec checks hashlib.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType'). hashlib is a single-file module (hashlib.py), not a package; therefore __spec__.submodule_search_locations is None. None.__class__.__name__ == 'NoneType'. This confirms hashlib is not a package. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.submodule_search_locations is None. For non-package modules loaded from a single .py file, ModuleSpec.submodule_search_locations is None (as opposed to packages, which have a list or _NamespacePath). None.__class__.__name__ == 'NoneType'. No prior hashlib spec checks submodule_search_locations in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Coverage gap 4: No prior hashlib spec checks hashlib.__spec__.has_location. For Python source modules, ModuleSpec.has_location is True because the module has a file path (origin). This is distinct from C built-in modules (e.g., sys, builtins) where has_location is False because there is no source file. has_location being True confirms hashlib is file-backed. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.__spec__.has_location == True. hashlib.py is a file-backed Python module; its ModuleSpec.has_location is True. C built-in modules have has_location == False. No prior hashlib spec checks __spec__.has_location. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib __spec__.origin + submodule_search_locations + has_location checks
#
# Wave 226 theme: __spec__.origin values + __spec__.submodule_search_locations +
# __loader__.__name__ length checks.
#
# hashlib is a single-file Python module (not a package). Its ModuleSpec has:
#   - origin: str path to hashlib.py
#   - submodule_search_locations: None (NoneType) — not a package
#   - has_location: True — file-backed module
#
# This table also includes the __loader__.__class__.__name__.__len__()==16 row
# (hashlib_extra36 covers it as a standalone invariant; this adds it as a table
# row in the wave 226 grouped context alongside the novel origin/submodule rows).
# ---------------------------------------------------------------------------

table hashlib_extra62.spec_origin_submodule_location:
  description: "hashlib __loader__.__class__.__name__.__len__()==16 / __spec__.origin.__class__.__name__.__eq__('str') / __spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') / __spec__.has_location==True — wave 226 theme: origin/submodule_search_locations/has_location checks for hashlib; hashlib is a single-file Python module (not a package); origin is a str path, submodule_search_locations is None (NoneType), has_location is True; all spec.origin/submodule/has_location rows are novel for hashlib"
  kind: python_call_eq
  category: module_structure
  id_prefix: hashlibspec62

  columns: [id, function, args, expected]
  rows:
    - [loader_class_name_len,              __loader__.__class__.__name__.__len__,                              [], 16]
    - [spec_origin_class_name_eq,          __spec__.origin.__class__.__name__.__eq__,                          ["str"],      true]
    - [spec_submodule_search_class_name_eq, __spec__.submodule_search_locations.__class__.__name__.__eq__,     ["NoneType"], true]
    - [spec_has_location,                  __spec__.has_location.__eq__,                                       [true],       true]

# ---------------------------------------------------------------------------
# hashlib.__spec__.origin.__class__.__name__.__eq__('str') — standalone
#
# hashlib.__spec__.origin is the absolute file path to hashlib.py, stored as
# a Python str. No prior hashlib spec checks __spec__.origin in any form.
# This is the primary origin type anchor for the hashlib module: it confirms
# that hashlib has a discoverable file-system location (as a str path), not
# None (as would be the case for namespace packages or virtual modules).
# ---------------------------------------------------------------------------

invariant hashlib_extra62.spec_origin_class_name_str:
  description: "hashlib.__spec__.origin.__class__.__name__.__eq__('str') == True — hashlib.__spec__.origin is the str path to hashlib.py; ModuleSpec.origin is str for file-backed Python modules; no prior hashlib spec checks __spec__.origin in any form; primary origin type anchor for hashlib confirming file-system-backed loading"
  category: module_structure
  kind: python_call_eq
  function: __spec__.origin.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType')
# — standalone
#
# hashlib is not a package: it is a single file (hashlib.py) with no
# sub-modules. ModuleSpec.submodule_search_locations is None for non-package
# modules. None.__class__.__name__ == 'NoneType'. This confirms at the type
# level that hashlib has no package search path — a structural fact about
# the module's design as a flat single-file wrapper.
# ---------------------------------------------------------------------------

invariant hashlib_extra62.spec_submodule_search_locations_nonetype:
  description: "hashlib.__spec__.submodule_search_locations.__class__.__name__.__eq__('NoneType') == True — hashlib is a single-file module (not a package); ModuleSpec.submodule_search_locations is None for non-package modules; None.__class__.__name__ == 'NoneType'; no prior hashlib spec checks submodule_search_locations; confirms hashlib has no package sub-path"
  category: module_structure
  kind: python_call_eq
  function: __spec__.submodule_search_locations.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true
