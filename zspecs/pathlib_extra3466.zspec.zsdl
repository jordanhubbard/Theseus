    - ["pp3466011", operator.contains, [pathlib.PurePath.__dict__,         "__len__"], false]
    - ["pp3466012", operator.contains, [pathlib.PurePosixPath.__dict__,    "__len__"], false]
    - ["pp3466013", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__len__"], false]
