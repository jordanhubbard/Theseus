spec: pp3466
version: ">=3.9"
backend: python_module(pathlib)
docs: https://docs.python.org/3/library/pathlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib: Object-oriented filesystem paths"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 678 (pp3466): __iter__, __next__, __len__ dict-presence checks for pathlib types."
    - "Classes covered: pathlib.PurePath, pathlib.PurePosixPath, pathlib.PureWindowsPath, pathlib.Path, pathlib.PosixPath (macOS only)."
    - "Theme: __iter__/__next__/__len__ dict-presence (iterator/sequence protocol)."
    - "No pathlib class defines __iter__ in its own __dict__: path objects are value types; the iterator protocol is not defined on any pathlib class's own __dict__."
    - "No pathlib class defines __next__ in its own __dict__: path objects are not iterators; __next__ is absent from all pathlib class __dict__s."
    - "No pathlib class defines __len__ in its own __dict__: path objects do not have a length protocol; __len__ is not defined on any pathlib class."
    - "pathlib.PosixPath is available on macOS/POSIX systems and verified false for all three methods."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __iter__ dict-presence — operator.contains(Cls.__dict__, '__iter__')
#
# No pathlib class defines __iter__ in its own __dict__; all false.
# Path objects are value types representing filesystem paths; the iterator
# protocol is not part of the pathlib protocol for any class.
# ---------------------------------------------------------------------------

table pp3466.iter:
  description: "pathlib types __iter__ dict-presence checks; wave 678"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: pp3466

  columns: [id, function, args, expected]
  rows:
    - ["pp3466001", operator.contains, [pathlib.PurePath.__dict__,         "__iter__"], false]
    - ["pp3466002", operator.contains, [pathlib.PurePosixPath.__dict__,    "__iter__"], false]
    - ["pp3466003", operator.contains, [pathlib.PureWindowsPath.__dict__,  "__iter__"], false]
    - ["pp3466004", operator.contains, [pathlib.Path.__dict__,             "__iter__"], false]
    - ["pp3466005", operator.contains, [pathlib.PosixPath.__dict__,        "__iter__"], false]

