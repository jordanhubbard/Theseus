# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# No pathlib class defines __len__ in its own __dict__; all false.
# Path objects do not have a length; __len__ is not defined on any
# pathlib class's own __dict__.
# ---------------------------------------------------------------------------

