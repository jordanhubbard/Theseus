spec: itertools_extra286
version: ">=3.9"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — itertools class identity, __doc__ types, and __qualname__ values"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "All itertools classes are implemented in C; their __doc__ attributes are str objects"
    - "All itertools class __qualname__ values equal their __name__ (no nesting)"
    - "zip_longest, islice, accumulate are C-level classes with str __doc__"
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

table itertools_extra286.doc_class_names:
  description: "__doc__ attribute is a str for each itertools class"
  kind: python_call_eq
  category: identity
  id_prefix: idcn

  columns: [id, function, args, expected, description]
  rows:
    - [idcn001, itertools.chain.__doc__.__class__.__name__.__eq__, ["str"], true, "chain.__doc__ is a str"]
    - [idcn002, itertools.count.__doc__.__class__.__name__.__eq__, ["str"], true, "count.__doc__ is a str"]
    - [idcn003, itertools.cycle.__doc__.__class__.__name__.__eq__, ["str"], true, "cycle.__doc__ is a str"]
    - [idcn004, itertools.repeat.__doc__.__class__.__name__.__eq__, ["str"], true, "repeat.__doc__ is a str"]
    - [idcn005, itertools.product.__doc__.__class__.__name__.__eq__, ["str"], true, "product.__doc__ is a str"]
    - [idcn006, itertools.combinations.__doc__.__class__.__name__.__eq__, ["str"], true, "combinations.__doc__ is a str"]
    - [idcn007, itertools.permutations.__doc__.__class__.__name__.__eq__, ["str"], true, "permutations.__doc__ is a str"]
    - [idcn008, itertools.accumulate.__doc__.__class__.__name__.__eq__, ["str"], true, "accumulate.__doc__ is a str"]
    - [idcn009, itertools.zip_longest.__doc__.__class__.__name__.__eq__, ["str"], true, "zip_longest.__doc__ is a str"]
    - [idcn010, itertools.islice.__doc__.__class__.__name__.__eq__, ["str"], true, "islice.__doc__ is a str"]

table itertools_extra286.qualnames:
  description: "__qualname__ values for itertools classes"
  kind: python_call_eq
  category: identity
  id_prefix: iqn

  columns: [id, function, args, expected, description]
  rows:
    - [iqn001, itertools.chain.__qualname__.__eq__, ["chain"], true, "chain.__qualname__ is 'chain'"]
    - [iqn002, itertools.count.__qualname__.__eq__, ["count"], true, "count.__qualname__ is 'count'"]
    - [iqn003, itertools.cycle.__qualname__.__eq__, ["cycle"], true, "cycle.__qualname__ is 'cycle'"]
    - [iqn004, itertools.repeat.__qualname__.__eq__, ["repeat"], true, "repeat.__qualname__ is 'repeat'"]
    - [iqn005, itertools.product.__qualname__.__eq__, ["product"], true, "product.__qualname__ is 'product'"]
    - [iqn006, itertools.combinations.__qualname__.__eq__, ["combinations"], true, "combinations.__qualname__ is 'combinations'"]
    - [iqn007, itertools.permutations.__qualname__.__eq__, ["permutations"], true, "permutations.__qualname__ is 'permutations'"]
    - [iqn008, itertools.accumulate.__qualname__.__eq__, ["accumulate"], true, "accumulate.__qualname__ is 'accumulate'"]

invariant itertools_extra286.chain_qualname:
  description: "itertools.chain.__qualname__ == 'chain'"
  category: identity
  kind: python_call_eq
  function: itertools.chain.__qualname__.__eq__
  args: ["chain"]
  expected: true

invariant itertools_extra286.count_qualname:
  description: "itertools.count.__qualname__ == 'count'"
  category: identity
  kind: python_call_eq
  function: itertools.count.__qualname__.__eq__
  args: ["count"]
  expected: true

invariant itertools_extra286.module_name_length:
  description: "The string 'itertools' has length 9"
  category: identity
  kind: python_call_eq
  function: itertools.__name__.__len__
  args: []
  expected: 9
