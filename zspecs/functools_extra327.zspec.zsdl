spec: functools_extra327
version: ">=3.9"
backend: python_module(functools)

docs: https://docs.python.org/3/library/functools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/functools.html — functools documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "functools.cache is a Python function (Python 3.9+): cache.__class__.__name__ == 'function'."
    - "functools.cache.__name__ == 'cache', __module__ == 'functools'."
    - "functools.lru_cache(maxsize=128) returns a decorator which is a plain function; __class__.__name__ == 'function'."
    - "Only when lru_cache(maxsize=128) is applied to a real function does the result become '_lru_cache_wrapper'."
    - "functools.lru_cache.__doc__.__class__.__name__ == 'str' — doc string is a str."
    - "WRAPPER_ASSIGNMENTS on Python 3.14 is a 6-tuple: __module__, __name__, __qualname__, __doc__, __annotate__, __type_params__."
    - "WRAPPER_UPDATES on Python 3.14 is a 1-tuple: ('__dict__',)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# functools.cache — identity (Python 3.9+)
#
# cache is a plain Python function that wraps lru_cache(maxsize=None).
# Its __name__ is 'cache', __module__ is 'functools', and its runtime
# type is 'function'.
# ---------------------------------------------------------------------------

invariant functools_extra327.cache.name:
  description: "functools.cache.__name__ == 'cache'"
  category: cache_identity
  kind: python_call_eq
  function: cache.__name__.__eq__
  args: ["cache"]
  expected: true

invariant functools_extra327.cache.module:
  description: "functools.cache.__module__ == 'functools'"
  category: cache_identity
  kind: python_call_eq
  function: cache.__module__.__eq__
  args: ["functools"]
  expected: true

invariant functools_extra327.cache.class_name:
  description: "functools.cache.__class__.__name__ == 'function'"
  category: cache_identity
  kind: python_call_eq
  function: cache.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# functools.lru_cache — decorator call returns a plain function
#
# lru_cache(maxsize=128) returns a decorator whose type is 'function'.
# The decorated function itself is of type '_lru_cache_wrapper', but that
# is a separate step not tested here.
# ---------------------------------------------------------------------------

invariant functools_extra327.lru_cache.decorator_class_name:
  description: "functools.lru_cache(maxsize=128).__class__.__name__ == 'function'"
  category: lru_cache_decorator
  kind: python_call_eq
  function: lru_cache
  args: [{maxsize: 128}]
  method: __class__
  method_args: []
  method_chain: __name__.__eq__
  method_chain_args: ["function"]
  expected: true

invariant functools_extra327.lru_cache.doc_class_name:
  description: "functools.lru_cache.__doc__.__class__.__name__ == 'str'"
  category: lru_cache_identity
  kind: python_call_eq
  function: lru_cache.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_ASSIGNMENTS — 6-tuple on Python 3.14
#
# Members: __module__, __name__, __qualname__, __doc__, __annotate__,
#          __type_params__
# Note: __annotations__ was replaced by __annotate__ + __type_params__
#       in Python 3.14.
# ---------------------------------------------------------------------------

invariant functools_extra327.wrapper_assignments.length:
  description: "len(functools.WRAPPER_ASSIGNMENTS) == 6 on Python 3.14"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__len__
  args: []
  expected: 6

invariant functools_extra327.wrapper_assignments.contains_name:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__name__') == True"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__name__"]
  expected: true

invariant functools_extra327.wrapper_assignments.contains_doc:
  description: "functools.WRAPPER_ASSIGNMENTS.__contains__('__doc__') == True"
  category: wrapper_assignments
  kind: python_call_eq
  function: WRAPPER_ASSIGNMENTS.__contains__
  args: ["__doc__"]
  expected: true

# ---------------------------------------------------------------------------
# WRAPPER_UPDATES — 1-tuple on Python 3.14
#
# Contains only '__dict__'.
# ---------------------------------------------------------------------------

invariant functools_extra327.wrapper_updates.length:
  description: "len(functools.WRAPPER_UPDATES) == 1"
  category: wrapper_updates
  kind: python_call_eq
  function: WRAPPER_UPDATES.__len__
  args: []
  expected: 1
