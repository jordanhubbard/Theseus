spec: decimal_extra40
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/_pydecimal.py"
    - "decimal_extra39.zspec.zsdl — covers Context/Decimal/DecimalException/InvalidOperation/DivisionByZero/Overflow/Underflow/Inexact/Rounded __qualname__.__eq__() (string equality)."
    - "decimal_extra38.zspec.zsdl — covers Rounded/Subnormal/Clamped/FloatOperation __module__; Decimal/__bases__[0].__name__; Decimal.__mro__.__len__(); Context/__name__/__module__/__bases__[0].__name__."
    - "decimal_extra36.zspec.zsdl — covers DecimalException/__name__/__module__; InvalidOperation/__name__/__bases__[0].__name__; DivisionByZero/Overflow/Underflow/Inexact __name__."
    - "decimal_extra33.zspec.zsdl — covers Decimal dunder method __qualname__.__len__()."
    - "decimal_extra13.zspec.zsdl — covers Decimal.__name__.__eq__('Decimal')."
  notes:
    - "This spec extends decimal_extra39.zspec.zsdl."
    - "Prior specs collectively covered: Decimal/__name__/__module__ equality; all exception class __name__ equality; all exception __module__ equality; Decimal dunder method __qualname__.__len__() (decimal_extra33); Context/__name__/__module__/__bases__[0].__name__; all nine class __qualname__.__eq__() string equality (decimal_extra39). No prior decimal spec covers __qualname__.__len__() for any decimal class."
    - "This spec covers: decimal.Context.__qualname__.__len__()==7 (NOVEL — decimal_extra39 covers Context.__qualname__.__eq__('Context'); no prior decimal spec checks Context.__qualname__.__len__(); novel length anchor in decimal_extra40 namespace); decimal.Decimal.__qualname__.__len__()==7 (NOVEL); decimal.DecimalException.__qualname__.__len__()==16 (NOVEL); decimal.InvalidOperation.__qualname__.__len__()==16 (NOVEL); decimal.DivisionByZero.__qualname__.__len__()==14 (NOVEL); decimal.Overflow.__qualname__.__len__()==8 (NOVEL); decimal.Underflow.__qualname__.__len__()==9 (NOVEL); decimal.Inexact.__qualname__.__len__()==7 (NOVEL); decimal.Rounded.__qualname__.__len__()==7 (NOVEL)."
    - "decimal.Context.__qualname__.__len__() == 7. 'Context' has 7 characters. decimal_extra39 covers string equality; no prior decimal spec checks the length. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Decimal.__qualname__.__len__() == 7. 'Decimal' has 7 characters. Novel length anchor. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DecimalException.__qualname__.__len__() == 16. 'DecimalException' has 16 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.InvalidOperation.__qualname__.__len__() == 16. 'InvalidOperation' has 16 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.DivisionByZero.__qualname__.__len__() == 14. 'DivisionByZero' has 14 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Overflow.__qualname__.__len__() == 8. 'Overflow' has 8 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Underflow.__qualname__.__len__() == 9. 'Underflow' has 9 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Inexact.__qualname__.__len__() == 7. 'Inexact' has 7 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "decimal.Rounded.__qualname__.__len__() == 7. 'Rounded' has 7 characters. Novel. Verified Python 3.14 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# decimal class __qualname__.__len__() values
#
# All public classes in the decimal module are defined at module scope, so
# their __qualname__ equals their bare class name. __qualname__.__len__()
# therefore equals the length of that name.
#
# The decimal public class hierarchy:
#   Decimal              — the main numeric type         (7 chars)
#   Context              — arithmetic configuration      (7 chars)
#   DecimalException     — base exception                (16 chars)
#     InvalidOperation   — invalid operation signal      (16 chars)
#     DivisionByZero     — division by zero signal       (14 chars)
#     Overflow           — overflow signal               (8 chars)
#     Underflow          — underflow signal              (9 chars)
#     Inexact            — inexact result signal         (7 chars)
#     Rounded            — rounding occurred signal      (7 chars)
#
# decimal_extra39 covers __qualname__.__eq__() (string equality) for all nine.
# No prior decimal spec covers __qualname__.__len__() for any decimal class.
# All nine are novel length anchors in the decimal_extra40 namespace.
# Verified Python 3.14 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table decimal_extra40.class_qualname_lengths:
  description: "decimal class __qualname__.__len__() values: Context(7)/Decimal(7)/DecimalException(16)/InvalidOperation(16)/DivisionByZero(14)/Overflow(8)/Underflow(9)/Inexact(7)/Rounded(7) — length equals bare class name length for top-level classes; decimal_extra39 covers string equality; no prior decimal spec checks __qualname__.__len__() for any decimal class; all nine novel length anchors in decimal_extra40 namespace; verified Python 3.14 macOS/Darwin 25.4.0"
  kind: python_call_eq
  category: class_identity
  id_prefix: dcql40

  columns: [id, function, args, expected]
  rows:
    - [Context_qualname_len,          "Context.__qualname__.__len__",          [], 7]
    - [Decimal_qualname_len,          "Decimal.__qualname__.__len__",          [], 7]
    - [DecimalException_qualname_len, "DecimalException.__qualname__.__len__", [], 16]
    - [InvalidOperation_qualname_len, "InvalidOperation.__qualname__.__len__", [], 16]
    - [DivisionByZero_qualname_len,   "DivisionByZero.__qualname__.__len__",   [], 14]
    - [Overflow_qualname_len,         "Overflow.__qualname__.__len__",         [], 8]
    - [Underflow_qualname_len,        "Underflow.__qualname__.__len__",        [], 9]
    - [Inexact_qualname_len,          "Inexact.__qualname__.__len__",          [], 7]
    - [Rounded_qualname_len,          "Rounded.__qualname__.__len__",          [], 7]
