  expected: true

invariant itertools_extra101.product_sizeof_qualname_len:
  description: "len(itertools.product.__sizeof__.__qualname__) == 18 — qualname is 'product.__sizeof__'; product defines its own __sizeof__; wave 258; new to extra101"
  kind: python_call_eq
