spec: itertools_extra101
version: ">=3.9"
backend: python_module(itertools)
extends: itertools_extra100

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec extends itertools_extra100.zspec.zsdl."
    - "This spec covers: itertools.__spec__ class name ('ModuleSpec') and module ('_frozen_importlib'); itertools C-type __sizeof__ method_descriptor class name and __qualname__ strings; product/__sizeof__ and combinations/__sizeof__ have their own qualnames while chain/cycle/repeat/count/islice/starmap/takewhile fall through to object.__sizeof__; wave 258."
    - "itertools.__spec__.__class__.__name__ == 'ModuleSpec'. Verified with Python 3.14.3."
    - "itertools.__spec__.__class__.__module__ == '_frozen_importlib'. Verified with Python 3.14.3."
    - "itertools.chain.__sizeof__.__class__.__name__ == 'method_descriptor'. Verified with Python 3.14.3."
    - "itertools.product.__sizeof__.__qualname__ == 'product.__sizeof__'. Verified with Python 3.14.3."
    - "itertools.combinations.__sizeof__.__qualname__ == 'combinations.__sizeof__'. Verified with Python 3.14.3."
    - "itertools.permutations.__sizeof__.__qualname__ == 'permutations.__sizeof__'. Verified with Python 3.14.3."
    - "itertools.chain.__sizeof__.__qualname__ == 'object.__sizeof__' (inherits from object). Verified with Python 3.14.3."
    - "itertools.cycle.__sizeof__.__qualname__ == 'object.__sizeof__'. Verified with Python 3.14.3."
    - "itertools.repeat.__sizeof__.__qualname__ == 'object.__sizeof__'. Verified with Python 3.14.3."
    - "itertools.count.__sizeof__.__qualname__ == 'object.__sizeof__'. Verified with Python 3.14.3."
    - "itertools.combinations_with_replacement.__sizeof__.__qualname__ == 'combinations_with_replacement.__sizeof__'. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.__spec__ class name and module
#
# Wave 258 theme: itertools.__spec__ ModuleSpec class identity.
#
# itertools.__spec__.__class__.__name__ == 'ModuleSpec'
# itertools.__spec__.__class__.__module__ == '_frozen_importlib'
# itertools.__spec__.__class__.__qualname__ == 'ModuleSpec'
# len('ModuleSpec') == 10
# len('_frozen_importlib') == 17
#
# itertools is a C extension module; its ModuleSpec is the import system
# record created by importlib. ModuleSpec lives in _frozen_importlib
# (the frozen/built-in version of importlib._bootstrap). New to extra101.
# ---------------------------------------------------------------------------

table itertools_extra101.spec_class_identity:
  description: "itertools.__spec__.__class__.__name__=='ModuleSpec'; __module__=='_frozen_importlib'; __qualname__=='ModuleSpec'; len checks; wave 258; new to extra101"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolsspec101

  columns: [id, function, args, expected, description]
  rows:
    - [spec_class_name_eq_ModuleSpec,
       "__spec__.__class__.__name__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__name__.__eq__('ModuleSpec') == True — itertools.__spec__ is the ModuleSpec created by the import system when itertools was loaded; ModuleSpec is defined in importlib._bootstrap (frozen as _frozen_importlib); __spec__.__class__.__name__ is 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra101"]
    - [spec_class_module_eq_frozen_importlib,
       "__spec__.__class__.__module__.__eq__",
       ["_frozen_importlib"],
       true,
       "itertools.__spec__.__class__.__module__.__eq__('_frozen_importlib') == True — ModuleSpec's __module__ attribute is '_frozen_importlib', which is the internal name for the frozen version of importlib._bootstrap; str.__eq__('_frozen_importlib') returns True; new to extra101"]
    - [spec_class_qualname_eq_ModuleSpec,
       "__spec__.__class__.__qualname__.__eq__",
       ["ModuleSpec"],
       true,
       "itertools.__spec__.__class__.__qualname__.__eq__('ModuleSpec') == True — ModuleSpec is defined at module scope in _frozen_importlib; its __qualname__ is the simple class name 'ModuleSpec'; str.__eq__('ModuleSpec') returns True; new to extra101"]
    - [spec_class_name_len_eq_10,
       "__spec__.__class__.__name__.__len__",
       [],
       10,
       "itertools.__spec__.__class__.__name__.__len__() == 10 — __class__.__name__ is 'ModuleSpec'; len('ModuleSpec') == 10 (M-o-d-u-l-e-S-p-e-c); new to extra101"]
    - [spec_class_module_len_eq_17,
       "__spec__.__class__.__module__.__len__",
       [],
       17,
       "itertools.__spec__.__class__.__module__.__len__() == 17 — __class__.__module__ is '_frozen_importlib'; len('_frozen_importlib') == 17 (_-f-r-o-z-e-n-_-i-m-p-o-r-t-l-i-b); new to extra101"]

# ---------------------------------------------------------------------------
# Table 2: itertools C-type __sizeof__ class name (method_descriptor)
#
# Wave 258 theme: __sizeof__ on itertools C types is a 'method_descriptor'.
#
# itertools.chain.__sizeof__.__class__.__name__ == 'method_descriptor'
# itertools.cycle.__sizeof__.__class__.__name__ == 'method_descriptor'
# itertools.repeat.__sizeof__.__class__.__name__ == 'method_descriptor'
# itertools.count.__sizeof__.__class__.__name__ == 'method_descriptor'
# itertools.product.__sizeof__.__class__.__name__ == 'method_descriptor'
# itertools.combinations.__sizeof__.__class__.__name__ == 'method_descriptor'
#
# Accessing __sizeof__ on a C extension type yields a 'method_descriptor'
# (not a 'builtin_function_or_method' — the latter appears on instances).
# New to extra101.
# ---------------------------------------------------------------------------

table itertools_extra101.sizeof_class_names:
  description: "itertools C-type __sizeof__ accessed on the type itself gives class 'method_descriptor' for chain/cycle/repeat/count/product/combinations; wave 258; new to extra101"
  kind: python_call_eq
  category: class_names
  id_prefix: itertoolssizeof101

  columns: [id, function, args, expected, description]
  rows:
    - [chain_sizeof_class_name_eq_method_descriptor,
       "chain.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.chain.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — accessing __sizeof__ on the chain type (not an instance) yields a 'method_descriptor', which is the unbound form of a C-level method slot; str.__eq__('method_descriptor') returns True; new to extra101"]
    - [cycle_sizeof_class_name_eq_method_descriptor,
       "cycle.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.cycle.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — cycle.__sizeof__ on the type yields a 'method_descriptor'; cycle is a C extension type; str.__eq__('method_descriptor') returns True; new to extra101"]
    - [repeat_sizeof_class_name_eq_method_descriptor,
       "repeat.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.repeat.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — repeat.__sizeof__ on the type yields a 'method_descriptor'; repeat is a C extension type for repeating a value; str.__eq__('method_descriptor') returns True; new to extra101"]
    - [count_sizeof_class_name_eq_method_descriptor,
       "count.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.count.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — count.__sizeof__ on the type yields a 'method_descriptor'; count is a C extension type for counting from a start value; str.__eq__('method_descriptor') returns True; new to extra101"]
    - [product_sizeof_class_name_eq_method_descriptor,
       "product.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.product.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — product.__sizeof__ on the type yields a 'method_descriptor'; product is a C extension type for Cartesian product; str.__eq__('method_descriptor') returns True; new to extra101"]
    - [combinations_sizeof_class_name_eq_method_descriptor,
       "combinations.__sizeof__.__class__.__name__.__eq__",
       ["method_descriptor"],
       true,
       "itertools.combinations.__sizeof__.__class__.__name__.__eq__('method_descriptor') == True — combinations.__sizeof__ on the type yields a 'method_descriptor'; combinations is a C extension type; str.__eq__('method_descriptor') returns True; new to extra101"]

# ---------------------------------------------------------------------------
# Table 3: itertools C-type __sizeof__ __qualname__ values
#
# Wave 258 theme: __sizeof__ __qualname__ reveals inheritance pattern.
#
# itertools.product.__sizeof__.__qualname__ == 'product.__sizeof__' (len 18)
# itertools.combinations.__sizeof__.__qualname__ == 'combinations.__sizeof__' (len 23)
# itertools.permutations.__sizeof__.__qualname__ == 'permutations.__sizeof__' (len 23)
# itertools.combinations_with_replacement.__sizeof__.__qualname__ == 'combinations_with_replacement.__sizeof__' (len 40)
# itertools.chain.__sizeof__.__qualname__ == 'object.__sizeof__' (len 17)
# itertools.cycle.__sizeof__.__qualname__ == 'object.__sizeof__' (len 17)
#
# Types that define their own __sizeof__ have a qualname of 'TypeName.__sizeof__'.
# Types that inherit it from object have 'object.__sizeof__'. New to extra101.
# ---------------------------------------------------------------------------

table itertools_extra101.sizeof_qualnames:
  description: "itertools __sizeof__ __qualname__ values: product/combinations/permutations/combinations_with_replacement define their own; chain/cycle inherit from object; wave 258; new to extra101"
  kind: python_call_eq
  category: string_identity
  id_prefix: itertoolssizeof101

  columns: [id, function, args, expected, description]
  rows:
    - [product_sizeof_qualname_len_eq_18,
       "product.__sizeof__.__qualname__.__len__",
       [],
       18,
       "itertools.product.__sizeof__.__qualname__.__len__() == 18 — product defines its own __sizeof__ (it stores internal state requiring custom sizing); its __qualname__ is 'product.__sizeof__'; len('product.__sizeof__') == 18; new to extra101"]
    - [combinations_sizeof_qualname_len_eq_23,
       "combinations.__sizeof__.__qualname__.__len__",
       [],
       23,
       "itertools.combinations.__sizeof__.__qualname__.__len__() == 23 — combinations defines its own __sizeof__; its __qualname__ is 'combinations.__sizeof__'; len('combinations.__sizeof__') == 23; new to extra101"]
    - [permutations_sizeof_qualname_len_eq_23,
       "permutations.__sizeof__.__qualname__.__len__",
       [],
       23,
       "itertools.permutations.__sizeof__.__qualname__.__len__() == 23 — permutations defines its own __sizeof__; its __qualname__ is 'permutations.__sizeof__'; len('permutations.__sizeof__') == 23; new to extra101"]
    - [chain_sizeof_qualname_eq_object_sizeof,
       "chain.__sizeof__.__qualname__.__eq__",
       ["object.__sizeof__"],
       true,
       "itertools.chain.__sizeof__.__qualname__.__eq__('object.__sizeof__') == True — chain does not define its own __sizeof__; it inherits __sizeof__ from object; the qualname is 'object.__sizeof__'; str.__eq__('object.__sizeof__') returns True; new to extra101"]
    - [cycle_sizeof_qualname_eq_object_sizeof,
       "cycle.__sizeof__.__qualname__.__eq__",
       ["object.__sizeof__"],
       true,
       "itertools.cycle.__sizeof__.__qualname__.__eq__('object.__sizeof__') == True — cycle does not define its own __sizeof__; it inherits from object; qualname is 'object.__sizeof__'; str.__eq__('object.__sizeof__') returns True; new to extra101"]
    - [chain_sizeof_qualname_len_eq_17,
       "chain.__sizeof__.__qualname__.__len__",
       [],
       17,
       "itertools.chain.__sizeof__.__qualname__.__len__() == 17 — __qualname__ is 'object.__sizeof__'; len('object.__sizeof__') == 17 (o-b-j-e-c-t-.-_-_-s-i-z-e-o-f-_-_); new to extra101"]

