invariant itertools_extra101.combinations_with_replacement_sizeof_qualname_len:
  description: "len(itertools.combinations_with_replacement.__sizeof__.__qualname__) == 40 — qualname is 'combinations_with_replacement.__sizeof__'; wave 258; new to extra101"
