spec: pathlib_extra265
version: ">=3.9"
backend: python_module(pathlib)

docs: https://docs.python.org/3/library/pathlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/pathlib.html — pathlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/pathlib/"
    - "pathlib.zspec.zsdl — covers PurePosixPath name/stem/suffix/parts/parent/joinpath/str"
    - "pathlib_extra.zspec.zsdl — covers Path class identity, PurePosixPath components/predicates/truediv"
  notes:
    - "Path.exists, is_file, is_dir, stat, chmod, unlink are defined on Path; qualnames use 'Path.' prefix."
    - "Path.is_absolute.__qualname__ == 'PurePath.is_absolute' — inherited from PurePath, not overridden."
    - "Path.exists.__class__.__name__ == 'function' — these are plain Python functions in pathlib."
    - "PurePath.with_name, with_suffix, with_stem are defined on PurePath; qualnames use 'PurePath.' prefix."
    - "PurePath.with_name.__class__.__name__ == 'function'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Path existence/metadata methods — qualnames
# ---------------------------------------------------------------------------

table pathlib_extra265.Path.method_qualnames:
  description: "Path existence and metadata methods report correct __qualname__ attributes"
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [exists,  Path.exists.__qualname__.__eq__,  ["Path.exists"],  true]
    - [is_file, Path.is_file.__qualname__.__eq__,  ["Path.is_file"],  true]
    - [is_dir,  Path.is_dir.__qualname__.__eq__,   ["Path.is_dir"],   true]
    - [stat,    Path.stat.__qualname__.__eq__,     ["Path.stat"],     true]
    - [chmod,   Path.chmod.__qualname__.__eq__,    ["Path.chmod"],    true]
    - [unlink,  Path.unlink.__qualname__.__eq__,   ["Path.unlink"],   true]

# ---------------------------------------------------------------------------
# Path.is_absolute — inherited from PurePath (qualname reflects that)
# ---------------------------------------------------------------------------

invariant pathlib_extra265.Path.is_absolute.qualname:
  description: "Path.is_absolute.__qualname__ == 'PurePath.is_absolute' — method is inherited, not overridden"
  category: method_identity
  kind: python_call_eq
  function: Path.is_absolute.__qualname__.__eq__
  args: ["PurePath.is_absolute"]
  expected: true

# ---------------------------------------------------------------------------
# Path.exists — descriptor/class type
# ---------------------------------------------------------------------------

invariant pathlib_extra265.Path.exists.class_name:
  description: "Path.exists.__class__.__name__ == 'function' — pathlib methods are plain Python functions"
  category: method_identity
  kind: python_call_eq
  function: Path.exists.__class__.__name__.__eq__
  args: ["function"]
  expected: true

# ---------------------------------------------------------------------------
# PurePath with_* methods — qualnames
# ---------------------------------------------------------------------------

table pathlib_extra265.PurePath.with_methods_qualnames:
  description: "PurePath.with_name, with_suffix, with_stem report correct __qualname__ attributes"
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [with_name,   PurePath.with_name.__qualname__.__eq__,   ["PurePath.with_name"],   true]
    - [with_suffix, PurePath.with_suffix.__qualname__.__eq__, ["PurePath.with_suffix"], true]
    - [with_stem,   PurePath.with_stem.__qualname__.__eq__,   ["PurePath.with_stem"],   true]

# ---------------------------------------------------------------------------
# PurePath.with_name — descriptor/class type
# ---------------------------------------------------------------------------

invariant pathlib_extra265.PurePath.with_name.class_name:
  description: "PurePath.with_name.__class__.__name__ == 'function'"
  category: method_identity
  kind: python_call_eq
  function: PurePath.with_name.__class__.__name__.__eq__
  args: ["function"]
  expected: true
