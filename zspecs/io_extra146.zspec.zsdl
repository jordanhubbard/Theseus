# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra146.BufferedReader.name_len_14:
  description: "io.BufferedReader.__name__.__len__() == 14 ('BufferedReader' has 14 characters; the 'Buffered' prefix accounts for 8 of those, distinguishing it from the raw FileIO (6))"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__name__.__len__
  args: []
  expected: 14

invariant io_extra146.BufferedReader.module_is_underscore_io:
  description: "io.BufferedReader.__module__ == '_io' (length 3; BufferedReader is a C extension type defined in the _io module, exposed through the io module wrapper; the underscore prefix signals it is an implementation detail)"
  category: class_identity
  kind: python_call_eq
  function: BufferedReader.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra146.BufferedReader.mro_len_4:
  description: "io.BufferedReader.__mro__.__len__() == 4 (MRO is: BufferedReader, _BufferedIOBase, _IOBase, object — four entries; BufferedReader has a single linear inheritance chain with no multiple inheritance)"
  category: class_identity
  kind: python_call_eq
  function: "BufferedReader.__mro__.__len__"
  args: []
  expected: 4

invariant io_extra146.BufferedWriter.name_len_14:
  description: "io.BufferedWriter.__name__.__len__() == 14 ('BufferedWriter' has 14 characters; same length as BufferedReader (14), both sharing the 'Buffered' prefix and 6-character suffix)"
  category: class_identity
  kind: python_call_eq
  function: BufferedWriter.__name__.__len__
  args: []
  expected: 14

invariant io_extra146.FileIO.name_len_6:
  description: "io.FileIO.__name__.__len__() == 6 ('FileIO' has 6 characters; the shortest name among the concrete io C extension types — no 'Buffered'/'Text' prefix)"
  category: class_identity
  kind: python_call_eq
  function: FileIO.__name__.__len__
  args: []
  expected: 6

invariant io_extra146.TextIOWrapper.base0_is_TextIOBase:
  description: "io.TextIOWrapper.__bases__[0].__name__ == '_TextIOBase' (the C-level text IO base class; TextIOWrapper sits one level above it, adding encoding/decoding logic on top of the binary buffered stream)"
  category: class_identity
  kind: python_call_eq
  function: "TextIOWrapper.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

