spec: io_extra146
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_io/_iomodule.c"
    - "CPython source: Lib/io.py"
  notes:
    - "This spec covers: io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.FileIO, io.TextIOWrapper class identity (__name__, __module__, __qualname__, __class__.__name__) and MRO structure."
    - "BufferedReader, BufferedWriter, BufferedRandom, FileIO, TextIOWrapper all live in the C extension _io (module == '_io'), not the Python wrapper io."
    - "io.BufferedReader.__name__ == 'BufferedReader' (length 14); __module__ == '_io' (length 3)."
    - "io.BufferedWriter.__name__ == 'BufferedWriter' (length 14); __module__ == '_io' (length 3)."
    - "io.BufferedRandom.__name__ == 'BufferedRandom' (length 14); __module__ == '_io' (length 3)."
    - "io.FileIO.__name__ == 'FileIO' (length 6); __module__ == '_io' (length 3)."
    - "io.TextIOWrapper.__name__ == 'TextIOWrapper' (length 13); __module__ == '_io' (length 3)."
    - "All five classes have __mro__ of length 4: [ClassName, _XIOBase, _IOBase, object]."
    - "All five classes have __class__.__name__ == 'type' (plain metaclass, not ABCMeta)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# io.BufferedReader class identity
# BufferedReader is a C extension type; __module__ == '_io' (not 'io').
# __name__ == 'BufferedReader' (14), __qualname__ == 'BufferedReader' (14),
# __class__.__name__ == 'type', __bases__[0].__name__ == '_BufferedIOBase'.
# ---------------------------------------------------------------------------

table io_extra146.BufferedReader_class_identity:
  description: "io.BufferedReader class identity: __name__='BufferedReader' (14), __module__='_io' (3), __qualname__='BufferedReader' (14), __class__.__name__='type'"
  kind: python_call_eq
  category: class_identity
  id_prefix: iobr146

  columns: [id, function, args, expected]
  rows:
    - [br_name_eq,      BufferedReader.__name__.__eq__,           ["BufferedReader"], true]
    - [br_name_len,     BufferedReader.__name__.__len__,          [],                 14]
    - [br_module_eq,    BufferedReader.__module__.__eq__,         ["_io"],            true]
    - [br_module_len,   BufferedReader.__module__.__len__,        [],                 3]
    - [br_qualname_eq,  BufferedReader.__qualname__.__eq__,       ["BufferedReader"], true]
    - [br_qualname_len, BufferedReader.__qualname__.__len__,      [],                 14]
    - [br_cls_eq,       BufferedReader.__class__.__name__.__eq__, ["type"],           true]

# ---------------------------------------------------------------------------
