    - [br_base0_eq,   "BufferedReader.__bases__[0].__name__.__eq__", ["_BufferedIOBase"], true]
    - [br_mro_len,    "BufferedReader.__mro__.__len__",            [],                  4]
    - [br_mro0_eq,    "BufferedReader.__mro__[0].__name__.__eq__", ["BufferedReader"],  true]
    - [br_mro1_eq,    "BufferedReader.__mro__[1].__name__.__eq__", ["_BufferedIOBase"], true]
    - [br_mro2_eq,    "BufferedReader.__mro__[2].__name__.__eq__", ["_IOBase"],         true]
