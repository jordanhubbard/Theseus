spec: concurrent_futures_extra242
version: ">=3.2"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — Python concurrent.futures documentation"
    - "https://docs.python.org/3/library/concurrent.futures.html#concurrent.futures.Future — Future class"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py (internal implementation)"
  notes:
    - "This spec covers concurrent.futures.Future exception-related method contracts."
    - "Future.set_result.__module__ == 'concurrent.futures._base' (len=24) — defined in _base.py."
    - "Future.set_exception.__module__ == 'concurrent.futures._base' (len=24) — defined in _base.py."
    - "Future.add_done_callback.__module__ == 'concurrent.futures._base' (len=24) — defined in _base.py."
    - "Future.set_result.__qualname__ == 'Future.set_result' (len=17)."
    - "Future.set_exception.__qualname__ == 'Future.set_exception' (len=20)."
    - "Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24)."
    - "All three methods have __class__.__name__ == 'function' — unbound Python methods."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Future.set_result and Future.set_exception name/qualname identity
#
# Future.set_result.__name__ == 'set_result' (len=10)
# Future.set_result.__qualname__ == 'Future.set_result' (len=17)
# Future.set_exception.__name__ == 'set_exception' (len=13)
# Future.set_exception.__qualname__ == 'Future.set_exception' (len=20)
# ---------------------------------------------------------------------------

table concurrent_futures_extra242.set_methods_identity:
  description: "Future.set_result and Future.set_exception name and qualname identity — set_result.__name__.__eq__('set_result')==True (len=10); set_result.__qualname__.__eq__('Future.set_result')==True (len=17, prefixed with class name); set_exception.__name__.__eq__('set_exception')==True (len=13); set_exception.__qualname__.__eq__('Future.set_exception')==True (len=20); both methods share __module__ == 'concurrent.futures._base' (len=24); both have __class__.__name__ == 'function' (unbound Python methods accessed via class); verified with Python 3.14.3"
  kind: python_call_eq
  category: set_methods_identity
  id_prefix: cf242futm

  columns: [id, function, args, expected, description]
  rows:
    - [sr_name_eq,   Future.set_result.__name__.__eq__,      ["set_result"],         true, "Future.set_result.__name__ == 'set_result'; verified with Python 3.14.3"]
    - [sr_name_len,  Future.set_result.__name__.__len__,     [],                     10,   "Future.set_result.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [sr_qname_eq,  Future.set_result.__qualname__.__eq__,  ["Future.set_result"],  true, "Future.set_result.__qualname__ == 'Future.set_result'; verified with Python 3.14.3"]
    - [sr_qname_len, Future.set_result.__qualname__.__len__, [],                     17,   "Future.set_result.__qualname__.__len__() == 17; verified with Python 3.14.3"]
    - [se_name_eq,   Future.set_exception.__name__.__eq__,      ["set_exception"],         true, "Future.set_exception.__name__ == 'set_exception'; verified with Python 3.14.3"]
    - [se_name_len,  Future.set_exception.__name__.__len__,     [],                        13,   "Future.set_exception.__name__.__len__() == 13; verified with Python 3.14.3"]
    - [se_qname_eq,  Future.set_exception.__qualname__.__eq__,  ["Future.set_exception"],  true, "Future.set_exception.__qualname__ == 'Future.set_exception'; verified with Python 3.14.3"]
    - [se_qname_len, Future.set_exception.__qualname__.__len__, [],                        20,   "Future.set_exception.__qualname__.__len__() == 20; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Future.add_done_callback name/qualname identity and module checks
#
# Future.add_done_callback.__name__ == 'add_done_callback' (len=17)
# Future.add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24)
# Future.add_done_callback.__module__ == 'concurrent.futures._base' (len=24)
# ---------------------------------------------------------------------------

table concurrent_futures_extra242.add_done_callback_identity:
  description: "Future.add_done_callback name, qualname, and module identity — add_done_callback.__name__.__eq__('add_done_callback')==True (len=17); add_done_callback.__qualname__.__eq__('Future.add_done_callback')==True (len=24); notably add_done_callback.__qualname__.__len__()==24 equals __module__.__len__()==24 ('concurrent.futures._base' is 24 chars); add_done_callback.__module__.__eq__('concurrent.futures._base')==True; add_done_callback.__class__.__name__.__eq__('function')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: add_done_callback_identity
  id_prefix: cf242futm

  columns: [id, function, args, expected, description]
  rows:
    - [adc_name_eq,   Future.add_done_callback.__name__.__eq__,      ["add_done_callback"],         true, "Future.add_done_callback.__name__ == 'add_done_callback'; verified with Python 3.14.3"]
    - [adc_name_len,  Future.add_done_callback.__name__.__len__,     [],                            17,   "Future.add_done_callback.__name__.__len__() == 17; verified with Python 3.14.3"]
    - [adc_qname_eq,  Future.add_done_callback.__qualname__.__eq__,  ["Future.add_done_callback"],  true, "Future.add_done_callback.__qualname__ == 'Future.add_done_callback'; verified with Python 3.14.3"]
    - [adc_qname_len, Future.add_done_callback.__qualname__.__len__, [],                            24,   "Future.add_done_callback.__qualname__.__len__() == 24; verified with Python 3.14.3"]
    - [adc_mod_eq,    Future.add_done_callback.__module__.__eq__,    ["concurrent.futures._base"],  true, "Future.add_done_callback.__module__ == 'concurrent.futures._base'; verified with Python 3.14.3"]
    - [adc_mod_len,   Future.add_done_callback.__module__.__len__,   [],                            24,   "Future.add_done_callback.__module__.__len__() == 24; verified with Python 3.14.3"]
    - [adc_cls_nm,    Future.add_done_callback.__class__.__name__.__eq__, ["function"],             true, "Future.add_done_callback.__class__.__name__ == 'function'; verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — concurrent_futures_extra242
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra242.set_result_qualname:
  description: "Future.set_result.__qualname__.__eq__('Future.set_result') returns True — the qualname includes the class prefix 'Future.' because set_result is a method defined inside the Future class body; __qualname__ == 'Future.set_result' (len=17 = len('Future.')+len('set_result') = 7+10); compare add_done_callback.__qualname__ == 'Future.add_done_callback' (len=24); set_result.__name__ is 'set_result' (len=10); NEW in extra242: first standalone set_result qualname invariant in cf242futm namespace; verified with Python 3.14.3"
  category: set_methods_identity
  kind: python_call_eq
  function: Future.set_result.__qualname__.__eq__
  args: ["Future.set_result"]
  expected: true

invariant concurrent_futures_extra242.set_exception_qualname:
  description: "Future.set_exception.__qualname__.__eq__('Future.set_exception') returns True — the qualname includes the class prefix 'Future.' because set_exception is a method defined inside the Future class body; __qualname__ == 'Future.set_exception' (len=20 = len('Future.')+len('set_exception') = 7+13); compare set_result.__qualname__.__len__()==17; set_exception.__name__ is 'set_exception' (len=13); NEW in extra242: first standalone set_exception qualname invariant in cf242futm namespace; verified with Python 3.14.3"
  category: set_methods_identity
  kind: python_call_eq
  function: Future.set_exception.__qualname__.__eq__
  args: ["Future.set_exception"]
  expected: true

invariant concurrent_futures_extra242.add_done_callback_qualname:
  description: "Future.add_done_callback.__qualname__.__eq__('Future.add_done_callback') returns True — qualname includes class prefix 'Future.' (len=7) plus method name 'add_done_callback' (len=17) = total 24; notably __qualname__.__len__()==24 equals __module__.__len__()==24 ('concurrent.futures._base'); __name__ is 'add_done_callback' (len=17); NEW in extra242: first standalone add_done_callback qualname invariant in cf242futm namespace; verified with Python 3.14.3"
  category: add_done_callback_identity
  kind: python_call_eq
  function: Future.add_done_callback.__qualname__.__eq__
  args: ["Future.add_done_callback"]
  expected: true

invariant concurrent_futures_extra242.set_result_module:
  description: "Future.set_result.__module__.__eq__('concurrent.futures._base') returns True — set_result is defined in Lib/concurrent/futures/_base.py; __module__ == 'concurrent.futures._base' (len=24); all three methods (set_result, set_exception, add_done_callback) share this module; set_result.__qualname__ == 'Future.set_result' (len=17); set_result.__name__ == 'set_result' (len=10); NEW in extra242: first standalone set_result module invariant; verified with Python 3.14.3"
  category: set_methods_identity
  kind: python_call_eq
  function: Future.set_result.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra242.set_exception_module:
  description: "Future.set_exception.__module__.__eq__('concurrent.futures._base') returns True — set_exception is defined in Lib/concurrent/futures/_base.py; __module__ == 'concurrent.futures._base' (len=24); same module as set_result and add_done_callback; set_exception.__qualname__ == 'Future.set_exception' (len=20); set_exception.__name__ == 'set_exception' (len=13); NEW in extra242: first standalone set_exception module invariant; verified with Python 3.14.3"
  category: set_methods_identity
  kind: python_call_eq
  function: Future.set_exception.__module__.__eq__
  args: ["concurrent.futures._base"]
  expected: true

invariant concurrent_futures_extra242.add_done_callback_module_len_24:
  description: "Future.add_done_callback.__module__.__len__() == 24 — 'concurrent.futures._base' has 24 characters: 'concurrent'=10 + '.'=1 + 'futures'=7 + '.'=1 + '_base'=5 = 24; coincidentally equals add_done_callback.__qualname__.__len__()==24 ('Future.add_done_callback'); set_result.__module__.__len__()==24 and set_exception.__module__.__len__()==24 are the same; NEW in extra242: first standalone add_done_callback module length invariant; verified with Python 3.14.3"
  category: add_done_callback_identity
  kind: python_call_eq
  function: Future.add_done_callback.__module__.__len__
  args: []
  expected: 24

invariant concurrent_futures_extra242.set_result_class_is_function:
  description: "Future.set_result.__class__.__name__.__eq__('function') returns True — when accessed via the class (not an instance), unbound Python methods have __class__.__name__ == 'function'; set_result is a regular Python function stored as a class attribute; set_result.__name__ == 'set_result' (len=10); set_result.__qualname__ == 'Future.set_result' (len=17); set_result.__module__ == 'concurrent.futures._base' (len=24); NEW in extra242: first standalone set_result class invariant; verified with Python 3.14.3"
  category: set_methods_identity
  kind: python_call_eq
  function: Future.set_result.__class__.__name__.__eq__
  args: ["function"]
  expected: true
