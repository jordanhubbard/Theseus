spec: struct_extra110
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
    - "struct_extra109.zspec.zsdl — covers Struct method_descriptor __objclass__.__name__ equality / module-level function __name__ equality (pack/unpack/calcsize/pack_into) / Struct class __module__/__qualname__ equality (table + invariants)."
    - "struct_extra108.zspec.zsdl — covers module-level function __name__ lengths / struct.error __name__/__module__/__qualname__ equality and lengths / struct.Struct.__name__ equality / struct.error MRO structure (table + invariants)."
    - "struct_extra107.zspec.zsdl — covers Struct.size/format getset_descriptor qualname equality and __objclass__.__name__ / module-level calcsize/pack/unpack qualname equality / Struct.__doc__ type (table + invariants)."
    - "struct_extra106.zspec.zsdl — covers Struct.pack/unpack/pack_into/unpack_from/iter_unpack qualname equality / Struct.__init__ qualname and wrapper_descriptor type / all five methods are method_descriptor (table + invariants)."
    - "struct_extra105.zspec.zsdl — covers struct.__spec__ attributes / struct.__name__ and __package__ equality and lengths / struct.error __init__/__str__ qualnames (table + invariants)."
    - "struct_extra104.zspec.zsdl — covers Struct.size/format getset_descriptor qualnames and __objclass__ / module-level function qualname equality for all six functions (table + invariants)."
    - "struct_extra100.zspec.zsdl — covers Struct instance method qualname lengths / module-level function qualname lengths / Struct class-level method_descriptor type names (table + invariants)."
    - "struct_extra99.zspec.zsdl — covers module-level function __doc__ lengths / Struct.size/__format__ __doc__ equality (table + invariants)."
    - "struct_extra95.zspec.zsdl — covers Struct.__qualname__.__len__()==6 / module-level function __module__.__eq__('_struct') (table + invariants)."
  notes:
    - "This spec extends struct through struct_extra109; it does NOT duplicate invariants present in those files."
    - "Wave 274 theme: struct module-level function __module__ equality for iter_unpack and unpack_from (not yet individually anchored as __eq__ calls) / module-level function type identity as builtin_function_or_method / iter_unpack and unpack_from __name__ equality / struct.error __qualname__ and module / struct.Struct instance method __name__ equality."
    - "struct.iter_unpack.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__module__ == '_struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__name__ == 'iter_unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__name__ == 'unpack_from'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.iter_unpack.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.unpack_from.__class__.__name__ == 'builtin_function_or_method'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('I').pack.__name__ == 'pack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.Struct('I').unpack.__name__ == 'unpack'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__qualname__ == 'error'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "struct.error.__module__ == 'struct'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: struct_extra109 anchors pack/unpack/calcsize/pack_into __name__ equality via __eq__ calls; struct_extra95 anchors all six module-level functions __module__=='_struct'. This spec anchors iter_unpack and unpack_from __name__ equality and module equality as new individual __eq__ call anchors, plus the module-level function type identity as builtin_function_or_method for the first time."
    - "Note: All six struct module-level functions (pack, unpack, calcsize, pack_into, unpack_from, iter_unpack) are builtin_function_or_method — they are C-level functions from _struct.c exposed via the struct Python wrapper module. This type identity was implied by __module__=='_struct' but never explicitly anchored as a type identity table."
    - "Note: struct.Struct instance methods (pack, unpack, pack_into, unpack_from, iter_unpack) are builtin_function_or_method at the instance level (bound C methods). Their __name__ attributes match the method name without any class prefix: Struct('I').pack.__name__ == 'pack', Struct('I').unpack.__name__ == 'unpack'. struct_extra109 anchors pack/unpack __name__ at the module level; this spec anchors the Struct instance method __name__ values."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.iter_unpack.__module__.__eq__('_struct')
# struct.unpack_from.__module__.__eq__('_struct')
# struct.iter_unpack.__name__.__eq__('iter_unpack')
# struct.unpack_from.__name__.__eq__('unpack_from')
# struct.iter_unpack.__name__.__len__() == 11
#
# Wave 274 theme: iter_unpack and unpack_from __module__ and __name__ equality.
#
# struct_extra109 anchors pack/unpack/calcsize/pack_into __name__ equality.
# struct_extra95 anchors all six module-level functions __module__=='_struct'
# (in a table). This spec anchors iter_unpack and unpack_from __name__ equality
# and __module__ equality as new individual __eq__ call anchors for the first time.
# iter_unpack.__name__ == 'iter_unpack' (11 chars); unpack_from.__name__ == 'unpack_from' (11 chars).
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra110.iter_unpack_unpack_from_name_and_module:
  description: "iter_unpack.__module__.__eq__('_struct')==True / unpack_from.__module__.__eq__('_struct')==True / iter_unpack.__name__.__eq__('iter_unpack')==True / unpack_from.__name__.__eq__('unpack_from')==True / iter_unpack.__name__.__len__()==11 — iter_unpack and unpack_from both have __module__=='_struct' and 11-char __name__ values; extra95 anchors all six module functions __module__ in a table; extra109 anchors pack/unpack/calcsize/pack_into __name__ equality; first structfn110 anchor for iter_unpack/unpack_from __name__ and standalone __module__ equality"
  kind: python_call_eq
  category: function_identity
  id_prefix: structfn110

  columns: [id, function, args, expected, description]
  rows:
    - [iter_unpack_module_eq,   "iter_unpack.__module__.__eq__",   ["_struct"],     true, "struct.iter_unpack.__module__ is '_struct' (C extension; same module as all other struct module-level functions)"]
    - [unpack_from_module_eq,   "unpack_from.__module__.__eq__",   ["_struct"],     true, "struct.unpack_from.__module__ is '_struct' (C extension; '_struct' prefix distinguishes from Python 'struct' wrapper)"]
    - [iter_unpack_name_eq,     "iter_unpack.__name__.__eq__",     ["iter_unpack"], true, "struct.iter_unpack.__name__ is 'iter_unpack' (11 chars; returns iterator over packed data; no class prefix for module-level C function)"]
    - [unpack_from_name_eq,     "unpack_from.__name__.__eq__",     ["unpack_from"], true, "struct.unpack_from.__name__ is 'unpack_from' (11 chars; reads packed bytes from buffer at offset; same length as iter_unpack)"]
    - [iter_unpack_name_len,    "iter_unpack.__name__.__len__",    [],              11,   "struct.iter_unpack.__name__.__len__() is 11 (tied with unpack_from; both 11 chars; longest module-level struct function names)"]

# ---------------------------------------------------------------------------
# struct.pack.__class__.__name__.__eq__('builtin_function_or_method')
# struct.unpack.__class__.__name__.__eq__('builtin_function_or_method')
# struct.calcsize.__class__.__name__.__eq__('builtin_function_or_method')
# struct.iter_unpack.__class__.__name__.__eq__('builtin_function_or_method')
# struct.unpack_from.__class__.__name__.__eq__('builtin_function_or_method')
#
# Wave 274 theme: module-level struct function type identity as builtin_function_or_method.
#
# All six struct module-level functions are C-level builtin_function_or_method
# objects from _struct.c. This type identity was implied by __module__=='_struct'
# but never explicitly anchored as a type identity table. No prior struct spec
# anchors the type identity for module-level struct functions as a grouped table.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra110.module_function_type_identity:
  description: "pack.__class__.__name__.__eq__('builtin_function_or_method')==True / unpack.__class__.__name__.__eq__('builtin_function_or_method')==True / calcsize.__class__.__name__.__eq__('builtin_function_or_method')==True / iter_unpack.__class__.__name__.__eq__('builtin_function_or_method')==True / unpack_from.__class__.__name__.__eq__('builtin_function_or_method')==True — all six module-level struct functions are C-level builtin_function_or_method from _struct.c; type identity was implied by __module__=='_struct' but never anchored as table; first structfn110 anchor for module function type identity"
  kind: python_call_eq
  category: type_identity
  id_prefix: structfn110

  columns: [id, function, args, expected, description]
  rows:
    - [pack_type_eq,        "pack.__class__.__name__.__eq__",        ["builtin_function_or_method"], true, "struct.pack is a C-level builtin_function_or_method (from _struct.c; packs values into bytes per format string)"]
    - [unpack_type_eq,      "unpack.__class__.__name__.__eq__",      ["builtin_function_or_method"], true, "struct.unpack is a C-level builtin_function_or_method (from _struct.c; unpacks bytes into Python values)"]
    - [calcsize_type_eq,    "calcsize.__class__.__name__.__eq__",    ["builtin_function_or_method"], true, "struct.calcsize is a C-level builtin_function_or_method (from _struct.c; returns byte count for format)"]
    - [iter_unpack_type_eq, "iter_unpack.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "struct.iter_unpack is a C-level builtin_function_or_method (from _struct.c; returns iterator over packed records)"]
    - [unpack_from_type_eq, "unpack_from.__class__.__name__.__eq__", ["builtin_function_or_method"], true, "struct.unpack_from is a C-level builtin_function_or_method (from _struct.c; reads from buffer at optional offset)"]

# ---------------------------------------------------------------------------
# struct.Struct('I').pack.__name__.__eq__('pack')
# struct.Struct('I').unpack.__name__.__eq__('unpack')
# struct.error.__qualname__.__eq__('error')
# struct.error.__module__.__eq__('struct')
# struct.unpack_from.__name__.__len__() == 11
#
# Wave 274 theme: Struct instance method __name__ equality and error class identity.
#
# When a Struct method_descriptor is bound to a Struct instance (via descriptor
# protocol), the resulting builtin_function_or_method has __name__ equal to the
# bare method name: Struct('I').pack.__name__ == 'pack', Struct('I').unpack.__name__
# == 'unpack'. struct_extra109 anchors module-level function __name__ equality;
# this spec anchors Struct instance method __name__ values for the first time.
# struct.error.__qualname__ == 'error' and __module__ == 'struct' (the Python
# wrapper, not _struct). Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table struct_extra110.Struct_instance_method_names_and_error_identity:
  description: "Struct('I').pack.__name__.__eq__('pack')==True / Struct('I').unpack.__name__.__eq__('unpack')==True / error.__qualname__.__eq__('error')==True / error.__module__.__eq__('struct')==True / unpack_from.__name__.__len__()==11 — Struct instance bound methods have bare __name__ (no class prefix; 'pack' not 'Struct.pack'); struct.error __qualname__=='error' and __module__=='struct' (Python wrapper, not _struct C extension); extra109 anchors module-level function __name__; first structfn110 anchor for instance method __name__ and error identity"
  kind: python_call_eq
  category: function_identity
  id_prefix: structfn110

  columns: [id, function, args, expected, description]
  rows:
    - [instance_pack_name_eq,   "Struct('I').pack.__name__.__eq__",   ["pack"],    true, "struct.Struct('I').pack.__name__ is 'pack' (bare method name; no class prefix at instance level; bound builtin_function_or_method)"]
    - [instance_unpack_name_eq, "Struct('I').unpack.__name__.__eq__", ["unpack"],  true, "struct.Struct('I').unpack.__name__ is 'unpack' (bare method name; same pattern as pack; all Struct instance methods have bare __name__)"]
    - [error_qualname_eq,       "error.__qualname__.__eq__",          ["error"],   true, "struct.error.__qualname__ is 'error' (5 chars; top-level class; __qualname__==__name__ for non-nested class)"]
    - [error_module_eq,         "error.__module__.__eq__",            ["struct"],  true, "struct.error.__module__ is 'struct' (Python wrapper module; not '_struct'; error is defined in Lib/struct.py not _struct.c)"]
    - [unpack_from_name_len,    "unpack_from.__name__.__len__",       [],          11,   "struct.unpack_from.__name__.__len__() is 11 (tied with iter_unpack; both 11 chars; longest module-level struct function names)"]

# ---------------------------------------------------------------------------
# struct.iter_unpack.__module__.__eq__('_struct') — standalone
#
# struct.iter_unpack.__module__ is '_struct'. iter_unpack is a C-level function
# from the _struct C extension (Modules/_struct.c). It takes a format string and
# a buffer and returns an iterator that yields successive tuples of values
# unpacked from the buffer. struct_extra95 anchors all six module-level function
# __module__ values in a table; no prior struct spec anchors iter_unpack.__module__
# as a standalone under structfn110. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra110.iter_unpack_module_eq:
  description: "struct.iter_unpack.__module__.__eq__('_struct') == True — __module__ is '_struct' (C extension; 7 chars; leading underscore is CPython convention for private C extension); iter_unpack returns iterator over packed records; extra95 anchors all six function __module__ in table; first standalone for iter_unpack __module__ under structfn110"
  category: function_identity
  kind: python_call_eq
  function: "iter_unpack.__module__.__eq__"
  args: ["_struct"]
  expected: true

# ---------------------------------------------------------------------------
# struct.iter_unpack.__name__.__eq__('iter_unpack') — standalone
#
# struct.iter_unpack.__name__ is 'iter_unpack' (11 chars). For C-level module
# functions, __name__ equals __qualname__ (no class prefix). iter_unpack is the
# longest-named module-level struct function (tied with unpack_from at 11 chars).
# struct_extra109 anchors pack/unpack/calcsize/pack_into __name__ equality;
# struct_extra108 anchors all six function __name__ lengths. No prior spec anchors
# iter_unpack __name__ equality as a standalone under structfn110.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra110.iter_unpack_name_eq:
  description: "struct.iter_unpack.__name__.__eq__('iter_unpack') == True — __name__ is 'iter_unpack' (11 chars; tied with unpack_from for longest; 'iter_'=5 + 'unpack'=6); __name__==__qualname__ for C-level module function; extra109 anchors pack/unpack/calcsize/pack_into __name__; extra108 anchors all __name__ lengths; first standalone for iter_unpack __name__ equality under structfn110"
  category: function_identity
  kind: python_call_eq
  function: "iter_unpack.__name__.__eq__"
  args: ["iter_unpack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.pack.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# struct.pack.__class__.__name__ is 'builtin_function_or_method'. All six
# module-level struct functions (pack, unpack, calcsize, pack_into, unpack_from,
# iter_unpack) are C-level builtin_function_or_method objects from _struct.c.
# This type name indicates they are C-level callable objects (either C functions
# or C bound methods). No prior struct spec anchors the module-level function
# type identity as a standalone under structfn110.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra110.pack_type_builtin:
  description: "struct.pack.__class__.__name__.__eq__('builtin_function_or_method') == True — struct.pack is a C-level builtin_function_or_method (from _struct.c; same type as all other module-level struct functions); 'builtin_function_or_method' is the type for C-level callables in CPython; no prior spec anchors this type as standalone; first standalone under structfn110"
  category: type_identity
  kind: python_call_eq
  function: "pack.__class__.__name__.__eq__"
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# struct.Struct('I').pack.__name__.__eq__('pack') — standalone
#
# struct.Struct('I').pack.__name__ is 'pack'. When a Struct method_descriptor
# is accessed on a Struct instance, the descriptor protocol produces a
# builtin_function_or_method (a bound C method). The bound method's __name__
# is the bare method name 'pack' (4 chars) — without any 'Struct.' prefix.
# This is analogous to how hashlib.sha256().update.__name__ == 'update' (from
# hashlib_extra116). struct_extra109 anchors module-level pack.__name__=='pack';
# this spec anchors the Struct instance method __name__ as a standalone.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra110.instance_pack_name_eq:
  description: "struct.Struct('I').pack.__name__.__eq__('pack') == True — instance method __name__ is bare 'pack' (4 chars; no 'Struct.' prefix; bound builtin_function_or_method); parallels hashlib.sha256().update.__name__=='update' (extra116); extra109 anchors module-level pack.__name__=='pack'; first standalone for Struct instance method __name__ under structfn110"
  category: function_identity
  kind: python_call_eq
  function: "Struct('I').pack.__name__.__eq__"
  args: ["pack"]
  expected: true

# ---------------------------------------------------------------------------
# struct.error.__qualname__.__eq__('error') — standalone
#
# struct.error.__qualname__ is 'error' (5 chars). struct.error is the exception
# class raised when packing/unpacking fails (e.g., format string is invalid or
# buffer is too short). It is defined in Lib/struct.py as a subclass of Exception.
# As a top-level class (not nested), __qualname__ == __name__ == 'error'. Its
# __module__ is 'struct' (the Python wrapper), not '_struct'. struct_extra108
# anchors struct.error __name__ and __module__ in a table; this spec anchors
# struct.error __qualname__ as a standalone for the first time under structfn110.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant struct_extra110.error_qualname_eq:
  description: "struct.error.__qualname__.__eq__('error') == True — __qualname__ is 'error' (5 chars; same as __name__; top-level class in Lib/struct.py; no nesting); __module__=='struct' (Python wrapper, not '_struct' C extension); extra108 anchors error __name__ and __module__; first standalone for error __qualname__ under structfn110"
  category: class_identity
  kind: python_call_eq
  function: "error.__qualname__.__eq__"
  args: ["error"]
  expected: true

