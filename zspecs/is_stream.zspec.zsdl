spec: is_stream
version: ">=4.0.0"
backend: node(is-stream)
esm: true

docs: https://github.com/sindresorhus/is-stream#readme

provenance:
  derived_from:
    - "is-stream README — https://github.com/sindresorhus/is-stream#readme"
    - "Node.js Streams docs — https://nodejs.org/api/stream.html"
    - "Test vectors verified with is-stream via Node.js 22 on macOS Darwin 25.4.0, 2026-04-26"
  not_derived_from:
    - "is-stream source"
  notes:
    - "Predicates for detecting Node streams — Readable / Writable / Duplex / Transform."
    - "Install: npm install is-stream"
    - "v4 ESM only; named exports isStream, isReadableStream, isWritableStream, isDuplexStream, isTransformStream."
    - "Spec tests shape only; constructing real streams via JSON entry_args is not possible."
  created_at: "2026-04-26T00:00:00Z"

error_model:
  semantics: "Pure functions; never throw on any input."
  stderr: "null"
  stickiness: "N/A — each call independent."
  codes: {}

invariant is_stream.has_isStream:
  description: "isStream() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "isStream.constructor.name"}
  expected: "Function"

invariant is_stream.has_isReadableStream:
  description: "isReadableStream() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "isReadableStream.constructor.name"}
  expected: "Function"

invariant is_stream.has_isWritableStream:
  description: "isWritableStream() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "isWritableStream.constructor.name"}
  expected: "Function"

invariant is_stream.has_isDuplexStream:
  description: "isDuplexStream() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "isDuplexStream.constructor.name"}
  expected: "Function"

invariant is_stream.has_isTransformStream:
  description: "isTransformStream() exposed"
  category: shape
  kind: node_chain_eq
  entry: bare
  chain:
    - {get: "isTransformStream.constructor.name"}
  expected: "Function"

invariant is_stream.isStream_plain_object_false:
  description: "isStream({}) returns false"
  category: detect
  kind: node_chain_eq
  entry: named
  function: isStream
  entry_args: [{}]
  chain: []
  expected: false

invariant is_stream.isStream_null_false:
  description: "isStream(null) returns false"
  category: edge
  kind: node_chain_eq
  entry: named
  function: isStream
  entry_args: [null]
  chain: []
  expected: false

invariant is_stream.isStream_string_false:
  description: "isStream('stream') returns false"
  category: edge
  kind: node_chain_eq
  entry: named
  function: isStream
  entry_args: ["stream"]
  chain: []
  expected: false
