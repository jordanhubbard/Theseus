spec: decimal_extra255
version: ">=3.9"
backend: python_module(decimal)

docs: https://docs.python.org/3/library/decimal.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — decimal module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
    - "decimal.zspec.zsdl — covers str_repr, predicates, as_tuple, class_name, context, error cases"
    - "decimal_extra.zspec.zsdl — covers predicates, eng_string, Context/BasicContext/ExtendedContext, rounding modes"
  notes:
    - "Decimal comparison dunder methods (__lt__, __le__, __gt__, __ge__, __eq__, __ne__) are wrapper_descriptors."
    - "Decimal.__lt__.__name__ == '__lt__', __qualname__ == 'Decimal.__lt__'."
    - "All six comparison methods share __class__.__name__ == 'wrapper_descriptor'."
    - "Decimal.__hash__.__qualname__ == 'Decimal.__hash__' and __class__.__name__ == 'wrapper_descriptor'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Decimal comparison methods — __name__ and __qualname__
# ---------------------------------------------------------------------------

table decimal_extra255.Decimal.comparison_names:
  description: "Decimal comparison dunder methods report correct __name__ attributes"
  kind: python_call_eq
  category: method_identity
  id_prefix: name

  columns: [id, function, args, expected]
  rows:
    - [lt_name, Decimal.__lt__.__name__.__eq__, ["__lt__"], true]
    - [le_name, Decimal.__le__.__name__.__eq__, ["__le__"], true]
    - [gt_name, Decimal.__gt__.__name__.__eq__, ["__gt__"], true]
    - [ge_name, Decimal.__ge__.__name__.__eq__, ["__ge__"], true]
    - [eq_name, Decimal.__eq__.__name__.__eq__, ["__eq__"], true]
    - [ne_name, Decimal.__ne__.__name__.__eq__, ["__ne__"], true]

table decimal_extra255.Decimal.comparison_qualnames:
  description: "Decimal comparison dunder methods report correct __qualname__ attributes"
  kind: python_call_eq
  category: method_identity
  id_prefix: qualname

  columns: [id, function, args, expected]
  rows:
    - [lt_qualname, Decimal.__lt__.__qualname__.__eq__, ["Decimal.__lt__"], true]
    - [le_qualname, Decimal.__le__.__qualname__.__eq__, ["Decimal.__le__"], true]
    - [gt_qualname, Decimal.__gt__.__qualname__.__eq__, ["Decimal.__gt__"], true]
    - [ge_qualname, Decimal.__ge__.__qualname__.__eq__, ["Decimal.__ge__"], true]
    - [eq_qualname, Decimal.__eq__.__qualname__.__eq__, ["Decimal.__eq__"], true]
    - [ne_qualname, Decimal.__ne__.__qualname__.__eq__, ["Decimal.__ne__"], true]

# ---------------------------------------------------------------------------
# Decimal comparison methods — descriptor type
# All six are wrapper_descriptors (C-implemented slot wrappers)
# ---------------------------------------------------------------------------

invariant decimal_extra255.Decimal.lt.class_name:
  description: "Decimal.__lt__.__class__.__name__ == 'wrapper_descriptor'"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__lt__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true

# ---------------------------------------------------------------------------
# Decimal.__hash__ — qualname and descriptor type
# ---------------------------------------------------------------------------

invariant decimal_extra255.Decimal.hash.qualname:
  description: "Decimal.__hash__.__qualname__ == 'Decimal.__hash__'"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__hash__.__qualname__.__eq__
  args: ["Decimal.__hash__"]
  expected: true

invariant decimal_extra255.Decimal.hash.class_name:
  description: "Decimal.__hash__.__class__.__name__ == 'wrapper_descriptor'"
  category: method_identity
  kind: python_call_eq
  function: Decimal.__hash__.__class__.__name__.__eq__
  args: ["wrapper_descriptor"]
  expected: true
