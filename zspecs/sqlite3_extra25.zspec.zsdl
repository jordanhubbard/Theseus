spec: sqlite3_extra25
version: ">=3.9"
backend: python_module(sqlite3)

docs: https://docs.python.org/3/library/sqlite3.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/sqlite3.html — Python sqlite3 module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/sqlite3/__init__.py"
    - "CPython source: Modules/_sqlite/module.c"
    - "CPython source: Modules/_sqlite/connection.c"
    - "CPython source: Modules/_sqlite/cursor.c"
    - "sqlite3_extra24.zspec.zsdl — covers Connection/Cursor/Row __module__.__len__() and __name__.__len__(); Error/DatabaseError/OperationalError __module__.__len__() and __name__.__len__(); connect.__module__.__len__()."
  notes:
    - "This spec extends sqlite3_extra24.zspec.zsdl."
    - "Prior specs covered: Connection/Cursor/Row __name__/__module__/__qualname__, Error/DatabaseError/OperationalError/IntegrityError/InterfaceError/DataError/NotSupportedError/ProgrammingError/InternalError/Warning __name__/__module__ and bases, connect/__name__/__module__, sqlite3.sqlite_version type, Connection/__init__.__name__, Cursor/__init__.__name__, Connection/Cursor/Row __module__.__len__()/__name__.__len__(), Error/DatabaseError/OperationalError __module__.__len__()/__name__.__len__(), connect.__module__.__len__()."
    - "This spec covers: sqlite3.IntegrityError.__name__.__len__(); sqlite3.OperationalError.__name__.__len__(); sqlite3.InterfaceError.__name__.__len__(); sqlite3.ProgrammingError.__name__.__len__(); sqlite3.NotSupportedError.__name__.__len__(); sqlite3.Warning.__name__.__len__(); sqlite3.connect.__qualname__.__len__(); sqlite3.Row.__qualname__.__len__(); sqlite3.Connection.__qualname__.__len__(); sqlite3.Cursor.__qualname__.__len__()."
    - "sqlite3.IntegrityError.__name__ == 'IntegrityError' — length 14. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.OperationalError.__name__ == 'OperationalError' — length 16. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.InterfaceError.__name__ == 'InterfaceError' — length 14. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.ProgrammingError.__name__ == 'ProgrammingError' — length 16. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.NotSupportedError.__name__ == 'NotSupportedError' — length 17. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Warning.__name__ == 'Warning' — length 7. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.connect.__qualname__ == 'connect' — length 7; C-extension function qualname equals name. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Row.__qualname__ == 'Row' — length 3. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Connection.__qualname__ == 'Connection' — length 10. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "sqlite3.Cursor.__qualname__ == 'Cursor' — length 6. Verified Python 3.12 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# sqlite3 exception __name__.__len__() — longer exception class names
#
# sqlite3_extra24 covers Error.__name__.__len__()==5 and
# DatabaseError.__name__.__len__()==13. No prior spec checks __name__.__len__()
# for IntegrityError, OperationalError, InterfaceError, ProgrammingError,
# NotSupportedError, or Warning.
# ---------------------------------------------------------------------------

invariant sqlite3_extra25.IntegrityError.name_len:
  description: "len(sqlite3.IntegrityError.__name__) == 14 — 'IntegrityError' has 14 characters"
  category: class_identity
  kind: python_call_eq
  function: IntegrityError.__name__.__len__
  args: []
  expected: 14

invariant sqlite3_extra25.OperationalError.name_len:
  description: "len(sqlite3.OperationalError.__name__) == 16 — 'OperationalError' has 16 characters"
  category: class_identity
  kind: python_call_eq
  function: OperationalError.__name__.__len__
  args: []
  expected: 16

# ---------------------------------------------------------------------------
# sqlite3 exception __name__.__len__() table — InterfaceError/ProgrammingError/
# NotSupportedError/Warning
#
# No prior spec checks __name__.__len__() for these exception classes.
# ---------------------------------------------------------------------------

table sqlite3_extra25.exception_name_lengths:
  description: "sqlite3 exception __name__.__len__() — InterfaceError/ProgrammingError/NotSupportedError/Warning"
  kind: python_call_eq
  category: class_identity
  id_prefix: senl25

  columns: [id, function, args, expected, description]
  rows:
    - [InterfaceError,
       InterfaceError.__name__.__len__,
       [],
       14,
       "len('InterfaceError') == 14"]
    - [ProgrammingError,
       ProgrammingError.__name__.__len__,
       [],
       16,
       "len('ProgrammingError') == 16"]
    - [NotSupportedError,
       NotSupportedError.__name__.__len__,
       [],
       17,
       "len('NotSupportedError') == 17"]
    - [Warning,
       Warning.__name__.__len__,
       [],
       7,
       "len('Warning') == 7"]

# ---------------------------------------------------------------------------
# sqlite3.connect.__qualname__.__len__()
#
# No prior spec checks connect.__qualname__ length.
# connect.__qualname__ == 'connect' (len 7); for C-extension builtin functions
# __qualname__ equals __name__. Verified Python 3.12 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant sqlite3_extra25.connect.qualname_len:
  description: "len(sqlite3.connect.__qualname__) == 7 — 'connect' has 7 characters; C-extension __qualname__ equals __name__"
  category: function_identity
  kind: python_call_eq
  function: connect.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# sqlite3 class __qualname__.__len__() — Connection, Cursor, Row
#
# Prior specs verify __qualname__.__eq__ for Connection/Cursor/Row.
# No prior spec checks __qualname__.__len__() for any of these classes.
# Connection.__qualname__ == 'Connection' (len 10);
# Cursor.__qualname__ == 'Cursor' (len 6);
# Row.__qualname__ == 'Row' (len 3).
# ---------------------------------------------------------------------------

table sqlite3_extra25.class_qualname_lengths:
  description: "sqlite3.Connection/Cursor/Row __qualname__.__len__() — verifying lengths of top-level class qualnames"
  kind: python_call_eq
  category: class_identity
  id_prefix: scql25

  columns: [id, function, args, expected, description]
  rows:
    - [Connection,
       Connection.__qualname__.__len__,
       [],
       10,
       "len(Connection.__qualname__) == 10"]
    - [Cursor,
       Cursor.__qualname__.__len__,
       [],
       6,
       "len(Cursor.__qualname__) == 6"]
    - [Row,
       Row.__qualname__.__len__,
       [],
       3,
       "len(Row.__qualname__) == 3"]

# ---------------------------------------------------------------------------
# sqlite3.Warning.__module__.__len__()
#
# Prior specs verify various exception __module__ == 'sqlite3'. No prior spec
# checks Warning.__module__.__len__(). Warning.__module__ == 'sqlite3' (len 7).
# ---------------------------------------------------------------------------

invariant sqlite3_extra25.Warning.module_len:
  description: "len(sqlite3.Warning.__module__) == 7 — 'sqlite3' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Warning.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# sqlite3.Warning.__name__.__len__() as standalone invariant
#
# Warning.__name__ == 'Warning' (len 7). Covered in the table above;
# this standalone invariant provides additional regression anchor.
# ---------------------------------------------------------------------------

invariant sqlite3_extra25.Warning.name_len:
  description: "len(sqlite3.Warning.__name__) == 7 — 'Warning' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Warning.__name__.__len__
  args: []
  expected: 7
