# ---------------------------------------------------------------------------
# Table 1: functools.update_wrapper __code__.co_varnames[1] through [3]
#
# Wave 273 theme: functools.update_wrapper(wrapper, wrapped, assigned=...,
# updated=...) is a pure-Python function with 4 declared parameters and 2
# internal loop variables. Prior spec extra70 covered co_varnames[0]=='wrapper'.
# New here: co_varnames[1] through [3]. co_varnames[1] == 'wrapped' (7 chars)
# — the function being wrapped; its attributes are copied onto wrapper.
# co_varnames[2] == 'assigned' (8 chars) — tuple of attribute names to copy
# directly; defaults to WRAPPER_ASSIGNMENTS = ('__module__', '__name__',
# '__qualname__', '__annotations__', '__doc__', '__type_params__').
# co_varnames[3] == 'updated' (7 chars) — tuple of attribute names to update;
# defaults to WRAPPER_UPDATES = ('__dict__',). Both 'wrapped' and 'updated'
# share length 7 with co_varnames[0] 'wrapper'. 'assigned' is one char longer.
#
# update_wrapper.__code__.co_varnames[1] == 'wrapped'   (len 7)
# update_wrapper.__code__.co_varnames[2] == 'assigned'  (len 8)
# update_wrapper.__code__.co_varnames[3] == 'updated'   (len 7)
#
# New to extra127.
# ---------------------------------------------------------------------------

table functools_extra127.update_wrapper_co_varnames_1_to_3:
  description: "functools.update_wrapper co_varnames[1]='wrapped'(7), [2]='assigned'(8), [3]='updated'(7); prior extra70 covered [0]='wrapper'(7); 'assigned' is longest param; 'wrapped'/'updated'/'wrapper' all len=7; wave 273; new to extra127"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsuwcv127

  columns: [id, function, args, expected, description]
  rows:
    - [uw_cv1_eq,
       "update_wrapper.__code__.co_varnames.__getitem__",
       [1],
       "wrapped",
       "functools.update_wrapper.__code__.co_varnames[1] == 'wrapped' — the function being wrapped; its attributes (module, name, qualname, etc.) are copied onto wrapper; signature update_wrapper(wrapper, wrapped, assigned=..., updated=...); tuple.__getitem__(1) returns 'wrapped'; new to extra127"]
    - [uw_cv1_len,
       "update_wrapper.__code__.co_varnames.__getitem__(1).__len__",
       [],
       7,
       "functools.update_wrapper.__code__.co_varnames[1].__len__() == 7 — 'wrapped' has 7 chars: w-r-a-p-p-e-d; same length as co_varnames[0] 'wrapper' (7) and co_varnames[3] 'updated' (7); one less than 'assigned' (8); str.__len__() returns 7; new to extra127"]
    - [uw_cv2_eq,
       "update_wrapper.__code__.co_varnames.__getitem__",
       [2],
       "assigned",
       "functools.update_wrapper.__code__.co_varnames[2] == 'assigned' — tuple of attribute names to copy directly from wrapped to wrapper; defaults to WRAPPER_ASSIGNMENTS; tuple.__getitem__(2) returns 'assigned'; new to extra127"]
    - [uw_cv2_len,
       "update_wrapper.__code__.co_varnames.__getitem__(2).__len__",
       [],
       8,
       "functools.update_wrapper.__code__.co_varnames[2].__len__() == 8 — 'assigned' has 8 chars: a-s-s-i-g-n-e-d; the longest of the 4 declared parameter names (wrapper=7, wrapped=7, assigned=8, updated=7); str.__len__() returns 8; new to extra127"]
    - [uw_cv3_eq,
       "update_wrapper.__code__.co_varnames.__getitem__",
       [3],
       "updated",
       "functools.update_wrapper.__code__.co_varnames[3] == 'updated' — tuple of attribute names to update on wrapper from wrapped; defaults to WRAPPER_UPDATES = ('__dict__',); tuple.__getitem__(3) returns 'updated'; new to extra127"]
    - [uw_cv3_len,
       "update_wrapper.__code__.co_varnames.__getitem__(3).__len__",
       [],
       7,
       "functools.update_wrapper.__code__.co_varnames[3].__len__() == 7 — 'updated' has 7 chars: u-p-d-a-t-e-d; same length as co_varnames[0] 'wrapper' (7) and co_varnames[1] 'wrapped' (7); str.__len__() returns 7; new to extra127"]

# ---------------------------------------------------------------------------
# Table 2: functools.update_wrapper __code__.co_varnames[4] and [5], total len
#
# Wave 273 theme: The final two co_varnames for update_wrapper are internal loop
# variables used in the for-loop that copies attributes. co_varnames[4] == 'attr'
# (4 chars) — the loop variable iterating over each attribute name in the
# 'assigned' tuple. co_varnames[5] == 'value' (5 chars) — the loop variable
# holding the retrieved attribute value before copying. Together the 4 declared
# parameters and 2 loop locals give co_varnames a total length of 6. This is
# more than lru_cache (5) and wraps (3), reflecting update_wrapper's broader
# implementation: it copies multiple attributes in a loop, requiring 'attr' and
# 'value' as iteration locals not needed by simpler decorators.
#
# update_wrapper.__code__.co_varnames[4] == 'attr'   (len 4)
# update_wrapper.__code__.co_varnames[5] == 'value'  (len 5)
# update_wrapper.__code__.co_varnames.__len__() == 6
#
# New to extra127.
# ---------------------------------------------------------------------------

table functools_extra127.update_wrapper_co_varnames_4_5_and_len:
  description: "functools.update_wrapper co_varnames[4]='attr'(4), [5]='value'(5); tuple len=6; 4 declared params + 2 loop locals (attr, value); more than lru_cache (5) and wraps (3); wave 273; new to extra127"
  kind: python_call_eq
  category: string_identity
  id_prefix: functoolsuwcvl127

  columns: [id, function, args, expected, description]
  rows:
    - [uw_cv4_eq,
       "update_wrapper.__code__.co_varnames.__getitem__",
       [4],
       "attr",
       "functools.update_wrapper.__code__.co_varnames[4] == 'attr' — internal loop variable iterating over each attribute name in the 'assigned' tuple; used in 'for attr in assigned: ...' to copy attributes from wrapped to wrapper; tuple.__getitem__(4) returns 'attr'; new to extra127"]
    - [uw_cv4_len,
       "update_wrapper.__code__.co_varnames.__getitem__(4).__len__",
       [],
       4,
       "functools.update_wrapper.__code__.co_varnames[4].__len__() == 4 — 'attr' has 4 chars: a-t-t-r; the shortest co_varnames entry; shorter than 'value'(5), 'wrapper'(7), 'wrapped'(7), 'assigned'(8), 'updated'(7); str.__len__() returns 4; new to extra127"]
    - [uw_cv5_eq,
       "update_wrapper.__code__.co_varnames.__getitem__",
       [5],
       "value",
       "functools.update_wrapper.__code__.co_varnames[5] — internal loop variable holding the attribute value retrieved from the wrapped function before copying it to wrapper; 'value' is also used for getattr/setattr in the update loop; tuple.__getitem__(5) returns 'value'; new to extra127"]
    - [uw_cv5_len,
       "update_wrapper.__code__.co_varnames.__getitem__(5).__len__",
       [],
       5,
       "functools.update_wrapper.__code__.co_varnames[5].__len__() == 5 — 'value' has 5 chars: v-a-l-u-e; one more than 'attr' (4) but two less than 'wrapper' (7); str.__len__() returns 5; new to extra127"]
    - [uw_cv_len,
       "update_wrapper.__code__.co_varnames.__len__",
       [],
       6,
       "functools.update_wrapper.__code__.co_varnames.__len__() == 6 — update_wrapper has 6 local variable names: 4 declared parameters (wrapper, wrapped, assigned, updated) + 2 loop variables (attr, value); more than lru_cache (5) and wraps (3); tuple.__len__() returns 6; new to extra127"]
    - [uw_cv5_ne_cv4,
       "update_wrapper.__code__.co_varnames.__getitem__(5).__eq__",
       ["attr"],
       false,
       "functools.update_wrapper.__code__.co_varnames[5].__eq__('attr') == False — 'value' is not 'attr'; confirming the two loop variables are distinct; co_varnames[4]='attr' vs co_varnames[5]='value'; str.__eq__('attr') returns False; new to extra127"]

# ---------------------------------------------------------------------------
# Table 3: functools.update_wrapper __code__ metadata: co_argcount, co_consts len
#
# Wave 273 theme: update_wrapper.__code__.co_argcount == 4 — there are 4
# positional-or-keyword parameters (wrapper, wrapped, assigned, updated). This is
# the highest co_argcount among the three functools decorators: update_wrapper(4),
# lru_cache(2), wraps(3). The co_consts tuple has exactly 1 entry: the docstring.
# co_consts[0] is the function docstring (458 chars), confirming update_wrapper
# has a docstring and no other constants (no numeric literals or string constants
# in the function body — the attribute names are taken from the 'assigned' and
# 'updated' parameters, not hardcoded as constants).
#
# update_wrapper.__code__.co_argcount == 4
# update_wrapper.__code__.co_consts.__len__() == 1
#
# New to extra127.
# ---------------------------------------------------------------------------

table functools_extra127.update_wrapper_co_argcount_and_co_consts_len:
  description: "functools.update_wrapper co_argcount=4 (highest among update_wrapper/lru_cache/wraps); co_consts len=1 (docstring only); co_name='update_wrapper'(14); wave 273; new to extra127"
  kind: python_call_eq
  category: type_identity
  id_prefix: functoolsuwmeta127

  columns: [id, function, args, expected, description]
  rows:
    - [uw_co_argcount,
       "update_wrapper.__code__.co_argcount.__eq__",
       [4],
       true,
       "functools.update_wrapper.__code__.co_argcount.__eq__(4) == True — update_wrapper has 4 positional-or-keyword parameters: wrapper, wrapped, assigned, updated; co_argcount is 4; higher than wraps (3) and lru_cache (2); int.__eq__(4) returns True; new to extra127"]
    - [uw_co_consts_len,
       "update_wrapper.__code__.co_consts.__len__",
       [],
       1,
       "functools.update_wrapper.__code__.co_consts.__len__() == 1 — co_consts contains only the docstring; no numeric literals or string constants in the body (attribute names come from the 'assigned' and 'updated' parameter tuples); tuple.__len__() returns 1; new to extra127"]
    - [uw_co_name_eq,
       "update_wrapper.__code__.co_name.__eq__",
       ["update_wrapper"],
       true,
       "functools.update_wrapper.__code__.co_name.__eq__('update_wrapper') == True — co_name holds the function name as defined in source; 'update_wrapper' (14 chars) matches the function name; str.__eq__('update_wrapper') returns True; new to extra127"]
    - [uw_co_name_len,
       "update_wrapper.__code__.co_name.__len__",
       [],
       14,
       "functools.update_wrapper.__code__.co_name.__len__() == 14 — 'update_wrapper' has 14 chars; same length as functools.__all__[0] == 'update_wrapper'; str.__len__() returns 14; new to extra127"]
    - [uw_cv_len_gt_wraps,
       "update_wrapper.__code__.co_varnames.__len__",
       [],
       6,
       "functools.update_wrapper.__code__.co_varnames.__len__() == 6 — update_wrapper (6 locals) has more co_varnames entries than wraps (3) and lru_cache (5); the two loop variables attr and value are unique to update_wrapper; tuple.__len__() returns 6; new to extra127"]

