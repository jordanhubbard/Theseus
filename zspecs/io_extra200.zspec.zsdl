spec: io_extra200
version: ">=3.9"
backend: python_module(io)

docs: https://docs.python.org/3/library/io.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — Python io module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/io.py"
    - "CPython source: Modules/_io/stringio.c"
  notes:
    - "This spec extends io_extra199.zspec.zsdl."
    - "This spec covers io.StringIO class identity — __name__, __module__, __bases__[0].__name__, __class__.__name__, __init__.__qualname__, read.__qualname__, write.__qualname__, and getvalue.__qualname__."
    - "io.StringIO.__name__ == 'StringIO' (len=8); confirmed Python 3.14.3 macOS."
    - "io.StringIO.__module__ == '_io' (len=3); StringIO is implemented in the _io C extension, not the pure-Python io wrapper; confirmed Python 3.14.3 macOS."
    - "io.StringIO.__bases__[0].__name__ == '_TextIOBase' (len=11); the direct base is the C-level _TextIOBase, not the pure-Python TextIOBase; confirmed Python 3.14.3 macOS."
    - "io.StringIO.__class__.__name__ == 'type' — StringIO uses the plain type metaclass; confirmed Python 3.14.3 macOS."
    - "io.StringIO.__init__.__qualname__ == 'StringIO.__init__' (len=17: 'StringIO.'=9+'__init__'=8=17); confirmed Python 3.14.3 macOS."
    - "io.StringIO.read.__qualname__ == 'StringIO.read' (len=13: 'StringIO.'=9+'read'=4=13); shortest qualname in spec; confirmed Python 3.14.3 macOS."
    - "io.StringIO.write.__qualname__ == 'StringIO.write' (len=14: 'StringIO.'=9+'write'=5=14); confirmed Python 3.14.3 macOS."
    - "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue' (len=17: 'StringIO.'=9+'getvalue'=8=17); same length as __init__ qualname; confirmed Python 3.14.3 macOS."
    - "Qualname length ordering: read(13) < write(14) < __init__(17)==getvalue(17); confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: io.StringIO method __qualname__ equality
# read(13), write(14), __init__(17), getvalue(17)
# ---------------------------------------------------------------------------

table io_extra200.stringio_method_qualnames:
  description: "io.StringIO method __qualname__ values: read='StringIO.read'(13), write='StringIO.write'(14), __init__='StringIO.__init__'(17), getvalue='StringIO.getvalue'(17)"
  kind: python_call_eq
  category: identity
  id_prefix: iostringio200

  columns: [id, function, args, expected, description]
  rows:
    - [read_qn_eq,     io.StringIO.read.__qualname__.__eq__,     ["StringIO.read"],     true, "io.StringIO.read.__qualname__ == 'StringIO.read' (len=13); shortest qualname in spec; confirmed Python 3.14.3 macOS"]
    - [write_qn_eq,    io.StringIO.write.__qualname__.__eq__,    ["StringIO.write"],    true, "io.StringIO.write.__qualname__ == 'StringIO.write' (len=14); confirmed Python 3.14.3 macOS"]
    - [init_qn_eq,     io.StringIO.__init__.__qualname__.__eq__, ["StringIO.__init__"], true, "io.StringIO.__init__.__qualname__ == 'StringIO.__init__' (len=17); tied longest qualname in spec; confirmed Python 3.14.3 macOS"]
    - [getvalue_qn_eq, io.StringIO.getvalue.__qualname__.__eq__, ["StringIO.getvalue"], true, "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue' (len=17); same length as __init__ qualname; confirmed Python 3.14.3 macOS"]
    - [read_qn_len,    io.StringIO.read.__qualname__.__len__,    [], 13, "io.StringIO.read.__qualname__.__len__() == 13 ('StringIO.'=9+'read'=4); shortest qualname in spec; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: io.StringIO method __qualname__ lengths
# read(13) < write(14) < __init__(17)==getvalue(17)
# ---------------------------------------------------------------------------

table io_extra200.stringio_method_qualname_lengths:
  description: "io.StringIO method __qualname__ lengths: read=13, write=14, __init__=17, getvalue=17; length ordering read < write < __init__==getvalue"
  kind: python_call_eq
  category: identity
  id_prefix: iostringio200

  columns: [id, function, args, expected, description]
  rows:
    - [read_qn_len,     io.StringIO.read.__qualname__.__len__,     [], 13, "io.StringIO.read.__qualname__.__len__() == 13 ('StringIO.'=9+'read'=4); shortest in spec; confirmed Python 3.14.3 macOS"]
    - [write_qn_len,    io.StringIO.write.__qualname__.__len__,    [], 14, "io.StringIO.write.__qualname__.__len__() == 14 ('StringIO.'=9+'write'=5); confirmed Python 3.14.3 macOS"]
    - [init_qn_len,     io.StringIO.__init__.__qualname__.__len__, [], 17, "io.StringIO.__init__.__qualname__.__len__() == 17 ('StringIO.'=9+'__init__'=8); tied longest in spec; confirmed Python 3.14.3 macOS"]
    - [getvalue_qn_len, io.StringIO.getvalue.__qualname__.__len__, [], 17, "io.StringIO.getvalue.__qualname__.__len__() == 17 ('StringIO.'=9+'getvalue'=8); same length as __init__ qualname; confirmed Python 3.14.3 macOS"]
    - [module_len,      io.StringIO.__module__.__len__,            [], 3,  "io.StringIO.__module__.__len__() == 3 — _io (underscore+i+o); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: io.StringIO class-level identity attributes
# __name__(StringIO,8), __module__(_io,3), __bases__[0].__name__(_TextIOBase,11), __class__(type)
# ---------------------------------------------------------------------------

table io_extra200.stringio_class_identity:
  description: "io.StringIO class-level identity: __name__='StringIO'(8), __module__='_io'(3), __bases__[0].__name__='_TextIOBase'(11), __class__.__name__='type'"
  kind: python_call_eq
  category: identity
  id_prefix: iostringio200

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,       io.StringIO.__name__.__eq__,                          ["StringIO"],   true, "io.StringIO.__name__ == 'StringIO' (len=8); confirmed Python 3.14.3 macOS"]
    - [module_eq,     io.StringIO.__module__.__eq__,                        ["_io"],        true, "io.StringIO.__module__ == '_io' (C extension, len=3); confirmed Python 3.14.3 macOS"]
    - [base_eq,       "io.StringIO.__bases__[0].__name__.__eq__",           ["_TextIOBase"], true, "io.StringIO.__bases__[0].__name__ == '_TextIOBase' (len=11); the C-level text IO base class; confirmed Python 3.14.3 macOS"]
    - [class_name_eq, io.StringIO.__class__.__name__.__eq__,                ["type"],       true, "io.StringIO.__class__.__name__ == 'type' (plain type metaclass); confirmed Python 3.14.3 macOS"]
    - [name_len,      io.StringIO.__name__.__len__,                         [],             8,    "io.StringIO.__name__.__len__() == 8 — S(1)t(2)r(3)i(4)n(5)g(6)I(7)O(8); confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant io_extra200.stringio_name_eq:
  description: "io.StringIO.__name__ == 'StringIO' — class name string length 8 ('StringIO'); io.StringIO is the in-memory text stream class that reads and writes str objects; its __name__ attribute returns the plain class name as a string; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.StringIO.__name__.__eq__
  args: ["StringIO"]
  expected: true

invariant io_extra200.stringio_module_eq:
  description: "io.StringIO.__module__ == '_io' — StringIO is implemented in the _io C extension (len=3); although accessed as io.StringIO, the class itself lives in the C extension module _io; this is consistent with other io classes such as BytesIO and FileIO; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.StringIO.__module__.__eq__
  args: ["_io"]
  expected: true

invariant io_extra200.stringio_base_name_eq:
  description: "io.StringIO.__bases__[0].__name__ == '_TextIOBase' — the direct base class of StringIO is _TextIOBase (len=11), which is the internal C-level text IO base class; StringIO inherits from _TextIOBase which provides the abstract text stream interface; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: "io.StringIO.__bases__[0].__name__.__eq__"
  args: ["_TextIOBase"]
  expected: true

invariant io_extra200.stringio_class_name_type:
  description: "io.StringIO.__class__.__name__ == 'type' — StringIO's metaclass is the plain 'type' (not ABCMeta); StringIO is a C-level extension type and uses the standard type metaclass; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.StringIO.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant io_extra200.stringio_init_qualname_eq:
  description: "io.StringIO.__init__.__qualname__ == 'StringIO.__init__' — the qualified name of the __init__ method is 'StringIO.__init__' (len=17: 'StringIO.'=9 + '__init__'=8 = 17); tied longest qualname in the spec along with getvalue; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.StringIO.__init__.__qualname__.__eq__
  args: ["StringIO.__init__"]
  expected: true

invariant io_extra200.stringio_read_qualname_eq:
  description: "io.StringIO.read.__qualname__ == 'StringIO.read' — the qualified name of the read method is 'StringIO.read' (len=13: 'StringIO.'=9 + 'read'=4 = 13); this is the shortest qualname in the spec; read reads up to size characters from the stream; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.StringIO.read.__qualname__.__eq__
  args: ["StringIO.read"]
  expected: true

invariant io_extra200.stringio_write_qualname_eq:
  description: "io.StringIO.write.__qualname__ == 'StringIO.write' — the qualified name of the write method is 'StringIO.write' (len=14: 'StringIO.'=9 + 'write'=5 = 14); write writes a string to the stream and returns the number of characters written; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.StringIO.write.__qualname__.__eq__
  args: ["StringIO.write"]
  expected: true

invariant io_extra200.stringio_getvalue_qualname_eq:
  description: "io.StringIO.getvalue.__qualname__ == 'StringIO.getvalue' — the qualified name of the getvalue method is 'StringIO.getvalue' (len=17: 'StringIO.'=9 + 'getvalue'=8 = 17); tied longest qualname in the spec along with __init__; getvalue returns the entire contents of the stream as a single string; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: io.StringIO.getvalue.__qualname__.__eq__
  args: ["StringIO.getvalue"]
  expected: true
