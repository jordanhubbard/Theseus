spec: textwrap_extra
version: ">=3.9"
backend: python_module(textwrap)

docs: https://docs.python.org/3/library/textwrap.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/textwrap.html — Python textwrap documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/textwrap.py"
  notes:
    - "This spec covers class/function identity invariants and short behavioral cases not in textwrap.zspec.zsdl."
    - "TextWrapper is the class underlying all textwrap convenience functions."
    - "wrap() returns a list of strings; fill() returns a single newline-joined string."
    - "dedent() removes common leading whitespace from every line in the string."
    - "indent() adds a prefix to the beginning of every non-empty line."
    - "shorten() collapses whitespace and truncates to fit within width, appending a placeholder."
    - "wrap('hello world', width=5) splits 'hello' and 'world' onto separate lines since 'hello world' (11 chars) exceeds width=5."
    - "shorten('hello world', width=8, placeholder='...') — 'hello' (5) + '...' (3) = 8, so 'hello...' fits exactly."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Class identity — TextWrapper
# ---------------------------------------------------------------------------

invariant textwrap_extra.class_names.TextWrapper_name:
  description: "TextWrapper.__name__ == 'TextWrapper'"
  category: class_names
  kind: python_call_eq
  function: TextWrapper.__name__.__eq__
  args: ["TextWrapper"]
  expected: true

invariant textwrap_extra.class_names.TextWrapper_module:
  description: "TextWrapper.__module__ == 'textwrap'"
  category: class_names
  kind: python_call_eq
  function: TextWrapper.__module__.__eq__
  args: ["textwrap"]
  expected: true

# ---------------------------------------------------------------------------
# Function identity — wrap, fill, dedent, indent, shorten
# ---------------------------------------------------------------------------

invariant textwrap_extra.function_names.wrap:
  description: "wrap.__name__ == 'wrap'"
  category: function_names
  kind: python_call_eq
  function: wrap.__name__.__eq__
  args: ["wrap"]
  expected: true

invariant textwrap_extra.function_names.fill:
  description: "fill.__name__ == 'fill'"
  category: function_names
  kind: python_call_eq
  function: fill.__name__.__eq__
  args: ["fill"]
  expected: true

invariant textwrap_extra.function_names.dedent:
  description: "dedent.__name__ == 'dedent'"
  category: function_names
  kind: python_call_eq
  function: dedent.__name__.__eq__
  args: ["dedent"]
  expected: true

invariant textwrap_extra.function_names.indent:
  description: "indent.__name__ == 'indent'"
  category: function_names
  kind: python_call_eq
  function: indent.__name__.__eq__
  args: ["indent"]
  expected: true

invariant textwrap_extra.function_names.shorten:
  description: "shorten.__name__ == 'shorten'"
  category: function_names
  kind: python_call_eq
  function: shorten.__name__.__eq__
  args: ["shorten"]
  expected: true

# ---------------------------------------------------------------------------
# wrap() — narrow width splits single-word boundaries
# ---------------------------------------------------------------------------

invariant textwrap_extra.wrap.two_words_width5:
  description: "wrap('hello world', width=5) == ['hello', 'world']"
  category: wrap
  kind: python_call_eq
  function: wrap
  args: ["hello world", 5]
  expected: ["hello", "world"]

# ---------------------------------------------------------------------------
# fill() — newline-joined output at narrow width
# ---------------------------------------------------------------------------

invariant textwrap_extra.fill.two_words_width5:
  description: "fill('hello world', width=5) == 'hello\\nworld'"
  category: fill
  kind: python_call_eq
  function: fill
  args: ["hello world", 5]
  expected: "hello\nworld"

# ---------------------------------------------------------------------------
# dedent() — removes 2-space common indent
# ---------------------------------------------------------------------------

invariant textwrap_extra.dedent.two_space_indent:
  description: "dedent('  hello\\n  world') == 'hello\\nworld'"
  category: dedent
  kind: python_call_eq
  function: dedent
  args: ["  hello\n  world"]
  expected: "hello\nworld"

# ---------------------------------------------------------------------------
# indent() — adds 2-space prefix to each line
# ---------------------------------------------------------------------------

invariant textwrap_extra.indent.two_space_prefix:
  description: "indent('hello\\nworld', '  ') == '  hello\\n  world'"
  category: indent
  kind: python_call_eq
  function: indent
  args: ["hello\nworld", "  "]
  expected: "  hello\n  world"

# ---------------------------------------------------------------------------
# shorten() — truncates with custom placeholder
# ---------------------------------------------------------------------------

invariant textwrap_extra.shorten.custom_placeholder:
  description: "shorten('hello world', width=8, placeholder='...') == 'hello...'"
  category: shorten
  kind: python_call_eq
  function: shorten
  args: ["hello world", 8]
  kwargs: {placeholder: "..."}
  expected: "hello..."
