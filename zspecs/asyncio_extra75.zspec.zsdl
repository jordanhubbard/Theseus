invariant asyncio_extra75.Lock_dict_class_name:
  description: "asyncio.Lock.__dict__.__class__.__name__.__eq__('mappingproxy') returns True — class __dict__ objects are always mappingproxy in CPython; NEW in extra75: first standalone __dict__.__class__.__name__ invariant for Lock in asynciomore75 namespace; wave 241; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: Lock.__dict__.__class__.__name__.__eq__
  args: ["mappingproxy"]
  expected: true

invariant asyncio_extra75.Lock_dict_has_locked:
  description: "asyncio.Lock.__dict__.__contains__('locked') returns True — Lock defines the locked() method directly in asyncio/locks.py; NEW in extra75: first standalone __contains__('locked') invariant for Lock in asynciomore75 namespace; wave 241; verified with Python 3.14.3"
  category: dict_content
  kind: python_call_eq
  function: Lock.__dict__.__contains__
  args: ["locked"]
  expected: true

