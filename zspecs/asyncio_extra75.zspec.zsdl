spec: asyncio_extra75
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio Synchronization Primitives"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
  notes:
    - "This spec extends asyncio_extra74.zspec.zsdl."
    - "This spec covers: wave 241 theme — asyncio Lock/Event/Semaphore __dict__ content. NEW in extra75: Lock.__dict__.__class__.__name__=='mappingproxy'; Lock.__dict__.__contains__('acquire')==True; Lock.__dict__.__contains__('release')==True; Lock.__dict__.__contains__('locked')==True; Event.__dict__.__class__.__name__=='mappingproxy'; Event.__dict__.__contains__('set')==True; Event.__dict__.__contains__('clear')==True; Event.__dict__.__contains__('wait')==True; Semaphore.__dict__.__class__.__name__=='mappingproxy'; Semaphore.__dict__.__contains__('acquire')==True; Semaphore.__dict__.__contains__('release')==True."
    - "asyncio.Lock.__dict__.__class__.__name__ == 'mappingproxy'. The __dict__ of any Python class is a read-only mappingproxy; Lock.__dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__dict__.__contains__('acquire') == True. Lock defines acquire directly in its own __dict__ in asyncio/locks.py. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__dict__.__contains__('release') == True. Lock defines release directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Lock.__dict__.__contains__('locked') == True. Lock defines the locked() method in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__dict__.__class__.__name__ == 'mappingproxy'. Event.__dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__dict__.__contains__('set') == True. Event defines set directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__dict__.__contains__('clear') == True. Event defines clear directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Event.__dict__.__contains__('wait') == True. Event defines wait directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__dict__.__class__.__name__ == 'mappingproxy'. Semaphore.__dict__.__class__.__name__ is 'mappingproxy'. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__dict__.__contains__('acquire') == True. Semaphore defines acquire directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "asyncio.Semaphore.__dict__.__contains__('release') == True. Semaphore defines release directly in its own __dict__. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio Lock.__dict__ class name and method content — extra75
#
# Wave 241 theme: asyncio Lock/Event/Semaphore __dict__ content.
#
# Lock.__dict__.__class__.__name__ == 'mappingproxy'
# Lock.__dict__.__contains__('acquire') == True
# Lock.__dict__.__contains__('release') == True
# Lock.__dict__.__contains__('locked') == True
# ---------------------------------------------------------------------------

table asyncio_extra75.Lock_dict_class_and_methods:
  description: "asyncio Lock.__dict__ class name and method content checks in asynciomore75 namespace — wave 241 theme: Lock/Event/Semaphore __dict__ content; Lock.__dict__.__class__.__name__=='mappingproxy' (class __dict__ is read-only mappingproxy in CPython); Lock.__dict__.__contains__('acquire')==True; Lock.__dict__.__contains__('release')==True; Lock.__dict__.__contains__('locked')==True; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_content
  id_prefix: asynciomore75

  columns: [id, function, args, expected, description]
  rows:
    - [lock_dict_class_name, Lock.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true, "Lock.__dict__.__class__.__name__ == 'mappingproxy' — class __dict__ is always a mappingproxy in CPython; verified with Python 3.14.3"]
    - [lock_dict_has_acquire, Lock.__dict__.__contains__,             ["acquire"],      true, "Lock.__dict__.__contains__('acquire') == True — Lock defines acquire in asyncio/locks.py; verified with Python 3.14.3"]
    - [lock_dict_has_release, Lock.__dict__.__contains__,             ["release"],      true, "Lock.__dict__.__contains__('release') == True — Lock defines release in asyncio/locks.py; verified with Python 3.14.3"]
    - [lock_dict_has_locked,  Lock.__dict__.__contains__,             ["locked"],       true, "Lock.__dict__.__contains__('locked') == True — Lock defines locked() method in asyncio/locks.py; verified with Python 3.14.3"]

