spec: hl3526
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 682 (hl3526): __set_name__, __init_subclass__, __class_getitem__ dict-presence checks for hashlib types."
    - "All values false — hashlib hash object types do not implement class creation hooks or generic parameterization."
    - "type(hashlib.md5()), type(hashlib.sha1()), type(hashlib.sha256()), type(hashlib.sha512()), type(hashlib.blake2b(b'')): none define __set_name__, __init_subclass__, or __class_getitem__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __set_name__ dict-presence — operator.contains(Cls.__dict__, '__set_name__')
# ---------------------------------------------------------------------------

table hl3526.set_name:
  description: "hashlib types __set_name__ dict-presence checks; wave 682"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: hl3526
  columns: [id, function, args, expected]
  rows:
    - ["hl3526001", operator.contains, [type(hashlib.md5()).__dict__,        "__set_name__"], false]
    - ["hl3526002", operator.contains, [type(hashlib.sha1()).__dict__,       "__set_name__"], false]
    - ["hl3526003", operator.contains, [type(hashlib.sha256()).__dict__,     "__set_name__"], false]
    - ["hl3526004", operator.contains, [type(hashlib.sha512()).__dict__,     "__set_name__"], false]
    - ["hl3526005", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__set_name__"], false]

