spec: dis_extra6
version: ">=3.9"
backend: python_module(dis)

docs: https://docs.python.org/3/library/dis.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/dis.html — Python dis module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/dis.py"
    - "CPython source: Python/compile.c"
    - "dis.zspec.zsdl — covers __name__ for Instruction/Bytecode/dis/disassemble/code_info/show_code/get_instructions/stack_effect; opname class/length; opmap contains/values; stack_effect values; haslocal/hasname"
    - "dis_extra.zspec.zsdl — covers dis.__name__ (module name), distb/__name__, findlinestarts/__name__, findlabels/__name__, disassemble/__name__, code_info/__name__, show_code/__name__, get_instructions/__name__, stack_effect/__name__, Instruction/__name__/__module__, opname/__class__/__name__, opmap/__class__/__name__, HAVE_ARGUMENT/__class__/__name__"
    - "dis_extra2.zspec.zsdl — covers __module__ for dis/disassemble/get_instructions/findlinestarts/findlabels/code_info; Instruction/__name__/__module__/__bases__[0]; Bytecode/__name__/__module__/__bases__[0]; opname/opmap class checks; HAVE_ARGUMENT class check"
    - "dis_extra3.zspec.zsdl — covers __name__/__module__ for Instruction/Bytecode (table); __name__ for findlinestarts/findlabels/get_instructions/stack_effect (table); opname class/length; opmap class/contains; HAVE_ARGUMENT value; Bytecode.__module__"
    - "dis_extra4.zspec.zsdl — covers Instruction.__qualname__; Instruction._fields class/contains-opname/contains-opcode; opname.__len__ >= 100; dis/disassemble/get_instructions/findlinestarts __qualname__ (table)"
    - "dis_extra5.zspec.zsdl — covers __qualname__ for code_info/show_code/stack_effect/findlabels/distb; Bytecode.__qualname__; Instruction._fields[0] == 'opname'; show_code/__module__; distb/__module__"
  notes:
    - "This spec adds new axes: hasjabs is an empty list in Python 3.12+ (all jumps use relative offsets); hasjrel/hasconst/hascompare/hasfree class and length checks; Instruction._fields[1] == 'opcode' and _fields[2] == 'arg'; additional opmap entries (LOAD_CONST, LOAD_GLOBAL, RETURN_VALUE, STORE_NAME); opname indexed access for LOAD_CONST."
    - "dis.hasjabs is an empty list in Python 3.12+ — all absolute-jump opcodes were removed in 3.12."
    - "dis.hasjrel is a list with 16 entries in Python 3.12."
    - "dis.hasconst is a list with 1 entry in Python 3.12 (only LOAD_CONST)."
    - "dis.hascompare is a list with 1 entry in Python 3.12."
    - "dis.hasfree is a list with entries for opcodes that access free/cell variables."
    - "dis.Instruction._fields[1] == 'opcode' — second field of the Instruction namedtuple."
    - "dis.Instruction._fields[2] == 'arg' — third field of the Instruction namedtuple."
    - "dis.opmap['LOAD_CONST'] == 82 in Python 3.12."
    - "dis.opmap['RETURN_VALUE'] == 35 in Python 3.12."
    - "dis.opmap['STORE_NAME'] == 116 in Python 3.12."
    - "dis.opname[82] == 'LOAD_CONST' — indexed access into opname list."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hasjabs — empty list in Python 3.12+
# dis.zspec.zsdl checks haslocal/hasname. dis_extra* check hasjabs class via
# HAVE_ARGUMENT checks but never verify hasjabs is actually empty.
# ---------------------------------------------------------------------------

invariant dis_extra6.hasjabs.is_list:
  description: "dis.hasjabs is a list"
  category: opcode_sets
  kind: python_call_eq
  function: hasjabs.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant dis_extra6.hasjabs.len_zero:
  description: "len(dis.hasjabs) == 0 — no absolute-jump opcodes in Python 3.12+"
  category: opcode_sets
  kind: python_call_eq
  function: hasjabs.__len__
  args: []
  expected: 0

# ---------------------------------------------------------------------------
# hasjrel, hasconst, hascompare, hasfree — class and length checks
# No prior spec verifies these four opcode-category lists.
# ---------------------------------------------------------------------------

table dis_extra6.opcode_set_classes:
  kind: python_call_eq
  category: opcode_sets
  id_prefix: ocls

  columns: [id, function, args, expected]
  rows:
    - [hasjrel,     hasjrel.__class__.__name__.__eq__,     ["list"], true]
    - [hasconst,    hasconst.__class__.__name__.__eq__,    ["list"], true]
    - [hascompare,  hascompare.__class__.__name__.__eq__,  ["list"], true]
    - [hasfree,     hasfree.__class__.__name__.__eq__,     ["list"], true]

invariant dis_extra6.hasjrel.nonempty:
  description: "dis.hasjrel has at least one entry"
  category: opcode_sets
  kind: python_call_eq
  function: hasjrel.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

invariant dis_extra6.hasfree.nonempty:
  description: "dis.hasfree has at least one entry"
  category: opcode_sets
  kind: python_call_eq
  function: hasfree.__len__
  args: []
  method: __ge__
  method_args: [1]
  expected: true

# ---------------------------------------------------------------------------
# Instruction._fields[1] == 'opcode', _fields[2] == 'arg'
# dis_extra5 confirmed _fields[0] == 'opname'. The next two fields
# have not been independently verified in any prior spec.
# ---------------------------------------------------------------------------

invariant dis_extra6.Instruction.fields_index1:
  description: "dis.Instruction._fields[1] == 'opcode' — second field of Instruction namedtuple"
  category: instruction_fields
  kind: python_call_eq
  function: Instruction._fields.__getitem__
  args: [1]
  expected: "opcode"

invariant dis_extra6.Instruction.fields_index2:
  description: "dis.Instruction._fields[2] == 'arg' — third field of Instruction namedtuple"
  category: instruction_fields
  kind: python_call_eq
  function: Instruction._fields.__getitem__
  args: [2]
  expected: "arg"

# ---------------------------------------------------------------------------
# opmap — additional opcode entries not in prior specs
# dis.zspec.zsdl covers LOAD_FAST (84) and POP_TOP (31).
# New here: LOAD_CONST (82), LOAD_GLOBAL (92), RETURN_VALUE (35), STORE_NAME (116).
# ---------------------------------------------------------------------------

table dis_extra6.opmap_values:
  kind: python_call_eq
  category: opmap
  id_prefix: opmap

  columns: [id, function, args, expected]
  rows:
    - [LOAD_CONST,    opmap.__getitem__, ["LOAD_CONST"],    82]
    - [LOAD_GLOBAL,   opmap.__getitem__, ["LOAD_GLOBAL"],   92]
    - [RETURN_VALUE,  opmap.__getitem__, ["RETURN_VALUE"],  35]
    - [STORE_NAME,    opmap.__getitem__, ["STORE_NAME"],   116]

# ---------------------------------------------------------------------------
# opmap contains checks for additional opcodes not in prior specs
# dis.zspec.zsdl covers LOAD_FAST and POP_TOP.
# New here: LOAD_CONST, RETURN_VALUE, STORE_NAME.
# ---------------------------------------------------------------------------

invariant dis_extra6.opmap.contains_load_const:
  description: "'LOAD_CONST' in dis.opmap"
  category: opmap
  kind: python_call_eq
  function: opmap.__contains__
  args: ["LOAD_CONST"]
  expected: true

invariant dis_extra6.opmap.contains_return_value:
  description: "'RETURN_VALUE' in dis.opmap"
  category: opmap
  kind: python_call_eq
  function: opmap.__contains__
  args: ["RETURN_VALUE"]
  expected: true

# ---------------------------------------------------------------------------
# opname indexed access
# dis.zspec.zsdl checks opname class and length but not index-based lookup.
# Verify opname[82] == 'LOAD_CONST'.
# ---------------------------------------------------------------------------

invariant dis_extra6.opname.index82:
  description: "dis.opname[82] == 'LOAD_CONST'"
  category: opname
  kind: python_call_eq
  function: opname.__getitem__
  args: [82]
  expected: "LOAD_CONST"
