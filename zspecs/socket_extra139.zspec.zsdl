spec: socket_extra139
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
    - "socket_extra138.zspec.zsdl — covers socket.socket.__doc__ identity and content / socket.__spec__ and __loader__ attribute identity / socket.herror and socket.gaierror exception class identity / socket.getfqdn and socket.create_connection qualnames (table + invariants)."
    - "socket_extra99.zspec.zsdl — covers socket.gethostname/gethostbyname/getaddrinfo/setdefaulttimeout/getdefaulttimeout __qualname__.__len__() / SocketIO class identity."
    - "socket_extra98.zspec.zsdl — covers socket.socket C-level and Python-level method __qualname__.__len__() values."
    - "socket_extra97.zspec.zsdl — covers socket.socket.__init__/accept/makefile/close __class__.__name__=='function' and __module__=='socket' / socket.socket.send/sendall/fileno __qualname__.__eq__."
    - "socket_extra96.zspec.zsdl — covers socket.AF_INET/AF_UNIX/AF_INET6/AF_UNSPEC class names / SOCK_STREAM/SOCK_DGRAM/SOCK_RAW class names / AddressFamily/SocketKind __bases__ / gethostname/gethostbyname/setdefaulttimeout/getdefaulttimeout __class__.__name__=='builtin_function_or_method'."
    - "socket_extra95.zspec.zsdl — covers AddressFamily/SocketKind enum member values and names / socket.__all__ class name and length."
    - "socket_extra94.zspec.zsdl — covers socket module-level function __qualname__ and __module__ values / byte-order function class names."
    - "socket_extra93.zspec.zsdl — covers socket.socket C-level method_descriptor class names."
    - "socket.zspec / early extras — cover socket.__name__/__package__ (base spec)."
  notes:
    - "This spec does NOT duplicate invariants present in socket_extra93 through socket_extra138."
    - "Wave 287 theme: socket.socket.__eq__ and __hash__ qualnames (inherited from object) / socket.socket.family and type as property descriptors / socket.socket class __name__/__module__/__mro__ / socket.getfqdn and create_connection __doc__ lengths."
    - "socket.socket.__eq__.__qualname__ == 'object.__eq__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__eq__.__qualname__.__len__() == 13. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__hash__.__qualname__ == 'object.__hash__'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__hash__.__qualname__.__len__() == 15. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.family.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.type.__class__.__name__ == 'property'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__name__.__eq__('socket') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__name__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__.__eq__('socket') == True. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__module__.__len__() == 6. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__mro__.__len__() == 3. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__name__ == 'socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.socket.__bases__[0].__module__ == '_socket'. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.getfqdn.__doc__.__len__() == 354. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "socket.create_connection.__doc__.__len__() == 721. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "Note: socket.socket.__eq__ and __hash__ are inherited from object (qualnames 'object.__eq__' and 'object.__hash__'). The Python-level socket.socket class in Lib/socket.py does not override these comparison operators."
    - "Note: socket.socket.family and socket.socket.type are property descriptors on the Python-level socket class (defined in Lib/socket.py). The underlying _socket.socket stores family/type/proto as member_descriptor objects; Lib/socket.py wraps them as Python properties. socket.socket.proto is NOT a property on socket.socket — it is inherited directly from _socket.socket as a member_descriptor."
    - "Note: socket.socket.__mro__ is [socket(socket), socket(_socket), object] — length 3. The Python-level socket.socket inherits from _socket.socket (the C class), which in turn inherits from object."
    - "Note: socket.create_connection.__doc__ (721 chars) is the longest function docstring in the socket module — it documents the host/port/timeout/source_address/all_errors parameters in detail."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# socket.socket.__eq__.__qualname__.__eq__('object.__eq__')
# socket.socket.__eq__.__qualname__.__len__()==13
# socket.socket.__hash__.__qualname__.__eq__('object.__hash__')
# socket.socket.__hash__.__qualname__.__len__()==15
#
# Wave 287 theme: socket.socket.__eq__ and __hash__ inherited from object.
#
# socket.socket (the Python-level class in Lib/socket.py) does not override
# __eq__ or __hash__. Both are inherited from object: __eq__ as a
# wrapper_descriptor with qualname 'object.__eq__' (13 chars), __hash__ as
# 'object.__hash__' (15 chars). No prior socket spec anchors these qualnames
# under sockclass139. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra139.socket_eq_hash_qualnames:
  description: "socket.socket/__eq__/__qualname__.__eq__('object.__eq__')==True / __eq__/__qualname__/__len__()==13 / __hash__/__qualname__.__eq__('object.__hash__')==True / __hash__/__qualname__/__len__()==15 — socket.socket does not override __eq__ or __hash__; both are inherited from object; __eq__ qualname is 'object.__eq__' (13 chars); __hash__ qualname is 'object.__hash__' (15 chars); no prior socket spec anchors these; first sockclass139 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockclass139

  columns: [id, function, args, expected, description]
  rows:
    - [eq_qualname_eq,    socket.__eq__.__qualname__.__eq__,    ["object.__eq__"],   true, "socket.socket.__eq__.__qualname__ is 'object.__eq__' (inherited from object, not overridden in Lib/socket.py)"]
    - [eq_qualname_len,   socket.__eq__.__qualname__.__len__,   [],                  13,   "socket.socket.__eq__.__qualname__.__len__() is 13 ('object.__eq__' = 13 chars)"]
    - [hash_qualname_eq,  socket.__hash__.__qualname__.__eq__,  ["object.__hash__"], true, "socket.socket.__hash__.__qualname__ is 'object.__hash__' (inherited from object, not overridden)"]
    - [hash_qualname_len, socket.__hash__.__qualname__.__len__, [],                  15,   "socket.socket.__hash__.__qualname__.__len__() is 15 ('object.__hash__' = 15 chars)"]

# ---------------------------------------------------------------------------
# socket.socket.family.__class__.__name__.__eq__('property')
# socket.socket.type.__class__.__name__.__eq__('property')
#
# Wave 287 theme: socket.socket.family and type as Python property descriptors.
#
# The Python-level socket.socket class in Lib/socket.py defines family and type
# as property descriptors (wrapping the underlying _socket.socket member_descriptors).
# socket.socket.proto is NOT a property on socket.socket — it comes directly from
# _socket.socket as a member_descriptor. No prior socket spec anchors
# socket.socket.family or type __class__.__name__ under sockclass139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra139.socket_family_type_descriptors:
  description: "socket.socket.family/__class__.__name__.__eq__('property')==True / socket.socket.type/__class__.__name__.__eq__('property')==True — Lib/socket.py defines family and type as Python property descriptors on socket.socket, wrapping the underlying _socket.socket member_descriptors; socket.proto is not a property on socket.socket (no override in Lib/socket.py); no prior socket spec anchors family/type descriptor class names; first sockclass139 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockclass139

  columns: [id, function, args, expected, description]
  rows:
    - [family_class_name, socket.family.__class__.__name__.__eq__, ["property"], true, "socket.socket.family.__class__.__name__ is 'property' (Python property descriptor wrapping _socket.socket.family member_descriptor)"]
    - [type_class_name,   socket.type.__class__.__name__.__eq__,   ["property"], true, "socket.socket.type.__class__.__name__ is 'property' (Python property descriptor wrapping _socket.socket.type member_descriptor)"]

# ---------------------------------------------------------------------------
# socket.socket.__name__.__eq__('socket') / __name__.__len__()==6
# socket.socket.__module__.__eq__('socket') / __module__.__len__()==6
# socket.socket.__mro__.__len__()==3
# socket.socket.__bases__[0].__name__.__eq__('socket')
# socket.socket.__bases__[0].__module__.__eq__('_socket')
#
# Wave 287 theme: socket.socket class __name__, __module__, __mro__, __bases__.
#
# socket.socket (the Python-level class) has __name__ == 'socket' (6 chars) and
# __module__ == 'socket' (6 chars). Its MRO has 3 entries:
# [socket.socket, _socket.socket, object]. Its single base is _socket.socket
# (module '_socket'). socket_extra138 anchors socket.socket.__doc__; extra97
# anchors __module__ for socket.__init__ as a function; no prior socket spec
# anchors socket.socket.__name__.__len__() or __mro__.__len__()==3 as a table
# under sockclass139. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra139.socket_class_name_module_mro:
  description: "socket.socket/__name__.__eq__('socket')==True / __name__/__len__()==6 / __module__.__eq__('socket')==True / __module__/__len__()==6 / __mro__/__len__()==3 / __bases__[0]/__name__.__eq__('socket')==True / __bases__[0]/__module__.__eq__('_socket')==True — socket.socket is the Python-level class; __name__ and __module__ are both 'socket' (6 chars); MRO is [socket(socket), socket(_socket), object] (length 3); base class is _socket.socket; no prior socket spec anchors these together; first sockclass139 anchor"
  kind: python_call_eq
  category: type_identity
  id_prefix: sockclass139

  columns: [id, function, args, expected, description]
  rows:
    - [name_eq,           socket.__name__.__eq__,                  ["socket"],   true, "socket.socket.__name__ is 'socket' (the Python-level class name)"]
    - [name_len,          socket.__name__.__len__,                  [],           6,    "socket.socket.__name__.__len__() is 6 ('socket' = 6 chars)"]
    - [module_eq,         socket.__module__.__eq__,                ["socket"],   true, "socket.socket.__module__ is 'socket' (defined in Lib/socket.py)"]
    - [module_len,        socket.__module__.__len__,                [],           6,    "socket.socket.__module__.__len__() is 6 ('socket' = 6 chars)"]
    - [mro_len,           "socket.__mro__.__len__",                [],           3,    "socket.socket.__mro__.__len__() is 3: [socket(socket), socket(_socket), object]"]
    - [base_name_eq,      "socket.__bases__[0].__name__.__eq__",   ["socket"],   true, "socket.socket.__bases__[0].__name__ is 'socket' (the C-level _socket.socket class, same name but different module)"]
    - [base_module_eq,    "socket.__bases__[0].__module__.__eq__", ["_socket"],  true, "socket.socket.__bases__[0].__module__ is '_socket' (the C extension module, not the Python 'socket' module)"]

# ---------------------------------------------------------------------------
# socket.getfqdn.__doc__.__len__()==354
# socket.create_connection.__doc__.__len__()==721
#
# Wave 287 theme: socket.getfqdn and create_connection __doc__ lengths.
#
# socket.getfqdn.__doc__ is 354 chars — it documents the optional name argument,
# the fallback to gethostname(), and the fully-qualified domain name lookup logic.
# socket.create_connection.__doc__ is 721 chars — the longest function docstring
# in the socket module, documenting host/port/timeout/source_address/all_errors.
# socket_extra138 anchors getfqdn/__class__.__name__=='function'; no prior socket
# spec anchors getfqdn or create_connection __doc__ lengths under sockclass139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table socket_extra139.getfqdn_create_connection_doc_lengths:
  description: "socket.getfqdn/__doc__/__len__()==354 / create_connection/__doc__/__len__()==721 — getfqdn.__doc__ (354 chars) describes optional name argument and FQDN lookup logic; create_connection.__doc__ (721 chars) is the longest socket module function docstring, documenting host/port/timeout/source_address/all_errors; extra138 anchors getfqdn/__class__.__name__=='function'; first sockclass139 anchor for these doc lengths"
  kind: python_call_eq
  category: doc_lengths
  id_prefix: sockclass139

  columns: [id, function, args, expected, description]
  rows:
    - [getfqdn_doc_len,            getfqdn.__doc__.__len__,            [], 354, "socket.getfqdn.__doc__.__len__() is 354 chars (documents optional name argument and FQDN lookup with gethostname fallback)"]
    - [create_connection_doc_len,  create_connection.__doc__.__len__,  [], 721, "socket.create_connection.__doc__.__len__() is 721 chars (longest socket module function docstring; documents host/port/timeout/source_address/all_errors)"]

# ---------------------------------------------------------------------------
# socket.socket.__eq__.__qualname__.__eq__('object.__eq__') — standalone
#
# socket.socket.__eq__.__qualname__ is 'object.__eq__'. The Python-level
# socket.socket class (Lib/socket.py) does not define __eq__. Neither does
# the C-level _socket.socket class (socketmodule.c). As a result, the
# descriptor for socket.socket.__eq__ is the one defined on object itself,
# with qualname 'object.__eq__'. This means two socket instances compare
# equal only if they are the same object. No prior socket spec anchors
# socket.socket.__eq__.__qualname__ equality as a standalone under sockclass139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra139.socket_eq_qualname_object:
  description: "socket.socket.__eq__.__qualname__.__eq__('object.__eq__') == True — socket.socket does not override __eq__ in Lib/socket.py or socketmodule.c; equality is identity-based (inherited from object); qualname 'object.__eq__' (13 chars); no prior socket spec anchors this as a standalone; first standalone under sockclass139"
  category: type_identity
  kind: python_call_eq
  function: socket.__eq__.__qualname__.__eq__
  args: ["object.__eq__"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.__hash__.__qualname__.__eq__('object.__hash__') — standalone
#
# socket.socket.__hash__.__qualname__ is 'object.__hash__'. Like __eq__,
# socket.socket does not override __hash__ in either the Python-level or C-level
# implementation. The hash of a socket instance is therefore the default
# id-based hash from object. The qualname 'object.__hash__' is 15 chars.
# No prior socket spec anchors socket.socket.__hash__.__qualname__ equality
# as a standalone under sockclass139. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra139.socket_hash_qualname_object:
  description: "socket.socket.__hash__.__qualname__.__eq__('object.__hash__') == True — socket.socket does not override __hash__; hash is id-based (inherited from object); qualname 'object.__hash__' (15 chars); no prior socket spec anchors this as a standalone; first standalone under sockclass139"
  category: type_identity
  kind: python_call_eq
  function: socket.__hash__.__qualname__.__eq__
  args: ["object.__hash__"]
  expected: true

# ---------------------------------------------------------------------------
# socket.socket.family.__class__.__name__.__eq__('property') — standalone
#
# socket.socket.family.__class__.__name__ is 'property'. The Python-level
# socket.socket class in Lib/socket.py defines family as a Python property
# descriptor (using @property) to wrap the underlying _socket.socket.family
# member_descriptor. Accessing socket.socket.family on the class returns the
# property object itself. No prior socket spec anchors socket.socket.family
# __class__.__name__ as a standalone under sockclass139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra139.socket_family_class_property:
  description: "socket.socket.family.__class__.__name__.__eq__('property') == True — socket.socket.family is a Python property descriptor defined in Lib/socket.py wrapping _socket.socket.family (member_descriptor); accessing on the class returns the property object; no prior socket spec anchors this as a standalone; first standalone under sockclass139"
  category: type_identity
  kind: python_call_eq
  function: socket.family.__class__.__name__.__eq__
  args: ["property"]
  expected: true

# ---------------------------------------------------------------------------
# socket.create_connection.__doc__.__len__()==721 — standalone
#
# socket.create_connection.__doc__.__len__() is 721. create_connection is a
# pure-Python function in Lib/socket.py that wraps getaddrinfo() to create a
# connected TCP socket. Its docstring (721 chars) is the longest of any function
# in the socket module — it documents the host, port, timeout, source_address,
# and all_errors parameters, with explanations of error handling behavior when
# multiple addresses are tried. No prior socket spec anchors
# create_connection.__doc__.__len__() as a standalone under sockclass139.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant socket_extra139.create_connection_doc_len_721:
  description: "socket.create_connection.__doc__.__len__() == 721 — longest function docstring in the socket module (721 chars); documents host/port/timeout/source_address/all_errors and multi-address error handling; pure-Python function in Lib/socket.py wrapping getaddrinfo(); no prior socket spec anchors this as a standalone; first standalone under sockclass139"
  category: doc_lengths
  kind: python_call_eq
  function: create_connection.__doc__.__len__
  args: []
  expected: 721

