spec: asyncio_extra208
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/tasks.py, Lib/asyncio/queues.py"
  notes:
    - "asyncio.sleep.__code__.co_varnames.__class__.__name__ == 'tuple' — co_varnames is always a tuple of local variable names; asyncio.sleep co_varnames is ('delay', 'result', 'loop', 'future', 'h') on Python 3.14.3."
    - "asyncio.sleep.__code__.co_varnames.__contains__('delay') returns True — 'delay' is the first positional parameter of asyncio.sleep(delay=0, result=None)."
    - "asyncio.Task.__dict__.__contains__('cancel') returns True — Task defines cancel() directly in its class body; Task.cancel is in asyncio.tasks."
    - "asyncio.Task.__dict__.__contains__('result') returns True — Task.result() is defined directly on the class; returns the result or raises an exception."
    - "asyncio.Queue.__dict__.__contains__('put') returns True — Queue.put() is defined directly on the class in asyncio.queues."
    - "asyncio.Queue.__dict__.__contains__('get') returns True — Queue.get() is defined directly on the class."
    - "asyncio.Task public non-dunder dict keys include: result, exception, add_done_callback, remove_done_callback, cancelled, done, set_result, set_exception, cancel, cancelling, uncancel, get_stack, print_stack, get_name, set_name, get_coro, get_context."
    - "asyncio.Queue public non-dunder dict keys include: qsize, maxsize, empty, full, put, put_nowait, get, get_nowait, task_done, join, shutdown."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: asyncio.sleep co_varnames type and membership checks
#
# asyncio.sleep.__code__.co_varnames.__class__.__name__  == 'tuple'
# asyncio.sleep.__code__.co_varnames.__contains__('delay')  == True
# asyncio.sleep.__code__.co_varnames.__contains__('result') == True
# asyncio.sleep.__code__.co_varnames.__contains__('future') == True
# ---------------------------------------------------------------------------

table asyncio_extra208.sleep_covarnames:
  description: "asyncio.sleep __code__.co_varnames type and membership checks in asynciocovarnames208 namespace — sleep.__code__.co_varnames.__class__.__name__=='tuple' (co_varnames is always a tuple of parameter and local variable name strings); co_varnames.__contains__('delay')==True ('delay' is the first positional param of asyncio.sleep(delay=0, result=None)); co_varnames.__contains__('result')==True ('result' is the second param); co_varnames.__contains__('future')==True ('future' is a local variable created inside sleep); full co_varnames on 3.14.3 is ('delay', 'result', 'loop', 'future', 'h'); verified with Python 3.14.3"
  kind: python_call_eq
  category: covarnames
  id_prefix: asynciocovarnames208

  columns: [id, function, args, expected, description]
  rows:
    - [sleep_covarnames_class_name,   "asyncio.sleep.__code__.co_varnames.__class__.__name__.__eq__",   ["tuple"], true, "asyncio.sleep.__code__.co_varnames.__class__.__name__ == 'tuple'; verified Python 3.14.3"]
    - [sleep_covarnames_has_delay,    "asyncio.sleep.__code__.co_varnames.__contains__",                ["delay"], true, "asyncio.sleep.__code__.co_varnames.__contains__('delay') — delay is first param; verified Python 3.14.3"]
    - [sleep_covarnames_has_result,   "asyncio.sleep.__code__.co_varnames.__contains__",                ["result"], true, "asyncio.sleep.__code__.co_varnames.__contains__('result') — result is second param; verified Python 3.14.3"]
    - [sleep_covarnames_has_future,   "asyncio.sleep.__code__.co_varnames.__contains__",                ["future"], true, "asyncio.sleep.__code__.co_varnames.__contains__('future') — future is a local var; verified Python 3.14.3"]

