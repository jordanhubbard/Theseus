# asyncio.Task.__dict__.__contains__('result')             == True
# asyncio.Task.__dict__.__contains__('done')               == True
# asyncio.Task.__dict__.__contains__('add_done_callback')  == True
# ---------------------------------------------------------------------------

table asyncio_extra208.task_dict_membership:
  description: "asyncio.Task.__dict__ membership checks in asynciocovarnames208 namespace — Task.__dict__.__contains__('cancel')==True (Task.cancel() is defined directly on the class; it cancels the task and schedules it to raise CancelledError); Task.__dict__.__contains__('result')==True (Task.result() returns the result or re-raises the stored exception); Task.__dict__.__contains__('done')==True (Task.done() returns True if the task is finished); Task.__dict__.__contains__('add_done_callback')==True; all four methods are defined in asyncio.tasks on Python 3.14.3; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: asynciocovarnames208a

  columns: [id, function, args, expected, description]
  rows:
    - [task_dict_has_cancel,            "asyncio.Task.__dict__.__contains__",   ["cancel"],            true, "asyncio.Task.__dict__.__contains__('cancel') == True; verified Python 3.14.3"]
    - [task_dict_has_result,            "asyncio.Task.__dict__.__contains__",   ["result"],            true, "asyncio.Task.__dict__.__contains__('result') == True; verified Python 3.14.3"]
    - [task_dict_has_done,              "asyncio.Task.__dict__.__contains__",   ["done"],              true, "asyncio.Task.__dict__.__contains__('done') == True; verified Python 3.14.3"]
    - [task_dict_has_add_done_callback, "asyncio.Task.__dict__.__contains__",   ["add_done_callback"], true, "asyncio.Task.__dict__.__contains__('add_done_callback') == True; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Table 3: asyncio.Queue.__dict__ membership checks
#
# asyncio.Queue.__dict__.__contains__('put')    == True
# asyncio.Queue.__dict__.__contains__('get')    == True
# asyncio.Queue.__dict__.__contains__('empty')  == True
# asyncio.Queue.__dict__.__contains__('qsize')  == True
# ---------------------------------------------------------------------------

table asyncio_extra208.queue_dict_membership:
  description: "asyncio.Queue.__dict__ membership checks in asynciocovarnames208 namespace — Queue.__dict__.__contains__('put')==True (Queue.put() is a coroutine that adds an item, blocking until space is available); Queue.__dict__.__contains__('get')==True (Queue.get() is a coroutine that removes and returns an item, blocking until available); Queue.__dict__.__contains__('empty')==True (Queue.empty() returns True if the queue is empty); Queue.__dict__.__contains__('qsize')==True (Queue.qsize() returns the number of items); all four methods are defined directly on asyncio.Queue in asyncio.queues on Python 3.14.3; verified with Python 3.14.3"
  kind: python_call_eq
  category: dict_membership
  id_prefix: asynciocovarnames208b

  columns: [id, function, args, expected, description]
  rows:
    - [queue_dict_has_put,   "asyncio.Queue.__dict__.__contains__",   ["put"],   true, "asyncio.Queue.__dict__.__contains__('put') == True; verified Python 3.14.3"]
    - [queue_dict_has_get,   "asyncio.Queue.__dict__.__contains__",   ["get"],   true, "asyncio.Queue.__dict__.__contains__('get') == True; verified Python 3.14.3"]
    - [queue_dict_has_empty, "asyncio.Queue.__dict__.__contains__",   ["empty"], true, "asyncio.Queue.__dict__.__contains__('empty') == True; verified Python 3.14.3"]
    - [queue_dict_has_qsize, "asyncio.Queue.__dict__.__contains__",   ["qsize"], true, "asyncio.Queue.__dict__.__contains__('qsize') == True; verified Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — asyncio_extra208
# ---------------------------------------------------------------------------

invariant asyncio_extra208.sleep_covarnames_class_name_tuple:
  description: "asyncio.sleep.__code__.co_varnames.__class__.__name__.__eq__('tuple') returns True — asyncio.sleep.__code__.co_varnames is always a tuple of local variable name strings; co_varnames includes all parameter names and local names assigned inside the function body; sleep co_varnames on Python 3.14.3 is ('delay', 'result', 'loop', 'future', 'h') (length 5); co_varnames.__class__.__name__ is 'tuple' (len=5: t-u-p-l-e); NEW in extra208: first standalone asyncio.sleep co_varnames class name invariant; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: covarnames
  kind: python_call_eq
  function: asyncio.sleep.__code__.co_varnames.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant asyncio_extra208.sleep_covarnames_contains_delay:
  description: "asyncio.sleep.__code__.co_varnames.__contains__('delay') returns True — 'delay' is the first positional parameter of asyncio.sleep(delay=0, result=None); it appears as the first element of co_varnames; the default value of delay is 0 (a coroutine that yields to the event loop then resumes after delay seconds); co_varnames is ('delay', 'result', 'loop', 'future', 'h') on Python 3.14.3; 'delay' in co_varnames is True; NEW in extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: covarnames
  kind: python_call_eq
  function: asyncio.sleep.__code__.co_varnames.__contains__
  args: ["delay"]
  expected: true

invariant asyncio_extra208.task_dict_contains_cancel:
  description: "asyncio.Task.__dict__.__contains__('cancel') returns True — asyncio.Task defines cancel() directly in its class body in Lib/asyncio/tasks.py; Task.cancel(msg=None) requests cancellation by scheduling CancelledError to be thrown into the coroutine; 'cancel' is in Task.__dict__ (not inherited from a base class); Task also has cancelling() and uncancel() for nested cancellation tracking (Python 3.11+); NEW in extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Task.__dict__.__contains__
  args: ["cancel"]
  expected: true

invariant asyncio_extra208.task_dict_contains_result:
  description: "asyncio.Task.__dict__.__contains__('result') returns True — asyncio.Task defines result() directly in its class body; Task.result() returns the result of the wrapped coroutine, or re-raises the stored exception if the coroutine raised; if the task was cancelled it raises CancelledError; 'result' is in Task.__dict__ (not inherited); NEW in extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Task.__dict__.__contains__
  args: ["result"]
  expected: true

invariant asyncio_extra208.queue_dict_contains_put:
  description: "asyncio.Queue.__dict__.__contains__('put') returns True — asyncio.Queue defines put() directly in its class body in Lib/asyncio/queues.py; Queue.put(item) is a coroutine that puts an item into the queue, blocking until a free slot is available if the queue is full (maxsize > 0); 'put' is in Queue.__dict__ (not inherited); Queue also has put_nowait() for non-blocking puts; NEW in extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Queue.__dict__.__contains__
  args: ["put"]
  expected: true

invariant asyncio_extra208.queue_dict_contains_get:
  description: "asyncio.Queue.__dict__.__contains__('get') returns True — asyncio.Queue defines get() directly in its class body; Queue.get() is a coroutine that removes and returns an item from the queue, blocking until an item is available if the queue is empty; 'get' is in Queue.__dict__ (not inherited); Queue also has get_nowait() for non-blocking gets; NEW in extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Queue.__dict__.__contains__
  args: ["get"]
  expected: true

invariant asyncio_extra208.sleep_covarnames_len:
  description: "asyncio.sleep.__code__.co_varnames.__len__() returns 5 — asyncio.sleep co_varnames has exactly 5 entries on Python 3.14.3: ('delay', 'result', 'loop', 'future', 'h'); 'delay' and 'result' are parameters; 'loop', 'future', 'h' are local variables; len==5 confirms the exact tuple length; NEW in extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: covarnames
  kind: python_call_eq
  function: asyncio.sleep.__code__.co_varnames.__len__
  args: []
  expected: 5

invariant asyncio_extra208.task_dict_contains_done:
  description: "asyncio.Task.__dict__.__contains__('done') returns True — asyncio.Task defines done() directly on the class; Task.done() returns True when the task is finished (completed normally, raised an exception, or was cancelled); 'done' is in Task.__dict__ (not inherited from a base class); Task.done() returns False while the coroutine is still running; NEW in extra208; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: dict_membership
  kind: python_call_eq
  function: asyncio.Task.__dict__.__contains__
  args: ["done"]
  expected: true
