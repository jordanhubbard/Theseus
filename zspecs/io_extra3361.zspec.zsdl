spec: io3361
version: ">=3.9"
backend: python_module(io)
docs: https://docs.python.org/3/library/io.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/io.html — io: Core tools for working with streams"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 671 (io3361): __invert__, __floor__, __ceil__ dict-presence checks for io types."
    - "Classes covered: io.RawIOBase, io.BufferedIOBase, io.TextIOBase, io.FileIO, io.BytesIO, io.StringIO, io.BufferedReader, io.BufferedWriter, io.BufferedRandom, io.BufferedRWPair, io.TextIOWrapper."
    - "Theme: __invert__, __floor__, __ceil__ dict-presence (~x, math.floor(x), math.ceil(x))."
    - "No io class defines __invert__ in its own __dict__: stream I/O classes are sequential I/O abstractions, not integer types; bitwise inversion (~x) has no meaning for I/O streams."
    - "No io class defines __floor__ in its own __dict__: stream I/O classes are not numeric types; math.floor() has no meaning for I/O stream objects."
    - "No io class defines __ceil__ in its own __dict__: stream I/O classes are not numeric types; math.ceil() has no meaning for I/O stream objects."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all unary arithmetic and rounding operators absent from io class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __invert__ dict-presence — operator.contains(Cls.__dict__, '__invert__')
#
# No io class defines __invert__ in its own __dict__; all false.
# io stream classes are sequential I/O abstractions, not integer types,
# and do not implement the bitwise inversion operator (~x).
# ---------------------------------------------------------------------------

table io3361.invert:
  description: "io types __invert__ dict-presence checks; wave 671"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
