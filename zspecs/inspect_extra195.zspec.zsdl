spec: inspect_extra195
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "inspect.getmembers.__name__ == 'getmembers' (len=10); getmembers returns all members of an object as (name, value) pairs; it is a plain Python function defined in inspect.py; verified with Python 3.14.3."
    - "inspect.getmembers.__module__ == 'inspect' (len=7); defined at top level in inspect.py; verified with Python 3.14.3."
    - "inspect.getmembers.__qualname__ == 'getmembers' (len=10); top-level function so qualname equals name; verified with Python 3.14.3."
    - "inspect.getmodule.__name__ == 'getmodule' (len=9); getmodule tries to guess the module in which an object was defined; it is a plain Python function in inspect.py; verified with Python 3.14.3."
    - "inspect.getmodule.__module__ == 'inspect' (len=7); defined at top level in inspect.py; verified with Python 3.14.3."
    - "inspect.getsource.__name__ == 'getsource' (len=9); getsource returns the text of the source code for an object; it is a plain Python function in inspect.py; verified with Python 3.14.3."
    - "inspect.getsource.__module__ == 'inspect' (len=7); defined at top level in inspect.py; verified with Python 3.14.3."
    - "inspect.getsourcelines.__name__ == 'getsourcelines' (len=14); getsourcelines returns a list of source lines and starting line number; it is a plain Python function in inspect.py; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: inspect.getmembers name, module, and qualname identity
#
# inspect.getmembers.__name__    == 'getmembers' (len=10)
# inspect.getmembers.__module__  == 'inspect' (len=7)
# inspect.getmembers.__qualname__ == 'getmembers' (len=10)
#
# getmembers is a plain Python function defined at top level in inspect.py.
# New to extra195.
# ---------------------------------------------------------------------------

table inspect_extra195.getmembers_name_module_qualname:
  description: "inspect.getmembers identity: __name__=='getmembers'(len=10); __module__=='inspect'(len=7); __qualname__=='getmembers'(len=10); new to extra195"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgetmembers195

  columns: [id, function, args, expected, description]
  rows:
    - [gm_name_eq,
       getmembers.__name__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__name__.__eq__('getmembers') == True — getmembers returns all members of an object as (name, value) pairs; __name__ is 'getmembers' (len=10); str.__eq__('getmembers') returns True; verified with Python 3.14.3; new to extra195"]
    - [gm_name_len,
       getmembers.__name__.__len__,
       [],
       10,
       "inspect.getmembers.__name__.__len__() == 10 — 'getmembers' has 10 characters; str.__len__() returns 10; verified with Python 3.14.3; new to extra195"]
    - [gm_module_eq,
       getmembers.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getmembers.__module__.__eq__('inspect') == True — getmembers is defined at top level in inspect.py; __module__ is 'inspect' (len=7); str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra195"]
    - [gm_module_len,
       getmembers.__module__.__len__,
       [],
       7,
       "inspect.getmembers.__module__.__len__() == 7 — 'inspect' has 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; verified with Python 3.14.3; new to extra195"]
    - [gm_qualname_eq,
       getmembers.__qualname__.__eq__,
       ["getmembers"],
       true,
       "inspect.getmembers.__qualname__.__eq__('getmembers') == True — getmembers is a top-level function so qualname equals name; __qualname__ is 'getmembers' (len=10); str.__eq__('getmembers') returns True; verified with Python 3.14.3; new to extra195"]

# ---------------------------------------------------------------------------
# Table 2: inspect.getmodule name and module identity
#
# inspect.getmodule.__name__   == 'getmodule' (len=9)
# inspect.getmodule.__module__ == 'inspect' (len=7)
# inspect.getsource.__name__   == 'getsource' (len=9)
#
# getmodule and getsource are plain Python functions in inspect.py. New to extra195.
# ---------------------------------------------------------------------------

table inspect_extra195.getmodule_getsource_identity:
  description: "inspect.getmodule and getsource identity: getmodule.__name__=='getmodule'(len=9); getmodule.__module__=='inspect'(len=7); getsource.__name__=='getsource'(len=9); new to extra195"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgetmembers195

  columns: [id, function, args, expected, description]
  rows:
    - [gmod_name_eq,
       getmodule.__name__.__eq__,
       ["getmodule"],
       true,
       "inspect.getmodule.__name__.__eq__('getmodule') == True — getmodule tries to guess the module in which an object was defined; __name__ is 'getmodule' (len=9); str.__eq__('getmodule') returns True; verified with Python 3.14.3; new to extra195"]
    - [gmod_name_len,
       getmodule.__name__.__len__,
       [],
       9,
       "inspect.getmodule.__name__.__len__() == 9 — 'getmodule' has 9 characters: g-e-t-m-o-d-u-l-e; str.__len__() returns 9; verified with Python 3.14.3; new to extra195"]
    - [gmod_module_eq,
       getmodule.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getmodule.__module__.__eq__('inspect') == True — getmodule is defined at top level in inspect.py; __module__ is 'inspect' (len=7); str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra195"]
    - [gsrc_name_eq,
       getsource.__name__.__eq__,
       ["getsource"],
       true,
       "inspect.getsource.__name__.__eq__('getsource') == True — getsource returns the text of the source code for an object; __name__ is 'getsource' (len=9); str.__eq__('getsource') returns True; verified with Python 3.14.3; new to extra195"]
    - [gsrc_name_len,
       getsource.__name__.__len__,
       [],
       9,
       "inspect.getsource.__name__.__len__() == 9 — 'getsource' has 9 characters: g-e-t-s-o-u-r-c-e; str.__len__() returns 9; verified with Python 3.14.3; new to extra195"]

# ---------------------------------------------------------------------------
# Table 3: inspect.getsource module and getsourcelines name identity
#
# inspect.getsource.__module__       == 'inspect' (len=7)
# inspect.getsourcelines.__name__    == 'getsourcelines' (len=14)
# inspect.getsourcelines.__module__  == 'inspect' (len=7)
#
# getsource and getsourcelines are plain Python functions in inspect.py. New to extra195.
# ---------------------------------------------------------------------------

table inspect_extra195.getsource_module_getsourcelines_identity:
  description: "inspect.getsource and getsourcelines: getsource.__module__=='inspect'(len=7); getsourcelines.__name__=='getsourcelines'(len=14); getsourcelines.__module__=='inspect'(len=7); new to extra195"
  kind: python_call_eq
  category: identity
  id_prefix: inspectgetmembers195

  columns: [id, function, args, expected, description]
  rows:
    - [gsrc_module_eq,
       getsource.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsource.__module__.__eq__('inspect') == True — getsource is defined at top level in inspect.py; __module__ is 'inspect' (len=7); str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra195"]
    - [gsrc_module_len,
       getsource.__module__.__len__,
       [],
       7,
       "inspect.getsource.__module__.__len__() == 7 — 'inspect' has 7 characters: i-n-s-p-e-c-t; str.__len__() returns 7; verified with Python 3.14.3; new to extra195"]
    - [gsl_name_eq,
       getsourcelines.__name__.__eq__,
       ["getsourcelines"],
       true,
       "inspect.getsourcelines.__name__.__eq__('getsourcelines') == True — getsourcelines returns a list of source lines and starting line number; __name__ is 'getsourcelines' (len=14); str.__eq__('getsourcelines') returns True; verified with Python 3.14.3; new to extra195"]
    - [gsl_name_len,
       getsourcelines.__name__.__len__,
       [],
       14,
       "inspect.getsourcelines.__name__.__len__() == 14 — 'getsourcelines' has 14 characters; str.__len__() returns 14; verified with Python 3.14.3; new to extra195"]
    - [gsl_module_eq,
       getsourcelines.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.getsourcelines.__module__.__eq__('inspect') == True — getsourcelines is defined at top level in inspect.py; __module__ is 'inspect' (len=7); str.__eq__('inspect') returns True; verified with Python 3.14.3; new to extra195"]

