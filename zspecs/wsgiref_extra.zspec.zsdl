spec: wsgiref_extra
version: ">=3.9"
backend: python_module(wsgiref.simple_server)

docs: https://docs.python.org/3/library/wsgiref.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/wsgiref.html — Python wsgiref documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/wsgiref/simple_server.py"
    - "CPython source: Lib/wsgiref/handlers.py"
  notes:
    - "This spec extends wsgiref.zspec.zsdl (which covers wsgiref.util functions and is_hop_by_hop/guess_scheme behavior)."
    - "wsgiref.simple_server provides a basic WSGI server built on http.server.HTTPServer."
    - "WSGIServer.__name__ == 'WSGIServer' — the WSGI-capable HTTP server class."
    - "WSGIServer.__module__ == 'wsgiref.simple_server' — defined in the simple_server submodule."
    - "WSGIServer inherits from HTTPServer: WSGIServer.__bases__[0].__name__ == 'HTTPServer'."
    - "WSGIRequestHandler.__name__ == 'WSGIRequestHandler' — handles individual HTTP requests in WSGI mode."
    - "WSGIRequestHandler.__module__ == 'wsgiref.simple_server'."
    - "WSGIRequestHandler inherits from BaseHTTPRequestHandler."
    - "make_server and demo_app are module-level functions in wsgiref.simple_server."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# WSGIServer — class name, module, and base class
# ---------------------------------------------------------------------------

invariant wsgiref_extra.WSGIServer.name:
  description: "wsgiref.simple_server.WSGIServer.__name__ == 'WSGIServer'"
  category: classes
  kind: python_call_eq
  function: WSGIServer.__name__.__eq__
  args: ["WSGIServer"]
  expected: true

invariant wsgiref_extra.WSGIServer.module:
  description: "wsgiref.simple_server.WSGIServer.__module__ == 'wsgiref.simple_server'"
  category: classes
  kind: python_call_eq
  function: WSGIServer.__module__.__eq__
  args: ["wsgiref.simple_server"]
  expected: true

invariant wsgiref_extra.WSGIServer.base_is_HTTPServer:
  description: "wsgiref.simple_server.WSGIServer.__bases__[0].__name__ == 'HTTPServer'"
  category: class_hierarchy
  kind: python_call_eq
  function: WSGIServer.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "HTTPServer"

invariant wsgiref_extra.WSGIServer.qualname:
  description: "wsgiref.simple_server.WSGIServer.__qualname__ == 'WSGIServer'"
  category: classes
  kind: python_call_eq
  function: WSGIServer.__qualname__.__eq__
  args: ["WSGIServer"]
  expected: true

# ---------------------------------------------------------------------------
# WSGIRequestHandler — class name, module, and base class
# ---------------------------------------------------------------------------

invariant wsgiref_extra.WSGIRequestHandler.name:
  description: "wsgiref.simple_server.WSGIRequestHandler.__name__ == 'WSGIRequestHandler'"
  category: classes
  kind: python_call_eq
  function: WSGIRequestHandler.__name__.__eq__
  args: ["WSGIRequestHandler"]
  expected: true

invariant wsgiref_extra.WSGIRequestHandler.module:
  description: "wsgiref.simple_server.WSGIRequestHandler.__module__ == 'wsgiref.simple_server'"
  category: classes
  kind: python_call_eq
  function: WSGIRequestHandler.__module__.__eq__
  args: ["wsgiref.simple_server"]
  expected: true

invariant wsgiref_extra.WSGIRequestHandler.base_is_BaseHTTPRequestHandler:
  description: "wsgiref.simple_server.WSGIRequestHandler.__bases__[0].__name__ == 'BaseHTTPRequestHandler'"
  category: class_hierarchy
  kind: python_call_eq
  function: WSGIRequestHandler.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "BaseHTTPRequestHandler"

# ---------------------------------------------------------------------------
# make_server — module-level factory function
# ---------------------------------------------------------------------------

invariant wsgiref_extra.make_server.name:
  description: "wsgiref.simple_server.make_server.__name__ == 'make_server'"
  category: functions
  kind: python_call_eq
  function: make_server.__name__.__eq__
  args: ["make_server"]
  expected: true

invariant wsgiref_extra.make_server.module:
  description: "wsgiref.simple_server.make_server.__module__ == 'wsgiref.simple_server'"
  category: functions
  kind: python_call_eq
  function: make_server.__module__.__eq__
  args: ["wsgiref.simple_server"]
  expected: true

# ---------------------------------------------------------------------------
# demo_app — module-level demo WSGI application
# ---------------------------------------------------------------------------

invariant wsgiref_extra.demo_app.name:
  description: "wsgiref.simple_server.demo_app.__name__ == 'demo_app'"
  category: functions
  kind: python_call_eq
  function: demo_app.__name__.__eq__
  args: ["demo_app"]
  expected: true

invariant wsgiref_extra.demo_app.module:
  description: "wsgiref.simple_server.demo_app.__module__ == 'wsgiref.simple_server'"
  category: functions
  kind: python_call_eq
  function: demo_app.__module__.__eq__
  args: ["wsgiref.simple_server"]
  expected: true
