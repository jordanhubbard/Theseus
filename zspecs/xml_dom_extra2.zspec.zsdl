spec: xml_dom_extra2
version: ">=3.0"
backend: python_module(xml.dom)

docs: https://docs.python.org/3/library/xml.dom.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/xml.dom.html — Python xml.dom documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/xml/dom/__init__.py"
  notes:
    - "This spec targets the xml.dom package itself (backend: python_module(xml.dom)), not xml.dom.minidom."
    - "xml_dom.zspec.zsdl and xml_dom_extra.zspec.zsdl use backend python_module(xml.dom.minidom) and cover minidom-specific symbols."
    - "This spec covers: xml.dom-level integer error code constants, exception subclass __name__ checks, namespace URI string constants, and UserDataHandler metadata."
    - "DOMException integer error codes are module-level constants on the xml.dom package (e.g. xml.dom.INDEX_SIZE_ERR == 1)."
    - "All DOM exception subclasses (HierarchyRequestErr, NotFoundErr, etc.) have DOMException as their sole base."
    - "DOMException itself inherits from Exception."
    - "xml.dom.EMPTY_NAMESPACE and xml.dom.EMPTY_PREFIX are both None."
    - "xml.dom.XML_NAMESPACE == 'http://www.w3.org/XML/1998/namespace'."
    - "xml.dom.XHTML_NAMESPACE == 'http://www.w3.org/1999/xhtml'."
    - "xml.dom.XMLNS_NAMESPACE == 'http://www.w3.org/2000/xmlns/'."
    - "UserDataHandler.__name__ == 'UserDataHandler'; __module__ == 'xml.dom'."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# DOMException error code integer constants (module-level on xml.dom)
# ---------------------------------------------------------------------------

table xml_dom_extra2.error_codes:
  kind: python_call_eq
  category: constants
  id_prefix: errc

  columns: [id, function, args, expected]
  rows:
    - [index_size,           INDEX_SIZE_ERR.__eq__,            [1],  true]
    - [domstring_size,       DOMSTRING_SIZE_ERR.__eq__,        [2],  true]
    - [hierarchy_request,    HIERARCHY_REQUEST_ERR.__eq__,     [3],  true]
    - [wrong_document,       WRONG_DOCUMENT_ERR.__eq__,        [4],  true]
    - [invalid_char,         INVALID_CHARACTER_ERR.__eq__,     [5],  true]
    - [no_data_allowed,      NO_DATA_ALLOWED_ERR.__eq__,       [6],  true]
    - [no_mod_allowed,       NO_MODIFICATION_ALLOWED_ERR.__eq__, [7], true]
    - [not_found,            NOT_FOUND_ERR.__eq__,             [8],  true]
    - [not_supported,        NOT_SUPPORTED_ERR.__eq__,         [9],  true]
    - [inuse_attribute,      INUSE_ATTRIBUTE_ERR.__eq__,       [10], true]
    - [invalid_state,        INVALID_STATE_ERR.__eq__,         [11], true]
    - [syntax,               SYNTAX_ERR.__eq__,                [12], true]
    - [invalid_modification, INVALID_MODIFICATION_ERR.__eq__,  [13], true]
    - [namespace,            NAMESPACE_ERR.__eq__,             [14], true]
    - [invalid_access,       INVALID_ACCESS_ERR.__eq__,        [15], true]
    - [validation,           VALIDATION_ERR.__eq__,            [16], true]

# ---------------------------------------------------------------------------
# Exception subclass __name__ checks
# ---------------------------------------------------------------------------

table xml_dom_extra2.exception_subclass_names:
  kind: python_call_eq
  category: classes
  id_prefix: excname

  columns: [id, function, args, expected]
  rows:
    - [hierarchy_request_err,     HierarchyRequestErr.__name__.__eq__,     ["HierarchyRequestErr"],     true]
    - [wrong_document_err,        WrongDocumentErr.__name__.__eq__,        ["WrongDocumentErr"],        true]
    - [invalid_character_err,     InvalidCharacterErr.__name__.__eq__,     ["InvalidCharacterErr"],     true]
    - [no_data_allowed_err,       NoDataAllowedErr.__name__.__eq__,        ["NoDataAllowedErr"],        true]
    - [no_modification_allowed,   NoModificationAllowedErr.__name__.__eq__, ["NoModificationAllowedErr"], true]
    - [not_found_err,             NotFoundErr.__name__.__eq__,             ["NotFoundErr"],             true]
    - [not_supported_err,         NotSupportedErr.__name__.__eq__,         ["NotSupportedErr"],         true]
    - [inuse_attribute_err,       InuseAttributeErr.__name__.__eq__,       ["InuseAttributeErr"],       true]
    - [invalid_state_err,         InvalidStateErr.__name__.__eq__,         ["InvalidStateErr"],         true]
    - [syntax_err,                SyntaxErr.__name__.__eq__,               ["SyntaxErr"],               true]
    - [invalid_modification_err,  InvalidModificationErr.__name__.__eq__,  ["InvalidModificationErr"],  true]
    - [namespace_err,             NamespaceErr.__name__.__eq__,            ["NamespaceErr"],            true]
    - [invalid_access_err,        InvalidAccessErr.__name__.__eq__,        ["InvalidAccessErr"],        true]

# ---------------------------------------------------------------------------
# DOMException base is Exception
# ---------------------------------------------------------------------------

invariant xml_dom_extra2.DOMException.base_is_exception:
  description: "xml.dom.DOMException.__bases__[0].__name__ == 'Exception'"
  category: classes
  kind: python_call_eq
  function: DOMException.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "Exception"

# ---------------------------------------------------------------------------
# HierarchyRequestErr base is DOMException
# ---------------------------------------------------------------------------

invariant xml_dom_extra2.HierarchyRequestErr.base_is_DOMException:
  description: "xml.dom.HierarchyRequestErr.__bases__[0].__name__ == 'DOMException'"
  category: classes
  kind: python_call_eq
  function: HierarchyRequestErr.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "DOMException"

# ---------------------------------------------------------------------------
# Namespace URI string constants
# ---------------------------------------------------------------------------

invariant xml_dom_extra2.xml_namespace:
  description: "xml.dom.XML_NAMESPACE == 'http://www.w3.org/XML/1998/namespace'"
  category: constants
  kind: python_call_eq
  function: XML_NAMESPACE.__eq__
  args: ["http://www.w3.org/XML/1998/namespace"]
  expected: true

invariant xml_dom_extra2.xmlns_namespace:
  description: "xml.dom.XMLNS_NAMESPACE == 'http://www.w3.org/2000/xmlns/'"
  category: constants
  kind: python_call_eq
  function: XMLNS_NAMESPACE.__eq__
  args: ["http://www.w3.org/2000/xmlns/"]
  expected: true

invariant xml_dom_extra2.xhtml_namespace:
  description: "xml.dom.XHTML_NAMESPACE == 'http://www.w3.org/1999/xhtml'"
  category: constants
  kind: python_call_eq
  function: XHTML_NAMESPACE.__eq__
  args: ["http://www.w3.org/1999/xhtml"]
  expected: true

# ---------------------------------------------------------------------------
# UserDataHandler class metadata
# ---------------------------------------------------------------------------

invariant xml_dom_extra2.UserDataHandler.name:
  description: "xml.dom.UserDataHandler.__name__ == 'UserDataHandler'"
  category: classes
  kind: python_call_eq
  function: UserDataHandler.__name__.__eq__
  args: ["UserDataHandler"]
  expected: true

invariant xml_dom_extra2.UserDataHandler.module:
  description: "xml.dom.UserDataHandler.__module__ == 'xml.dom'"
  category: classes
  kind: python_call_eq
  function: UserDataHandler.__module__.__eq__
  args: ["xml.dom"]
  expected: true
