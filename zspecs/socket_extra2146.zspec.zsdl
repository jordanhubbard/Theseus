spec: socket_extra2146
version: ">=3.9"
backend: python_module(socket)
error_model: python_exceptions
provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/socketmodule.c"
    - "_socket_extra.zspec.zsdl — covers _socket C extension class attrs"
    - "socket_extra2131.zspec.zsdl — covers exception protocol dict-presence wave"
  notes:
    - "Wave (_extra2146): numeric conversion protocol dict-presence — checking __trunc__, __floor__, __ceil__, __index__, __complex__, __bool__, __int__ in class __dict__."
    - "socket.socket is a non-numeric I/O type; none of the numeric conversion protocol methods appear in its __dict__."
    - "socket.error is an alias for OSError (socket.error is OSError evaluates True); its own __dict__ check uses socket.error but the dict is essentially OSError's dict — no numeric protocol methods present."
    - "socket.timeout (TimeoutError subclass) and socket.gaierror each have minimal own __dict__ entries (__doc__ only or similar); no numeric conversion methods."
    - "socket.AddressFamily is an IntEnum; its own __dict__ does NOT directly contain __int__, __index__, or __bool__ — those are inherited from IntEnum/int ancestors, not stored in AddressFamily.__dict__ itself."
    - "socket.SocketKind is an IntEnum; same situation as AddressFamily — numeric conversion methods not in SocketKind.__dict__ directly."
    - "All expected values (false) verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12"

table socket_extra2146.socket_trunc_floor_ceil:
  description: "socket.socket __dict__ numeric conversion dict-presence — __trunc__, __floor__, __ceil__ absent"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["sk2146001", "socket.socket.__dict__.__contains__", ["__trunc__"], false]
    - ["sk2146002", "socket.socket.__dict__.__contains__", ["__floor__"], false]
    - ["sk2146003", "socket.socket.__dict__.__contains__", ["__ceil__"], false]

