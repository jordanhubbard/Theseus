table socket_extra2146.socket_real_attrs:
  description: "socket.socket __dict__ positive presence — known real attributes confirm __dict__.__contains__ works for socket.socket"
  kind: python_call_eq
  category: dict_contains

  columns: [id, function, args, expected]
  rows:
    - ["sk2146043", "socket.socket.__dict__.__contains__", ["accept"],    true]
    - ["sk2146044", "socket.socket.__dict__.__contains__", ["dup"],       true]
    - ["sk2146045", "socket.socket.__dict__.__contains__", ["makefile"],  true]
    - ["sk2146046", "socket.socket.__dict__.__contains__", ["sendfile"],  true]
    - ["sk2146047", "socket.socket.__dict__.__contains__", ["close"],     true]

