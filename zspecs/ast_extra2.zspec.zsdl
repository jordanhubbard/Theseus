spec: ast_extra2
version: ">=3.2"
backend: python_module(ast)

docs: https://docs.python.org/3/library/ast.html

provenance:
  derived_from:
    - "CPython docs — https://docs.python.org/3/library/ast.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ast.py"
    - "CPython source: Python/Python-ast.c"
  notes:
    - "This spec covers ast behaviors not already in ast.zspec.zsdl or ast_extra.zspec.zsdl."
    - "literal_eval for int, str, list, dict, bool, None — all basic safe literal types."
    - "literal_eval('42') == 42 — integer round-trip."
    - "literal_eval('\"hello\"') == 'hello' — string round-trip."
    - "literal_eval('[1, 2, 3]') == [1, 2, 3] — list container round-trip."
    - "literal_eval('{\"a\": 1}') == {'a': 1} — dict container round-trip."
    - "literal_eval('True') == True — boolean literal."
    - "literal_eval('None') is None — None literal."
    - "get_docstring.__name__ == 'get_docstring' — public function in ast module."
    - "NodeVisitor.__name__ == 'NodeVisitor' — base class for tree walkers."
    - "NodeTransformer.__name__ == 'NodeTransformer' — subclass of NodeVisitor."
    - "fix_missing_locations.__name__ == 'fix_missing_locations' — fills lineno/col_offset for nodes missing them."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# literal_eval — basic types
# ---------------------------------------------------------------------------

invariant ast_extra2.literal_eval.int:
  description: "ast.literal_eval('42') == 42"
  category: literal_eval
  kind: python_call_eq
  function: literal_eval
  args: ["42"]
  expected: 42

invariant ast_extra2.literal_eval.str:
  description: "ast.literal_eval('\"hello\"') == 'hello'"
  category: literal_eval
  kind: python_call_eq
  function: literal_eval
  args: ["\"hello\""]
  expected: "hello"

invariant ast_extra2.literal_eval.list:
  description: "ast.literal_eval('[1, 2, 3]') == [1, 2, 3]"
  category: literal_eval
  kind: python_call_eq
  function: literal_eval
  args: ["[1, 2, 3]"]
  expected: [1, 2, 3]

invariant ast_extra2.literal_eval.dict:
  description: "ast.literal_eval('{\"a\": 1}') == {'a': 1}"
  category: literal_eval
  kind: python_call_eq
  function: literal_eval
  args: ["{\"a\": 1}"]
  expected: {"a": 1}

invariant ast_extra2.literal_eval.bool_true:
  description: "ast.literal_eval('True') == True"
  category: literal_eval
  kind: python_call_eq
  function: literal_eval
  args: ["True"]
  expected: true

invariant ast_extra2.literal_eval.none:
  description: "ast.literal_eval('None') is None"
  category: literal_eval
  kind: python_call_eq
  function: literal_eval
  args: ["None"]
  expected: null

# ---------------------------------------------------------------------------
# get_docstring — class name
# ---------------------------------------------------------------------------

invariant ast_extra2.get_docstring.name:
  description: "ast.get_docstring.__name__ == 'get_docstring'"
  category: get_docstring
  kind: python_call_eq
  function: get_docstring.__name__.__eq__
  args: ["get_docstring"]
  expected: true

# ---------------------------------------------------------------------------
# NodeVisitor — class name
# ---------------------------------------------------------------------------

invariant ast_extra2.NodeVisitor.name:
  description: "ast.NodeVisitor.__name__ == 'NodeVisitor'"
  category: node_visitor
  kind: python_call_eq
  function: NodeVisitor.__name__.__eq__
  args: ["NodeVisitor"]
  expected: true

# ---------------------------------------------------------------------------
# NodeTransformer — class name
# ---------------------------------------------------------------------------

invariant ast_extra2.NodeTransformer.name:
  description: "ast.NodeTransformer.__name__ == 'NodeTransformer'"
  category: node_transformer
  kind: python_call_eq
  function: NodeTransformer.__name__.__eq__
  args: ["NodeTransformer"]
  expected: true

# ---------------------------------------------------------------------------
# fix_missing_locations — function name
# ---------------------------------------------------------------------------

invariant ast_extra2.fix_missing_locations.name:
  description: "ast.fix_missing_locations.__name__ == 'fix_missing_locations'"
  category: fix_missing_locations
  kind: python_call_eq
  function: fix_missing_locations.__name__.__eq__
  args: ["fix_missing_locations"]
  expected: true
