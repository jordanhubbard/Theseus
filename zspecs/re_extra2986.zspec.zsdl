    - ["re2986008", operator.contains, [re.Match.__dict__,     "__length_hint__"], false]
    - ["re2986009", operator.contains, [re.RegexFlag.__dict__,               "__length_hint__"], false]
    - ["re2986010", operator.contains, [re.Pattern.__dict__,       "__length_hint__"], false]
    - ["re2986011", operator.contains, [re.Match.__dict__,     "__length_hint__"], false]
    - ["re2986012", operator.contains, [re.RegexFlag.__dict__,               "__length_hint__"], false]

# ---------------------------------------------------------------------------
# __contains__ dict-presence — operator.contains(Cls.__dict__, '__contains__')
#
# re.Pattern does not support 'in' operator; re.Match does not either.
# re.RegexFlag as IntFlag does not define __contains__ in its own __dict__.
# All false.
# ---------------------------------------------------------------------------

table re2986.contains:
  description: "re types __contains__ dict-presence checks; wave 646"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2986
  columns: [id, function, args, expected]
  rows:
    - ["re2986013", operator.contains, [re.Pattern.__dict__,       "__contains__"], false]
    - ["re2986014", operator.contains, [re.Match.__dict__,     "__contains__"], false]
    - ["re2986015", operator.contains, [re.RegexFlag.__dict__,               "__contains__"], false]
    - ["re2986016", operator.contains, [re.Pattern.__dict__,       "__contains__"], false]
    - ["re2986017", operator.contains, [re.Match.__dict__,     "__contains__"], false]
    - ["re2986018", operator.contains, [re.RegexFlag.__dict__,               "__contains__"], false]

