spec: re2986
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re module compiled pattern and match objects"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 646 (re2986): __len__, __length_hint__, __contains__ dict-presence checks for re types."
    - "re.Pattern (type(re.compile(''))) is a compiled regex object — not a container; no __len__ or __contains__."
    - "re.Match (type(re.match('', ''))) holds match results but does not implement container protocol slots."
    - "re.RegexFlag is an IntFlag enum subclass with bitwise semantics; it does not define __len__ or __contains__ in its own __dict__."
    - "None of the three re types define __len__, __length_hint__, or __contains__ in their own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __len__ dict-presence — operator.contains(Cls.__dict__, '__len__')
#
# Pattern, Match, and RegexFlag do not define __len__; all false.
# ---------------------------------------------------------------------------

table re2986.len:
  description: "re types __len__ dict-presence checks; wave 646"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2986
  columns: [id, function, args, expected]
  rows:
    - ["re2986001", operator.contains, [re.Pattern.__dict__,       "__len__"], false]
    - ["re2986002", operator.contains, [re.Match.__dict__,     "__len__"], false]
    - ["re2986003", operator.contains, [re.RegexFlag.__dict__,               "__len__"], false]
    - ["re2986004", operator.contains, [re.Pattern.__dict__,       "__len__"], false]
    - ["re2986005", operator.contains, [re.Match.__dict__,     "__len__"], false]
    - ["re2986006", operator.contains, [re.RegexFlag.__dict__,               "__len__"], false]

# ---------------------------------------------------------------------------
# __length_hint__ dict-presence — operator.contains(Cls.__dict__, '__length_hint__')
#
# re types are not iterators; none define __length_hint__; all false.
# ---------------------------------------------------------------------------

table re2986.length_hint:
  description: "re types __length_hint__ dict-presence checks; wave 646"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2986
