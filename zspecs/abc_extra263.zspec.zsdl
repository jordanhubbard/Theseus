spec: abc_extra263
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "abc.abstractmethod is a plain Python function; __class__.__name__ == 'function', __module__ == 'abc'."
    - "abc.abstractclassmethod and abc.abstractstaticmethod are deprecated but still present in Python 3.9–3.12; removed in Python 3.13."
    - "abc.abstractclassmethod and abc.abstractstaticmethod are classes (type), not functions."
    - "abc.abstractproperty is also a class (type); __class__.__name__ == 'type'."
    - "abc.ABC.__abstractmethods__ is an empty frozenset on the ABC helper class itself."
    - "abc.get_cache_token is a builtin function; __class__.__name__ == 'builtin_function_or_method', __module__ == '_abc'."
    - "abc.update_abstractmethods (Python 3.10+) is a plain Python function; __module__ == 'abc'."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abstractmethod identity — table
#
# abc.abstractmethod: __name__, __module__, __class__.__name__, __qualname__.
# Also covers abc.abstractclassmethod, abstractstaticmethod, abstractproperty
# (deprecated; present in Python <3.13).
# ---------------------------------------------------------------------------

table abc_extra263.decorator_names:
  description: "abc abstract decorator markers report the expected __name__ strings"
  kind: python_call_eq
  category: identity
  id_prefix: dname

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod,       abstractmethod.__name__.__eq__,       ["abstractmethod"],       true, "abstractmethod.__name__ == 'abstractmethod'"]
    - [abstractclassmethod,  abstractclassmethod.__name__.__eq__,  ["abstractclassmethod"],  true, "abstractclassmethod.__name__ == 'abstractclassmethod'"]
    - [abstractstaticmethod, abstractstaticmethod.__name__.__eq__, ["abstractstaticmethod"], true, "abstractstaticmethod.__name__ == 'abstractstaticmethod'"]
    - [abstractproperty,     abstractproperty.__name__.__eq__,     ["abstractproperty"],     true, "abstractproperty.__name__ == 'abstractproperty'"]

# ---------------------------------------------------------------------------
# decorator __module__ — table
#
# abstractmethod, abstractclassmethod, abstractstaticmethod, abstractproperty
# all report __module__ == 'abc'.
# ---------------------------------------------------------------------------

table abc_extra263.decorator_modules:
  description: "abc abstract decorator markers report __module__ == 'abc'"
  kind: python_call_eq
  category: identity
  id_prefix: dmod

  columns: [id, function, args, expected, description]
  rows:
    - [abstractmethod,       abstractmethod.__module__.__eq__,       ["abc"], true, "abstractmethod.__module__ == 'abc'"]
    - [abstractclassmethod,  abstractclassmethod.__module__.__eq__,  ["abc"], true, "abstractclassmethod.__module__ == 'abc'"]
    - [abstractstaticmethod, abstractstaticmethod.__module__.__eq__, ["abc"], true, "abstractstaticmethod.__module__ == 'abc'"]
    - [abstractproperty,     abstractproperty.__module__.__eq__,     ["abc"], true, "abstractproperty.__module__ == 'abc'"]

# ---------------------------------------------------------------------------
# abstractmethod __class__.__name__ and __qualname__ — standalone invariants
# ---------------------------------------------------------------------------

invariant abc_extra263.abstractmethod.class_name:
  description: "abc.abstractmethod.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__class__.__name__.__eq__
  args: ["function"]
  expected: true

invariant abc_extra263.abstractmethod.qualname:
  description: "abc.abstractmethod.__qualname__ == 'abstractmethod'"
  category: identity
  kind: python_call_eq
  function: abstractmethod.__qualname__.__eq__
  args: ["abstractmethod"]
  expected: true

# ---------------------------------------------------------------------------
# abstractclassmethod and abstractproperty are classes (type) — standalone invariants
# ---------------------------------------------------------------------------

invariant abc_extra263.abstractclassmethod.class_name:
  description: "abc.abstractclassmethod.__class__.__name__ == 'type'"
  category: identity
  kind: python_call_eq
  function: abstractclassmethod.__class__.__name__.__eq__
  args: ["type"]
  expected: true

invariant abc_extra263.abstractproperty.class_name:
  description: "abc.abstractproperty.__class__.__name__ == 'type'"
  category: identity
  kind: python_call_eq
  function: abstractproperty.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# ABC class identity — standalone invariants
#
# abc.ABC.__name__ == 'ABC' and __abstractmethods__ is an empty frozenset.
# ---------------------------------------------------------------------------

invariant abc_extra263.ABC.name:
  description: "abc.ABC.__name__ == 'ABC'"
  category: identity
  kind: python_call_eq
  function: ABC.__name__.__eq__
  args: ["ABC"]
  expected: true

invariant abc_extra263.ABC.abstractmethods_type:
  description: "type(abc.ABC.__abstractmethods__).__name__ == 'frozenset'"
  category: identity
  kind: python_call_eq
  function: ABC.__abstractmethods__.__class__.__name__.__eq__
  args: ["frozenset"]
  expected: true

# ---------------------------------------------------------------------------
# get_cache_token identity — standalone invariants
#
# abc.get_cache_token is a builtin function defined in the _abc C extension.
# ---------------------------------------------------------------------------

invariant abc_extra263.get_cache_token.name:
  description: "abc.get_cache_token.__name__ == 'get_cache_token'"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__name__.__eq__
  args: ["get_cache_token"]
  expected: true

invariant abc_extra263.get_cache_token.class_name:
  description: "abc.get_cache_token.__class__.__name__ == 'builtin_function_or_method'"
  category: identity
  kind: python_call_eq
  function: get_cache_token.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

# ---------------------------------------------------------------------------
# update_abstractmethods identity — standalone invariants (Python 3.10+)
# ---------------------------------------------------------------------------

invariant abc_extra263.update_abstractmethods.name:
  description: "abc.update_abstractmethods.__name__ == 'update_abstractmethods'"
  category: identity
  kind: python_call_eq
  function: update_abstractmethods.__name__.__eq__
  args: ["update_abstractmethods"]
  expected: true

invariant abc_extra263.update_abstractmethods.class_name:
  description: "abc.update_abstractmethods.__class__.__name__ == 'function'"
  category: identity
  kind: python_call_eq
  function: update_abstractmethods.__class__.__name__.__eq__
  args: ["function"]
  expected: true
