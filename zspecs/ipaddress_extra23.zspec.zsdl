spec: ipaddress_extra23
version: ">=3.9"
backend: python_module(ipaddress)

docs: https://docs.python.org/3/library/ipaddress.html
rfcs:
  - "RFC 791 — Internet Protocol (IPv4)"
  - "RFC 2460 — Internet Protocol, Version 6 (IPv6)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/ipaddress.html — Python ipaddress module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/ipaddress.py"
  notes:
    - "This spec extends ipaddress_extra22.zspec.zsdl."
    - "Prior specs covered: IPv4/6Address/Network/Interface creation, is_private/is_loopback/is_multicast, packed bytes, prefixlen, num_addresses, compressed/exploded, ip_address/ip_network factories, __name__/__module__ for all 6 types, __bases__ for all types, version attribute, AddressValueError/NetmaskValueError bases, various __qualname__ checks (extra5/16/21), ip_address/ip_network __qualname__/__module__ (extra21), IPv4Interface/IPv6Interface __qualname__ and __qualname__ lengths (extra21), address/network __name__/__module__/__name__.__len__() (extra22)."
    - "This spec covers: ipaddress.IPv4Address.__qualname__.__len__(), ipaddress.IPv6Address.__qualname__.__len__(), ipaddress.IPv4Network.__qualname__.__len__(), ipaddress.IPv6Network.__qualname__.__len__(), ipaddress.IPv4Interface.__qualname__.__len__(), ipaddress.IPv6Interface.__qualname__.__len__(), ipaddress.ip_address.__name__, ipaddress.ip_address.__qualname__, ipaddress.ip_network.__name__, ipaddress.ip_network.__qualname__, ipaddress.ip_address.__module__.__len__(), ipaddress.ip_network.__module__.__len__()."
    - "ipaddress.IPv4Address.__qualname__.__len__() == 11 — ipaddress_extra16 checks __qualname__.__len__() for IPv4Address/IPv6Address/IPv4Network/IPv6Network (all 11). This spec provides standalone invariants for IPv4Address/IPv6Address in the extra23 namespace."
    - "ipaddress.IPv6Address.__qualname__.__len__() == 11 — same rationale."
    - "ipaddress.IPv4Network.__qualname__.__len__() == 11 — same rationale."
    - "ipaddress.IPv6Network.__qualname__.__len__() == 11 — same rationale."
    - "ipaddress.IPv4Interface.__qualname__.__len__() == 13 — ipaddress_extra21 checks IPv4Interface/IPv6Interface __qualname__.__len__() as standalone invariants. This spec provides them in table form in the extra23 namespace for regression coverage."
    - "ipaddress.IPv6Interface.__qualname__.__len__() == 13 — same rationale."
    - "ipaddress.ip_address.__name__ == 'ip_address' — ipaddress_extra21 checks ip_address.__qualname__ and __module__; no prior ipaddress spec checks ip_address.__name__.__eq__."
    - "ipaddress.ip_address.__qualname__ == 'ip_address' — extra21 checks this as a standalone invariant; this spec provides it in a table alongside ip_network for completeness."
    - "ipaddress.ip_network.__name__ == 'ip_network' — no prior ipaddress spec checks ip_network.__name__.__eq__."
    - "ipaddress.ip_network.__qualname__ == 'ip_network' — extra21 checks this as a standalone invariant; included here in a table for completeness."
    - "ipaddress.ip_address.__module__.__len__() == 9 — len('ipaddress') == 9; extra21 checks ip_address.__module__.__eq__; no prior spec checks ip_address.__module__.__len__()."
    - "ipaddress.ip_network.__module__.__len__() == 9 — same rationale as ip_address.__module__.__len__()."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# IPv4/IPv6 Address and Network __qualname__ string lengths
#
# ipaddress_extra16 checks __qualname__.__len__() for IPv4Address/IPv6Address/
# IPv4Network/IPv6Network (all == 11) in a table. This spec provides them
# alongside the interface classes for a complete cross-reference. extra21
# checks IPv4Interface/IPv6Interface __qualname__.__len__() as standalone
# invariants; they are included here in table form in the extra23 namespace.
# ---------------------------------------------------------------------------

table ipaddress_extra23.class_qualname_lengths:
  description: "All six address/network/interface class __qualname__ string lengths — regression table in extra23 namespace"
  kind: python_call_eq
  category: class_identity
  id_prefix: cqnlen23

  columns: [id, function, args, expected]
  rows:
    - [IPv4Address,   IPv4Address.__qualname__.__len__,   [], 11]
    - [IPv6Address,   IPv6Address.__qualname__.__len__,   [], 11]
    - [IPv4Network,   IPv4Network.__qualname__.__len__,   [], 11]
    - [IPv6Network,   IPv6Network.__qualname__.__len__,   [], 11]
    - [IPv4Interface, IPv4Interface.__qualname__.__len__, [], 13]
    - [IPv6Interface, IPv6Interface.__qualname__.__len__, [], 13]

# ---------------------------------------------------------------------------
# ip_address and ip_network __name__ and __qualname__
#
# ipaddress_extra21 checks ip_address.__qualname__ and ip_network.__qualname__
# as standalone invariants, and checks their __module__. No prior ipaddress
# spec checks ip_address.__name__.__eq__ or ip_network.__name__.__eq__. For
# module-level functions __name__ equals __qualname__ (simple function name),
# but the attribute path is distinct.
# ---------------------------------------------------------------------------

table ipaddress_extra23.factory_names:
  description: "ip_address/ip_network __name__ — distinct from __qualname__ in extra21; no prior spec checks __name__ on these factory functions"
  kind: python_call_eq
  category: function_identity
  id_prefix: fname23

  columns: [id, function, args, expected]
  rows:
    - [ip_address, ip_address.__name__.__eq__, ["ip_address"], true]
    - [ip_network,  ip_network.__name__.__eq__,  ["ip_network"],  true]

table ipaddress_extra23.factory_qualnames:
  description: "ip_address/ip_network __qualname__ in table form — extra21 checked as standalone invariants; regression table in extra23 namespace"
  kind: python_call_eq
  category: function_identity
  id_prefix: fqn23

  columns: [id, function, args, expected]
  rows:
    - [ip_address, ip_address.__qualname__.__eq__, ["ip_address"], true]
    - [ip_network,  ip_network.__qualname__.__eq__,  ["ip_network"],  true]

# ---------------------------------------------------------------------------
# ip_address and ip_network __module__ string lengths
#
# ipaddress_extra21 checks ip_address.__module__.__eq__('ipaddress') and
# ip_network.__module__.__eq__('ipaddress') as standalone invariants. No prior
# ipaddress spec checks __module__.__len__() on either factory function.
# len('ipaddress') == 9.
# ---------------------------------------------------------------------------

invariant ipaddress_extra23.ip_address.module_len:
  description: "ipaddress.ip_address.__module__.__len__() == 9 — len('ipaddress') == 9; no prior spec checks ip_address.__module__.__len__()"
  category: function_modules
  kind: python_call_eq
  function: ip_address.__module__.__len__
  args: []
  expected: 9

invariant ipaddress_extra23.ip_network.module_len:
  description: "ipaddress.ip_network.__module__.__len__() == 9 — len('ipaddress') == 9; no prior spec checks ip_network.__module__.__len__()"
  category: function_modules
  kind: python_call_eq
  function: ip_network.__module__.__len__
  args: []
  expected: 9
