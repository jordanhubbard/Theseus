spec: struct_extra317
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html
rfcs:
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic (for float and double format strings)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source code"
  notes:
    - "This spec covers struct.calcsize with the '=' (native byte order, no alignment) prefix."
    - "The '=' prefix uses standard sizes: B=1, H=2, I=4, l=4, q=8, f=4, d=8."
    - "IMPORTANT: '=l' is 4 bytes (standard size for long), NOT 8. '@l' is 8 bytes (native C long on 64-bit macOS)."
    - "This differs from '@l' which uses the platform's native C sizeof(long) == 8 on 64-bit macOS."
    - "'>l' is also 4 bytes (big-endian uses standard sizes too)."
    - "'10s' (no prefix) is 10 bytes — the count multiplies the size of 's' (1 byte)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.calcsize with '=' (native byte order, standard sizes, no alignment)
# ---------------------------------------------------------------------------

table struct_extra317.calcsize.native_standard:
  kind: python_call_eq
  category: calcsize
  function: calcsize
  id_prefix: calcsize317

  columns: [id, args, expected]
  rows:
    - [native_uint32,   ["=I"],  4]
    - [native_short,    ["=H"],  2]
    - [native_byte,     ["=B"],  1]
    - [native_double,   ["=d"],  8]
    - [native_float,    ["=f"],  4]
    - [native_long,     ["=l"],  4]
    - [native_longlong, ["=q"],  8]
    - [ten_byte_string, ["10s"], 10]
