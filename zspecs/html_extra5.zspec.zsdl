spec: html_extra5
version: ">=3.4"
backend: python_module(html.parser)

docs: https://docs.python.org/3/library/html.parser.html

provenance:
  derived_from:
    - "Python html.parser documentation — https://docs.python.org/3/library/html.parser.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/html/parser.py"
    - "html_parser.zspec.zsdl — covers HTMLParser.__name__, HTMLParser.__module__, convert_charrefs default, getpos(), method names, reset/close return None"
    - "html_extra.zspec.zsdl — covers html.escape.__module__, html.unescape.__module__, html.escape.__name__, html.unescape.__name__"
    - "html_extra2.zspec.zsdl — covers html.escape('<div>'), html.unescape('&lt;div&gt;'), quote=False/True variants"
    - "html_extra3.zspec.zsdl — covers html.parser.HTMLParser.__name__ and __module__ via html backend, html.unescape('&amp;')"
    - "html_extra4.zspec.zsdl — covers html.escape.__qualname__, html.unescape.__qualname__, escape('<script>'), escape positional bool args"
    - "NOTE: html.parser.HTMLParseError was deprecated in Python 3.3 and removed in Python 3.5 — not tested here"
  notes:
    - "This spec extends html_parser.zspec.zsdl and html_extra[1-4].zspec.zsdl."
    - "Focus: HTMLParser.__qualname__ (not in any prior spec); method __qualname__ checks for HTMLParser methods."
    - "html.parser.HTMLParser.__qualname__ == 'HTMLParser' — top-level class, qualname equals name."
    - "HTMLParser method __qualname__ values follow the pattern 'HTMLParser.method_name' for instance methods."
    - "HTMLParser.feed.__qualname__ == 'HTMLParser.feed' — qualified name includes the class."
    - "HTMLParser.reset.__qualname__ == 'HTMLParser.reset'."
    - "HTMLParser.close.__qualname__ == 'HTMLParser.close'."
    - "HTMLParser.getpos.__qualname__ == 'HTMLParser.getpos'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# HTMLParser.__qualname__ — top-level class, qualname equals __name__
# (html_parser.zspec.zsdl covers __name__ and __module__; __qualname__ is new)
# ---------------------------------------------------------------------------

invariant html_extra5.HTMLParser.qualname:
  description: "html.parser.HTMLParser.__qualname__ == 'HTMLParser' — top-level class qualname"
  category: identity
  kind: python_call_eq
  function: HTMLParser.__qualname__.__eq__
  args: ["HTMLParser"]
  expected: true

# ---------------------------------------------------------------------------
# HTMLParser method __qualname__ — qualified names include the class name
# (html_parser.zspec.zsdl covers __name__ for these methods; __qualname__ is new)
# ---------------------------------------------------------------------------

table html_extra5.HTMLParser.method_qualnames:
  kind: python_call_eq
  category: method_qualnames
  id_prefix: mqname

  columns: [id, function, args, expected]
  rows:
    - [feed,           HTMLParser.feed.__qualname__.__eq__,           ["HTMLParser.feed"],           true]
    - [reset,          HTMLParser.reset.__qualname__.__eq__,          ["HTMLParser.reset"],          true]
    - [close,          HTMLParser.close.__qualname__.__eq__,          ["HTMLParser.close"],          true]
    - [getpos,         HTMLParser.getpos.__qualname__.__eq__,         ["HTMLParser.getpos"],         true]
    - [handle_starttag, HTMLParser.handle_starttag.__qualname__.__eq__, ["HTMLParser.handle_starttag"], true]
    - [handle_endtag,  HTMLParser.handle_endtag.__qualname__.__eq__,  ["HTMLParser.handle_endtag"],  true]
    - [handle_data,    HTMLParser.handle_data.__qualname__.__eq__,    ["HTMLParser.handle_data"],    true]
    - [handle_comment, HTMLParser.handle_comment.__qualname__.__eq__, ["HTMLParser.handle_comment"], true]

# ---------------------------------------------------------------------------
# HTMLParser.__class__.__name__ — the class itself is a type
# (not in any prior spec)
# ---------------------------------------------------------------------------

invariant html_extra5.HTMLParser.is_type:
  description: "html.parser.HTMLParser.__class__.__name__ == 'type' — HTMLParser is a class object"
  category: identity
  kind: python_call_eq
  function: HTMLParser.__class__.__name__.__eq__
  args: ["type"]
  expected: true

# ---------------------------------------------------------------------------
# HTMLParser.__bases__[0].__name__ — direct base class is object
# (not in any prior spec)
# ---------------------------------------------------------------------------

invariant html_extra5.HTMLParser.base_is_object:
  description: "html.parser.HTMLParser.__bases__[0].__name__ == 'object'"
  category: hierarchy
  kind: python_call_eq
  function: HTMLParser.__bases__.__getitem__
  args: [0]
  method: __name__
  expected: "object"
