spec: abc_extra33
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra32.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__.__len__() and __name__.__len__() and __qualname__.__len__() for ABC/ABCMeta/abstractmethod/get_cache_token/update_abstractmethods, abstractproperty lengths, ABCMeta.register/__name__/__qualname__ lengths, ABCMeta.__new__/__instancecheck__/__subclasscheck__ __qualname__.__len__(), __mro__.__len__() for ABCMeta(3)/ABC(2), ABC/ABCMeta __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__() for ABC/ABCMeta (both 12), ABCMeta.__subclasshook__/__qualname__.__len__()==24, update_abstractmethods/__qualname__.__len__()==22, ABC.__abstractmethods__.__class__.__name__.__len__()==9, ABC.__name__.__len__()==3, ABCMeta.register.__qualname__.__len__()==16, abstractmethod/__name__.__len__()==14, get_cache_token/__name__.__len__()==15, abc/__name__.__len__()==3, ABCMeta mro entry name lengths (ABCMeta/type/object), ABC mro entry name lengths, ABCMeta/__subclasshook__/__qualname__.__len__()==24, issubclass/isinstance behavioral invariants, abstractmethod/__class__/__name__.__len__()==8, ABC/__doc__/__class__/__name__.__len__()==3, ABC/__module__.__len__()==3, ABCMeta/__prepare__/__qualname__.__len__()==19, ABCMeta/__init__/__qualname__.__len__()==13, ABCMeta/__getattribute__/__qualname__.__len__()==21, ABCMeta/__call__/__repr__/__qualname__.__len__()==13, ABCMeta/__setattr__/__delattr__/__qualname__.__len__()==16, abstractmethod/__code__/__class__/__name__.__len__()==4, ABC/__subclasshook__/__qualname__.__len__()==20, ABCMeta protocol method __name__.__len__()==17, ABC/__init_subclass__/__qualname__/__len__()==21, metaclass chain __class__/__name__.__len__() tables, abstractmethod/__annotations__/__class__/__name__.__len__()==4, get_cache_token/__class__/__name__.__len__()==26."
    - "This spec covers: ABCMeta.__bases__[0].__module__.__len__()==8 ('builtins'); ABCMeta.__bases__[0].__qualname__.__len__()==4 ('type'); ABC.__bases__[0].__module__.__len__()==8 ('builtins'); ABC.__bases__[0].__qualname__.__len__()==6 ('object'); abstractmethod.__class__.__module__.__len__()==8 ('builtins'); abc.__spec__.__class__.__name__.__len__()==10 ('ModuleSpec'); ABCMeta.__mro__[0].__module__.__len__()==3 ('abc'); ABCMeta.__mro__[1].__module__.__len__()==8 ('builtins'); ABCMeta.__mro__[2].__module__.__len__()==8 ('builtins'); ABCMeta.__mro__[0].__qualname__.__len__()==7 ('ABCMeta'); ABCMeta.__mro__[1].__qualname__.__len__()==4 ('type'); ABCMeta.__mro__[2].__qualname__.__len__()==6 ('object')."
    - "ABCMeta.__bases__[0] is type. type.__module__ == 'builtins' (8 chars); type.__qualname__ == 'type' (4 chars). Prior specs (extra24, extra26) measured ABCMeta.__bases__[0].__name__.__len__() == 4, but NOT __module__.__len__() or __qualname__.__len__() as integer invariants."
    - "ABC.__bases__[0] is object. object.__module__ == 'builtins' (8 chars); object.__qualname__ == 'object' (6 chars). Prior specs (extra24, extra27) measured ABC.__bases__[0].__name__.__len__() == 6, but NOT __module__.__len__() or __qualname__.__len__() as integer invariants."
    - "Both ABCMeta.__bases__[0].__module__.__len__() and ABC.__bases__[0].__module__.__len__() equal 8, because both base classes (type and object) live in 'builtins' (8 chars). The shared module length (8) connects the abc hierarchy to the Python builtin type system."
    - "abstractmethod.__class__.__module__ == 'builtins' (8 chars). abstractmethod is a Python class whose metaclass is type (a builtin). The metaclass type lives in 'builtins', so this chain abc.abstractmethod -> __class__ (type) -> __module__ ('builtins') resolves to length 8. Prior spec extra32 captured abstractmethod.__class__.__name__.__len__() == 8 ('function'?), but NOT __module__.__len__()."
    - "abc.__spec__.__class__.__name__ == 'ModuleSpec' (10 chars). ModuleSpec is from importlib.machinery and represents the specification for a module. All standard-library modules have a ModuleSpec. This traversal (module -> __spec__ -> __class__ -> __name__ -> __len__()) is a novel path through abc's module-level attributes."
    - "ABCMeta MRO qualname lengths reveal the metaclass chain: ABCMeta (7) -> type (4) -> object (6). These differ from the MRO name lengths (also 7/4/6) because for top-level classes __qualname__ == __name__, but the attribute chain (__qualname__ vs __name__) is distinct."
    - "ABCMeta MRO module lengths: ABCMeta (index 0) is in 'abc' (3); type (index 1) is in 'builtins' (8); object (index 2) is in 'builtins' (8). The two builtin entries (type and object) share the same module length, while ABCMeta itself is in the shorter 'abc' module."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc base class __module__ and __qualname__ lengths — extra33 namespace
#
# ABCMeta.__bases__[0] is type; ABC.__bases__[0] is object. Both base classes
# live in 'builtins' (8 chars), so both share __module__.__len__() == 8.
# Their __qualname__ lengths differ: type.__qualname__ == 'type' (4 chars);
# object.__qualname__ == 'object' (6 chars).
# Prior specs measured __name__.__len__() for both base classes (4 and 6
# respectively) but NOT __module__.__len__() or __qualname__.__len__() as
# integer invariants.
# ---------------------------------------------------------------------------

table abc_extra33.base_class_module_lengths:
  description: "abc base class __module__.__len__() in extra33 namespace — both type and object live in 'builtins' (8 chars)"
  kind: python_call_eq
  category: module_names
  id_prefix: abcbasemodlen33

  columns: [id, function, args, expected, description]
  rows:
    - [ABCMeta_base, "ABCMeta.__bases__[0].__module__.__len__", [], 8, "ABCMeta.__bases__[0] is type; type.__module__ == 'builtins' (8 chars)"]
    - [ABC_base,     "ABC.__bases__[0].__module__.__len__",     [], 8, "ABC.__bases__[0] is object; object.__module__ == 'builtins' (8 chars)"]

table abc_extra33.base_class_qualname_lengths:
  description: "abc base class __qualname__.__len__() in extra33 namespace — type (4) vs object (6)"
  kind: python_call_eq
  category: class_names
  id_prefix: abcbasequlen33

  columns: [id, function, args, expected, description]
  rows:
    - [ABCMeta_base, "ABCMeta.__bases__[0].__qualname__.__len__", [], 4, "ABCMeta.__bases__[0] is type; type.__qualname__ == 'type' (4 chars)"]
    - [ABC_base,     "ABC.__bases__[0].__qualname__.__len__",     [], 6, "ABC.__bases__[0] is object; object.__qualname__ == 'object' (6 chars)"]

# ---------------------------------------------------------------------------
# ABCMeta MRO __module__.__len__() — extra33 namespace
#
# ABCMeta.__mro__ == (ABCMeta, type, object). The module for each entry:
#   ABCMeta.__mro__[0].__module__ == 'abc'      (3 chars)
#   ABCMeta.__mro__[1].__module__ == 'builtins' (8 chars)
#   ABCMeta.__mro__[2].__module__ == 'builtins' (8 chars)
# The first entry (ABCMeta itself) is in 'abc' (3 chars); the remaining two
# (type and object) are in 'builtins' (8 chars). No prior abc spec has
# measured ABCMeta MRO entry __module__.__len__() values.
# ---------------------------------------------------------------------------

table abc_extra33.abcmeta_mro_module_lengths:
  description: "ABCMeta MRO entry __module__.__len__() in extra33 namespace — shows transition from abc to builtins"
  kind: python_call_eq
  category: module_names
  id_prefix: abcmetamromodlen33

  columns: [id, function, args, expected, description]
  rows:
    - [mro0, "ABCMeta.__mro__[0].__module__.__len__", [], 3, "ABCMeta is in 'abc' (3 chars)"]
    - [mro1, "ABCMeta.__mro__[1].__module__.__len__", [], 8, "type is in 'builtins' (8 chars)"]
    - [mro2, "ABCMeta.__mro__[2].__module__.__len__", [], 8, "object is in 'builtins' (8 chars)"]

# ---------------------------------------------------------------------------
# ABCMeta MRO __qualname__.__len__() — extra33 namespace
#
# ABCMeta.__mro__ == (ABCMeta, type, object). The __qualname__ lengths are:
#   ABCMeta.__mro__[0].__qualname__ == 'ABCMeta' (7 chars)
#   ABCMeta.__mro__[1].__qualname__ == 'type'    (4 chars)
#   ABCMeta.__mro__[2].__qualname__ == 'object'  (6 chars)
# For these top-level classes, __qualname__ == __name__, so the lengths match
# the __name__.__len__() values measured in prior specs (extra27: ABCMeta=7,
# type=4, object=6 as name lengths). The __qualname__.__len__() values are
# distinct measurements — taken through a different attribute chain — and have
# not been captured in any prior abc spec.
# ---------------------------------------------------------------------------

table abc_extra33.abcmeta_mro_qualname_lengths:
  description: "ABCMeta MRO entry __qualname__.__len__() in extra33 namespace — ABCMeta(7), type(4), object(6)"
  kind: python_call_eq
  category: class_names
  id_prefix: abcmetamroqulen33

  columns: [id, function, args, expected, description]
  rows:
    - [mro0, "ABCMeta.__mro__[0].__qualname__.__len__", [], 7, "ABCMeta.__qualname__ == 'ABCMeta' (7 chars)"]
    - [mro1, "ABCMeta.__mro__[1].__qualname__.__len__", [], 4, "type.__qualname__ == 'type' (4 chars)"]
    - [mro2, "ABCMeta.__mro__[2].__qualname__.__len__", [], 6, "object.__qualname__ == 'object' (6 chars)"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra33
# ---------------------------------------------------------------------------

invariant abc_extra33.abstractmethod_class_module_len:
  description: "abc.abstractmethod.__class__.__module__.__len__() == 8 — abstractmethod's metaclass is type; type.__module__ == 'builtins' (8 chars)"
  category: module_names
  kind: python_call_eq
  function: abstractmethod.__class__.__module__.__len__
  args: []
  expected: 8

invariant abc_extra33.abc_spec_class_name_len:
  description: "abc.__spec__.__class__.__name__.__len__() == 10 — the module spec class is 'ModuleSpec' (10 chars); used by importlib for all standard-library modules"
  category: class_names
  kind: python_call_eq
  function: abc.__spec__.__class__.__name__.__len__
  args: []
  expected: 10

invariant abc_extra33.ABCMeta_base_module_len:
  description: "abc.ABCMeta.__bases__[0].__module__.__len__() == 8 — ABCMeta's base is type; type.__module__ == 'builtins' (8 chars)"
  category: module_names
  kind: python_call_eq
  function: "ABCMeta.__bases__[0].__module__.__len__"
  args: []
  expected: 8

invariant abc_extra33.ABC_base_qualname_len:
  description: "abc.ABC.__bases__[0].__qualname__.__len__() == 6 — ABC's base is object; object.__qualname__ == 'object' (6 chars); same length as object.__name__ but measured via __qualname__"
  category: class_names
  kind: python_call_eq
  function: "ABC.__bases__[0].__qualname__.__len__"
  args: []
  expected: 6
