spec: decimal_extra1921
version: ">=3.9"
backend: python_module(decimal)

provenance:
  derived_from:
    - "https://docs.python.org/3/library/decimal.html — Python decimal module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Modules/_decimal/_decimal.c"
    - "CPython source: Lib/_pydecimal.py"
  notes:
    - "Wave 575 (_extra1921): __slots__, __abstractmethods__, __subclasshook__, __init_subclass__ checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "decimal.Decimal is a C extension type (_decimal.Decimal); its __dict__ does not contain __slots__."
    - "decimal.Context is a C extension type (_decimal.Context); its __dict__ does not contain __slots__."
    - "decimal.DecimalException and all its subclasses are Python exception classes; none define __slots__ in their own __dict__."
    - "None of the decimal types are abstract; __abstractmethods__ is absent from all their __dict__s."
    - "None of the decimal types define __subclasshook__ in their own __dict__."
    - "None of the decimal types define __init_subclass__ in their own __dict__."
    - "decimal.DecimalException.__dict__ contains __module__, __weakref__, __doc__."
    - "decimal.InvalidOperation.__dict__ contains __module__, __doc__ — subclass of DecimalException."
    - "decimal.Decimal.__module__ == 'decimal' even though implemented in _decimal C extension."
    - "decimal.Overflow, decimal.Underflow, decimal.Inexact, decimal.Rounded, decimal.Subnormal are all Python exception subclasses with no __slots__."
  created_at: "2026-04-12"

error_model: python_exceptions

table decimal_extra1921.slots_protocol:
  description: "decimal types __slots__ dict-presence checks — all false, C types and exceptions do not define Python __slots__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: dc1921

  columns: [id, function, args, expected]
  rows:
    - ["dc1921001", "decimal.Decimal.__dict__.__contains__", ["__slots__"], false]
    - ["dc1921002", "decimal.Context.__dict__.__contains__", ["__slots__"], false]
    - ["dc1921003", "decimal.DecimalException.__dict__.__contains__", ["__slots__"], false]
    - ["dc1921004", "decimal.InvalidOperation.__dict__.__contains__", ["__slots__"], false]
    - ["dc1921005", "decimal.DivisionByZero.__dict__.__contains__", ["__slots__"], false]
    - ["dc1921006", "decimal.Overflow.__dict__.__contains__", ["__slots__"], false]
    - ["dc1921007", "decimal.Underflow.__dict__.__contains__", ["__slots__"], false]
    - ["dc1921008", "decimal.Inexact.__dict__.__contains__", ["__slots__"], false]
    - ["dc1921009", "decimal.Rounded.__dict__.__contains__", ["__slots__"], false]
    - ["dc1921010", "decimal.Subnormal.__dict__.__contains__", ["__slots__"], false]

