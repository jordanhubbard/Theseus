# collections.abc.Buffer class identity (Python 3.12+)
#
# collections.abc.Buffer.__name__ == 'Buffer' (len=6)
# collections.abc.Buffer.__module__ == 'collections.abc' (len=15)
# collections.abc.Buffer.__bases__[0].__name__ == 'object' (len=6)
# collections.abc.Buffer.__abstractmethods__ == frozenset({'__buffer__'}) (len=1)
# ---------------------------------------------------------------------------

table abc_extra255.buffer_class_identity:
  description: "collections.abc.Buffer(len=6) class identity — added in Python 3.12; inherits from object(len=6, same as Buffer name length); defined in collections.abc(len=15); __abstractmethods__ has 1 member: __buffer__; Buffer.__name__ length (6) equals object.__name__ length (6); verified with Python 3.14.4"
  kind: python_call_eq
  category: identity
  id_prefix: abc255buf

  columns: [id, function, args, expected, description]
  rows:
    - [buf_name_eq,        Buffer.__name__.__eq__,                                 ["Buffer"],             true, "collections.abc.Buffer.__name__ == 'Buffer'; verified with Python 3.14.4"]
    - [buf_name_len,       Buffer.__name__.__len__,                                [],                     6,    "collections.abc.Buffer.__name__.__len__() == 6 — same length as 'object'; verified with Python 3.14.4"]
    - [buf_mod_eq,         Buffer.__module__.__eq__,                               ["collections.abc"],    true, "collections.abc.Buffer.__module__ == 'collections.abc'; verified with Python 3.14.4"]
    - [buf_mod_len,        Buffer.__module__.__len__,                              [],                     15,   "collections.abc.Buffer.__module__.__len__() == 15; verified with Python 3.14.4"]
    - [buf_base_eq,        "Buffer.__bases__[0].__name__.__eq__",                  ["object"],             true, "collections.abc.Buffer.__bases__[0].__name__ == 'object' — Buffer inherits directly from object; verified with Python 3.14.4"]
    - [buf_base_len,       "Buffer.__bases__[0].__name__.__len__",                 [],                     6,    "collections.abc.Buffer.__bases__[0].__name__.__len__() == 6 — same length as Buffer.__name__; verified with Python 3.14.4"]
    - [buf_am_len,         Buffer.__abstractmethods__.__len__,                     [],                     1,    "collections.abc.Buffer.__abstractmethods__.__len__() == 1; verified with Python 3.14.4"]
    - [buf_am_buffer,      "Buffer.__abstractmethods__.__contains__",              ["__buffer__"],         true, "collections.abc.Buffer.__abstractmethods__.__contains__('__buffer__') == True; verified with Python 3.14.4"]

