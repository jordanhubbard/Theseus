# ---------------------------------------------------------------------------
# Standalone invariants — abc_extra255
# ---------------------------------------------------------------------------

invariant abc_extra255.buffer_abstract_method_is_buffer:
  description: "collections.abc.Buffer.__abstractmethods__.__contains__('__buffer__') returns True — Buffer's single abstract method is __buffer__; Buffer was added in Python 3.12 (PEP 688); Buffer.__name__ length (6) equals object.__name__ length (6) — a numeric coincidence; verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: "Buffer.__abstractmethods__.__contains__"
  args: ["__buffer__"]
  expected: true

invariant abc_extra255.coroutine_has_three_abstract_methods:
  description: "collections.abc.Coroutine.__abstractmethods__.__len__() == 3 — Coroutine is the only ABC in this spec with more than 1 abstract method (3: __await__, send, throw); it inherits from Awaitable (which has 1 abstract method: __await__); Coroutine and Awaitable share __name__ length 9; verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: Coroutine.__abstractmethods__.__len__
  args: []
  expected: 3

invariant abc_extra255.coroutine_base_is_awaitable:
  description: "collections.abc.Coroutine.__bases__[0].__name__.__eq__('Awaitable') returns True — Coroutine inherits from Awaitable; both have __name__ length 9; Awaitable inherits from object while Coroutine inherits from Awaitable; this makes Coroutine the only non-object-direct-subclass in this spec (excluding Coroutine itself); verified with Python 3.14.4"
  category: identity
  kind: python_call_eq
  function: "Coroutine.__bases__[0].__name__.__eq__"
  args: ["Awaitable"]
  expected: true
