spec: abc_extra255
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/collections.abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/collections.abc.html — collections.abc documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/_collections_abc.py"
  notes:
    - "collections.abc.Buffer.__name__ == 'Buffer' (len=6); __module__ == 'collections.abc' (len=15); __bases__[0].__name__ == 'object' (len=6); __abstractmethods__ == frozenset({'__buffer__'}) (len=1). Buffer was added in Python 3.12."
    - "collections.abc.Hashable.__name__ == 'Hashable' (len=8); __bases__[0].__name__ == 'object' (len=6); __abstractmethods__ == frozenset({'__hash__'}) (len=1)."
    - "collections.abc.Sized.__name__ == 'Sized' (len=5); __bases__[0].__name__ == 'object' (len=6); __abstractmethods__ == frozenset({'__len__'}) (len=1)."
    - "collections.abc.Callable.__name__ == 'Callable' (len=8); __bases__[0].__name__ == 'object' (len=6); __abstractmethods__ == frozenset({'__call__'}) (len=1)."
    - "collections.abc.Awaitable.__name__ == 'Awaitable' (len=9); __bases__[0].__name__ == 'object' (len=6); __abstractmethods__ == frozenset({'__await__'}) (len=1)."
    - "collections.abc.Coroutine.__name__ == 'Coroutine' (len=9); __bases__[0].__name__ == 'Awaitable' (len=9, same); __abstractmethods__ == frozenset({'__await__', 'send', 'throw'}) (len=3 — most in spec)."
    - "Awaitable and Coroutine share __name__ length 9; Coroutine.__bases__[0] is Awaitable so their names also share length 9."
    - "Hashable and Callable share __name__ length 8; Buffer.__name__ length (6) equals object.__name__ length (6)."
    - "Buffer, Hashable, Sized, Callable, Awaitable all inherit directly from object and have exactly 1 abstract method. Coroutine inherits from Awaitable and has 3 abstract methods."
    - "Note: SupportsInt, SupportsFloat, SupportsComplex, SupportsBytes, SupportsAbs, SupportsRound do NOT exist in Python 3.14 collections.abc — they were removed."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

