spec: re_extra216
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
    - "re_extra215.zspec.zsdl — covers re function __doc__ contains checks (different words)"
  notes:
    - "re.compile.__doc__ == 'Compile a regular expression pattern, returning a Pattern object.'; confirmed Python 3.14.3 macOS."
    - "re.compile.__doc__.__contains__('Compile') == True; word appears at start of doc; confirmed Python 3.14.3 macOS."
    - "re.compile.__doc__.__contains__('regular') == True; doc says 'regular expression pattern'; confirmed Python 3.14.3 macOS."
    - "re.match.__doc__.__contains__('apply') == True; doc says 'Try to apply the pattern at the start'; confirmed Python 3.14.3 macOS."
    - "re.match.__doc__.__contains__('Match') == True; doc says 'returning a Match object'; confirmed Python 3.14.3 macOS."
    - "re.search.__doc__.__contains__('Scan') == True; doc starts with 'Scan through string'; confirmed Python 3.14.3 macOS."
    - "re.search.__doc__.__contains__('looking') == True; doc says 'looking for a match'; confirmed Python 3.14.3 macOS."
    - "re.findall.__doc__.__contains__('Return') == True; doc starts with 'Return a list'; confirmed Python 3.14.3 macOS."
    - "re.findall.__doc__.__contains__('capturing') == True; doc mentions capturing groups; confirmed Python 3.14.3 macOS."
    - "re.sub.__doc__.__contains__('leftmost') == True; doc says 'replacing the leftmost'; confirmed Python 3.14.3 macOS."
    - "re.sub.__doc__.__contains__('repl') == True; doc mentions the repl argument; confirmed Python 3.14.3 macOS."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: __doc__ contains checks for re.compile and re.match (new words)
# re.compile and re.match __doc__ string substring membership
# ---------------------------------------------------------------------------

table re_extra216.compile_and_match_doc_contains:
  description: "re.compile and re.match __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: redoccontains216a

  columns: [id, function, args, expected, description]
  rows:
    - [compile_doc_contains_Compile,   re.compile.__doc__.__contains__, ["Compile"],   true, "re.compile.__doc__.__contains__('Compile') == True; doc starts with 'Compile a regular expression pattern'; confirmed Python 3.14.3 macOS"]
    - [compile_doc_contains_regular,   re.compile.__doc__.__contains__, ["regular"],   true, "re.compile.__doc__.__contains__('regular') == True; doc says 'regular expression pattern'; confirmed Python 3.14.3 macOS"]
    - [compile_doc_contains_Pattern,   re.compile.__doc__.__contains__, ["Pattern"],   true, "re.compile.__doc__.__contains__('Pattern') == True; doc says 'returning a Pattern object'; confirmed Python 3.14.3 macOS"]
    - [compile_doc_contains_returning,  re.compile.__doc__.__contains__, ["returning"], true, "re.compile.__doc__.__contains__('returning') == True; doc says 'returning a Pattern object'; confirmed Python 3.14.3 macOS"]
    - [match_doc_contains_apply,       re.match.__doc__.__contains__,   ["apply"],     true, "re.match.__doc__.__contains__('apply') == True; doc says 'Try to apply the pattern at the start'; confirmed Python 3.14.3 macOS"]
    - [match_doc_contains_Match,       re.match.__doc__.__contains__,   ["Match"],     true, "re.match.__doc__.__contains__('Match') == True; doc says 'returning a Match object'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 2: __doc__ contains checks for re.match and re.search (new words)
# re.match and re.search __doc__ string substring membership
# ---------------------------------------------------------------------------

table re_extra216.match_and_search_doc_contains:
  description: "re.match and re.search __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: redoccontains216b

  columns: [id, function, args, expected, description]
  rows:
    - [match_doc_contains_start,   re.match.__doc__.__contains__,  ["start"],   true, "re.match.__doc__.__contains__('start') == True; doc says 'at the start of the string'; confirmed Python 3.14.3 macOS"]
    - [match_doc_contains_None,    re.match.__doc__.__contains__,  ["None"],    true, "re.match.__doc__.__contains__('None') == True; doc says 'or None if no match was found'; confirmed Python 3.14.3 macOS"]
    - [match_doc_contains_string,  re.match.__doc__.__contains__,  ["string"],  true, "re.match.__doc__.__contains__('string') == True; doc says 'at the start of the string'; confirmed Python 3.14.3 macOS"]
    - [search_doc_contains_Scan,   re.search.__doc__.__contains__,  ["Scan"],   true, "re.search.__doc__.__contains__('Scan') == True; doc starts with 'Scan through string'; confirmed Python 3.14.3 macOS"]
    - [search_doc_contains_looking, re.search.__doc__.__contains__, ["looking"], true, "re.search.__doc__.__contains__('looking') == True; doc says 'looking for a match to the pattern'; confirmed Python 3.14.3 macOS"]
    - [search_doc_contains_Match,  re.search.__doc__.__contains__,  ["Match"],  true, "re.search.__doc__.__contains__('Match') == True; doc says 'returning a Match object'; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Table 3: __doc__ contains checks for re.findall and re.sub (new words)
# re.findall and re.sub __doc__ string substring membership
# ---------------------------------------------------------------------------

table re_extra216.findall_and_sub_doc_contains:
  description: "re.findall and re.sub __doc__ string contains expected substrings"
  kind: python_call_eq
  category: identity
  id_prefix: redoccontains216c

  columns: [id, function, args, expected, description]
  rows:
    - [findall_doc_contains_Return,      re.findall.__doc__.__contains__, ["Return"],          true, "re.findall.__doc__.__contains__('Return') == True; doc starts with 'Return a list'; confirmed Python 3.14.3 macOS"]
    - [findall_doc_contains_list,        re.findall.__doc__.__contains__, ["list"],             true, "re.findall.__doc__.__contains__('list') == True; doc says 'Return a list of all non-overlapping matches'; confirmed Python 3.14.3 macOS"]
    - [findall_doc_contains_capturing,   re.findall.__doc__.__contains__, ["capturing"],        true, "re.findall.__doc__.__contains__('capturing') == True; doc mentions capturing groups; confirmed Python 3.14.3 macOS"]
    - [findall_doc_contains_non_overlapping, re.findall.__doc__.__contains__, ["non-overlapping"], true, "re.findall.__doc__.__contains__('non-overlapping') == True; doc says 'non-overlapping matches'; confirmed Python 3.14.3 macOS"]
    - [sub_doc_contains_leftmost,        re.sub.__doc__.__contains__,     ["leftmost"],         true, "re.sub.__doc__.__contains__('leftmost') == True; doc says 'replacing the leftmost non-overlapping occurrences'; confirmed Python 3.14.3 macOS"]
    - [sub_doc_contains_repl,            re.sub.__doc__.__contains__,     ["repl"],             true, "re.sub.__doc__.__contains__('repl') == True; doc mentions the repl replacement argument; confirmed Python 3.14.3 macOS"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra216.compile_doc_contains_Compile:
  description: "re.compile.__doc__.__contains__('Compile') == True — compile doc starts with 'Compile a regular expression pattern'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.compile.__doc__.__contains__
  args: ["Compile"]
  expected: true

invariant re_extra216.compile_doc_contains_Pattern:
  description: "re.compile.__doc__.__contains__('Pattern') == True — compile doc says 'returning a Pattern object'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.compile.__doc__.__contains__
  args: ["Pattern"]
  expected: true

invariant re_extra216.match_doc_contains_apply:
  description: "re.match.__doc__.__contains__('apply') == True — match doc says 'Try to apply the pattern at the start'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.match.__doc__.__contains__
  args: ["apply"]
  expected: true

invariant re_extra216.search_doc_contains_Scan:
  description: "re.search.__doc__.__contains__('Scan') == True — search doc starts with 'Scan through string looking for a match'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.search.__doc__.__contains__
  args: ["Scan"]
  expected: true

invariant re_extra216.findall_doc_contains_non_overlapping:
  description: "re.findall.__doc__.__contains__('non-overlapping') == True — findall doc says 'Return a list of all non-overlapping matches'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.findall.__doc__.__contains__
  args: ["non-overlapping"]
  expected: true

invariant re_extra216.sub_doc_contains_leftmost:
  description: "re.sub.__doc__.__contains__('leftmost') == True — sub doc says 'replacing the leftmost non-overlapping occurrences'; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.sub.__doc__.__contains__
  args: ["leftmost"]
  expected: true

invariant re_extra216.sub_doc_contains_repl:
  description: "re.sub.__doc__.__contains__('repl') == True — sub doc mentions the repl replacement argument; confirmed Python 3.14.3 macOS"
  category: identity
  kind: python_call_eq
  function: re.sub.__doc__.__contains__
  args: ["repl"]
  expected: true
