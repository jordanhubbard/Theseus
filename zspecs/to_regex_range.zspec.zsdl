  derived_from:
    - "to-regex-range README — https://www.npmjs.com/package/to-regex-range"
    - "Test vectors verified with to-regex-range via Node.js 22 on Ubuntu / Docker, 2026-04-24"
  not_derived_from:
    - "to-regex-range source"
  notes:
    - "to-regex-range is an npm package. Install: npm install to-regex-range"
    - "Returns a regex character class string that matches all integers in the given range."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a string."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table to_regex_range.range:
  kind: node_module_call_eq
  function: ~
  category: regex
  id_prefix: trr

  columns: [id, args, expected]
  rows:
    - [small,    [1, 5],    "[1-5]"]
    - [large,    [0, 100],  "(?:[0-9]|[1-9][0-9]|100)"]

