spec: itertools_extra226
version: ">=3.12"
backend: python_module(itertools)

docs: https://docs.python.org/3/library/itertools.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/itertools.html — Python itertools module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/itertoolsmodule.c"
  notes:
    - "This spec covers itertools module __dict__ membership checks for all major public names including batched (added in Python 3.12) and pairwise (added in Python 3.10)."
    - "itertools.__dict__.__contains__('chain') == True — chain is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('cycle') == True — cycle is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('count') == True — count is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('repeat') == True — repeat is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('product') == True — product is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('combinations') == True — combinations is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('permutations') == True — permutations is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('accumulate') == True — accumulate is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('compress') == True — compress is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('dropwhile') == True — dropwhile is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('takewhile') == True — takewhile is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('islice') == True — islice is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('starmap') == True — starmap is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('groupby') == True — groupby is a C extension type in itertools. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('pairwise') == True — pairwise is a C extension type added in Python 3.10. Verified with Python 3.14.3."
    - "itertools.__dict__.__contains__('batched') == True — batched is a C extension type added in Python 3.12. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: itertools.__dict__.__contains__ — infinite iterators
#
# itertools.__dict__.__contains__('chain') == True
# itertools.__dict__.__contains__('cycle') == True
# itertools.__dict__.__contains__('count') == True
# itertools.__dict__.__contains__('repeat') == True
# itertools.__dict__.__contains__('product') == True
#
# All are C extension types defined in Modules/itertoolsmodule.c. New to extra226.
# ---------------------------------------------------------------------------

table itertools_extra226.module_dict_contains_infinite:
  description: "itertools.__dict__.__contains__: chain True, cycle True, count True, repeat True, product True; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra226dictinf

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_chain,
       __dict__.__contains__,
       ["chain"],
       true,
       "itertools.__dict__.__contains__('chain') == True — chain is a C extension type registered in the itertools module dict; it chains multiple iterables together end-to-end; dict.__contains__('chain') returns True; new to extra226"]
    - [dict_contains_cycle,
       __dict__.__contains__,
       ["cycle"],
       true,
       "itertools.__dict__.__contains__('cycle') == True — cycle is a C extension type registered in the itertools module dict; it cycles through an iterable indefinitely; dict.__contains__('cycle') returns True; new to extra226"]
    - [dict_contains_count,
       __dict__.__contains__,
       ["count"],
       true,
       "itertools.__dict__.__contains__('count') == True — count is a C extension type registered in the itertools module dict; it counts up from a start value with a step; dict.__contains__('count') returns True; new to extra226"]
    - [dict_contains_repeat,
       __dict__.__contains__,
       ["repeat"],
       true,
       "itertools.__dict__.__contains__('repeat') == True — repeat is a C extension type registered in the itertools module dict; it repeats an object a given number of times (or indefinitely); dict.__contains__('repeat') returns True; new to extra226"]
    - [dict_contains_product,
       __dict__.__contains__,
       ["product"],
       true,
       "itertools.__dict__.__contains__('product') == True — product is a C extension type registered in the itertools module dict; it yields the Cartesian product of input iterables; dict.__contains__('product') returns True; new to extra226"]

# ---------------------------------------------------------------------------
# Table 2: itertools.__dict__.__contains__ — combinatoric iterators
#
# itertools.__dict__.__contains__('combinations') == True
# itertools.__dict__.__contains__('permutations') == True
# itertools.__dict__.__contains__('accumulate') == True
# itertools.__dict__.__contains__('compress') == True
# itertools.__dict__.__contains__('dropwhile') == True
#
# New to extra226.
# ---------------------------------------------------------------------------

table itertools_extra226.module_dict_contains_combinatoric:
  description: "itertools.__dict__.__contains__: combinations True, permutations True, accumulate True, compress True, dropwhile True; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra226dictcomb

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_combinations,
       __dict__.__contains__,
       ["combinations"],
       true,
       "itertools.__dict__.__contains__('combinations') == True — combinations is a C extension type registered in the itertools module dict; it yields r-length tuples of elements from the input with no repeated elements; dict.__contains__('combinations') returns True; new to extra226"]
    - [dict_contains_permutations,
       __dict__.__contains__,
       ["permutations"],
       true,
       "itertools.__dict__.__contains__('permutations') == True — permutations is a C extension type registered in the itertools module dict; it yields all r-length permutations of elements from the input; dict.__contains__('permutations') returns True; new to extra226"]
    - [dict_contains_accumulate,
       __dict__.__contains__,
       ["accumulate"],
       true,
       "itertools.__dict__.__contains__('accumulate') == True — accumulate is a C extension type registered in the itertools module dict; it yields running totals (or results of a binary function); dict.__contains__('accumulate') returns True; new to extra226"]
    - [dict_contains_compress,
       __dict__.__contains__,
       ["compress"],
       true,
       "itertools.__dict__.__contains__('compress') == True — compress is a C extension type registered in the itertools module dict; it filters data by a selector iterable; dict.__contains__('compress') returns True; new to extra226"]
    - [dict_contains_dropwhile,
       __dict__.__contains__,
       ["dropwhile"],
       true,
       "itertools.__dict__.__contains__('dropwhile') == True — dropwhile is a C extension type registered in the itertools module dict; it drops elements while the predicate is True then yields the rest; dict.__contains__('dropwhile') returns True; new to extra226"]

# ---------------------------------------------------------------------------
# Table 3: itertools.__dict__.__contains__ — filtering and slicing iterators
#
# itertools.__dict__.__contains__('takewhile') == True
# itertools.__dict__.__contains__('islice') == True
# itertools.__dict__.__contains__('starmap') == True
# itertools.__dict__.__contains__('groupby') == True
# itertools.__dict__.__contains__('pairwise') == True
# itertools.__dict__.__contains__('batched') == True
#
# pairwise added Python 3.10; batched added Python 3.12. New to extra226.
# ---------------------------------------------------------------------------

table itertools_extra226.module_dict_contains_filter_slice:
  description: "itertools.__dict__.__contains__: takewhile True, islice True, starmap True, groupby True, pairwise True, batched True; new to extra226"
  kind: python_call_eq
  category: identity
  id_prefix: itertoolsextra226dictfilt

  columns: [id, function, args, expected, description]
  rows:
    - [dict_contains_takewhile,
       __dict__.__contains__,
       ["takewhile"],
       true,
       "itertools.__dict__.__contains__('takewhile') == True — takewhile is a C extension type registered in the itertools module dict; it yields elements while the predicate is True then stops; dict.__contains__('takewhile') returns True; new to extra226"]
    - [dict_contains_islice,
       __dict__.__contains__,
       ["islice"],
       true,
       "itertools.__dict__.__contains__('islice') == True — islice is a C extension type registered in the itertools module dict; it slices an iterator like Python's slice notation; dict.__contains__('islice') returns True; new to extra226"]
    - [dict_contains_starmap,
       __dict__.__contains__,
       ["starmap"],
       true,
       "itertools.__dict__.__contains__('starmap') == True — starmap is a C extension type registered in the itertools module dict; it maps a function over an iterable of argument tuples using star-unpacking; dict.__contains__('starmap') returns True; new to extra226"]
    - [dict_contains_groupby,
       __dict__.__contains__,
       ["groupby"],
       true,
       "itertools.__dict__.__contains__('groupby') == True — groupby is a C extension type registered in the itertools module dict; it groups consecutive elements that share the same key; dict.__contains__('groupby') returns True; new to extra226"]
    - [dict_contains_pairwise,
       __dict__.__contains__,
       ["pairwise"],
       true,
       "itertools.__dict__.__contains__('pairwise') == True — pairwise is a C extension type added in Python 3.10 registered in the itertools module dict; it yields overlapping pairs of consecutive elements; dict.__contains__('pairwise') returns True; new to extra226"]
    - [dict_contains_batched,
       __dict__.__contains__,
       ["batched"],
       true,
       "itertools.__dict__.__contains__('batched') == True — batched is a C extension type added in Python 3.12 registered in the itertools module dict; it yields non-overlapping batches of a fixed size; dict.__contains__('batched') returns True; new to extra226"]

