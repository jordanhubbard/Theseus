# Standalone invariants — extra226
# ---------------------------------------------------------------------------

invariant itertools_extra226.dict_contains_chain:
  description: "itertools.__dict__.__contains__('chain') == True — chain is in module dict; new to extra226"
  kind: python_call_eq
  function: __dict__.__contains__
  args: ["chain"]
  expected: true

