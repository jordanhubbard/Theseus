spec: bisect_extra24
version: ">=3.9"
backend: python_module(bisect)

docs: https://docs.python.org/3/library/bisect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/bisect.html — Python bisect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/bisect.py"
    - "CPython source: Modules/_bisectmodule.c"
  notes:
    - "This spec extends bisect_extra23.zspec.zsdl."
    - "Prior specs covered: bisect.__name__/__package__, bisect_left/bisect_right/insort_left/insort_right/__name__/__module__, bisect.__name__=='bisect_right' (alias), insort.__name__=='insort_right' (alias), name length table, bisect.__doc__.__class__.__name__, __qualname__ checks, __qualname__.__eq__ table (extra23), __module__.__len__() for bisect_left/bisect_right/insort_left (extra23), __module__.__eq__ for bisect_left/bisect_right (extra23)."
    - "This spec covers: __name__.__len__() table for all 6 bisect callables; __qualname__.__len__() table for all 6; insort_right.__module__.__len__() and insort.__module__.__len__() standalone; alias name/qualname cross-checks."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
    - "bisect.bisect_left.__name__.__len__() == 11. Verified."
    - "bisect.bisect_right.__name__.__len__() == 12. Verified."
    - "bisect.insort_left.__name__.__len__() == 11. Verified."
    - "bisect.insort_right.__name__.__len__() == 12. Verified."
    - "bisect.bisect.__name__.__len__() == 12 (alias -> bisect_right). Verified."
    - "bisect.insort.__name__.__len__() == 12 (alias -> insort_right). Verified."
    - "bisect.bisect_left.__qualname__.__len__() == 11. Verified."
    - "bisect.bisect_right.__qualname__.__len__() == 12. Verified."
    - "bisect.insort_left.__qualname__.__len__() == 11. Verified."
    - "bisect.insort_right.__qualname__.__len__() == 12. Verified."
    - "bisect.insort_right.__module__.__len__() == 7 (C builtin from _bisect). Verified."
    - "bisect.insort.__module__.__len__() == 7 (alias -> insort_right, same C origin). Verified."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __name__.__len__() for all 6 bisect callables — extra24 namespace
#
# bisect_left=11, bisect_right=12, insort_left=11, insort_right=12.
# The aliases bisect and insort point to bisect_right and insort_right; their
# __name__ is the name of the underlying function (bisect_right=12,
# insort_right=12), not the alias name. No prior bisect spec collects all 6
# __name__.__len__() values in a single table in the extra24 namespace.
# id_prefix bsnl24 is novel.
# ---------------------------------------------------------------------------

table bisect_extra24.name_lens:
  description: "__name__.__len__() for all 6 bisect callables — aliases resolve to underlying function name lengths"
  kind: python_call_eq
  category: function_name
  id_prefix: bsnl24

  columns: [id, function, method, method_args, expected]
  rows:
    - [bisect_left_nl,  bisect_left.__name__,  __len__, [], 11]
    - [bisect_right_nl, bisect_right.__name__, __len__, [], 12]
    - [insort_left_nl,  insort_left.__name__,  __len__, [], 11]
    - [insort_right_nl, insort_right.__name__, __len__, [], 12]
    - [bisect_alias_nl, bisect.__name__,       __len__, [], 12]
    - [insort_alias_nl, insort.__name__,       __len__, [], 12]

# ---------------------------------------------------------------------------
# __qualname__.__len__() for all 6 bisect callables — extra24 namespace
#
# For all C builtins from _bisect the qualname equals the function name
# (module-level definitions). Aliases bisect and insort resolve to
# bisect_right and insort_right; their __qualname__ is that of the underlying
# function. So __qualname__.__len__() values match __name__.__len__() exactly.
# id_prefix bsql24 is novel.
# ---------------------------------------------------------------------------

table bisect_extra24.qualname_lens:
  description: "__qualname__.__len__() for all 6 bisect callables — qualname equals name for C builtins; aliases resolve to underlying qualname"
  kind: python_call_eq
  category: function_qualname
  id_prefix: bsql24

  columns: [id, function, method, method_args, expected]
  rows:
    - [bisect_left_ql,  bisect_left.__qualname__,  __len__, [], 11]
    - [bisect_right_ql, bisect_right.__qualname__, __len__, [], 12]
    - [insort_left_ql,  insort_left.__qualname__,  __len__, [], 11]
    - [insort_right_ql, insort_right.__qualname__, __len__, [], 12]
    - [bisect_alias_ql, bisect.__qualname__,       __len__, [], 12]
    - [insort_alias_ql, insort.__qualname__,       __len__, [], 12]

# ---------------------------------------------------------------------------
# bisect.insort_right.__module__.__len__() — length of '_bisect' (7 chars)
#
# insort_right is a C builtin from _bisect. Its __module__ == '_bisect' (7
# characters). bisect_extra23 covers insort_left.__module__.__len__() as a
# standalone invariant; this fills the insort_right gap in the extra24 namespace.
# ---------------------------------------------------------------------------

invariant bisect_extra24.insort_right.module_len:
  description: "bisect.insort_right.__module__.__len__() == 7 — len('_bisect') == 7; C builtin from _bisect"
  category: function_module
  kind: python_call_eq
  function: insort_right.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# bisect.insort.__module__.__len__() — length of '_bisect' (7 chars)
#
# bisect.insort is an alias for insort_right. Since it is the same underlying
# C function object, __module__ == '_bisect' (len 7). This confirms that
# attribute access via the alias name yields the same module metadata as the
# canonical name. No prior bisect spec checks insort.__module__.__len__() in
# the extra24 namespace.
# ---------------------------------------------------------------------------

invariant bisect_extra24.insort.module_len:
  description: "bisect.insort.__module__.__len__() == 7 — alias insort points to insort_right; same C origin"
  category: function_module
  kind: python_call_eq
  function: insort.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# bisect.bisect_left.__name__.__len__() — length of 'bisect_left' (11 chars)
#
# bisect_left.__name__ == 'bisect_left'; len == 11. Standalone invariant in
# extra24 namespace. The bisect_left and insort_left names share the same
# length (11), while bisect_right and insort_right are one character longer (12).
# ---------------------------------------------------------------------------

invariant bisect_extra24.bisect_left.name_len:
  description: "bisect.bisect_left.__name__.__len__() == 11 — len('bisect_left') == 11"
  category: function_name
  kind: python_call_eq
  function: bisect_left.__name__.__len__
  args: []
  expected: 11

# ---------------------------------------------------------------------------
# bisect.bisect_right.__name__.__len__() — length of 'bisect_right' (12 chars)
#
# bisect_right.__name__ == 'bisect_right'; len == 12. One character longer than
# bisect_left (11) due to the 'right' suffix vs 'left'. Standalone invariant
# in extra24 namespace.
# ---------------------------------------------------------------------------

invariant bisect_extra24.bisect_right.name_len:
  description: "bisect.bisect_right.__name__.__len__() == 12 — len('bisect_right') == 12"
  category: function_name
  kind: python_call_eq
  function: bisect_right.__name__.__len__
  args: []
  expected: 12

# ---------------------------------------------------------------------------
# bisect.insort_right.__name__.__len__() — length of 'insort_right' (12 chars)
#
# insort_right.__name__ == 'insort_right'; len == 12. Matches bisect_right's
# name length (12). Standalone invariant in extra24 namespace confirming the
# symmetric structure of the bisect API naming convention.
# ---------------------------------------------------------------------------

invariant bisect_extra24.insort_right.name_len:
  description: "bisect.insort_right.__name__.__len__() == 12 — len('insort_right') == 12"
  category: function_name
  kind: python_call_eq
  function: insort_right.__name__.__len__
  args: []
  expected: 12
