spec: concurrent_futures_extra260
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/__init__.py"
  notes:
    - "concurrent.futures.__name__ == 'concurrent.futures' (full dotted name)."
    - "concurrent.futures.__package__ == 'concurrent.futures'."
    - "concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec' (importlib machinery)."
    - "concurrent.futures.__spec__.name == 'concurrent.futures'."
    - "concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader'."
    - "concurrent is a namespace package; type(concurrent.__path__).__name__ == 'list'."
    - "concurrent.__name__ == 'concurrent'."
    - "concurrent.__spec__.__class__.__name__ == 'ModuleSpec'."
    - "concurrent.futures does NOT define __version__."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures module identity
#
# The module's __name__ is the full dotted name 'concurrent.futures'.
# __package__ is the same as __name__ for packages.
# __spec__ is a ModuleSpec from importlib._bootstrap.
# __loader__ is a SourceFileLoader (concrete package with __init__.py).
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra260.module.name:
  description: "concurrent.futures.__name__ == 'concurrent.futures'"
  category: identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra260.module.package:
  description: "concurrent.futures.__package__ == 'concurrent.futures'"
  category: identity
  kind: python_call_eq
  function: __package__.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra260.module.spec_class:
  description: "concurrent.futures.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: __spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant concurrent_futures_extra260.module.spec_name:
  description: "concurrent.futures.__spec__.name == 'concurrent.futures'"
  category: identity
  kind: python_call_eq
  function: __spec__.name.__eq__
  args: ["concurrent.futures"]
  expected: true

invariant concurrent_futures_extra260.module.loader_class:
  description: "concurrent.futures.__loader__.__class__.__name__ == 'SourceFileLoader'"
  category: identity
  kind: python_call_eq
  function: __loader__.__class__.__name__.__eq__
  args: ["SourceFileLoader"]
  expected: true

# ---------------------------------------------------------------------------
# concurrent package identity
#
# 'concurrent' is a namespace package (no __init__.py).
# Its __path__ is a plain list (not a _NamespacePath) on Python 3.14.
# __spec__.name is 'concurrent'.
# ---------------------------------------------------------------------------

invariant concurrent_futures_extra260.concurrent_pkg.name:
  description: "concurrent.__name__ == 'concurrent'"
  category: identity
  kind: python_call_eq
  function: concurrent.__name__.__eq__
  args: ["concurrent"]
  expected: true

invariant concurrent_futures_extra260.concurrent_pkg.path_type:
  description: "type(concurrent.__path__).__name__ == 'list'"
  category: identity
  kind: python_call_eq
  function: concurrent.__path__.__class__.__name__.__eq__
  args: ["list"]
  expected: true

invariant concurrent_futures_extra260.concurrent_pkg.spec_class:
  description: "concurrent.__spec__.__class__.__name__ == 'ModuleSpec'"
  category: identity
  kind: python_call_eq
  function: concurrent.__spec__.__class__.__name__.__eq__
  args: ["ModuleSpec"]
  expected: true

invariant concurrent_futures_extra260.concurrent_pkg.spec_name:
  description: "concurrent.__spec__.name == 'concurrent'"
  category: identity
  kind: python_call_eq
  function: concurrent.__spec__.name.__eq__
  args: ["concurrent"]
  expected: true
