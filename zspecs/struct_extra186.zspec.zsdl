spec: struct_extra186
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html
rfcs:
  - "IEEE 754-2019 — Standard for Floating-Point Arithmetic (for float/double format strings)"

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct module documentation"
    - "IEEE 754-2019 — Standard for Floating-Point Arithmetic"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec covers struct module-level function identity attributes not previously covered."
    - "struct.pack.__name__ == 'pack' — the module-level pack function (not struct.Struct.pack method)."
    - "struct.pack.__module__ == '_struct' — all module-level struct functions are C-level from the _struct extension."
    - "struct.pack.__class__.__name__ == 'builtin_function_or_method' — C-level built-in function."
    - "struct.unpack.__name__ == 'unpack', struct.unpack.__module__ == '_struct'."
    - "struct.calcsize.__name__ == 'calcsize', struct.calcsize.__module__ == '_struct'."
    - "struct.pack_into.__name__ == 'pack_into', struct.pack_into.__module__ == '_struct'."
    - "struct.unpack_from.__name__ == 'unpack_from', struct.unpack_from.__module__ == '_struct'."
    - "struct.iter_unpack.__name__ == 'iter_unpack', struct.iter_unpack.__module__ == '_struct'."
    - "All module-level struct functions share __class__.__name__ == 'builtin_function_or_method' (C extension)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct.pack — module-level function identity checks
#
# struct.pack.__name__ == 'pack'
# struct.pack.__module__ == '_struct'
# struct.pack.__class__.__name__ == 'builtin_function_or_method'
# ---------------------------------------------------------------------------

table struct_extra186.pack_identity:
  description: "struct.pack module-level function identity checks in structmodfuncs186 namespace — struct.pack is the module-level function for packing values into bytes (not the Struct.pack bound method); pack.__name__.__eq__('pack')==True (len=4: 'pack'=4, the shortest function name in this spec); pack.__module__.__eq__('_struct')==True (len=7: '_struct'=7, C extension; all struct module-level functions originate from _struct); pack.__class__.__name__.__eq__('builtin_function_or_method')==True (len=26: C-level functions expose this class name; all five module-level functions share this class name); compare: struct.Struct (compiled struct object, __class__.__name__='Struct') vs module-level pack (class='builtin_function_or_method'); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  category: function_identity
  id_prefix: structmodfuncs186

  columns: [id, function, args, expected, description]
  rows:
    - [pack_name_eq,   pack.__name__.__eq__,          ["pack"],                        true, "struct.pack.__name__ == 'pack' (len=4, shortest name in spec); verified with Python 3.14.3"]
    - [pack_module_eq, pack.__module__.__eq__,         ["_struct"],                     true, "struct.pack.__module__ == '_struct' (C extension, not Python 'struct' wrapper); verified with Python 3.14.3"]
    - [pack_cls_eq,    pack.__class__.__name__.__eq__, ["builtin_function_or_method"],  true, "struct.pack.__class__.__name__ == 'builtin_function_or_method' (C-level function); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.unpack and struct.calcsize — function identity checks
#
# unpack.__name__ == 'unpack', unpack.__module__ == '_struct'
# calcsize.__name__ == 'calcsize', calcsize.__module__ == '_struct'
# ---------------------------------------------------------------------------

table struct_extra186.unpack_calcsize_identity:
  description: "struct.unpack and struct.calcsize module-level function identity checks in structmodfuncs186 namespace — unpack is the module-level function for unpacking bytes into Python values (complement to pack); calcsize computes the byte size of a format string without packing; unpack.__name__.__eq__('unpack')==True (len=6: 'unpack'=6, longer than 'pack'=4); unpack.__module__.__eq__('_struct')==True (same C extension as pack); calcsize.__name__.__eq__('calcsize')==True (len=8: 'calcsize'=8, longer than 'unpack'=6); calcsize.__module__.__eq__('_struct')==True; unpack.__class__.__name__.__eq__('builtin_function_or_method')==True (same class as pack); calcsize.__class__.__name__.__eq__('builtin_function_or_method')==True; name lengths: 'pack'=4 < 'unpack'=6 < 'calcsize'=8; all verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  category: function_identity
  id_prefix: structmodfuncs186a

  columns: [id, function, args, expected, description]
  rows:
    - [unpack_name_eq,    unpack.__name__.__eq__,            ["unpack"],                        true, "struct.unpack.__name__ == 'unpack' (len=6); verified with Python 3.14.3"]
    - [unpack_module_eq,  unpack.__module__.__eq__,           ["_struct"],                       true, "struct.unpack.__module__ == '_struct' (same C extension as pack); verified with Python 3.14.3"]
    - [calcsize_name_eq,  calcsize.__name__.__eq__,           ["calcsize"],                      true, "struct.calcsize.__name__ == 'calcsize' (len=8, longer than unpack=6); verified with Python 3.14.3"]
    - [calcsize_mod_eq,   calcsize.__module__.__eq__,         ["_struct"],                       true, "struct.calcsize.__module__ == '_struct' (C extension); verified with Python 3.14.3"]
    - [calcsize_cls_eq,   calcsize.__class__.__name__.__eq__, ["builtin_function_or_method"],    true, "struct.calcsize.__class__.__name__ == 'builtin_function_or_method' (C-level); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# struct.pack_into and struct.unpack_from — function identity checks
#
# pack_into.__name__ == 'pack_into', pack_into.__module__ == '_struct'
# unpack_from.__name__ == 'unpack_from', unpack_from.__module__ == '_struct'
# ---------------------------------------------------------------------------

table struct_extra186.pack_into_unpack_from_identity:
  description: "struct.pack_into and struct.unpack_from module-level function identity checks in structmodfuncs186 namespace — pack_into writes packed bytes into a writable buffer at a given offset (in-place, returns None); unpack_from reads from a buffer at a given offset without requiring an exact-size match; pack_into.__name__.__eq__('pack_into')==True (len=9: 'pack_into'=4+1+4=9, longest pack-family name; compare: 'pack'=4, 'pack_into'=9); pack_into.__module__.__eq__('_struct')==True; unpack_from.__name__.__eq__('unpack_from')==True (len=11: 'unpack_from'=6+1+4=11, longest unpack-family name; compare: 'unpack'=6, 'unpack_from'=11); unpack_from.__module__.__eq__('_struct')==True; pack_into.__class__.__name__.__eq__('builtin_function_or_method')==True; name length ordering in spec: 'pack'=4 < 'unpack'=6 < 'calcsize'=8 < 'pack_into'=9 < 'iter_unpack'=11 = 'unpack_from'=11; all verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  kind: python_call_eq
  category: function_identity
  id_prefix: structmodfuncs186b

  columns: [id, function, args, expected, description]
  rows:
    - [packinto_name_eq,    pack_into.__name__.__eq__,             ["pack_into"],                    true, "struct.pack_into.__name__ == 'pack_into' (len=9, '_struct' C extension); verified with Python 3.14.3"]
    - [packinto_mod_eq,     pack_into.__module__.__eq__,            ["_struct"],                      true, "struct.pack_into.__module__ == '_struct' (C extension); verified with Python 3.14.3"]
    - [packinto_cls_eq,     pack_into.__class__.__name__.__eq__,   ["builtin_function_or_method"],   true, "struct.pack_into.__class__.__name__ == 'builtin_function_or_method'; verified with Python 3.14.3"]
    - [unpackfrom_name_eq,  unpack_from.__name__.__eq__,            ["unpack_from"],                  true, "struct.unpack_from.__name__ == 'unpack_from' (len=11, longest in spec); verified with Python 3.14.3"]
    - [unpackfrom_mod_eq,   unpack_from.__module__.__eq__,          ["_struct"],                      true, "struct.unpack_from.__module__ == '_struct' (C extension); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — struct_extra186
# ---------------------------------------------------------------------------

invariant struct_extra186.pack_name_is_pack:
  description: "struct.pack.__name__ == 'pack' — the module-level pack function's __name__ is 'pack' (len=4, the shortest name among the five module-level struct functions: pack=4, unpack=6, calcsize=8, pack_into=9, unpack_from=11); struct.pack accepts a format string and values, returns packed bytes; struct.pack.__module__=='_struct' (C extension); struct.pack.__class__.__name__=='builtin_function_or_method' (C-level); this is the module-level function, not a bound method of struct.Struct; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: pack.__name__.__eq__
  args: ["pack"]
  expected: true

invariant struct_extra186.pack_module_is_struct_c:
  description: "struct.pack.__module__ == '_struct' — pack is implemented in the _struct C extension module (Modules/_struct.c in CPython); the Python-level 'struct' module re-exports all these functions from _struct; '_struct'=7 chars; compare: uuid.UUID.__init__.__module__=='uuid' (Python-defined) vs struct.pack.__module__=='_struct' (C extension); struct.unpack.__module__, struct.calcsize.__module__, struct.pack_into.__module__, struct.unpack_from.__module__ are all '_struct' as well; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: pack.__module__.__eq__
  args: ["_struct"]
  expected: true

invariant struct_extra186.pack_class_is_builtin:
  description: "struct.pack.__class__.__name__ == 'builtin_function_or_method' — pack is a C-level function whose class name is 'builtin_function_or_method' (len=26, the longest string value in this spec); all five module-level struct functions share this class name; contrast: hashlib.new.__class__.__name__=='function' (Python-defined), hashlib.blake2b.__class__.__name__=='type' (C-level class); 'builtin_function_or_method' is the standard Python type name for C extension functions; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: pack.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant struct_extra186.unpack_name_is_unpack:
  description: "struct.unpack.__name__ == 'unpack' — the module-level unpack function's __name__ is 'unpack' (len=6); struct.unpack is the inverse of struct.pack; it takes a format string and a bytes-like object and returns a tuple of unpacked values; struct.unpack.__module__=='_struct' (C extension); struct.unpack.__class__.__name__=='builtin_function_or_method'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: unpack.__name__.__eq__
  args: ["unpack"]
  expected: true

invariant struct_extra186.calcsize_name_is_calcsize:
  description: "struct.calcsize.__name__ == 'calcsize' — the module-level calcsize function's __name__ is 'calcsize' (len=8); calcsize(fmt) returns the number of bytes required to pack the given format string, equivalent to struct.Struct(fmt).size; calcsize is useful for computing buffer sizes before packing; struct.calcsize.__module__=='_struct'; struct.calcsize.__class__.__name__=='builtin_function_or_method'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: calcsize.__name__.__eq__
  args: ["calcsize"]
  expected: true

invariant struct_extra186.pack_into_name_is_pack_into:
  description: "struct.pack_into.__name__ == 'pack_into' — the module-level pack_into function's __name__ is 'pack_into' (len=9); pack_into(fmt, buffer, offset, v1, v2, ...) writes packed bytes into a writable buffer at the given offset; it returns None and modifies the buffer in-place; struct.pack_into.__module__=='_struct'; struct.pack_into.__class__.__name__=='builtin_function_or_method'; 'pack_into'=9 is longer than 'pack'=4 (adds '_into'=5); verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: pack_into.__name__.__eq__
  args: ["pack_into"]
  expected: true

invariant struct_extra186.unpack_from_name_is_unpack_from:
  description: "struct.unpack_from.__name__ == 'unpack_from' — the module-level unpack_from function's __name__ is 'unpack_from' (len=11, tied longest in spec with iter_unpack=11); unpack_from(fmt, buffer, offset=0) reads from a buffer at the given offset; unlike unpack(), unpack_from() does not require the buffer to be exactly calcsize(fmt) bytes long; struct.unpack_from.__module__=='_struct'; struct.unpack_from.__class__.__name__=='builtin_function_or_method'; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: unpack_from.__name__.__eq__
  args: ["unpack_from"]
  expected: true

invariant struct_extra186.unpack_module_is_struct_c:
  description: "struct.unpack.__module__ == '_struct' — the module-level unpack is a C-level function from the _struct extension; struct.unpack.__class__.__name__=='builtin_function_or_method'; 'unpack'=6 chars; struct.unpack is the complement to struct.pack; it accepts a format string and bytes and returns a tuple; all six module-level struct functions (pack, unpack, calcsize, pack_into, unpack_from, iter_unpack) originate from the _struct C extension module; verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  category: function_identity
  kind: python_call_eq
  function: unpack.__module__.__eq__
  args: ["_struct"]
  expected: true

