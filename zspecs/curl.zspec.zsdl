  status: infeasible
  model: claude-cli
  attempted_at: 2026-04-15T03:40:01Z
  iterations: 1
  pass_count: 0
  fail_count: 0
  total_invariants: 24
  notes: "LLM unavailable: claude CLI timed out after 600s"
  infeasible_reason: llm_unavailable
  invariant_annotations: {}
