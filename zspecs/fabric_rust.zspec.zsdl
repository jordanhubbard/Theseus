spec: fabric_rust
version: ">=3.9"
backend: rust_module(fabric_rust)

docs: https://www.fabfile.org/

provenance:
  derived_from:
    - "https://www.fabfile.org/ — Fabric documentation"
  not_derived_from:
    - "fabric source: fabric/__init__.py"
  notes:
    - "Fabric provides streamlining of SSH for Python."
    - "fabric.Connection is available."
    - "fabric.Connection.__name__ == 'Connection'."
    - "fabric.task is available as a decorator."
    - "fabric.__version__ is a non-empty string."
    - "Expose fabric_conn_name() -> str: fabric.Connection.__name__."
    - "Expose fabric_has_task() -> bool: hasattr(fabric, 'task')."
    - "Expose fabric_version_nonempty() -> bool: len(fabric.__version__) > 0."
    - "All test vectors verified against fabric 3.2.2."
  created_at: "2026-04-19T00:00:00Z"

error_model: python_exceptions

# fabric_conn_name — Connection class name
invariant fabric_rust.connection.class_name:
  description: "fabric.Connection.__name__ == 'Connection'"
  category: connection
  kind: python_call_eq
  function: fabric_conn_name
  args: []
  expected: "Connection"

# fabric_has_task — task decorator present
invariant fabric_rust.module.has_task:
  description: "fabric.task is available"
  category: module
  kind: python_call_eq
  function: fabric_has_task
  args: []
  expected: true

# fabric_version_nonempty — version non-empty
invariant fabric_rust.version.nonempty:
  description: "fabric.__version__ is non-empty"
  category: version
  kind: python_call_eq
  function: fabric_version_nonempty
  args: []
  expected: true

