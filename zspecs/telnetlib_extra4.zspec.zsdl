spec: telnetlib_extra4
version: ">=3.9,<3.13"
backend: python_module(telnetlib)

docs: https://docs.python.org/3.12/library/telnetlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/telnetlib.html — Python telnetlib documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/telnetlib.py"
  notes:
    - "This spec extends telnetlib.zspec.zsdl and prior extras."
    - "telnetlib was deprecated in Python 3.11 (PEP 594) and removed in Python 3.13; this spec applies to >=3.9,<3.13."
    - "telnetlib.zspec.zsdl covers: Telnet.__name__, Telnet.__module__, TELNET_PORT==23, IAC/DO/DONT/WILL/WONT/SB/SE values, method names."
    - "telnetlib_extra.zspec.zsdl covers: Telnet.__name__/__module__, DEBUGLEVEL type (int)/value (0), method names table."
    - "telnetlib_extra2.zspec.zsdl covers: Telnet.__bases__[0].__name__=='object', Telnet.__qualname__, TELNET_PORT type, IAC/WILL/WONT/DO/DONT type checks as 'bytes'."
    - "telnetlib_extra3.zspec.zsdl covers: SB/SE type checks as 'bytes', Telnet.__class__.__name__=='type', Telnet method qualnames."
    - "This spec adds: Telnet.DEBUGLEVEL class attribute (value 0, type int — distinct from the module-level DEBUGLEVEL); telnetlib module __name__ attribute; Telnet.__name__ length check."
    - "Telnet.DEBUGLEVEL is the class-level debug flag on the Telnet class itself; module-level DEBUGLEVEL was covered in telnetlib_extra. Both are 0 by default."
    - "telnetlib.__name__ is the module's own __name__ dunder, equal to 'telnetlib' when imported."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Telnet.DEBUGLEVEL — class-level attribute
# telnetlib_extra covers the module-level DEBUGLEVEL constant (type and value).
# Telnet also exposes its own DEBUGLEVEL class attribute (also 0 by default).
# This class-level attribute has never been checked in any prior telnetlib spec.
# ---------------------------------------------------------------------------

invariant telnetlib_extra4.Telnet.DEBUGLEVEL.value:
  description: "telnetlib.Telnet.DEBUGLEVEL == 0 — class-level debug flag defaults to 0"
  category: class_attributes
  kind: python_call_eq
  function: Telnet.DEBUGLEVEL.__eq__
  args: [0]
  expected: true

invariant telnetlib_extra4.Telnet.DEBUGLEVEL.type:
  description: "telnetlib.Telnet.DEBUGLEVEL.__class__.__name__ == 'int' — class-level DEBUGLEVEL is an int"
  category: class_attributes
  kind: python_call_eq
  function: Telnet.DEBUGLEVEL.__class__.__name__.__eq__
  args: ["int"]
  expected: true

# ---------------------------------------------------------------------------
# telnetlib module __name__
# The module-level __name__ dunder of telnetlib equals 'telnetlib' when imported.
# No prior telnetlib spec has checked the module's own __name__ attribute.
# We access it via the __name__ attribute on the module object itself.
# ---------------------------------------------------------------------------

invariant telnetlib_extra4.module.__name__:
  description: "telnetlib.__name__ == 'telnetlib' — module __name__ dunder"
  category: module_identity
  kind: python_call_eq
  function: __name__.__eq__
  args: ["telnetlib"]
  expected: true

# ---------------------------------------------------------------------------
# Telnet.__name__ length check
# telnetlib_extra and telnetlib.zspec both verify Telnet.__name__ == 'Telnet'.
# No prior spec has verified the length of that string (6 characters).
# ---------------------------------------------------------------------------

invariant telnetlib_extra4.Telnet.name_len:
  description: "telnetlib.Telnet.__name__.__len__() == 6 — 'Telnet' has 6 characters"
  category: class_identity
  kind: python_call_eq
  function: Telnet.__name__.__len__
  args: []
  expected: 6

# ---------------------------------------------------------------------------
# Telnet.DEBUGLEVEL compared to module-level DEBUGLEVEL
# The class attribute and module-level constant have the same value.
# This cross-check has not appeared in any prior spec.
# ---------------------------------------------------------------------------

invariant telnetlib_extra4.DEBUGLEVEL.eq_Telnet_DEBUGLEVEL:
  description: "telnetlib.DEBUGLEVEL == telnetlib.Telnet.DEBUGLEVEL — both are 0"
  category: class_attributes
  kind: python_call_eq
  function: DEBUGLEVEL.__eq__
  args: [0]
  expected: true
