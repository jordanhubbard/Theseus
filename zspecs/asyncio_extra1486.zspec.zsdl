spec: asyncio_extra1486
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio.html — Python asyncio module documentation"
    - "https://docs.python.org/3/library/asyncio-sync.html — asyncio synchronization primitives"
    - "https://docs.python.org/3/library/asyncio-task.html — asyncio Tasks and coroutines"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/asyncio/locks.py"
    - "CPython source: Lib/asyncio/taskgroups.py"
  notes:
    - "Wave 546 theme: __enter__/__exit__ and __aenter__/__aexit__ context manager protocol checks."
    - "asyncio.Lock, asyncio.Semaphore, asyncio.Condition all inherit __aenter__/__aexit__ from asyncio.locks._ContextManagerMixin; they do NOT have these methods in their own __dict__."
    - "asyncio.locks._ContextManagerMixin.__dict__.__contains__('__aenter__') == True (defined here)."
    - "asyncio.locks._ContextManagerMixin.__dict__.__contains__('__aexit__') == True (defined here)."
    - "asyncio.TaskGroup.__dict__.__contains__('__aenter__') == True (TaskGroup defines its own __aenter__)."
    - "asyncio.TaskGroup.__dict__.__contains__('__aexit__') == True (TaskGroup defines its own __aexit__)."
    - "asyncio.Queue, asyncio.Task, asyncio.Future do NOT support context managers (sync or async) — __aenter__ not in __dict__ for any of them."
    - "asyncio.Lock.__dict__.__contains__('__aenter__') == False — __aenter__ is inherited from _ContextManagerMixin, not defined directly on Lock."
    - "All __aenter__/__aexit__ in asyncio are 'function' (plain Python functions, not C-level descriptors)."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.locks._ContextManagerMixin — async context manager protocol presence
#
# _ContextManagerMixin defines __aenter__ and __aexit__ directly in its own
# __dict__. Lock, Semaphore, and Condition inherit from it and therefore do NOT
# have these methods in their own __dict__. The mixin itself has neither
# __enter__ nor __exit__ — only the async variants.
# ---------------------------------------------------------------------------

table asyncio_extra1486.contextmgrmixin_dict_contains:
  description: "asyncio.locks._ContextManagerMixin.__dict__.__contains__ checks for async context manager protocol in as1486cm namespace — wave 546 theme: __aenter__ and __aexit__ are defined directly in _ContextManagerMixin.__dict__ (True); __enter__ and __exit__ (sync) are NOT defined there (False); Lock, Semaphore, Condition all inherit __aenter__/__aexit__ from this mixin and do NOT have them in their own __dict__; verified with Python 3.12"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: as1486cm

  columns: [id, function, args, expected]
  rows:
    - [as1486cm001, asyncio.locks._ContextManagerMixin.__dict__.__contains__, ["__aenter__"], true]
    - [as1486cm002, asyncio.locks._ContextManagerMixin.__dict__.__contains__, ["__aexit__"],  true]
    - [as1486cm003, asyncio.locks._ContextManagerMixin.__dict__.__contains__, ["__enter__"],  false]
    - [as1486cm004, asyncio.locks._ContextManagerMixin.__dict__.__contains__, ["__exit__"],   false]
    - [as1486cm005, asyncio.locks._ContextManagerMixin.__aenter__.__class__.__name__.__eq__, ["function"], true]
    - [as1486cm006, asyncio.locks._ContextManagerMixin.__aexit__.__class__.__name__.__eq__,  ["function"], true]

# ---------------------------------------------------------------------------
# asyncio.TaskGroup — async context manager protocol presence
#
# TaskGroup defines __aenter__ and __aexit__ directly in its own __dict__.
# It has neither __enter__ nor __exit__ (sync) in its __dict__. The class
# was added in Python 3.11 as the canonical way to run concurrent tasks.
# ---------------------------------------------------------------------------

table asyncio_extra1486.taskgroup_dict_contains:
  description: "asyncio.TaskGroup.__dict__.__contains__ checks for async context manager protocol in as1486tg namespace — wave 546 theme: TaskGroup.__dict__.__contains__('__aenter__') == True (TaskGroup defines its own async enter, added Python 3.11); TaskGroup.__dict__.__contains__('__aexit__') == True (TaskGroup defines its own async exit); TaskGroup has no sync __enter__ or __exit__; __aenter__.__class__.__name__=='function', __aexit__.__class__.__name__=='function'; verified with Python 3.12"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: as1486tg

  columns: [id, function, args, expected]
  rows:
    - [as1486tg001, asyncio.TaskGroup.__dict__.__contains__, ["__aenter__"], true]
    - [as1486tg002, asyncio.TaskGroup.__dict__.__contains__, ["__aexit__"],  true]
    - [as1486tg003, asyncio.TaskGroup.__dict__.__contains__, ["__enter__"],  false]
    - [as1486tg004, asyncio.TaskGroup.__dict__.__contains__, ["__exit__"],   false]
    - [as1486tg005, asyncio.TaskGroup.__aenter__.__class__.__name__.__eq__, ["function"], true]
    - [as1486tg006, asyncio.TaskGroup.__aexit__.__class__.__name__.__eq__,  ["function"], true]

# ---------------------------------------------------------------------------
# asyncio.Lock, asyncio.Semaphore, asyncio.Condition — NOT in their own __dict__
#
# These classes inherit __aenter__/__aexit__ from _ContextManagerMixin and do
# NOT define them in their own __dict__. asyncio.Queue, asyncio.Task, and
# asyncio.Future do not support any context manager protocol at all.
# ---------------------------------------------------------------------------

table asyncio_extra1486.lock_sem_cond_dict_no_enter:
  description: "asyncio Lock/Semaphore/Condition do NOT have __aenter__/__aexit__ in their own __dict__ — wave 546: these classes inherit async context manager methods from _ContextManagerMixin; __aenter__ NOT in Lock/__dict__, Semaphore/__dict__, Condition/__dict__; likewise __aexit__ not in their own __dict__; Queue/Task/Future have no context manager protocol whatsoever; verified with Python 3.12"
  kind: python_call_eq
  category: context_manager_protocol
  id_prefix: as1486nc

  columns: [id, function, args, expected]
  rows:
    - [as1486nc001, asyncio.Lock.__dict__.__contains__,      ["__aenter__"], false]
    - [as1486nc002, asyncio.Lock.__dict__.__contains__,      ["__aexit__"],  false]
    - [as1486nc003, asyncio.Semaphore.__dict__.__contains__,  ["__aenter__"], false]
    - [as1486nc004, asyncio.Semaphore.__dict__.__contains__,  ["__aexit__"],  false]
    - [as1486nc005, asyncio.Condition.__dict__.__contains__,  ["__aenter__"], false]
    - [as1486nc006, asyncio.Condition.__dict__.__contains__,  ["__aexit__"],  false]
    - [as1486nc007, asyncio.Queue.__dict__.__contains__,      ["__aenter__"], false]
    - [as1486nc008, asyncio.Task.__dict__.__contains__,       ["__aenter__"], false]
    - [as1486nc009, asyncio.Future.__dict__.__contains__,     ["__aenter__"], false]
