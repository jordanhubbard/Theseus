spec: abc_extra45
version: ">=3.9"
backend: python_module(abc)

docs: https://docs.python.org/3/library/abc.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/abc.html — Python abc module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/abc.py"
    - "CPython source: Modules/_abc.c"
  notes:
    - "This spec extends abc_extra44.zspec.zsdl."
    - "Prior specs covered: ABC/__name__/__module__/__qualname__/__bases__[0].__name__, ABCMeta/__name__/__module__/__qualname__, abstractmethod/__name__/__module__/__qualname__, get_cache_token/__name__/__module__/__qualname__, __module__/__name__/__qualname__.__len__() for all five, abstractproperty lengths, ABCMeta.register qualname lengths (extra35: register.__qualname__.__len__()==16), ABCMeta method __qualname__.__len__() tables, __mro__.__len__() for ABCMeta(3)/ABC(2), __bases__[0].__name__.__len__(), __dict__.__class__.__name__.__len__(), various qualname length tables, ABCMeta MRO entries, ABC/__abstractmethods__/__class__/__name__=='frozenset', ABC/__abstractmethods__/__len__()==0, ABCMeta.__call__/__qualname__=='type.__call__', class qualname string equality, abstractmethod/__class__.__name__=='function', abstractproperty/__class__.__name__=='type', ABC/__class__.__name__=='ABCMeta', abstractproperty/__mro__.__len__()==3, abstractclassmethod/__mro__.__len__()==3, abstractstaticmethod/__mro__.__len__()==3 (extra40), __class__.__qualname__ string equality and __len__() for all abc exports (extra41–extra43), abstractmethod/__doc__/__class__/__name__=='str', ABCMeta/__doc__/__class__/__name__=='str', ABC/__doc__/__class__/__name__=='str', get_cache_token/__doc__/__class__/__name__=='str', abstractproperty/__doc__/__class__/__name__=='str', abc/__doc__/__class__/__name__=='str', abc/__doc__/__class__/__qualname__=='str', abstractmethod/__doc__/__class__/__qualname__=='str', ABCMeta/__doc__/__class__/__module__=='builtins', abstractmethod/__doc__/__class__/__module__=='builtins' (extra44)."
    - "This spec covers: ABCMeta/__subclasshook__/__qualname__.__eq__('ABCMeta.__subclasshook__'); ABC/__subclasshook__/__qualname__.__eq__('ABC.__subclasshook__'); ABCMeta/__instancecheck__/__qualname__.__len__()==25; ABCMeta/__subclasscheck__/__qualname__.__len__()==25; ABCMeta/__instancecheck__/__qualname__.__eq__('ABCMeta.__instancecheck__'); ABCMeta/__subclasscheck__/__qualname__.__eq__('ABCMeta.__subclasscheck__'); abstractclassmethod/__doc__/__class__/__name__=='str'; abstractstaticmethod/__doc__/__class__/__name__=='str'; update_abstractmethods/__doc__/__class__/__name__=='str'."
    - "abc.ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__'. __subclasshook__ is a classmethod defined on ABCMeta that allows subclasses to customize issubclass() behavior. Its __qualname__ is 'ABCMeta.__subclasshook__' (7+1+16 = 24 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__'. ABC inherits __subclasshook__ from ABCMeta but re-exposes it with the 'ABC.' prefix in its qualname (3+1+16 = 20 chars). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25. 'ABCMeta.__instancecheck__' has 7+1+17 = 25 characters. __instancecheck__ is the hook for isinstance(); it is defined on ABCMeta in the C extension _abc. The __qualname__ prefix 'ABCMeta.' (8 chars) plus '__instancecheck__' (17 chars) equals 25. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25. 'ABCMeta.__subclasscheck__' has 7+1+17 = 25 characters. __subclasscheck__ is the hook for issubclass(); it is defined on ABCMeta in the C extension _abc. The __qualname__ prefix 'ABCMeta.' (8 chars) plus '__subclasscheck__' (17 chars) equals 25. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'. The full qualname string matches the dotted 'ClassName.method_name' pattern. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'. The full qualname string matches the dotted 'ClassName.method_name' pattern. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractclassmethod.__doc__.__class__.__name__ == 'str'. abstractclassmethod is a deprecated class (subclass of classmethod) defined in abc.py. Its class docstring is a plain Python string; __class__.__name__ == 'str'. Note: abstractclassmethod is deprecated since Python 3.3 and removed in Python 3.13. The version constraint '>=3.9' of this spec covers versions where it still exists. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.abstractstaticmethod.__doc__.__class__.__name__ == 'str'. abstractstaticmethod is a deprecated class (subclass of staticmethod) defined in abc.py. Its class docstring is a plain Python string; __class__.__name__ == 'str'. Same deprecation status as abstractclassmethod. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "abc.update_abstractmethods.__doc__.__class__.__name__ == 'str'. update_abstractmethods is a Python function added in Python 3.10. Its docstring is a plain Python string; __class__.__name__ == 'str'. This completes the __doc__ survey for abc exports that was started in extra44. Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "The __subclasshook__, __instancecheck__, and __subclasscheck__ methods on ABCMeta are defined in the _abc C extension. Their __qualname__ attributes still follow the 'ClassName.method' pattern because CPython records __qualname__ at definition time. The length of 25 for both __instancecheck__ and __subclasscheck__ reflects the equal length of those two dunder names (each 17 chars with both double-underscore pairs). Verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# abc.ABCMeta __subclasshook__ and ABC.__subclasshook__ qualname equality — extra45
#
# __subclasshook__ is the classmethod hook that allows ABCMeta subclasses to
# customize issubclass() behavior without calling register():
#   ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__'  (24 chars)
#   ABC.__subclasshook__.__qualname__     == 'ABC.__subclasshook__'      (20 chars)
# Both have the 'ClassName.__subclasshook__' qualname pattern.
# Prior specs covered ABCMeta.__subclasshook__.__qualname__.__len__()==24
# and ABC.__subclasshook__.__qualname__.__len__()==20 (from extra34 notes),
# but not the full string equality checks, which are new in extra45.
# ---------------------------------------------------------------------------

table abc_extra45.subclasshook_qualname_eq:
  description: "abc ABCMeta and ABC __subclasshook__.__qualname__ string equality in extra45 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: abcmeth45subhook

  columns: [id, function, args, expected, description]
  rows:
    - [ABCMeta, ABCMeta.__subclasshook__.__qualname__.__eq__, ["ABCMeta.__subclasshook__"], true, "ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' (24 chars: 'ABCMeta.'(8) + '__subclasshook__'(16))"]
    - [ABC,     ABC.__subclasshook__.__qualname__.__eq__,     ["ABC.__subclasshook__"],     true, "ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' (20 chars: 'ABC.'(4) + '__subclasshook__'(16))"]

# ---------------------------------------------------------------------------
# abc.ABCMeta __instancecheck__ and __subclasscheck__ qualname lengths — extra45
#
# ABCMeta defines __instancecheck__ and __subclasscheck__ as the hooks for
# isinstance() and issubclass() respectively. Both are defined in the _abc
# C extension:
#   ABCMeta.__instancecheck__.__qualname__.__len__() == 25
#     ('ABCMeta.__instancecheck__': 'ABCMeta.'(8) + '__instancecheck__'(17) = 25)
#   ABCMeta.__subclasscheck__.__qualname__.__len__() == 25
#     ('ABCMeta.__subclasscheck__': 'ABCMeta.'(8) + '__subclasscheck__'(17) = 25)
# Both dunder names have equal length (17 chars each), so both qualnames
# are 25 chars. These lengths have not been captured in prior specs.
# ---------------------------------------------------------------------------

table abc_extra45.instancecheck_subclasscheck_qualname_len:
  description: "abc.ABCMeta __instancecheck__ and __subclasscheck__ __qualname__.__len__() in extra45 namespace — both == 25"
  kind: python_call_eq
  category: method_names
  id_prefix: abcmeth45chklen

  columns: [id, function, args, expected, description]
  rows:
    - [instancecheck,  ABCMeta.__instancecheck__.__qualname__.__len__, [], 25, "ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — 'ABCMeta.__instancecheck__': 'ABCMeta.'(8) + '__instancecheck__'(17) = 25 chars"]
    - [subclasscheck,  ABCMeta.__subclasscheck__.__qualname__.__len__, [], 25, "ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 — 'ABCMeta.__subclasscheck__': 'ABCMeta.'(8) + '__subclasscheck__'(17) = 25 chars"]

# ---------------------------------------------------------------------------
# abc.ABCMeta __instancecheck__ and __subclasscheck__ qualname string equality — extra45
#
# The full qualname string for each of ABCMeta's check methods:
#   ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__'
#   ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__'
# These confirm both methods follow the 'ClassName.method_name' pattern
# and are defined directly on ABCMeta (not inherited).
# ---------------------------------------------------------------------------

table abc_extra45.instancecheck_subclasscheck_qualname_eq:
  description: "abc.ABCMeta __instancecheck__ and __subclasscheck__ __qualname__ string equality in extra45 namespace"
  kind: python_call_eq
  category: method_names
  id_prefix: abcmeth45chkeq

  columns: [id, function, args, expected, description]
  rows:
    - [instancecheck, ABCMeta.__instancecheck__.__qualname__.__eq__, ["ABCMeta.__instancecheck__"], true, "ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — hook for isinstance(); defined directly on ABCMeta in _abc C extension"]
    - [subclasscheck, ABCMeta.__subclasscheck__.__qualname__.__eq__, ["ABCMeta.__subclasscheck__"], true, "ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' — hook for issubclass(); defined directly on ABCMeta in _abc C extension"]

# ---------------------------------------------------------------------------
# abc deprecated class and update_abstractmethods __doc__.__class__.__name__ — extra45
#
# Completing the __doc__ survey started in extra44:
#   abstractclassmethod.__doc__.__class__.__name__  == 'str'
#   abstractstaticmethod.__doc__.__class__.__name__ == 'str'
#   update_abstractmethods.__doc__.__class__.__name__ == 'str'
# Extra44 covered abstractmethod/ABCMeta/ABC/get_cache_token/abstractproperty/abc-module.
# Extra45 covers the three remaining abc exports that have docstrings:
# abstractclassmethod, abstractstaticmethod (both deprecated since 3.3),
# and update_abstractmethods (added in 3.10).
# ---------------------------------------------------------------------------

table abc_extra45.remaining_doc_class_name_eq:
  description: "abc remaining exports __doc__.__class__.__name__ string equality in extra45 namespace — abstractclassmethod, abstractstaticmethod, update_abstractmethods all have str docstrings"
  kind: python_call_eq
  category: class_names
  id_prefix: abcmeth45docname

  columns: [id, function, args, expected, description]
  rows:
    - [abstractclassmethod,   abstractclassmethod.__doc__.__class__.__name__.__eq__,   ["str"], true, "abstractclassmethod.__doc__.__class__.__name__ == 'str' — deprecated class (subclass of classmethod); docstring is a plain Python string"]
    - [abstractstaticmethod,  abstractstaticmethod.__doc__.__class__.__name__.__eq__,  ["str"], true, "abstractstaticmethod.__doc__.__class__.__name__ == 'str' — deprecated class (subclass of staticmethod); docstring is a plain Python string"]
    - [update_abstractmethods, update_abstractmethods.__doc__.__class__.__name__.__eq__, ["str"], true, "update_abstractmethods.__doc__.__class__.__name__ == 'str' — function added in Python 3.10; docstring is a plain Python string"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra45
# ---------------------------------------------------------------------------

invariant abc_extra45.ABCMeta_subclasshook_qualname_eq:
  description: "abc.ABCMeta.__subclasshook__.__qualname__ == 'ABCMeta.__subclasshook__' — classmethod hook for issubclass(); __qualname__ is 'ABCMeta.__subclasshook__' (24 chars)"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__subclasshook__.__qualname__.__eq__
  args: ["ABCMeta.__subclasshook__"]
  expected: true

invariant abc_extra45.ABC_subclasshook_qualname_eq:
  description: "abc.ABC.__subclasshook__.__qualname__ == 'ABC.__subclasshook__' — ABC re-exposes the __subclasshook__ classmethod with 'ABC.' prefix in qualname (20 chars)"
  category: method_names
  kind: python_call_eq
  function: ABC.__subclasshook__.__qualname__.__eq__
  args: ["ABC.__subclasshook__"]
  expected: true

invariant abc_extra45.ABCMeta_instancecheck_qualname_len:
  description: "abc.ABCMeta.__instancecheck__.__qualname__.__len__() == 25 — 'ABCMeta.__instancecheck__': 'ABCMeta.'(8) + '__instancecheck__'(17) = 25 chars"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__qualname__.__len__
  args: []
  expected: 25

invariant abc_extra45.ABCMeta_subclasscheck_qualname_len:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__.__len__() == 25 — 'ABCMeta.__subclasscheck__': 'ABCMeta.'(8) + '__subclasscheck__'(17) = 25 chars"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__qualname__.__len__
  args: []
  expected: 25

invariant abc_extra45.ABCMeta_instancecheck_qualname_eq:
  description: "abc.ABCMeta.__instancecheck__.__qualname__ == 'ABCMeta.__instancecheck__' — isinstance() hook defined on ABCMeta in _abc C extension; follows 'ClassName.method_name' pattern"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__instancecheck__.__qualname__.__eq__
  args: ["ABCMeta.__instancecheck__"]
  expected: true

invariant abc_extra45.ABCMeta_subclasscheck_qualname_eq:
  description: "abc.ABCMeta.__subclasscheck__.__qualname__ == 'ABCMeta.__subclasscheck__' — issubclass() hook defined on ABCMeta in _abc C extension; follows 'ClassName.method_name' pattern"
  category: method_names
  kind: python_call_eq
  function: ABCMeta.__subclasscheck__.__qualname__.__eq__
  args: ["ABCMeta.__subclasscheck__"]
  expected: true

invariant abc_extra45.abstractclassmethod_doc_class_name_eq:
  description: "abc.abstractclassmethod.__doc__.__class__.__name__ == 'str' — deprecated class (subclass of classmethod); class docstring is a plain Python string"
  category: class_names
  kind: python_call_eq
  function: abstractclassmethod.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra45.abstractstaticmethod_doc_class_name_eq:
  description: "abc.abstractstaticmethod.__doc__.__class__.__name__ == 'str' — deprecated class (subclass of staticmethod); class docstring is a plain Python string"
  category: class_names
  kind: python_call_eq
  function: abstractstaticmethod.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true

invariant abc_extra45.update_abstractmethods_doc_class_name_eq:
  description: "abc.update_abstractmethods.__doc__.__class__.__name__ == 'str' — function added in Python 3.10; its docstring is a plain Python string; __class__.__name__ == 'str'"
  category: class_names
  kind: python_call_eq
  function: update_abstractmethods.__doc__.__class__.__name__.__eq__
  args: ["str"]
  expected: true
