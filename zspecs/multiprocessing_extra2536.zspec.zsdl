# ---------------------------------------------------------------------------
# Table 5: cross-class parity — __fspath__ absence across Process and all Queue variants
#
# Symmetric cross-check: Process and all three Queue variants all lack __fspath__.
# None of the core multiprocessing work classes implement the os.PathLike
# protocol — they are not filesystem objects.
# ---------------------------------------------------------------------------

table multiprocessing_extra2536.cross_class_fspath_parity:
  description: "__fspath__ absent from Process and all Queue variants; no multiprocessing class implements os.PathLike; wave 2536"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: mp2536

  columns: [id, function, args, expected]
  rows:
    - ["mp2536-013", multiprocessing.Process.__dict__.__contains__,              ["__fspath__"], false]
    - ["mp2536-014", multiprocessing.queues.Queue.__dict__.__contains__,         ["__fspath__"], false]
    - ["mp2536-015", multiprocessing.queues.SimpleQueue.__dict__.__contains__,   ["__fspath__"], false]
    - ["mp2536-016", multiprocessing.queues.JoinableQueue.__dict__.__contains__,  ["__fspath__"], false]

# ---------------------------------------------------------------------------
# Table 6: cross-class parity — __bytes__ absence across Process and all Queue variants
#
# Symmetric cross-check: Process and all three Queue variants all lack __bytes__.
# No multiprocessing class defines a custom bytes conversion — they communicate
# via pickle serialization of payloads, not via an object-level __bytes__ protocol.
# ---------------------------------------------------------------------------

table multiprocessing_extra2536.cross_class_bytes_parity:
  description: "__bytes__ absent from Process and all Queue variants; no multiprocessing class defines bytes conversion; wave 2536"
