    - ["mp2536-018", multiprocessing.queues.Queue.__dict__.__contains__,         ["__bytes__"], false]
    - ["mp2536-019", multiprocessing.queues.SimpleQueue.__dict__.__contains__,   ["__bytes__"], false]
    - ["mp2536-020", multiprocessing.queues.JoinableQueue.__dict__.__contains__,  ["__bytes__"], false]
