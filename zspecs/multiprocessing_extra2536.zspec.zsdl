spec: multiprocessing_extra2536
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — multiprocessing documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/process.py"
    - "CPython source: Lib/multiprocessing/queues.py"
    - "CPython source: Lib/multiprocessing/context.py"
  notes:
    - "Theme: __format__, __bytes__, and __fspath__ dict-presence — checking whether multiprocessing classes define custom formatting, bytes conversion, and filesystem path protocol in their class __dict__."
    - "multiprocessing.Process is a pure-Python class representing an OS-level subprocess; its interface is start/join/terminate and daemon/name/pid properties — no formatting, bytes, or path protocol is defined. Verified with Python 3.14."
    - "multiprocessing.queues.Queue is a process-safe FIFO backed by a socket/pipe pair; it carries no string-format override, bytes conversion, or OS path protocol in its class __dict__. Verified with Python 3.14."
    - "multiprocessing.queues.SimpleQueue is a stripped-down process-safe queue; it defines no __format__, __bytes__, or __fspath__ in its class __dict__. Verified with Python 3.14."
    - "multiprocessing.queues.JoinableQueue extends Queue with join() and task_done(); like Queue it defines no formatting, bytes, or path protocol. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: multiprocessing.Process — __format__/__bytes__/__fspath__ absence
#
# Theme: custom formatting, bytes conversion, and path protocol absent from
# multiprocessing.Process __dict__.
# Process manages OS subprocesses via start/join/terminate; it is not a
# formattable, byte-serializable, or path-like object.
# ---------------------------------------------------------------------------

table multiprocessing_extra2536.process_format_bytes_fspath:
  description: "__format__, __bytes__, __fspath__ absent from multiprocessing.Process __dict__; wave 2536"
  kind: python_call_eq
  category: protocol_dict_presence
  id_prefix: mp2536

  columns: [id, function, args, expected]
  rows:
    - ["mp2536-001", multiprocessing.Process.__dict__.__contains__, ["__format__"], false]
    - ["mp2536-002", multiprocessing.Process.__dict__.__contains__, ["__bytes__"],  false]
    - ["mp2536-003", multiprocessing.Process.__dict__.__contains__, ["__fspath__"], false]

