spec: re3361
version: ">=3.9"
backend: python_module(re)
docs: https://docs.python.org/3/library/re.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — re: Regular expression operations"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 671 (re3361): __invert__, __floor__, __ceil__ dict-presence checks for re types."
    - "Classes covered: re.Pattern, re.Match, re.RegexFlag."
    - "Theme: __invert__, __floor__, __ceil__ dict-presence (~x, math.floor(x), math.ceil(x))."
    - "No re class defines __invert__ in its own __dict__: re.Pattern and re.Match are compiled-pattern and read-only match result objects; bitwise inversion has no meaning for them. re.RegexFlag is an IntFlag enum but __invert__ is not present in re.RegexFlag.__dict__."
    - "No re class defines __floor__ in its own __dict__: re types are not numeric operands; math.floor() is not defined on any re type. re.RegexFlag (IntFlag) does not define __floor__ in its own __dict__."
    - "No re class defines __ceil__ in its own __dict__: re types are not numeric operands; math.ceil() is not defined on any re type. re.RegexFlag (IntFlag) does not define __ceil__ in its own __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Consistent with prior waves: all bitwise and rounding operators absent from re class __dict__s."
  created_at: "2026-04-13"
error_model: python_exceptions

# ---------------------------------------------------------------------------
# __invert__ dict-presence — operator.contains(Cls.__dict__, '__invert__')
#
# No re class defines __invert__ in its own __dict__; all false.
# re.Pattern and re.Match are read-only result objects; re.RegexFlag is an
# IntFlag enum but bitwise inversion is not stored in re.RegexFlag.__dict__.
# ---------------------------------------------------------------------------

table re3361.invert:
  description: "re types __invert__ dict-presence checks; wave 671"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: re3361

  columns: [id, function, args, expected]
  rows:
    - ["re3361001", operator.contains, [re.Pattern.__dict__,   "__invert__"], false]
    - ["re3361002", operator.contains, [re.Match.__dict__,     "__invert__"], false]
    - ["re3361003", operator.contains, [re.RegexFlag.__dict__, "__invert__"], false]

# ---------------------------------------------------------------------------
