table multiprocessing_extra133.mp_sync_rlock_identity:
  description: "multiprocessing.synchronize.RLock class identity checks in mpsync133 namespace — wave 258 theme: RLock class identity; RLock inherits from SemLock like Lock, giving MRO=[RLock, SemLock, object] (len=3); RLock.__init__.__qualname__.__eq__('RLock.__init__')==True (len=14: 'RLock'=5+'.'=1+'__init__'=8); RLock.__module__.__eq__('multiprocessing.synchronize')==True (len=27, same module as Semaphore, BoundedSemaphore, Lock); RLock.__bases__[0].__name__.__eq__('SemLock')==True (same direct base as Lock and Semaphore); RLock.__mro__.__len__()==3; RLock.__qualname__.__len__()==5 ('RLock'=5: 'R'=1+'Lock'=4); Lock.__qualname__.__len__()==4 ('Lock'=4), making RLock one char longer than Lock; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsync133b

  columns: [id, function, args, expected, description]
  rows:
