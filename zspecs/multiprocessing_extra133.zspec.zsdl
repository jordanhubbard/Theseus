spec: multiprocessing_extra133
version: ">=3.9"
backend: python_module(multiprocessing.synchronize)

docs: https://docs.python.org/3/library/multiprocessing.html#synchronization-between-processes

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html#synchronization-between-processes — Python multiprocessing synchronization documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/synchronize.py"
  notes:
    - "This spec covers: wave 258 theme — multiprocessing.synchronize.Semaphore, BoundedSemaphore, Lock, and RLock class identity and method qualnames. NEW in extra133: multiprocessing.synchronize.Semaphore.__init__.__qualname__=='Semaphore.__init__' (len=18); multiprocessing.synchronize.Semaphore.__module__=='multiprocessing.synchronize' (len=27); multiprocessing.synchronize.Semaphore.__bases__[0].__name__=='SemLock'; multiprocessing.synchronize.Semaphore.__mro__.__len__()==3; multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__=='Semaphore'; multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__()==4; multiprocessing.synchronize.Lock.__bases__[0].__name__=='SemLock'; multiprocessing.synchronize.Lock.__mro__.__len__()==3; multiprocessing.synchronize.RLock.__init__.__qualname__=='RLock.__init__' (len=14); multiprocessing.synchronize.RLock.__mro__.__len__()==3. All verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.synchronize.Semaphore.__bases__[0].__name__ == 'SemLock'. SemLock is the C-extension-backed base class in multiprocessing.synchronize that wraps the OS-level semaphore. Semaphore, Lock, and RLock all directly inherit from SemLock. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.synchronize.BoundedSemaphore.__mro__ == [BoundedSemaphore, Semaphore, SemLock, object] (length=4). BoundedSemaphore subclasses Semaphore, adding one level to the MRO compared to Semaphore's 3-element MRO. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.synchronize.Semaphore.__module__ == 'multiprocessing.synchronize' (len=27: 'multiprocessing'=15+'.'=1+'synchronize'=11=27). This is 5 chars longer than 'multiprocessing.queues' (len=22). Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "multiprocessing.synchronize.Semaphore does NOT have acquire or release as Python-level class attributes — those methods are provided by SemLock (the C extension base). Only __init__, get_value, and __repr__ are defined directly in Semaphore. Verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# multiprocessing.synchronize.Semaphore class identity — extra133
#
# Wave 258 theme: Semaphore, BoundedSemaphore, Lock, RLock class identity.
#
# multiprocessing.synchronize.Semaphore.__init__.__qualname__   == 'Semaphore.__init__' (len=18)
# multiprocessing.synchronize.Semaphore.__module__              == 'multiprocessing.synchronize' (len=27)
# multiprocessing.synchronize.Semaphore.__bases__[0].__name__   == 'SemLock'
# multiprocessing.synchronize.Semaphore.__mro__.__len__()       == 3
# multiprocessing.synchronize.Semaphore.__qualname__.__len__()  == 9
# multiprocessing.synchronize.Semaphore.__init__.__code__.co_argcount == 2
# ---------------------------------------------------------------------------

table multiprocessing_extra133.mp_sync_semaphore_identity:
  description: "multiprocessing.synchronize.Semaphore class identity checks in mpsync133 namespace — wave 258 theme: Semaphore class identity; Semaphore is defined in Lib/multiprocessing/synchronize.py; Semaphore.__init__.__qualname__.__eq__('Semaphore.__init__')==True (len=18: 'Semaphore'=9+'.'=1+'__init__'=8); Semaphore.__module__.__eq__('multiprocessing.synchronize')==True (len=27: 'multiprocessing'=15+'.'=1+'synchronize'=11); Semaphore.__bases__[0].__name__.__eq__('SemLock')==True (SemLock is the C-extension semaphore wrapper); Semaphore.__mro__.__len__()==3 ([Semaphore, SemLock, object]); Semaphore.__qualname__.__len__()==9 ('Semaphore'=9, module-level class); Semaphore.__init__.__code__.co_argcount==2 (self + value, where value defaults to 1); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsync133

  columns: [id, function, args, expected, description]
  rows:
    - [init_qn_eq,    multiprocessing.synchronize.Semaphore.__init__.__qualname__.__eq__,    ["Semaphore.__init__"],          true, "multiprocessing.synchronize.Semaphore.__init__.__qualname__ == 'Semaphore.__init__' (len=18); verified with Python 3.14.3"]
    - [init_qn_len,   multiprocessing.synchronize.Semaphore.__init__.__qualname__.__len__,   [],                              18,   "multiprocessing.synchronize.Semaphore.__init__.__qualname__.__len__() == 18; verified with Python 3.14.3"]
    - [mod_eq,        multiprocessing.synchronize.Semaphore.__module__.__eq__,               ["multiprocessing.synchronize"], true, "multiprocessing.synchronize.Semaphore.__module__ == 'multiprocessing.synchronize' (len=27); verified with Python 3.14.3"]
    - [mod_len,       multiprocessing.synchronize.Semaphore.__module__.__len__,              [],                              27,   "multiprocessing.synchronize.Semaphore.__module__.__len__() == 27; verified with Python 3.14.3"]
    - [base0_eq,      "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__",  ["SemLock"],                     true, "multiprocessing.synchronize.Semaphore.__bases__[0].__name__ == 'SemLock' (C-extension base); verified with Python 3.14.3"]
    - [mro_len,       multiprocessing.synchronize.Semaphore.__mro__.__len__,                 [],                              3,    "multiprocessing.synchronize.Semaphore.__mro__.__len__() == 3 — [Semaphore, SemLock, object]; verified with Python 3.14.3"]
    - [cls_qn_len,    multiprocessing.synchronize.Semaphore.__qualname__.__len__,            [],                              9,    "multiprocessing.synchronize.Semaphore.__qualname__.__len__() == 9 ('Semaphore'=9); verified with Python 3.14.3"]
    - [init_argc,     multiprocessing.synchronize.Semaphore.__init__.__code__.co_argcount.__eq__, [2],                        true, "multiprocessing.synchronize.Semaphore.__init__.__code__.co_argcount == 2 (self + value); verified with Python 3.14.3"]

