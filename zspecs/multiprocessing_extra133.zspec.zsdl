    - [rlock_init_qn_len, multiprocessing.synchronize.RLock.__init__.__qualname__.__len__,   [],                              14,   "multiprocessing.synchronize.RLock.__init__.__qualname__.__len__() == 14 ('RLock.__init__'=14); verified with Python 3.14.3"]
    - [rlock_mod_eq,      multiprocessing.synchronize.RLock.__module__.__eq__,               ["multiprocessing.synchronize"], true, "multiprocessing.synchronize.RLock.__module__ == 'multiprocessing.synchronize' (len=27); verified with Python 3.14.3"]
    - [rlock_mod_len,     multiprocessing.synchronize.RLock.__module__.__len__,              [],                              27,   "multiprocessing.synchronize.RLock.__module__.__len__() == 27; verified with Python 3.14.3"]
    - [rlock_base0_eq,    "multiprocessing.synchronize.RLock.__bases__[0].__name__.__eq__",  ["SemLock"],                     true, "multiprocessing.synchronize.RLock.__bases__[0].__name__ == 'SemLock'; verified with Python 3.14.3"]
