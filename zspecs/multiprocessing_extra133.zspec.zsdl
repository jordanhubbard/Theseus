table multiprocessing_extra133.mp_sync_bounded_semaphore_lock_identity:
  description: "multiprocessing.synchronize.BoundedSemaphore and Lock class identity checks in mpsync133 namespace — wave 258 theme: BoundedSemaphore and Lock class identity; BoundedSemaphore inherits from Semaphore, giving MRO=[BoundedSemaphore, Semaphore, SemLock, object] (len=4); BoundedSemaphore.__init__.__qualname__.__eq__('BoundedSemaphore.__init__')==True (len=25: 'BoundedSemaphore'=16+'.'=1+'__init__'=8); BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore')==True; BoundedSemaphore.__module__.__eq__('multiprocessing.synchronize')==True (len=27, same module as Semaphore); Lock inherits directly from SemLock like Semaphore, giving MRO=[Lock, SemLock, object] (len=3); Lock.__init__.__qualname__.__eq__('Lock.__init__')==True (len=13: 'Lock'=4+'.'=1+'__init__'=8); Lock.__bases__[0].__name__.__eq__('SemLock')==True; Lock.__init__.__code__.co_argcount==1 (self only — Lock.__init__ takes no extra args); verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: mpsync133a

  columns: [id, function, args, expected, description]
  rows:
    - [bs_init_qn_eq,   "multiprocessing.synchronize.BoundedSemaphore.__init__.__qualname__.__eq__",   ["BoundedSemaphore.__init__"],   true, "multiprocessing.synchronize.BoundedSemaphore.__init__.__qualname__ == 'BoundedSemaphore.__init__' (len=25); verified with Python 3.14.3"]
    - [bs_init_qn_len,  "multiprocessing.synchronize.BoundedSemaphore.__init__.__qualname__.__len__",  [],                              25,   "multiprocessing.synchronize.BoundedSemaphore.__init__.__qualname__.__len__() == 25; verified with Python 3.14.3"]
    - [bs_base0_eq,     "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__.__eq__",   ["Semaphore"],                   true, "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__ == 'Semaphore'; verified with Python 3.14.3"]
    - [bs_mro_len,      "multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__",                [],                              4,    "multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__() == 4 — [BoundedSemaphore, Semaphore, SemLock, object]; verified with Python 3.14.3"]
    - [bs_mod_len,      "multiprocessing.synchronize.BoundedSemaphore.__module__.__len__",             [],                              27,   "multiprocessing.synchronize.BoundedSemaphore.__module__.__len__() == 27 ('multiprocessing.synchronize'=27); verified with Python 3.14.3"]
    - [lock_init_qn_eq,  multiprocessing.synchronize.Lock.__init__.__qualname__.__eq__,               ["Lock.__init__"],               true, "multiprocessing.synchronize.Lock.__init__.__qualname__ == 'Lock.__init__' (len=13); verified with Python 3.14.3"]
    - [lock_init_qn_len, multiprocessing.synchronize.Lock.__init__.__qualname__.__len__,              [],                              13,   "multiprocessing.synchronize.Lock.__init__.__qualname__.__len__() == 13 ('Lock.__init__'=13); verified with Python 3.14.3"]
    - [lock_base0_eq,   "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__",              ["SemLock"],                     true, "multiprocessing.synchronize.Lock.__bases__[0].__name__ == 'SemLock' (same base as Semaphore); verified with Python 3.14.3"]
    - [lock_mro_len,     multiprocessing.synchronize.Lock.__mro__.__len__,                            [],                              3,    "multiprocessing.synchronize.Lock.__mro__.__len__() == 3 — [Lock, SemLock, object]; verified with Python 3.14.3"]
    - [lock_argc,        multiprocessing.synchronize.Lock.__init__.__code__.co_argcount.__eq__,       [1],                             true, "multiprocessing.synchronize.Lock.__init__.__code__.co_argcount == 1 (self only); verified with Python 3.14.3"]

