# ---------------------------------------------------------------------------
# Standalone invariants — extra133
# ---------------------------------------------------------------------------

invariant multiprocessing_extra133.Semaphore_module_len_27:
  description: "multiprocessing.synchronize.Semaphore.__module__.__len__() == 27 — Semaphore.__module__ is 'multiprocessing.synchronize' (27 chars: 'multiprocessing'=15 + '.'=1 + 'synchronize'=11 = 27); this is 5 chars longer than 'multiprocessing.queues' (len=22) and the longest multiprocessing submodule name among the specs; all four classes in this spec (Semaphore, BoundedSemaphore, Lock, RLock) share this same __module__ of 'multiprocessing.synchronize' (len=27); Semaphore.__bases__[0].__name__ is 'SemLock'; Semaphore.__mro__.__len__() is 3; NEW in extra133: first standalone Semaphore module length invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: multiprocessing.synchronize.Semaphore.__module__.__len__
  args: []
  expected: 27

invariant multiprocessing_extra133.Semaphore_bases_SemLock:
  description: "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__('SemLock') returns True — SemLock is the C-extension-backed class in multiprocessing.synchronize that wraps OS-level semaphore primitives; Semaphore, Lock, and RLock all directly inherit from SemLock (same __bases__[0].__name__ of 'SemLock'); BoundedSemaphore differs — its direct base is Semaphore (not SemLock directly); Semaphore.__mro__ is [Semaphore, SemLock, object] (len=3); Semaphore.__module__ is 'multiprocessing.synchronize' (len=27); Semaphore.__init__.__qualname__ is 'Semaphore.__init__' (len=18); NEW in extra133: first standalone Semaphore SemLock base invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.synchronize.Semaphore.__bases__[0].__name__.__eq__"
  args: ["SemLock"]
  expected: true

invariant multiprocessing_extra133.BoundedSemaphore_mro_len_4:
  description: "multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__() == 4 — BoundedSemaphore's MRO is [BoundedSemaphore, Semaphore, SemLock, object] (length=4); BoundedSemaphore subclasses Semaphore rather than SemLock directly, adding one level compared to Semaphore's MRO (len=3: [Semaphore, SemLock, object]); BoundedSemaphore.__bases__[0].__name__ is 'Semaphore' (distinct from Semaphore/Lock/RLock whose base is 'SemLock'); BoundedSemaphore.__init__.__qualname__ is 'BoundedSemaphore.__init__' (len=25); BoundedSemaphore.__module__ is 'multiprocessing.synchronize' (len=27); NEW in extra133: first standalone BoundedSemaphore MRO length invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.synchronize.BoundedSemaphore.__mro__.__len__"
  args: []
  expected: 4

invariant multiprocessing_extra133.Lock_bases_SemLock:
  description: "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__('SemLock') returns True — Lock directly inherits from SemLock, giving MRO=[Lock, SemLock, object] (len=3); this is the same depth as Semaphore (also len=3), and shallower than BoundedSemaphore (len=4); Lock.__init__.__code__.co_argcount is 1 (self only, no additional parameters unlike Semaphore which takes a value); Lock.__init__.__qualname__ is 'Lock.__init__' (len=13: 'Lock'=4+'.'=1+'__init__'=8); Lock.__qualname__.__len__() is 4 ('Lock'=4); Lock.__module__ is 'multiprocessing.synchronize' (len=27); NEW in extra133: first standalone Lock SemLock base invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.synchronize.Lock.__bases__[0].__name__.__eq__"
  args: ["SemLock"]
  expected: true

invariant multiprocessing_extra133.BoundedSemaphore_bases_Semaphore:
  description: "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__.__eq__('Semaphore') returns True — BoundedSemaphore's direct base is Semaphore (not SemLock), making BoundedSemaphore the only class in the synchronize module (among Semaphore, BoundedSemaphore, Lock, RLock) that does NOT directly inherit from SemLock; this extra level of inheritance gives BoundedSemaphore an MRO of [BoundedSemaphore, Semaphore, SemLock, object] (len=4); BoundedSemaphore.__init__.__qualname__ is 'BoundedSemaphore.__init__' (len=25); BoundedSemaphore.__module__ is 'multiprocessing.synchronize' (len=27); NEW in extra133: first standalone BoundedSemaphore Semaphore base invariant; wave 258; verified with Python 3.14.3"
  category: identity
  kind: python_call_eq
  function: "multiprocessing.synchronize.BoundedSemaphore.__bases__[0].__name__.__eq__"
  args: ["Semaphore"]
  expected: true
