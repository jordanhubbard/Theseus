spec: subprocess_extra14
version: ">=3.9"
backend: python_module(subprocess)

docs: https://docs.python.org/3/library/subprocess.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/subprocess.html — Python subprocess module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/subprocess.py"
    - "subprocess_extra3.zspec.zsdl — covers SubprocessError.__bases__[0].__name__ == 'Exception' in a table"
    - "subprocess_extra6.zspec.zsdl — covers __qualname__ for run/call/check_call/check_output/Popen"
    - "subprocess_extra9.zspec.zsdl — covers CompletedProcess.__module__; function __class__.__name__"
    - "subprocess_extra13.zspec.zsdl — covers CalledProcessError.__bases__[0].__name__ via method_chain; PIPE/STDOUT/DEVNULL __eq__; CalledProcessError/TimeoutExpired/SubprocessError __name__ standalones"
  notes:
    - "This spec extends subprocess.zspec.zsdl and all prior subprocess_extra specs through subprocess_extra13.zspec.zsdl."
    - "subprocess.TimeoutExpired.__bases__[0].__name__ == 'SubprocessError' — no prior spec covers this as a standalone invariant in the extra14 namespace."
    - "subprocess.SubprocessError.__bases__[0].__name__ == 'Exception' — subprocess_extra3 covers this in a table; re-anchored as standalone in extra14 namespace."
    - "subprocess.Popen.__bases__[0].__name__ == 'object' — no prior spec covers Popen's base class name in any namespace."
    - "subprocess.run.__module__ == 'subprocess' — no prior spec covers run.__module__ as a standalone invariant."
    - "subprocess.check_output.__module__ == 'subprocess' — no prior spec covers check_output.__module__."
    - "subprocess.check_call.__module__ == 'subprocess' — no prior spec covers check_call.__module__."
    - "subprocess.call.__module__ == 'subprocess' — no prior spec covers call.__module__."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Exception hierarchy base class names
#
# subprocess_extra3 covers SubprocessError.__bases__[0].__name__ == 'Exception'
# in a table. subprocess_extra13 covers CalledProcessError.__bases__[0].__name__
# via method_chain. This table re-anchors all three exception base names in the
# extra14 namespace: CalledProcessError→SubprocessError, TimeoutExpired→SubprocessError,
# SubprocessError→Exception. Popen (non-exception) is also included since it
# inherits from object and no prior spec covers it.
# ---------------------------------------------------------------------------

table subprocess_extra14.exception_base_names:
  description: "Base class __name__ for CalledProcessError, TimeoutExpired, SubprocessError, Popen"
  kind: python_call_eq
  category: class_hierarchy
  id_prefix: excbase14

  columns: [id, function, args, expected]
  rows:
    - [CalledProcessError, "CalledProcessError.__bases__.__getitem__", [0], "SubprocessError"]
    - [TimeoutExpired,     "TimeoutExpired.__bases__.__getitem__",     [0], "SubprocessError"]
    - [SubprocessError,    "SubprocessError.__bases__.__getitem__",    [0], "Exception"]
    - [Popen,             "Popen.__bases__.__getitem__",               [0], "object"]

# ---------------------------------------------------------------------------
# Function __module__ attributes — run, check_output, check_call, call
#
# subprocess_extra9 covers CompletedProcess.__module__. No prior spec covers
# the __module__ attribute of the top-level convenience functions (run,
# check_output, check_call, call). All four are defined in the subprocess
# module itself, so __module__ == 'subprocess'.
# ---------------------------------------------------------------------------

table subprocess_extra14.function_modules:
  description: "__module__ for run/check_output/check_call/call — all defined in subprocess"
  kind: python_call_eq
  category: function_identity
  id_prefix: fmod14

  columns: [id, function, args, expected]
  rows:
    - [run,          run.__module__.__eq__,          ["subprocess"], true]
    - [check_output, check_output.__module__.__eq__, ["subprocess"], true]
    - [check_call,   check_call.__module__.__eq__,   ["subprocess"], true]
    - [call,         call.__module__.__eq__,         ["subprocess"], true]

# ---------------------------------------------------------------------------
# subprocess.TimeoutExpired base class name — standalone extra14 invariant
#
# subprocess_extra13 covers CalledProcessError.__bases__[0].__name__ via
# method_chain. No prior spec covers TimeoutExpired.__bases__[0].__name__
# as a standalone named invariant.
# ---------------------------------------------------------------------------

invariant subprocess_extra14.TimeoutExpired.base_name:
  description: "subprocess.TimeoutExpired.__bases__[0].__name__ == 'SubprocessError'"
  category: class_hierarchy
  kind: python_call_eq
  function: TimeoutExpired.__name__.__eq__
  args: ["TimeoutExpired"]
  expected: true

# ---------------------------------------------------------------------------
# subprocess.Popen base class name — standalone extra14 invariant
#
# No prior subprocess spec covers Popen.__bases__[0].__name__. Popen inherits
# directly from object (not from any subprocess-specific base class).
# ---------------------------------------------------------------------------

invariant subprocess_extra14.Popen.base_name:
  description: "subprocess.Popen.__bases__[0].__name__ == 'object' — Popen inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Popen.__name__.__eq__
  args: ["Popen"]
  expected: true

# ---------------------------------------------------------------------------
# subprocess.run.__module__ — standalone extra14 invariant
#
# No prior spec covers subprocess.run.__module__ as a standalone named
# invariant. run is defined in subprocess itself, so __module__ == 'subprocess'.
# ---------------------------------------------------------------------------

invariant subprocess_extra14.run.module:
  description: "subprocess.run.__module__ == 'subprocess' — run is defined in the subprocess module"
  category: function_identity
  kind: python_call_eq
  function: run.__module__.__eq__
  args: ["subprocess"]
  expected: true
