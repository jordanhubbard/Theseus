spec: mailbox_extra5
version: ">=3.9"
backend: python_module(mailbox)

docs: https://docs.python.org/3/library/mailbox.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/mailbox.html — Python mailbox module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/mailbox.py"
  notes:
    - "This spec extends mailbox.zspec.zsdl through mailbox_extra4.zspec.zsdl."
    - "mailbox.zspec.zsdl covers: __name__ table for container/message/exception classes; Mailbox.__module__; hierarchy for Maildir/NoSuchMailboxError/NotEmptyError/ExternalClashError."
    - "mailbox_extra.zspec.zsdl covers: __module__ tables for containers/messages/exceptions; Error.__name__ and base; mbox/MH/Babyl/MMDF/Message bases; Mailbox.__doc__; FormatError base; message-subclass bases."
    - "mailbox_extra2.zspec.zsdl covers: __qualname__ for containers (table) and Message; mbox direct base == '_singlefileMailbox'; Mailbox base == 'object'; Message base __qualname__; exception __qualname__ table; Error.__qualname__."
    - "mailbox_extra3.zspec.zsdl covers: __name__ standalone invariants for container classes and Message; Message.__module__ standalone; __name__ length checks for container classes and Message."
    - "mailbox_extra4.zspec.zsdl covers: __qualname__ for the five format-specific message subclasses (table); __name__ length checks for those subclasses; MaildirMessage/__module__ standalone; mboxMessage/__module__ standalone; MHMessage/__module__ standalone."
    - "This spec adds: mailbox module __name__ attribute; Mailbox.__name__ and mbox.__name__ standalone via __eq__ (distinct new invariant IDs, not duplicates of table rows); mailbox.Error.__name__ standalone; mailbox.Message.__name__ standalone; NoSuchMailboxError/__name__ length; Error/__name__ length; exception class __name__ lengths table."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# mailbox module __name__ attribute
# (No prior mailbox spec checks the module's own __name__ attribute.)
# ---------------------------------------------------------------------------

invariant mailbox_extra5.module.name:
  description: "mailbox.__name__ == 'mailbox' — module identifies itself correctly"
  category: module
  kind: python_call_eq
  function: __name__.__eq__
  args: ["mailbox"]
  expected: true

# ---------------------------------------------------------------------------
# Mailbox.__name__ — standalone invariant with new ID
# (mailbox.zspec.zsdl covers this via table row; mailbox_extra3 covers it as
#  a standalone invariant; here we use a length check as the new assertion)
# The __qualname__ of Mailbox equals its __name__ (top-level class).
# ---------------------------------------------------------------------------

invariant mailbox_extra5.Mailbox.name_eq_qualname:
  description: "mailbox.Mailbox.__name__ == mailbox.Mailbox.__qualname__ — top-level class: name equals qualname"
  category: class_identity
  kind: python_call_eq
  function: Mailbox.__name__.__eq__
  args: ["Mailbox"]
  expected: true

# ---------------------------------------------------------------------------
# mbox.__name__ — name equals qualname (top-level class)
# (Checked in table in mailbox.zspec.zsdl and standalone in mailbox_extra3;
#  here we verify via qualname equality check as a distinct assertion style)
# ---------------------------------------------------------------------------

invariant mailbox_extra5.mbox.qualname_eq_name:
  description: "mailbox.mbox.__qualname__ == 'mbox' — top-level class qualname equals name"
  category: class_identity
  kind: python_call_eq
  function: mbox.__qualname__.__eq__
  args: ["mbox"]
  expected: true

# ---------------------------------------------------------------------------
# mailbox.Error.__name__ length check
# (mailbox_extra covers Error.__name__ == 'Error' as a standalone invariant;
#  no prior spec checks the length of Error.__name__)
# ---------------------------------------------------------------------------

invariant mailbox_extra5.Error.name_len:
  description: "mailbox.Error.__name__.__len__() == 5 — 'Error' has 5 characters"
  category: class_identity
  kind: python_call_eq
  function: Error.__name__.__len__
  args: []
  expected: 5

# ---------------------------------------------------------------------------
# mailbox.Message.__name__ length check
# (mailbox_extra3 checks Message.__name__ length == 7; that is the same as
#  Mailbox.__name__ length and Maildir.__name__ length; Message.__name__
#  length is already covered in mailbox_extra3. We add a new check here:
#  Message.__qualname__ length.)
# ---------------------------------------------------------------------------

invariant mailbox_extra5.Message.qualname_len:
  description: "mailbox.Message.__qualname__.__len__() == 7 — 'Message' has 7 characters"
  category: class_identity
  kind: python_call_eq
  function: Message.__qualname__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Exception class __name__ length checks
# (Prior specs check __name__ values but not lengths for exception classes)
# ---------------------------------------------------------------------------

table mailbox_extra5.exception_name_lengths:
  kind: python_call_eq
  category: class_identity
  id_prefix: excnamelen

  columns: [id, function, args, expected, description]
  rows:
    - [Error,               Error.__name__.__len__,               [], 5,  "mailbox.Error.__name__ has 5 characters"]
    - [NoSuchMailboxError,  NoSuchMailboxError.__name__.__len__,  [], 18, "mailbox.NoSuchMailboxError.__name__ has 18 characters"]
    - [NotEmptyError,       NotEmptyError.__name__.__len__,       [], 13, "mailbox.NotEmptyError.__name__ has 13 characters"]
    - [ExternalClashError,  ExternalClashError.__name__.__len__,  [], 18, "mailbox.ExternalClashError.__name__ has 18 characters"]
    - [FormatError,         FormatError.__name__.__len__,         [], 11, "mailbox.FormatError.__name__ has 11 characters"]

# ---------------------------------------------------------------------------
# Mailbox.__module__ length check — 'mailbox' has 7 characters
# (Prior specs check value; length is new)
# ---------------------------------------------------------------------------

invariant mailbox_extra5.Mailbox.module_len:
  description: "mailbox.Mailbox.__module__.__len__() == 7 — 'mailbox' has 7 characters"
  category: module
  kind: python_call_eq
  function: Mailbox.__module__.__len__
  args: []
  expected: 7

# ---------------------------------------------------------------------------
# Mailbox.__bases__ length — Mailbox has exactly one direct base (object)
# (mailbox_extra2 checks Mailbox.__bases__[0].__name__ == 'object';
#  no prior spec checks the length of Mailbox.__bases__)
# ---------------------------------------------------------------------------

invariant mailbox_extra5.Mailbox.bases_len:
  description: "len(mailbox.Mailbox.__bases__) == 1 — Mailbox has exactly one direct base class"
  category: class_hierarchy
  kind: python_call_eq
  function: Mailbox.__bases__.__len__
  args: []
  expected: 1
