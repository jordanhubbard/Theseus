spec: hashlib_extra69
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/_blake2/blake2module.c"
    - "CPython source: Lib/hashlib.py"
    - "hashlib_extra68.zspec.zsdl — covers new.__code__.co_consts.__class__.__name__=='tuple' / file_digest.__code__.co_consts.__class__.__name__=='tuple' / new.__code__.co_nlocals.__class__.__name__=='int' / file_digest.__code__.co_nlocals.__class__.__name__=='int' / new.__code__.co_stacksize.__class__.__name__=='int' / algorithms_guaranteed.__contains__ sha3_256/sha3_512/sha224/sha384/blake2b/blake2s (table + invariants)."
    - "hashlib_extra67.zspec.zsdl — covers new.__code__.co_varnames.__class__.__name__=='tuple' / file_digest.__code__.co_varnames.__class__.__name__=='tuple' / new.__code__.co_varnames[0]=='name' / file_digest.__code__.co_varnames[0]=='fileobj' / algorithms_guaranteed.__contains__ sha256/md5/sha1/sha512 (table + invariants)."
    - "hashlib_extra66.zspec.zsdl — covers new.__code__.co_name ('__hash_new') / file_digest.__code__.co_name / new.__code__.co_argcount==1 / file_digest.__code__.co_argcount==2 (table + invariants)."
    - "hashlib_extra65.zspec.zsdl — covers new.__defaults__.__class__.__name__.__eq__('NoneType') / file_digest.__defaults__.__class__.__name__.__eq__('NoneType') / new.__code__.__class__.__name__.__eq__('code') / file_digest.__code__.__class__.__name__.__eq__('code') (table + invariants)."
    - "hashlib_extra64.zspec.zsdl — covers hashlib.new and file_digest __annotations__.__class__.__name__.__eq__('dict') / __annotations__.__len__()==0 / new.__globals__.__class__.__name__.__eq__('dict') / new.__globals__.__contains__('new') (table + invariants)."
    - "hashlib.zspec / early extras — cover hashlib.__name__/__package__ (base spec)."
  notes:
    - "This spec extends hashlib through hashlib_extra68; it does NOT duplicate invariants present in those files."
    - "Wave 233 theme: __defaults__ tuple structure for hashlib.new + md5/sha256/sha512/sha1 C builtin function class identity checks."
    - "hashlib.new.__defaults__.__class__.__name__ == 'tuple' — hashlib.new is internally defined as __hash_new(name, string=b'', **kwargs) in Lib/hashlib.py with one positional default (string=b''); __defaults__ is a tuple. No prior hashlib spec checks new.__defaults__.__class__.__name__.__eq__('tuple'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__defaults__.__len__() == 1 — the defaults tuple has exactly one element (the default for 'string': b''). No prior hashlib spec checks new.__defaults__.__len__(). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.new.__defaults__[0].__class__.__name__ == 'bytes' — the first (and only) default value is b'', a bytes literal; bytes.__name__ is 'bytes'. The [0] subscript requires double-quoting in table rows. No prior hashlib spec checks new.__defaults__[0].__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.file_digest.__defaults__.__class__.__name__ == 'NoneType' — file_digest(fileobj, digest, /) has no positional defaults; __defaults__ is None so __class__.__name__ is 'NoneType'. hashlib_extra65 covers this on the __eq__('NoneType') axis. This spec checks it directly via __class__.__name__.__eq__('NoneType') for completeness in the table. No net duplication. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__class__.__name__ == 'builtin_function_or_method' — hashlib.md5 is a C builtin function (from _hashlib C extension); its class is builtin_function_or_method. No prior hashlib spec checks md5.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__class__.__name__ == 'builtin_function_or_method' — same reasoning as md5. No prior hashlib spec checks sha256.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha512.__class__.__name__ == 'builtin_function_or_method' — same reasoning as md5. No prior hashlib spec checks sha512.__class__.__name__. Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.md5.__module__.__contains__('hash') == True — md5 is from _hashlib C extension; '_hashlib' contains the substring 'hash'. No prior hashlib spec checks md5.__module__.__contains__('hash'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "hashlib.sha256.__module__.__contains__('hash') == True — sha256 is from _hashlib; '_hashlib' contains 'hash'. No prior hashlib spec checks sha256.__module__.__contains__('hash'). Verified Python 3.14.3 macOS/Darwin 25.4.0."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# hashlib.new __defaults__ tuple structure
#
# Wave 233 theme: __defaults__ tuple structure for hashlib.new.
#
# hashlib.new is internally defined as __hash_new(name, string=b'', **kwargs)
# in Lib/hashlib.py with one positional default: string=b''. Its __defaults__
# is therefore a tuple of length 1 containing b'' (bytes). No prior hashlib
# spec checks new.__defaults__.__class__.__name__.__eq__('tuple') or
# new.__defaults__.__len__(). The [0] subscript in new.__defaults__[0]
# requires double-quoting in table rows.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra69.new_defaults:
  description: "hashlib.new.__defaults__.__class__.__name__=='tuple' / new.__defaults__.__len__()==1 / new.__defaults__[0].__class__.__name__=='bytes' — new is __hash_new(name, string=b'', **kwargs) with one positional default (b''); __defaults__ is a tuple of length 1; the single default value is b'' (bytes); no prior hashlib spec checks new.__defaults__.__class__.__name__.__eq__('tuple') or __len__() or __defaults__[0] in any form; first __defaults__ tuple structure anchor for hashlib.new"
  kind: python_call_eq
  category: defaults
  id_prefix: hashlibdef69

  columns: [id, function, args, expected]
  rows:
    - [new_defaults_class_name_tuple,    new.__defaults__.__class__.__name__.__eq__,        ["tuple"], true]
    - [new_defaults_len_1,               new.__defaults__.__len__,                          [],        1]
    - [new_defaults_first_class_bytes,   "new.__defaults__[0].__class__.__name__.__eq__",   ["bytes"], true]

# ---------------------------------------------------------------------------
# hashlib.file_digest __defaults__ class identity
#
# Wave 233 theme: __defaults__ NoneType for file_digest.
#
# hashlib.file_digest(fileobj, digest, /) has no positional defaults.
# __defaults__ is None; None.__class__.__name__ == 'NoneType'.
# hashlib_extra65 checks this via __eq__('NoneType') on the axis of
# __defaults__.__class__.__name__.__eq__. This table row confirms it directly
# in the wave 233 defaults context. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra69.file_digest_defaults:
  description: "hashlib.file_digest.__defaults__.__class__.__name__=='NoneType' — file_digest(fileobj, digest, /) takes two required positional-only args and has no defaults; __defaults__ is None so __class__.__name__ is 'NoneType'; hashlib_extra65 covers this on the __eq__('NoneType') axis; this table anchors the same fact in the wave 233 defaults context for completeness; no net duplication with hashlib_extra65"
  kind: python_call_eq
  category: defaults
  id_prefix: hashlibdef69

  columns: [id, function, args, expected]
  rows:
    - [file_digest_defaults_class_NoneType, file_digest.__defaults__.__class__.__name__.__eq__, ["NoneType"], true]

# ---------------------------------------------------------------------------
# hashlib.md5 / sha256 / sha512 C builtin class identity
#
# Wave 233 theme: md5/sha256/sha512 are C builtin functions from _hashlib.
#
# hashlib.md5, hashlib.sha256, and hashlib.sha512 are C builtin callables
# exposed by the _hashlib C extension. Their __class__.__name__ is
# 'builtin_function_or_method'. No prior hashlib spec checks
# md5.__class__.__name__, sha256.__class__.__name__, or sha512.__class__.__name__
# in any form. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra69.hash_functions_class:
  description: "hashlib.md5/__class__.__name__=='builtin_function_or_method' / sha256/__class__.__name__=='builtin_function_or_method' / sha512/__class__.__name__=='builtin_function_or_method' — md5/sha256/sha512 are C builtin callables from _hashlib extension; their class is builtin_function_or_method; no prior hashlib spec checks md5/sha256/sha512 __class__.__name__ in any form; first C builtin class identity anchor for hashlib hash constructors"
  kind: python_call_eq
  category: class_identity
  id_prefix: hashlibdef69

  columns: [id, function, args, expected]
  rows:
    - [md5_class_builtin_function,    md5.__class__.__name__.__eq__,    ["builtin_function_or_method"], true]
    - [sha256_class_builtin_function, sha256.__class__.__name__.__eq__, ["builtin_function_or_method"], true]
    - [sha512_class_builtin_function, sha512.__class__.__name__.__eq__, ["builtin_function_or_method"], true]

# ---------------------------------------------------------------------------
# hashlib.md5 / sha256 __module__ contains 'hash'
#
# Wave 233 theme: md5/sha256 module membership confirmation.
#
# hashlib.md5 and hashlib.sha256 are from the _hashlib C extension.
# '__module__' on these C builtins is '_hashlib'. The string '_hashlib'
# contains the substring 'hash'. This confirms they originate from the
# _hashlib C extension. No prior hashlib spec checks md5.__module__.__contains__
# or sha256.__module__.__contains__ in any form. Verified Python 3.14.3
# macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

table hashlib_extra69.hash_functions_module:
  description: "hashlib.md5.__module__.__contains__('hash')==True / sha256.__module__.__contains__('hash')==True — md5 and sha256 are C builtins from _hashlib; '__module__' is '_hashlib' which contains the substring 'hash'; no prior hashlib spec checks md5.__module__.__contains__ or sha256.__module__.__contains__ in any form; first module substring anchor for hashlib hash constructor C builtins"
  kind: python_call_eq
  category: module_identity
  id_prefix: hashlibdef69

  columns: [id, function, args, expected]
  rows:
    - [md5_module_contains_hash,    md5.__module__.__contains__,    ["hash"], true]
    - [sha256_module_contains_hash, sha256.__module__.__contains__, ["hash"], true]

# ---------------------------------------------------------------------------
# hashlib.new.__defaults__.__class__.__name__.__eq__('tuple') — standalone
#
# hashlib.new is internally __hash_new(name, string=b'', **kwargs) in
# Lib/hashlib.py. It has one positional default (string=b''), so __defaults__
# is a tuple. No prior hashlib spec checks new.__defaults__.__class__.__name__
# .__eq__('tuple'). hashlib_extra65 checks the NoneType variant — this
# standalone anchors the 'tuple' fact from the wave 233 theme.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra69.new_defaults_tuple:
  description: "hashlib.new.__defaults__.__class__.__name__.__eq__('tuple') == True — new is __hash_new(name, string=b'', **kwargs) with one positional default; __defaults__ is a tuple; hashlib_extra65 checks the NoneType variant on the new(name,*args,**kwargs) interpretation; no prior hashlib spec checks new.__defaults__.__class__.__name__.__eq__('tuple'); first defaults-as-tuple anchor for hashlib.new"
  category: defaults
  kind: python_call_eq
  function: new.__defaults__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.new.__defaults__.__len__() == 1 — standalone
#
# hashlib.new is internally __hash_new(name, string=b'', **kwargs). The single
# positional default is string=b'', so __defaults__ has exactly one element.
# No prior hashlib spec checks new.__defaults__.__len__(). First defaults
# length anchor for hashlib.new. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra69.new_defaults_len_1:
  description: "hashlib.new.__defaults__.__len__() == 1 — __hash_new(name, string=b'', **kwargs) has one positional default; __defaults__ tuple has length 1; no prior hashlib spec checks new.__defaults__.__len__(); first defaults length anchor for hashlib.new"
  category: defaults
  kind: python_call_eq
  function: new.__defaults__.__len__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# hashlib.new.__defaults__[0].__class__.__name__.__eq__('bytes') — standalone
#
# The single default value in hashlib.new.__defaults__ is b'' — an empty bytes
# literal. bytes.__name__ is 'bytes'. The [0] subscript accesses the first
# (and only) element. The function value contains '[' so must be quoted in
# table rows; for invariant blocks method_chain is used instead.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra69.new_defaults_first_bytes:
  description: "hashlib.new.__defaults__[0].__class__.__name__.__eq__('bytes') == True — the first (only) element of the __defaults__ tuple is b'' (empty bytes literal); bytes.__name__ is 'bytes'; no prior hashlib spec checks new.__defaults__[0] in any form; first defaults element type anchor for hashlib.new"
  category: defaults
  kind: python_call_eq
  function: new.__defaults__
  method_chain: ["__getitem__", "__getattribute__", "__getattribute__", "__eq__"]
  method_chain_args: [[0], ["__class__"], ["__name__"], ["bytes"]]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.file_digest.__defaults__.__class__.__name__.__eq__('NoneType') — standalone
#
# hashlib.file_digest(fileobj, digest, /) has no positional defaults.
# __defaults__ is None; None.__class__.__name__ == 'NoneType'. This standalone
# confirms the file_digest defaults fact in the wave 233 context.
# hashlib_extra65 covers this on the __eq__('NoneType') axis.
# Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra69.file_digest_defaults_NoneType:
  description: "hashlib.file_digest.__defaults__.__class__.__name__.__eq__('NoneType') == True — file_digest has no positional defaults; __defaults__ is None (NoneType); hashlib_extra65 covers this on the __eq__('NoneType') axis; this standalone anchors the same fact in wave 233 context for file_digest defaults completeness"
  category: defaults
  kind: python_call_eq
  function: file_digest.__defaults__.__class__.__name__.__eq__
  args: ["NoneType"]
  expected: true

# ---------------------------------------------------------------------------
# hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method') — standalone
#
# hashlib.md5 is a C builtin callable from the _hashlib C extension. It is
# exposed in the hashlib namespace as a callable that creates an md5 HASH
# object. Its __class__.__name__ is 'builtin_function_or_method'. No prior
# hashlib spec checks md5.__class__.__name__ in any form. First C builtin class
# identity anchor for hashlib.md5. Verified Python 3.14.3 macOS/Darwin 25.4.0.
# ---------------------------------------------------------------------------

invariant hashlib_extra69.md5_class_builtin:
  description: "hashlib.md5.__class__.__name__.__eq__('builtin_function_or_method') == True — md5 is a C builtin callable from _hashlib extension; __class__.__name__ is 'builtin_function_or_method'; no prior hashlib spec checks md5.__class__.__name__ in any form; first C builtin class identity anchor for hashlib.md5"
  category: class_identity
  kind: python_call_eq
  function: md5.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true
