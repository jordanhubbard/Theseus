spec: multiprocessing_extra2371
version: ">=3.9"
backend: python_module(multiprocessing)

docs: https://docs.python.org/3/library/multiprocessing.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/multiprocessing.html — Python multiprocessing module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/multiprocessing/"
    - "CPython source: Modules/_multiprocessing/"
  notes:
    - "All expected values verified interactively with Python 3.14.4 on macOS/Darwin 25.4.0."
    - "multiprocessing.Process is a plain class — __class__.__name__ == 'type'."
    - "multiprocessing.Queue, Pipe, Pool, Value, Array, cpu_count, Manager are context-bound methods — __class__.__name__ == 'method'."
    - "multiprocessing.current_process and active_children are plain Python functions — __class__.__name__ == 'function'."
    - "multiprocessing.AuthenticationError and ProcessError are exception classes — __class__.__name__ == 'type'."
    - "Queue, Pipe, Pool, Value, Array, cpu_count, Manager are bound methods of the default multiprocessing context object (BaseContext), not free functions — hence 'method', not 'function'."
    - "The pattern function: Name.__class__.__name__.__eq__ with args: ['expected'] and expected: true is the canonical ZSDL idiom for attribute equality checks."
  created_at: "2026-04-12"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Module-level classes: __class__.__name__ == "type"
# ---------------------------------------------------------------------------

table multiprocessing_extra2371.object_types:
  kind: python_call_eq
  category: object_types

  columns: [id, function, args, expected]
  rows:
    - ["mp2371001", "Process.__class__.__name__.__eq__",            ["type"],   true]
    - ["mp2371002", "AuthenticationError.__class__.__name__.__eq__", ["type"],  true]
    - ["mp2371003", "ProcessError.__class__.__name__.__eq__",        ["type"],  true]

# ---------------------------------------------------------------------------
# Module-level context-bound methods: __class__.__name__ == "method"
# ---------------------------------------------------------------------------

table multiprocessing_extra2371.method_types:
  kind: python_call_eq
  category: object_types

  columns: [id, function, args, expected]
  rows:
    - ["mp2371004", "Queue.__class__.__name__.__eq__",         ["method"], true]
    - ["mp2371005", "Pipe.__class__.__name__.__eq__",          ["method"], true]
    - ["mp2371006", "Pool.__class__.__name__.__eq__",          ["method"], true]
    - ["mp2371007", "Value.__class__.__name__.__eq__",         ["method"], true]
    - ["mp2371008", "Array.__class__.__name__.__eq__",         ["method"], true]
    - ["mp2371009", "cpu_count.__class__.__name__.__eq__",     ["method"], true]
    - ["mp2371010", "Manager.__class__.__name__.__eq__",       ["method"], true]

# ---------------------------------------------------------------------------
# Module-level plain functions: __class__.__name__ == "function"
# ---------------------------------------------------------------------------

table multiprocessing_extra2371.function_types:
  kind: python_call_eq
  category: object_types

  columns: [id, function, args, expected]
  rows:
    - ["mp2371011", "current_process.__class__.__name__.__eq__", ["function"], true]
    - ["mp2371012", "active_children.__class__.__name__.__eq__", ["function"], true]

# ---------------------------------------------------------------------------
# Cross-checks: class __name__ attributes match expected string values
# ---------------------------------------------------------------------------

table multiprocessing_extra2371.class_names:
  kind: python_call_eq
  category: class_names

  columns: [id, function, args, expected]
  rows:
    - ["mp2371013", "Process.__name__.__eq__",             ["Process"],             true]
    - ["mp2371014", "AuthenticationError.__name__.__eq__", ["AuthenticationError"], true]
    - ["mp2371015", "ProcessError.__name__.__eq__",        ["ProcessError"],        true]

# ---------------------------------------------------------------------------
# Cross-checks: function __name__ attributes for context methods and free functions
# ---------------------------------------------------------------------------

table multiprocessing_extra2371.callable_names:
  kind: python_call_eq
  category: callable_names

  columns: [id, function, args, expected]
  rows:
    - ["mp2371016", "Queue.__name__.__eq__",           ["Queue"],           true]
    - ["mp2371017", "Pipe.__name__.__eq__",            ["Pipe"],            true]
    - ["mp2371018", "Pool.__name__.__eq__",            ["Pool"],            true]
    - ["mp2371019", "current_process.__name__.__eq__", ["current_process"], true]
    - ["mp2371020", "active_children.__name__.__eq__", ["active_children"], true]
