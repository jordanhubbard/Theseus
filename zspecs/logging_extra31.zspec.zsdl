spec: logging_extra31
version: ">=3.9"
backend: python_module(logging)

docs: https://docs.python.org/3/library/logging.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/logging.html — Python logging module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/logging/__init__.py"
    - "logging_extra30.zspec.zsdl — covers __mro__.__len__() for Logger (3), Handler (3), Formatter (2), LogRecord (2); __bases__[0].__name__.__len__() for Logger/Handler ('Filterer', 8) and LogRecord/Formatter ('object', 6); LogRecord.getMessage.__qualname__.__len__()==20; LogRecord.__init__.__qualname__.__len__()==18; Formatter.format.__qualname__.__len__()==16; Logger.debug/__qualname__.__len__()==12; Logger.info/__qualname__.__len__()==11; Logger.warning/__qualname__.__len__()==14; Handler.emit/__qualname__.__len__()==12."
    - "logging_extra29.zspec.zsdl — covers __module__.__len__()==7 for getLogger/basicConfig/warning/error/info/debug/critical (functions) and FileHandler/StreamHandler (classes); __name__.__len__() and __qualname__.__len__() for FileHandler/StreamHandler."
    - "logging_extra28.zspec.zsdl — covers __module__.__len__()==7 for Logger/Handler/Formatter/Filter/LogRecord; __name__.__len__() for Logger/Handler/Formatter/Filter/LogRecord."
  notes:
    - "This spec extends logging_extra30.zspec.zsdl."
    - "Prior specs covered: Logger/Handler/Formatter/Filter/LogRecord/FileHandler/StreamHandler __name__/__module__/__qualname__/__bases__[0].__name__/__mro__.__len__(), level constants, module-level function __name__/__module__/__qualname__ lengths, method __qualname__.__len__() for LogRecord/Formatter/Logger/Handler methods."
    - "This spec covers NEW angles: logging.__all__.__len__()==45; logging.__all__.__class__.__name__=='list' (len 4); logging level numeric constants DEBUG (10)/INFO (20)/WARNING (30)/ERROR (40)/CRITICAL (50)/NOTSET (0)/WARN (30)/FATAL (50); level constant __class__.__name__=='int' (len 3); logging.Logger.__dict__.__class__.__name__=='mappingproxy' (len 12) and same for Handler/Formatter/Filter/LogRecord; module-level function __qualname__.__len__() for getLevelName (12)/getLogger (9)/makeLogRecord (13)/basicConfig (11)."
    - "logging.__all__.__len__() == 45 — 45 public names exported. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.__all__.__class__.__name__ == 'list' (len 4). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.DEBUG == 10, logging.INFO == 20, logging.WARNING == 30, logging.ERROR == 40, logging.CRITICAL == 50, logging.NOTSET == 0. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.WARN == 30 (alias for WARNING), logging.FATAL == 50 (alias for CRITICAL). Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.DEBUG.__class__.__name__ == 'int' (len 3). All level constants are int instances. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.Logger.__dict__.__class__.__name__ == 'mappingproxy' (len 12). Same for Handler, Formatter, Filter, LogRecord. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "logging.getLevelName.__qualname__.__len__() == 12. logging.getLogger.__qualname__.__len__() == 9. logging.makeLogRecord.__qualname__.__len__() == 13. logging.basicConfig.__qualname__.__len__() == 11. Verified Python 3.12 macOS/Darwin 25.4.0, 2026-04-10."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# logging.__all__.__len__() and __all__.__class__.__name__.__len__()
#
# No prior spec checks __all__.__len__() or __all__.__class__.__name__ for
# the logging module. logging.__all__ exports 45 public names and is a list.
# ---------------------------------------------------------------------------

invariant logging_extra31.all.len:
  description: "logging.__all__.__len__() == 45 — 45 public names exported"
  category: module_membership
  kind: python_call_eq
  function: __all__.__len__
  args: []
  expected: 45

invariant logging_extra31.all.class.name.len:
  description: "logging.__all__.__class__.__name__.__len__() == 4 — __all__ is a 'list'"
  category: module_membership
  kind: python_call_eq
  function: __all__.__class__.__name__.__len__
  args: []
  expected: 4

# ---------------------------------------------------------------------------
# Logging level numeric constants
#
# No prior spec checks the numeric VALUES of the standard level constants.
# DEBUG=10, INFO=20, WARNING=30, ERROR=40, CRITICAL=50, NOTSET=0.
# WARN is an alias for WARNING (30); FATAL is an alias for CRITICAL (50).
# ---------------------------------------------------------------------------

invariant logging_extra31.DEBUG.value:
  description: "logging.DEBUG == 10"
  category: module_constants
  kind: python_call_eq
  function: DEBUG.__class__.__eq__
  args: [10]
  expected: true

invariant logging_extra31.NOTSET.value:
  description: "logging.NOTSET == 0"
  category: module_constants
  kind: python_call_eq
  function: NOTSET.__class__.__eq__
  args: [0]
  expected: true

# ---------------------------------------------------------------------------
# Level constant __class__.__name__.__len__() — all are int (len 3)
#
# No prior spec checks the class name length for any logging level constant.
# DEBUG, INFO, WARNING, ERROR, CRITICAL are all plain Python int instances.
# ---------------------------------------------------------------------------

invariant logging_extra31.DEBUG.class.name.len:
  description: "logging.DEBUG.__class__.__name__.__len__() == 3 — DEBUG is an 'int'"
  category: module_constants
  kind: python_call_eq
  function: DEBUG.__class__.__name__.__len__
  args: []
  expected: 3

invariant logging_extra31.CRITICAL.class.name.len:
  description: "logging.CRITICAL.__class__.__name__.__len__() == 3 — CRITICAL is an 'int'"
  category: module_constants
  kind: python_call_eq
  function: CRITICAL.__class__.__name__.__len__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# Table: logging level numeric constants
#
# No prior spec groups level constant values together in a table.
# DEBUG=10, INFO=20, WARNING=30, ERROR=40, CRITICAL=50, NOTSET=0,
# WARN=30 (alias), FATAL=50 (alias).
# ---------------------------------------------------------------------------

table logging_extra31.level_constants:
  description: "logging level numeric constants — DEBUG (10), INFO (20), WARNING (30), ERROR (40), CRITICAL (50), NOTSET (0), WARN (30), FATAL (50)"
  kind: python_call_eq
  category: module_constants

  columns: [id, function, args, expected, description]
  rows:
    - [DEBUG_value,
       DEBUG.__int__,
       [],
       10,
       "logging.DEBUG == 10"]
    - [INFO_value,
       INFO.__int__,
       [],
       20,
       "logging.INFO == 20"]
    - [WARNING_value,
       WARNING.__int__,
       [],
       30,
       "logging.WARNING == 30"]
    - [ERROR_value,
       ERROR.__int__,
       [],
       40,
       "logging.ERROR == 40"]
    - [CRITICAL_value,
       CRITICAL.__int__,
       [],
       50,
       "logging.CRITICAL == 50"]
    - [NOTSET_value,
       NOTSET.__int__,
       [],
       0,
       "logging.NOTSET == 0"]
    - [WARN_value,
       WARN.__int__,
       [],
       30,
       "logging.WARN == 30 (alias for WARNING)"]
    - [FATAL_value,
       FATAL.__int__,
       [],
       50,
       "logging.FATAL == 50 (alias for CRITICAL)"]

# ---------------------------------------------------------------------------
# Table: logging class __dict__.__class__.__name__.__len__()
#
# No prior spec checks __dict__.__class__.__name__.__len__() for any logging
# class. All logging classes expose their namespace via a mappingproxy
# (len 12). Covers Logger, Handler, Formatter, Filter, LogRecord.
# ---------------------------------------------------------------------------

table logging_extra31.class_dict_class_name_len:
  description: "logging class __dict__.__class__.__name__.__len__() — Logger/Handler/Formatter/Filter/LogRecord all return 12 ('mappingproxy')"
  kind: python_call_eq
  category: module_constants

  columns: [id, function, args, expected, description]
  rows:
    - [Logger_dict_class_name_len,
       Logger.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len('mappingproxy') == 12 — Logger.__dict__.__class__.__name__"]
    - [Handler_dict_class_name_len,
       Handler.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len('mappingproxy') == 12 — Handler.__dict__.__class__.__name__"]
    - [Formatter_dict_class_name_len,
       Formatter.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len('mappingproxy') == 12 — Formatter.__dict__.__class__.__name__"]
    - [Filter_dict_class_name_len,
       Filter.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len('mappingproxy') == 12 — Filter.__dict__.__class__.__name__"]
    - [LogRecord_dict_class_name_len,
       LogRecord.__dict__.__class__.__name__.__len__,
       [],
       12,
       "len('mappingproxy') == 12 — LogRecord.__dict__.__class__.__name__"]
    - [getLevelName_qualname_len,
       getLevelName.__qualname__.__len__,
       [],
       12,
       "len('getLevelName') == 12"]
    - [getLogger_qualname_len,
       getLogger.__qualname__.__len__,
       [],
       9,
       "len('getLogger') == 9"]
    - [makeLogRecord_qualname_len,
       makeLogRecord.__qualname__.__len__,
       [],
       13,
       "len('makeLogRecord') == 13"]
    - [basicConfig_qualname_len,
       basicConfig.__qualname__.__len__,
       [],
       11,
       "len('basicConfig') == 11"]
