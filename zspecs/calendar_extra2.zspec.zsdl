spec: calendar_extra2
version: ">=3.2"
backend: python_module(calendar)

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "Python calendar documentation — https://docs.python.org/3/library/calendar.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/calendar.py"
  notes:
    - "This spec covers calendar invariants not already in calendar.zspec.zsdl or calendar_extra.zspec.zsdl."
    - "Calendar.__name__ == 'Calendar' — base class for all calendar formatters."
    - "TextCalendar.__name__ == 'TextCalendar' — plain-text calendar subclass."
    - "HTMLCalendar.__name__ == 'HTMLCalendar' — HTML calendar subclass."
    - "MONDAY == 0 and SUNDAY == 6 — weekday constants (Monday is the first day per ISO)."
    - "month_name.__class__.__name__ == '_localized_month' — private sequence type for localized month names."
    - "isleap(2000) == True — 2000 is divisible by 400, so it is a leap year."
    - "isleap(1900) == False — 1900 is divisible by 100 but not by 400, so it is not a leap year."
    - "leapdays(2000, 2001) == 1 — only 2000 falls in [2000, 2001), and 2000 is a leap year."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Calendar — class name
# ---------------------------------------------------------------------------

invariant calendar_extra2.Calendar.name:
  description: "calendar.Calendar.__name__ == 'Calendar'"
  category: class_identity
  kind: python_call_eq
  function: Calendar.__name__.__eq__
  args: ["Calendar"]
  expected: true

# ---------------------------------------------------------------------------
# TextCalendar — class name
# ---------------------------------------------------------------------------

invariant calendar_extra2.TextCalendar.name:
  description: "calendar.TextCalendar.__name__ == 'TextCalendar'"
  category: class_identity
  kind: python_call_eq
  function: TextCalendar.__name__.__eq__
  args: ["TextCalendar"]
  expected: true

# ---------------------------------------------------------------------------
# HTMLCalendar — class name
# ---------------------------------------------------------------------------

invariant calendar_extra2.HTMLCalendar.name:
  description: "calendar.HTMLCalendar.__name__ == 'HTMLCalendar'"
  category: class_identity
  kind: python_call_eq
  function: HTMLCalendar.__name__.__eq__
  args: ["HTMLCalendar"]
  expected: true

# ---------------------------------------------------------------------------
# Constants — MONDAY and SUNDAY
# ---------------------------------------------------------------------------

invariant calendar_extra2.MONDAY.value:
  description: "calendar.MONDAY == 0"
  category: constants
  kind: python_call_eq
  function: MONDAY.__eq__
  args: [0]
  expected: true

invariant calendar_extra2.SUNDAY.value:
  description: "calendar.SUNDAY == 6"
  category: constants
  kind: python_call_eq
  function: SUNDAY.__eq__
  args: [6]
  expected: true

# ---------------------------------------------------------------------------
# month_name — class name of the sequence object
# ---------------------------------------------------------------------------

invariant calendar_extra2.month_name.class_name:
  description: "calendar.month_name.__class__.__name__ == '_localized_month'"
  category: month_name
  kind: python_call_eq
  function: month_name.__class__.__name__.__eq__
  args: ["_localized_month"]
  expected: true

# ---------------------------------------------------------------------------
# isleap — leap year detection
# ---------------------------------------------------------------------------

invariant calendar_extra2.isleap.year_2000:
  description: "calendar.isleap(2000) == True — divisible by 400"
  category: isleap
  kind: python_call_eq
  function: isleap
  args: [2000]
  expected: true

invariant calendar_extra2.isleap.year_1900:
  description: "calendar.isleap(1900) == False — divisible by 100 but not 400"
  category: isleap
  kind: python_call_eq
  function: isleap
  args: [1900]
  expected: false

# ---------------------------------------------------------------------------
# leapdays — count of leap years in [y1, y2) with exclusive upper bound
#
# leapdays(2000, 2001): only 2000 is in [2000, 2001), and 2000 is a leap year → 1
# ---------------------------------------------------------------------------

invariant calendar_extra2.leapdays.2000_to_2001:
  description: "calendar.leapdays(2000, 2001) == 1 — only 2000 in range and it is a leap year"
  category: leapdays
  kind: python_call_eq
  function: leapdays
  args: [2000, 2001]
  expected: 1
