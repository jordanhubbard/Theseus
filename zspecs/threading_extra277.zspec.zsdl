spec: threading_extra277
version: ">=3.8"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12"
  not_derived_from:
    - "CPython source: Lib/threading.py"
  notes:
    - "threading.excepthook is actually the C builtin _thread._excepthook re-exported by threading."
    - "threading.excepthook.__module__ == '_thread' and __name__ == '_excepthook' (NOT 'excepthook')."
    - "threading.excepthook.__class__.__name__ == 'builtin_function_or_method' — it is a C builtin."
    - "threading.settrace, setprofile, and enumerate are all pure-Python functions defined in threading."
    - "settrace.__module__ == 'threading'; settrace.__name__ == 'settrace' (8 chars)."
    - "setprofile.__module__ == 'threading'; setprofile.__name__ == 'setprofile' (10 chars)."
    - "enumerate.__module__ == 'threading'; enumerate.__name__ == 'enumerate' (9 chars)."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-12."
  created_at: "2026-04-12T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# threading.excepthook — C builtin identity
#
# threading.excepthook is the C builtin _thread._excepthook re-exported.
# __module__ == '_thread' (NOT 'threading'); __name__ == '_excepthook'.
# __class__.__name__ == 'builtin_function_or_method'.
# ---------------------------------------------------------------------------

table threading_extra277.excepthook_identity:
  description: "threading.excepthook C builtin identity — __name__ is '_excepthook', __module__ is '_thread', __class__.__name__; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex277eh

  columns: [id, function, args, expected, description]
  rows:
    - [eh_name_eq,  excepthook.__name__.__eq__,           ["_excepthook"],               true, "threading.excepthook.__name__ == '_excepthook' — actual name is _excepthook, not excepthook; verified with Python 3.14.3"]
    - [eh_mod_eq,   excepthook.__module__.__eq__,          ["_thread"],                  true, "threading.excepthook.__module__ == '_thread' — C builtin re-exported from _thread, not 'threading'; verified with Python 3.14.3"]
    - [eh_cls_eq,   excepthook.__class__.__name__.__eq__,  ["builtin_function_or_method"], true, "threading.excepthook.__class__.__name__ == 'builtin_function_or_method' (C builtin); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# threading.settrace, threading.setprofile, threading.enumerate
#
# All three are pure-Python functions defined in the threading module.
# settrace.__name__ == 'settrace' (8 chars); __module__ == 'threading'.
# setprofile.__name__ == 'setprofile' (10 chars); __module__ == 'threading'.
# enumerate.__name__ == 'enumerate' (9 chars); __module__ == 'threading'.
# ---------------------------------------------------------------------------

table threading_extra277.settrace_setprofile_enumerate_identity:
  description: "threading.settrace, setprofile, enumerate function identity — __name__, __module__, __class__.__name__; pure-Python functions in threading; verified with Python 3.14.3"
  kind: python_call_eq
  category: identity
  id_prefix: thex277sse

  columns: [id, function, args, expected, description]
  rows:
    - [st_name_eq,  settrace.__name__.__eq__,            ["settrace"],   true, "threading.settrace.__name__ == 'settrace'; verified with Python 3.14.3"]
    - [st_name_len, settrace.__name__.__len__,            [],             8,    "threading.settrace.__name__.__len__() == 8; verified with Python 3.14.3"]
    - [st_mod_eq,   settrace.__module__.__eq__,           ["threading"],  true, "threading.settrace.__module__ == 'threading' (pure-Python function); verified with Python 3.14.3"]
    - [st_cls_eq,   settrace.__class__.__name__.__eq__,   ["function"],   true, "threading.settrace.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [sp_name_eq,  setprofile.__name__.__eq__,           ["setprofile"], true, "threading.setprofile.__name__ == 'setprofile'; verified with Python 3.14.3"]
    - [sp_name_len, setprofile.__name__.__len__,           [],             10,   "threading.setprofile.__name__.__len__() == 10; verified with Python 3.14.3"]
    - [sp_mod_eq,   setprofile.__module__.__eq__,          ["threading"],  true, "threading.setprofile.__module__ == 'threading' (pure-Python function); verified with Python 3.14.3"]
    - [sp_cls_eq,   setprofile.__class__.__name__.__eq__,  ["function"],   true, "threading.setprofile.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]
    - [en_name_eq,  enumerate.__name__.__eq__,            ["enumerate"],  true, "threading.enumerate.__name__ == 'enumerate'; verified with Python 3.14.3"]
    - [en_name_len, enumerate.__name__.__len__,            [],             9,    "threading.enumerate.__name__.__len__() == 9; verified with Python 3.14.3"]
    - [en_mod_eq,   enumerate.__module__.__eq__,           ["threading"],  true, "threading.enumerate.__module__ == 'threading' (pure-Python function); verified with Python 3.14.3"]
    - [en_cls_eq,   enumerate.__class__.__name__.__eq__,   ["function"],   true, "threading.enumerate.__class__.__name__ == 'function' (pure-Python); verified with Python 3.14.3"]

# ---------------------------------------------------------------------------
# Standalone invariants — threading_extra277
# ---------------------------------------------------------------------------

invariant threading_extra277.excepthook_module_is_c_thread:
  description: "threading.excepthook.__module__ == '_thread' — excepthook is a C builtin from _thread, re-exported by threading (contrast with settrace which is pure-Python)"
  category: identity
  kind: python_call_eq
  function: excepthook.__module__.__eq__
  args: ["_thread"]
  expected: true

invariant threading_extra277.excepthook_name_is_private:
  description: "threading.excepthook.__name__ == '_excepthook' — the internal C name differs from the public export symbol 'excepthook'"
  category: identity
  kind: python_call_eq
  function: excepthook.__name__.__eq__
  args: ["_excepthook"]
  expected: true

invariant threading_extra277.excepthook_is_builtin:
  description: "threading.excepthook.__class__.__name__ == 'builtin_function_or_method' — excepthook is a C builtin, not a pure-Python function"
  category: identity
  kind: python_call_eq
  function: excepthook.__class__.__name__.__eq__
  args: ["builtin_function_or_method"]
  expected: true

invariant threading_extra277.settrace_module_is_threading:
  description: "threading.settrace.__module__ == 'threading' — settrace is a pure-Python function defined in threading (contrast with excepthook from _thread)"
  category: identity
  kind: python_call_eq
  function: settrace.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra277.setprofile_module_is_threading:
  description: "threading.setprofile.__module__ == 'threading' — setprofile is a pure-Python function defined in threading"
  category: identity
  kind: python_call_eq
  function: setprofile.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra277.enumerate_module_is_threading:
  description: "threading.enumerate.__module__ == 'threading' — enumerate is a pure-Python function in threading, distinct from the built-in enumerate type"
  category: identity
  kind: python_call_eq
  function: enumerate.__module__.__eq__
  args: ["threading"]
  expected: true

invariant threading_extra277.settrace_name_length_is_8:
  description: "threading.settrace.__name__.__len__() == 8 — 'settrace' has 8 characters"
  category: identity
  kind: python_call_eq
  function: settrace.__name__.__len__
  args: []
  expected: 8

invariant threading_extra277.setprofile_name_length_is_10:
  description: "threading.setprofile.__name__.__len__() == 10 — 'setprofile' has 10 characters"
  category: identity
  kind: python_call_eq
  function: setprofile.__name__.__len__
  args: []
  expected: 10

invariant threading_extra277.enumerate_name_length_is_9:
  description: "threading.enumerate.__name__.__len__() == 9 — 'enumerate' has 9 characters"
  category: identity
  kind: python_call_eq
  function: enumerate.__name__.__len__
  args: []
  expected: 9
