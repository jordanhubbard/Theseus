spec: re_extra128
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
  notes:
    - "This spec covers: re.Pattern and re.Match type identity attributes."
    - "re.Pattern.__name__ == 'Pattern' (length 7); both __name__ and __qualname__ are bare 'Pattern'."
    - "re.Pattern.__module__ == 're' (length 2) — even though the underlying C type lives in _sre, the public attribute is exposed through the re module."
    - "re.Pattern.__bases__[0].__name__ == 'object' — Pattern extends object directly; MRO length == 2."
    - "re.Match.__name__ == 'Match' (length 5); both __name__ and __qualname__ are bare 'Match'."
    - "re.Match.__module__ == 're' (length 2)."
    - "re.Match.__bases__[0].__name__ == 'object' — Match also extends object directly; MRO length == 2."
    - "re.Pattern.__name__ != 're.Pattern' (no module prefix in __name__)."
    - "re.Match.__name__ != 'SRE_Match' (the old internal C name no longer exposed)."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Pattern type identity: __name__, __qualname__, __module__
# Pattern.__name__ == 'Pattern' (length 7).
# Pattern.__qualname__ == 'Pattern' (same as __name__; module-level).
# Pattern.__module__ == 're' (length 2).
# ---------------------------------------------------------------------------

table re_extra128.Pattern_type_identity:
  description: "re.Pattern type identity: __name__, __qualname__, __module__, and their lengths"
  kind: python_call_eq
  category: type_identity
  id_prefix: repatternmatch128

  columns: [id, function, args, expected, description]
  rows:
    - [pat_name_eq,       Pattern.__name__.__eq__,      ["Pattern"],    true,  "re.Pattern.__name__ == 'Pattern'"]
    - [pat_name_len,      Pattern.__name__.__len__,     [],             7,     "re.Pattern.__name__.__len__() == 7 ('Pattern' has 7 characters)"]
    - [pat_qname_eq,      Pattern.__qualname__.__eq__,  ["Pattern"],    true,  "re.Pattern.__qualname__ == 'Pattern' (equals __name__ for module-level type)"]
    - [pat_qname_len,     Pattern.__qualname__.__len__, [],             7,     "re.Pattern.__qualname__.__len__() == 7"]
    - [pat_mod_eq,        Pattern.__module__.__eq__,    ["re"],         true,  "re.Pattern.__module__ == 're'"]
    - [pat_mod_len,       Pattern.__module__.__len__,   [],             2,     "re.Pattern.__module__.__len__() == 2 ('re' has 2 characters)"]
    - [pat_name_not_qual, Pattern.__name__.__eq__,      ["re.Pattern"], false, "re.Pattern.__name__ != 're.Pattern' (no module prefix in __name__)"]

# ---------------------------------------------------------------------------
# re.Pattern class hierarchy: __bases__[0].__name__ and __mro__.__len__()
# Pattern.__bases__[0].__name__ == 'object' (extends object directly).
# MRO is [Pattern, object]; length == 2.
# ---------------------------------------------------------------------------

table re_extra128.Pattern_class_hierarchy:
  description: "re.Pattern class hierarchy: __bases__[0].__name__ and __mro__.__len__()"
  kind: python_call_eq
  category: type_identity
  id_prefix: repatternmatch128

  columns: [id, function, args, expected, description]
  rows:
    - [pat_base_eq,        "Pattern.__bases__[0].__name__.__eq__", ["object"], true,  "re.Pattern.__bases__[0].__name__ == 'object' (Pattern extends object directly)"]
    - [pat_base_not_str,   "Pattern.__bases__[0].__name__.__eq__", ["str"],    false, "re.Pattern.__bases__[0].__name__ != 'str'"]
    - [pat_mro_len,        Pattern.__mro__.__len__,                [],         2,     "re.Pattern.__mro__.__len__() == 2 (MRO is [Pattern, object])"]
    - [pat_mro_not_len3,   Pattern.__mro__.__len__,                [],         3,     false]
    - [match_base_eq,      "Match.__bases__[0].__name__.__eq__",   ["object"], true,  "re.Match.__bases__[0].__name__ == 'object' (Match also extends object directly)"]
    - [match_mro_len,      Match.__mro__.__len__,                  [],         2,     "re.Match.__mro__.__len__() == 2 (MRO is [Match, object])"]
    - [pat_base_not_match, "Pattern.__bases__[0].__name__.__eq__", ["Match"],  false, "re.Pattern does not extend re.Match"]

# ---------------------------------------------------------------------------
# re.Match type identity: __name__, __qualname__, __module__
# Match.__name__ == 'Match' (length 5).
# Match.__qualname__ == 'Match' (same as __name__).
# Match.__module__ == 're' (length 2).
# ---------------------------------------------------------------------------

table re_extra128.Match_type_identity:
  description: "re.Match type identity: __name__, __qualname__, __module__, and their lengths"
  kind: python_call_eq
  category: type_identity
  id_prefix: repatternmatch128

  columns: [id, function, args, expected, description]
  rows:
    - [match_name_eq,     Match.__name__.__eq__,      ["Match"],    true,  "re.Match.__name__ == 'Match'"]
    - [match_name_len,    Match.__name__.__len__,     [],           5,     "re.Match.__name__.__len__() == 5 ('Match' has 5 characters)"]
    - [match_qname_eq,    Match.__qualname__.__eq__,  ["Match"],    true,  "re.Match.__qualname__ == 'Match' (equals __name__ for module-level type)"]
    - [match_qname_len,   Match.__qualname__.__len__, [],           5,     "re.Match.__qualname__.__len__() == 5"]
    - [match_mod_eq,      Match.__module__.__eq__,    ["re"],       true,  "re.Match.__module__ == 're'"]
    - [match_mod_len,     Match.__module__.__len__,   [],           2,     "re.Match.__module__.__len__() == 2 ('re' has 2 characters)"]
    - [match_name_neq,    Match.__name__.__eq__,      ["Pattern"],  false, "re.Match.__name__ != 'Pattern'"]

# ---------------------------------------------------------------------------
# Standalone invariants
# ---------------------------------------------------------------------------

invariant re_extra128.Pattern.name_is_Pattern:
  description: "re.Pattern.__name__ == 'Pattern' (the compiled regex type name is the bare 'Pattern', length 7; no module qualification)"
  category: type_identity
  kind: python_call_eq
  function: Pattern.__name__.__eq__
  args: ["Pattern"]
  expected: true

invariant re_extra128.Pattern.mro_len_2:
  description: "re.Pattern.__mro__.__len__() == 2 (MRO is [Pattern, object]; Pattern extends object directly with no intermediate base classes)"
  category: type_identity
  kind: python_call_eq
  function: Pattern.__mro__.__len__
  args: []
  expected: 2

invariant re_extra128.Match.name_is_Match:
  description: "re.Match.__name__ == 'Match' (the regex match result type name is the bare 'Match', length 5)"
  category: type_identity
  kind: python_call_eq
  function: Match.__name__.__eq__
  args: ["Match"]
  expected: true

invariant re_extra128.Match.module_is_re:
  description: "re.Match.__module__ == 're' (Match is exposed through the public re module; module name is the two-character string 're')"
  category: type_identity
  kind: python_call_eq
  function: Match.__module__.__eq__
  args: ["re"]
  expected: true

invariant re_extra128.Pattern.base_is_object:
  description: "re.Pattern.__bases__[0].__name__ == 'object' (Pattern extends object directly; it is a flat C extension type with no Python-visible intermediate base)"
  category: type_identity
  kind: python_call_eq
  function: Pattern.__bases__[0].__name__.__eq__
  args: ["object"]
  expected: true
