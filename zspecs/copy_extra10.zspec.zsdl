spec: copy_extra10
version: ">=3.9"
backend: python_module(copy)

docs: https://docs.python.org/3/library/copy.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/copy.html — Python copy module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/copy.py"
  notes:
    - "This spec extends copy.zspec.zsdl through copy_extra9.zspec.zsdl."
    - "copy_extra9 covers: copy('world')/deepcopy('test')/copy([1,2])/deepcopy([1,2]); copy({'x':10})/deepcopy({'x':10,'y':20}); copy(99); Error.__bases__.__len__()==1."
    - "copy_extra8 covers: copy.__name__.__len__()==4; deepcopy.__name__.__len__()==8; Error.__name__.__len__()==5; Error.__mro__[2]=='BaseException'/__mro__[3]=='object'."
    - "copy_extra7 covers: copy(-42)/copy(1000000)/deepcopy('world')/deepcopy(-5); copy([1,2,3]).__len__()==3; copy({'a':1,'b':2}).__len__()==2; deepcopy(['a','b','c']); Error.__mro__ len and mro[1]."
    - "copy_extra6 covers: copy.__qualname__/deepcopy.__qualname__/Error.__qualname__; Error.__bases__[0].__name__=='Exception'; Error.__bases__[0].__module__; Error.__class__.__name__."
    - "copy_extra5 covers: copy((1,2,3))/deepcopy({'a':[1,2]})/deepcopy([1,[2,3]]); qualnames."
    - "copy_extra4 covers: copy([1,2,3])/copy('hello')/copy({'a':1}); deepcopy([1,2,3])/deepcopy({'a':1})/deepcopy([1,[2,3]]); Error.__name__/Error.__module__ via table."
    - "NOT yet covered: copy.copy(False) == False — shallow copy of boolean False (extra2 covers True)."
    - "NOT yet covered: copy.deepcopy(False) == False — deepcopy of boolean False (extra2 covers True, deepcopy.true_eq_true)."
    - "NOT yet covered: copy.copy(0) == 0 — copy of integer zero (all prior copy ints are 42, -42, 1000000, 99)."
    - "NOT yet covered: copy.deepcopy(0) == 0 — deepcopy of integer zero."
    - "NOT yet covered: copy.copy([]) == [] — copy of empty list (extra2 covers {} but not [])."
    - "NOT yet covered: copy.deepcopy([]) == [] — deepcopy of empty list."
    - "NOT yet covered: copy.copy((1, 2)) == (1, 2) — two-element tuple (extra5 covers (1,2,3) only)."
    - "NOT yet covered: copy.deepcopy((1, 2)) == (1, 2) — deepcopy of two-element tuple."
    - "NOT yet covered: copy.Error.__mro__[0].__name__ == 'Error' — first MRO entry is the class itself."
    - "NOT yet covered: copy.Error.__qualname__.__len__() == 5 — len('Error') == 5."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# copy.copy and deepcopy — boolean False
#
# copy_extra2 covers copy(True) and deepcopy(True) (true_eq_true invariants).
# No prior spec covers copy(False) or deepcopy(False). Booleans are immutable;
# copy and deepcopy return an equal value.
# ---------------------------------------------------------------------------

invariant copy_extra10.copy.bool_false:
  description: "copy.copy(False) == False — shallow copy of False returns equal boolean"
  category: copy_immutable
  kind: python_call_eq
  function: copy
  args: [false]
  expected: false

invariant copy_extra10.deepcopy.bool_false:
  description: "copy.deepcopy(False) == False — deepcopy of False returns equal boolean"
  category: deepcopy_immutable
  kind: python_call_eq
  function: deepcopy
  args: [false]
  expected: false

# ---------------------------------------------------------------------------
# copy.copy and deepcopy — integer zero
#
# Prior specs cover integer 42, -42, 1000000, 99. No prior spec covers zero.
# Integers are immutable; copy and deepcopy return an equal value.
# ---------------------------------------------------------------------------

invariant copy_extra10.copy.zero:
  description: "copy.copy(0) == 0 — shallow copy of zero returns equal integer"
  category: copy_immutable
  kind: python_call_eq
  function: copy
  args: [0]
  expected: 0

invariant copy_extra10.deepcopy.zero:
  description: "copy.deepcopy(0) == 0 — deepcopy of zero returns equal integer"
  category: deepcopy_immutable
  kind: python_call_eq
  function: deepcopy
  args: [0]
  expected: 0

# ---------------------------------------------------------------------------
# copy.copy and deepcopy — empty list
#
# copy_extra2 covers copy({}) and deepcopy({}) (empty dicts). No prior spec
# covers copy([]) or deepcopy([]). An empty list is a distinct container type.
# ---------------------------------------------------------------------------

invariant copy_extra10.copy.empty_list:
  description: "copy.copy([]) == [] — shallow copy of empty list returns equal empty list"
  category: copy_containers
  kind: python_call_eq
  function: copy
  args: [[]]
  expected: []

invariant copy_extra10.deepcopy.empty_list:
  description: "copy.deepcopy([]) == [] — deepcopy of empty list returns equal empty list"
  category: deepcopy_containers
  kind: python_call_eq
  function: deepcopy
  args: [[]]
  expected: []

# ---------------------------------------------------------------------------
# copy.copy and deepcopy — two-element tuple
#
# copy_extra5 covers copy((1,2,3)) (three-element tuple). No prior spec covers
# a two-element tuple. Tuples are immutable; copy and deepcopy return equal values.
# Expected must use YAML list [val1, val2] for tuple representation.
# ---------------------------------------------------------------------------

invariant copy_extra10.copy.two_elem_tuple:
  description: "copy.copy((1, 2)) == (1, 2) — shallow copy of 2-element tuple returns equal value"
  category: copy_immutable
  kind: python_call_eq
  function: copy
  args: [[1, 2]]
  expected: [1, 2]

invariant copy_extra10.deepcopy.two_elem_tuple:
  description: "copy.deepcopy((1, 2)) == (1, 2) — deepcopy of 2-element tuple returns equal value"
  category: deepcopy_immutable
  kind: python_call_eq
  function: deepcopy
  args: [[1, 2]]
  expected: [1, 2]

# ---------------------------------------------------------------------------
# copy.Error — MRO first entry and qualname length
#
# copy_extra7 covers Error.__mro__.__len__()==4 and Error.__mro__[1].__name__=='Exception'.
# copy_extra8 covers Error.__mro__[2]=='BaseException' and Error.__mro__[3]=='object'.
# No prior spec checks Error.__mro__[0].__name__ — the first MRO entry (the class itself).
# copy_extra8 covers Error.__name__.__len__()==5 but not Error.__qualname__.__len__().
# copy_extra6 confirms Error.__qualname__=='Error'; its length 5 is a new axis.
# ---------------------------------------------------------------------------

invariant copy_extra10.Error.mro_first:
  description: "copy.Error.__mro__[0].__name__ == 'Error' — first MRO entry is the class itself"
  category: error_hierarchy
  kind: python_call_eq
  function: Error.__mro__.__getitem__
  args: [0]
  method: __name__
  expected: "Error"

invariant copy_extra10.Error.qualname_len:
  description: "copy.Error.__qualname__.__len__() == 5 — len('Error') == 5"
  category: error_attrs
  kind: python_call_eq
  function: Error.__qualname__.__len__
  args: []
  expected: 5
