spec: uuid_extra2
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid.zspec.zsdl — that spec covers the npm uuid package, not Python stdlib"
    - "uuid_extra.zspec.zsdl — covers UUID.__name__, UUID.__module__, uuid1/3/4/5 __name__ (table), uuid4 return type and version, NAMESPACE_* class names (table), UUID int/hex attribute types"
  notes:
    - "This spec extends uuid_extra.zspec.zsdl with additional invariants not covered there."
    - "uuid.uuid1.__name__ == 'uuid1' — already in uuid_extra table; repeated here as standalone for extra2 coverage."
    - "uuid.uuid3.__name__ == 'uuid3', uuid.uuid5.__name__ == 'uuid5' — likewise."
    - "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID' — verified: all NAMESPACE_* are UUID instances."
    - "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID' — confirmed."
    - "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID' — confirmed."
    - "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID' — confirmed."
    - "uuid.RESERVED_NCS is the string 'reserved for NCS compatibility'."
    - "uuid.RFC_4122 is the string 'specified in RFC 4122'."
    - "uuid.RESERVED_MICROSOFT is the string 'reserved for Microsoft compatibility'."
    - "uuid.RESERVED_FUTURE is the string 'reserved for future definition'."
    - "All expected values verified by running Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Function name identity — uuid1, uuid3, uuid4, uuid5 __name__
# (uuid_extra has these in a table; extra2 adds standalone invariants for
#  uuid1, uuid3, uuid5 and adds uuid4 as explicit invariant too)
# ---------------------------------------------------------------------------

invariant uuid_extra2.uuid1.name:
  description: "uuid.uuid1.__name__ == 'uuid1'"
  category: function_identity
  kind: python_call_eq
  function: uuid1.__name__.__eq__
  args: ["uuid1"]
  expected: true

invariant uuid_extra2.uuid3.name:
  description: "uuid.uuid3.__name__ == 'uuid3'"
  category: function_identity
  kind: python_call_eq
  function: uuid3.__name__.__eq__
  args: ["uuid3"]
  expected: true

invariant uuid_extra2.uuid4.name:
  description: "uuid.uuid4.__name__ == 'uuid4'"
  category: function_identity
  kind: python_call_eq
  function: uuid4.__name__.__eq__
  args: ["uuid4"]
  expected: true

invariant uuid_extra2.uuid5.name:
  description: "uuid.uuid5.__name__ == 'uuid5'"
  category: function_identity
  kind: python_call_eq
  function: uuid5.__name__.__eq__
  args: ["uuid5"]
  expected: true

# ---------------------------------------------------------------------------
# NAMESPACE_* constants — class name (UUID instance) and __class__.__name__
# uuid_extra has these in a table; extra2 adds NAMESPACE_OID and NAMESPACE_X500
# as explicit standalone invariants for completeness
# ---------------------------------------------------------------------------

invariant uuid_extra2.NAMESPACE_DNS.class_name:
  description: "uuid.NAMESPACE_DNS.__class__.__name__ == 'UUID'"
  category: namespaces
  kind: python_call_eq
  function: NAMESPACE_DNS.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra2.NAMESPACE_URL.class_name:
  description: "uuid.NAMESPACE_URL.__class__.__name__ == 'UUID'"
  category: namespaces
  kind: python_call_eq
  function: NAMESPACE_URL.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra2.NAMESPACE_OID.class_name:
  description: "uuid.NAMESPACE_OID.__class__.__name__ == 'UUID'"
  category: namespaces
  kind: python_call_eq
  function: NAMESPACE_OID.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

invariant uuid_extra2.NAMESPACE_X500.class_name:
  description: "uuid.NAMESPACE_X500.__class__.__name__ == 'UUID'"
  category: namespaces
  kind: python_call_eq
  function: NAMESPACE_X500.__class__.__name__.__eq__
  args: ["UUID"]
  expected: true

# ---------------------------------------------------------------------------
# String constants — RESERVED_NCS, RFC_4122, RESERVED_MICROSOFT, RESERVED_FUTURE
# These are module-level string constants documenting the variant bits.
# ---------------------------------------------------------------------------

invariant uuid_extra2.RESERVED_NCS.value:
  description: "uuid.RESERVED_NCS == 'reserved for NCS compatibility'"
  category: constants
  kind: python_call_eq
  function: RESERVED_NCS.__eq__
  args: ["reserved for NCS compatibility"]
  expected: true

invariant uuid_extra2.RFC_4122.value:
  description: "uuid.RFC_4122 == 'specified in RFC 4122'"
  category: constants
  kind: python_call_eq
  function: RFC_4122.__eq__
  args: ["specified in RFC 4122"]
  expected: true

invariant uuid_extra2.RESERVED_MICROSOFT.value:
  description: "uuid.RESERVED_MICROSOFT == 'reserved for Microsoft compatibility'"
  category: constants
  kind: python_call_eq
  function: RESERVED_MICROSOFT.__eq__
  args: ["reserved for Microsoft compatibility"]
  expected: true

invariant uuid_extra2.RESERVED_FUTURE.value:
  description: "uuid.RESERVED_FUTURE == 'reserved for future definition'"
  category: constants
  kind: python_call_eq
  function: RESERVED_FUTURE.__eq__
  args: ["reserved for future definition"]
  expected: true

# ---------------------------------------------------------------------------
# String constant type checks — all RESERVED_* and RFC_4122 are str
# ---------------------------------------------------------------------------

table uuid_extra2.constants.type_checks:
  description: "uuid string constants are all of type str"
  kind: python_call_eq
  category: constants
  id_prefix: const_type

  columns: [id, function, args, expected]
  rows:
    - [RESERVED_NCS,       RESERVED_NCS.__class__.__name__.__eq__,       ["str"], true]
    - [RFC_4122,           RFC_4122.__class__.__name__.__eq__,            ["str"], true]
    - [RESERVED_MICROSOFT, RESERVED_MICROSOFT.__class__.__name__.__eq__,  ["str"], true]
    - [RESERVED_FUTURE,    RESERVED_FUTURE.__class__.__name__.__eq__,     ["str"], true]
