spec: socket_extra16
version: ">=3.9"
backend: python_module(socket)

docs: https://docs.python.org/3/library/socket.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/socket.html — Python socket module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/socket.py"
    - "CPython source: Modules/socketmodule.c"
  notes:
    - "This spec extends socket.zspec.zsdl and prior extras through socket_extra15.zspec.zsdl."
    - "socket.zspec.zsdl covers: AF_INET == 2; SOCK_STREAM == 1; SOCK_DGRAM == 2 as plain equality checks."
    - "socket_extra2 covers: AF_INET.__class__.__name__ == 'AddressFamily'; SOCK_STREAM.__class__.__name__ == 'SocketKind'; SOCK_DGRAM.__class__.__name__ == 'SocketKind'."
    - "socket_extra12 covers: AF_INET6.__class__.__name__ == 'AddressFamily'; SOCK_RAW.__class__.__name__ == 'SocketKind'."
    - "socket_extra13 covers: AF_UNIX.__class__.__name__ == 'AddressFamily'."
    - "socket.zspec.zsdl covers: gethostname/__name__; getdefaulttimeout/__name__."
    - "socket_extra.zspec.zsdl covers: setdefaulttimeout/__name__."
    - "socket_extra3 covers: getaddrinfo/__name__; gethostbyname/__name__; getnameinfo/__name__; getfqdn/__name__ via standalone invariants."
    - "socket_extra8 covers: gethostbyname/__qualname__; getaddrinfo/__qualname__; getnameinfo/__qualname__; getfqdn/__qualname__ via table."
    - "No prior spec covers: AF_INET.__int__() == 2 — calling __int__() on an AddressFamily enum member."
    - "No prior spec covers: SOCK_STREAM.__int__() == 1 — calling __int__() on a SocketKind enum member."
    - "No prior spec covers: SOCK_DGRAM.__int__() == 2 — calling __int__() on a SocketKind enum member."
    - "No prior spec covers: AF_UNIX.__int__() == 1 — calling __int__() on an AddressFamily enum member."
    - "No prior spec covers: SOCK_RAW.__int__() == 3 — calling __int__() on a SocketKind enum member."
    - "No prior spec covers: AF_INET6.__int__().__ge__(0) — platform-safe check (value is 30 on macOS, 10 on Linux)."
    - "No prior spec covers: AF_INET6.__class__.__name__.__len__() == 13 — length of 'AddressFamily'."
    - "No prior spec covers: SOCK_STREAM.__class__.__name__.__len__() == 10 — length of 'SocketKind'."
    - "No prior spec covers: AF_INET.__int__.__class__.__name__ == 'builtin_function_or_method' — type of the __int__ method on an enum member."
    - "AF_INET.__int__() returns 2 on all platforms — AF_INET is standardized as 2 by POSIX."
    - "AF_UNIX.__int__() returns 1 on all POSIX platforms — AF_UNIX is 1 universally."
    - "SOCK_STREAM == 1, SOCK_DGRAM == 2, SOCK_RAW == 3 are POSIX-standardized values."
    - "AF_INET6 value is platform-dependent (30 on macOS, 10 on Linux); use __ge__(0) for portability."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# AF_INET.__int__() and AF_UNIX.__int__() — AddressFamily numeric values
#
# socket.zspec.zsdl checks AF_INET == 2 via __eq__. No prior spec calls
# __int__() directly on AF_INET or AF_UNIX enum members. AF_INET.__int__()
# must return 2 (POSIX standard). AF_UNIX.__int__() must return 1 (POSIX
# standard). These verify that AddressFamily members respond to __int__().
# ---------------------------------------------------------------------------

invariant socket_extra16.AF_INET.int_value:
  description: "socket.AF_INET.__int__() == 2 — AF_INET enum member converts to int 2"
  category: constants
  kind: python_call_eq
  function: AF_INET.__int__
  args: []
  expected: 2

invariant socket_extra16.AF_UNIX.int_value:
  description: "socket.AF_UNIX.__int__() == 1 — AF_UNIX enum member converts to int 1 (POSIX)"
  category: constants
  kind: python_call_eq
  function: AF_UNIX.__int__
  args: []
  expected: 1

# ---------------------------------------------------------------------------
# AF_INET6.__int__().__ge__(0) — platform-portable AddressFamily value check
#
# AF_INET6 is 30 on macOS/Darwin and 10 on Linux; no single integer equality
# is portable across both platforms. Using __ge__(0) confirms the value is a
# non-negative integer on all POSIX platforms without being platform-specific.
# ---------------------------------------------------------------------------

invariant socket_extra16.AF_INET6.int_ge_zero:
  description: "socket.AF_INET6.__int__() >= 0 — platform-safe check (30 on macOS, 10 on Linux)"
  category: constants
  kind: python_call_eq
  function: AF_INET6.__int__
  args: []
  method: __ge__
  method_args: [0]
  expected: true

# ---------------------------------------------------------------------------
# SOCK_STREAM.__int__(), SOCK_DGRAM.__int__(), SOCK_RAW.__int__()
#
# socket.zspec.zsdl checks SOCK_STREAM == 1 via __eq__. No prior spec calls
# __int__() directly on SocketKind enum members. These verify that SocketKind
# members respond to __int__() and return POSIX-standardized values.
# ---------------------------------------------------------------------------

invariant socket_extra16.SOCK_STREAM.int_value:
  description: "socket.SOCK_STREAM.__int__() == 1 — SOCK_STREAM enum member converts to int 1"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.__int__
  args: []
  expected: 1

invariant socket_extra16.SOCK_DGRAM.int_value:
  description: "socket.SOCK_DGRAM.__int__() == 2 — SOCK_DGRAM enum member converts to int 2"
  category: constants
  kind: python_call_eq
  function: SOCK_DGRAM.__int__
  args: []
  expected: 2

invariant socket_extra16.SOCK_RAW.int_value:
  description: "socket.SOCK_RAW.__int__() == 3 — SOCK_RAW enum member converts to int 3"
  category: constants
  kind: python_call_eq
  function: SOCK_RAW.__int__
  args: []
  expected: 3

# ---------------------------------------------------------------------------
# AddressFamily and SocketKind class name string lengths
#
# No prior spec checks the length of the class name strings 'AddressFamily'
# (13 characters) or 'SocketKind' (10 characters). These verify the string
# attribute values without duplicating the __eq__ checks in socket_extra2/12.
# ---------------------------------------------------------------------------

invariant socket_extra16.AddressFamily.class_name_len:
  description: "socket.AF_INET.__class__.__name__.__len__() == 13 — len('AddressFamily') == 13"
  category: constants
  kind: python_call_eq
  function: AF_INET.__class__.__name__.__len__
  args: []
  expected: 13

invariant socket_extra16.SocketKind.class_name_len:
  description: "socket.SOCK_STREAM.__class__.__name__.__len__() == 10 — len('SocketKind') == 10"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.__len__
  args: []
  expected: 10

# ---------------------------------------------------------------------------
# AF_INET.__class__.__name__ starts with 'Address'
#
# Verifies the first 7 characters of 'AddressFamily' are 'Address'.
# No prior spec checks startswith on these class name strings.
# ---------------------------------------------------------------------------

invariant socket_extra16.AddressFamily.class_name_startswith:
  description: "socket.AF_INET.__class__.__name__.startswith('Address') == True"
  category: constants
  kind: python_call_eq
  function: AF_INET.__class__.__name__.startswith
  args: ["Address"]
  expected: true

invariant socket_extra16.SocketKind.class_name_startswith:
  description: "socket.SOCK_STREAM.__class__.__name__.startswith('Socket') == True"
  category: constants
  kind: python_call_eq
  function: SOCK_STREAM.__class__.__name__.startswith
  args: ["Socket"]
  expected: true

# ---------------------------------------------------------------------------
# AF_INET6.__class__.__name__.__eq__('AddressFamily') — class name equality
#
# socket_extra12 covers AF_INET6.__class__.__name__ via invariant.
# No prior spec checks it via a method_chain or any alternate route.
# This adds AF_INET6.__class__.__name__.__len__() == 13.
# ---------------------------------------------------------------------------

invariant socket_extra16.AF_INET6.class_name_len:
  description: "socket.AF_INET6.__class__.__name__.__len__() == 13 — len('AddressFamily') == 13"
  category: constants
  kind: python_call_eq
  function: AF_INET6.__class__.__name__.__len__
  args: []
  expected: 13

# ---------------------------------------------------------------------------
# SOCK_DGRAM.__class__.__name__.__len__() == 10
#
# socket_extra2 covers SOCK_DGRAM.__class__.__name__ == 'SocketKind'.
# No prior spec checks the length of the resulting string.
# ---------------------------------------------------------------------------

invariant socket_extra16.SOCK_DGRAM.class_name_len:
  description: "socket.SOCK_DGRAM.__class__.__name__.__len__() == 10 — len('SocketKind') == 10"
  category: constants
  kind: python_call_eq
  function: SOCK_DGRAM.__class__.__name__.__len__
  args: []
  expected: 10
