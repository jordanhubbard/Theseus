spec: re_extra2446
version: ">=3.9"
backend: python_module(re)
error_model: python_exceptions

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "Python re documentation — https://docs.python.org/3/library/re.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/re/__init__.py"
    - "CPython source: Modules/_sre.c"
    - "re_extra.zspec.zsdl"
    - "re_extra1771.zspec.zsdl"
  notes:
    - "Wave 2446, theme: __enter__/__exit__ context manager protocol dict-presence."
    - "re.Pattern is NOT a context manager — __enter__ and __exit__ are absent from re.Pattern.__dict__."
    - "re.Match is NOT a context manager — __enter__ and __exit__ are absent from re.Match.__dict__."
    - "re.error (aliased as re.PatternError in Python 3.13+) is NOT a context manager."
    - "re.RegexFlag is an IntFlag enum — NOT a context manager; __enter__/__exit__ absent from its __dict__."
    - "re.Pattern.__dict__ DOES contain: match, search, fullmatch, findall, finditer, sub, subn, split, flags, pattern, groups, groupindex, scanner."
    - "re.Match.__dict__ DOES contain: group, groups, groupdict, start, end, span, expand, string, pos, endpos."
    - "re.error.__dict__ DOES contain __init__ (custom constructor with msg, pattern, pos parameters)."
    - "re.RegexFlag.__dict__ DOES contain IGNORECASE, MULTILINE, DOTALL, VERBOSE, ASCII."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

# ---------------------------------------------------------------------------
# re.Pattern — context manager protocol NOT in own __dict__
# ---------------------------------------------------------------------------

table re_extra2446.pattern_cm_protocol:
  description: "re.Pattern.__dict__ does not define __enter__ or __exit__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2446

  columns: [id, function, args, expected]
  rows:
    - ["re2446001", "re.Pattern.__dict__.__contains__", ["__enter__"], false]
    - ["re2446002", "re.Pattern.__dict__.__contains__", ["__exit__"],  false]
    - ["re2446003", "re.Match.__dict__.__contains__",   ["__enter__"], false]
    - ["re2446004", "re.Match.__dict__.__contains__",   ["__exit__"],  false]
    - ["re2446005", "re.error.__dict__.__contains__",   ["__enter__"], false]
    - ["re2446006", "re.error.__dict__.__contains__",   ["__exit__"],  false]
    - ["re2446007", "re.RegexFlag.__dict__.__contains__",["__enter__"],false]
    - ["re2446008", "re.RegexFlag.__dict__.__contains__",["__exit__"], false]

# ---------------------------------------------------------------------------
# re.Pattern — methods that ARE in own __dict__
# ---------------------------------------------------------------------------

table re_extra2446.pattern_own_methods:
  description: "re.Pattern defines these matching methods in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2446

  columns: [id, function, args, expected]
  rows:
    - ["re2446009", "re.Pattern.__dict__.__contains__", ["match"],      true]
    - ["re2446010", "re.Pattern.__dict__.__contains__", ["search"],     true]
    - ["re2446011", "re.Pattern.__dict__.__contains__", ["fullmatch"],  true]
    - ["re2446012", "re.Pattern.__dict__.__contains__", ["findall"],    true]
    - ["re2446013", "re.Pattern.__dict__.__contains__", ["finditer"],   true]
    - ["re2446014", "re.Pattern.__dict__.__contains__", ["sub"],        true]
    - ["re2446015", "re.Pattern.__dict__.__contains__", ["subn"],       true]
    - ["re2446016", "re.Pattern.__dict__.__contains__", ["split"],      true]
    - ["re2446017", "re.Pattern.__dict__.__contains__", ["flags"],      true]
    - ["re2446018", "re.Pattern.__dict__.__contains__", ["pattern"],    true]

# ---------------------------------------------------------------------------
# re.Match — methods that ARE in own __dict__
# ---------------------------------------------------------------------------

table re_extra2446.match_own_methods:
  description: "re.Match defines these group and position methods in its own __dict__"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2446

  columns: [id, function, args, expected]
  rows:
    - ["re2446019", "re.Match.__dict__.__contains__", ["group"],     true]
    - ["re2446020", "re.Match.__dict__.__contains__", ["groups"],    true]
    - ["re2446021", "re.Match.__dict__.__contains__", ["groupdict"], true]
    - ["re2446022", "re.Match.__dict__.__contains__", ["start"],     true]
    - ["re2446023", "re.Match.__dict__.__contains__", ["end"],       true]
    - ["re2446024", "re.Match.__dict__.__contains__", ["span"],      true]
    - ["re2446025", "re.Match.__dict__.__contains__", ["string"],    true]

# ---------------------------------------------------------------------------
# re.error and re.RegexFlag — complementary dict membership
# ---------------------------------------------------------------------------

table re_extra2446.error_and_flags_own_members:
  description: "re.error and re.RegexFlag own __dict__ members"
  kind: python_call_eq
  category: dict_contains
  id_prefix: re2446

  columns: [id, function, args, expected]
  rows:
    - ["re2446026", "re.error.__dict__.__contains__",     ["__init__"],   true]
    - ["re2446027", "re.RegexFlag.__dict__.__contains__", ["IGNORECASE"], true]
    - ["re2446028", "re.RegexFlag.__dict__.__contains__", ["MULTILINE"],  true]
    - ["re2446029", "re.RegexFlag.__dict__.__contains__", ["DOTALL"],     true]
    - ["re2446030", "re.RegexFlag.__dict__.__contains__", ["VERBOSE"],    true]
