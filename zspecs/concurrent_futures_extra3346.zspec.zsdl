spec: cf3346
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 670 (cf3346): __neg__, __pos__, __abs__ dict-presence (unary -x, +x, abs(x)) for concurrent.futures types."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
    - "Classes covered: concurrent.futures.Future, concurrent.futures.ThreadPoolExecutor, concurrent.futures.ProcessPoolExecutor."
    - "Key finding (__neg__): all 3 concurrent.futures classes return false for __neg__. Unary negation (__neg__, -x) belongs to the numeric data model. concurrent.futures types are parallel execution handles and pool managers — not numeric types. concurrent.futures.Future is a result handle with a PENDING/RUNNING/CANCELLED/FINISHED state machine; -future is not a valid Python expression for a state-machine object. ThreadPoolExecutor and ProcessPoolExecutor manage worker pools via submit()/map()/shutdown(); negating an executor is not a defined Python operation."
    - "Key finding (__pos__): all 3 concurrent.futures classes return false for __pos__. Unary plus (__pos__, +x) is the mirror of __neg__ in the numeric data model. concurrent.futures types define no arithmetic protocol of any kind — confirmed false across waves 658–669 for all arithmetic and bitwise operators. +future is not a valid Python expression for a state-machine result handle. +executor is not defined for pool-manager objects."
    - "Key finding (__abs__): all 3 concurrent.futures classes return false for __abs__. The abs() built-in delegates to __abs__, which is part of the numeric data model. concurrent.futures types implement no numeric magnitude. abs(future), abs(executor) are not meaningful operations — a Future represents a pending asynchronous computation, not a numeric value; ThreadPoolExecutor/ProcessPoolExecutor are lifecycle managers for worker pools, not numeric objects."
    - "All 9 values in this wave are false. concurrent.futures is a high-level parallel execution API operating entirely through method calls — submit(), map(), result(), cancel(), add_done_callback(), shutdown() — with no arithmetic, bitwise, unary numeric, or operator overloading of any kind."
    - "Cross-wave summary for cf subjects:"
    - "  Wave 658 (cf3166): __add__/__sub__/__mul__ — all false for all 3."
    - "  Wave 659 (cf3181): __truediv__/__floordiv__/__mod__ — all false for all 3."
    - "  Wave 660 (cf3196): __pow__/__lshift__/__rshift__ — all false for all 3."
    - "  Wave 661 (cf3211): __and__/__or__/__xor__ — all false for all 3."
    - "  Wave 662 (cf3226): __radd__/__rsub__/__rmul__ — all false for all 3."
    - "  Wave 663 (cf3241): __rtruediv__/__rfloordiv__/__rmod__ — all false for all 3."
    - "  Wave 664 (cf3256): __rpow__/__rlshift__/__rrshift__ — all false for all 3."
    - "  Wave 665 (cf3271): __rand__/__ror__/__rxor__ — all false for all 3."
    - "  Wave 666 (cf3286): __iadd__/__isub__/__imul__ — all false for all 3."
    - "  Wave 667 (cf3301): __itruediv__/__ifloordiv__/__imod__ — all false for all 3."
    - "  Wave 668 (cf3316): __ipow__/__ilshift__/__irshift__ — all false for all 3."
    - "  Wave 669 (cf3331): __iand__/__ior__/__ixor__ — all false for all 3."
    - "  Wave 670 (cf3346): __neg__/__pos__/__abs__ — all false for all 3."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __neg__ dict-presence — operator.contains(Cls.__dict__, '__neg__')
#
# All 3 concurrent.futures classes return false for __neg__.
# Unary negation (__neg__, -x) belongs to the numeric data model.
# concurrent.futures.Future: a result handle with PENDING/RUNNING/CANCELLED/
#   FINISHED states; -future is not a valid Python expression for a state-
#   machine object. Future manages asynchronous results through callbacks and
#   state transitions, not numeric operators.
# ThreadPoolExecutor/ProcessPoolExecutor: worker-pool lifecycle managers;
#   negating a pool manager is not a defined Python operation. Pool size and
#   worker count are not exposed for unary arithmetic.
# ---------------------------------------------------------------------------

table cf3346.neg:
  description: "concurrent.futures types __neg__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3346

  columns: [id, function, args, expected]
  rows:
    - ["cf3346001", operator.contains, [concurrent.futures.Future.__dict__,              "__neg__"], false]
    - ["cf3346002", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__neg__"], false]
    - ["cf3346003", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__neg__"], false]

# ---------------------------------------------------------------------------
# __pos__ dict-presence — operator.contains(Cls.__dict__, '__pos__')
#
# All 3 concurrent.futures classes return false for __pos__.
# Unary plus (__pos__, +x) mirrors __neg__ and belongs to the same numeric
#   data model. concurrent.futures types define no arithmetic protocol —
#   confirmed false across waves 658–669 for all arithmetic and bitwise operators.
# concurrent.futures.Future: a state-machine result handle; +future is not a
#   valid Python expression. The future's value is retrieved via result() or
#   callbacks, not unary plus.
# ThreadPoolExecutor/ProcessPoolExecutor: pool lifecycle managers with an
#   entirely method-based API; +executor is not defined.
# ---------------------------------------------------------------------------

table cf3346.pos:
  description: "concurrent.futures types __pos__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3346

  columns: [id, function, args, expected]
  rows:
    - ["cf3346004", operator.contains, [concurrent.futures.Future.__dict__,              "__pos__"], false]
    - ["cf3346005", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__pos__"], false]
    - ["cf3346006", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__pos__"], false]

# ---------------------------------------------------------------------------
# __abs__ dict-presence — operator.contains(Cls.__dict__, '__abs__')
#
# All 3 concurrent.futures classes return false for __abs__.
# The abs() built-in delegates to __abs__, part of the numeric data model
#   (numbers.Number). concurrent.futures types implement no numeric magnitude.
# concurrent.futures.Future: a state-machine result handle, not a numeric type;
#   abs(future) is not a meaningful operation. Future state is one of PENDING/
#   RUNNING/CANCELLED/FINISHED — none of these are a scalar magnitude.
# ThreadPoolExecutor/ProcessPoolExecutor: executor types that encapsulate pools
#   of worker threads or processes; abs(executor) is not a defined Python
#   operation. Pool configuration is accessed through constructor arguments
#   and context manager protocol, not numeric data model methods.
# ---------------------------------------------------------------------------

table cf3346.abs_:
  description: "concurrent.futures types __abs__ dict-presence checks; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3346

  columns: [id, function, args, expected]
  rows:
    - ["cf3346007", operator.contains, [concurrent.futures.Future.__dict__,              "__abs__"], false]
    - ["cf3346008", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__abs__"], false]
    - ["cf3346009", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__abs__"], false]

# ---------------------------------------------------------------------------
# combined — __neg__, __pos__, __abs__ across all 3 cf subjects
#
# Covers the full matrix: 3 classes x 3 methods = 9 rows.
# __neg__: false for all 3 — unary negation is not defined.
# __pos__: false for all 3 — unary plus is not defined.
# __abs__: false for all 3 — abs() is not defined.
# All 9 values are false.
# concurrent.futures is a high-level parallel execution API. Its entire
#   public surface is method-based: submit(), map(), result(), cancel(),
#   done(), running(), cancelled(), add_done_callback(), shutdown().
#   Waves 658–669 established that no arithmetic, bitwise, reflected, or
#   in-place augmented assignment operator appears anywhere in the concurrent.
#   futures type hierarchy. The unary numeric operators tested here follow
#   the same pattern.
# concurrent.futures.Future note: despite the name, Future is a state-machine
#   result handle — not a numeric, set, or dict-like type. __neg__, __pos__,
#   and __abs__ are all absent from its __dict__.
# ThreadPoolExecutor/ProcessPoolExecutor note: executor types encapsulate
#   a pool of worker threads or processes; they expose only lifecycle and
#   dispatch methods. No numeric unary operator overloads are defined.
# ---------------------------------------------------------------------------

table cf3346.combined:
  description: "concurrent.futures types combined __neg__/__pos__/__abs__; wave 670"
  kind: python_call_eq
  version: ">=3.9"
  error_model: python_exceptions
  category: dict_contains
  id_prefix: cf3346

  columns: [id, function, args, expected]
  rows:
    - ["cf3346010", operator.contains, [concurrent.futures.Future.__dict__,              "__neg__"], false]
    - ["cf3346011", operator.contains, [concurrent.futures.Future.__dict__,              "__pos__"], false]
    - ["cf3346012", operator.contains, [concurrent.futures.Future.__dict__,              "__abs__"], false]
    - ["cf3346013", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__neg__"], false]
    - ["cf3346014", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__pos__"], false]
    - ["cf3346015", operator.contains, [concurrent.futures.ThreadPoolExecutor.__dict__,  "__abs__"], false]
    - ["cf3346016", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__neg__"], false]
    - ["cf3346017", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__pos__"], false]
    - ["cf3346018", operator.contains, [concurrent.futures.ProcessPoolExecutor.__dict__, "__abs__"], false]
