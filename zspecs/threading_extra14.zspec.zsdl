spec: threading_extra14
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec extends threading.zspec.zsdl and threading_extra through threading_extra13."
    - "threading_extra13 covers: __class__.__name__ == 'type' for Thread/Event/Semaphore/Condition/Lock; RLock.__class__.__name__ == 'function'; Thread/Semaphore __mro__[1].__name__ == 'object'."
    - "threading_extra12 covers: Barrier.reset/abort __qualname__; Barrier(2).parties/n_waiting/broken; Event.set/clear/wait __qualname__; Condition.notify_all __qualname__."
    - "threading_extra11 covers: Barrier.wait __qualname__; Thread.start/run/join/is_alive __qualname__; Semaphore.acquire/release __qualname__; Condition.wait/notify __qualname__; BoundedSemaphore MRO[1]/MRO[2]."
    - "threading_extra10 covers: Barrier/Condition/RLock/local __bases__[0].__name__; function __module__ attrs."
    - "threading_extra8 covers: class-level __qualname__ for Thread/RLock/Event/Condition/Semaphore/BoundedSemaphore/Timer/Barrier/local."
    - "NOT yet covered in any prior spec: Timer.__mro__[1].__name__ == 'Thread' — MRO access path (vs. __bases__ in extra4)."
    - "NOT yet covered: Timer.__mro__[2].__name__ == 'object'."
    - "NOT yet covered: Condition.__mro__[1].__name__ == 'object' — MRO access path."
    - "NOT yet covered: Barrier.__mro__[1].__name__ == 'object' — MRO access path."
    - "NOT yet covered: Timer.__class__.__name__ == 'type' — metaclass check for Timer."
    - "NOT yet covered: Barrier.__class__.__name__ == 'type' — metaclass check for Barrier."
    - "NOT yet covered: BrokenBarrierError.__class__.__name__ == 'type' — metaclass check."
    - "NOT yet covered: local.__class__.__name__ == 'type' — metaclass check for local."
    - "NOT yet covered: Timer.cancel.__name__ == 'cancel' — method __name__ for Timer.cancel."
    - "NOT yet covered: Timer.run.__name__ == 'run' — method __name__ for Timer.run."
    - "NOT yet covered: Timer.cancel.__qualname__ == 'Timer.cancel' — method qualname."
    - "NOT yet covered: Timer.run.__qualname__ == 'Timer.run' — method qualname."
    - "threading.Timer.__mro__[1].__name__ == 'Thread' — Timer extends Thread; MRO is [Timer, Thread, object]."
    - "threading.Timer.__mro__[2].__name__ == 'object' — third MRO entry."
    - "threading.Condition.__mro__[1].__name__ == 'object' — Condition inherits directly from object."
    - "threading.Barrier.__mro__[1].__name__ == 'object' — Barrier inherits directly from object."
    - "threading.Timer.__class__.__name__ == 'type' — Timer is a plain Python class."
    - "threading.Barrier.__class__.__name__ == 'type' — Barrier is a plain Python class."
    - "threading.BrokenBarrierError.__class__.__name__ == 'type' — plain Python exception class."
    - "threading.local.__class__.__name__ == 'type' — local is a C-level type object; its metaclass is 'type'."
    - "threading.Timer.cancel.__name__ == 'cancel'."
    - "threading.Timer.run.__name__ == 'run'."
    - "threading.Timer.cancel.__qualname__ == 'Timer.cancel'."
    - "threading.Timer.run.__qualname__ == 'Timer.run'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Timer MRO — index-based access
#
# threading_extra4 covers Timer.__bases__[0].__name__ == 'Thread'. No prior
# spec accesses Timer's MRO via __mro__[n]. Timer's MRO is [Timer, Thread,
# object], so __mro__[1] is Thread and __mro__[2] is object. This is a
# distinct access path from __bases__[0].
# ---------------------------------------------------------------------------

invariant threading_extra14.Timer.mro_index1:
  description: "threading.Timer.__mro__[1].__name__ == 'Thread' — Timer extends Thread"
  category: class_hierarchy
  kind: python_call_eq
  function: Timer.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "Thread"

invariant threading_extra14.Timer.mro_index2:
  description: "threading.Timer.__mro__[2].__name__ == 'object'"
  category: class_hierarchy
  kind: python_call_eq
  function: Timer.__mro__.__getitem__
  args: [2]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Condition and Barrier MRO — index-based access
#
# threading_extra10 covers Condition.__bases__[0].__name__ == 'object' and
# Barrier.__bases__[0].__name__ == 'object'. No prior spec uses the __mro__
# access path for these classes. Condition and Barrier both inherit directly
# from object, so their MRO is [ClassName, object].
# ---------------------------------------------------------------------------

invariant threading_extra14.Condition.mro_index1:
  description: "threading.Condition.__mro__[1].__name__ == 'object' — inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Condition.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

invariant threading_extra14.Barrier.mro_index1:
  description: "threading.Barrier.__mro__[1].__name__ == 'object' — inherits directly from object"
  category: class_hierarchy
  kind: python_call_eq
  function: Barrier.__mro__.__getitem__
  args: [1]
  method: __name__
  expected: "object"

# ---------------------------------------------------------------------------
# Class-level __class__.__name__ — metaclass checks for Timer, Barrier,
# BrokenBarrierError, and local
#
# threading_extra13 covers Thread/Event/Semaphore/Condition/Lock/RLock.
# No prior spec checks the metaclass (__class__.__name__) of Timer, Barrier,
# BrokenBarrierError, or local. All four are plain Python classes (or C-level
# types) whose __class__.__name__ is 'type'.
# ---------------------------------------------------------------------------

table threading_extra14.class_metaclass_names:
  description: "Timer/Barrier/BrokenBarrierError/local have __class__.__name__ == 'type'"
  kind: python_call_eq
  category: class_types
  id_prefix: cmeta

  columns: [id, function, args, expected]
  rows:
    - [Timer,             Timer.__class__.__name__.__eq__,             ["type"], true]
    - [Barrier,           Barrier.__class__.__name__.__eq__,           ["type"], true]
    - [BrokenBarrierError, BrokenBarrierError.__class__.__name__.__eq__, ["type"], true]
    - [local,             local.__class__.__name__.__eq__,             ["type"], true]

# ---------------------------------------------------------------------------
# Timer method __name__ and __qualname__
#
# threading_extra11/12 cover Thread/Barrier method __qualname__. No prior
# spec checks __name__ or __qualname__ for Timer.cancel or Timer.run.
# Timer.cancel is defined in Timer itself; Timer.run is also defined in
# Timer (overriding Thread.run to implement the delay-then-call behavior).
# ---------------------------------------------------------------------------

table threading_extra14.Timer_method_names:
  description: "threading.Timer methods have expected __name__ values"
  kind: python_call_eq
  category: method_names
  id_prefix: tmname

  columns: [id, function, args, expected]
  rows:
    - [cancel, Timer.cancel.__name__.__eq__, ["cancel"], true]
    - [run,    Timer.run.__name__.__eq__,    ["run"],    true]

table threading_extra14.Timer_method_qualnames:
  description: "threading.Timer methods have __qualname__ == 'Timer.<method>'"
  kind: python_call_eq
  category: method_qualnames
  id_prefix: tmqname

  columns: [id, function, args, expected]
  rows:
    - [cancel, Timer.cancel.__qualname__.__eq__, ["Timer.cancel"], true]
    - [run,    Timer.run.__qualname__.__eq__,    ["Timer.run"],    true]
