spec: hashlib_extra246
version: ">=3.9"
backend: python_module(hashlib)

docs: https://docs.python.org/3/library/hashlib.html
rfcs:
  - "FIPS 180-4 — Secure Hash Standard (SHS)"
  - "RFC 1321 — The MD5 Message-Digest Algorithm"

provenance:
  derived_from:
    - "FIPS 180-4 — Secure Hash Standard (SHS), NIST, August 2015"
    - "RFC 1321 — The MD5 Message-Digest Algorithm, April 1992"
    - "https://docs.python.org/3/library/hashlib.html — Python hashlib documentation"
    - "Test vectors verified by running Python 3.14.3 hashlib on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Modules/_hashopenssl.c"
    - "CPython source: Modules/_sha256module.c"
    - "CPython source: Modules/md5module.c"
  notes:
    - "This spec extends hashlib.zspec.zsdl, hashlib_extra.zspec.zsdl, and hashlib_extra2.zspec.zsdl; it does NOT duplicate invariants present in those files."
    - "hashlib.sha256().name == 'sha256' — the .name attribute returns a lower-case algorithm identifier string."
    - "hashlib.new('sha256').name == 'sha256' — new() returns the same object type as the direct constructor."
    - "hashlib.md5().name == 'md5', hashlib.sha1().name == 'sha1' — name attribute is algorithm-specific."
    - "hashlib.sha256().digest_size == hashlib.new('sha256').digest_size == 32 — both constructors produce objects with identical digest_size."
    - "hashlib.sha256().block_size == hashlib.new('sha256').block_size == 64."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model:
  semantics: "hashlib raises ValueError for unknown algorithm names passed to hashlib.new(). Hash constructor calls do not raise for valid algorithms."
  stderr: "null"
  stickiness: "N/A — hash objects are independent; module-level attributes are read-only."
  codes: {}

# ---------------------------------------------------------------------------
# .name attribute — direct constructors
# hashlib.zspec.zsdl already covers sha256.name via hash_object_attr kind;
# this spec covers it via python_call_eq for orthogonal coverage and adds
# new algorithms not yet covered.
# ---------------------------------------------------------------------------

table hashlib_extra246.name_attr.direct_constructors:
  kind: python_call_eq
  category: name_attribute
  id_prefix: hl246name
  rfc: "FIPS 180-4"

  columns: [id, function, args, expected]
  rows:
    - [sha256_name,  sha256.name.__eq__,  ["sha256"],  true]
    - [sha1_name,    sha1.name.__eq__,    ["sha1"],    true]
    - [md5_name,     md5.name.__eq__,     ["md5"],     true]
    - [sha512_name,  sha512.name.__eq__,  ["sha512"],  true]

# ---------------------------------------------------------------------------
# .name attribute — sha3 and blake2 variants
# ---------------------------------------------------------------------------

table hashlib_extra246.name_attr.sha3_blake2:
  kind: python_call_eq
  category: name_attribute
  id_prefix: hl246name

  columns: [id, function, args, expected]
  rows:
    - [sha3_256_name, sha3_256.name.__eq__, ["sha3_256"], true]
    - [sha3_512_name, sha3_512.name.__eq__, ["sha3_512"], true]
    - [blake2b_name,  blake2b.name.__eq__,  ["blake2b"],  true]
    - [blake2s_name,  blake2s.name.__eq__,  ["blake2s"],  true]

# ---------------------------------------------------------------------------
# .name attribute — hashlib.new() factory equivalence
# hashlib.new('sha256') must produce an object with .name == 'sha256',
# matching the direct constructor.
# ---------------------------------------------------------------------------

invariant hashlib_extra246.new_sha256.name_attr:
  description: "hashlib.new('sha256').name == 'sha256' — new() yields same name as direct constructor"
  category: name_attribute
  kind: python_call_eq
  function: new
  args: ["sha256", ""]
  method: name.__eq__
  method_args: ["sha256"]
  expected: true

invariant hashlib_extra246.new_md5.name_attr:
  description: "hashlib.new('md5').name == 'md5' — new() yields same name as direct constructor"
  category: name_attribute
  kind: python_call_eq
  function: new
  args: ["md5", ""]
  method: name.__eq__
  method_args: ["md5"]
  expected: true

invariant hashlib_extra246.new_sha1.name_attr:
  description: "hashlib.new('sha1').name == 'sha1' — new() yields same name as direct constructor"
  category: name_attribute
  kind: python_call_eq
  function: new
  args: ["sha1", ""]
  method: name.__eq__
  method_args: ["sha1"]
  expected: true

# ---------------------------------------------------------------------------
# digest_size equivalence — sha256() vs new('sha256')
# Both constructors produce objects with identical digest_size (32 bytes)
# ---------------------------------------------------------------------------

invariant hashlib_extra246.sha256.digest_size_direct:
  description: "hashlib.sha256().digest_size == 32 (256 bits = 32 bytes)"
  category: digest_size_equivalence
  kind: python_call_eq
  function: sha256
  args: []
  method: digest_size.__eq__
  method_args: [32]
  expected: true

invariant hashlib_extra246.new_sha256.digest_size:
  description: "hashlib.new('sha256').digest_size == 32 — new() produces same digest_size as direct constructor"
  category: digest_size_equivalence
  kind: python_call_eq
  function: new
  args: ["sha256", ""]
  method: digest_size.__eq__
  method_args: [32]
  expected: true

# ---------------------------------------------------------------------------
# block_size equivalence — sha256() vs new('sha256')
# ---------------------------------------------------------------------------

invariant hashlib_extra246.sha256.block_size_direct:
  description: "hashlib.sha256().block_size == 64 (512-bit block)"
  category: block_size_equivalence
  kind: python_call_eq
  function: sha256
  args: []
  method: block_size.__eq__
  method_args: [64]
  expected: true

invariant hashlib_extra246.new_sha256.block_size:
  description: "hashlib.new('sha256').block_size == 64 — new() produces same block_size as direct constructor"
  category: block_size_equivalence
  kind: python_call_eq
  function: new
  args: ["sha256", ""]
  method: block_size.__eq__
  method_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# md5 attribute contracts — digest_size and block_size
# ---------------------------------------------------------------------------

invariant hashlib_extra246.md5.digest_size:
  description: "hashlib.md5().digest_size == 16 (128 bits = 16 bytes)"
  category: md5_attributes
  kind: python_call_eq
  function: md5
  args: []
  method: digest_size.__eq__
  method_args: [16]
  expected: true

invariant hashlib_extra246.md5.block_size:
  description: "hashlib.md5().block_size == 64 (512-bit block, same as SHA-256)"
  category: md5_attributes
  kind: python_call_eq
  function: md5
  args: []
  method: block_size.__eq__
  method_args: [64]
  expected: true

# ---------------------------------------------------------------------------
# sha1 attribute contracts — digest_size
# ---------------------------------------------------------------------------

invariant hashlib_extra246.sha1.digest_size:
  description: "hashlib.sha1().digest_size == 20 (160 bits = 20 bytes)"
  category: sha1_attributes
  kind: python_call_eq
  function: sha1
  args: []
  method: digest_size.__eq__
  method_args: [20]
  expected: true
