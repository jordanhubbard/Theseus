    - [pl961n002, pathlib.PurePath.__module__.__eq__,      ["pathlib"],         true]
    - [pl961n003, pathlib.Path.__name__.__eq__,            ["Path"],            true]
    - [pl961n004, pathlib.Path.__module__.__eq__,          ["pathlib"],         true]
    - [pl961n005, pathlib.PurePosixPath.__name__.__eq__,   ["PurePosixPath"],   true]
    - [pl961n006, pathlib.PurePosixPath.__module__.__eq__, ["pathlib"],         true]
    - [pl961n007, pathlib.PureWindowsPath.__name__.__eq__, ["PureWindowsPath"], true]
    - [pl961n008, pathlib.PureWindowsPath.__module__.__eq__, ["pathlib"],       true]

table pathlib_extra961.module_identity:
