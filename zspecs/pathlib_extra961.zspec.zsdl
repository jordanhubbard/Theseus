error_model: python_exceptions

table pathlib_extra961.class_dict_identity:
  description: "pathlib path class __dict__ is a mappingproxy"
  kind: python_call_eq
  category: class_dict_identity
  id_prefix: pl961d
  columns: [id, function, args, expected]
  rows:
    - [pl961d001, pathlib.PurePath.__dict__.__class__.__name__.__eq__,        ["mappingproxy"], true]
    - [pl961d002, pathlib.Path.__dict__.__class__.__name__.__eq__,            ["mappingproxy"], true]
    - [pl961d003, pathlib.PurePosixPath.__dict__.__class__.__name__.__eq__,   ["mappingproxy"], true]
    - [pl961d004, pathlib.PureWindowsPath.__dict__.__class__.__name__.__eq__, ["mappingproxy"], true]
    - [pl961d005, pathlib.PurePath.__class__.__name__.__eq__,                 ["ABCMeta"],      true]
    - [pl961d006, pathlib.Path.__class__.__name__.__eq__,                     ["ABCMeta"],      true]

table pathlib_extra961.class_module_identity:
  description: "pathlib class __module__ and __name__ identity"
