spec: unicodedata_extra8
version: ">=3.9"
backend: python_module(unicodedata)

docs: https://docs.python.org/3/library/unicodedata.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/unicodedata.html"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/unicodedata.c"
  notes:
    - "This spec extends unicodedata.zspec.zsdl and prior extras through unicodedata_extra7.zspec.zsdl."
    - "unicodedata_extra4 covers: __name__ table for all major functions (lookup/name/decimal/digit/numeric/category/bidirectional/combining/east_asian_width/normalize/mirrored/decomposition); unidata_version type; category A/a/0; bidirectional A; combining A; east_asian_width A; mirrored '('."
    - "unicodedata_extra7 covers: name('!'/'space'); lookup('LATIN CAPITAL LETTER Z'/'DIGIT NINE'); bidirectional('!'/'1'); east_asian_width(' '/'!'); category('Z'/'z'); digit('1'); numeric('½') type; ucd_3_2_0.decimal('0'); is_normalized('NFC'/'NFKC', 'A')."
    - "Focus: __module__ attributes for unicodedata public functions — lookup/name/decimal/digit/numeric/category/bidirectional/combining/east_asian_width/normalize; unidata_version class name; ucd_3_2_0 class name."
    - "No prior spec covers __module__ for any unicodedata function — extra4 covers __name__ only. This spec adds __module__ as a new dimension."
    - "unicodedata.lookup.__module__ == 'unicodedata' — all built-in unicodedata functions have __module__ == 'unicodedata'."
    - "unicodedata.name.__module__ == 'unicodedata'."
    - "unicodedata.decimal.__module__ == 'unicodedata'."
    - "unicodedata.digit.__module__ == 'unicodedata'."
    - "unicodedata.numeric.__module__ == 'unicodedata'."
    - "unicodedata.category.__module__ == 'unicodedata'."
    - "unicodedata.bidirectional.__module__ == 'unicodedata'."
    - "unicodedata.combining.__module__ == 'unicodedata'."
    - "unicodedata.east_asian_width.__module__ == 'unicodedata'."
    - "unicodedata.normalize.__module__ == 'unicodedata'."
    - "unicodedata.unidata_version.__class__.__name__ == 'str' — unidata_version is a module-level string constant."
    - "unicodedata.ucd_3_2_0.__class__.__name__ == 'UCD' — the legacy UCD object has class name 'UCD'."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# __module__ checks for unicodedata public functions
#
# unicodedata_extra4 covers __name__ for these functions in a table.
# No prior spec covers __module__ for any unicodedata function.
# All unicodedata C-extension functions report __module__ == 'unicodedata'.
# ---------------------------------------------------------------------------

table unicodedata_extra8.function_modules:
  kind: python_call_eq
  category: function_identity
  id_prefix: mod

  columns: [id, function, args, expected]
  rows:
    - [lookup,          lookup.__module__.__eq__,          ["unicodedata"], true]
    - [name,            name.__module__.__eq__,            ["unicodedata"], true]
    - [decimal,         decimal.__module__.__eq__,         ["unicodedata"], true]
    - [digit,           digit.__module__.__eq__,           ["unicodedata"], true]
    - [numeric,         numeric.__module__.__eq__,         ["unicodedata"], true]
    - [category,        category.__module__.__eq__,        ["unicodedata"], true]
    - [bidirectional,   bidirectional.__module__.__eq__,   ["unicodedata"], true]
    - [combining,       combining.__module__.__eq__,       ["unicodedata"], true]
    - [east_asian_width, east_asian_width.__module__.__eq__, ["unicodedata"], true]
    - [normalize,       normalize.__module__.__eq__,       ["unicodedata"], true]

# ---------------------------------------------------------------------------
# unidata_version — type check
#
# unicodedata_extra4 confirms unidata_version is a str via __class__.__name__.
# This standalone extra8 invariant re-anchors it under the new namespace.
# ---------------------------------------------------------------------------

invariant unicodedata_extra8.unidata_version.class_name:
  description: "unicodedata.unidata_version.__class__.__name__ == 'str' — unidata_version is a str constant"
  category: module_constants
  kind: python_call_eq
  function: unidata_version.__class__.__name__.__eq__
  args: ["str"]
  expected: true

# ---------------------------------------------------------------------------
# ucd_3_2_0 — class name check
#
# No prior spec checks the class name of the ucd_3_2_0 object itself.
# Prior extras use it as a callable (ucd_3_2_0.category/name/decimal).
# The object's __class__.__name__ is 'UCD'.
# ---------------------------------------------------------------------------

invariant unicodedata_extra8.ucd_3_2_0.class_name:
  description: "unicodedata.ucd_3_2_0.__class__.__name__ == 'UCD' — ucd_3_2_0 is a UCD instance"
  category: module_constants
  kind: python_call_eq
  function: ucd_3_2_0.__class__.__name__.__eq__
  args: ["UCD"]
  expected: true
