spec: concurrent_futures_extra2821
version: ">=3.9"
backend: python_module(concurrent.futures)

docs: https://docs.python.org/3/library/concurrent.futures.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/concurrent.futures.html — concurrent.futures module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/concurrent/futures/_base.py"
    - "CPython source: Lib/concurrent/futures/thread.py"
    - "CPython source: Lib/concurrent/futures/process.py"
    - "concurrent_futures_extra.zspec.zsdl — covers class names, module checks, function names, constant type checks"
    - "concurrent_futures_extra2.zspec.zsdl — covers module checks, constant values, method names"
    - "concurrent_futures_extra2806.zspec.zsdl — covers __ilshift__, __irshift__, __ipow__ dict-presence checks"
  notes:
    - "Wave 635 theme: __radd__, __rsub__, and __rmul__ dict-presence checks (reflected arithmetic operators)."
    - "None of the concurrent.futures public classes define __radd__, __rsub__, or __rmul__ in their __dict__."
    - "Future is a pure-Python result container; ThreadPoolExecutor and ProcessPoolExecutor are executor pool classes."
    - "'__radd__' in Future.__dict__ == False; likewise for __rsub__ and __rmul__."
    - "All expected values verified by running Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# concurrent.futures.Future — __radd__/__rsub__/__rmul__
# dict-presence checks
#
# Future is a pure-Python result container (Lib/concurrent/futures/_base.py).
# It wraps the result of an async computation. It does not define reflected
# arithmetic operator dunders: __radd__, __rsub__, or __rmul__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2821.future_operator_dict:
  description: "concurrent.futures.Future __radd__, __rsub__, __rmul__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2821f

  columns: [id, function, args, expected]
  rows:
    - ["cf2821f_rad",  Future.__dict__.__contains__, ["__radd__"],  false]
    - ["cf2821f_rsb",  Future.__dict__.__contains__, ["__rsub__"],  false]
    - ["cf2821f_rml",  Future.__dict__.__contains__, ["__rmul__"],  false]

# ---------------------------------------------------------------------------
# concurrent.futures.ThreadPoolExecutor — __radd__/__rsub__/__rmul__
# dict-presence checks
#
# ThreadPoolExecutor manages a pool of threads and dispatches callables to them.
# It does not implement reflected arithmetic operator dunders.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2821.threadpoolexecutor_operator_dict:
  description: "concurrent.futures.ThreadPoolExecutor __radd__, __rsub__, __rmul__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2821tpe

  columns: [id, function, args, expected]
  rows:
    - ["cf2821tpe_rad",  ThreadPoolExecutor.__dict__.__contains__, ["__radd__"],  false]
    - ["cf2821tpe_rsb",  ThreadPoolExecutor.__dict__.__contains__, ["__rsub__"],  false]
    - ["cf2821tpe_rml",  ThreadPoolExecutor.__dict__.__contains__, ["__rmul__"],  false]

# ---------------------------------------------------------------------------
# concurrent.futures.ProcessPoolExecutor — __radd__/__rsub__/__rmul__
# dict-presence checks
#
# ProcessPoolExecutor manages a pool of worker processes. Like ThreadPoolExecutor,
# it is a task dispatching class and does not define reflected arithmetic operator dunders.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2821.processpoolexecutor_operator_dict:
  description: "concurrent.futures.ProcessPoolExecutor __radd__, __rsub__, __rmul__ dict-presence — all False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2821ppe

  columns: [id, function, args, expected]
  rows:
    - ["cf2821ppe_rad",  ProcessPoolExecutor.__dict__.__contains__, ["__radd__"],  false]
    - ["cf2821ppe_rsb",  ProcessPoolExecutor.__dict__.__contains__, ["__rsub__"],  false]
    - ["cf2821ppe_rml",  ProcessPoolExecutor.__dict__.__contains__, ["__rmul__"],  false]

# ---------------------------------------------------------------------------
# Full 3×3 cross-type matrix — all concurrent.futures types, all three reflected arithmetic operator dunders
#
# Consolidates the complete 3×3 dict-presence check in one table.
# Every cell is False: Future, ThreadPoolExecutor, and ProcessPoolExecutor
# do not define +, -, or * reflected operator dunders in their __dict__.
# ---------------------------------------------------------------------------

table concurrent_futures_extra2821.all_types_radd_rsub_rmul_matrix:
  description: "Full 3×3 dict-presence matrix for concurrent.futures types vs __radd__/__rsub__/__rmul__ — all 9 results are False; verified with Python 3.14.4"
  kind: python_call_eq
  category: behavior
  id_prefix: cf2821mx

  columns: [id, function, args, expected]
  rows:
    - ["cf2821mx_f_rad",   Future.__dict__.__contains__,              ["__radd__"],  false]
    - ["cf2821mx_f_rsb",   Future.__dict__.__contains__,              ["__rsub__"],  false]
    - ["cf2821mx_f_rml",   Future.__dict__.__contains__,              ["__rmul__"],  false]
    - ["cf2821mx_tpe_rad", ThreadPoolExecutor.__dict__.__contains__,  ["__radd__"],  false]
    - ["cf2821mx_tpe_rsb", ThreadPoolExecutor.__dict__.__contains__,  ["__rsub__"],  false]
    - ["cf2821mx_tpe_rml", ThreadPoolExecutor.__dict__.__contains__,  ["__rmul__"],  false]
    - ["cf2821mx_ppe_rad", ProcessPoolExecutor.__dict__.__contains__, ["__radd__"],  false]
    - ["cf2821mx_ppe_rsb", ProcessPoolExecutor.__dict__.__contains__, ["__rsub__"],  false]
    - ["cf2821mx_ppe_rml", ProcessPoolExecutor.__dict__.__contains__, ["__rmul__"],  false]
