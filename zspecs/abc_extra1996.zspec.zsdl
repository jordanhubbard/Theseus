spec: abc_extra1996
version: ">=3.9"
backend: python_module(abc)
docs: https://docs.python.org/3/library/abc.html
provenance:
  derived_from:
    - "Python docs"
    - "https://docs.python.org/3/library/abc.html"
  not_derived_from:
    - "CPython source: Lib/abc.py"
  notes:
    - "Wave 580 (_extra1996): __index__, __complex__, __float__, __round__, __abs__ dict-presence checks."
    - "All values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-12."
    - "abc.ABCMeta is a metaclass; abc.ABC is an abstract base class; abc.abstractmethod is a function decorator."
    - "None of these define __index__, __complex__, __float__, __round__, or __abs__ in their own __dict__."
    - "abc.abstractmethod.__dict__ is the instance dict of a plain function object, which contains no numeric dunders."
  created_at: "2026-04-12"
error_model: python_exceptions

table abc_extra1996.index_protocol:
  description: "abc types __index__ dict-presence checks — all False"
  kind: python_call_eq
  category: dict_contains
  id_prefix: ab1996

  columns: [id, function, args, expected]
  rows:
    - ["ab1996001", "abc.ABCMeta.__dict__.__contains__",      ["__index__"],   false]
    - ["ab1996002", "abc.ABC.__dict__.__contains__",           ["__index__"],   false]
    - ["ab1996003", "abc.abstractmethod.__dict__.__contains__", ["__index__"],  false]

