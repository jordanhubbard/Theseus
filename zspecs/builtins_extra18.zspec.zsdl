spec: builtins_extra18
version: ">=3.9"
backend: python_module(builtins)

docs: https://docs.python.org/3/library/exceptions.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/exceptions.html — Python exceptions documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Objects/exceptions.c"
  notes:
    - "This spec extends prior builtins specs."
    - "OSError.__bases__[0].__name__ == 'Exception' — base for OS-level I/O errors."
    - "IOError.__qualname__ == 'OSError' — IOError is an alias for OSError since Python 3.3."
    - "FileNotFoundError.__bases__[0].__name__ == 'OSError' — raised when a file is not found."
    - "PermissionError.__bases__[0].__name__ == 'OSError' — raised on permission denied."
    - "IsADirectoryError.__bases__[0].__name__ == 'OSError' — raised when a file op is attempted on a directory."
    - "FileExistsError.__bases__[0].__name__ == 'OSError' — raised when a file already exists."
    - "TimeoutError.__bases__[0].__name__ == 'OSError' — raised when a system operation times out."
    - "ConnectionError.__bases__[0].__name__ == 'OSError' — base for connection-related errors."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# OSError — base class
#
# OSError (also known as EnvironmentError, IOError, WindowsError) is the
# base class for exceptions raised by OS-level operations. It derives
# directly from Exception.
# ---------------------------------------------------------------------------

invariant builtins_extra18.OSError.base:
  description: "OSError.__bases__[0].__name__ == 'Exception'"
  category: exception_hierarchy
  kind: python_call_eq
  function: OSError.__bases__.__getitem__(0).__name__.__eq__
  args: ["Exception"]
  expected: true

# ---------------------------------------------------------------------------
# IOError alias
#
# Since Python 3.3, IOError is an alias for OSError. Its __qualname__
# resolves to 'OSError', not 'IOError'.
# ---------------------------------------------------------------------------

invariant builtins_extra18.IOError.qualname:
  description: "IOError.__qualname__ == 'OSError' — IOError is an alias for OSError since Python 3.3"
  category: exception_classes
  kind: python_call_eq
  function: IOError.__qualname__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# OSError subclasses — base class verification
#
# FileNotFoundError, PermissionError, IsADirectoryError, FileExistsError,
# TimeoutError, and ConnectionError all derive directly from OSError.
# ---------------------------------------------------------------------------

invariant builtins_extra18.FileNotFoundError.base:
  description: "FileNotFoundError.__bases__[0].__name__ == 'OSError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: FileNotFoundError.__bases__.__getitem__(0).__name__.__eq__
  args: ["OSError"]
  expected: true

invariant builtins_extra18.PermissionError.base:
  description: "PermissionError.__bases__[0].__name__ == 'OSError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: PermissionError.__bases__.__getitem__(0).__name__.__eq__
  args: ["OSError"]
  expected: true

invariant builtins_extra18.IsADirectoryError.base:
  description: "IsADirectoryError.__bases__[0].__name__ == 'OSError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: IsADirectoryError.__bases__.__getitem__(0).__name__.__eq__
  args: ["OSError"]
  expected: true

invariant builtins_extra18.FileExistsError.base:
  description: "FileExistsError.__bases__[0].__name__ == 'OSError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: FileExistsError.__bases__.__getitem__(0).__name__.__eq__
  args: ["OSError"]
  expected: true

invariant builtins_extra18.TimeoutError.base:
  description: "TimeoutError.__bases__[0].__name__ == 'OSError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: TimeoutError.__bases__.__getitem__(0).__name__.__eq__
  args: ["OSError"]
  expected: true

invariant builtins_extra18.ConnectionError.base:
  description: "ConnectionError.__bases__[0].__name__ == 'OSError'"
  category: exception_hierarchy
  kind: python_call_eq
  function: ConnectionError.__bases__.__getitem__(0).__name__.__eq__
  args: ["OSError"]
  expected: true

# ---------------------------------------------------------------------------
# __qualname__ table for OSError/FileNotFoundError/PermissionError/
# IsADirectoryError/FileExistsError/TimeoutError
#
# All are simple non-nested exception classes so __qualname__ equals __name__.
# ---------------------------------------------------------------------------

table builtins_extra18.os_exception_qualnames:
  description: "__qualname__ attributes for OSError/FileNotFoundError/PermissionError/IsADirectoryError/FileExistsError/TimeoutError"
  kind: python_call_eq
  category: exception_classes

  columns: [id, function, args, expected]
  rows:
    - [OSError,             OSError.__qualname__.__eq__,             ["OSError"],             true]
    - [FileNotFoundError,   FileNotFoundError.__qualname__.__eq__,   ["FileNotFoundError"],   true]
    - [PermissionError,     PermissionError.__qualname__.__eq__,     ["PermissionError"],     true]
    - [IsADirectoryError,   IsADirectoryError.__qualname__.__eq__,   ["IsADirectoryError"],   true]
    - [FileExistsError,     FileExistsError.__qualname__.__eq__,     ["FileExistsError"],     true]
    - [TimeoutError,        TimeoutError.__qualname__.__eq__,        ["TimeoutError"],        true]
