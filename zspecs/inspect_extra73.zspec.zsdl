spec: inspect_extra73
version: ">=3.9"
backend: python_module(inspect)

docs: https://docs.python.org/3/library/inspect.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/inspect.html — Python inspect module documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Lib/inspect.py"
  notes:
    - "This spec extends inspect_extra72.zspec.zsdl."
    - "Wave 239 theme: inspect Signature, Parameter, and BoundArguments class identity."
    - "Signature.__name__ == 'Signature' — Signature is a pure-Python class in Lib/inspect.py. Verified with Python 3.14.3."
    - "Signature.__module__ == 'inspect' — Signature is defined in the inspect module. Verified with Python 3.14.3."
    - "Signature.__qualname__ == 'Signature' — Signature is a top-level class (not nested). Verified with Python 3.14.3."
    - "Signature.__bases__[0].__name__ == 'object' — Signature inherits directly from object. Verified with Python 3.14.3."
    - "Signature.__mro__.__len__() == 2 — Signature MRO is [Signature, object] with 2 entries. Verified with Python 3.14.3."
    - "Parameter.__qualname__ == 'Parameter' — Parameter is a top-level class (not nested). Verified with Python 3.14.3."
    - "Parameter.__bases__[0].__name__ == 'object' — Parameter inherits directly from object. Verified with Python 3.14.3."
    - "Parameter.__mro__.__len__() == 2 — Parameter MRO is [Parameter, object] with 2 entries. Verified with Python 3.14.3."
    - "BoundArguments.__name__ == 'BoundArguments' — BoundArguments is a pure-Python class in Lib/inspect.py. Verified with Python 3.14.3."
    - "BoundArguments.__module__ == 'inspect' — BoundArguments is defined in the inspect module. Verified with Python 3.14.3."
    - "BoundArguments.__mro__.__len__() == 2 — BoundArguments MRO is [BoundArguments, object] with 2 entries. Verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Signature class identity — extra73
#
# Wave 239 theme: Signature class identity attributes.
#
# inspect.Signature is a pure-Python class defined in Lib/inspect.py.
# It represents the call signature of a callable.
#
# Signature.__name__     == 'Signature'
# Signature.__module__   == 'inspect'
# Signature.__qualname__ == 'Signature'
#
# No prior inspect spec checks Signature identity via inspmore73. New to extra73.
# ---------------------------------------------------------------------------

table inspect_extra73.Signature_identity:
  description: "Signature.__name__=='Signature', __module__=='inspect', __qualname__=='Signature'; wave 239 Signature class identity; new to extra73"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore73

  columns: [id, function, args, expected, description]
  rows:
    - [Signature_name_eq_Signature,
       Signature.__name__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__name__.__eq__('Signature') == True — Signature is a pure-Python class in Lib/inspect.py that represents the call signature of a callable object; __name__ stores the class name as a str 'Signature' (9 chars); str.__eq__('Signature') returns True; no prior inspect spec checks Signature.__name__ via inspmore73; new to extra73"]
    - [Signature_module_eq_inspect,
       Signature.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.Signature.__module__.__eq__('inspect') == True — Signature is defined in Lib/inspect.py and its __module__ attribute records the module name as the str 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks Signature.__module__ via inspmore73; new to extra73"]
    - [Signature_qualname_eq_Signature,
       Signature.__qualname__.__eq__,
       ["Signature"],
       true,
       "inspect.Signature.__qualname__.__eq__('Signature') == True — Signature is a top-level class in Lib/inspect.py (not nested inside another class or function); __qualname__ for a top-level class equals its simple name 'Signature' (9 chars); str.__eq__('Signature') returns True; no prior inspect spec checks Signature.__qualname__ via inspmore73; new to extra73"]

# ---------------------------------------------------------------------------
# Signature MRO and base class — extra73
#
# Wave 239 theme: Signature MRO length and base class.
#
# Signature.__bases__[0].__name__ == 'object'
# Signature.__mro__.__len__()     == 2
#
# No prior inspect spec checks Signature MRO via inspmore73. New to extra73.
# ---------------------------------------------------------------------------

table inspect_extra73.Signature_mro:
  description: "Signature.__bases__[0].__name__=='object', Signature.__mro__.__len__()==2; wave 239 Signature MRO; new to extra73"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore73

  columns: [id, function, args, expected, description]
  rows:
    - [Signature_bases0_name_eq_object,
       "Signature.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Signature.__bases__[0].__name__.__eq__('object') == True — Signature is defined as 'class Signature:' which in Python 3 implicitly inherits from object; __bases__ is a tuple of direct base classes and __bases__[0] is object; object.__name__ == 'object' (6 chars); str.__eq__('object') returns True; no prior inspect spec checks Signature.__bases__[0].__name__ via inspmore73; new to extra73"]
    - [Signature_mro_len_eq_2,
       Signature.__mro__.__len__,
       [],
       2,
       "inspect.Signature.__mro__.__len__() == 2 — Signature inherits directly from object with no intermediate base classes; the MRO is therefore [Signature, object] with exactly 2 entries; tuple.__len__() returns 2; no prior inspect spec checks Signature.__mro__.__len__ via inspmore73; new to extra73"]

# ---------------------------------------------------------------------------
# Parameter qualname, base, and MRO — extra73
#
# Wave 239 theme: Parameter __qualname__, base class, and MRO length.
#
# inspect.Parameter is a pure-Python class defined in Lib/inspect.py.
# Parameter.__name__ and __module__ were already covered in extra72.
#
# Parameter.__qualname__          == 'Parameter'
# Parameter.__bases__[0].__name__ == 'object'
# Parameter.__mro__.__len__()     == 2
#
# No prior inspect spec checks Parameter.__qualname__ or MRO via inspmore73. New to extra73.
# ---------------------------------------------------------------------------

table inspect_extra73.Parameter_qualname_mro:
  description: "Parameter.__qualname__=='Parameter', __bases__[0].__name__=='object', __mro__.__len__()==2; wave 239 Parameter MRO; new to extra73"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore73

  columns: [id, function, args, expected, description]
  rows:
    - [Parameter_qualname_eq_Parameter,
       Parameter.__qualname__.__eq__,
       ["Parameter"],
       true,
       "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter is a top-level class in Lib/inspect.py (not nested); __qualname__ for a top-level class equals its simple name 'Parameter' (9 chars); str.__eq__('Parameter') returns True; no prior inspect spec checks Parameter.__qualname__ via inspmore73; new to extra73"]
    - [Parameter_bases0_name_eq_object,
       "Parameter.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.Parameter.__bases__[0].__name__.__eq__('object') == True — Parameter is defined as 'class Parameter:' which in Python 3 implicitly inherits from object; __bases__[0] is object; object.__name__ == 'object' (6 chars); str.__eq__('object') returns True; no prior inspect spec checks Parameter.__bases__[0].__name__ via inspmore73; new to extra73"]
    - [Parameter_mro_len_eq_2,
       Parameter.__mro__.__len__,
       [],
       2,
       "inspect.Parameter.__mro__.__len__() == 2 — Parameter inherits directly from object with no intermediate base classes; the MRO is therefore [Parameter, object] with exactly 2 entries; tuple.__len__() returns 2; no prior inspect spec checks Parameter.__mro__.__len__ via inspmore73; new to extra73"]

# ---------------------------------------------------------------------------
# BoundArguments class identity and MRO — extra73
#
# Wave 239 theme: BoundArguments class identity and MRO.
#
# inspect.BoundArguments is a pure-Python class in Lib/inspect.py.
# It holds the result of binding arguments to a Signature.
#
# BoundArguments.__name__              == 'BoundArguments'
# BoundArguments.__module__            == 'inspect'
# BoundArguments.__qualname__          == 'BoundArguments'
# BoundArguments.__bases__[0].__name__ == 'object'
# BoundArguments.__mro__.__len__()     == 2
#
# No prior inspect spec checks BoundArguments identity via inspmore73. New to extra73.
# ---------------------------------------------------------------------------

table inspect_extra73.BoundArguments_identity:
  description: "BoundArguments.__name__=='BoundArguments', __module__=='inspect', __mro__.__len__()==2; wave 239 BoundArguments class identity; new to extra73"
  kind: python_call_eq
  category: type_identity
  id_prefix: inspmore73

  columns: [id, function, args, expected, description]
  rows:
    - [BoundArguments_name_eq_BoundArguments,
       BoundArguments.__name__.__eq__,
       ["BoundArguments"],
       true,
       "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments is a pure-Python class in Lib/inspect.py that holds the result of binding positional and keyword arguments to a Signature; __name__ stores the class name as a str 'BoundArguments' (14 chars); str.__eq__('BoundArguments') returns True; no prior inspect spec checks BoundArguments.__name__ via inspmore73; new to extra73"]
    - [BoundArguments_module_eq_inspect,
       BoundArguments.__module__.__eq__,
       ["inspect"],
       true,
       "inspect.BoundArguments.__module__.__eq__('inspect') == True — BoundArguments is defined in Lib/inspect.py and its __module__ attribute records the module name as the str 'inspect' (7 chars); str.__eq__('inspect') returns True; no prior inspect spec checks BoundArguments.__module__ via inspmore73; new to extra73"]
    - [BoundArguments_bases0_name_eq_object,
       "BoundArguments.__bases__[0].__name__.__eq__",
       ["object"],
       true,
       "inspect.BoundArguments.__bases__[0].__name__.__eq__('object') == True — BoundArguments is defined as 'class BoundArguments:' which in Python 3 implicitly inherits from object; __bases__[0] is object; object.__name__ == 'object' (6 chars); str.__eq__('object') returns True; no prior inspect spec checks BoundArguments.__bases__[0].__name__ via inspmore73; new to extra73"]
    - [BoundArguments_mro_len_eq_2,
       BoundArguments.__mro__.__len__,
       [],
       2,
       "inspect.BoundArguments.__mro__.__len__() == 2 — BoundArguments inherits directly from object with no intermediate base classes; the MRO is therefore [BoundArguments, object] with exactly 2 entries; tuple.__len__() returns 2; no prior inspect spec checks BoundArguments.__mro__.__len__ via inspmore73; new to extra73"]

# ---------------------------------------------------------------------------
# Standalone invariants — extra73
# ---------------------------------------------------------------------------

invariant inspect_extra73.Signature_name:
  description: "inspect.Signature.__name__.__eq__('Signature') == True — Signature class name is 'Signature'; wave 239 Signature class identity; new to extra73"
  kind: python_call_eq
  function: Signature.__name__.__eq__
  args: ["Signature"]
  expected: true

invariant inspect_extra73.Signature_mro_len:
  description: "inspect.Signature.__mro__.__len__() == 2 — Signature MRO is [Signature, object] with 2 entries; wave 239 Signature MRO; new to extra73"
  kind: python_call_eq
  function: Signature.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra73.Parameter_qualname:
  description: "inspect.Parameter.__qualname__.__eq__('Parameter') == True — Parameter.__qualname__ is 'Parameter'; wave 239 Parameter class identity; new to extra73"
  kind: python_call_eq
  function: Parameter.__qualname__.__eq__
  args: ["Parameter"]
  expected: true

invariant inspect_extra73.Parameter_mro_len:
  description: "inspect.Parameter.__mro__.__len__() == 2 — Parameter MRO is [Parameter, object] with 2 entries; wave 239 Parameter MRO; new to extra73"
  kind: python_call_eq
  function: Parameter.__mro__.__len__
  args: []
  expected: 2

invariant inspect_extra73.BoundArguments_name:
  description: "inspect.BoundArguments.__name__.__eq__('BoundArguments') == True — BoundArguments class name is 'BoundArguments'; wave 239 BoundArguments class identity; new to extra73"
  kind: python_call_eq
  function: BoundArguments.__name__.__eq__
  args: ["BoundArguments"]
  expected: true
