spec: time_extra21
version: ">=3.9"
backend: python_module(time)

docs: https://docs.python.org/3/library/time.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/time.html — Python time module documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10"
  not_derived_from:
    - "CPython source: Modules/timemodule.c"
    - "time_extra20.zspec.zsdl — covers __qualname__.__len__() for mktime(6)/strftime(8)/strptime(8)/asctime(7)/ctime(5)/monotonic_ns(12)/perf_counter_ns(15)/time_ns(7)/clock_getres(12)/clock_gettime(13)/clock_gettime_ns(16)/clock_settime(13)/clock_settime_ns(16)/tzset(5); timezone/altzone/daylight __class__.__name__.__len__()==3; time.__name__.__len__()==4."
    - "time_extra19.zspec.zsdl — covers tzname len (2) and class name len (5); struct_time __mro__/__bases__[0]/__name__/__dict__ lengths; n_sequence_fields (9), n_unnamed_fields (0), n_fields (11); process_time_ns (15), thread_time (11), thread_time_ns (14), get_clock_info (14) qualname lengths."
    - "time_extra18.zspec.zsdl — covers __qualname__.__len__() for time(4)/sleep(5)/monotonic(9)/perf_counter(12)/process_time(12)/gmtime(6)/localtime(9); __name__/__module__.__len__() for gmtime through perf_counter_ns."
  notes:
    - "This spec extends time_extra20.zspec.zsdl."
    - "Prior specs covered: time/sleep/monotonic/perf_counter/process_time/gmtime/localtime/mktime/strftime/strptime/ctime/struct_time __name__/__module__/__qualname__ and lengths; timezone/altzone/daylight class names; all clock_* and _ns function qualname lengths; struct_time n_sequence/unnamed/fields constants; tzname class name."
    - "This spec covers NEW angles: struct_time.__name__.__len__()==11; struct_time.__qualname__.__len__()==11; struct_time.__mro__.__len__()==3 (struct_time→tuple→object); struct_time.__bases__[0].__name__.__len__()==5 ('tuple'); time.time.__name__.__len__()==4; time.gmtime.__name__.__len__()==6; time.localtime.__name__.__len__()==9; time.strftime.__name__.__len__()==8; time.mktime.__name__.__len__()==6; time.monotonic.__name__.__len__()==9."
    - "struct_time inherits from tuple (not object directly) — MRO depth is 3, and base class name is 'tuple' (len 5). This distinguishes struct_time from simple object subclasses."
    - "struct_time.__name__ == 'struct_time' (len 11); __qualname__ also 'struct_time' (len 11) — the longest class name in the time module."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-10."
  created_at: "2026-04-10T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# struct_time class identity: __name__, __qualname__, __mro__, __bases__
#
# struct_time.__name__ == 'struct_time' (len 11). struct_time.__qualname__
# == 'struct_time' (len 11) — agrees with __name__. struct_time.__mro__ has
# 3 entries: [struct_time, tuple, object]. struct_time.__bases__[0].__name__
# == 'tuple' (len 5). struct_time is a named-tuple-like C type that inherits
# from tuple, giving it depth 3 in the MRO — unlike Template/Formatter which
# inherit directly from object (depth 2).
# ---------------------------------------------------------------------------

table time_extra21.struct_time_class_identity:
  description: "time.struct_time class identity: __name__.__len__()==11, __qualname__.__len__()==11, __mro__.__len__()==3, __bases__[0].__name__.__len__()==5"
  kind: python_call_eq
  category: class_identity
  id_prefix: st_id

  columns: [id, function, args, expected, description]
  rows:
    - [name_len,
       struct_time.__name__.__len__,
       [],
       11,
       "len(time.struct_time.__name__) == 11 — 'struct_time'"]
    - [qualname_len,
       struct_time.__qualname__.__len__,
       [],
       11,
       "len(time.struct_time.__qualname__) == 11 — 'struct_time'; equals __name__"]
    - [mro_len,
       struct_time.__mro__.__len__,
       [],
       3,
       "len(time.struct_time.__mro__) == 3 — [struct_time, tuple, object]"]
    - [bases_name_len,
       "struct_time.__bases__[0].__name__.__len__",
       [],
       5,
       "time.struct_time.__bases__[0].__name__ == 'tuple' (len 5) — inherits from tuple, not object"]

# ---------------------------------------------------------------------------
# time module function __name__.__len__() — core functions
#
# The __name__ attribute for C-implemented builtins in the time module equals
# the function's public name. These six functions cover the primary time API:
#   time     -> 'time'      (4)
#   gmtime   -> 'gmtime'    (6)
#   localtime -> 'localtime' (9)
#   strftime -> 'strftime'  (8)
#   mktime   -> 'mktime'    (6)
#   monotonic -> 'monotonic' (9)
# Prior specs covered __qualname__.__len__() for these functions but __name__
# has not been recorded in a single grouped table.
# ---------------------------------------------------------------------------

table time_extra21.core_function_name_lens:
  description: "time module core function __name__.__len__() — time(4), gmtime(6), localtime(9), strftime(8), mktime(6), monotonic(9)"
  kind: python_call_eq
  category: function_identity
  id_prefix: tm_name_len

  columns: [id, function, args, expected, description]
  rows:
    - [time_fn,
       time.__name__.__len__,
       [],
       4,
       "len(time.time.__name__) == 4 — 'time'"]
    - [gmtime,
       gmtime.__name__.__len__,
       [],
       6,
       "len(time.gmtime.__name__) == 6 — 'gmtime'"]
    - [localtime,
       localtime.__name__.__len__,
       [],
       9,
       "len(time.localtime.__name__) == 9 — 'localtime'"]
    - [strftime,
       strftime.__name__.__len__,
       [],
       8,
       "len(time.strftime.__name__) == 8 — 'strftime'"]
    - [mktime,
       mktime.__name__.__len__,
       [],
       6,
       "len(time.mktime.__name__) == 6 — 'mktime'"]
    - [monotonic,
       monotonic.__name__.__len__,
       [],
       9,
       "len(time.monotonic.__name__) == 9 — 'monotonic'"]

# ---------------------------------------------------------------------------
# time.struct_time.__mro__.__len__() == 3 — standalone invariant
#
# struct_time inherits from tuple rather than directly from object, making its
# MRO depth 3: [struct_time, tuple, object]. This contrasts with simple
# single-inheritance classes (depth 2) and marks struct_time as a sequence
# subtype. No prior time spec records this as a standalone invariant.
# ---------------------------------------------------------------------------

invariant time_extra21.struct_time.mro.len:
  description: "time.struct_time.__mro__.__len__() == 3 — MRO is [struct_time, tuple, object]; tuple-based inheritance gives depth 3"
  category: class_identity
  kind: python_call_eq
  function: struct_time.__mro__.__len__
  args: []
  expected: 3
