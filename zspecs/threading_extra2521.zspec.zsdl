spec: threading_extra2521
version: ">=3.9"
backend: python_module(threading)

docs: https://docs.python.org/3/library/threading.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/threading.html — Python threading module documentation"
    - "Test vectors verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Lib/threading.py"
    - "CPython source: Modules/_threadmodule.c"
  notes:
    - "This spec covers: __bool__, __index__, and __int__ dict-presence checks for threading module classes."
    - "Theme: truthiness, integer coercion, and indexing protocol dict-presence — checking whether classes define __bool__, __index__, or __int__ in their class __dict__."
    - "threading.Thread, Lock, Condition, Semaphore, BoundedSemaphore, Event, Barrier, Timer, local — none define __bool__, __index__, or __int__."
    - "threading.Thread is a pure-Python class representing an OS-level thread of execution; its state is managed via name, daemon, ident, and start/join/run methods — it carries no truthiness override or numeric protocol. Verified with Python 3.14."
    - "threading.Lock is the C-level _thread.lock type; it exposes acquire/release and a context-manager protocol only. No __bool__, __index__, or __int__ in its class __dict__. Verified with Python 3.14."
    - "threading.Semaphore maintains an internal integer counter accessed via acquire() and release(); despite the counter it carries no __int__, __index__, or __bool__ in its class __dict__ — callers manage the counter through the method API, not via coercion. Verified with Python 3.14."
    - "threading.BoundedSemaphore is a Semaphore subclass that raises ValueError if the count exceeds the initial value; like Semaphore it defines no numeric or truthiness protocol in its own __dict__. Verified with Python 3.14."
    - "threading.Event is a simple flag-based synchronization primitive wrapping an internal Condition; its truth value is accessed through is_set(), not via __bool__. Verified with Python 3.14."
    - "threading.Barrier synchronizes a fixed number of threads at a rendezvous point; it tracks an internal count but exposes no __int__, __index__, or __bool__. Verified with Python 3.14."
    - "threading.Condition wraps a lock and provides wait/notify; it has no numeric semantics. Verified with Python 3.14."
    - "threading.Timer is a Thread subclass that fires a function after a delay; it inherits no numeric protocol from Thread and adds none of its own. Verified with Python 3.14."
    - "threading.local provides per-thread attribute namespaces via attribute access; it defines no numeric coercion or truthiness protocol. Verified with Python 3.14."
    - "All expected values verified with Python 3.14 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# Table 1: threading.Thread and threading.Timer — truthiness/int/index absence
#
# Theme: __bool__, __index__, __int__ absent from Thread and Timer.__dict__.
# Thread manages OS threads; Timer is a Thread subclass for delayed execution.
# Neither is a numeric type and neither defines a truthiness or coercion protocol.
# ---------------------------------------------------------------------------

table threading_extra2521.thread_timer_bool_index_int:
  description: "__bool__, __index__, __int__ absent from threading.Thread and threading.Timer __dict__; wave 2521"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: th2521

  columns: [id, function, args, expected]
  rows:
    - ["th2521-001", "Thread.__dict__.__contains__", ["__bool__"], false]
    - ["th2521-002", "Thread.__dict__.__contains__", ["__index__"], false]
    - ["th2521-003", "Thread.__dict__.__contains__", ["__int__"], false]
    - ["th2521-004", "Timer.__dict__.__contains__", ["__bool__"], false]
    - ["th2521-005", "Timer.__dict__.__contains__", ["__index__"], false]
    - ["th2521-006", "Timer.__dict__.__contains__", ["__int__"], false]

# ---------------------------------------------------------------------------
# Table 2: threading.Lock and threading.Condition — truthiness/int/index absence
#
# Theme: __bool__, __index__, __int__ absent from Lock and Condition.__dict__.
# Lock is the C-level _thread.lock primitive; Condition wraps a lock with
# wait/notify semantics. Both are purely synchronization primitives with
# no numeric role or truthiness override.
# ---------------------------------------------------------------------------

table threading_extra2521.lock_condition_bool_index_int:
  description: "__bool__, __index__, __int__ absent from threading.Lock and Condition __dict__; wave 2521"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: th2521

  columns: [id, function, args, expected]
  rows:
    - ["th2521-007", "Lock.__dict__.__contains__", ["__bool__"], false]
    - ["th2521-008", "Lock.__dict__.__contains__", ["__index__"], false]
    - ["th2521-009", "Lock.__dict__.__contains__", ["__int__"], false]
    - ["th2521-010", "Condition.__dict__.__contains__", ["__bool__"], false]
    - ["th2521-011", "Condition.__dict__.__contains__", ["__index__"], false]
    - ["th2521-012", "Condition.__dict__.__contains__", ["__int__"], false]

# ---------------------------------------------------------------------------
# Table 3: threading.Semaphore and threading.BoundedSemaphore
#
# Theme: __bool__, __index__, __int__ absent from Semaphore and
# BoundedSemaphore.__dict__.
# Semaphore maintains an internal integer count but the count is managed
# exclusively through acquire() and release(); the class itself defines no
# __int__, __index__, or __bool__ protocol. BoundedSemaphore adds an upper
# bound check but equally defines no numeric coercion in its own __dict__.
# ---------------------------------------------------------------------------

table threading_extra2521.semaphore_bool_index_int:
  description: "__bool__, __index__, __int__ absent from threading.Semaphore and BoundedSemaphore __dict__; wave 2521"
  kind: python_call_eq
  category: boolean_identity
  id_prefix: th2521

  columns: [id, function, args, expected]
  rows:
    - ["th2521-013", "Semaphore.__dict__.__contains__", ["__bool__"], false]
    - ["th2521-014", "Semaphore.__dict__.__contains__", ["__index__"], false]
    - ["th2521-015", "Semaphore.__dict__.__contains__", ["__int__"], false]
    - ["th2521-016", "BoundedSemaphore.__dict__.__contains__", ["__bool__"], false]
    - ["th2521-017", "BoundedSemaphore.__dict__.__contains__", ["__index__"], false]
    - ["th2521-018", "BoundedSemaphore.__dict__.__contains__", ["__int__"], false]

# ---------------------------------------------------------------------------
# Table 4: threading.Event, threading.Barrier, threading.local
#
# Theme: __bool__, __index__, __int__ absent from Event, Barrier, local.__dict__.
# Event wraps an internal Condition to implement a simple flag; Barrier
# synchronizes a fixed count of threads; local provides per-thread attribute
# namespaces. All three are structural/organizational primitives with no
# numeric coercion or truthiness override.
# ---------------------------------------------------------------------------

