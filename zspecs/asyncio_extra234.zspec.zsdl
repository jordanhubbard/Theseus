spec: asyncio_extra234
version: ">=3.9"
backend: python_module(asyncio)

docs: https://docs.python.org/3/library/asyncio-stream.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/asyncio-stream.html — asyncio Streams documentation"
    - "Test vectors verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/asyncio/streams.py"
  notes:
    - "asyncio.StreamReader.__name__ == 'StreamReader' — 12 characters; module is 'asyncio.streams'; verified with Python 3.14.3."
    - "asyncio.StreamWriter.__name__ == 'StreamWriter' — 12 characters; module is 'asyncio.streams'; verified with Python 3.14.3."
    - "asyncio.StreamReader.__bases__[0].__name__ == 'object' — StreamReader directly inherits from object; verified with Python 3.14.3."
    - "asyncio.StreamWriter.__bases__[0].__name__ == 'object' — StreamWriter directly inherits from object; verified with Python 3.14.3."
    - "asyncio.StreamReader.read.__name__ == 'read' — 4 characters; qualname is 'StreamReader.read'; verified with Python 3.14.3."
    - "asyncio.StreamReader.readline.__name__ == 'readline' — 8 characters; qualname is 'StreamReader.readline'; verified with Python 3.14.3."
    - "asyncio.StreamWriter.write.__name__ == 'write' — 5 characters; qualname is 'StreamWriter.write'; verified with Python 3.14.3."
    - "asyncio.StreamWriter.drain.__name__ == 'drain' — 5 characters; qualname is 'StreamWriter.drain'; verified with Python 3.14.3."
    - "asyncio.StreamWriter.close.__name__ == 'close' — 5 characters; qualname is 'StreamWriter.close'; verified with Python 3.14.3."
    - "All expected values verified with Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# asyncio.StreamReader class identity contracts — extra234 namespace
#
# StreamReader.__name__ == 'StreamReader' (12 chars).
# StreamReader.__module__ == 'asyncio.streams'.
# StreamReader.__bases__[0].__name__ == 'object'.
# StreamReader.read.__name__ == 'read' (4 chars), qualname 'StreamReader.read'.
# StreamReader.readline.__name__ == 'readline' (8 chars), qualname 'StreamReader.readline'.
# ---------------------------------------------------------------------------

table asyncio_extra234.stream_reader_identity:
  description: "asyncio.StreamReader class identity and method name contracts in aio234sri namespace"
  kind: python_call_eq
  category: identity
  id_prefix: aio234sri

  columns: [id, function, args, expected, description]
  rows:
    - [sr_name_eq,           StreamReader.__name__.__eq__,               ["StreamReader"],       true, "asyncio.StreamReader.__name__ == 'StreamReader'; verified with Python 3.14.3"]
    - [sr_name_len_12,       StreamReader.__name__.__len__,              [],                     12,   "asyncio.StreamReader.__name__.__len__() == 12 — 'StreamReader' has 12 characters; verified with Python 3.14.3"]
    - [sr_module_eq,         StreamReader.__module__.__eq__,             ["asyncio.streams"],    true, "asyncio.StreamReader.__module__ == 'asyncio.streams'; verified with Python 3.14.3"]
    - [sr_read_name_eq,      StreamReader.read.__name__.__eq__,          ["read"],               true, "asyncio.StreamReader.read.__name__ == 'read'; verified with Python 3.14.3"]
    - [sr_read_name_len_4,   StreamReader.read.__name__.__len__,         [],                     4,    "asyncio.StreamReader.read.__name__.__len__() == 4 — 'read' has 4 characters; verified with Python 3.14.3"]
    - [sr_read_qualname_eq,  StreamReader.read.__qualname__.__eq__,      ["StreamReader.read"],  true, "asyncio.StreamReader.read.__qualname__ == 'StreamReader.read'; verified with Python 3.14.3"]
    - [sr_readline_name_eq,  StreamReader.readline.__name__.__eq__,      ["readline"],           true, "asyncio.StreamReader.readline.__name__ == 'readline'; verified with Python 3.14.3"]
    - [sr_readline_len_8,    StreamReader.readline.__name__.__len__,     [],                     8,    "asyncio.StreamReader.readline.__name__.__len__() == 8 — 'readline' has 8 characters; verified with Python 3.14.3"]
    - [sr_readline_qname_eq, StreamReader.readline.__qualname__.__eq__,  ["StreamReader.readline"], true, "asyncio.StreamReader.readline.__qualname__ == 'StreamReader.readline'; verified with Python 3.14.3"]

