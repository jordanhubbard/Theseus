spec: hl3121
version: ">=3.9"
backend: python_module(hashlib)
docs: https://docs.python.org/3/library/hashlib.html
provenance:
  derived_from:
    - "https://docs.python.org/3/library/hashlib.html — hashlib module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source code"
    - "any proprietary source"
  notes:
    - "Wave 655 (hl3121): __ge__, __repr__, __str__ dict-presence checks for hashlib types."
    - "type(hashlib.md5()), type(hashlib.sha256()), type(hashlib.sha512()) all resolve to the same C-level _hashlib.HASH type."
    - "type(hashlib.blake2b(b'')) is _blake2.blake2b — distinct from HASH."
    - "type(hashlib.blake2s(b'')) is _blake2.blake2s — distinct from HASH and blake2b."
    - "None of the hashlib types define __ge__ or __str__ in their own __dict__."
    - "HASH defines __repr__; blake2b and blake2s do not define __repr__ in their __dict__."
    - "All values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"
error_model: python_exceptions

table hl3121.ge:
  description: "hashlib types __ge__ dict-presence checks; wave 655"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl3121
  columns: [id, function, args, expected]
  rows:
    - ["hl3121001", operator.contains, [type(hashlib.md5()).__dict__,        "__ge__"], false]
    - ["hl3121002", operator.contains, [type(hashlib.sha256()).__dict__,     "__ge__"], false]
    - ["hl3121003", operator.contains, [type(hashlib.sha512()).__dict__,     "__ge__"], false]
    - ["hl3121004", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__ge__"], false]
    - ["hl3121005", operator.contains, [type(hashlib.blake2s(b'')).__dict__, "__ge__"], false]

table hl3121.repr:
  description: "hashlib types __repr__ dict-presence checks; wave 655"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl3121
  columns: [id, function, args, expected]
  rows:
    - ["hl3121006", operator.contains, [type(hashlib.md5()).__dict__,        "__repr__"], true]
    - ["hl3121007", operator.contains, [type(hashlib.sha256()).__dict__,     "__repr__"], true]
    - ["hl3121008", operator.contains, [type(hashlib.sha512()).__dict__,     "__repr__"], true]
    - ["hl3121009", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__repr__"], false]
    - ["hl3121010", operator.contains, [type(hashlib.blake2s(b'')).__dict__, "__repr__"], false]

table hl3121.str:
  description: "hashlib types __str__ dict-presence checks; wave 655"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl3121
  columns: [id, function, args, expected]
  rows:
    - ["hl3121011", operator.contains, [type(hashlib.md5()).__dict__,        "__str__"], false]
    - ["hl3121012", operator.contains, [type(hashlib.sha256()).__dict__,     "__str__"], false]
    - ["hl3121013", operator.contains, [type(hashlib.sha512()).__dict__,     "__str__"], false]
    - ["hl3121014", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__str__"], false]
    - ["hl3121015", operator.contains, [type(hashlib.blake2s(b'')).__dict__, "__str__"], false]

table hl3121.combined:
  description: "hashlib types __ge__/__repr__/__str__ combined dict-presence checks; wave 655"
  kind: python_call_eq
  category: dict_contains
  id_prefix: hl3121
  columns: [id, function, args, expected]
  rows:
    - ["hl3121016", operator.contains, [type(hashlib.md5()).__dict__,        "__ge__"],   false]
    - ["hl3121017", operator.contains, [type(hashlib.md5()).__dict__,        "__repr__"], true]
    - ["hl3121018", operator.contains, [type(hashlib.md5()).__dict__,        "__str__"],  false]
    - ["hl3121019", operator.contains, [type(hashlib.sha256()).__dict__,     "__ge__"],   false]
    - ["hl3121020", operator.contains, [type(hashlib.sha256()).__dict__,     "__repr__"], true]
    - ["hl3121021", operator.contains, [type(hashlib.sha256()).__dict__,     "__str__"],  false]
    - ["hl3121022", operator.contains, [type(hashlib.sha512()).__dict__,     "__ge__"],   false]
    - ["hl3121023", operator.contains, [type(hashlib.sha512()).__dict__,     "__repr__"], true]
    - ["hl3121024", operator.contains, [type(hashlib.sha512()).__dict__,     "__str__"],  false]
    - ["hl3121025", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__ge__"],   false]
    - ["hl3121026", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__repr__"], false]
    - ["hl3121027", operator.contains, [type(hashlib.blake2b(b'')).__dict__, "__str__"],  false]
    - ["hl3121028", operator.contains, [type(hashlib.blake2s(b'')).__dict__, "__ge__"],   false]
    - ["hl3121029", operator.contains, [type(hashlib.blake2s(b'')).__dict__, "__repr__"], false]
    - ["hl3121030", operator.contains, [type(hashlib.blake2s(b'')).__dict__, "__str__"],  false]
