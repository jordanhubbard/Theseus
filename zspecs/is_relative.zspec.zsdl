spec: is_relative
version: ">=1.0.0"
backend: node(is-relative)

docs: https://www.npmjs.com/package/is-relative

provenance:
  derived_from:
    - "is-relative README — https://www.npmjs.com/package/is-relative"
    - "Test vectors verified with is-relative via Node.js 22.22.2 on Ubuntu 26.04 / Docker, 2026-04-24"
  not_derived_from:
    - "is-relative source"
  notes:
    - "is-relative is an npm package. Install: npm install is-relative"
    - "Returns true if the path is relative (does not start with '/')."
  created_at: "2026-04-24T00:00:00Z"

error_model:
  semantics: "Returns a boolean."
  stderr: "null"
  stickiness: "N/A — stateless."
  codes: {}

table is_relative.check:
  kind: node_module_call_eq
  function: ~
  category: path
  id_prefix: isrel

  columns: [id, args, expected]
  rows:
    - [relative,  ["./foo"],  true]
    - [absolute,  ["/foo"],   false]
    - [bare,      ["foo"],    true]
