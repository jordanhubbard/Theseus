spec: uuid_extra196
version: ">=3.9"
backend: python_module(uuid)

docs: https://docs.python.org/3/library/uuid.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/uuid.html — Python uuid module documentation"
    - "Test vectors verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11"
  not_derived_from:
    - "CPython source: Lib/uuid.py"
    - "uuid_extra195.zspec.zsdl — covers uuid module __dict__.__contains__ for UUID, uuid1–uuid5, SafeUUID, NAMESPACE_* constants; uuid.UUID.__mro__.__len__()==2 and __mro__[0].__name__=='UUID'."
  notes:
    - "uuid.UUID.__mro__ is a tuple of length 2: (UUID, object). UUID inherits only from object. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.__mro__[0].__name__ == 'UUID' — the first MRO entry is UUID itself. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.__mro__[1].__name__ == 'object' — the second MRO entry is object. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.SafeUUID.__mro__ is a tuple of length 3: (SafeUUID, Enum, object). SafeUUID inherits from Enum. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.SafeUUID.__mro__[0].__name__ == 'SafeUUID' — the first MRO entry is SafeUUID itself. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.SafeUUID.__mro__[1].__name__ == 'Enum' — SafeUUID's immediate base is the Enum class. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.__dict__.__contains__('int') == True — 'int' is a descriptor in UUID.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.__dict__.__contains__('hex') == True — 'hex' is a descriptor in UUID.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "uuid.UUID.__dict__.__contains__('version') == True — 'version' is a descriptor in UUID.__dict__. Verified Python 3.14.3 macOS/Darwin 25.4.0, 2026-04-11."
    - "All expected values verified by running Python 3.14.3 on macOS/Darwin 25.4.0, 2026-04-11."
  created_at: "2026-04-11T00:00:00Z"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# uuid.UUID.__mro__ — tuple type, length, and entry names
# ---------------------------------------------------------------------------

table uuid_extra196.UUID_mro_type_and_length:
  description: "uuid.UUID.__mro__ is a tuple of length 2; __mro__[0].__name__=='UUID' and __mro__[1].__name__=='object'"
  kind: python_call_eq
  category: class_mro
  id_prefix: uuidmro196

  columns: [id, function, args, expected, description]
  rows:
    - [mro_type,       UUID.__mro__.__class__.__name__.__eq__,    ["tuple"], true,   "uuid.UUID.__mro__.__class__.__name__ == 'tuple' — __mro__ is always a tuple"]
    - [mro_len,        UUID.__mro__.__len__,                      [],        2,      "uuid.UUID.__mro__.__len__() == 2 — UUID inherits only from object (UUID, object)"]
    - ["mro0_name",    "UUID.__mro__[0].__name__.__eq__",         ["UUID"],  true,   "uuid.UUID.__mro__[0].__name__ == 'UUID' — first MRO entry is UUID itself"]
    - ["mro1_name",    "UUID.__mro__[1].__name__.__eq__",         ["object"], true,  "uuid.UUID.__mro__[1].__name__ == 'object' — second MRO entry is object"]

# ---------------------------------------------------------------------------
# uuid.SafeUUID.__mro__ — length and entry names
# ---------------------------------------------------------------------------

table uuid_extra196.SafeUUID_mro_length_and_names:
  description: "uuid.SafeUUID.__mro__.__len__()==3; __mro__[0].__name__=='SafeUUID'; __mro__[1].__name__=='Enum'"
  kind: python_call_eq
  category: class_mro
  id_prefix: uuidmro196

  columns: [id, function, args, expected, description]
  rows:
    - [safeuuid_mro_len,    SafeUUID.__mro__.__len__,                      [], 3,            "uuid.SafeUUID.__mro__.__len__() == 3 — SafeUUID MRO is (SafeUUID, Enum, object)"]
    - ["safeuuid_mro0",     "SafeUUID.__mro__[0].__name__.__eq__",         ["SafeUUID"], true, "uuid.SafeUUID.__mro__[0].__name__ == 'SafeUUID' — first MRO entry is SafeUUID itself"]
    - ["safeuuid_mro1",     "SafeUUID.__mro__[1].__name__.__eq__",         ["Enum"], true,    "uuid.SafeUUID.__mro__[1].__name__ == 'Enum' — SafeUUID's immediate base class is Enum"]
    - ["safeuuid_mro2",     "SafeUUID.__mro__[2].__name__.__eq__",         ["object"], true,  "uuid.SafeUUID.__mro__[2].__name__ == 'object' — third MRO entry is object"]

# ---------------------------------------------------------------------------
# uuid.UUID.__dict__ membership — int, hex, version descriptors
# ---------------------------------------------------------------------------

table uuid_extra196.UUID_dict_descriptor_membership:
  description: "uuid.UUID.__dict__.__contains__ checks for int, hex, version — the three core UUID value descriptors present in UUID.__dict__"
  kind: python_call_eq
  category: class_dict
  id_prefix: uuidmro196

  columns: [id, function, args, expected, description]
  rows:
    - [dict_has_int,     UUID.__dict__.__contains__, ["int"],     true, "uuid.UUID.__dict__.__contains__('int') — int descriptor is in UUID.__dict__"]
    - [dict_has_hex,     UUID.__dict__.__contains__, ["hex"],     true, "uuid.UUID.__dict__.__contains__('hex') — hex descriptor is in UUID.__dict__"]
    - [dict_has_version, UUID.__dict__.__contains__, ["version"], true, "uuid.UUID.__dict__.__contains__('version') — version descriptor is in UUID.__dict__"]
    - [mro_len_2,        UUID.__mro__.__len__,        [],         2,    "uuid.UUID.__mro__.__len__() == 2 re-anchored in dict table"]

# ---------------------------------------------------------------------------
# Standalone invariants (8 total)
# ---------------------------------------------------------------------------

invariant uuid_extra196.UUID_mro_type_is_tuple:
  description: "uuid.UUID.__mro__.__class__.__name__ == 'tuple' — the MRO is always a tuple"
  category: class_mro
  kind: python_call_eq
  function: UUID.__mro__.__class__.__name__.__eq__
  args: ["tuple"]
  expected: true

invariant uuid_extra196.UUID_mro_len:
  description: "uuid.UUID.__mro__.__len__() == 2 — UUID inherits only from object; its MRO is (UUID, object)"
  category: class_mro
  kind: python_call_eq
  function: UUID.__mro__.__len__
  args: []
  expected: 2

invariant uuid_extra196.UUID_mro0_name:
  description: "uuid.UUID.__mro__[0].__name__ == 'UUID' — first entry in UUID's MRO is UUID itself"
  category: class_mro
  kind: python_call_eq
  function: "UUID.__mro__[0].__name__.__eq__"
  args: ["UUID"]
  expected: true

invariant uuid_extra196.UUID_mro1_name:
  description: "uuid.UUID.__mro__[1].__name__ == 'object' — second entry in UUID's MRO is object"
  category: class_mro
  kind: python_call_eq
  function: "UUID.__mro__[1].__name__.__eq__"
  args: ["object"]
  expected: true

invariant uuid_extra196.SafeUUID_mro_len:
  description: "uuid.SafeUUID.__mro__.__len__() == 3 — SafeUUID MRO is (SafeUUID, Enum, object)"
  category: class_mro
  kind: python_call_eq
  function: SafeUUID.__mro__.__len__
  args: []
  expected: 3

invariant uuid_extra196.SafeUUID_mro1_name:
  description: "uuid.SafeUUID.__mro__[1].__name__ == 'Enum' — SafeUUID inherits from Enum"
  category: class_mro
  kind: python_call_eq
  function: "SafeUUID.__mro__[1].__name__.__eq__"
  args: ["Enum"]
  expected: true

invariant uuid_extra196.UUID_dict_has_int:
  description: "uuid.UUID.__dict__.__contains__('int') == True — 'int' is a property descriptor in UUID.__dict__"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["int"]
  expected: true

invariant uuid_extra196.UUID_dict_has_hex:
  description: "uuid.UUID.__dict__.__contains__('hex') == True — 'hex' is a property descriptor in UUID.__dict__"
  category: class_dict
  kind: python_call_eq
  function: UUID.__dict__.__contains__
  args: ["hex"]
  expected: true

