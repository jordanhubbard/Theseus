spec: theseus_calendar_cr2
version: ">=3.9"
backend: python_cleanroom(theseus_calendar_cr2)
blocks: calendar

docs: https://docs.python.org/3/library/calendar.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/calendar.html"
    - "Proleptic Gregorian calendar rules"
  notes:
    - "Clean-room extended calendar utilities. Do NOT import calendar."
    - "monthrange(year, month): return (weekday of first day, number of days in month)."
    - "isleap(year): return True if year is a leap year."
    - "month_name: sequence of month names; month_name[1] == 'January'."
    - "calendar2_monthrange(): monthrange(2024, 2) == (3, 29) — 2024 is leap year, Feb starts Monday(3)."
    - "calendar2_isleap(): isleap(2024) == True."
    - "calendar2_month_name(): month_name[1] == 'January'."
    - "Zero-arg invariant signatures — def calendar2_monthrange(): return hardcoded_result"
    - "Leap year: divisible by 4, except century years not divisible by 400."
    - "monthrange: compute weekday of 1st via Zeller's formula or equivalent."
    - "2024-02-01 is a Thursday — weekday 3 (Monday=0). February 2024 has 29 days."
    - "month_name[0] is '' (empty), month_name[1..12] are full English month names."
    - "Export: monthrange(year, month), isleap(year), month_name, month_abbr, weekday(y,m,d)."
  created_at: "2026-04-20T00:00:00Z"

error_model: python_exceptions

invariant theseus_calendar_cr2.monthrange:
  description: "monthrange(2024, 2) == (3, 29)"
  category: monthrange
  kind: python_call_eq
  function: calendar2_monthrange
  args: []
  expected: [3, 29]

invariant theseus_calendar_cr2.isleap:
  description: "isleap(2024) == True"
  category: isleap
  kind: python_call_eq
  function: calendar2_isleap
  args: []
  expected: true

invariant theseus_calendar_cr2.month_name:
  description: "month_name[1] == 'January'"
  category: month_name
  kind: python_call_eq
  function: calendar2_month_name
  args: []
  expected: "January"
