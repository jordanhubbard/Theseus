spec: struct_extra5
version: ">=3.9"
backend: python_module(struct)

docs: https://docs.python.org/3/library/struct.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/struct.html — Python struct documentation"
    - "Test vectors verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09"
  not_derived_from:
    - "CPython source: Modules/_struct.c"
    - "CPython source: Lib/struct.py"
  notes:
    - "This spec extends struct.zspec.zsdl and prior extras."
    - "struct_extra4 covers: Struct.__name__, pack_into.__name__, __qualname__ for pack/unpack/pack_into/unpack_from/iter_unpack/calcsize, error.__qualname__, pack(>I,65536)/pack(<I,65536)/pack(>i,-256), calcsize(>i/<i/>I)."
    - "struct_extra3 covers: pack/unpack/calcsize for network-order float/double/bool; calcsize for !5s/!3p/!x/!5x."
    - "struct_extra2 covers: pack/__name__, unpack/__name__, calcsize/__name__, all function __module__, Struct/__module__, pack(>H,256)==b'\\x01\\x00', unpack(>H,b'\\x01\\x00')==(256,), calcsize(>HHH)==6."
    - "struct_extra covers: Struct format/size attrs, calcsize extras, pack_into method name, unpack_from with offset, iter_unpack, error name/bases."
    - "Focus: Struct.__qualname__ (extra4 covers __name__ only); Struct instance .format and .size attribute values; pack(>B,255) and unpack(>B,b\\xff) for uint8; calcsize for '>B'/'<B'/'<i' formats not yet covered."
    - "struct.Struct.__qualname__ == 'Struct' — top-level C type has flat qualname."
    - "struct.Struct('>I').format == '>I' — the format string is preserved on the Struct object."
    - "struct.Struct('>I').size == 4 — 32-bit unsigned int is 4 bytes."
    - "struct.Struct('>H').format == '>H' — big-endian unsigned short."
    - "struct.Struct('>H').size == 2 — 16-bit unsigned short is 2 bytes."
    - "struct.pack('>B', 255) == b'\\xff' — unsigned byte; not in any prior spec."
    - "struct.unpack('>B', b'\\xff') == (255,) — decoded as list [255] after tuple normalisation."
    - "struct.calcsize('>B') == 1 — unsigned byte is 1 byte."
    - "struct.calcsize('<B') == 1 — byte size is byte-order independent."
    - "struct.Struct('>I').pack(256) == b'\\x00\\x00\\x01\\x00' — table form of method call."
    - "All expected values verified with Python 3.12 on macOS/Darwin 25.4.0, 2026-04-09."
  created_at: "2026-04-09T00:00:00Z"

error_model:
  semantics: "struct.error is raised for mismatched buffer sizes and invalid format strings. It is a subclass of Exception."
  stderr: "null"
  stickiness: "N/A — struct functions are pure; Struct objects are immutable after construction."
  codes: {}

# ---------------------------------------------------------------------------
# struct.Struct.__qualname__
#
# struct_extra4 records Struct.__name__ == 'Struct'. The __qualname__ attribute
# is a distinct check (same value for top-level classes, but a different
# attribute slot) not yet recorded in any prior struct spec.
# ---------------------------------------------------------------------------

invariant struct_extra5.Struct.qualname:
  description: "struct.Struct.__qualname__ == 'Struct' — top-level C type has flat qualname"
  category: class_identity
  kind: python_call_eq
  function: Struct.__qualname__.__eq__
  args: ["Struct"]
  expected: true

# ---------------------------------------------------------------------------
# Struct instance attributes — format and size
#
# struct_extra covers Struct format/size for a different fixture (via struct_extra
# notes mention format/size attrs). struct_extra2 covers __module__ on the class
# object. This table adds concrete format/size values for '>I' and '>H' instances
# that are not in any prior spec.
# ---------------------------------------------------------------------------

table struct_extra5.struct_instance_attrs:
  kind: python_call_eq
  category: struct_attrs
  id_prefix: attr

  columns: [id, function, args, expected, method]
  rows:
    - [Struct_I_format, Struct, [">I"], ">I", format]
    - [Struct_I_size,   Struct, [">I"], 4,    size]
    - [Struct_H_format, Struct, [">H"], ">H", format]
    - [Struct_H_size,   Struct, [">H"], 2,    size]

# ---------------------------------------------------------------------------
# pack() — unsigned byte ('>B', 255)
#
# struct.zspec.zsdl uses '>B' only for zero (b'\x00'); struct_extra3 uses bool
# format '?'. No prior spec packs the maximum uint8 value 255.
# ---------------------------------------------------------------------------

invariant struct_extra5.pack.uint8_max:
  description: "struct.pack('>B', 255) == b'\\xff' — maximum unsigned byte value"
  category: pack_values
  kind: python_call_eq
  function: pack
  args: [">B", 255]
  expected: !hex ff

# ---------------------------------------------------------------------------
# unpack() — unsigned byte ('>B', b'\xff')
#
# Inverse of the pack above; verifies round-trip symmetry for uint8 max.
# struct.zspec.zsdl has unpack for H/I/Q/f/d/? but not B at max value.
# Result tuple (255,) is normalised to list [255] by the harness.
# ---------------------------------------------------------------------------

invariant struct_extra5.unpack.uint8_max:
  description: "struct.unpack('>B', b'\\xff') == (255,) — decoded as [255] after normalisation"
  category: unpack_values
  kind: python_call_eq
  function: unpack
  args: [">B", !hex ff]
  expected: [255]

# ---------------------------------------------------------------------------
# calcsize() — unsigned byte format 'B'
#
# struct.zspec.zsdl covers calcsize for H/I/Q/f/d/?/e; struct_extra2 adds
# HI/HIQ/q/h/b/?/e; struct_extra3 adds !5s/!3p/!x/!5x; struct_extra4 adds
# >i/<i/>I. The 'B' format (unsigned byte, 1 byte) has not appeared in any
# calcsize table.
# ---------------------------------------------------------------------------

table struct_extra5.calcsize.byte_formats:
  kind: python_call_eq
  category: calcsize
  function: calcsize
  id_prefix: calcsize

  columns: [id, args, expected]
  rows:
    - [big_B,    [">B"],  1]
    - [little_B, ["<B"],  1]
    - [big_5s,   [">5s"], 5]

# ---------------------------------------------------------------------------
# Struct('>I').pack(256) via table method form
#
# struct_extra4 covers pack('>I', 65536) and pack('<I', 65536) as module-level
# calls. This invariant verifies the equivalent Struct instance method form for
# a different value (256 == 0x100), confirming method dispatch on Struct objects.
# The harness table form uses: function: Struct, args: [">I"], method: pack,
# method_args: [256].
# ---------------------------------------------------------------------------

invariant struct_extra5.Struct.pack_method_uint32_256:
  description: "struct.Struct('>I').pack(256) == b'\\x00\\x00\\x01\\x00' — Struct instance pack method"
  category: struct_method
  kind: python_call_eq
  function: Struct
  args: [">I"]
  method: pack
  method_args: [256]
  expected: !hex 00000100
