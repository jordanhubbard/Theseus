spec: re_extra2491
version: ">=3.9"
backend: python_module(re)

docs: https://docs.python.org/3/library/re.html

provenance:
  derived_from:
    - "https://docs.python.org/3/library/re.html — Python re module documentation"
    - "Test vectors verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13"
  not_derived_from:
    - "CPython source: Modules/_sre.c"
    - "CPython source: Lib/re/__init__.py"
  notes:
    - "Theme: __setitem__, __delitem__, and __missing__ dict-presence — checking whether re classes define mutable item access and missing-key protocol in their class __dict__."
    - "re.Match defines __getitem__ (True) for group access via match[group], but NOT __setitem__ — matches are immutable."
    - "re.Match.__dict__.__contains__('__getitem__') is True — Match supports read-only subscript access to named/numbered groups."
    - "re.Match.__dict__.__contains__('__setitem__') is False — matches are immutable; you cannot assign to match[group]."
    - "re.Match.__dict__.__contains__('__delitem__') is False — item deletion is not supported on Match objects."
    - "re.Match.__dict__.__contains__('__missing__') is False — Match has no missing-key fallback protocol."
    - "re.Pattern.__dict__.__contains__('__setitem__') is False — compiled patterns are immutable."
    - "re.Pattern.__dict__.__contains__('__delitem__') is False — item deletion is not supported on Pattern objects."
    - "re.Pattern.__dict__.__contains__('__missing__') is False — Pattern has no missing-key protocol."
    - "re.Pattern.__dict__.__contains__('__getitem__') is False — Pattern does not support subscript access at all."
    - "Asymmetry: re.Match has __getitem__ (read-only group access) but no __setitem__ or __delitem__; re.Pattern has neither."
    - "Accessing '__setitem__' via re.Match.__dict__.__getitem__ raises KeyError — the key is genuinely absent."
    - "re.Match.__dict__ DOES contain 'group', 'groups', 'groupdict', 'start', 'end', 'span', 'expand' — the match API."
    - "re.Pattern.__dict__ DOES contain 'match', 'search', 'findall', 'finditer', 'sub', 'subn', 'split', 'pattern', 'flags' — the pattern API."
    - "All expected values verified with Python 3.14.4 on macOS/Darwin 25.4.0, 2026-04-13."
  created_at: "2026-04-13"

error_model: python_exceptions

# ---------------------------------------------------------------------------
# re.Match.__dict__ — mutable item access protocol absence
#
# re.Match defines __getitem__ for read-only group access (match[0], match['name']),
# but matches are immutable — __setitem__, __delitem__, and __missing__ are all
# absent from Match.__dict__. This asymmetry is intentional and documented.
# ---------------------------------------------------------------------------

table re_extra2491.Match_mutable_item_absence:
  description: "re.Match.__dict__ does not contain __setitem__, __delitem__, or __missing__ — matches are immutable despite having __getitem__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: re2491

  columns: [id, function, args, expected]
  rows:
    - ["re2491001", Match.__dict__.__contains__, ["__setitem__"], false]
    - ["re2491002", Match.__dict__.__contains__, ["__delitem__"], false]
    - ["re2491003", Match.__dict__.__contains__, ["__missing__"], false]
    - ["re2491004", Match.__dict__.__contains__, ["__getitem__"], true]

# ---------------------------------------------------------------------------
# re.Match.__dict__ — match API methods that ARE present
# group, groups, start, end, span, expand are defined directly on Match,
# contrasting with the absent mutable-mapping protocol entries.
# ---------------------------------------------------------------------------

table re_extra2491.Match_api_method_presence:
  description: "re.Match.__dict__ contains its match API: group, groups, groupdict, start, end, span, expand"
  kind: python_call_eq
  category: dict_membership
  id_prefix: re2491

  columns: [id, function, args, expected]
  rows:
    - ["re2491005", Match.__dict__.__contains__, ["group"],     true]
    - ["re2491006", Match.__dict__.__contains__, ["groups"],    true]
    - ["re2491007", Match.__dict__.__contains__, ["groupdict"], true]
    - ["re2491008", Match.__dict__.__contains__, ["start"],     true]
    - ["re2491009", Match.__dict__.__contains__, ["end"],       true]
    - ["re2491010", Match.__dict__.__contains__, ["span"],      true]
    - ["re2491011", Match.__dict__.__contains__, ["expand"],    true]

# ---------------------------------------------------------------------------
# re.Match.__dict__.__getitem__ — KeyError for mutable-item protocol keys
# Accessing an absent key via __getitem__ raises KeyError, consistent with
# mappingproxy semantics. Confirms __setitem__/__delitem__ are genuinely absent.
# ---------------------------------------------------------------------------

table re_extra2491.Match_dict_getitem_raises:
  description: "re.Match.__dict__.__getitem__ raises KeyError for __setitem__, __delitem__, __missing__"
  kind: python_call_raises
  category: dict_membership
  id_prefix: re2491

  columns: [id, function, args, expected]
  rows:
    - ["re2491012", Match.__dict__.__getitem__, ["__setitem__"], KeyError]
    - ["re2491013", Match.__dict__.__getitem__, ["__delitem__"], KeyError]
    - ["re2491014", Match.__dict__.__getitem__, ["__missing__"], KeyError]

# ---------------------------------------------------------------------------
# re.Pattern.__dict__ — mutable item access and item access protocol absence
#
# re.Pattern defines no __getitem__, __setitem__, __delitem__, or __missing__.
# Compiled patterns expose no subscript interface at all — they are accessed
# solely through their method API (match, search, findall, etc.).
# ---------------------------------------------------------------------------

table re_extra2491.Pattern_item_protocol_absence:
  description: "re.Pattern.__dict__ does not contain __setitem__, __delitem__, __missing__, or __getitem__"
  kind: python_call_eq
  category: dict_membership
  id_prefix: re2491

  columns: [id, function, args, expected]
  rows:
    - ["re2491015", Pattern.__dict__.__contains__, ["__setitem__"], false]
    - ["re2491016", Pattern.__dict__.__contains__, ["__delitem__"], false]
    - ["re2491017", Pattern.__dict__.__contains__, ["__missing__"], false]
    - ["re2491018", Pattern.__dict__.__contains__, ["__getitem__"], false]
    - ["re2491019", Pattern.__dict__.__contains__, ["match"],       true]
    - ["re2491020", Pattern.__dict__.__contains__, ["search"],      true]
    - ["re2491021", Pattern.__dict__.__contains__, ["findall"],     true]
    - ["re2491022", Pattern.__dict__.__contains__, ["pattern"],     true]
    - ["re2491023", Pattern.__dict__.__contains__, ["flags"],       true]
